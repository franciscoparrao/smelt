@article{ WOS:001561383300002,
Author = {Verma, Jyoti and Bhandari, Abhinav and Snehi, Manish and Snehi, Pratham},
Title = {Integrating neural networks and spark for cloud security: A unified
   dataset approach to network intrusion detection},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2025},
Volume = {160},
Number = {C},
Month = {NOV 27},
Abstract = {The heterogeneous network traffic from Internet of Things (IoT) devices
   and sophisticated computing infrastructure have enabled attackers to
   employ cutting-edge technology to exploit the advanced cloud
   infrastructure. Hence, the focus of research has drifted toward
   developing high-performance Network Intrusion Detection Systems (NIDS)
   to ensure the integrity of cloud systems and defend against
   cyber-attacks. However, the unavailability of a universal dataset
   encapsulating multifarious attack scenarios, the absence of thorough
   validation techniques, and an inadequate discourse on the deployment
   architecture collectively present an impediment. The research offers a
   five-stage framework for constructing a high-performance cloud-based
   NIDS. The proposed framework involves preparing a unified dataset
   covering various attack scenarios and adapting multiple feature
   selection techniques. Further, the experiment performs a comprehensive
   validation by employing diverse deep learning techniques (Artificial
   Neural Networks, Long Short-Term Memory, and Auto Encoders) to assess
   the efficacy of each feature set derived from the feature selection
   techniques. Finally, the paper deploys the model that yields the highest
   accuracy onto the Spark cluster for real-time volumetric network
   traffic. The multidimensional feature selection drops the number of
   employed features by 77 \%. Experiment results indicate a high accuracy
   of 99.34 percent for Artificial Neural Networks implemented on top of a
   Random Forest feature set for binary classification and 99.76 percent
   for Analysis of Variance (ANOVA) features for multi-class
   classification. Whereas Long Short Term Memory model showed an accuracy
   of 99.62 \% and Auto Encoder has accuracy of 99.50 \%. The article
   presents a thorough performance analysis of the Spark-based design on
   the Docker cluster at Amazon Web Services.},
Type = {Article},
Affiliation = {Bhandari, A (Corresponding Author), Punjabi Univ, Comp Sci \& Engn, Patiala, Punjab, India.
   Verma, Jyoti; Bhandari, Abhinav, Punjabi Univ, Comp Sci \& Engn, Patiala, Punjab, India.
