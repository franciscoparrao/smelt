}

@article{ WOS:001538752800001,
Author = {Teodoro, Douglas and Naderi, Nona and Yazdani, Anthony and Zhang, Boya
   and Bornet, Alban},
Title = {A scoping review of artificial intelligence applications in clinical
   trial risk assessment},
Journal = {NPJ DIGITAL MEDICINE},
Year = {2025},
Volume = {8},
Number = {1},
Month = {JUL 30},
Abstract = {Artificial intelligence (AI) is increasingly applied to clinical trial
   risk assessment, aiming to improve safety and efficiency. This scoping
   review analyzed 142 studies published between 2013 and 2024, focusing on
   safety (n = 55), efficacy (n = 46), and operational (n = 45) risk
   prediction. AI techniques, including traditional machine learning, deep
   learning (e.g., graph neural networks, transformers), and causal machine
   learning, are used for tasks like adverse drug event prediction,
   treatment effect estimation, and phase transition prediction. These
   methods utilize diverse data sources, from molecular structures and
   clinical trial protocols to patient data and scientific publications.
   Recently, large language models (LLMs) have seen a surge in
   applications, featuring in 7 out of 33 studies in 2023. While some
   models achieve high performance (AUROC up to 96\%), challenges remain,
   including selection bias, limited prospective studies, and data quality
   issues. Despite these limitations, AI-based risk assessment holds
   substantial promise for transforming clinical trials, particularly
   through improved risk-based monitoring frameworks.},
Type = {Article},
Affiliation = {Teodoro, D (Corresponding Author), Univ Geneva, Fac Med, Dept Radiol \& Med Informat, Geneva, Switzerland.
   Teodoro, Douglas; Yazdani, Anthony; Zhang, Boya; Bornet, Alban, Univ Geneva, Fac Med, Dept Radiol \& Med Informat, Geneva, Switzerland.
