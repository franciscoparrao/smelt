}

@article{ WOS:001591309000001,
Author = {Ben Hamida, Mohamed Bechir and Rasheed, Rassol Hamed and Alizadeh, As'ad
   and Singh, Narinderjit Singh Sawaran and Chamkha, Ali},
Title = {Intelligent design framework for finned solar air heaters: A synergy
   between PSO/GA-tuned MLPNN and multi-objective crystal structure
   algorithm (MOCryStAl)},
Journal = {INTERNATIONAL COMMUNICATIONS IN HEAT AND MASS TRANSFER},
Year = {2025},
Volume = {169},
Number = {C},
Month = {DEC},
Abstract = {Solar air heaters (SAHs) are widely used in renewable thermal systems,
   but their performance is often limited by the trade-off between
   heat-transfer enhancement and pumping power. This persistent challenge
   highlights the need for integrated approaches that can simultaneously
   predict performance, optimize geometry, and support design decisions.
   This study proposes a four-stage, data-driven framework that unifies
   machine-learning modeling, metaheuristic multi-objective optimization,
   and multi-criteria decision analysis to systematically design finned
   SAHs. CFD simulation data were used to train a multilayer perceptron
   neural network, with hyperparameters tuned by particle swarm
   optimization (PSO) and genetic algorithm (GA). The most accurate
   surrogate model was coupled with the multi-objective crystal structure
   algorithm (MOCryStAl) and compared against NSGA-II to generate diverse
   Pareto-optimal solutions. Subsequently, the TOPSIS method was applied to
   evaluate design scenarios under ten distinct priority weightings.
   Results showed that the PSO-based model accurately predicted thermal and
   hydraulic metrics (R > 0.99), while GA was more effective for friction
   factor modeling (R approximate to 0.999). NSGA-II achieved complete
   frontier coverage and revealed a spectrum of optimal designs ranging
   from low-drag to high-transfer configurations. Decision analysis
   indicated that optimal fin geometries vary significantly with
   performance priorities, though some compact-fin designs remained
   consistently favorable. The proposed framework offers a robust,
   computationally efficient pathway for tailoring high-performance SAHs to
   diverse operational needs in real-world solar applications.},
Type = {Article},
Affiliation = {Ben Hamida, MB (Corresponding Author), Imam Mohammad Ibn Saud Islamic Univ IMSIU, Deanship Sci Res, Riyadh, Saudi Arabia.
   Alizadeh, A (Corresponding Author), Cihan Univ Erbil, Coll Engn, Dept Civil Engn, Erbil, Iraq.
