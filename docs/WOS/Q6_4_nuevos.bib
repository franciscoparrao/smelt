}

@article{ WOS:001697950200001,
Author = {Yang, Yujuan and Huang, Qiuhong and Li, Shuhua and Du, Juanjuan and
   Ming, Zhongyuan and Li, Heguo and Liang, Hong and Ma, Kaikai and Gong,
   Lintao and Lin, Yingtong and Zhao, Yue and Wu, Yufang and Qiao, Zhiwei},
Title = {Pore topology fingerprints and big-data mining to accelerate the design
   of high-performance metal-organic frameworks},
Journal = {CHEMICAL ENGINEERING SCIENCE},
Year = {2026},
Volume = {327},
Month = {JUN 1},
Abstract = {For the combination of big data mining and high-performance porous
   materials, it is necessary to establish the accurate descriptors,
   especially when it comes to capturing the pore topology of crystalline
   materials. This study developed persistent homology-based topology
   fingerprints for metal-organic frameworks (MOFs) and automated software
   to generate topological fingerprints. An Machine learning-based strategy
   was primarily applied to screen MOFs with high adsorption properties for
   xylenes from a database of 137,953 hypothetical MOFs. The approach was
   then extended to two additional systems (methane/ethane/propane, and
   chemical warfare agents) to demonstrate its universality. By
   incorporating topology fingerprints, the model accuracy (R2) was
   improved from 0.7798 to 0.9205, and the generality was validated.
   Topology fingerprints identified beneficial pore shapes, sizes, and
   interpenetration, with rhombic pores being particularly effective for
   xylene separation. This method offers a new approach for designing
   high-performance MOFs by focusing on pore topology.},
