@article{ WOS:001613098200002,
Author = {Zheng, Rongrong and Liang, Boyang and Huo, Wenjia and Wu, Xiang and Bai,
   Yaoyao},
Title = {Machine learning-driven design of polyimides with tailored dielectric
   constants},
Journal = {COMPUTATIONAL MATERIALS SCIENCE},
Year = {2026},
Volume = {262},
Month = {JAN 30},
Abstract = {With the development of data-driven technology, machine learning (ML)
   can facilitate performance prediction and structural design of polyimide
   (PI). We established a dataset containing 990 structure-dielectric
   constant (DC) data, encoded molecular structures as SMILES notations,
   and extracted substructure-based Morgan fingerprints. Redundant Morgan
   fingerprints were eliminated through multiple feature selection methods,
   followed by implementing five ML algorithms to develop DC quantitative
   structure-property relationship (DC-QSPR) models. Bayesian optimization
   was employed for parameter optimization. The optimized ML model
   demonstrated excellent performance, with the determination coefficient
   of 0.895 on the test set. SHAP analysis identified methylene groups and
   fluorinated moieties as the critical factors influencing DC. Five
   designed PI structures were calculated by Molecular dynamics (MD)
   simulations to verify predictive performance of the ML-model. The
   proposed DC-QSPR framework in this work provides a computation-driven
   pipeline for the rapid discovery of high-performance dielectric
   polymers, offering direct implications for flexible electronics and
   energy storage applications.},
