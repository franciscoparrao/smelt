   Alnaser, Ali S., Amer Univ Sharjah, Coll Arts \& Sci, Dept Phys, Sharjah 26666, U Arab Emirates.},
DOI = {10.1016/j.rser.2026.116750},
EarlyAccessDate = {MAY 2026},
