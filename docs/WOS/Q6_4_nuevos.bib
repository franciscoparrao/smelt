@article{ WOS:001693050200006,
Author = {Zhao, Fen and Chen, Jie and Zhang, Yuqing and Ren, Dengling and Li,
   Yanmei and Yang, Junbo},
Title = {Long-Wave Infrared High-Efficiency Metalens and Enhanced Imaging},
Journal = {ACTA OPTICA SINICA},
Year = {2026},
Volume = {46},
Number = {2},
Month = {JAN},
Abstract = {Objective With the widespread application of long-wave infrared
   lightweight detection systems in military, security, environmental
   monitoring, and other fields, the demand for high-performance metalenses
   has become increasingly urgent. However, the design of metalenses faces
   the complex challenge of high degrees of freedom and multi-parameter
   optimization. Traditional optimization methods, such as genetic
   algorithms and particle swarm optimization, are inefficient in exploring
   complex design spaces and are limited in design dimensions, making it
   difficult to meet practical requirements. Although existing machine
   learning methods have made some progress, they are restricted by the
   dependency on training data and computational efficiency, and are unable
   to achieve efficient and intelligent design optimization. In this paper,
   a deep reinforcement learning (DRL) framework based on the deep Qnetwork
   (DQN) is utilized. By constructing a ``state-action-reward{''}
   optimization mechanism, intelligent design of metalens structures is
   realized. Not only does this study achieve high-efficiency focusing
   through DRL optimization of binary phase metalenses, but it also
   introduces vortex phase on this basis. By altering the spin state of the
   incident light, dual-mode functionality of bright-field imaging and edge
   enhancement is realized on an eight-value phase metalens. Combined with
   image fusion technology, the recognizability of targets is effectively
   improved, providing a new solution for high-precision target recognition
   in long-wave infrared systems and significantly enhancing the
   application capability of long-wave infrared detection systems in
   complex scenarios. Methods Silicon nanorods were employed as the
   meta-atom building blocks in this study. Initially, a database of
   nanorod phase-amplitude containing 13000 samples was established through
   finite-difference time-domain (FDTD) simulations, providing fundamental
   data support for subsequent designs. Based on the DQN reinforcement
   learning framework, a ``state-action-reward{''} optimization mechanism
   was constructed. For the operating wavelength of 10.6 \& micro;m, a
   binary phase high-efficiency metalens was initially designed. The
   annular structure of the metalens was transformed into the state space
   of a Markov decision process, with nanorod phase switching defined as
   discrete actions. The intensity at the focal plane, calculated using the
   vector angular spectrum diffraction method, was employed as the reward
   function. During the training process, an experience replay buffer (with
   a capacity of 106) and an epsilon-greedy strategy (exploration rate
   decaying from 0.99 to 0.01) were utilized. The Bellman equation
   optimization was achieved through a dual-neural-network architecture
   (Q-network and target network), ultimately yielding the optimal phase
   distribution. To verify the universality of the method, an eight-value
   phase dual-mode metalens was further designed. Eight types of
   rectangular nanorods were selected to construct a half-wave plate unit
   library. By combining the principles of propagation phase and geometric
   phase, seamless switching between bright-field imaging and edge imaging
   modes could be realized simply by adjusting the spin state of the
   illumination light. The phase distribution optimized by DRL was used as
   the phase for the bright-field imaging mode, further enhancing the
   imaging performance.
   Finally, image deblurring was performed using Wiener filtering, and
   target recognizability was improved through image fusion technology,
   providing strong support for high-precision target recognition in
   long-wave infrared systems. Through the aforementioned research, not
   only was the design of high-efficiency metalenses successfully realized,
   but the imaging performance was also significantly enhanced. The
   powerful potential and broad application prospects of deep reinforcement
   learning in complex optical design were demonstrated. Results and
   Discussions The design of a high-efficiency binary phase metalens is
   successfully accomplished in this study. Compared with the hyperbolic
   metalens, the metalens designed by DRL achieved a tightly focused spot
   without scattering in the propagation plane. The full width at half
   maximum (FWHM), focal spot intensity, and focusing efficiency of
   different metalenses are shown in Fig. 3(c). When the amplitude values
   of the two nanorods are relatively high and the difference between them
   is small, the metalens designed by DRL exhibits a higher focusing
   efficiency, approximately 0.2 \% higher, and a stronger focal spot
   intensity, about 16.68 \% higher. The Strehl ratio of the DRL-designed
   metalens is 72.9 \%. When the amplitude values of the two nanorods are
   relatively low and the difference between them is large, compared with
   the traditional hyperbolic binary phase metalens, the DRL-designed
   metalens shows an increase in focusing efficiency by 4.8 \% and an
   enhancement in focal spot intensity by 36.5 \%. The Strehl ratio of the
   DRL-designed metalens is 49.6 \% (Fig. 3). To demonstrate the
   adaptability and scalability of DRL, a high-efficiency eight-value phase
   metalens is further designed. Compared with the traditional hyperbolic
   phase distribution, the focusing efficiency is improved by 7.8 \%, and
   the focal spot intensity is enhanced by 3.1 \%. Based on this, vortex
   phase is introduced (Fig. 4), and bright-field and edge-enhanced imaging
   are realized by altering the spin state of the incident light. Figure 5
   presents the fused image of bright-field imaging and clear edge imaging,
   which significantly enhances the key features such as the shape and
   boundary of the target. Compared with the bright-field image, the fused
   image makes the target boundary clearer and more prominent, increases
   the contrast between the target and the background, thereby effectively
   improving the recognizability and locatability of the target and
   providing strong support for subsequent image analysis and processing
   tasks. Conclusions DRL framework utilizing a DQN for the design of
   metalenses is proposed in this paper. Initially, a high-efficiency
   binary phase metalens with a radius of 1001 and a focal length of 50
   lambda is successfully designed. An optimization mechanism based on
   ``state-action-reward{''} is established, and through continuous policy
   updates, the optimal structural arrangement of the metalens is learned.
   For combinations of nanorods with phase differences close to pi and
   large amplitude differences, a 4.8 \% improvement in focusing efficiency
   and a 36.5 \% increase in light intensity are achieved by the designed
   metalens compared to traditional hyperbolic binary phase metalenses.
   Furthermore, the method is extended to the design of larger-sized
   multifunctional metalenses. A high-efficiency eight-value phase
   dual-mode metalens with a radius of 5601 and a focal length of 11101 is
   realized. Under illumination with left-circularly polarized (LCP) light,
   this metalens demonstrates a 7.
   8 \% improvement in focusing efficiency and a 3.1 \% increase in light
   intensity compared to traditional hyperbolic eight-value phase
   metalenses. Dual-functional imaging based on the spin state of the
   incident light is achieved by introducing an additional vortex phase
   with topological charge +1, through the combination of geometric and
   propagation phase designs. The final results confirmed that the
   recognizability of targets is effectively enhanced by this method. In
   the next step, a high-efficiency achromatic metalens for long-wave
   infrared applications will be designed using three-bit binary encoding.
   Systematic exploration of the design of multi-phase, multi-wavelength,
   and multifunctional metalenses will continue, with the aim of exploring
   innovative optimization pathways and significantly improving device
   performance. Therefore, DRL is expected to become a key tool for optical
   design and optimization.},
Type = {Article},
Affiliation = {Yang, JB (Corresponding Author), Natl Univ Def Technol, Ctr Mat Sci, Changsha 410073, Hunan, Peoples R China.
   Zhao, Fen; Chen, Jie; Ren, Dengling; Li, Yanmei, Chongqing Univ Technol, Sch Artificial Intelligence, Chongqing 401135, Peoples R China.
   Zhang, Yuqing, Southwest Univ, Sch Phys Sci \& Technol, Chongqing 400715, Peoples R China.
   Yang, Junbo, Natl Univ Def Technol, Ctr Mat Sci, Changsha 410073, Hunan, Peoples R China.},
Keywords = {high-efficiency metalens; deep reinforcement learning; deep Q-network;
   bifunctional imaging},
Keywords-Plus = {DEEP NEURAL-NETWORKS; INVERSE DESIGN; METASURFACES; ALGORITHM},
Author-Email = {yangjunbo@nudt.edu.cn},
Number-of-Cited-References = {54},
Times-Cited = {0},
Unique-ID = {WOS:001693050200006},
}

@article{ WOS:001700001000001,
Author = {Rookard, Curtis},
Title = {SpIDER: Space Satellite Intrusion Detection Using Explainable
   Reinforcement Learning for Next-Generation Satellite Communication
   Networks},
Journal = {TELECOM},
Year = {2026},
Volume = {7},
Number = {1},
Month = {JAN 1},
Abstract = {Space and satellite-based systems have had a monumental impact on
   providing greater interconnectivity across the world. The usage of space
   and satellite-based systems has increased the ability to access internet
   resources even in remote areas. Unfortunately, these systems are subject
   to malicious and multi-faceted cyberattacks. Therefore, proper threat
   detection systems must be implemented to safeguard these space systems.
   In our study, we present our novel intrusion detection framework,
   SpIDER, a space satellite intrusion detection system using explainable
   reinforcement learning. SpIDER leverages the benefits offered by
   reinforcement learning and Shapley additive global explanations to
   improve both the performance and explainability of space-based intrusion
   detection. We compare our SpIDER framework to several popular machine
   learning algorithms using the STIN and NSL-KDD datasets. We observe that
   our SpIDER framework achieves high performance, with accuracy and G-Mean
   above 99.98\% on the STIN satellite dataset. SpIDER also outperforms
   other machine learning models on the NSL-KDD local area network dataset,
   achieving accuracy of 76.71\% and a G-Mean of 80.49\%. These results
   demonstrate that our SpIDER explainable deep reinforcement learning
   framework can perform as well or better than supervised machine learning
   models on both satellite-style and local area network data.},
Type = {Article},
Affiliation = {Rookard, C (Corresponding Author), Indian River State Coll, Dept Comp Informat Technol, Ft Pierce, FL 34981 USA.
   Rookard, Curtis, Indian River State Coll, Dept Comp Informat Technol, Ft Pierce, FL 34981 USA.},
DOI = {10.3390/telecom7010003},
Article-Number = {3},
Keywords = {intrusion detection system; satellite-terrestrial integrated network;
   reinforcement learning; deep Q-learning; shapley additive global
   explanations; cybersecurity},
Author-Email = {crookard@irsc.edu},
Number-of-Cited-References = {25},
Times-Cited = {0},
Unique-ID = {WOS:001700001000001},
}

@article{ WOS:001701542100001,
Author = {Xu, Shengzhi and Li, Ming and Shen, Yuxin and Chen, Huimin and
   Taiwaikuli, Nuerbiye},
Title = {Research on Non⁃Line⁃of⁃Sight Free⁃Space Continuous⁃Variable Quantum Key
   Distribution Based on RIS⁃ATP Compensation},
Journal = {CHINESE JOURNAL OF LASERS-ZHONGGUO JIGUANG},
Year = {2026},
Volume = {53},
Number = {2},
Month = {JAN},
Abstract = {Objective In free-space continuous-variable quantum key distribution
   (CV-QKD) systems, line-of-sight (LoS) links are typically required to
   maintain a stable optical channel for secure quantum communication.
   However, practical deployment scenarios, such as urban environment
   communication, often involve dynamic obstacles and environmental factors
   that block direct paths between transmitter and receiver. These
   blockages, combined with the inevitable influence of atmospheric
   turbulence, significantly degrade the channel quality and limit the
   achievable secret key rate and secure communication distance. To address
   these challenges, this paper proposes a non-line-of-sight (NLoS) CV-QKD
   scheme enhanced by a reconfigurable intelligent surface (RIS) assisted
   acquisition, tracking, and pointing (ATP) system. The RIS serves as an
   adaptive optical relay to steer the quantum signals toward the receiver
   while actively compensating for beam wandering caused by atmospheric
   turbulence. This approach enables robust quantum key distribution in
   environments where traditional LoS-based systems would fail. Methods The
   proposed system architecture models the NLoS link as a two-hop channel:
   Alice sends Gaussian-modulated coherent states toward a programmable
   RIS, which applies a spatially varying phase shift to reflect the
   signals toward Bob. The RIS not only redirects the propagation direction
   and focuses the beam but also serves as an adaptive optical element
   capable of ATP compensation. To simulate realistic free-space channel
   conditions, atmospheric turbulence is modeled using a sparse-spectrum
   phase screen method that samples the spatial frequency domain to model
   wavefront distortion. The distorted phase profiles are then propagated
   via a split-step beam propagation algorithm to evaluate their cumulative
   effect on optical signal degradation. The model incorporates key
   parameters including Rytov parameter to characterize turbulence
   intensity, receiver aperture radius, beam waist radius, and turbulence
   channel length. The CV-QKD protocol adopted is the Gaussian-modulated
   coherent state protocol with homodyne detection (GG02), and the secure
   key rate is calculated under the assumption of collective Gaussian
   attacks, incorporating reconciliation efficiency and excess noise.
   Numerical simulations are conducted for a range of transmission
   distances (500-1500 m) and receiver aperture radii (0.01 -0.10 m), both
   with and without RIS-ATP compensation. It is noteworthy that the
   simulation assumes that the RIS-ATP system tracks the beam perfectly.
   Results and Discussions According to the proposed theoretical model and
   under specific simulation parameters, the following simulations are
   carried out: the probability density function of turbulence-induced
   transmittance before and after ATP compensation (Fig. 3), the
   relationship between secret key rate and turbulence channel length
   before and after compensation for different aperture radii (Fig. 4), and
   the influence of aperture radius on secret key rate (Fig. 5). It can be
   seen from Fig. 3 that the sparse spectrum model for the phase-screen
   method integrating the split-step propagation method is effective in
   accurately capturing the statistical characteristics of
   turbulence-induced fading under moderate turbulence condition (Rytov
   parameter between 1 and 10). For a representative case of 750 m
   turbulence channel length and a receiver aperture radius of 0.04 m, the
   average transmittance of the quantum channel increases by 22.69\% due to
   ATP compensation.
   This improvement leads to a substantial gain in the secret key rate,
   which increases by 64\% compared to the uncompensated scenario shown in
   Fig. 5. Furthermore, according to Fig. 4, for systems with restricted
   receiver apertures, the RIS-ATP scheme provides an effective secure
   distance gain of approximately 100 m. The enhancement is particularly
   valuable in mobile or temporary quantum communication setups where
   hardware limitations impose trade-offs between size and performance.
   Moreover, an important observation from the simulation is the nonlinear
   inverse correlation between ATP compensation gain and receiver aperture
   radius. As the aperture radius increases, the relative performance gain
   of secret key rate decreases, dropping to 0 at a receiver aperture
   radius of 0.1 m, as shown in Fig. 5. The results reveal that when the
   aperture is small, the beam wandering induced by turbulence leads to
   significant energy loss and significant orthogonal component
   interference at the receiver. In such cases, ATP compensation
   substantially enhances beam alignment, thereby recovering signal power
   and reducing excess noise. However, as the receiver aperture radius
   increases, the receiver's inherent spatial filtering capability allows
   it to tolerate beam displacement more effectively. As a result, the
   marginal benefit of ATP compensation gradually diminishes. This
   indicates that in large-aperture configurations, the RIS-ATP system
   reaches performance saturation and its added value becomes marginal.
   Conclusions This work propose a CV-QKD system based on RIS-ATP
   compensation which effectively addresses the dual challenges of
   geometric blockage and turbulence-induced fading. By integrating RIS
   technology with an adaptive ATP mechanism, the proposed architecture
   enables stable, high-performance quantum key distribution in scenarios
   where direct LoS is unavailable. The simulation framework accurately
   models the propagation of quantum optical beams through turbulent media
   and quantitatively evaluates the benefits of ATP compensation across a
   range of system configurations. Key findings demonstrate that ATP
   compensation is particularly beneficial for small-aperture systems
   operating under moderate turbulence, resulting in significant
   improvements in transmittance, key rate, and secure communication
   distance. For larger-aperture receivers, however, the performance gain
   from ATP compensation diminishes, suggesting that complementary
   approaches, such as high-speed wavefront sensing, machine learning-based
   adaptive optics, or spatial-mode multiplexing may be required to further
   enhance system robustness. Overall, the RIS-ATP scheme offers a
   practical and scalable solution for extending the operational range and
   reliability of free-space CV-QKD systems in complex and obstructed
   environments.},
Type = {Article},
Affiliation = {Li, M (Corresponding Author), Tianjin Normal Univ, Coll Elect \& Commun Engn, Tianjin 300387, Peoples R China.
   Li, M (Corresponding Author), Tianjin Normal Univ, Tianjin Key Lab Wireless Mobile Commun \& Power Tra, Tianjin 300387, Peoples R China.
   Xu, Shengzhi; Li, Ming; Shen, Yuxin; Chen, Huimin; Taiwaikuli, Nuerbiye, Tianjin Normal Univ, Coll Elect \& Commun Engn, Tianjin 300387, Peoples R China.
   Xu, Shengzhi; Li, Ming; Shen, Yuxin; Chen, Huimin; Taiwaikuli, Nuerbiye, Tianjin Normal Univ, Tianjin Key Lab Wireless Mobile Commun \& Power Tra, Tianjin 300387, Peoples R China.},
DOI = {10.3788/CJL250757},
Article-Number = {0212001},
Keywords = {quantum optics; free space; non-line-of-sight; continuous-variable
   quantum key distribution; acquisition; tracking; pointing},
Keywords-Plus = {BEAMS},
Author-Email = {mingli@tjnu.edu.cn},
Number-of-Cited-References = {36},
Times-Cited = {0},
Unique-ID = {WOS:001701542100001},
}

@article{ WOS:001696503700001,
Author = {Nian, Yingpu and Yi, Bo and He, Qiang and Wang, Xingwei and Min, Geyong
   and Li, Keqin and Das, Sajal K.},
Title = {PAHInA: Precision-Aware Hierarchical In-Network Aggregation for Edge
   Distributed Training},
Journal = {IEEE TRANSACTIONS ON NETWORKING},
Year = {2026},
Volume = {34},
Pages = {3319-3333},
Abstract = {The rise of edge intelligence is driving distributed machine learning
   toward a new paradigm of edge-collaborative computing. To overcome the
   severe communication bottleneck in this paradigm, In-Network Aggregation
   is a critical enabling technology. However, its effectiveness is
   fundamentally undermined by the profound resource heterogeneity of edge
   networks. Specifically, edge devices, adapting to hardware constraints,
   operate at varying numerical precisions, leading to significant data
   inflation as gradients are aggregated. Compounding this, unevenly
   distributed network resources and traditional, precision-oblivious
   routing strategies often misallocate critical, high-precision gradients
   to low-quality paths. This mismatch creates severe network congestion,
   crippling the efficiency of distributed training. To address this, we
   propose the Precision-Aware Hierarchical In-Network Aggregation (PAHInA)
   framework, the first, to our knowledge, to perform routing optimization
   for in-network aggregation that explicitly considers precision
   heterogeneity. The core of PAHInA is an intelligent control-plane
   scheduler that co-optimizes for gradient priority and path cost,
   dynamically planning the most cost-effective aggregation strategy for
   each flow. This fine-grained scheduling guarantees that high-priority
   gradients are routed through premium, low-latency paths, minimizing
   global communication overhead. On the data plane, we leverage the
   eXpress Data Path (XDP) for high-performance packet processing to reduce
   aggregation-induced overhead. Extensive simulations show that, compared
   to state-of-the-art baselines, PAHInA significantly mitigates network
   congestion, reducing end-to-end communication time by up to 33\% and
   boosting overall training throughput by approximately 30\%.},
Type = {Article},
Affiliation = {Yi, B; Wang, XW (Corresponding Author), Northeastern Univ, Coll Comp Sci \& Engn, Shenyang 110169, Peoples R China.
   Nian, Yingpu; Yi, Bo; He, Qiang; Wang, Xingwei, Northeastern Univ, Coll Comp Sci \& Engn, Shenyang 110169, Peoples R China.
   Yi, Bo, Guangdong Lab Artificial Intelligence \& Digital Ec, Shenzhen 518000, Peoples R China.
   Min, Geyong, Univ Exeter, Dept Comp Sci, Exeter EX4 4QF, England.
   Li, Keqin, SUNY Coll New Paltz, Dept Comp Sci, New Paltz, NY 12561 USA.
   Das, Sajal K., Missouri Univ Sci \& Technol, Dept Comp Sci, Rolla, MO 65409 USA.},
DOI = {10.1109/TON.2026.3660333},
Keywords = {Training; Routing; Servers; Data centers; Computational modeling;
   Computer architecture; Peer-to-peer computing; Optimization; Computer
   science; Topology; Edge computing; distributed training; heterogeneous
   precision; in-network aggregation; XDP},
Author-Email = {nianpupu0124@gmail.com
