   Alammar, Ammar, King Saud Univ, Dept Architecture \& Bldg Sci, Riyadh 145111, Saudi Arabia.},
DOI = {10.3390/buildings15183256},
Article-Number = {3256},
Keywords = {machine learning for energy analysis; graph machine learning; deep graph
   learning (DGL); building energy simulation (BES); heating and cooling
   loads},
Keywords-Plus = {DECISION-TREE; CONSUMPTION; PREDICTION; REGRESSION; SIMULATION},
