@article{ WOS:001589515400009,
Author = {Ji, Zhanlin and Guan, Hao and Wang, Meng and Li, Zeyu and Dong, Yingchao},
Title = {Polymeric membrane concentration of lithium-magnesium solution for
   sustainable resource recovery with machine learning},
Journal = {WATER RESEARCH},
Year = {2025},
Volume = {287},
Number = {B},
Month = {DEC 1},
Abstract = {It is crucial to efficiently recover high value sources from seawater
   and salt-lake brines for global sustainable development goals. However,
   conventional membrane-based recovery methods face some significant
   challenges such as insufficient membrane performance and unclear
   mechanism. To address this issue, we propose a machine learning-driven
   framework with various models to systematically optimize nanofiltration
   membrane performance and then elucidate the underlying mechanism at the
   structure-process-performance nexus. To understand how the membrane and
   process variables affect the performance, we integrate shapley additive
   explanations (SHAP) and partial dependence analysis. Interestingly, we
   find that steric hindrance effect plays a dominant role in separation
   performance, which is dependent by transmembrane pressure, molecular
   weight cut-off, and membrane surface roughness. Specifically, high
   performance such as water permeance and rejection can be achieved under
   the transmembrane pressures of 5-10 bar and surface roughness of 3.4-3.5
   nm. Through particle swarm optimization, a high water permeance of 15.12
   L \& sdot;m-2 \& sdot;h-1 could be achieved while retaining high Li+ and
   Mg2+ rejection. This work could hopefully advance membrane-based
   resource recovery by establishing a machine learning-driven paradigm for
   system optimization and mechanism understanding, thus offering a
   reliable path for furnishing some theoretical guidance in the field.},
Type = {Article},
Affiliation = {Dong, YC (Corresponding Author), Chinese Univ Hong Kong, Sch Sci \& Engn, Shenzhen 518172, Guangdong, Peoples R China.
   Ji, Zhanlin, Zhejiang A\&F Univ, Coll Math \& Comp Sci, Hangzhou 311300, Peoples R China.
   Guan, Hao; Wang, Meng; Li, Zeyu; Dong, Yingchao, Chinese Univ Hong Kong, Sch Sci \& Engn, Shenzhen 518172, Guangdong, Peoples R China.
   Guan, Hao; Wang, Meng, North China Univ Sci \& Technol, Coll Artificial Intelligence, Tangshan 063009, Peoples R China.},
DOI = {10.1016/j.watres.2025.124438},
EarlyAccessDate = {AUG 2025},
Article-Number = {124438},
Keywords = {Lithium resource recovery; Nanofiltration; Machine learning; Global
   optimization algorithm; Performance prediction},
Author-Email = {ycdong@cuhk.edu.cn},
Number-of-Cited-References = {73},
Times-Cited = {2},
Unique-ID = {WOS:001589515400009},
}

@article{ WOS:001564175400003,
Author = {Nachnani, Aditi and Li-Caldwell, Kai K. and Biswas, Saptarshi and
   Sharma, Prince and Ouyang, Gaoyuan and Singh, Prashant},
Title = {Interpretable machine learning-guided design of Fe-based soft magnetic
   alloys},
Journal = {PHYSICAL REVIEW MATERIALS},
Year = {2025},
Volume = {9},
Number = {8},
Month = {AUG 22},
Abstract = {We present a machine learning (ML) guided approach to predict saturation
   magnetization (MS) and coercivity (HC) in Fe-rich soft magnetic alloys,
   particularly Fe-Si-B systems. ML models trained on experimental data
   reveal that increasing Si and B content reduces MS from 1.81 T (DFT 2.04
   T) to 1.54 T (DFT 1.56 T) in Fe-Si-B, which is attributed to decreased
   magnetic density and structural modifications. Experimental validation
   of ML predicted magnetic saturation on Fe-1Si-1B (2.09 T), Fe-5Si-5B
   (2.01 T), and Fe-10Si-10B (1.54 T) alloy compositions further supports
   our findings. These trends are consistent with density functional theory
   predictions, which link increased electronic disorder and band
   broadening to lower MS values. Experimental validation on selected
   alloys confirms the predictive accuracy of the ML model, with good
   agreement across compositions. Beyond predictive accuracy, detailed
   uncertainty quantification and model interpretability including through
   feature importance and partial dependence analysis reveal that MS is
   governed by a nonlinear interplay between Fe content and early
   transition metal ratios, while HC is more sensitive to processing
   conditions such as ribbon thickness and thermal treatment windows. The
   ML framework was further applied to Fe-Si-B/Cr/Cu/Zr/Nb alloys in a
   pseudoquaternary compositional space, which shows comparable magnetic
   properties to NANOMET (Fe84.8Si0.5B9.4Cu0.8P3.5C1), FINEMET
   (Fe73.5Si13.5B9 Cu1Nb3), NANOPERM (Fe88Zr7B4Cu1), and HITPERM
   (Fe44Co44Zr7B4Cu1. Our findings demonstrate the potential of the ML
   framework for accelerated search of high-performance soft magnetic
   materials.},
Type = {Article},
Affiliation = {Singh, P (Corresponding Author), Iowa State Univ, Ames Natl Lab, US DOE, Ames, IA 50011 USA.
   Nachnani, Aditi; Li-Caldwell, Kai K.; Biswas, Saptarshi; Sharma, Prince; Ouyang, Gaoyuan; Singh, Prashant, Iowa State Univ, Ames Natl Lab, US DOE, Ames, IA 50011 USA.},
DOI = {10.1103/w6m3-ymsf},
Article-Number = {084411},
Keywords-Plus = {HIGH SATURATION MAGNETIZATION; TRANSITION-METAL ALLOYS; HIGH-B-S;
   CRYSTALLIZATION PROCESS; NANOCRYSTALLINE ALLOYS; TEMPERATURE-DEPENDENCE;
   FINEMET ALLOYS; CORE LOSS; ZR-B; MICROSTRUCTURE},
Author-Email = {psingh84@ameslab.gov},
Number-of-Cited-References = {129},
Times-Cited = {8},
Unique-ID = {WOS:001564175400003},
}

@article{ WOS:001562202900001,
Author = {Peng, Ligang and Miao, Xu and Zhu, Ji-Xiang and Zhang, Ming-Qi and
   Zheng, Xiao-Qing and Li, Heng-Yang and Wang, Yuzhou and Jiang, Xi and
   Huang, Bo-Tao},
Title = {Hybrid machine learning and multi-objective optimization for intelligent
   design of green and low-carbon concrete},
Journal = {SUSTAINABLE MATERIALS AND TECHNOLOGIES},
Year = {2025},
Volume = {45},
Month = {OCT},
Abstract = {The increasing utilization of recycled aggregates and supplementary
   cementitious materials in green and lowcarbon concrete production
   demands advanced methods to predict and optimize the performance, yet
   challenges remain in performance, sustainability, and cost trade-offs.
   In this study, a comprehensive database for recycled aggregate concrete
   using supplementary cementitious materials was established, and a hybrid
   framework integrating machine learning and multi-objective optimization
   was proposed. Results demonstrated that Sparrow Search Algorithm
   optimized models significantly outperformed base models, with Sparrow
   Search Algorithm-Extreme Gradient Boosting achieving superior accuracy
   with R2 values of 0.9403 for slump, 0.9428 for compressive strength,
   0.9017 for total charge passed. Shapley additive explanation analysis
   quantified feature contributions, revealing fly ash/superplasticizer
   dosage, effective water-binder ratio, and cement dosage as dominant
   factors for slump, compressive strength, and total charge passed,
   respectively. Furthermore, the advanced third-generation non-dominated
   sorting genetic algorithm and the technique for order of preference by
   similarity to ideal solution were integrated to optimize mix designs,
   balancing compressive strength, carbon emissions, and material costs.
   Sensitivity analysis highlighted the impacts of recycled aggregates and
   supplementary cementitious material replacement ratios, and
   transportation distances on performance, sustainability, and
   cost-effectiveness. This study is the establishment of this robust
   framework, which provides a systematic, data-driven roadmap for
   designing high-performance, low-carbon, and cost-effective concrete,
   thereby offering a viable pathway toward sustainable infrastructure.},
Type = {Article},
Affiliation = {Miao, X (Corresponding Author), Zhejiang Univ, Inst Struct Engn, Hangzhou, Peoples R China.
