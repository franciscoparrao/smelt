@article{ WOS:001548392400001,
Author = {Tan, Rui-Hao and Xie, Qing-Yu and Xiang, Fan and Zhang, Kai-Wang},
Title = {Four-phonon scattering-induced ultralow thermal conductivity in
   Ba3X2 (X = P, As) monolayers: promising
   high-performance thermoelectric candidates at room temperature},
Journal = {PHYSICAL CHEMISTRY CHEMICAL PHYSICS},
Year = {2025},
Volume = {27},
Number = {34},
Pages = {17970-17983},
Month = {AUG 28},
Abstract = {Two-dimensional thermoelectric materials hold great promise for
   efficient energy harvesting and self-powered electronic devices. In this
   study, we systematically investigate the thermoelectric properties of
   Ba3X2 (X = P, As) monolayers at 300 K by combining first-principles
   calculations with a machine-learning-assisted four-phonon scattering
   framework. The results reveal that Ba3X2 monolayers overcome the
   conventional limitation imposed by narrow band gaps and exhibit
   outstanding thermoelectric performance at room temperature.
   Specifically, both materials demonstrate excellent electron mobilities
   (similar to 104 cm2 V-1 s-1) and favorable power factors, reaching as
   high as 0.089 and 0.027 W m-1 K-2 for Ba3P2 and Ba3As2, respectively.
   Due to the pronounced anharmonicity arising from anti-bonding states and
   weak interatomic forces, the inclusion of four-phonon scattering results
   in a marked decrease in the lattice thermal conductivity (kappa L). The
   kappa L is remarkably suppressed to ultralow levels, with Ba3P2 and
   Ba3As2 exhibiting values of 2.27 W m-1 K-1 (2.56 W m-1 K-1) and 0.95 W
   m-1 K-1 (0.98 W m-1 K-1), respectively. These values represent
   reductions of 25.8\% (28.8\%) and 44.7\% (34.4\%) relative to
   predictions, considering only three-phonon scattering processes.
   Moreover, kappa L exhibits a nonmonotonic response to biaxial strain,
   with Ba3P2 displaying a nearly linear decrease within the 0.5\% to 3\%
   strain range, indicating exceptional tunability of thermal transport. In
   summary, the room-temperature ZT values reach similar to 2.62 for Ba3P2
   and similar to 4.0 for Ba3As2 outperforming many two-dimensional
   thermoelectric materials. These findings underscore the pivotal role of
   four-phonon scattering in tailoring low-dimensional thermal transport
   and highlight Ba3X2 monolayers as highly promising candidates for
   high-performance thermoelectric applications at room temperature.},
Type = {Article},
Affiliation = {Zhang, KW (Corresponding Author), Xiangtan Univ, Sch Phys \& Optoelect, Xiangtan 411105, Hunan, Peoples R China.
   Tan, Rui-Hao; Xie, Qing-Yu; Xiang, Fan; Zhang, Kai-Wang, Xiangtan Univ, Sch Phys \& Optoelect, Xiangtan 411105, Hunan, Peoples R China.},
DOI = {10.1039/d5cp01993a},
EarlyAccessDate = {AUG 2025},
Keywords-Plus = {FIGURE; TRANSPORT; MERIT; POWER; STATE},
Author-Email = {kwzhang@xtu.edu.cn},
Number-of-Cited-References = {81},
Times-Cited = {0},
Unique-ID = {WOS:001548392400001},
}

@article{ WOS:001550574900006,
Author = {Dixon, Breanna and Ahmed, Waqar M. and Fowler, Stephen J. and Felton,
   Tim and Trivedi, Drupad K.},
Title = {LC-MS/MS metabolomics unravels the resistant phenotype of
   carbapenemase-producing Enterobacterales},
Journal = {METABOLOMICS},
Year = {2025},
Volume = {21},
Number = {5},
Month = {AUG 12},
Abstract = {IntroductionThe degree of antimicrobial resistance demonstrated by
   carbapenemase-producing Enterobacterales (CPE) represents a growing
   public health challenge. Conventional methods for detecting CPE involve
   culture-based techniques with lengthy incubation steps. There is a need
   to develop rapid and accurate methods for the detection of resistance,
   for implementation into clinical diagnostics.ObjectivesWith cellular
   phenotype closely linked to the metabolome, the acquisition of
   resistance should result in detectable differences in microbial
   metabolism. Accordingly, we sought to profile the metabolome of
   Enterobacterales isolates belonging to both CPE and non-CPE groups to
   identify metabolites linked to CPE.MethodsWe used liquid
   chromatography-mass spectrometry to profile the endo- and exometabolome
   of 32 Klebsiella pneumoniae and Escherichia coli isolates to identify
   metabolites which could predict CPE in antibiotic-free conditions after
   6 h of growth.ResultsUsing supervised machine learning and multivariate
   analysis algorithms (partial least squares-discriminant analysis,
   k-nearest neighbour and random forest), we identified 21 metabolite
   biomarkers which displayed high performance metrics for the prediction
   of CPE (AUROCs >= 0.845). Results revealed a range of alterations
   between the metabolomes of CPE and non-CPE isolates. Pathway analysis
   revealed enrichment of microbial pathways including arginine metabolism,
   ATP-binding cassette transporters, purine metabolism, biotin metabolism,
   nucleotide metabolism, and biofilm formation, providing mechanistic
   insight into the resistance phenotype of CPE.ConclusionOur models
   demonstrate the ability to distinguish CPE from non-CPE in under 7 h
   using metabolite biomarkers, showing potential for the development of a
   targeted diagnostic assay.},
Type = {Article},
Affiliation = {Trivedi, DK (Corresponding Author), Univ Manchester, Manchester Inst Biotechnol, Dept Chem, Manchester, England.
   Dixon, Breanna; Ahmed, Waqar M.; Fowler, Stephen J.; Felton, Tim, Univ Manchester, Fac Biol Med \& Hlth, Sch Biol Sci, Div Immunol Immun Infect \& Resp Med, Manchester, England.
   Dixon, Breanna; Trivedi, Drupad K., Univ Manchester, Manchester Inst Biotechnol, Dept Chem, Manchester, England.
   Fowler, Stephen J.; Felton, Tim, Manchester Univ Hosp NHS Fdn Trust, Manchester, England.},
DOI = {10.1007/s11306-025-02300-9},
Article-Number = {115},
Keywords-Plus = {MASS-SPECTROMETRY DATA; MALDI-TOF; PROTEOMICS},
Author-Email = {drupad.trivedi@manchester.ac.uk},
Number-of-Cited-References = {66},
Times-Cited = {1},
Unique-ID = {WOS:001550574900006},
}

@article{ WOS:001584167500008,
Author = {Liang, Wentao and Xiao, Wenjun and Meng, Linxing and Bi, Jinshun and
   Aierken, Abuduwayiti and Rong, Xiaofeng and Wang, Degui and Liu, Xuefei},
Title = {Unveiling d-band synergy in anti-sandwich dual-atom catalysts for
   hydrogen evolution reaction: High-throughput DFT screening and machine
   learning insights},
Journal = {APPLIED SURFACE SCIENCE},
Year = {2025},
Volume = {712},
Month = {DEC 7},
Abstract = {The electrocatalytic hydrogen evolution reaction (HER) is a highly
   efficient electrocatalytic process and offers a promising strategy for
   clean energy generation. Dual-atom catalysts (DACs) have emerged as a
   cutting-edge approach to enhance electrocatalytic HER performance.
   However, the precise mechanisms governing the synergistic interaction
   between the two metal centers remains unclear. In this study, we employ
   density functional theory (DFT) calculations to systematically
   investigate DACs with an inverted interlayer configuration anchored on a
   BC3 substrate, thereby providing a comprehensive evaluation of their
   catalytic potential. We identify efficient and stable DACs by analyzing
   Gibbs free energy, binding energy, formation energy, dissolution energy,
   and by conducting first-principles molecular dynamics simulations. Based
   on the DFT results, eight DACs structures are found to possess both high
   catalytic activity and robust long-term stability. Furthermore, we apply
   machine-learning techniques to correlate key physicochemical descriptors
   with DACs activity, aiming to elucidate the intrinsic mechanism behind
   the synergistic effects in dual-atom systems. Overall, this work not
   only identifies promising HER catalysts but also establishes a
   data-driven research paradigm that addresses the limitations of
   traditional approaches in mechanistic studies of complex catalytic
   systems, thereby providing a theoretical framework for the rational
   design of high-performance HER catalysts featuring inverted interlayer
   configurations.},
Type = {Article},
Affiliation = {Xiao, WJ; Rong, XF; Liu, XF (Corresponding Author), Guizhou Normal Univ, Sch Phys \& Elect Sci, Guiyang 550025, Peoples R China.
