   Jiang, Shilin, AECC Chengdu Engine Co Ltd, Chengdu 610500, Peoples R China.},
DOI = {10.1007/s11668-025-02306-4},
EarlyAccessDate = {OCT 2025},
Keywords = {Erosion damage prediction; iHHO-XGBoost; SHAP},
Keywords-Plus = {VELOCITIES; PARTICLES; METALS; ANGLES; DAMAGE},
Author-Email = {wanghao@cauc.edu.cn
   2023011030@cauc.edu.cn
   ZeshangZhang@outlook.com
   517597952@qq.com},
