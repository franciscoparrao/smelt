@article{ WOS:001575076200008,
Author = {Zhou, Haoran and Ma, Yingchun and Li, Huaiqian and Zhang, Jiayun and
   Yang, Mingke and Miao, Zhiquan and Yu, Bo and Jiang, Chenghui and Wei,
   Yanpeng},
Title = {Process prediction of M2052 alloy selective laser melting using a
   prototype network-enhanced SVC},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2025},
Volume = {1041},
Month = {OCT 10},
Abstract = {M2052 is a high-performance damping alloy known for its excellent
   mechanical properties and damping capacity. Selective Laser Melting
   (SLM), as an advanced additive manufacturing technique, overcomes the
   limitations of conventional forming methods by enabling the efficient
   and precise fabrication of complex geometries. The additive
   manufacturing of M2052 alloy is hindered by issues such as inadequate
   build quality and a high susceptibility of defect formation to process
   parameter variations. What's more, Machine learning methods in additive
   manufacturing process prediction face challenges such as limited
   datasets, prolonged testing times, and high associated costs. In this
   study, a simulation-assisted prototype neural network model is proposed
   to establish a predictive framework for the process window of M2052
   alloy using limited sample data. Experimental validation demonstrates
   the model's high predictive accuracy in identifying optimal processing
   parameters for achieving high-quality SLM-formed M2052 components.
   Specifically, at laser power P = 100 W and scanning speed V= 600 mm/s,
   the as-built sample achieves a tensile strength of 567.3 MPa and an
   elongation of 28.6 \%. Post-processing via solution treatment at 885
   degrees C for 1 h followed by aging at 430 degrees C for 2 h enhances
   the tensile strength to 619.3 MPa, elongation to 34.0 \%, and internal
   friction (Tan delta) to 0.051. The machine learning-based approach
   presented in this work effectively predicts a robust SLM processing
   window, enabling the fabrication of M2052 alloy components with
   mechanical properties comparable to forgings and superior damping
   performance.},
Type = {Article},
Affiliation = {Wei, YP (Corresponding Author), Shenyang Res Inst Foundry, Natl Key Lab Adv Casting Technol, Shenyang 110022, Peoples R China.
   Zhou, Haoran; Ma, Yingchun; Li, Huaiqian; Zhang, Jiayun; Yang, Mingke; Miao, Zhiquan; Yu, Bo; Wei, Yanpeng, Shenyang Res Inst Foundry, Natl Key Lab Adv Casting Technol, Shenyang 110022, Peoples R China.
   Wei, Yanpeng, Tsinghua Univ, Dept Mech Engn, Beijing 100084, Peoples R China.
   Jiang, Chenghui, Harbin Inst Technol, State Key Lab Precis Welding \&Joining Mat \& Struct, Harbin 150001, Peoples R China.},
DOI = {10.1016/j.jallcom.2025.183559},
EarlyAccessDate = {SEP 2025},
Article-Number = {183559},
Keywords = {Selective laser melting; M2052 alloy; Machine learning; Mechanical
   property; Damping alloy},
Keywords-Plus = {CU ALLOY; TRANSFORMATION},
Author-Email = {wyp20@tsinghua.org.cn},
Number-of-Cited-References = {52},
Times-Cited = {1},
