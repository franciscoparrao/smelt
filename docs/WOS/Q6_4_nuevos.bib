   Kent, Daniel J.; Mwatha, Tolani; Thottingal, Paul, Kaiser Permanente Washington, Seattle, WA USA.
   Kent, Daniel J., Univ Washington, Sch Pharm, Seattle, WA USA.},
DOI = {10.1007/s11121-025-01844-5},
EarlyAccessDate = {OCT 2025},
Keywords = {Algorithm fairness; Clinical prediction model; Health equity; Learning
   health system; Nirmatrelvir/ritonavir (Paxlovid (R)); Prospective
   validation},
Keywords-Plus = {NIRMATRELVIR; STATES},
Author-Email = {rebecca.y.coley@kp.org},
Number-of-Cited-References = {40},
