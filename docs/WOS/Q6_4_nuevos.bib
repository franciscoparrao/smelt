   Ahamed, F. A. Sabbir, Int Univ Business Agr \& Technol, Dept Phys, Dhaka, Bangladesh.
   Khan, Habeeb Faruk, Int Univ Business Agr \& Technol, Dept English \& Modern Language, Dhaka, Bangladesh.},
DOI = {10.1117/1.JNP.19.046003},
Keywords = {metamaterial absorber; solar energy harvesting; broadband absorption;
   machine learning optimized},
Keywords-Plus = {METASURFACE ABSORBER; PERFECT ABSORPTION; LIGHT},
