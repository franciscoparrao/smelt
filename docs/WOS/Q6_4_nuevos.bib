Unique-ID = {WOS:001614180000001},
}

@article{ WOS:001629187800001,
Author = {Shourehdeli, Shaban Alyari and Gholipour, Hamed},
Title = {Harnessing multi-source data to develop universal machine learning
   models for saturated flow boiling heat transfer in mini/macro channels},
Journal = {INTERNATIONAL COMMUNICATIONS IN HEAT AND MASS TRANSFER},
Year = {2026},
Volume = {170},
Month = {JAN},
Abstract = {Reliable knowledge of Heat Transfer Coefficient (HTC) under flow boiling
   conditions underpins the optimization of thermal systems where compact,
   high-performance heat exchangers are required. This study develops and
   evaluates Machine Learning (ML) models for predicting HTC in saturated
   flow boiling within mini and macro channels. A large and diverse
   experimental database containing 24,614 data points from 120 sources is
   compiled to train and validate four ML regression approaches for
   construction of universal predictive models. The results show that all
   models outperform existing correlations, with mean prediction errors of
   around 4 \% for the majority of models. Tests on excluded data subsets
   demonstrate reasonable generalization capability, although performance
   declines when operating conditions differ significantly from the
   training data. Analysis of these cases highlights the importance of data
   representativeness and provides insights for guiding future experimental
   efforts. Overall, the proposed ML-based framework offers a more accurate
   and versatile tool for HTC prediction compared to conventional methods.},
Type = {Article},
Affiliation = {Shourehdeli, SA (Corresponding Author), Shahid Rajaee Teacher Training Univ, Dept Mech Engn, POB 16785163, Tehran, Iran.
   Shourehdeli, Shaban Alyari; Gholipour, Hamed, Shahid Rajaee Teacher Training Univ, Dept Mech Engn, POB 16785163, Tehran, Iran.},
