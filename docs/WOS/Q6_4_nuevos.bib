EarlyAccessDate = {DEC 2025},
Article-Number = {125024},
Keywords = {Machine learning; Molecular structure embedding; Emerging contaminants;
   Polyamide membranes; Rejection mechanisms},
Keywords-Plus = {NANOFILTRATION MEMBRANES; ORGANIC SOLUTES; AQUEOUS-SOLUTIONS; WATER;
