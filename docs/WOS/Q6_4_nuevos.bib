   Zhang, Lei, Pengcheng Lab, Shenzhen 518000, Peoples R China.},
DOI = {10.26599/BDMA.2025.9020055},
Keywords = {Training; Accuracy; Heuristic algorithms; Closed box; Predictive models;
   Prediction algorithms; Inference algorithms; Classification algorithms;
   Glass box; Classification tree analysis; interpretable machine learning;
   Decision Trees (DTs); classification},
