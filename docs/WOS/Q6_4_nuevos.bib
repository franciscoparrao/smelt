@article{ WOS:001707440800001,
Author = {Fan, Lin and He, Yan and Mo, Yunfeng and Cao, Yiming},
Title = {An interpretable ensemble machine learning model for predicting carbon
   dioxide adsorption on magnesium oxide-based sorbents},
Journal = {ENVIRONMENTAL RESEARCH},
Year = {2026},
Volume = {297},
Month = {MAY 15},
Abstract = {Accurately predicting the carbon dioxide (CO2) adsorption capacity of
   magnesium oxide (MgO)-based sorbents is crucial for advancing carbon
   capture technologies. This study develops an interpretable machine
   learning framework to address this challenge. Fourteen candidate models
   were evaluated, with six top-performing ones selected for Bayesian
   hyperparameter optimization using the Optuna framework. A novel weighted
   ensemble model was then constructed by integrating the entropy weight
   method and the Technique for Order Preference by Similarity to Ideal
   Solution. The optimized ensemble model demonstrated outstanding
   performance on an independent test set, achieving an R2 of 0.9903 with
   MSE, RMSE, and MAE of 0.361, 0.6008, and 0.2544 respectively, surpassing
   most individual models. SHapley Additive exPlanations analysis
   identified material morphology as the most significant feature (43.8\%
   contribution), particularly granular morphology. Process parameters
   including time (23.3\%) and temperature (14.1\%) were the next major
   contributors, while pore structure variables collectively contributed
   15.3\%. The analysis further revealed complex non-linear dependencies
   and interaction effects, with the combination of medium temperature
   (200-400 degrees C) and adsorption time (100-250 min) proving optimal.
   Additionally, a web application was deployed to provide real-time
   prediction capability. This work provides both a reliable predictive
   tool and valuable mechanistic insights for designing high-performance
   MgO-based CO2 adsorbents.},
Type = {Article},
Affiliation = {He, Y (Corresponding Author), Liaoning Petrochem Univ, Sch Mech Engn, Fushun 113001, Liaoning, Peoples R China.
   Fan, Lin; Mo, Yunfeng, Liaoning Petrochem Univ, Engn Training Ctr, Fushun 113001, Liaoning, Peoples R China.
   Fan, Lin, Shenyang Univ Technol, Sch Mech Engn, Shenyang 110870, Liaoning, Peoples R China.
   He, Yan; Cao, Yiming, Liaoning Petrochem Univ, Sch Mech Engn, Fushun 113001, Liaoning, Peoples R China.},
DOI = {10.1016/j.envres.2026.124126},
Article-Number = {124126},
Keywords = {Ensemble learning; MgO-based sorbents; CO 2 adsorption; Model
   interpretation; Streamlit},
Keywords-Plus = {CO2 CAPTURE; MGO},
Author-Email = {1422017226@qq.com},
Number-of-Cited-References = {54},
Times-Cited = {1},
Unique-ID = {WOS:001707440800001},
}

@article{ WOS:001700650000006,
Author = {Chang, Hongliang and Jia, Yanqing and Wang, Yue and Alquwayzani,
   Abdullah and Lu, Hang and Niu, Wenqing and Lin, Heming and Hassine,
   Mohamed Ben and Ng, Tien Khee and Ooi, Boon S.},
Title = {α-Ga2O3 Molecular Beam Epitaxy for Photodetection
   and Authentication},
Journal = {IEEE PHOTONICS TECHNOLOGY LETTERS},
Year = {2026},
Volume = {38},
Number = {10},
Pages = {655-658},
Month = {MAY 15},
Abstract = {With the growing demand for secure and tamper-resistant solutions in
   optical communication and authentication, optoelectronic devices that
   can simultaneously perform high-performance photodetection and security
   functions are of particular significance. In this context, physical
   unclonable functions (PUFs) implemented using wide-and ultrawide-bandgap
   semiconductors are especially attractive, as they combine the ability to
   detect optical signals with the intrinsic randomness needed for robust
   anti-cloning capabilities. Exploring the inherent variation in
   UV-visible light optoelectronic devices for PUF implementation can be
   promising for applications that potentially need authentication and
   encryption. Herein, we present the first proof-of-concept demonstration
   of a machine learning assisted authentication scheme utilizing
   alpha-Ga2O3 based photodetector (PD), demonstrating its dual
   functionality, including photodetection and its potential toward PUF
   implementation. Transmission electron microscope analysis confirmed that
   the epitaxially grown alpha-Ga2O3 exhibits both single-crystalline and
   amorphous regions. This, together with the fabrication variance, serves
   to enhance the device authentication capability. The fabricated PD shows
   a distinct light-to-dark current response and a pronounced persistent
   photoconductivity effect, with a paired-pulse facilitation index of
   similar to 130\%, attributed to the intrinsic defects in the
   alpha-Ga2O3. Furthermore, the photo-response of the fabricated PD under
   chopped 260-nm illumination at different voltage biases serves as
   digital fingerprints for authentication. By employing a convolutional
   neural network, the system achieves a high authentication accuracy of
   99.58\%. The seminal work lays the foundation for developing a
   full-scale device identification and authentication framework based on
   multiple challenge parameters, such as wavelength, pulse width, and
   beyond.},
Type = {Article},
Affiliation = {Ng, TK; Ooi, BS (Corresponding Author), King Abdullah Univ Sci \& Technol KAUST, Elect \& Comp Engn Dept, Div Comp Elect \& Math Sci \& Engn CEMSE, Photon Lab, Thuwal 239556900, Saudi Arabia.
