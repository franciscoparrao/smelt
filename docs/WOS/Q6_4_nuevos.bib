   tongliu@nciae.edu.cn},
Number-of-Cited-References = {71},
Times-Cited = {0},
Unique-ID = {WOS:001714939600001},
}

@article{ WOS:001718540900002,
Author = {Chen, Guixin and Yan, Yonggang and Zhao, Yi and Li, Hui and Wang, Dong
   and Hu, Xunxiang},
Title = {A machine learning framework for high-strength Mo-Re alloy design},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2026},
Volume = {1060},
Month = {MAR 31},
Abstract = {Optimizing the mechanical properties of Molybdenum-Rhenium (Mo-Re)
   alloys is paramount to unlocking their potential for applications in
   extreme environments (e.g. fission \& fusion reactors, space
   applications, etc.). Compositional design offers a promising route, but
   the vast compositional space hinders its practical exploration. Herein,
   we propose a data-driven strategy to investigate the strength of Mo-Re
   alloys based on high-throughput fabrication and machine learning (ML)
   methods. Specifically, adequate high-quality data was generated with 57
   samples synthesized by the self-developed high-throughput apparatuses.
   Among the models trained on the obtained dataset, the Gaussian Process
   (GP) model exhibited the best performance (R2 = 0.82) in predicting the
   ultimate tensile strength (UTS) of Mo-Re alloys. Interpretable ML
   analysis further revealed that mixing enthalpy (Delta Hmix) and atomic
   radius difference (delta) are the dominant factors governing strength in
   this system. Guided by these insights, we successfully designed and
   fabricated two alloys - Mo87.9Re4.3Ti1.2Nb6.4Zr0.2 and Mo88.9Re2.6Nb8.5,
   which achieved ultra-high UTS values of 933 MPa and 946 MPa,
   respectively. These results validate the effectiveness of ML-guided
   compositional design for Mo-Re alloys and demonstrate a viable pathway
   toward the discovery of high-performance structural materials for
   extreme environments.},
Type = {Article},
Affiliation = {Zhao, Y (Corresponding Author), Nucl Power Inst China, Natl Key Lab Nucl Reactor Technol, Chengdu 610213, Peoples R China.
