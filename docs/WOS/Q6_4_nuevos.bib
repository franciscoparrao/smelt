@article{ WOS:001722739300001,
Author = {Li, Sanai and Guo, Wenxuan},
Title = {Multi-scale cotton yield prediction using machine learning and
   Sentinel-2 imagery},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2026},
Volume = {14},
Month = {AUG},
Abstract = {Accurate yield prediction at various spatial and temporal scales is
   essential for optimizing crop production and management strategies. This
   study applied machine learning models to predict cotton yield using
   time-series Sentinel-2 imagery and assessed the generalizability and
   effects of resolution at the sub-field and field scales across multiple
   seasons in the Texas High Plains. High-resolution yield monitor data
   were collected from irrigated and rainfed fields in three counties
   during 2022-2024 for model training and testing. Sentinel-2 imagery and
   yield monitor data at 10 m resolution were resampled to 20 m, 60 m, and
   100 m scales to examine the effects of spatial resolution on model
   performance. Model generalizability was evaluated using independent-year
   validation at the sub-field (2022-2023) and field scales (2017 and
   2022). Machine learning performed well on all data at the 80/20 split
   (R2=0.79-0.91 for Multiple Linear Regression and 0.86-0.97 for
   Exponential Gaussian Process Regression). However, with independent-year
   validation, their performance declined (R2=0.63-0.85), highlighting the
   importance of testing model generalizability across different years and
   climate conditions. At the sub-field scale, model performance generally
   improved as the spatial resolution of input data decreased from 10 m
   (R2=0.63-0.79) to 100 m (R2=0.72-0.87). In contrast, performance at the
   field scale was relatively insensitive to predictor resolution from 10 m
   to 60 m. More complex models, including CNN-LSTM (Long Short-Term Memory
   networks) and EGPR (Exponential Gaussian Process Regression) using
   four-band reflectance, slightly outperformed NDVI input data at the
   sub-field scale. However, monthly median NDVI (R2 = 0.65-0.75) provided
   effective predictions at the field scale, outperforming four-band
   reflectance (R2 = 0.58-0.69). Prediction improved with resolution
   decreasing from 10 m to 20 m (field scale) or 60 m (sub-field scale)
   while reducing computational time. Overall, CNN-LSTM and EGPR using
   monthly median NDVI demonstrated high performance in capturing
   non-linear interactions and predicting cotton yield. This study reveals
   the importance of selecting appropriate predictors and validating models
   across independent years for crop yield prediction at different scales
   when using machine learning models.},
Type = {Article},
Affiliation = {Guo, WX (Corresponding Author), Texas Tech Univ, Dept Plant \& Soil Sci, Lubbock, TX 79409 USA.
   Guo, WX (Corresponding Author), Texas A\&M AgriLife Res, Dept Soil \& Crop Sci, Lubbock, TX 79403 USA.
   Li, Sanai; Guo, Wenxuan, Texas Tech Univ, Dept Plant \& Soil Sci, Lubbock, TX 79409 USA.
   Guo, Wenxuan, Texas A\&M AgriLife Res, Dept Soil \& Crop Sci, Lubbock, TX 79403 USA.},
DOI = {10.1016/j.atech.2026.101999},
Article-Number = {101999},
Keywords = {Spatial resolutions; Yield monitor data; CNN-LSTM; EGPR; Model
   generalizability; Texas High Plains},
Keywords-Plus = {VEGETATION INDEXES; WHEAT YIELDS; TIME-SERIES; CROP; ALGORITHMS;
   FRAMEWORK; FUTURE; LEVEL},
Author-Email = {wenxuan.guo@ttu.edu},
Number-of-Cited-References = {70},
Times-Cited = {0},
Unique-ID = {WOS:001722739300001},
}

@article{ WOS:001722826700001,
Author = {Remyamol, K. M. and Samuel, Philip},
Title = {Hierarchical attention-assisted feature pyramid network with Variational
   Sparse Autoencoder for cancer classification using gene data},
Journal = {COMPUTATIONAL BIOLOGY AND CHEMISTRY},
Year = {2026},
Volume = {123},
Month = {AUG},
Abstract = {Analyzing gene expression data is essential for predicting and detecting
   diseases, including cancer. The data is very repetitive and noisy, which
   makes it hard to find important information about illnesses. In the past
   decade, several traditional machine learning and feature selection
   models have been developed for cancer type classification from gene
   expression data. Rather than introducing new deep learning primitives,
   this work presents a principled integration framework that combines
   sparsity-aware representation learning, structure-inducing spatial
   embedding, and hierarchical multi-scale attention. This paper presents a
   method for cancer gene classification based on Hierarchical Attention
   Assisted Feature Pyramid Network (HA-FPN). The work involved two
   publicly available datasets. The proposed methodology starts with
   dimensionality reduction through a Variational Sparse Autoencoder
   (VSAE), followed by an updated DeepInsight algorithm for image
   conversion of the input. Next, the classification technique is
   constructed using the proposed HA-FPN model. Moreover, the improved
   gradient descent optimization (IGDO) is utilized to change the
   hyperparameter of the classification model. In addition, the results
   demonstrate that the model combined with an IGDO outperforms the
   currently existing methods in terms of accuracy, precision, recall, and
   F1-score. The method that is presented efficiently brings out different
   aspects of the data through t-SNE computations. Moreover, the proposed
   approach is very robust, and hence, it can reach high performance levels
   on two different datasets.},
Type = {Article},
Affiliation = {Remyamol, KM (Corresponding Author), Cochin Univ Sci \& Technol, Sch Engn, Dept Informat Technol, Kochi 682022, Kerala, India.
   Remyamol, K. M., Cochin Univ Sci \& Technol, Sch Engn, Dept Informat Technol, Kochi 682022, Kerala, India.
   Samuel, Philip, Cochin Univ Sci \& Technol, Dept Comp Sci, Kochi 682022, Kerala, India.},
DOI = {10.1016/j.compbiolchem.2026.109005},
Article-Number = {109005},
Keywords = {Genomics; Sparse; Hierarchical Attention; Pyramid; Autoencoder; Gradient
   descent Optimization; And cancer classification},
Author-Email = {remyamolkm@cusat.ac.in},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001722826700001},
}

@article{ WOS:001721987300001,
Author = {Piersall, Scott and Gao, Yang and Liu, Shenyang and Wang, Liqiang},
Title = {Improving MPI error detection and repair with large language models and
   bug references},
Journal = {JOURNAL OF PARALLEL AND DISTRIBUTED COMPUTING},
Year = {2026},
Volume = {213},
Month = {JUL},
Abstract = {Message Passing Interface (MPI) is a foundational technology in
   high-performance computing (HPC), widely used for large-scale
   simulations and distributed training (e.g., in machine learning
   frameworks such as PyTorch and TensorFlow). However, maintaining MPI
   programs remains challenging due to their complex interplay among
   processes and the intricacies of message passing and synchronization.
   With the advancement of large language models like ChatGPT, it is
   tempting to adopt such technology for automated error detection and
   repair. Yet, our studies reveal that directly applying large language
   models (LLMs) yields suboptimal results, largely because these models
   lack essential knowledge about correct and incorrect usage, particularly
   the bugs found in MPI programs. In this paper, we design a bug detection
   and repair technique alongside Few-Shot Learning (FSL), Chain-of-Thought
   (CoT) reasoning, and Retrieval Augmented Generation (RAG) techniques in
   LLMs to enhance large language model's ability to detect and repair
   errors. Surprisingly, such enhancements lead to a significant
   improvement, from 44\% to 77\%, in error detection accuracy compared to
   baseline methods that use ChatGPT directly. Additionally, our
   experiments demonstrate our bug referencing technique generalizes well
   to other large language models.},
Type = {Article},
Affiliation = {Wang, LQ (Corresponding Author), Univ Cent Florida, Dept Comp Sci, Orlando, FL 32816 USA.
   Piersall, Scott; Gao, Yang; Liu, Shenyang; Wang, Liqiang, Univ Cent Florida, Dept Comp Sci, Orlando, FL 32816 USA.},
DOI = {10.1016/j.jpdc.2026.105255},
Article-Number = {105255},
Keywords = {MPI programs; Large language models; Error detection and repair},
Author-Email = {spiersall@ucf.edu
   yang.gao@ucf.edu
   shenyang.liu@ucf.edu
   liqiang.wang@ucf.edu},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001721987300001},
}

@article{ WOS:001710112700001,
Author = {Zhang, Pei-Fu and Zhang, Daxu and Zhao, Qi and Tuerxunmaimaiti, Yiliyaer
   and Yang, Xinyu and Zhao, Xuan and Iqbal, Mudassir},
Title = {Machine learning-guided interpretable modelling of code-based equation
   for bond strength of composite bars in ultra-high-performance concrete},
Journal = {ADVANCED ENGINEERING INFORMATICS},
Year = {2026},
Volume = {73},
Month = {JUL},
Abstract = {Accurate prediction of bond strength between fibre-reinforced polymer
   (FRP) bars and ultra-high-performance concrete (UHPC) is critical for
   the design and durability of marine structures. Conventional code-based
   equations, such as those in American Concrete Institute (ACI) 440.1R-15,
   assume that the normalised bond strength can be expressed as the sum of
   linear functions of geometric and material parameters, often failing to
   capture the nonlinear effects observed in FRP-UHPC systems. While
   machine learning (ML) models, including Random Forest (RF) and XGBoost,
   can model these complex relationships with high predictive accuracy,
   their non-additive outputs and the qualitative nature of explainable AI
   techniques limit direct integration into code-compatible design
   equations. This study proposes a ML-guided framework to develop an
   interpretable, code-compatible bond strength equation. RF and XGBoost
   models, were trained on a comprehensive pullout test dataset of 290
   glass fibre-reinforced polymer (GFRP)-UHPC specimens, achieving high
   predictive accuracy with R2 values exceeding 0.95. This provides a
   reliable basis for capturing complex nonlinear interactions among
   cover-to-diameter, bonded-length-to-diameter, rib-height-to-diameter
   ratios, and concrete compressive strength. SHapley Additive exPlanations
   (SHAP) were employed to decompose ML predictions into additive
   contributions for each parameter. These contributions were then fitted
   with physically meaningful nonlinear functions, including saturation,
   exponential-decay, and extreme-type forms, and integrated into an
   ACI-style additive equation. The resulting ML-guided code-format
   equation achieves R2 of 0.836 on GFRP-UHPC data, substantially
   outperforming the conventional ACI equation which exhibits a negative R2
   value, while maintaining interpretability. Parametric analysis
   demonstrates the ability to capture threshold effects, nonlinear
   confinement, load-transfer, and mechanical interlock mechanisms. This
   hybrid paradigm bridges empirical design codes and data-driven
   modelling, enabling transparent, code-style calculations with enhanced
   accuracy. More broadly, the proposed framework establishes a new pathway
   for embedding explainable AI knowledge into civil engineering design
   formulations, advancing the development of intelligent, reliable, and
   standardised design methodologies for FRP-UHPC and other structural
   systems.},
Type = {Article},
Affiliation = {Zhang, DX (Corresponding Author), Shanghai Jiao Tong Univ, Sch Ocean \& Civil Engn, State Key Lab Ocean Engn, Shanghai Key Lab Digital Maintenance Bldg \&, Shanghai 200240, Peoples R China.
   Zhang, Pei-Fu; Zhang, Daxu; Tuerxunmaimaiti, Yiliyaer; Yang, Xinyu; Zhao, Xuan; Iqbal, Mudassir, Shanghai Jiao Tong Univ, Sch Ocean \& Civil Engn, State Key Lab Ocean Engn, Shanghai Key Lab Digital Maintenance Bldg \&, Shanghai 200240, Peoples R China.
   Zhao, Qi; Iqbal, Mudassir, Hong Kong Polytech Univ, Dept Civil \& Environm Engn, Hong Kong, Peoples R China.},
DOI = {10.1016/j.aei.2026.104542},
Article-Number = {104542},
Keywords-Plus = {REINFORCED POLYMER BARS},
Author-Email = {peifu.zhang@sjtu.edu.cn
   daxu.zhang@sjtu.edu.cn
   qi-cn.zhao@polyu.edu.hk
   elyar2018@sjtu.edu.cn
   young\_xinyu@sjtu.edu.cn
   zhaoxuanwells1222@sjtu.edu.cn
   mudassiriqbal29@sjtu.edu.cn},
Number-of-Cited-References = {64},
Times-Cited = {0},
Unique-ID = {WOS:001710112700001},
}

@article{ WOS:001713418500001,
Author = {Zhang, Ziyang and Chen, Cheng and Qin, Wentao and Wu, Xue and Liu, Yang
   and Wu, Lijun and Lv, Xiaoyi and Chang, Chenjie and Chen, Xinya and
   Chen, Zhiyuan and Xu, Qianxi and Li, Zhuoyu and Ma, Mengsi and Chen,
   Chen},
Title = {Feature-consistent cyclic domain adversarial network for unsupervised
   transfer diagnosis of the autoimmune disease IgG4-RD by Raman
   spectroscopy},
Journal = {CHEMOMETRICS AND INTELLIGENT LABORATORY SYSTEMS},
Year = {2026},
Volume = {273},
Month = {JUN 15},
Abstract = {IgG4-related disease (IgG4-RD) is a rare multi-organ immune disease with
   a complex pathogenesis and systemic clinical manifestations, which poses
   tremendous challenges for clinical diagnosis. Conventional diagnostic
   models based on supervised machine learning or deep learning are
   severely limited by the scarcity of labeled data arising from the above
   clinical characteristics of the disease. To address this problem, we
   propose a Feature-Consistent Cyclic Domain Adversarial Network (FCCDAN)
   framework specially designed for the onedimensional time-series
   characteristics of Raman spectral data and the demand for scarce labeled
   data in IgG4-RD diagnosis. This framework innovatively designs a 1D
   Patch-GAN discriminator and introduces bidirectional feature consistency
   loss on both the generator and the discriminator to construct a
   pixel-semantic-feature three-level cross-domain alignment system. By
   taking common autoimmune diseases as the knowledge source, FCCDAN
   achieves high-performance unsupervised transfer diagnosis for IgG4-RD
   and demonstrates its excellent generalization ability on datasets of
   homologous autoimmune diseases and non-homologous diseases, with an
   average diagnostic accuracy of up to 90.62\%-4.36\% higher than that of
   the best baseline model. In addition, we combine Grad-CAM visualization
   with the pathological mechanism analysis of Raman spectra to highlight
   the key spectral features that influence model decision-making and
   explore potential molecular biomarkers of IgG4-RD and related autoimmune
   diseases, thus greatly enhancing the interpretability and clinical
   credibility of the model. FCCDAN is the first to integrate cyclic
   adversarial unsupervised domain adaptation technology with Raman
   spectroscopy for the diagnosis of autoimmune diseases, making up for the
   deficiency that existing diagnostic methods based on Raman spectroscopy
   generally lack cross-domain generalization ability. This effectively
   expands the application scope of Raman spectroscopy in label-scarce
   diagnostic scenarios while maintaining high performance and
   interpretability, and provides a valuable and feasible framework for the
   intelligent diagnosis of similar rare diseases with scarce labeled data
   in clinical practice.},
Type = {Article},
Affiliation = {Chen, C (Corresponding Author), Xinjiang Univ, Coll Software, Urumqi 830046, Peoples R China.
   Chen, C (Corresponding Author), Xinjiang Univ, Xinjiang Cloud Comp Applicat Lab, Karamay 834099, Peoples R China.
   Zhang, Ziyang; Chen, Cheng; Qin, Wentao; Liu, Yang; Lv, Xiaoyi; Chen, Chen, Xinjiang Univ, Coll Software, Urumqi 830046, Peoples R China.
   Chen, Chen, Xinjiang Univ, Xinjiang Cloud Comp Applicat Lab, Karamay 834099, Peoples R China.
   Chang, Chenjie; Chen, Xinya; Chen, Zhiyuan, Xinjiang Univ, Sch Comp Sci \& Technol, Urumqi 830046, Peoples R China.
   Lv, Xiaoyi, Xinjiang Univ, Key Lab Signal Detect \& Proc, Urumqi 830046, Peoples R China.
   Wu, Xue; Wu, Lijun; Xu, Qianxi; Li, Zhuoyu; Ma, Mengsi, Peoples Hosp Xinjiang Uygur Autonomous Reg, Dept Rheumatol \& Immunol, Urumqi, Xinjiang, Peoples R China.
   Wu, Xue; Wu, Lijun, Xinjiang Clin Res Ctr Rheumatoid Arthrit, Urumqi, Xinjiang, Peoples R China.},
DOI = {10.1016/j.chemolab.2026.105703},
Article-Number = {105703},
Keywords = {Unsupervised domain adaptation (UDA); Cycle-consistent; IgG4-RD; Disease
   diagnosis},
Keywords-Plus = {CANCER},
