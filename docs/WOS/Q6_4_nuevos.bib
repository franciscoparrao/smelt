@article{ WOS:001645921100001,
Author = {Wang, Qian and Li, Quancai and Zou, Jian and Ren, Hehe and Gong, Ziyi
   and Liang, Jing and Wu, Wei},
Title = {A multi-metric evaluation framework guides the high-throughput design of
   versatile flexible pressure sensors},
Journal = {COMPOSITES PART B-ENGINEERING},
Year = {2026},
Volume = {312},
Month = {MAR 1},
Abstract = {The widespread application of flexible piezoresistive pressure sensors
   (FPPS) across multiple scenarios via highthroughput fabrication has been
   limited by an insufficient understanding of the microstructure-electrode
   interface and a lack of design principles for multi-parameter
   performance. Herein, we develop a modular hybrid manufacturing strategy
   that combines casting, printing and surface modification to achieve
   stable fullinterface integration. This strategy enables the rapid
   fabrication of twelve sensor configurations by combining four
   microstructures with three interdigital electrodes (IDEs). We further
   establish a multidimensional evaluation framework that incorporates
   signal-to-noise ratio (SNR), noise power spectral density, and
   time-frequency analysis beyond mere sensitivity coefficient (S). This
   approach directly visualized, for the first time, the performance
   variations across configurations under dynamic pressure and quantified
   the inherent trade-offs among sensitivity, linearity, and noise. The
   optimal configuration was determined to be a combination of a rhombic
   pyramid microstructure and an IDE-Type-1 (RP-1-FPPS), achieving a wide
   sensing range of 0-260 kPa, a S of 14.368 kPa-1 in sensing range of 0-30
   kPa, 2.636 kPa-1 in sensing range of 30-200 kPa, low 1/f noise, and an
   SNR exceeding 45 dB. It exhibited reliably in diverse applications,
   including pulse monitoring, industrial equipment condition monitoring,
   and machine-learning-driven robotic grasp recognition. This study
   proposes a strategy for developing cost-effective, high-performance
   FPPS, which provides a deeper understanding of the relationship between
   structure and performance and lays the foundation for reliable
   multi-scenario applications.},
Type = {Article},
Affiliation = {Wu, W (Corresponding Author), Wuhan Univ, Sch Phys \& Technol, Lab Printable Funct Mat \& Printed Elect, Wuhan 430072, Peoples R China.
   Wang, Qian; Li, Quancai; Zou, Jian; Ren, Hehe; Gong, Ziyi; Liang, Jing; Wu, Wei, Wuhan Univ, Sch Phys \& Technol, Lab Printable Funct Mat \& Printed Elect, Wuhan 430072, Peoples R China.},
DOI = {10.1016/j.compositesb.2025.113327},
EarlyAccessDate = {DEC 2025},
Article-Number = {113327},
Keywords = {Flexible piezoresistive pressure sensor; Printing; Interface; Signal
   analysis},
Author-Email = {weiwu@whu.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {1},
Unique-ID = {WOS:001645921100001},
}

@article{ WOS:001646239100001,
Author = {Rai, Soumya and Gupta, Sanvi and Sajwan, Shraddha and Aditi,
   Vandemataram and Kant, Chhaya Ravi},
Title = {Artificial intelligence models for supercapacitor performance prediction
   in energy storage},
Journal = {JOURNAL OF ENERGY STORAGE},
Year = {2026},
Volume = {145},
Month = {FEB 1},
Abstract = {The growing shift toward renewable energy systems has intensified the
   demand for efficient energy storage devices, with supercapacitors
   emerging as key contenders due to their high power density, rapid
   charge-discharge capability, and long cycle life. However, improving
   their energy density and optimizing performance remain persistent
   challenges. Artificial intelligence (AI) offers a powerful route to
   accelerate material discovery and device optimization by predicting
   electrochemical performance from structural, morphological, and
   compositional features. This review provides a systematic analysis of AI
   models including artificial neural networks (ANN), random forest
   regression (RFR), support vector regression (SVR), gaussian process
   regression (GPR), linear and polynomial regression (LPR), and extreme
   gradient boosting (XGBoost), applied to supercapacitor performance
   prediction across diverse electrode materials such as MXenes,
   carbon-based materials, metal oxides/dichalcogenides, and metal-organic
   frameworks (MOFs). Unlike existing reviews, this work integrates
   harmonized performance metrics, task-wise comparisons, and model
   interpretability insights (SHAP, permutation importance) while
   explicitly considering dataset size, leakage-safe validation, and fixed
   electrochemical testing conditions. The review identifies clear
   model-specific strengths such as ANN's nonlinear mapping capability,
   GPR's uncertainty quantification, and XGBoost's scalability, alongside
   persisting challenges related to data scarcity, standardization, and
   generalizability. By consolidating literature insights and benchmark
   comparisons, this review offers practical guidance for selecting
   suitable AI models and supports the development of AI-assisted
   approaches for designing next-generation supercapacitors in
   high-performance energy storage systems.},
Type = {Review},
Affiliation = {Kant, CR (Corresponding Author), Indira Gandhi Delhi Tech Univ Women, Dept Appl Sci \& Humanities, Kashmere Gate, Delhi 110006, India.
   Rai, Soumya; Kant, Chhaya Ravi, Indira Gandhi Delhi Tech Univ Women, Dept Appl Sci \& Humanities, Kashmere Gate, Delhi 110006, India.
   Gupta, Sanvi; Sajwan, Shraddha, Indira Gandhi Delhi Tech Univ Women, Dept Comp Sci \& Engn, Kashmere Gate, Delhi 110006, India.
   Aditi, Vandemataram, Stanley Coll Engn \& Technol Women, Abids 500001, Telangana, India.},
DOI = {10.1016/j.est.2025.119919},
EarlyAccessDate = {DEC 2025},
Article-Number = {119919},
Keywords = {Artificial Intelligence; Supercapacitors; Energy storage; Artificial
   neural networks; Machine Learning; Extreme Gradient Boosting},
Keywords-Plus = {NEURAL-NETWORKS; RANDOM FORESTS; CAPACITANCE; REGRESSION; SELECTION;
   ELECTRODE; ENSEMBLE},
Author-Email = {chhayaravikant@igdtuw.ac.in},
Number-of-Cited-References = {113},
Times-Cited = {0},
Unique-ID = {WOS:001646239100001},
}

@article{ WOS:001645874200001,
Author = {Sudarsan, Sujesh and Murugesan, Gokulakrishnan and Varadavenkatesan,
   Thivaharan and Vinayagam, Ramesh and Selvaraj, Raja},
Title = {Machine learning modelling and mechanistic insights into malachite green
   adsorption on sustainable magnetic activated carbon},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2026},
Volume = {81},
Month = {JAN},
Abstract = {The efficient removal of toxic dyes from industrial effluents remains a
   persistent environmental challenge, necessitating the development of
   high-performance and recyclable adsorbents. In this study, a
   superparamagnetic activated carbon derived from Spathodea campanulata
   flowers (SCMAC) was synthesized via a sustainable low-temperature
   carbonization-magnetization route and employed for the fixed-bed
   adsorption of Malachite Green (MG) dye. The influence of key operational
   parameters, including bed height (Z:1-3 cm), flow rate (Q:3-5 mL/min),
   and inlet concentration (C-0:20-60 mg/L), was systematically
   investigated. Increasing the bed height from 1 to 3 cm prolonged the
   breakthrough time and enhanced dye removal (34.32 to 50.37 \%), while
   higher flow rates and feed concentrations accelerated saturation. The
   optimal conditions (Z = 2 cm, Q = 4.2 mL/min, C-0 = 40 mg/L), yielded a
   maximum equilibrium adsorption capacity of 108.06 mg/g. Breakthrough
   modeling using the Thomas, Yoon-Nelson, Adams-Bohart, Clark, and Bed
   Depth Service Time models showed excellent agreement with experimental
   data, validating the adsorption kinetics and mass-transfer dynamics. To
   further improve predictive capability, advanced machine-learning models
   were developed, with CatBoost (R-2 = 0.9965) identified as the most
   accurate predictor. SHapley Additive exPlanations (SHAP) and Partial
   Dependence Plots (PDP) analyses revealed time as the dominant parameter
   influencing MG breakthrough behavior. These findings establish SCMAC as
   a magnetically separable, high-efficient adsorbent and introduce a
   data-driven modeling framework for optimizing continuous adsorption
   systems for dye-laden wastewater remediation.},
Type = {Article},
Affiliation = {Vinayagam, R; Selvaraj, R (Corresponding Author), Manipal Inst Technol, Manipal Acad Higher Educ, Dept Chem Engn, Manipal 576104, Karnataka, India.
   Sudarsan, Sujesh; Vinayagam, Ramesh; Selvaraj, Raja, Manipal Inst Technol, Manipal Acad Higher Educ, Dept Chem Engn, Manipal 576104, Karnataka, India.
   Murugesan, Gokulakrishnan, MS Ramaiah Inst Technol, Dept Biotechnol, Bengaluru 560054, Karnataka, India.
   Varadavenkatesan, Thivaharan, Manipal Acad Higher Educ, Dept Biotechnol, Manipal Inst Technol, Manipal 576104, Karnataka, India.},
DOI = {10.1016/j.jwpe.2025.109327},
EarlyAccessDate = {DEC 2025},
Article-Number = {109327},
Keywords = {Magnetic activated carbon; Malachite green adsorption; Spathodea
   campanulata pods; Machine learning; Wastewater treatment},
Keywords-Plus = {AQUEOUS-SOLUTIONS; DYE; REMOVAL; PERFORMANCE},
Author-Email = {ramesh.v@manipal.edu
   raja.s@manipal.edu},
Number-of-Cited-References = {75},
Times-Cited = {0},
Unique-ID = {WOS:001645874200001},
}

@article{ WOS:001643757400001,
Author = {Ochiai, Haruki and Nagai, Kazukiyo and Kaneko, Hiromasa},
Title = {Machine Learning-Driven Design of Sustainable Polymer Membranes:
   Integrated Prediction of Gas Permeability, Selectivity, and
   Biodegradability},
Journal = {ACS OMEGA},
Year = {2026},
Volume = {11},
Number = {1},
Pages = {1935-1944},
Month = {JAN 13},
Abstract = {Increasing CO2 emissions are causing environmental pollution worldwide,
   and there is a growing need for the development of efficient CO2
   separation and recovery technologies. Many polymer materials, including
   polymer membranes, are difficult to decompose once released into the
   environment, leading to environmental pollution and adverse effects on
   ecosystems, and accordingly, biodegradable materials are required. In
   this study, we focused on the gas permeability and biodegradability of
   polymer materials and developed machine learning models to explore
   highly selective CO2 separation polymer membrane materials and predict
   their biodegradability. For gas permeability prediction, we used a data
   set of polymer membranes with standardized synthesis and film-forming
   conditions, confirming that highly accurate gas permeability coefficient
   predictions were possible even with a small number of polymer samples.
   Furthermore, we predicted the gas permeability coefficients and gas
   selectivity of 3219 polymer material candidates and identified
   approximately 500 high-performance polymers that exceed the Robeson
   upper bounds. Then, the polymers predicted to have biodegradability were
   also included. The present machine-learning framework enables us to
   propose computational candidates for CO2-separation membranes that are
   predicted to exhibit both high gas separation performance and
   biodegradability within the studied chemical space, providing
   hypothesis-generating guidance for future experimental studies.},
Type = {Article},
Affiliation = {Kaneko, H (Corresponding Author), Meiji Univ, Sch Sci \& Technol, Dept Appl Chem, Kawasaki, Kanagawa 2148571, Japan.
   Ochiai, Haruki; Nagai, Kazukiyo; Kaneko, Hiromasa, Meiji Univ, Sch Sci \& Technol, Dept Appl Chem, Kawasaki, Kanagawa 2148571, Japan.},
DOI = {10.1021/acsomega.5c10251},
EarlyAccessDate = {DEC 2025},
Keywords-Plus = {TRANSPORT PROPERTIES; REGRESSION; MODELS},
Author-Email = {hkaneko@meiji.ac.jp},
Number-of-Cited-References = {49},
Times-Cited = {0},
Unique-ID = {WOS:001643757400001},
}

@article{ WOS:001643145100001,
Author = {Xiong, Rui and Wang, Xianfeng},
Title = {Interpretable Multimodal Machine Learning for Sustainable Electret
   Materials: Deciphering Process-Structure-Property Relationships in PLA
   Melt-Blown Nonwovens via Integrated CNN and CatBoost},
Journal = {ACS SUSTAINABLE CHEMISTRY \& ENGINEERING},
Year = {2026},
Volume = {14},
Number = {1},
Pages = {347-362},
Month = {JAN 12},
Abstract = {The sustainable development of high-performance polylactic acid (PLA)
   electret melt-blown nonwovens, a promising biodegradable alternative to
   conventional polypropylene filters, has been hindered by the inefficient
   trial-and-error optimization of multivariate process parameters. To
   address this challenge, we propose an interpretable multimodal machine
   learning (ML) framework that integrates a multi-input convolutional
   neural network (CNN) with the CatBoost algorithm. This innovative
   pipeline synergistically combines process parameters and microstructural
   features extracted from scanning electron microscopy (SEM) images to
   predict key electret performance metrics, including surface potential
   and charge density, with exceptional accuracy (R-2 > 0.90). SHapley
   Additive exPlanations (SHAP) analysis further quantifies complex
   nonlinear and synergistic interactions among 13 input features,
   surpassing traditional black-box models by providing physically grounded
   insights. Our analysis identified an optimized processing window, a
   medium-high die temperature (210-225 degrees C), and hydraulic pressure
   (3-4 MPa), which balances charge implantation with thermal degradation,
   thereby enhancing charge stability. This interpretable ML framework
   reduces overall development expenditures by more than 80\% (calculated
   by comparing the 480 experimental runs required for conventional
   single-factor scanning with the 83 runs used in our reduced factorial
   design). Beyond lowering the material, labor, equipment, and
   computational costs, the workflow supports a transition from
   trial-and-error optimization to a more knowledge-driven and sustainable
   strategy for material development. Additional long-term efficiencies
   arise from the SHAP-guided elimination of unproductive regions in the
   design space.},
Type = {Article},
Affiliation = {Wang, XF (Corresponding Author), Donghua Univ, Coll Text, Shanghai Frontiers Sci Ctr Adv Text, Shanghai 201620, Peoples R China.
   Xiong, Rui, Jiangxi Inst Fash Technol, Dept Big Data, Nanchang 330201, Jiangxi, Peoples R China.
   Xiong, Rui, Key Lab Big Data Apparel Nanchang, Nanchang 330201, Jiangxi, Peoples R China.
   Wang, Xianfeng, Donghua Univ, Coll Text, Shanghai Frontiers Sci Ctr Adv Text, Shanghai 201620, Peoples R China.},
DOI = {10.1021/acssuschemeng.5c09925},
EarlyAccessDate = {DEC 2025},
Keywords = {interpretable machine learning; multimodal data fusion; electret
   performance prediction; melt-blown nonwovens; PLA electret},
Author-Email = {wxf@dhu.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {0},
Unique-ID = {WOS:001643145100001},
}

@article{ WOS:001641011500001,
Author = {Mendhe, Vaishali N. and Bahoria, Boskey V. and Patil, Tejas R. and
   Vairagade, Vikrant S. and Upadhye, Sachin and Shelke, Nilesh and
   Jagadesh, P. and Isleem, Haytham F. and Jangir, Pradeep and Arpita},
Title = {Multifunctional property predictions of nano-engineered cementitious
   composites for high-performance concrete structures using hybrid machine
   learning techniques},
Journal = {FRONTIERS OF STRUCTURAL AND CIVIL ENGINEERING},
Year = {2025},
Month = {2025 DEC 18},
Abstract = {The interest in nano-engineered cements basically brought by the demands
   on increasing the performance of concrete structures in challenging
   applications, such as extreme thermal, electrical, and electromagnetic
   environments. Traditional cementitious materials lack technological
   capabilities regarding thermal conductivity, electrical resistivity,
   mechanical strength, and electromagnetic shielding. Such limitations
   prevent their application in high-performance and multifunctional
   concrete structures, which are increasingly required in modern
   construction. The high-dimensional complexity of multivariable
   optimization of multiple properties makes most of the current approaches
   unsuitable, and so requires new ways to predict, model, and optimize the
   performance of such advanced materials. In the present contribution, we
   introduce a holistic approach to the optimization of nano-engineered
   cements composites incorporating epoxy resin, nano titanium dioxide,
   carbon nanotubes, and portland cement. Advanced techniques of machine
   learning used include random forest regressor for multi-output property
   prediction and eXtreme gradient boosting, an implementation of the
   gradient-boosting algorithm that proved particularly useful in
   multi-objective optimization, for electrical codes' thermal and
   mechanical properties. Bayesian optimization is also employed to
   decrease the experimental trials and fine-tune the processing
   parameters; high-dimensional input space is reduced using principal
   component analysis to attain optimal model performance. Graph neural
   networks are utilized for modeling structure-property relations, and
   Gaussian processes serve as a surrogate model mimicking the outcome of
   finite element analysis simulation effectively reducing delays at the
   computational level. The model yields noteworthy improvements:
   resistivity decreases by 30\%-40\%, thermal conductivity increases by
   25\%-30\%, and tensile strength increases by 15\%-20\%. These
   enhancements make nano-engineered cements composites highly promising
   for multifunctional applications such as vibration absorption and
   electromagnetic shielding, which presents the need for smart,
   high-performance concrete structures for advanced applications in
   construction.},
Type = {Article; Early Access},
Affiliation = {Vairagade, VS (Corresponding Author), Priyadarshini Coll Engn, Dept Civil Engn, Nagpur 440019, India.
   Mendhe, Vaishali N.; Bahoria, Boskey V., Yeshwantrao Chavan Coll Engn, Dept Civil Engn, Nagpur 441110, India.
   Patil, Tejas R., Priyadarshini Bhagwati Coll Engn, Dept Civil Engn, Nagpur 440024, India.
   Vairagade, Vikrant S., Priyadarshini Coll Engn, Dept Civil Engn, Nagpur 440019, India.
   Upadhye, Sachin, Ramdeobaba Univ, Sch Comp Sci \& Engn, Dept Comp Sci \& Applicat, Nagpur 440013, India.
   Shelke, Nilesh, Symbiosis Int Deemed Univ, Symbiosis Inst Technol, Nagpur Campus, Pune 440008, India.
   Jagadesh, P., Coimbatore Inst Technol, Dept Civil Engn, Coimbatore 641014, India.
   Isleem, Haytham F., Univ York, Dept Comp Sci, York YO10 5DD, England.
   Jangir, Pradeep, Chandigarh Univ, Univ Ctr Res \& Dev, Mohali 140413, India.
   Arpita, Saveetha Inst Med \& Tech Sci, Saveetha Sch Engn, Dept Biosci, Chennai 602105, India.},
DOI = {10.1007/s11709-025-1247-7},
EarlyAccessDate = {DEC 2025},
Keywords = {nano-engineered cements; epoxy resin; nano titanium dioxide; carbon
   nanotubes; machine learning; Bayesian optimization},
Author-Email = {vikrant.vairagade@pcenagpur.edu.in},
Number-of-Cited-References = {49},
Times-Cited = {1},
Unique-ID = {WOS:001641011500001},
}

@article{ WOS:001645633000001,
Author = {Wu, Zhong-Yuan and Li, Zhi-Lei and Zheng, Xiao-Hong and Zhang, Cheng and
   Liu, Yu-Feng},
Title = {Machine learning-assisted development of high-performance Cr-doped
   tungsten oxide triethylamine gas sensors},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2026},
Volume = {527},
Month = {JAN 1},
Abstract = {Accurate detection of triethylamine (TEA) is essential for environmental
   and industrial safety. However, conventional metal oxide semiconductor
   sensors exhibit insufficient sensitivity and selectivity. This study
   develops an intelligent TEA sensor based on Cr-doped WO3 nanomaterials
   integrated with machine learning. The 1 wt\% Cr-WO3 sensor exhibited
   optimal performance, with a response of 330.1 to 50 ppm TEA at 240
   degrees C (4.78 times higher than pristine WO3), rapid response/recovery
   times (11 s/44 s), and a low detection limit of 42 ppb. The sensor also
   demonstrated excellent selectivity, repeatability, and stability,
   attributed to Cr-induced surface oxygen vacancies that enhance gas
   interactions. Based on machine learning, we established a gas
   recognition model using the KNN algorithm and a concentration prediction
   model using the neural network algorithm. This work integrates material
   optimization and intelligent algorithms to establish a
   ``high-sensitivity detection-smart analysis{''} framework, thereby
   advancing gas sensors toward systematic intelligence for next-generation
   monitoring systems.},
Type = {Article},
Affiliation = {Zheng, XH; Liu, YF (Corresponding Author), Shanghai Inst Technol, Fac Mat Technol, Shanghai 201418, Peoples R China.
   Wu, Zhong-Yuan; Li, Zhi-Lei; Zheng, Xiao-Hong; Zhang, Cheng; Liu, Yu-Feng, Shanghai Inst Technol, Fac Mat Technol, Shanghai 201418, Peoples R China.},
DOI = {10.1016/j.cej.2025.171530},
EarlyAccessDate = {DEC 2025},
Article-Number = {171530},
Keywords = {Triethylamine; Gas sensor; Machine learning; Principal component
   analysis},
Keywords-Plus = {SENSITIVE DETECTION; FAST-RESPONSE; NANOFIBERS; NANORODS},
Author-Email = {zhengxiaohong@sit.edu.cn
   yfliu@sit.edu.cn},
Number-of-Cited-References = {60},
Times-Cited = {0},
Unique-ID = {WOS:001645633000001},
}

@article{ WOS:001642295600001,
Author = {Bezik, Cody T. and Ethier, Jeffrey G. and Vashisth, Aniruddh and
   Varshney, Vikas},
Title = {A Hybrid Simulation-Machine Learning Framework for Predicting Thermal
   Degradation in High-Performance Polyimides},
Journal = {MACROMOLECULES},
Year = {2026},
Volume = {59},
Number = {1},
Pages = {60-74},
Month = {JAN 13},
Abstract = {Accurately predicting the onset of thermal degradation (T d ) in
   polyimides is critical to materials development in high-temperature
   aerospace and electronics applications. Direct measurement of T d via
   thermogravimetric analysis requires costly synthesis, necessitating
   alternate routes to rapidly screen monomer chemistries for promising new
   materials. In this work, we develop an integrated framework combining
   reactive molecular dynamics with machine learning models to rapidly and
   accurately estimate the 5\% mass loss T d of polyimide chemistries.
   Beginning from a curated data set of polyimide repeat units with
   experimentally validated T d values, we perform reactive molecular
   dynamics with ReaxFF to simulate thermal degradation as the polymers are
   heated from 300 to 4000 K. We use the simulations to create features
   related to the onset of thermal degradation, which we combine with
   chemical fingerprint information obtained from RDKit to serve as the
   input to XGBoost models which are trained to predict T d . We find the
   performance of such models is highly dependent on the choice of
   features, and the means by which such features are combined. While
   purely chemistry-based models perform well, we find we can significantly
   enhance the accuracy of T d prediction by training meta-models, in which
   the predictions of separate XGBoost models trained on chemistry
   information and simulation information, respectively, are used to
   featurize new machine learning models to make final predictions. Our
   work provides a foundation upon which new chemistries can be evaluated
   for thermal degradation performance, leading to the generation and
   design of new polyimide chemistries with very high T d .},
Type = {Article},
Affiliation = {Bezik, CT; Varshney, V (Corresponding Author), US Air Force, Wright Patterson Air Force Base, Mat \& Mfg Directorate, Res Lab, Wright, OH 45433 USA.
   Bezik, CT (Corresponding Author), Natl Res Council Res Associate Program Fellow, Washington, DC 20001 USA.
   Bezik, Cody T.; Ethier, Jeffrey G.; Varshney, Vikas, US Air Force, Wright Patterson Air Force Base, Mat \& Mfg Directorate, Res Lab, Wright, OH 45433 USA.
   Vashisth, Aniruddh, Univ Washington, Dept Mech Engn, Seattle, WA 98195 USA.
   Bezik, Cody T., Natl Res Council Res Associate Program Fellow, Washington, DC 20001 USA.},
DOI = {10.1021/acs.macromol.5c02507},
EarlyAccessDate = {DEC 2025},
Keywords-Plus = {REACTIVE FORCE-FIELD; ALKYL FUNCTIONAL-GROUP; MOLECULAR-DYNAMICS;
   TEMPERATURE; REAXFF; DECOMPOSITION; METHODOLOGY; DERIVATION; POLYMERS;
   BEHAVIOR},
Author-Email = {cody.bezik.ctr@us.af.mil
   vikas.varshney.2@us.af.mil},
Number-of-Cited-References = {74},
Times-Cited = {0},
Unique-ID = {WOS:001642295600001},
}

@article{ WOS:001640585000001,
Author = {Abdullah, Ahmed Choukri and Tasoglu, Savas},
Title = {ML-augmented Ti-based Microrobotic Stents},
Journal = {ADVANCED THEORY AND SIMULATIONS},
Year = {2025},
Month = {2025 DEC 17},
Abstract = {The integration of microrobotic stents into biomedical applications has
   the potential to revolutionize invasive procedures by enabling precise
   drug delivery, imaging, and vascular interventions. These interventions
   demand alloys with high radial stiffness for structural integrity and
   low density for biocompatibility. We developed a machine learning
   (ML)-finite element analysis (FEA) framework to optimize titanium
   (Ti)-based and Ti-based high-entropy alloys (Ti-HEAs) compositions using
   a curated database of 238 alloys. Gaussian process regression (GPR) is
   trained on FEA-simulated radial stiffness and constrained optimization
   (interior-point, sequential quadratic programming (SQP), active-set)
   identified high-performance candidates. The interior-point algorithm
   yielded the highest stiffness (483.54 kN/m) with balanced composition
   (Ti: 76.29 at\%, Nb: 6.88\%, Zr: 7.34\%, Ta: 7.31\%), outperforming the
   dataset maximum (TiSn 20, 472.49 kN/m) by 2.32\% and Ti-6Al-4 V (368.96
   kN/m) by 31\%. All algorithms converged to at least 469 kN/m despite
   compositional diversity, confirming robustness. The framework enables
   rapid, physics-informed alloy design for next-generation biomedical
   microrobotics.},
Type = {Article; Early Access},
Affiliation = {Tasoglu, S (Corresponding Author), Koc Univ, Dept Mech Engn, Istanbul, Turkiye.
   Tasoglu, S (Corresponding Author), Koc Univ, Is Bank Artificial Intelligence Lab KUIS AILab, Istanbul, Turkiye.
   Tasoglu, S (Corresponding Author), Koc Univ, Translat Med Res Ctr KUTTAM, Istanbul, Turkiye.
   Tasoglu, S (Corresponding Author), Bogazici Univ, Bogazici Inst Biomed Engn, Istanbul, Turkiye.
   Tasoglu, S (Corresponding Author), Koc Univ, Arcelik Res Ctr Creat Ind KUAR, Istanbul, Turkiye.
   Abdullah, Ahmed Choukri; Tasoglu, Savas, Koc Univ, Dept Mech Engn, Istanbul, Turkiye.
   Tasoglu, Savas, Koc Univ, Is Bank Artificial Intelligence Lab KUIS AILab, Istanbul, Turkiye.
   Tasoglu, Savas, Koc Univ, Translat Med Res Ctr KUTTAM, Istanbul, Turkiye.
   Tasoglu, Savas, Bogazici Univ, Bogazici Inst Biomed Engn, Istanbul, Turkiye.
   Tasoglu, Savas, Koc Univ, Arcelik Res Ctr Creat Ind KUAR, Istanbul, Turkiye.},
DOI = {10.1002/adts.202502105},
EarlyAccessDate = {DEC 2025},
Keywords = {finite element analysis (FEA); machine learning optimization; material
   property prediction; microrobotic stents; titanium alloys},
Keywords-Plus = {ANTERIOR CEREBRAL-ARTERY; PATHOGENESIS},
