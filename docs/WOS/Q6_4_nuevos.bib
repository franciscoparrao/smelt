   Habibi, Mostafa, Halic Univ, Fac Engn, Dept Mech Engn, Istanbul, Turkiye.
   Bai, Zhem, Inst Sci \& Design Al Kharj, Dubai, U Arab Emirates.},
DOI = {10.12989/anr.2025.19.6.607},
Keywords = {advanced composites; artificial neural networks; buckling analysis;
   functionally graded materials; nanoscale structures; protective
   equipment; sports engineering; stability prediction},
Keywords-Plus = {DRUG-DELIVERY; VIBRATION; RESISTANCE; PERFORMANCE; BEHAVIOR; OIL;
   NANOPARTICLES; SIMULATION; RESPONSES; CONCRETE},
