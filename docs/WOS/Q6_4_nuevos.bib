@article{ WOS:001559803200001,
Author = {Abbas, Yassir M. and Alharbi, Yousef R.},
Title = {Multiple-criteria optimization of ternary-cementitious concrete
   formulations: An evolutionary data-driven framework for
   high-performance, cost-efficiency, and sustainable designs},
Journal = {STRUCTURES},
Year = {2025},
Volume = {80},
Month = {OCT},
Abstract = {The need for sustainable concrete design has intensified as the
   construction industry strives to balance structural performance,
   economic feasibility, and environmental responsibility. This study
   addresses a critical research gap by integrating machine learning (ML)
   with the Non-dominated Sorting Genetic Algorithm II (NSGA-II) to
   optimize ternary cementitious concrete containing fly ash (FA) and blast
   furnace slag (BFS) formulations. A curated dataset comprising 1011
   concrete mixtures was used to develop predictive models for compressive
   strength (CS), total cost (TC), and CO2 emissions. To model CS, five
   state-of-the-art ML algorithms were evaluated for their predictive
   capabilities. The category boosting (CatBoost) emerged as the top
   performer (R2 = 0.98, MAE = 1.294, RMSE = 2.341) and was fine-tuned for
   robust generalization. The NSGA-II algorithm was applied to identify 38
   Pareto-optimal concrete mixtures, achieving a well-defined trade-off
   between maximizing CS while minimizing TC and CO2. Key features
   influencing CS included age of testing (AG), water-to-binder ratio (WB),
   aggregate-tobinder ratio (AB), and cement content (PC), collectively
   contributing over 75 \% to cumulative importance in Pareto analysis.
   Partial dependence plots highlighted the WB's nonlinear impact and PC's
   consistent enhancement of CS. Secondary features like FA and BFS
   demonstrated localized benefits that emphasize the role of supplementary
   cementitious materials in sustainable design. This study establishes a
   transformative framework for designing high-performance, low-carbon
   concrete. Future research should focus on experimental validation of the
   optimized designs, integration of lifecycle assessments, and inclusion
   of durability parameters such as environmental degradation and recycling
   potential.},
Type = {Article},
Affiliation = {Abbas, YM; Alharbi, YR (Corresponding Author), King Saud Univ, Coll Engn, Dept Civil Engn, Riyadh 12372, Saudi Arabia.
   Abbas, Yassir M.; Alharbi, Yousef R., King Saud Univ, Coll Engn, Dept Civil Engn, Riyadh 12372, Saudi Arabia.},
DOI = {10.1016/j.istruc.2025.109955},
EarlyAccessDate = {AUG 2025},
Article-Number = {109955},
Keywords = {Compressive strength; Machine learning; Non-dominated sorting genetic
   algorithm II; Supplementary cementitious materials; Sustainable concrete
   optimization},
Keywords-Plus = {STRENGTH; CO2; REDUCTION; SHRINKAGE; EMISSIONS; SYSTEMS; ENERGY},
Author-Email = {yabbas@ksu.edu.sa
   yrharbi@ksu.edu.sa},
Number-of-Cited-References = {124},
Times-Cited = {1},
Unique-ID = {WOS:001559803200001},
}

@article{ WOS:001586004500001,
Author = {Zhang, Pei-Fu and Zhang, Daxu and Zhao, Qi and Zhao, Xuan and
   Tuerxunmaimaiti, Yiliyaer},
Title = {A semantic-aware transfer learning framework via natural language
   processing to predict the cross-material bond strength of composite bars
   with limited data},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2025},
Volume = {160},
Number = {C},
Month = {NOV 27},
Abstract = {This study develops a novel transfer learning (TL) framework integrating
   natural language processing (NLP) and deep learning (DL) to predict the
   bond strength of fiber-reinforced polymer (FRP) composite bars in
   ultra-highperformance seawater sea-sand concrete (UHPSSC) using limited
   experimental data. The framework incorporates an NLP data processor to
   handle textual variables, a gated transformer to enhance parameter
   representations, and DL models for regression. Through leveraging the
   characteristics of seawater sea-sand concrete (SWSSC) and
   ultra-high-performance concrete (UHPC), it enables effective TL from
   large FRP-SWSSC/UHPC datasets to smaller FRP-UHPSSC datasets. Three
   pre-trained models were developed using FRP-SWSSC, FRP-UHPC, and
   combined datasets, respectively, and then fine-tuned on FRP-UHPSSC data
   to create three TL models. Compared with traditional machine learning
   (ML) models such as XGBoost and random forest (RF) trained directly on
   FRP-UHPSSC data, the proposed TL models achieved significantly higher
   predictive accuracy. Specifically, the optimal-performing TL model
   fine-tuned using combined FRP-SWSSC/UHPC data, achieved an R2 of 0.914
   and root mean square error (RMSE) of 0.75 on the test set, corresponding
   to a 13 \% increase in R2 and a 47.6 \% reduction in RMSE relative to
   the optimal ML model. Furthermore, NLP-based textual representation
   improved the TL model's test R2 from 0.876 to 0.914, highlighting the
   effectiveness in handling tabular data. The TL model also demonstrates
   semantic recognition capabilities, addressing variations in parameter
   expressions and dimensionality, enhancing robustness across scenarios.
   Overall, the proposed NLP-based TL framework effectively integrates
   heterogeneous material knowledge and substantially enhances predictive
   performance and generalization, offering a promising approach for
   data-limited engineering applications.},
Type = {Article},
Affiliation = {Zhang, DX (Corresponding Author), Shanghai Jiao Tong Univ, Sch Ocean \& Civil Engn, Shanghai Key Lab Digital Maintenance Bldg \& Infras, State Key Lab Ocean Engn, Shanghai 200240, Peoples R China.
