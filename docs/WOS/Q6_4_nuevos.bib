   Ahmadi, Fatemeh; Jafari, Atefeh, Western Univ, Dept Epidemiol \& Biostat, London, ON, Canada.
   Abdullah, Sheikh S., MacEwan Univ, Dept Comp Sci, Edmonton, AB, Canada.
   Abdullah, Sheikh S., London Hlth Sci Ctr, Res Inst, London, ON, Canada.
   Sedig, Kamran, Western Univ, Fac Informat \& Media Studies, London, ON, Canada.
   Muanda, Flory T., London Hlth Sci Ctr, Lawson Hlth Res Inst, London, ON, Canada.},
DOI = {10.1002/bcp.70377},
EarlyAccessDate = {DEC 2025},
Keywords = {adverse drug events; machine learning; outpatient; pharmacovigilance;
   predictive modelling; systematic review},
Keywords-Plus = {MODEL; VALIDATION; PROBAST; RISK; BIAS; TOOL},
Author-Email = {fmuandat@uwo.ca},
Number-of-Cited-References = {86},
