@article{ WOS:001722999100001,
Author = {Jia, Xiaoke and Chen, Li and Xiong, Kun and Wang, Yujie and Zhou, Linjie
   and Xu, Xiaohui and Li, Shuang and Wang, Mao and Thomas, Arne and Cheng,
   Chong},
Title = {Machine learning-accelerated discovery of covalent organic frameworks
   for hydrogen peroxide photosynthesis},
Journal = {NATURE SYNTHESIS},
Year = {2026},
Month = {2026 MAR 25},
Abstract = {Covalent organic frameworks (COFs) are promising photocatalysts for
   hydrogen peroxide (H2O2) production, yet their rational design remains
   challenging. Although machine learning has advanced the prediction of
   properties of porous materials, its application to COF-based
   photocatalysis faces two major challenges: the representation of
   multilevel structural features and the limited availability of training
   datasets. Here we present a comprehensive computational framework,
   termed `information co-evolution', that accelerates the discovery of
   efficient COF structures for H2O2 photosynthesis. This framework
   integrates two pathways: to mitigate data limitations, we introduce data
   augmentation techniques and ensemble modelling; concurrently, to address
   the structural encoding challenge, we introduce a cross-level feature
   fusion strategy that integrates these fragment descriptors with
   mechanism-driven physical descriptors. These strategies collectively
   reduced the validation root mean square error from 4.70 to 3.31. Among
   over 10,000 candidates, our framework can successfully identify
   high-performance COFs for H2O2 photosynthesis, for example, COF-343
