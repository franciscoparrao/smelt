@article{ WOS:001542416000026,
Author = {Huang, Sisi and Guo, Yusen and Huo, Pengyu and Li, Qiliang},
Title = {Redefining Vibration Sensing: AI-Driven Analytics, Self-Powered Systems,
   and Multimodal Fusion: A Review},
Journal = {IEEE SENSORS JOURNAL},
Year = {2025},
Volume = {25},
Number = {15},
Pages = {27922-27941},
Month = {AUG 1},
Abstract = {The evolution of vibration sensing technologies has driven critical
   advancements in structural safety monitoring (SSM), environmental
   vibration monitoring (EVM), human-machine interaction (HMI), and
   biomedical health monitoring (BHM). However, despite decades of
   progress, fundamental limitations persist: low-frequency signal
   attenuation, environmental instability, and the lack of self-powered
   solutions continue to constrain real-world applicability. Existing
   sensor technologies face inherent tradeoffs-piezoelectric sensors suffer
   from brittleness, piezoresistive sensors exhibit temperature drift,
   capacitive sensors struggle with long-term stability, triboelectric
   sensors remain limited by material degradation, and fiber-optic sensors
   face high costs and integration challenges. These challenges hinder the
   development of next-generation intelligent monitoring systems. This
   review presents a systematic, quantitative benchmarking of major
   vibration sensor technologies, comparing their performance in
   sensitivity, frequency response, environmental resilience, and
   scalability. Unlike conventional surveys, we bridge theoretical
   foundations with practical deployment challenges, revealing key trends
   in AI-assisted analytics, multimodal sensor fusion, and
   energy-autonomous architectures. Furthermore, we propose a roadmap for
   overcoming existing technological barriers, emphasizing bio-inspired
   materials, hybrid energy harvesting, and physics-informed machine
   learning for adaptive sensing. By redefining the intersection of sensor
   physics and intelligent systems, this work establishes a framework for
   the next generation of high-performance vibration sensors with enhanced
   robustness, precision, and sustainability.},
Type = {Article},
Affiliation = {Li, QL (Corresponding Author), Peking Univ, Coll Engn, Dept Adv Mfg \& Robot, Beijing 100871, Peoples R China.
   Huang, Sisi; Guo, Yusen; Huo, Pengyu; Li, Qiliang, Peking Univ, Coll Engn, Dept Adv Mfg \& Robot, Beijing 100871, Peoples R China.},
DOI = {10.1109/JSEN.2025.3579345},
Keywords = {Sensors; Vibrations; Intelligent sensors; Sensitivity; Optical fiber
   sensors; Monitoring; Capacitive sensors; Temperature sensors; Robot
   sensing systems; Triboelectricity; Application-driven sensing;
   cross-modal benchmarking; emergent sensing paradigms; vibration sensing
   technologies},
Keywords-Plus = {HIGH-SENSITIVITY; PRESSURE SENSOR; DESIGN; PERFORMANCE; FABRICATION;
   RESOLUTION; SKIN},
