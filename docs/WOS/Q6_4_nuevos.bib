   Liao, Shuheng, Chinese Univ Hong Kong, Dept Mech \& Automat Engn, Hong Kong, Peoples R China.
   Li, Xiang, China Iron \& Steel Res Inst Grp, Beijing 100081, Peoples R China.},
DOI = {10.1007/s00366-026-02290-9},
