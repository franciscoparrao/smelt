   Zhang, Shuyan, Natl Inst Extremely, Weak Magnet Field Infrastruct, Hangzhou 310051, Peoples R China.},
DOI = {10.1007/s40192-025-00408-3},
EarlyAccessDate = {JUL 2025},
Keywords = {Thermal spraying; Iron-based amorphous coating; Preparation process
   optimization; Machine learning},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; FLIGHT PARTICLE CHARACTERISTICS; CAVITATION
