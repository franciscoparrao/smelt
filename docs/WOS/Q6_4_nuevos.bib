@article{ WOS:001657926000001,
Author = {Rizehbandi, Shirin and Taghaddos, Hosein and Sadatnya, Amir},
Title = {An integrated machine learning and optimization framework for enhancing
   sustainable building design},
Journal = {ENERGY AND BUILDINGS},
Year = {2026},
Volume = {353},
Month = {FEB 15},
Abstract = {Designing energy-efficient buildings is crucial due to global concerns
   about energy. Early design decisions have a significant impact on a
   building's energy performance, often made with limited information.
   Traditional building performance simulation tools are costly and
   time-consuming. These challenges, along with the need for fully
   integrated optimization and simulation, make it difficult to assess a
   building's energy performance. This paper presents an integrated
   semi-automated framework that utilizes machine learning models and
   optimization techniques to facilitate early-stage design and promote
   efficient, sustainable decision-making. Multiple machine learning
   prediction models have been developed to predict building energy
   consumption and CO2 emissions. Then, the developed high-performance
   machine learning models are combined with optimization modules,
   including single-objective and multi-objective optimization, to identify
   optimized design solutions and their associated costs. The framework's
   validation through a case study and comparison to actual data ensures
   practical relevance, with the highest accuracy observed in the random
   forest and gradient boosting models.},
Type = {Article},
Affiliation = {Taghaddos, H (Corresponding Author), Univ Alberta, Dept Civil \& Environm Engn, Edmonton, AB, Canada.
   Taghaddos, H (Corresponding Author), Univ Tehran, Sch Civil Engn, Tehran, Iran.
