@article{ WOS:001617602500002,
Author = {Wen, Haocheng and Luo, Faxuan and Xu, Sheng and Wang, Bing},
Title = {JANC: A cost-effective, differentiable compressible reacting flow solver
   featured with JAX-based adaptive mesh refinement},
Journal = {COMPUTER PHYSICS COMMUNICATIONS},
Year = {2026},
Volume = {319},
Month = {FEB},
Abstract = {The compressible reacting flow numerical solver is an essential tool in
   the study of combustion, energy disciplines, as well as in the design of
   industrial power and propulsion devices. We have established the first
   JAXbased (a Python library developed by Google for accelerator-oriented
   array computation and highperformance numerical computing)
   block-structured adaptive mesh refinement (AMR) framework, called
   JAX-AMR, and then developed a fully-differentiable solver for
   compressible reacting flows, named JANC. JANC is implemented in Python
   and features automatic differentiation capabilities, enabling an
   efficient integration of the solver with machine learning. Furthermore,
   benefited by multiple acceleration features such as accelerated linear
   algebra (XLA)-powered Just-In-Time (JIT) compilation, GPU/TPU computing,
   parallel computing, and AMR, the computational efficiency of JANC has
   been significantly improved. In a comparative test of a twodimensional
   detonation tube case, the computational cost of the JANC core solver,
   running on a single A100 GPU, was reduced to 1\% of that of OpenFOAM,
   which was parallelized across 384 CPU cores. When the AMR method is
   enabled for both solvers, JANC's computational cost can be reduced to
   1-2\% of that of OpenFOAM. The core solver of JANC has also been tested
   for parallel computation on a 4-card A100 setup, demonstrating its
   convenient and efficient parallel computing capability. JANC also shows
   strong compatibility with machine learning by combining adjoint
   optimization to make the whole dynamic trajectory efficiently
   differentiable. JANC provides a new generation of high-performance,
   cost-effective, and high-precision solver framework for large-scale
   numerical simulations of compressible reacting flows and related machine
   learning research. Program summary Program title: JAX-AMR and JANC CPC
   Library link to program files: https://doi.org/10.17632/pkbxp5tm8w.1
   Developer's repository link: https://github.com/JA4S/JAX-AMR,
   https://github.com/JA4S/JANC Licensing provisions: MIT Programming
   language: Python Nature of problem: The numerical solution of
   compressible reactive flows plays a crucial role in combustion, energy
   utilization, and the design and manufacturing of propulsion systems.
   However, the multi-species nature, highly transient behavior, and strong
   numerical stiffness of reactive flows lead to significantly higher
   computational costs compared to conventional flow problems. In addition,
   conventional reactive flow solvers are typically built on Fortran or C++
   frameworks, making them difficult to integrate with data-driven methods
   based on existing Python ecosystems-particularly gradient-based
   optimization techniques such as machine learning. Although several
   JAX-based differential solver prototypes have been developed to address
   these issues, leveraging the multi-core computing power of GPUs and
   JAX's automatic differentiation framework for efficient and
   differentiable flow simulations, no JAX-based solver for compressible
   reactive flows has yet been developed. More critically, due to the
   multiscale nature of reactive flows, there is currently no adaptive mesh
   refinement (AMR) framework compatible with JAX, making large-scale,
   high-resolution simulations prohibitively expensive and difficult to
   perform. Solution method: We have developed JANC: A cost-effective,
   differentiable compressible reacting flows solver featured with
   JAX-based adaptive mesh refinement.
   JANC is a solver built on the JAX framework, fully leveraging JAX's XLA
   high-performance computing compilation and automatic differentiation
   capabilities, resulting in a significant speedup compared to traditional
   reactive flow solvers such as OpenFOAM. By incorporating adjoint-based
   optimization algorithms, our solver is efficiently compatible with
   existing differentiable optimization methods, offering lower memory
   consumption and faster differentiable computation. Building upon the
   solver, we propose JAX-AMR, a novel adaptive mesh refinement framework
   based on dynamically updated multi-level blocks with fixed locations and
   shapes. This framework is fully compatible with JAX's just-in-time (JIT)
   compilation and vectorization (vmap) operations, enabling efficient
   integration of AMR capabilities into the flow solver. In addition, our
   reactive flow solver supports multi-device parallelism to meet the
   demands of large-scale problems. JANC offers a high degree of
   customization and user-friendly interfaces for defining boundary
   conditions, source terms, and other problem-specific functions. JANC can
   be easily installed via pip install as a Python package, and the entire
   workflow for reactive flow simulation can be executed within a single
   Jupyter Notebook. Additional comments including restrictions and unusual
   features: Some functionalities of JANC rely on open-source third-party
   Python libraries, which are set to be automatically installed.
   Currently, JANC supports structured mesh computations on two-dimensional
   rectangular computational domains only. In future versions, we will
   incorporate features such as immersed boundaries, body-fitted meshes,
   and extend the framework to three dimensions. The JANC program has been
   practically tested within a Google Colab notebook environment.},
Type = {Article},
Affiliation = {Wen, HC; Luo, FX; Wang, B (Corresponding Author), Tsinghua Univ, Sch Aerosp Engn, Beijing 100084, Peoples R China.
   Wen, Haocheng; Luo, Faxuan; Xu, Sheng; Wang, Bing, Tsinghua Univ, Sch Aerosp Engn, Beijing 100084, Peoples R China.},
DOI = {10.1016/j.cpc.2025.109915},
EarlyAccessDate = {NOV 2025},
Article-Number = {109915},
Keywords = {JAX; Adaptive mesh refinement; Open source; Compressible reactive flow;
   Combustion; Computational fluid dynamics},
Keywords-Plus = {SIMULATION},
Author-Email = {haochengwenson@126.com
   luofx23@mails.tsinghua.edu.cn
   wbing@mail.tsinghua.edu.cn},
Number-of-Cited-References = {44},
Times-Cited = {1},
Unique-ID = {WOS:001617602500002},
}

@article{ WOS:001610755200001,
Author = {Ye, Jihong and Wang, Liwen and Tan, Shuhu and Ren, Xiaomin and Huang,
   Yongqing},
Title = {An AI-driven framework for the intelligent design of high-performance
   photodetectors},
Journal = {JOURNAL OF COMPUTATIONAL ELECTRONICS},
Year = {2025},
Volume = {25},
Number = {1},
Month = {NOV 10},
Abstract = {In this work, we propose an AI-driven framework for the automated and
   intelligent design of photodetectors, which significantly enhances
   design efficiency. Specifically, by integrating a high-accuracy machine
   learning (ML) model with a genetic algorithm (GA) and a decision-making
   technique (TOPSIS), this intelligent and automated approach eliminates
   the need for labor-intensive manual analysis and extensive physical
   prototyping, while simultaneously accounting for multiple interdependent
   parameters. The ML model is implemented as a backpropagation-trained
   multilayer perceptron (BP-MLP) neural network, which effectively
   captures the complex and nonlinear relationships between device
   structure and performance, enabling rapid and accurate prediction of
   device characteristics across various structural configurations.
   Building on this, the GA can rapidly identify the optimal device
   structure for specific performance targets. To demonstrate its
   effectiveness, we design two modified uni-traveling carrier
   photodetectors (MUTC-PDs): a high-speed device with a 3-dB bandwidth of
   246.1 GHz and a responsivity of 0.12 A/W, and a high-power device
   achieving a 3-dB bandwidth of 46.6 GHz and an RF output power of 31.82
   dBm at 30 GHz.},
Type = {Article},
Affiliation = {Huang, YQ (Corresponding Author), Beijing Univ Posts \& Telecommun, State Key Lab Informat Photon \& Opt Commun, Beijing 100876, Peoples R China.
   Ye, Jihong; Wang, Liwen; Tan, Shuhu; Ren, Xiaomin; Huang, Yongqing, Beijing Univ Posts \& Telecommun, State Key Lab Informat Photon \& Opt Commun, Beijing 100876, Peoples R China.},
DOI = {10.1007/s10825-025-02456-6},
Article-Number = {11},
Keywords = {Machine learning; Genetic algorithms; Photodiode; MUTC-PD},
Keywords-Plus = {PHOTODIODES; SATURATION},
Author-Email = {jhye@bupt.edu.cn
   2024110380@bupt.edu.cn
   shtan@bupt.edu.cn
   xmren@bupt.edu.cn
   yqhuang@bupt.edu.cn},
Number-of-Cited-References = {38},
