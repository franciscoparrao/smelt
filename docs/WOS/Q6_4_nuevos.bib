@article{ WOS:001656705700001,
Author = {Balavani, Kola and Padmavathy, N. and Bodasingi, Nalini},
Title = {Review of carbon nanotube on-chip interconnects in RLC prediction using
   artificial intelligence},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2026},
Volume = {50},
Month = {JAN},
Abstract = {Carbon nanotube based on-chip interconnects hold great promise for
   resolving the scalability problems associ ated with conventional metal
   interconnects in integrated circuits. They are a desirable option
   because of their unique mechanical, electrical, and thermal properties
   for creating dependable, low-power, high-speed intercon nects in
   upcoming nanoelectronic systems. As a result of their complex structure
   and behavior, it is still very difficult to estimate the resistance,
   inductance, and capacitance of interconnects or the RLC parameters
   collec tively. In the RLC parameter prediction for carbon nanotube
   on-chip interconnects, this review paper provides an extensive overview
   of recent advances and challenges. The present modeling approaches, such
   as deep learn ing, machine learning, and other analytical models, are
   first highlighted, which have helped in determining the key structural
   and electrical characteristics of carbon nanotubes that influence RLC
   prediction. Furthermore, the influences of several parameters on
   accuracy of RLC prediction, including contact resistance, defects,
   quantum effects, frequency dependence etc., are investigated. In
   conclusion, the paper recommends future directions to push the limits of
   RLC prediction for carbon nanotube on-chip interconnects and overcome
   current constraints. The analysis is conducted on a 22 nm technology
   node, and the estimated values indicate that compared to a traditional
   copper interconnect, the carbon nanotube on-chip interconnects had the
   lowest delay and power dissipation, measuring 46.902 ns and 0.314 mu W
   by mixed-wall carbon nanotubes. Therefore, by overcoming these
   challenges, carbon nanotube interconnects have the potential to
   fundamentally change the design and op timization of next-generation
   nanoelectronic systems, enabling the development of integrated circuits
   that are both extremely effective and energy-efficient circuits. The
   integration of advanced AI approaches, such as deep learning and
   Bayesian optimization, has significantly advanced the modeling of CNT
   interconnects. AI-enabled techniques facilitate accurate data-driven
   prediction of RLC parameters, reduce computational complexity, and
   enable predictive optimization of interconnect architectures. Unlike
   conventional analytical or numerical meth ods that are often limited by
   scalability and modeling assumptions, AI-based methodologies offer a
   robust and efficient framework for designing high-performance, reliable,
   and scalable nano electronic interconnect systems.},
Type = {Review},
Affiliation = {Padmavathy, N (Corresponding Author), Vishnu Inst Technol, Dept Elect \& Commun Engn, Bhimavaram, AP, India.
   Balavani, Kola, Jawaharlal Nehru Technol JNT Univ, Dept Elect \& Commun Engn, Kakinada, AP, India.
   Balavani, Kola, Lakireddy Bali Reddy Coll Engn, Dept Elect \& Commun Engn, Mylavaram, AP, India.
   Padmavathy, N., Vishnu Inst Technol, Dept Elect \& Commun Engn, Bhimavaram, AP, India.
   Bodasingi, Nalini, JNTU Coll Engn, Dept Elect \& Commun Engn, Gurajada Vizianagaram, AP, India.},
DOI = {10.1016/j.mtcomm.2025.114542},
EarlyAccessDate = {DEC 2025},
Article-Number = {114542},
Keywords = {Carbon nanotubes; Deep learning; Interconnects; Mixed carbon nanotubes;
   RLC prediction; Electronic circuits},
Keywords-Plus = {COPPER INTERCONNECTS; SINGLE-WALL; PERFORMANCE; GRAPHENE; FRAMEWORK;
   DESIGN; DELAY},
Author-Email = {padmavathy.n@vishnu.edu.in},
Number-of-Cited-References = {110},
Times-Cited = {0},
Unique-ID = {WOS:001656705700001},
}

@article{ WOS:001649708700001,
Author = {Li, Yuting and Bahamon, Daniel and Lozada-Hidalgo, Marcelo and Singh,
   Nirpendra and Geim, Andre K. and Vega, Lourdes F.},
Title = {Machine Learning-Accelerated Discovery of Proton-Conducting 2D Materials
   for Proton Exchange Membranes},
Journal = {ACS NANO},
Year = {2026},
Volume = {20},
Number = {1},
Pages = {719-730},
Month = {JAN 13},
Abstract = {Two-dimensional (2D) materials emerge as promising alternatives to
   conventional polymer-based proton exchange membranes (PEMs) due to their
   high proton conductivity, mechanical robustness, and surface tunability.
   Here we present an integrated framework combining ab initio molecular
   dynamics (AIMD) simulations and machine learning (ML) to accelerate the
   discovery of proton- and hydrogen-transport properties over 866
   nonmetallic 2D materials. Three ML models were trained using
   AIMD-derived permeation barriers from 488 materials, with Random Forest
   achieving the highest accuracy and revealing structure-property
   relationships that govern proton transport. Critical descriptors,
   including proton-atom distance, pore size, interlayer spacing, and
   electron affinity, emerged as key predictors of permeation behavior.
   H+/H2 selectivity through additional AIMD simulations allowed
   identifying 18 promising candidates, including the experimentally
   studied graphene and hexagonal boron nitride, thus supporting the
   robustness of our approach. Experimentally synthesized but barely
   explored materials, including 2D Si, Ge, TeC, TeCl, GeSe and CSe,
   emerged as strong candidates for proton conducting membranes. The
   framework further highlights theoretically stable compounds as
   unexplored opportunities for PEMs. By integrating atomic-scale
   simulations with data-driven models, this work provides both fundamental
   insights into proton permeation mechanisms and practical guidance for
   designing selective, high-performance nanomaterials for hydrogen energy
   technologies.},
Type = {Article},
Affiliation = {Vega, LF (Corresponding Author), Khalifa Univ Sci \& Technol, Res \& Innovat Ctr Graphene \& 2D Mat RIC 2D, Abu Dhabi 127788, U Arab Emirates.
