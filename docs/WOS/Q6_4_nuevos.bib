@article{ WOS:001717978200002,
Author = {Wang, Zheng and Li, Ruyu and Liu, Qiang and Wu, Mian and Wang, Gong and
   Han, Bing},
Title = {Ultrafast Laser Manufacturing of Microrobots (Invited)},
Journal = {LASER \& OPTOELECTRONICS PROGRESS},
Year = {2026},
Volume = {63},
Number = {3},
Month = {FEB},
Abstract = {Significance Microrobots, typically defined as robotic systems ranging
   in size from 1 mu m to 1 mm, have attracted increasing attention due to
   their potential in biomedical diagnosis, targeted drug delivery, and
   minimally invasive surgery. Their ability to operate within confined or
   complex biological environments requires the integration of structural
   design, driving mechanisms, and functional surfaces at the
   micro/nanoscale. Traditional fabrication methods face significant
   challenges in achieving such integration, particularly in realizing
   high-resolution three-dimensional (3D) architectures with multimaterial
   functionality. Ultrafast laser processing, especially femtosecond
   two-photon polymerization (fs-TPP), has emerged as a key enabling
   technology for the intelligent manufacturing of microrobots. With
   sub-micrometer precision, true 3D freeform fabrication, and adaptability
   to various photosensitive materials, fs-TPP enables programmable
   structural construction, multimodal actuation, and multifunctional
   surface integration. Building upon fs-TPP, intelligent manufacturing
   extends toward four-dimensional (4D) nanoprinting and multimaterial
   hybrid fabrication, which provide microrobots with programmable
   deformation, adaptive actuation, and dynamic functionality-essential
   characteristics for realizing next-generation micro/nanorobotic systems.
   Progress Recent research has demonstrated remarkable progress in
   fs-TPP-based microrobot manufacturing across structural design,
   actuation, and surface functionalization. Magnetically driven
   microrobots have become a research focus due to their high penetration
   depth, remote controllability, and minimal biological damage (Fig. 2).
   By embedding magnetic materials such as Ni, Fe, or NdFeB nanoparticles,
   microrobots can be manipulated through magnetic gradients or rotating
   magnetic fields to perform translation, rotation, or helical motion. For
   instance, Li et al. fabricated a porous, spiny microspherical robot via
   fs-TPP, whose hierarchical micro/nano features enhanced both magnetic
   responsiveness and cell adhesion efficiency. In another example, Wu et
   al. constructed a 3D helical magnetic robot using fs-TPP and magnetic
   alignment curing, enabling precise motion control under rotating
   magnetic fields. These advances demonstrate that fs-TPP enables
   customizable 3D geometries and tunable magnetization profiles for
   high-performance magnetic actuation. Optical actuation offers
   non-contact, high-resolution control by exploiting light-matter
   interactions in photothermal or photochemical responsive materials (Fig.
   3). Using fs-TPP, researchers can embed light-responsive regions within
   microstructures to realize reversible bending, twisting, or oscillation.
   For example, Deng et al. utilized 4D printing based on fs-TPP to
   fabricate carbon nanotube-hydrogel composites exhibiting fast
   photothermal deformation under near-infrared irradiation. Xin et al.
   proposed a dual-mode fs-laser strategy to integrate photothermal Ag
   nanoparticles into hydrogel joints, enabling independently controllable
   light-triggered deformation of multiple microactuators. Such hybrid
   optical systems demonstrate how fs-TPP-based intelligent manufacturing
   can integrate material composition, geometry, and response function at
   the voxel level for dynamic actuation control. Beyond magnetic and
   optical methods, fs-TPP fabrication supports the integration of diverse
   actuation strategies, including electric, acoustic, chemical, and
   biological mechanisms (Fig. 4).
   Electric-field-driven robots utilize electrophoretic or electroosmotic
   forces for precise particle manipulation in microfluidic environments.
   Acoustic actuation, leveraging ultrasound-induced acoustic streaming or
   microbubble oscillation, enables efficient motion within biocompatible
   media, with fs-TPP providing the means to fabricate high-precision
   resonant cavities and phononic lattices. Chemically powered robots rely
   on catalytic reactions-such as platinum-induced bubble propulsion or
   self-diffusiophoresis-to achieve autonomous motion, where fs-TPP can
   construct asymmetric cavities and catalytic deposition sites to enhance
   propulsion efficiency. Biohybrid actuation combines living
   microorganisms (e. g., sperm, bacteria, algae) with microstructures
   produced by fs-TPP, achieving natural propulsion and environmental
   adaptability while maintaining biocompatibility. These integrated
   systems illustrate the flexibility of fs-TPP in enabling multimodal,
   cross-physics-field actuation. Surface functionalization plays a crucial
   role in enhancing microrobot performance in sensing, adhesion, and
   biocompatibility. Fs-TPP facilitates both static and dynamic
   functionalization (Figs. 5 -6). Static functional surfaces are realized
   through laser-assisted patterning, nanoparticle embedding, or localized
   chemical modification, imparting permanent properties such as
   hydrophilicity, hydrophobicity, or catalytic activity. Dynamic surfaces,
   in contrast, are capable of reversible regulation under external stimuli
   (light, pH, temperature, or magnetic fields). For instance, fs-TPP has
   been employed to construct hydrogel-based dynamic interfaces that alter
   adhesion or wettability in response to pH changes, or to fabricate
   reconfigurable microtextures that modulate liquid transport and optical
   responses. The combination of fs-TPP precision structuring and
   responsive materials enables on-demand adaptation of surface functions,
   laying the foundation for multi-functional microrobotic systems.
   Conclusions and Prospects In summary, fs-TPP-based intelligent
   manufacturing has revolutionized the micro/nanorobotics field by
   enabling the direct fabrication of 3D multimaterial structures with
   programmable deformation and multifunctional integration. Compared with
   conventional top-down or lithographic processes, fs-TPP offers
   unparalleled spatial resolution, flexibility, and material
   compatibility, allowing seamless integration of magnetic, optical,
   acoustic, and chemical actuation mechanisms within a single
   microstructure. Despite these achievements, challenges remain in
   improving processing throughput, achieving large-scale parallel
   fabrication, and realizing precise control of material interfaces in
   multimaterial systems. Future developments are expected to focus on
   high-speed parallel fs-TPP systems, advanced photoresists with enhanced
   sensitivity and multi-response capability, and intelligent design
   frameworks integrating machine learning for structure-function
   optimization. Furthermore, the convergence of fs-TPP with 4D
   nanoprinting, multimaterial hybridization, and bioinspired fabrication
   will accelerate the realization of microrobots capable of autonomous
   navigation, targeted therapy, and adaptive environmental interaction.
   Ultimately, ultrafast laser intelligent manufacturing will drive
   microrobotics toward higher performance, multifunctionality, and
   clinical practicality-ushering in a new era of micro/nano-scale
   intelligent systems with transformative potential across biomedicine,
   microfluidics, and soft robotics.},
Type = {Article},
Affiliation = {Han, B (Corresponding Author), Shanghai Jiao Tong Univ, Inst Med Robot, Sch Biomed Engn, Shanghai 200240, Peoples R China.
   Wang, G (Corresponding Author), Hebei Univ Technol, Ctr Adv Laser Technol, Sch Elect \& Informat Engn, Tianjin 300401, Peoples R China.
   Wang, Zheng; Li, Ruyu; Liu, Qiang; Wu, Mian; Han, Bing, Shanghai Jiao Tong Univ, Inst Med Robot, Sch Biomed Engn, Shanghai 200240, Peoples R China.
   Wang, Zheng; Wang, Gong, Hebei Univ Technol, Ctr Adv Laser Technol, Sch Elect \& Informat Engn, Tianjin 300401, Peoples R China.},
DOI = {10.3788/LOP252035},
Article-Number = {0314007},
Keywords = {femtosecond laser fabrication; four-dimensional printing; microrobots;
   stimuli-responsive materials; functionalized surfaces},
Author-Email = {wanggong@hebut.edu.cn
   binghan@sjtu.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001717978200002},
}

@article{ WOS:001709479100001,
Author = {Zhou, Cetong and Mao, Zhouzhu and Cao, Taifeng and Zhang, Tuanwei and
   Xie, Jiale and Bai, Tianxiang and Du, Shiyu and Wang, Zhihua},
Title = {Machine learning-accelerated reverse design of a novel fine grain
   nickel-based superalloy with high γ′ volume fraction},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2026},
Volume = {51},
Month = {FEB},
Abstract = {Establishing the complex, non-linear relationship among composition,
   processing, microstructure, and performance poses significant challenges
   for traditional methods. In this study, we propose a machine learning
   (ML) framework for the rapid prediction of yield strength and inverse
   composition design of gamma `-strengthened nickel-based superalloys. A
   high-precision non-linear ML model was developed, achieving a
   coefficient of determination (R \& sup2;) of 0.95, with a prediction
   error in the test set of less than 5\%. Utilizing a simulated annealing
   algorithm (SA) for inverse design, we successfully developed a novel
   high-performance superalloy within the Ni-Co-Cr-Al-Ti system.
   Experimental results indicate that the designed alloy exhibits a yield
   strength of 920 MPa and an ultimate tensile strength of 1285 MPa at room
   temperature, surpassing the upper strength limits of conventional
   commercial counterparts. Furthermore, microstructure characterization
   and strengthening calculations reveal that the combination of fine
   grains (4.62 mu m) and a high volume fraction (similar to 70\%) of gamma
   ` phases contributes significantly to the alloy's exceptional strength.
   This methodology represents an efficient data-driven approach for
   accelerating the design of advanced superalloys.},
Type = {Article},
Affiliation = {Zhang, TW; Wang, ZH (Corresponding Author), Taiyuan Univ Technol, Inst Appl Mech, Coll Aeronaut \& Astronaut, Taiyuan 030024, Peoples R China.
   Zhang, TW; Wang, ZH (Corresponding Author), Taiyuan Univ Technol, Shanxi Key Lab Mat Strength \& Struct Impact, Taiyuan 030024, Peoples R China.
