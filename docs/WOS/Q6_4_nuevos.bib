@article{ WOS:001598667600001,
Author = {Yu, Yating and Zhang, Yi and Feng, Yijing and Leong, Zheng Hao and Pan,
   Junting and Su, Jianping and Li, Yeqing},
Title = {Using machine learning to deeply analyze the critical role of trace
   element additives in anaerobic digestion and guide the optimization of
   addition strategies},
Journal = {WATER RESEARCH},
Year = {2026},
Volume = {288},
Number = {B},
Month = {JAN 1},
Abstract = {Understanding the effects of trace elements (TEs) in anaerobic digestion
   (AD) can help maximize methane production. In this study, a database of
   AD systems with single and mixed TE additions was constructed for the
   first time, and a high-performance machine learning (ML) framework was
   designed to efficiently capture the relationships between substrate
   characteristics, operating conditions, TE characteristics, and methane
   production performance. In the single-additive system, the
   Bayesian-optimized stacking model of categorical boosting (CatBoost),
   light gradient boosting machine, and extreme gradient boosting (XGBoost)
   achieved the highest accuracy (R2 = 0.9537). In the mixed-additive
   system, the optimized CatBoost and XGBoost model performed best (R2 =
   0.9522). Based on the interpretability analysis, TE type, substrate
   type, and digestion time should be focused more on when optimizing
   cumulative methane production (CMP). In addition, Bayesian optimization
   was used to inverse design the trace element addition strategy (TEAS)
   and validate its application in batch and semi-continuous experiments.
   In the batch experiment, the CMP of the experimental group with the
   low-concentration mixed TEAS (8.51 mg/L Fe, 3.25 mg/L Co, 4.34 mg/L Ni,
