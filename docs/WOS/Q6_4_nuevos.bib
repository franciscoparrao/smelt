@article{ WOS:001598112500001,
Author = {Krichen, Mohamed and Ksibi, Hatem},
Title = {Compositional effects on phase and microstructural evolution during
   clay-sand sintering},
Journal = {NEXT MATERIALS},
Year = {2025},
Volume = {9},
Month = {OCT},
Abstract = {This study investigates the effect of fluxing oxides (Na2O, K2O, CaO,
   Fe2O3) on the sintering behavior of clay-sand composites derived from
   three Tunisian clays (AA: Weslatyia, AB: Bir Mcherga, AK: Kasserine),
   aiming to elucidate the role of vitrification in microstructural
   development and mechanical strengthening of ceramic materials. Samples
   were sintered under a controlled thermal cycle up to 1140 degrees C with
   a 60-min dwell, then characterized by scanning electron microscopy (SEM)
   and porosity measurements (0.198-0.071). Results indicate that moderate
   flux contents promote densification by lowering the vitrification
   temperature, whereas excessive flux causes deformation and premature
   pore closure. Experimental Young's modulus-temperature profiles were
   reproduced with 94 \% accuracy through numerical modeling. Activation
   energies, determined using a weighted group contribution method, ranged
   from 295 to 308 kJ/mol for pure clays and 503-518 kJ/mol for mixtures,
   indicating a transition from bulk diffusion to liquid-phase sintering.
   Machine learning models further outperformed traditional linear
   approaches (R-2 = 0.72), achieving a coefficient of determination of
   similar to 0.95 in modeling nonlinear sintering kinetics. The
   integration of experimental, numerical, and data-driven approaches
   provides a robust framework for the design and optimization of durable,
   high-performance ceramic composites.},
Type = {Article},
Affiliation = {Ksibi, H (Corresponding Author), Univ Sfax, IPEIS, P Box 1172, Sfax 3018, Tunisia.
