@article{ WOS:001619790100011,
Author = {Ashrafi, Bahare and Nakhaei-Kohani, Reza and Ebrahimi, Mohammad and
   Hadavimoghaddam, Fahimeh and Nedeljkovic, Dragutin and
   Hemmati-Sarapardeh, Abdolhossein and Mohaddespour, Ahmad and Atashrouz,
   Saeid},
Title = {CO2 solubility in ionic liquids: Bridging prediction and screening},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {6},
Month = {DEC},
Abstract = {Carbon dioxide (CO2) ranks among the most prevalent greenhouse gases in
   the planet's atmosphere. In recent years, ionic liquids (ILs) have
   emerged as promising solvents for COQ capture and gas sweetening
   technologies due to their tunable physicochemical properties and
   environmental compatibility. Precise estimation of COQ solubility in ILs
   using computational methods is critical for optimizing their application
   in carbon capture processes. This research investigates the efficacy of
   six advanced machine learning models as robust computational tools for
   forecasting COQ solubility across a diverse set of ILs under a wide
   range of thermodynamic conditions (271.11-453.15 K, 0.00001-100.12 MPa).
   The models were constructed using a dataset comprising 10368
   experimental data points, which detail COQ solubility in 170 distinct
   ILs, based on thermodynamic characteristics. The analysis reveals that,
   among the six algorithms evaluated, the Deep Gradient Boosting Machine
   (DeepGBM) stands out as the most precise, attaining a coefficient of
   determination (R2) of 0.9912 and a root mean square error (RMSE) of
   0.02249. Furthermore, the results highlight key trends: COQ solubility
   in ILs rises with higher pressure and diminishes with elevating
   temperature. Additionally, lengthening the alkyl chain on the cation was
   found to enhance solubility by expanding the non-polar domain and free
   volume, consistent with physical solubility mechanisms. The model's
   robustness was further validated using the leverage approach, which
   recognized only 1.85 \% of data points as suspected data, affirming its
   reliability across the dataset. The DeepGBM model exhibits high
   interpretability, as demonstrated by SHAP analysis, which provides clear
   insights into the factors influencing solubility predictions. Building
   on the predictive success of DeepGBM, the study extended its application
   to a screening phase targeting 1130 ILs, a significant expansion from
   the initial 170. The screening process utilized the validated model to
   extrapolate COQ solubility across the expanded IL library, incorporating
   diverse cation-anion combinations and functionalization patterns. This
   approach enabled the identification of high-performance ILs for COQ
   capture, with structural insights revealing that fluorinated anions and
   long-chain phosphonium cations significantly enhance solubility due to
   increased free volume and weak ion pairing. Conversely, polar anions and
   short-chain ammonium cations were associated with lower solubility
   unless chemically functionalized. Comparing the study's findings with
   traditional equations of state and other methodologies documented in
   existing literature revealed that the outcomes of this investigation
   demonstrate greater accuracy and a more thorough understanding of COQ
   solubility in ILs, positioning this study as a transformative tool for
   IL design in COQ capture applications, providing a data-driven
   foundation for sustainable engineering practices.},
Type = {Article},
Affiliation = {Hemmati-Sarapardeh, A (Corresponding Author), Shahid Bahonar Univ Kerman, Dept Petr Engn, Kerman, Iran.
   Mohaddespour, A (Corresponding Author), McGill Univ, Dept Chem Engn, Montreal, PQ H3A 0C5, Canada.
