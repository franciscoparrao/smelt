@article{ WOS:001701378100001,
Author = {Kalogeris, Ioannis},
Title = {Normalizing flows for Bayesian parameter inference in computational
   mechanics},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {171},
Month = {MAY 1},
Abstract = {Bayesian parameter inference is a key tool in computational mechanics
   for quantifying uncertainty in model parameters given observational
   data. However, traditional sampling-based methods such as Markov Chain
   Monte Carlo (MCMC) often suffer from high computational cost and poor
   scalability, particularly for complex, high-dimensional problems. These
   methods require a large number of forward model evaluations, and in
   computational mechanics, each evaluation typically involves solving
   partial differential equations via discretization schemes (e.g., finite
   elements or finite differences). Since a single simulation can take
   seconds to hours, such approaches can quickly become computationally
   prohibitive. In this study, we explore Normalizing Flows (NFs) as a
   modern, machine learning-based alternative for approximating posterior
   distributions in Bayesian inverse problems in computational mechanics.
   Specifically, we implement and evaluate three NF architectures:
   Real-valued Non-Volume Preserving (RealNVP) flows, Masked Autoregressive
   Flows (MAF), and Neural Spline Flows (NSF). Their performance is
   benchmarked against two widely adopted sampling-based approaches: the
   Metropolis-Hastings (MH) algorithm and Transitional Markov Chain Monte
   Carlo (TMCMC). Using numerical case studies from nonlinear structural
   mechanics and three-dimensional elasticity, we assess each method's
   ability to approximate posterior distributions under a fixed
   computational budget (i.e., a predefined number of model runs).
   Posterior accuracy is quantified via the L1 norm and the
   Kullback-Leibler divergence. Results show that NFs achieve accuracy
   comparable to classical MCMC methods, while being intrinsically scalable
   and thus capable of significantly accelerating computations in
   high-dimensional problems. When deployed on a small-scale
   High-Performance Computing (HPC) cluster, the proposed implementation
   achieved up to approximately \& times;102 speedup for 128 cores,
   demonstrating its strong parallel scalability. Among the examined
   architectures, the NSF demonstrates the highest accuracy, even
   surpassing MCMC results in certain cases. These findings demonstrate
   that Normalizing Flows provide a scalable and effective framework for
   Bayesian inference in computational mechanics.},
Type = {Article},
Affiliation = {Kalogeris, I (Corresponding Author), Natl Tech Univ Athens, Sch Mech Engn, Athens, Greece.
   Kalogeris, Ioannis, Natl Tech Univ Athens, Sch Mech Engn, Athens, Greece.},
DOI = {10.1016/j.engappai.2026.114263},
Article-Number = {114263},
Keywords = {Bayesian inference; Normalizing flows; Real-valued non-volume preserving
   flows; Masked autoregressive flows; Neural spline flows; Computational
   mechanics},
Keywords-Plus = {IDENTIFICATION; MODELS},
Author-Email = {ikalogeris@mail.ntua.gr},
Number-of-Cited-References = {56},
Times-Cited = {0},
Unique-ID = {WOS:001701378100001},
}

@article{ WOS:001703015000001,
Author = {Chu, Yangyang and Fang, Yun and Sun, Liangzhi and Zhang, Yang and Wang,
   Liujian and Han, Xiaomeng and Lv, Mou and Liu, Haixing and Xin, Kunlun
   and Wang, Weigang and Zhu, Yanping and Shu, Shihu},
Title = {AutoML democratizes water quality forecasting: Lowering expertise
   barriers},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2026},
Volume = {85},
Month = {APR},
Abstract = {Harmful algal blooms present a persistent threat to global water
   security. While advanced forecasting tools could help mitigate this
   risk, their widespread adoption is hindered by the extensive machine
   learning expertise required for their development and tuning. This study
   introduces the first application of Fast and Lightweight Automated
   Machine Learning (FLAML) framework to water quality forecasting and
   harmful algal bloom (HAB) early warning, specifically targeting
   blue-green algae and chlorophyll-a (Chl-a) concentrations. Our automated
   approach effectively democratizes predictive modeling by substantially
   reducing the need for manual architecture design and hyperparameter
   optimization. The FLAML framework achieves superior predictive accuracy,
   with blue-green algae forecasting attaining R2 = 0.982, RMSE = 1.71
   cells/mL, and MAPE = 1.72\%, while Chl-a prediction reached R2 = 0.991,
   RMSE = 0.013 mu g/L and MAPE = 0.5\%. These results substantially
   outperform the best deep learning baseline (CNN-LSTM: R2 = 0.874 for
   blue-green algae, R2 = 0.930 for Chl-a), as well as LSTM and Transformer
   architectures. Remarkably, this high performance is attained with a
   computational budget of only 600 s, drastically reducing the time and
   expertise barriers associated with traditional methods. The model also
   demonstrates robust performance across varying input time windows (6,
   12, 24, 36, and 48 h) and feature sets. This study establishes FLAML as
   a practical, efficient, and highly accessible solution for enabling
   real-time algal bloom forecasting in eutrophic drinking water
   reservoirs. The demonstrated performance suggests potential
   applicability for water utilities operating similar systems to implement
   advanced AI-driven management strategies with limited machine learning
   background. Validation across diverse climatic, hydrological, and
   trophic conditions is recommended before broader generalization.},
Type = {Article},
Affiliation = {Shu, SH (Corresponding Author), Donghua Univ, Coll Environm Sci \& Engn, Shanghai 201620, Peoples R China.
   Chu, Yangyang; Fang, Yun; Sun, Liangzhi; Zhang, Yang; Wang, Liujian; Han, Xiaomeng; Wang, Weigang; Zhu, Yanping; Shu, Shihu, Donghua Univ, Coll Environm Sci \& Engn, Shanghai 201620, Peoples R China.
