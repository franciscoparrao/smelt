   Pal, Sarika, Natl Inst Technol Uttarakhand, Elect \& Commun Engn, Srinagar 246174, India.},
DOI = {10.1109/JSTQE.2026.3669493},
Article-Number = {4600508},
Keywords = {Sensitivity; Plasmons; Photonic crystal fibers; Optical fiber sensors;
