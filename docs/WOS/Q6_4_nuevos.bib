@article{ WOS:001562403100001,
Author = {Xie, Zihao and Saboor, Abdul and Kwarteng, Francis and Arslonnazar,
   Khusenov and Saidalo, Saidakmalov and Hyun, Kuen Kee and Gadow, Samir I.
   and Chen, Lungang and Xiao, Rui and Luo, Zhicheng},
Title = {Integrated machine learning and genetic algorithm framework for
   optimizing methylcyclohexane dehydrogenation in liquid organic hydrogen
   carrier systems},
Journal = {INTERNATIONAL JOURNAL OF HYDROGEN ENERGY},
Year = {2025},
Volume = {169},
Month = {SEP 17},
Abstract = {The methylcyclohexane (MCH) dehydrogenation to toluene (TOL) is a key
   step in liquid organic hydrogen carrier (LOHC) systems, yet optimizing
   both catalyst properties and reaction conditions remains challenging due
   to their complex interdependencies. In this study, we present an
   integrated machine learning (ML)-genetic algorithm (GA) framework for
   the simultaneous optimization of MCH conversion and toluene selectivity
   across diverse catalyst-condition combinations. Trained on a curated
   dataset of 161 samples with 19 features from 20 literature sources, our
   XGBoost model accurately predicted conversion (R-2 = 0.962) and
   selectivity (R-2 = 0.991) across ten catalytic systems. By coupling this
   model with a non-dominated sorting genetic algorithm (NSGA-II), we
   explored over 20,000 candidate combinations and identified optimal
   regimes achieving >90 \% conversion and >85 \% selectivity for four
   catalyst systems. This ML-GA approach provides a robust, data-driven
   strategy for accelerating the design of high-performance catalytic
   systems in MCH dehydrogenation and broader LOHC applications.},
Type = {Article},
Affiliation = {Luo, ZC (Corresponding Author), Southeast Univ, Sch Energy \& Environm, MOE Key Lab Energy Thermal Convers \& Control, Nanjing 210096, Peoples R China.
   Xie, Zihao; Saboor, Abdul; Kwarteng, Francis; Chen, Lungang; Xiao, Rui; Luo, Zhicheng, Southeast Univ, Sch Energy \& Environm, MOE Key Lab Energy Thermal Convers \& Control, Nanjing 210096, Peoples R China.
