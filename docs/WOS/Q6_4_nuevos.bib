}

@article{ WOS:001648754500003,
Author = {Siddique, Rafat and Sidhu, Amandeep Singh and Klemczak, Barbara},
Title = {High strength concrete and the impact of metakaolin on its mechanical,
   durability and microstructural characteristics - A review},
Journal = {JOURNAL OF BUILDING ENGINEERING},
Year = {2026},
Volume = {118},
Month = {JAN 15},
Abstract = {High strength concrete (HSC), which is generally categorised by a low
   water-to-binder ratio and high cement content, has found widespread
   usage in infrastructure projects such as high rise buildings, precast
   constructions and long-span bridges. The study covers the fundamental
   characteristics of high strength concrete with a brief historical
   context. The present review study examines the importance of the role of
   metakaolin (MK) as a supplementary cementitious material in enhancing
   the performance of high strength concrete mix. The study critically
   evaluates the role of metakaolin on mechanical properties such as
   compressive strength, flexural strength, splitting tensile strength,
   modulus of elasticity, creep and toughness of high strength concrete. In
   terms of durability, the study also covers the effects of metakaolin on
   permeability and the damage caused by external chemical attacks
   (chlorides, sulfates, acids, carbonation) as well as internal attacks
   (alkali-silica reaction). The study also discusses the positive impact
   of metakaolin on the performance of high strength concrete under
   freeze-thaw cycles, and its contribution to increased electrical
   resistivity. The negative impact of MK on carbonation resistance, as
   well as its complex and dosage and temperature-dependent effect on the
   high-temperature performance of high strength concrete, is also examined
   in the study. A conceptual framework was established, which linked the
   results of the microstructural studies such as SEM-EDS, XRD, TGA and MIP
   to the macro properties. The study further explores predictive modeling
   for metakaolin based high strength concrete mixes, incorporating both
   regression and machine learning approaches to enhance the understanding
   of relationships among various mix design parameters. The synergistic
   effects of metakaolin with other supplementary materials such as silica
   fume, fly ash and glass powder were also evaluated to further maximize
   its potential in high strength concrete. The implications of the study's
   findings were discussed in relation to field conditions and the existing
   research gaps and future challenges were also identified.},
Type = {Review},
Affiliation = {Siddique, R (Corresponding Author), Thapar Inst Engn \& Technol, Civil Engn Dept, Patiala 147004, Punjab, India.
   Siddique, Rafat, Thapar Inst Engn \& Technol, Civil Engn Dept, Patiala 147004, Punjab, India.
   Sidhu, Amandeep Singh, Univ Padua, Dept Civil Environm \& Architectural Engn, Via Francesco Marzolo 9, I-35131 Padua, Italy.
   Klemczak, Barbara, Silesian Tech Univ, Fac Civil Engn, Akad 5, PL-44100 Gliwice, Poland.},
DOI = {10.1016/j.jobe.2025.114925},
EarlyAccessDate = {DEC 2025},
Article-Number = {114925},
Keywords-Plus = {SELF-COMPACTING CONCRETE; HIGH-PERFORMANCE CONCRETE; ALKALI-SILICA
   REACTION; FLY-ASH; COMPRESSIVE STRENGTH; HARDENED PROPERTIES; POZZOLANIC
   ACTIVITY; FUME; FRESH; HYDRATION},
