@article{ WOS:001672868600001,
Author = {Anaedevha, Roger Nick and Trofimov, Alexandre Gennadevich and
   Borodachev, Yuri Vladimirovich},
Title = {MambaShield: Selective state-space models for poisoning-resilient
   sequential modelling},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {308},
Month = {MAY 1},
Abstract = {Deep learning models achieve high accuracy in sequential prediction
   tasks but remain critically vulnerable to temporally orchestrated
   poisoning attacks, where accuracy can plummet from 95\% to below 40\%.
   This work presents MambaShield, a resilient, temporally aware
   architecture that attains linear-time complexity while delivering
   state-of-the-art adversarial robustness via selective state space models
   (SSMs). The proposed framework integrates four technical innovations:
   (1) a content-aware selective mechanism that adaptively filters 89\% of
   adversarial perturbations while preserving legitimate patterns; (2)
   Progressive Adversarial Robustness Distillation (PARD), which
   incrementally transfers defense capabilities from specialized teacher
   models to a unified student model using an adaptive schedule,
   alpha(t)=1-exp(-beta t); (3) hierarchical reinforcement learning to
   separate strategic and tactical decisions; and (4) PAC-Bayes-based
   certification, providing theoretical performance bounds under poisoning.
   A comprehensive evaluation on CIC-IoT-2023, CSE-CICIDS2018, and
   UNSW-NB15 using a 23-metric framework shows that MambaShield attains
   99.1\% clean accuracy and 97.3\% PAC-Bayes-bounded risk accuracy under
   poisoning (rho <= 0.3), while delivering 4.2 x faster inference than a
   Transformer baseline (L=1000), with limitations on sequences > 5000
   timesteps. Information-theoretic analysis confirms that MambaShield
   preserves 94.7\% mutual information between features and labels under
   attack, compared to 61.2\% for conventional recurrent models. These
   results establish a new foundation for trustworthy, high-performance
   deep learning in adversarial sequential modelling, with applications
   spanning network security, natural language processing, and time-series
   forecasting.},
Type = {Article},
Affiliation = {Anaedevha, RN (Corresponding Author), Natl Res Nucl Univ MEPhI, Moscow Engn Phys Inst, Moscow 115409, Russia.
   Anaedevha, Roger Nick; Trofimov, Alexandre Gennadevich, Natl Res Nucl Univ MEPhI, Moscow Engn Phys Inst, Moscow 115409, Russia.
   Borodachev, Yuri Vladimirovich, Natl Res Nucl Univ MEPhI, Artificial Intelligence Res Ctr, Moscow 115409, Russia.},
DOI = {10.1016/j.eswa.2026.131175},
EarlyAccessDate = {JAN 2026},
Article-Number = {131175},
Keywords = {Deep learning security; Selective state space models; Poisoning attacks
   and sequential modelling; PAC-Bayes theory; Progressive adversarial
   robustness distillation; Adversarial machine learning},
Keywords-Plus = {INTRUSION DETECTION},
Author-Email = {ar006@campus.mephi.ru
   agtrofimov@mephi.ru
   atrofimov@list.ru},
Number-of-Cited-References = {36},
