@article{ WOS:001654547600001,
Author = {Ali, Umar Farooq and Ali, Qasim and Ali, Asif and Noor, Hussain and
   Sohail, Usama and Haider, Sabah},
Title = {Integrated simulation and machine learning framework for
   high-performance lead-free RbGeI3 perovskite solar cells with
   WS2/CuI transport layers},
Journal = {JOURNAL OF COMPUTATIONAL ELECTRONICS},
Year = {2026},
Volume = {25},
Number = {1},
Month = {JAN 5},
Abstract = {The present work comprehensively investigates the design, optimization,
   and predictive modeling of a high-performance, lead-free RbGeI3-based
   perovskite solar cell employing WS2 as the ETL and CuI as the HTL.
   Numerical simulations performed using SCAPS-1D were validated against
   theoretical efficiency limits and electrostatic consistency checks,
   confirming the model's physical reliability. The device achieved an
   optimized eta of 24.15\%, with V-oc = 1.1184 V, J(sc) = 25.999 mA<middle
   dot>cm(-2), and FF = 83.09\%, demonstrating excellent charge extraction
   and minimal recombination losses. Systematic parametric analyses
   revealed the critical influence of absorber doping, transport layer
   defect density, resistive losses (R-s/R-sh), absorber thickness (t-Abs),
   defect density (Nt), temperature, and solar irradiance on overall
   performance. Optimal operation was achieved for Nt = 10(14) cm(-)(3),
   where light absorption and carrier transport are well balanced.
   Furthermore, machine learning (ML) algorithms, including XGBoost, random
   forest, and gradient boosting, were employed to predict photovoltaic
   outputs with near-perfect accuracy (R-2 approximate to 1.0). The XGBoost
   model successfully identified absorber defect density, series
   resistance, and illumination intensity as the most dominant
   performance-determining features. The results demonstrate that the
   synergistic combination of WS2/CuI transport layers and ML-guided
   optimization establishes a promising framework for stable, efficient,
   and eco-friendly RbGeI3-based PSCs, paving the way for next-generation
   lead-free photovoltaic technologies.},
Type = {Article},
Affiliation = {Ali, UF (Corresponding Author), Univ Punjab, Ctr Excellence Solid State Phys, Lahore 54590, Pakistan.
   Ali, Umar Farooq; Ali, Asif; Noor, Hussain; Sohail, Usama, Univ Punjab, Ctr Excellence Solid State Phys, Lahore 54590, Pakistan.
   Ali, Qasim, Acad Sinica, Inst Phys, Taipei 11529, Taiwan.
   Haider, Sabah, Univ Punjab, Inst Chem, Lahore 54590, Pakistan.},
DOI = {10.1007/s10825-025-02476-2},
Article-Number = {37},
Keywords = {RbGeI3 PSCs; Lead-free photovoltaics; SCAPS-1D simulation; Machine
   learning optimization; WS2/CuI transport layers; Charge transport and
   recombination dynamics},
Keywords-Plus = {ELECTRON-TRANSPORT; RANDOM FOREST; REGRESSION; DESIGN; IODIDE; TREES},
Author-Email = {umar.cssp.pu@gmail.com},
Number-of-Cited-References = {77},
