@article{ WOS:001709452000001,
Author = {Merc, Kevser Eylul and Ekici, Berk},
Title = {High-performance envelopes in the Mediterranean: Energy and comfort
   effects of BIPVs, shading devices, and green walls},
Journal = {ENERGY AND BUILDINGS},
Year = {2026},
Volume = {358},
Month = {MAY 1},
Abstract = {This study addresses the challenge of improving building envelope
   performance in Mediterranean climates, where dynamic seasonal changes
   require innovative solutions. The review examines the potential of
   highperformance building envelope applications, including
   building-integrated photovoltaics (BIPVs), shading devices, and vertical
   green walls, to enhance energy efficiency, comfort, and minimize
   environmental impact. While previous studies have predominantly focused
   on individual systems, this review considers a holistic approach by
   examining both separate and combined applications. The findings indicate
   that BIPV systems significantly enhance energy production, while shading
   devices mitigate overheating and enhance thermal and visual comfort.
   Additionally, vertical green walls enhance building performance by
   providing insulation and contributing to environmental benefits. The
   integration of these systems demonstrates synergistic potential to
   achieve multiple performance objectives, including energy savings,
   enhanced indoor comfort, and reduced emissions. However, the review
   identifies critical gaps in the literature, such as a lack of
   integration of holistic systems, limited consideration of future climate
   scenarios, and underutilization of optimization algorithms and machine
   learning in high-performance building envelope studies. Future research
   should lead to the development of adaptive design strategies, modular fa
   \& ccedil;ade systems, holistic use of various applications, and
   incorporation of future climate predictions to ensure long-term
   sustainability. This study highlights the importance of developing
   integrated, high-performance building envelopes that adapt to changing
   environmental and climatic conditions. In conclusion, this review offers
   a comprehensive framework for advancing sustainable building practices
   in Mediterranean climates, providing valuable insights for architects
   and engineers seeking to create energy-efficient and resilient built
   environments.},
Type = {Review},
Affiliation = {Merç, KE (Corresponding Author), Izmir Inst Technol, Dept Architecture, Gulbahce Campus, TR-35430 Izmir, Turkiye.
   Merc, Kevser Eylul; Ekici, Berk, Izmir Inst Technol, Dept Architecture, Gulbahce Campus, TR-35430 Izmir, Turkiye.},
DOI = {10.1016/j.enbuild.2026.117222},
Article-Number = {117222},
Keywords = {Building envelope; Energy efficiency; Building performance; Photovoltaic
   panel; Shading device; Green wall; Mediterranean},
Keywords-Plus = {RESIDENTIAL BUILDINGS; PASSIVE SYSTEMS; VISUAL COMFORT; DESIGN;
