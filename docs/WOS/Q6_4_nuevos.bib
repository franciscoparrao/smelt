   Ghazouani, Nejib, Northern Border Univ, Min Res Ctr, Ar Ar 73213, Saudi Arabia.
   Albaijan, Ibrahim, Prince Sattam Bin Abdulaziz Univ, Coll Engn Al Kharj, Mech Engn Dept, Al Kharj 16273, Saudi Arabia.},
DOI = {10.1038/s41598-025-19741-w},
