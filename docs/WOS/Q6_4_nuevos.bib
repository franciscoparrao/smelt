   Ji, Tianyi, Southern Univ Sci \& Technol, Dept Mech \& Energy Engn, Shenzhen 518055, Peoples R China.},
DOI = {10.1016/j.est.2025.117238},
EarlyAccessDate = {AUG 2025},
Article-Number = {117238},
Keywords = {Initial coulombic efficiency; Sodium-ion battery; Deep Gaussian process;
   Few-shot learning; SHAP analysis},
Author-Email = {jity@sustech.edu.cn},
