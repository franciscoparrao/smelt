   Khan, Adnan, Southeast Univ, Sch Transportat, Nanjing, Peoples R China.},
DOI = {10.1177/08927057261434862},
EarlyAccessDate = {MAR 2026},
Keywords = {Shear-thickening fluids (STFs); hexagonal boron nitride (h-BN)
