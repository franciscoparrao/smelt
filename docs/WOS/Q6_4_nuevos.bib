Keywords = {Vitrimer; Nanocomposites; MWCNTs; Cobalt ferrite; EMI shielding;
   Self-healing; Reprocessability},
Keywords-Plus = {CARBON; PERCOLATION; COMPOSITE; NETWORKS},
Author-Email = {sreekanth.ms@vit.ac},
