   Bismarck, Alexander, Univ Vienna, Inst Mat Chem \& Res, Fac Chem, Polymer \& Composite Engn PaCE Grp, Wahringer Str 42, A-1090 Vienna, Austria.},
DOI = {10.1016/j.carbon.2025.121138},
EarlyAccessDate = {DEC 2025},
