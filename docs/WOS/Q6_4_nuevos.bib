DOI = {10.1016/j.ceja.2025.100932},
EarlyAccessDate = {OCT 2025},
Article-Number = {100932},
Keywords = {Fixed-bed adsorption; Malachite green; Superparamagnetic activated
   carbon; Machine learning; Wastewater treatment},
Keywords-Plus = {METHYLENE-BLUE; DYE REMOVAL; COLUMN},
Author-Email = {ramesh.v@manipal.edu
   raja.s@manipal.edu},
Number-of-Cited-References = {64},
