Keywords = {Compressive strength; Geopolymer mortar; Machine learning; Portland
   cement; Sustainable construction materials; Teff straw ash},
Keywords-Plus = {RICE HUSK ASH; CURING TEMPERATURE; CONCRETE; NAOH; INDUSTRIAL; SLAG},
