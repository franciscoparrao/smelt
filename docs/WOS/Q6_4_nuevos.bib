   Shami, Abdallah, Western Univ, Dept Elect \& Comp Engn, London, ON N6A 3K7, Canada.
   Ong, Lyndon, Ciena, Hanover, MD 21076 USA.},
DOI = {10.1109/TCOMM.2025.3547764},
