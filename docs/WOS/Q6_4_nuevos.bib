@article{ WOS:001724226300002,
Author = {Zhang, Zhiyue and Liu, Zhiyu and Li, Yanshuai and Sun, Fanghong and Wu,
   Chun and Dong, Shizhi},
Title = {Machine learning-assisted screening of transition metal-doped nickel
   phosphide electrocatalysts for hydrogen evolution reaction},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2026},
Volume = {1061},
Month = {APR 5},
Abstract = {The lack of quantitative structure-activity relationships for
   metal-doped nickel phosphide electrocatalysts in the hydrogen evolution
   reaction (HER) remains a critical challenge. To address this gap, we
   develop an eXtreme Gradient Boosting (XGB) model to predict catalytic
   performance and identify the key physical descriptors governing HER
   activity. The model achieves a coefficient of determination (R2) of 0.88
   and a root-mean-square error (RMSE) of 6.05 mV on the test set,
   demonstrating robust predictive generalization. Feature importance
   analysis identifies the variance in the outermost D-electron count
   (delta DE) as the dominant descriptor regulating HER activity.
   Experimental validation of three top-performing predicted
   catalysts-using XRD, ICP-OES, and intrinsic electrochemical
   characterization-confirms the model's accuracy and establishes a
   quantitative link between delta DE and catalyst structural evolution.
   This work provides a robust machine-learning-driven framework for the
   efficient screening of high-performance HER electrocatalysts, and the
   identified descriptors offer quantitative guidelines for rational
   catalyst design.},
Type = {Article},
Affiliation = {Wu, C; Dong, SZ (Corresponding Author), Liaoning Tech Univ, Coll Mat Sci \& Engn, Fuxin 123000, Peoples R China.
   Zhang, Zhiyue; Li, Yanshuai; Wu, Chun; Dong, Shizhi, Liaoning Tech Univ, Coll Mat Sci \& Engn, Fuxin 123000, Peoples R China.
