   Yuan, Mengqi, Beijing Inst Technol, Chongqing Innovat Ctr, Chongqing 401120, Peoples R China.},
DOI = {10.1016/j.dt.2025.04.009},
Keywords = {Re-entrant honeycomb; Hybrid structures; Inverse design; Impact
