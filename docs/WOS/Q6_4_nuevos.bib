   Al-Nafjan, Abeer, Imam Mohammad Ibn Saud Islamic Univ IMSIU, Coll Comp \& Informat Sci, Comp Sci Dept, Riyadh 11432, Saudi Arabia.},
DOI = {10.3390/ai6090205},
Article-Number = {205},
