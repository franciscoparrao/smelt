@article{ WOS:001712016800001,
Author = {Wang, Min and Lei, Liming and Zhao, Cenkai and Cao, Ning and Zhang,
   Kunye and Zou, Jiexin and Chen, Ling and Jiang, Hao and Wu, Mingbo},
Title = {From Spent Batteries to Green Hydrogen: Catalytic Upcycling of
   Lithium-Ion Battery Cathodes for Water Electrolysis},
Journal = {ADVANCED MATERIALS},
Year = {2026},
Month = {2026 MAR 12},
Abstract = {The accelerating global ``dual-carbon{''} transition and the rapid
   proliferation of electric vehicles are driving an unprecedented surge in
   spent lithium-ion batteries (LIBs), with the first major retirement peak
   expected around 2030. Cathode materials form a pivotal bridge between
   urban mining and green-hydrogen technologies, coupling environmental
   risks with the strategic importance of critical metals. This review
   delivers a comprehensive overview of the recycling and upcycling
   landscape for the three dominant cathode families-LiCoO2,
   LiNixCoyMn1-x-yO2, and LiFePO4. We outline the compositional and
   structural features of these materials, evaluate pretreatment protocols,
   and critically compare pyrometallurgical, hydrometallurgical, and
   direct-regeneration strategies. We then highlight how multiscale
   structure-activity correlations guide the transformation of regenerated
   cathodes into high-performance electrocatalysts, with emphasis on defect
   engineering, electronic-structure modulation, interfacial coupling, and
   the assembly of conductive networks to accelerate both hydrogen- and
   oxygen-evolution pathways. Finally, we propose a forward-looking design
   framework that integrates atomic-site dynamics, multimetallic synergy,
   and process-environment co-optimization, while underscoring emerging
   opportunities in machine-learning-guided inverse design, operando
   mechanistic mapping, and device-level implementation. This review
   provides a conceptual blueprint for integrating battery recycling with
   green-hydrogen production in a closed-loop materials ecosystem.},
Type = {Review; Early Access},
Affiliation = {Wang, M; Wu, MB (Corresponding Author), China Univ Petr East China, Coll New Energy, Qingdao, Shandong, Peoples R China.
   Jiang, H (Corresponding Author), East China Univ Sci \& Technol, Key Lab Ultrafine Mat, Minist Educ, Shanghai, Peoples R China.
   Jiang, H (Corresponding Author), Xinjiang Univ, Sch Chem Engn, Urumgi, Xinjiang, Peoples R China.
   Wu, MB (Corresponding Author), Qingdao Univ Sci \& Technol, Coll Chem Engn, Qingda, Shandong, Peoples R China.
   Wang, Min; Lei, Liming; Zhao, Cenkai; Cao, Ning; Zhang, Kunye; Zou, Jiexin; Wu, Mingbo, China Univ Petr East China, Coll New Energy, Qingdao, Shandong, Peoples R China.
   Chen, Ling; Jiang, Hao, East China Univ Sci \& Technol, Key Lab Ultrafine Mat, Minist Educ, Shanghai, Peoples R China.
   Jiang, Hao, Xinjiang Univ, Sch Chem Engn, Urumgi, Xinjiang, Peoples R China.
   Wu, Mingbo, Qingdao Univ Sci \& Technol, Coll Chem Engn, Qingda, Shandong, Peoples R China.},
DOI = {10.1002/adma.202523322},
EarlyAccessDate = {MAR 2026},
