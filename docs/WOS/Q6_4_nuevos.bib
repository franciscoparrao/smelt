   Kaempfe, Thomas, Fraunhofer IPMS, Ctr Nanoelect Technol, D-01099 Dresden, Germany.
   Kaempfe, Thomas, TU, Inst CMOS Design, D-38092 Braunschweig, Germany.
   Ni, Kai, Univ Notre Dame, Elect Engn Dept, Notre Dame, IN 46556 USA.
   Zhuo, Cheng, Zhejiang Univ, Coll Integrated Circuits, Hangzhou 311200, Peoples R China.},
DOI = {10.1109/TC.2025.3576941},
Keywords = {Bayes methods; FeFETs; Engines; Computational modeling; Nonvolatile
   memory; Logic gates; Hardware; Sensors; Performance evaluation; Energy
   efficiency; Bayesian inference; ferroelectric FET; feature selection;
   in-memory computing},
Keywords-Plus = {FEATURE-SELECTION},
