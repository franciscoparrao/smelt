DOI = {10.1016/j.mtcomm.2026.114934},
Article-Number = {114934},
Keywords = {Nickel-based superalloy; Machine learning; Yield strength prediction;
   Composition optimization; Low density},
Keywords-Plus = {DEFORMATION MECHANISMS; TENSILE PROPERTIES; MICROSTRUCTURE; TEMPERATURE;
   BEHAVIOR; MODEL; PREDICTION; ELEMENTS},
Author-Email = {zhangtuanwei@tyut.edu.cn
   wangzh@tyut.edu.cn},
Number-of-Cited-References = {60},
