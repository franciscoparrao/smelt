@article{ WOS:001595699300001,
Author = {Rodriguez, Aaron and Cruz, Abdiel and Gonzalez, Stephanie and Vargas,
   Stephanie and Lopez, Alexis and Arroyo, Sabina and Lin, Yirong and
   Renteria, Anabel},
Title = {Prediction of the beta phase content of PVDF/BTO/MWCNT composites
   fabricated by phase immersion-direct Ink writing},
Journal = {JOURNAL OF MATERIALS SCIENCE-MATERIALS IN ELECTRONICS},
Year = {2025},
Volume = {36},
Number = {29},
Month = {OCT 18},
Abstract = {Enhancing the beta-phase content in polyvinylidene fluoride (PVDF)
   composites is crucial for improving the piezoelectric performance of
   sensors and actuators. However, conventional optimization approaches
   depend on repeated experimental trials, which are costly,
   time-consuming, and often limited in their ability to capture complex
   parameter interactions. To overcome these challenges, a Gaussian Process
   (GP) surrogate model was implemented to predict beta-phase content in
   PVDF/barium titanate (BTO)/multi-wall carbon nanotubes (MWCNTs)
   composites via phase immersion-direct ink writing (PI-DIW). The GP
   framework was chosen for its ability to model non-linear responses,
   quantify prediction uncertainty, and guide efficient exploration of the
   design space. The surrogate model identified optimal conditions of 26.62
   wt.\% BTO, 7 wt.\% MWCNT, 103 degrees C, and 7.45 kV/mm. Under these
   parameters, the composites achieved an experimentally validated
   beta-phase fraction of 84.44\% with 97.6\% model accuracy. This study
   demonstrates a novel integration of additive manufacturing and machine
   learning optimization, providing a powerful framework for accelerating
   the design of high-performance piezoelectric polymers.},
Type = {Article},
Affiliation = {Renteria, A (Corresponding Author), Univ Texas El Paso, Dept Aerosp \& Mech Engn, El Paso, TX 79968 USA.
   Rodriguez, Aaron; Cruz, Abdiel; Gonzalez, Stephanie; Vargas, Stephanie; Lopez, Alexis; Arroyo, Sabina; Lin, Yirong; Renteria, Anabel, Univ Texas El Paso, Dept Aerosp \& Mech Engn, El Paso, TX 79968 USA.},
