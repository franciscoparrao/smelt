@article{ WOS:001524661400001,
Author = {Yang, Sirui and Zhang, Guangpeng},
Title = {Optimization method for epoxy concrete formula based on GA-BP neural
   network},
Journal = {JOURNAL OF THE CHINESE INSTITUTE OF ENGINEERS},
Year = {2026},
Volume = {49},
Number = {1},
Pages = {79-93},
Month = {JAN 2},
Abstract = {This study addresses the critical challenge of optimizing aggregate
   structures to enhance the compressive strength of epoxy resin concrete
   (Resin E-51 content: 14\%) under uniaxial loading. Traditional
   experimental methods for analyzing multi-scale aggregate interactions
   are computationally intensive and lack predictive capability. To resolve
   this, we developed a hybrid computational framework integrating
   numerical simulation with machine learning. First, gray relational
   analysis quantified the influence of aggregate parameters on mechanical
   performance, revealing significant correlations (relational coefficients
   > 0.5) between fractal dimension, gradation, and strength. Subsequently,
   a genetic algorithm-optimized backpropagation (GA-BP) neural network
   with 5-12-1 architecture was established, where genetic algorithms
   optimized initial weights and thresholds to overcome local minima
   limitations of conventional BP models. The GA-BP model demonstrated
   superior predictive accuracy, reducing average compressive strength
   prediction errors by 78.2\% (from 7.0154 MPa to 1.5287 MPa) compared to
   standalone BP networks. Systematic parameter optimization identified the
   ideal aggregate configuration: coarse aggregate size = 10 mm, medium
   aggregate = 5 mm, fine aggregate = 2 mm, fractal dimension = 2.55, and
   total aggregate content = 85\%. These findings provide a mechanistic
   understanding of aggregate-structure-property relationships while
   offering an efficient machine learning-driven framework for designing
   high-performance resin-based composites, with direct implications for
   infrastructure and construction material optimization.},
Type = {Article},
Affiliation = {Zhang, GP (Corresponding Author), Xian Univ Technol, Sch Mech \& Precis Instrument Engn, 5 Jinhua South Rd, Xian 710048, Peoples R China.
   Yang, Sirui; Zhang, Guangpeng, Xian Univ Technol, Sch Mech \& Precis Instrument Engn, 5 Jinhua South Rd, Xian 710048, Peoples R China.},
DOI = {10.1080/02533839.2025.2526078},
EarlyAccessDate = {JUL 2025},
Keywords = {Resin concrete; simulation; correlation degree; GA-BP neural network;
   strength prediction},
Author-Email = {gpzhang@xaut.edu.cn},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001524661400001},
}

@article{ WOS:001528914800001,
Author = {Alzaabi, Sara and Elkamel, Ali and Karanikolos, Georgios N. and
   Alhammadi, Ali},
Title = {Accelerating sodium-ion electrode material development through AI-driven
   optimization and predictive modeling},
Journal = {ENERGY AND AI},
Year = {2025},
Volume = {21},
Month = {SEP},
Abstract = {Sodium-ion batteries (SIBs) are gaining traction as a cost-effective and
   sustainable alternative to lithium-ion batteries for large-scale energy
   storage, due to sodium's abundance, low cost, and safety advantages.
   However, the discovery of high-performance electrode materials for SIBs
   remains a significant challenge because of the complex interactions
   between compositional and structural features that govern key properties
   such as specific capacity, average voltage, and volume change. In this
   study, we present an artificial intelligence (AI)-driven framework that
   integrates machine learning and multi-objective optimization to
   accelerate the design of sodium-ion battery electrodes. Four predictive
   models, namely Decision Tree, Random Forest, Support Vector Machine
   (SVM), and Deep Neural Network (DNN), were trained on a feature-rich
   dataset derived from high-throughput computational databases. The DNN
   model achieved the highest predictive accuracy, with R2 values up to
   0.97 and mean absolute errors (MAE) below 0.11 for the target
   properties. To support material selection, the DNN was coupled with the
   Non-dominated Sorting Genetic Algorithm II (NSGA-II) to identify
   Pareto-optimal materials that maximize specific capacity while
   minimizing volume expansion. The resulting candidates exhibit balanced
   electrochemical performance and potential for practical SIB
   applications. This study demonstrates the power of combining deep
   learning and optimization to guide the discovery of next-generation
   energy storage materials with high efficiency and reduced experimental
   overhead.},
Type = {Article},
Affiliation = {Alzaabi, S (Corresponding Author), Khalifa Univ Sci \& Technol, Dept Civil Engn, Abu Dhabi 127788, U Arab Emirates.
