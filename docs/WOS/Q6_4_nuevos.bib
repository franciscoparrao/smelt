@article{ WOS:001689381000001,
Author = {Zhang, Yichen and Niu, Haoshuang},
Title = {Performance and sustainable utilization analysis of molybdenum tailings
   sand in self-compacting concrete based on machine learning},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2026},
Volume = {222},
Month = {MAR},
Abstract = {The sustainable utilization of industrial solid waste has become an
   important pathway to achieving low-carbon construction. This study
   investigates the performance evolution and sustainability benefits of
   Molybdenum Tailings Sand Self-Compacting Concrete (MTs-SCC) through an
   integrated framework combining laboratory experiments, machine learning
   prediction, and multi-objective optimization. A total of 120 mixture
   designs were developed with varying sand ratio (42\%-50\%), MTs
   replacement (0\%-100\%), water-binder ratio (0.35-0.42), and
   superplasticizer dosage (0.4\%-1.0\%). The experimental results showed
   that the 28-day compressive strength ranged from 61.5 MPa to 76.5 MPa,
   slump flow from 640 to 755 mm, and segregation index below 6\%. The
   hybrid XGBoost-DNN model achieved excellent predictive accuracy (R2 =
   0.972, MAE = 1.70 MPa) and stable convergence within 400 epochs. SHAP
   interpretability analysis revealed that MTs replacement had the greatest
   contribution (mean SHAP = 0.41) to compressive strength, followed by
   water-binder ratio (0.26) and sand ratio (0.19). Multi-objective
   optimization using NSGA-II indicated that a 30\%-40\% MTs replacement
   range provided an optimal balance between mechanical performance,
   flowability, and sustainability, achieving a 20\% reduction in Global
   Warming Potential (GWP) and a 9\% decrease in material cost. The
   optimized mix proportions obtained from the Pareto-optimal solution set
   were further verified against experimental results, showing good
   agreement between predicted and measured mechanical and workability
   performance, which confirms the reliability of the proposed optimization
   framework for engineering application. Life Cycle Assessment (LCA)
   confirmed that the optimized MTs-SCC exhibited lower environmental loads
   in GWP, AP, and EP indices while maintaining excellent workability. The
   integration of data-driven modeling and optimization establishes a
   robust framework for designing eco-efficient and high-performance
   concretes utilizing tailing resources.},
Type = {Article},
Affiliation = {Niu, HS (Corresponding Author), Henan Polytech Univ, Sch Civil Engn, Jiaozuo 454003, Peoples R China.
   Zhang, Yichen, Tianjin Chengjian Univ, Sch Int Engn, Tianjin 300384, Peoples R China.
