DOI = {10.1002/marc.202500482},
EarlyAccessDate = {SEP 2025},
Article-Number = {e00482},
Keywords = {artificial intelligence; composites; compressive-to-tensile strength
   ratio; genetic algorithm; inverse design},
Keywords-Plus = {CARBON-FIBER; HIGH-MODULUS; STRENGTH; OPTIMIZATION; FAILURE; KINKING},
