@incollection{ WOS:001579606700013,
Author = {Asifuzzaman, Kazi and Young, Aaron R. and Date, Prasanna and Kulkarni,
   Shruti R. and Miniskar, Narasinga Rao and Marinella, Matthew and Vetter,
   Jeffrey S.},
Editor = {Nagel, WE and Goehringer, D and Diniz, PC},
Title = {ReSpike: A Co-Design Framework for Evaluating SNNs on ReRAM-Based
   Neuromorphic Processors},
Booktitle = {EURO-PAR 2025: PARALLEL PROCESSING, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2026},
Volume = {15901},
Pages = {175-189},
Abstract = {With Moore's law approaching its end, traditional von Neumann
   architectures are struggling to keep up with the exceeding performance
   and memory requirements of artificial intelligence and machine learning
   algorithms. Unconventional computing approaches such as neuromorphic
   computing that leverage spiking neural networks (SNNs) to perform
   computation are gaining traction and seek the paradigm shift necessary
   to sustain the increasing demands of modern applications. Novel memory
   technologies, such as resistive RAM (ReRAM), employ a crossbar
   architecture that possesses the inherent capability of efficiently
   computing vector-matrix multiplication-a dominant operation in SNNs. The
   prospect of naturally mapping SNNs to the crossbar structures provides a
   unique opportunity for achieving a high-performance, powerefficient
   neuromorphic system. In this work, we present ReSpike, which is a new
   framework, behavioral simulator, and architectural design based on ReRAM
   crossbar architectures, enabling modeling and co-design to achieve
   efficient execution of SNNs. We drive this co-design forward by
   quantifying the impact that ReRAM cell nonidealities have on the
   corresponding accuracy of an SNN application.},
Type = {Proceedings Paper},
Affiliation = {Asifuzzaman, K (Corresponding Author), Oak Ridge Natl Lab, 1 Bethel Valley Rd, Oak Ridge, TN 37830 USA.
   Asifuzzaman, Kazi; Young, Aaron R.; Date, Prasanna; Kulkarni, Shruti R.; Miniskar, Narasinga Rao; Vetter, Jeffrey S., Oak Ridge Natl Lab, 1 Bethel Valley Rd, Oak Ridge, TN 37830 USA.
   Marinella, Matthew, Arizona State Univ, 1151 S Forest Ave, Tempe, AZ 85281 USA.},
DOI = {10.1007/978-3-031-99857-7\_13},
Keywords = {Neuromorphic computing; Spiking Neural Networks; ReRAM; Co-design
   framework},
Author-Email = {asifuzzamank@ornl.gov
