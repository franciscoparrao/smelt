@article{ WOS:001654178400001,
Author = {Kono, Takahiro and Miyamoto, Souta and Masuda, Taichi and Tanabe,
   Katsuaki},
Title = {Improving DFT-predicted band gaps by symbolic regression for
   semiconductor materials discovery},
Journal = {COMPUTATIONAL MATERIALS SCIENCE},
Year = {2026},
Volume = {263},
Month = {FEB},
Abstract = {We demonstrate a machine learning approach for interpretable correction
   of numerically predicted band gaps. Accurate estimation of semiconductor
   band gaps is crucial for the development of new optoelectronic materials
   and devices. However, experimentally measured band gap data remain
   scarce, and density functional theory (DFT) calculations consistently
   deviate from experimental values. We address this challenge using
   symbolic regression technique to derive a correction function that maps
   DFT-computed band gaps onto their experimental counterparts. Applying
   the correction to DFT records yielded 41,307 corrected values toward
   experimental estimate, nearly 17 times more than the 2483 experimental
   values, substantially expanding the materials space and enabling
   screening over this enlarged domain. Moreover, we leverage this expanded
   dataset by training an XGBoost regressor to screen ternary compounds for
   target band gap properties and evaluate the synthesizability of top
   candidates based on predicted formation enthalpies. Our approach
   provides a framework for accelerating the discovery of high-performance
   semiconductor materials.},
Type = {Article},
Affiliation = {Tanabe, K (Corresponding Author), Kyoto Univ, Dept Chem Engn, Nishikyo, Kyoto 6158510, Japan.
   Kono, Takahiro; Miyamoto, Souta; Masuda, Taichi; Tanabe, Katsuaki, Kyoto Univ, Dept Chem Engn, Nishikyo, Kyoto 6158510, Japan.
   Miyamoto, Souta; Tanabe, Katsuaki, Kyoto Univ, Sch Chem Sci \& Technol, Nishikyo, Kyoto 6158510, Japan.
   Tanabe, Katsuaki, Kyoto MPI Inc, Sakyo, Kyoto 6068501, Japan.},
