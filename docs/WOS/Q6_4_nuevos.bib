@article{ WOS:001712889300001,
Author = {Lv, Lai and Huang, Yuan and Lei, Lu and Han, Bing},
Title = {Machine learning models with monotonic constraints for predicting bond
   strength between reinforcing bars and UHPC},
Journal = {STRUCTURES},
Year = {2026},
Volume = {87},
Month = {MAY},
Abstract = {The bond-anchorage interaction between reinforcing bars and ultra high
   performance concrete (UHPC) plays a critical role in ensuring reliable
   composite structural behavior. However, existing empirical models often
   exhibit limited generalization capability in predicting bond strength.
   Although machine learning (ML) techniques have enhanced predictive
   accuracy, their lack of transparency and physical interpretability
   limits their engineering applicability. To overcome these challenges,
   this study proposes a machine learning framework with monotonic
   constraints, which incorporates key physical parameters, including UHPC
   compressive strength, relative cover thickness, and relative anchorage
   length, into the model. Monotonic constraints are imposed on these
   governing parameters to ensure physically consistent predictions. The
   results reveal that incorporating monotonic constraints enhances
   predictive accuracy and robustness on the test dataset. Furthermore,
   interpretability analyses based on Individual Conditional Expectation
   (ICE) plots and independent orthogonal experiments validate the
   framework's transparency and consistency. The findings demonstrate that
   integrating domain knowledge into machine learning models enables more
   reliable and physically interpretable predictions of ultimate bond
   strength in reinforcing bar-UHPC systems.},
Type = {Article},
Affiliation = {Huang, Y; Han, B (Corresponding Author), Hunan Univ, Coll Civil Engn, Changsha 410082, Peoples R China.
   Lv, Lai; Huang, Yuan; Lei, Lu; Han, Bing, Hunan Univ, Coll Civil Engn, Changsha 410082, Peoples R China.
   Huang, Yuan; Han, Bing, Hunan Univ, Hunan Prov Key Lab Damage Diag Engn Struct, Changsha 410082, Peoples R China.},
DOI = {10.1016/j.istruc.2026.111552},
Article-Number = {111552},
Keywords = {Bond strength; Monotonic constraints; Machine learning; Ultra-high
   performance concrete (UHPC); Reinforcing bar},
Keywords-Plus = {SLIP BEHAVIOR; PERFORMANCE; CONCRETE; STRESS; FIBERS},
Author-Email = {huangy@hnu.edu.cn
   hanbing06@hnu.edu.cn},
Number-of-Cited-References = {86},
Times-Cited = {0},
Unique-ID = {WOS:001712889300001},
}

