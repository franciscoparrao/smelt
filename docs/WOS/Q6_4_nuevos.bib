@article{ WOS:001632368300003,
Author = {Zhou, Jiani and Liu, Hongshuang and Xu, Peng and Sun, Wei},
Title = {Harnessing porosity: A review on polymer-based porous structures for
   high-performance passive radiative cooling},
Journal = {MATERIALS TODAY ENERGY},
Year = {2025},
Volume = {54},
Month = {DEC},
Abstract = {Porous polymeric materials for passive daytime radiative cooling (PDRC)
   enable significant sub-ambient cooling without energy input by
   leveraging a synergistic mechanism: high solar reflectance to minimize
   solar heat absorption, high infrared emissivity to dissipate heat
   through atmospheric windows. This review provides theoretical
   foundations and technical guidance for the design and engineering of
   high-performance, sustainable porous polymeric PDRC materials. It
   elaborates on the photothermal regulation mechanism, clarifying the
   critical interplay between Mie scattering-which governs solar
   reflectance-and molecular vibrations that drive infrared emission. It
   summarizes various preparation strategies, such as phase separation and
   templating methods, along with their correlations to structure and
   performance. It introduces machine learning applications in reverse
   material design, lifespan prediction, and anti-soiling optimization to
   accelerate the development of materials. Practical implementations in
   areas including building cooling, personal thermal management, and wound
   dressings are reviewed to demonstrate real-world efficacy. Future
   breakthroughs, which would require a shift from optimizing individual
   materials toward establishing a multidimensional, synergistic innovation
   system encompassing intelligent response mechanisms, energy synergy, and
   sustainable material development, are also discussed.},
Type = {Article},
Affiliation = {Sun, W (Corresponding Author), Ningbo Univ, Sch Mat Sci \& Chem Engn, Dept Mat Sci \& Engn, Ningbo 315211, Peoples R China.
   Zhou, Jiani; Liu, Hongshuang; Xu, Peng; Sun, Wei, Ningbo Univ, Sch Mat Sci \& Chem Engn, Dept Mat Sci \& Engn, Ningbo 315211, Peoples R China.},
DOI = {10.1016/j.mtener.2025.102146},
EarlyAccessDate = {NOV 2025},
Article-Number = {102146},
Keywords = {Passive daytime radiative cooling; Porous polymeric material; Machine
   learning; Material optimization; Pore-formation},
Keywords-Plus = {INDUCED PHASE-SEPARATION; FILMS; TEMPERATURE; NONSOLVENT},
Author-Email = {sunwei@nbu.edu.cn},
Number-of-Cited-References = {146},
Times-Cited = {1},
Unique-ID = {WOS:001632368300003},
}

@article{ WOS:001633123400003,
Author = {Li, Shu and Zhang, Weijia and Ding, Siqi and Lu, Jiahao and Ni, Yi-Qing},
Title = {A comprehensive review on energy-absorbing mechanical metamaterials:
   From mechanisms to applications},
Journal = {COMPOSITES PART B-ENGINEERING},
Year = {2026},
Volume = {311},
Month = {FEB 15},
Abstract = {Energy absorption (EA) is critical for enhancing the safety and
   resilience of modern structural systems, particularly under dynamic and
   impact loading conditions. Mechanical metamaterials (MMs), which derive
   their exceptional mechanical responses from their architected topologies
   rather than their constituent materials, offer a transformative paradigm
   for energy dissipation. Focusing on energy-absorbing mechanical
   metamaterials (EAMMs), this review covers four key aspects: fundamental
   mechanisms, advanced manufacturing, structural design, and engineering
   applications. The fundamental principles and evaluation metrics of
   energy dissipation are first discussed, followed by advanced
   manufacturing techniques enabling the realization of EA-MMs. At the core
   of this review is a systematic analysis of EA-MM configurations,
   including cellular, pentamode, origami/kirigami, and fractal
   architectures, which highlights their structural innovations,
   deformation modes, and EA performance. Furthermore, recent advances in
   AI-enabled design and optimization of EA-MMs are summarized. In
   addition, emerging applications of EA-MMs in civil infrastructure,
   transportation, aerospace, and protective systems are highlighted.
   Finally, a critical discussion of current challenges is provided, such
   as design complexity, scalable fabrication, and multifunctional
   integration as well as promising directions for next-generation EA-MMs.
   By integrating theory, fabrication, and application-driven design, this
   review aims to provide a comprehensive roadmap and accelerate the
   implementation of robust, high-performance EA-MMs in impact-critical and
   EAdemanding engineering systems.},
Type = {Article},
Affiliation = {Ding, SQ; Ni, YQ (Corresponding Author), Hong Kong Polytech Univ, Dept Civil \& Environm Engn, Kowloon, Hong Kong, Peoples R China.
