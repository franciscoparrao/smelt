@article{ WOS:001695642000001,
Author = {Madhukar, Bhawesh and Kumar, Sanjay and Rai, Baboo},
Title = {Metaheuristic-optimized gradient boosting models for predicting the
   compressive strength of WPP-modified high-performance concrete},
Journal = {JOURNAL OF STRUCTURAL INTEGRITY AND MAINTENANCE},
Year = {2026},
Volume = {11},
Number = {2},
Month = {APR 3},
Abstract = {This study presents a novel machine learning-based framework for
   predicting the compressive strength of high-performance concrete
   incorporating waste PVC powder (WPP) as a partial substitute for fine
   aggregate. A baseline Gradient Boosting Machine (GBM) model was
   developed and optimized using four advanced metaheuristic algorithms:
   the Whale Optimization Algorithm (WOA), the Dragonfly Optimization
   Algorithm (DOA), the Earthworm Optimization Algorithm (EOA) and the
   Adaptive Bat Algorithm (ABA). The experimental procedure is carried out
   with varying WPP content (0-15\%) and curing ages (3-90 days) as per the
   Indian Standards. A dataset of a total of 189 instances is collected.
   Performance evaluation through 5-fold cross-validation demonstrated that
   the hybrid GBM-WOA model achieved superior predictive performance with a
   test R2 of 0.9949, RMSE of 0.0195 and MAPE of 1.82\%. The standalone GBM
   model (R2 = 0.8004, RMSE = 0.1296, MAPE = 10.03\%) performs lower than
   the hybrid models. Sensitivity analysis revealed that fine aggregate
   content, curing age and WPP had relative influences of 38\%, 34\% and
   28\%, respectively. The study confirms the effectiveness of
   metaheuristic-optimized GBM models in accurately modeling the complex
   nonlinear behavior of sustainable concrete materials and offers a fast
   and accurate data-driven tool to reduce reliance on extensive laboratory
   testing.},
Type = {Article},
Affiliation = {Madhukar, B (Corresponding Author), Natl Inst Technol, Dept Civil Engn, Patna, India.
   Madhukar, Bhawesh; Kumar, Sanjay; Rai, Baboo, Natl Inst Technol, Dept Civil Engn, Patna, India.},
DOI = {10.1080/24705314.2026.2630085},
Article-Number = {2630085},
Keywords = {High-performance concrete; compressive strength; PVC powder; Gradient
   Boosting Machine},
Keywords-Plus = {BENTONITE; AGGREGATE; WASTE},
Author-Email = {bhaweshm.phd19.ce@nitp.ac.in},
Number-of-Cited-References = {76},
Times-Cited = {0},
Unique-ID = {WOS:001695642000001},
}

@article{ WOS:001719974600001,
Author = {Thi, Huong Pham and Thanh, Phong Nguyen and Dinh, Vuong Nguyen and
   Truong, Pham and Anh, Duong Tran and Le, Ngoc Anh and Mai, Thai Son and
   Van, Song Pham and Nguyen, Tuan B. H. and Van Tung, Pham},
Title = {Uncertainty quantification in water quality prediction using
   Optuna-optimized machine learning: A case study in the Quan Lo-Phung
   Hiep irrigation system, Vietnamese Mekong Delta},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2026},
Volume = {86},
Month = {APR},
Abstract = {Water quality degradation in irrigation systems of the Vietnamese Mekong
   Delta is increasingly driven by agricultural runoff, domestic
   wastewater, and strong seasonal hydrological variability, posing
   challenges to conventional deterministic Vietnam Water Quality Index
   (VN-WQI) assessments. This study proposes a decision-oriented and
   risk-aware methodology for VN-WQI prediction that integrates tree-based
   machine learning models, automated feature selection, explainable AI,
   and uncertainty quantification. This study applied multi-site monitoring
   data from 20 locations in the Quan Lo-Phung Hiep irrigation system
   during 2018-2024, with separate modeling for the dry and wet seasons to
   explicitly address seasonal non-stationarity. Among the evaluated
   models, the Extreme Gradient Boosting (XGB) model combined with Boruta
   feature selection achieved high performance and transferable
   performance, maintaining high predictive accuracy using only seven key
   water quality parameters. SHapley Additive exPlanations (SHAP)-based
   analysis identified Coliform, NH4+, and NO2- as the dominant
   contributors to VN-WQI variability, with distinct seasonal patterns
   reflecting underlying hydrological and biogeochemical processes.
   Predictive uncertainty was quantified through Monte Carlo Simulation
   driven by data-derived input variability, enabling probabilistic VN-WQI
   prediction intervals and class-based risk estimation. The results show
   that VN-WQI class switching is concentrated near classification
   thresholds and is governed by different uncertainty mechanisms across
   seasons, with aleatoric uncertainty dominating in the dry season and
   epistemic uncertainty becoming critical in the wet season. Calibration
   curves and misclassification risk-coverage analysis further demonstrate
   that the proposed framework provides reliable uncertainty estimates for
   risk-informed water quality assessment. Overall, this study offers a
   practical and interpretable tool to support uncertainty-aware
   decision-making in seasonally dynamic and data-constrained irrigation
   systems.},
Type = {Article},
Affiliation = {Tung, PV (Corresponding Author), Vietnam Acad Water Resources, Inst Coastal \& Offshore Engn, Ho Chi Minh City, Vietnam.
   Thi, Huong Pham; Thanh, Phong Nguyen; Anh, Duong Tran; Le, Ngoc Anh, Van Lang Univ, Inst Computat Sci \& Artificial Intelligence, Lab Environm Sci \& Climate Change, Ho Chi Minh City, Vietnam.
   Thi, Huong Pham; Thanh, Phong Nguyen; Anh, Duong Tran; Le, Ngoc Anh, Van Lang Univ, Fac Environm, Van Lang Sch Technol, Ho Chi Minh City, Vietnam.
   Dinh, Vuong Nguyen, Southern Inst Water Resources Res, Ho Chi Minh City, Vietnam.
   Dinh, Vuong Nguyen, Vietnam Acad Water Resources, Hanoi, Vietnam.
   Mai, Thai Son, Queens Univ Belfast, Sch Elect Elect Engn \& Comp Sci, Belfast, North Ireland.
   Van, Song Pham, Mien Dong Innovat Technol Univ, Dau Giay Town, Dong Nai, Vietnam.
   Nguyen, Tuan B. H., Van Hien Univ, Fac Engn \& Technol, Ho Chi Minh City, Vietnam.
   Van Tung, Pham, Vietnam Acad Water Resources, Inst Coastal \& Offshore Engn, Ho Chi Minh City, Vietnam.},
DOI = {10.1016/j.jwpe.2026.109858},
Article-Number = {109858},
Keywords = {Machine learning; Water quality prediction; Seasonal variability;
   Uncertainty quantification; Quan Lo-Phung Hiep irrigation system},
Keywords-Plus = {BORUTA},
Author-Email = {huong.phamthi@vlu.edu.vn
   phong.nguyenthanh@vlu.edu.vn
   phamtung73@gmail.com},
