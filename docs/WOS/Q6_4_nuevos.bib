@article{ WOS:001641950600002,
Author = {Han, Chang and Huang, Hongfeng and Wei, Lili and Chen, Xuandong and Li,
   Enbang and Qiu, Ming and Song, Shuangwu and Zhao, Zhouzhou},
Title = {Machine learning-driven design of high-strength ductile Al-Si alloys for
   casting applications},
Journal = {MATERIALS SCIENCE AND ENGINEERING A-STRUCTURAL MATERIALS PROPERTIES
   MICROSTRUCTURE AND PROCESSING},
Year = {2026},
Volume = {951},
Month = {JAN},
Abstract = {This study proposes a dual-layer Stacking ensemble learning framework,
   utilizing Deep Neural Networks (DNN) as meta-learners to integrate the
   predictive strengths of various base models. A hybrid optimization
   approach that combines Particle Swarm Optimization (PSO) with Bayesian
   Optimization (BO) is employed to fine-tune the model's hyperparameters.
   The model effectively captures the complex nonlinear relationship
   between alloy composition, heat treatment processes, and mechanical
   properties. The Expected Improvement (EI) algorithm drives iterative
   ``prediction-validation{''} cycles to optimize the design of
   high-performance Al-Si alloys and their corresponding heat treatment
   processes. Experimental results confirm that the designed
   Al-9.5Si-1.2Cu-0.6Mg0.2Mn-0.05Sr-0.1Ti (wt.\%) alloy demonstrates
   superior mechanical and casting properties, with a tensile strength
   (UTS) of 431 MPa, yield strength (YS) of 307.9 MPa, and elongation (EL)
   of 9.8 \%, achieving an excellent strength-ductility balance. The
   casting performance includes a flow length of 454 mm, a hot cracking
   sensitivity coefficient of 24, and a thermal shrinkage rate of 6.54 \%,
   indicating excellent casting suitability. Microstructural analysis using
   TEM, SEM, and 3D-XRT reveals that, after T6 heat treatment, the matrix
   contains fine, uniform, and highly spheroidized eutectic silicon, along
   with a high-density dispersion of 0 `, beta `, and Q ` nanoscale
   precipitates. These microstructural features synergistically promote
   precipitation strengthening and retard crack propagation, which is
   crucial for the alloy's outstanding strength-ductility balance.},
