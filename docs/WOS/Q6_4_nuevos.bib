@article{ WOS:001622761900001,
Author = {Adapa, Venkata Surya Karthik and Kalidindi, Surya R. and Saldana,
   Christopher J.},
Title = {A combinatorial AM-ML framework for high-throughput exploration of CPSP
   linkages in gamma prime-tailored nickel-based superalloys},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2025},
Volume = {1047},
Month = {DEC 5},
Abstract = {Establishing high-fidelity datasets and leveraging machine
   learning-driven analysis to uncover composition \&
   process-structure-property (CP-S-P) relationships in gamma
   `-strengthened Ni-based superalloys is essential for accelerating the
   design of high-performance alloys for demanding thermal environments.
   This study presents a highthroughput combinatorial framework to
   investigate gamma ` precipitation behavior across compositionally graded
   IN100-IN625 alloy mixtures fabricated using Directed Energy Deposition.
   By systematically varying alloy composition, the gamma ` evolution was
   examined across four processing stages: as-deposited (AD), solution
   heattreated (SHT), and first -and second-step age hardening (AG1 \&
   AG2), and the characteristics of the produced materials are evaluated in
   terms of nucleation thresholds, morphology, and mechanical performance.
   Microstructural analysis reveals that whilst no significant gamma ` is
   observed in AD and SHT conditions, the first discernible gamma `
   precipitates in cuboidal shapes appeared in AG1 at approximately 62.5
   wt\% IN100 and at 50 wt\% in AG2, as aging time increased. Automated
   hardness tests and small punch tests (SPT) confirmed that the tensile
   strength increased with gamma ` volume fraction, while ductility
   decreased. A novelty of our data analyses approach lies in the use of
   Principal Component Analysis (PCA) to reduce the dimensionality of
   time-temperature profiles, enabling efficient and compact representation
   of thermal histories. These PCA features were utilized in exploring
   different variants of reduced-order
   composition-process-structure-property (CPSP) models using Gaussian
   Process Regression (GPR). It was observed that including the
   microstructural descriptors in these models provided only marginal
   improvements, indicating that thermal history and composition
   predominantly governed mechanical properties. This study demonstrates
   the power of combining AM-based high-throughput experiments with machine
   learning to accelerate alloy design and deepen understanding of gamma `
   evolution in Ni-based superalloys.},
Type = {Article},
Affiliation = {Adapa, VSK (Corresponding Author), Georgia Inst Technol, George W Woodruff Sch Mech Engn, 801 Ferst Dr, Atlanta, GA 30332 USA.
   Adapa, Venkata Surya Karthik; Kalidindi, Surya R.; Saldana, Christopher J., Georgia Inst Technol, George W Woodruff Sch Mech Engn, 801 Ferst Dr, Atlanta, GA 30332 USA.},
DOI = {10.1016/j.jallcom.2025.185040},
EarlyAccessDate = {DEC 2025},
Article-Number = {185040},
Keywords = {Additive manufacturing; Machine Learning; Gamma prime; Nickel based
   superalloys; High throughput PSP relationships},
Keywords-Plus = {PRECIPITATION},
Author-Email = {karthik.adapa@gatech.edu
   surya.kalidindi@me.gatech.edu
   christopher.saldana@me.gatech.edu},
Number-of-Cited-References = {27},
