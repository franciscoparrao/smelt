@article{ WOS:001613610700001,
Author = {Sabet, Maziyar},
Title = {Defect-engineered rGO-NiCo2O4 hybrids:
   Eco-Friendly synthesis, interfacial chemistry, and reproducibility via
   bayesian optimization},
Journal = {MATERIALS CHEMISTRY AND PHYSICS},
Year = {2026},
Volume = {348},
Number = {2},
Month = {JAN 15},
Abstract = {Reduced graphene oxide (rGO)-NiCo2O4 hybrid electrodes were synthesized
   using eco-friendly chemical and thermal routes, and their
   structure-property relationships were systematically optimized through
   Bayesian machine learning. Raman spectroscopy and X-ray photoelectron
   spectroscopy revealed oxygen vacancies and C-O-metal bonding that
   facilitate interfacial charge transfer and enhance pseudocapacitance.
   Density-functional-theory calculations confirm type-II band alignment
   and defect-mediated electronic states near the Fermi level, establishing
   the mechanistic basis for the observed conductivity enhancement.
   Electrochemical characterization shows a high specific capacitance of
   1420 F g(-1) (three-electrode, normalized to active mass) and stable
   performance across a wide current-density range, with >90 \% capacitance
   retention after 10,000 cycles. The Bayesian optimization framework
   reduced experimental workload, improved batch-to-batch reproducibility,
   and identified synthesis parameters critical for defect control.
   Novelty: by combining binder-free green processing with closed-loop
   Bayesian optimization and mechanistic storage analysis, this work
   provides reproducible, transferable pathways for designing
   high-performance oxide-graphene electrodes for electrochemical energy
   storage.},
Type = {Article},
Affiliation = {Sabet, M (Corresponding Author), Univ Teknol Brunei, Chem \& Energy Engn, Bandar Seri Begawan, Brunei.
   Sabet, Maziyar, Univ Teknol Brunei, Chem \& Energy Engn, Bandar Seri Begawan, Brunei.},
DOI = {10.1016/j.matchemphys.2025.131749},
EarlyAccessDate = {NOV 2025},
Article-Number = {131749},
Keywords = {Reduced graphene oxide (rGO); Oxygen vacancies; Bayesian optimization;
   Electrochemical impedance spectroscopy (EIS); NiCo2O4 hybrid electrodes},
Keywords-Plus = {SUPERCAPACITORS},
Author-Email = {maziyar.sabet@utb.edu.bn},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001613610700001},
}

@article{ WOS:001605767600001,
Author = {Chen, Weiheng and Wu, Jialong and Li, Ling and Chen, Xiaoping and
   Maiyalagan, Thandavarayan and Chen, Wenhua and Jiang, Zhongqing},
Title = {Decoding the Buried Interface: A Synergistic Framework for Mastering the
   Core Challenges of Solid-State Batteries},
Journal = {SMALL},
Year = {2025},
Volume = {21},
Number = {50},
Month = {DEC 1},
Abstract = {All-solid-state batteries offer a significant advancement in energy
   density and safety compared to conventional lithium-ion battery
   technologies. However, their development is critically impeded by the
   complex instability of solid-solid interfaces. These buried junctions,
   governed by intricate chemical, electrochemical, and mechanical
   degradation processes, present substantial scientific challenges that
   cannot be effectively addressed by a single research methodology. This
   review emphasizes the crucial role of a synergistic paradigm that
   integrates computational simulations with advanced experimental
   characterization to overcome these significant interface issues. A
   conceptual framework is proposed that categorizes this synergistic
   approach into four hierarchical levels: Foundational, which validates
   essential material properties; Dynamic, which captures real-time
   interface evolution using operando techniques; Multi-Scale, which links
   atomic-scale changes to macroscopic failures; and Intelligent, which
   harnesses artificial intelligence and machine learning to accelerate
   discovery and enhance data analysis. Through detailed case studies, the
   vital role of this integated approach is demonstrated in elucidating
   ionic transport mechanisms, predicting interfacial reaction pathways,
   deconstructing the multiphysics of lithium-dendrite growth, and
   understanding chemo-mechanical failures in composite electrodes. It is
   concluded that this synergistic methodology is essential for
   transitioning from descriptive analysis to the predictive, rational
   engineering of stable, high-performance interfaces necessary for the
   next generation of energy storage systems.},
Type = {Review},
Affiliation = {Chen, WH (Corresponding Author), Zhejiang Sci Tech Univ, Natl \& Local Joint Engn Res Ctr Reliabil Anal \& Te, Hangzhou 310018, Peoples R China.
