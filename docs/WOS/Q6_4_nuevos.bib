   Bezerra, Joao Inacio Moreira; Cely, Marlon Mauricio Hernandez, Univ Fed Pelotas, Intelligent Syst \& Control Grp, Dona Mariana 13, BR-96010020 Pelotas, RS, Brazil.},
DOI = {10.1016/j.jwpe.2026.109751},
EarlyAccessDate = {FEB 2026},
Article-Number = {109751},
Keywords = {Leak detection and classification; Dynamic Time Warping;
   Mel-spectrograms; Sensor fusion; XGBoost},
