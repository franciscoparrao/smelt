@article{ WOS:001541138000013,
Author = {Tao, Weixiang and Wang, Peifang and Zhang, Bo and Zhou, Gang and Wang,
   Jie},
Title = {Dehydration-enabled sub-nanochannel lamellar membranes for
   high-performance osmotic energy harvesting},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2025},
Volume = {520},
Month = {SEP 15},
Abstract = {Osmotic energy, derived from the salinity gradient between seawater and
   freshwater, offers a sustainable solution to global energy challenges
   and climate change. However, its practical implementation is limited by
   low ionic selectivity and high transport resistance in current membrane
   materials. Machine learning analysis of previous studies identifies
   channel size as a critical factor influencing osmotic energy harvesting
   performance. Here, we tune the membrane pore size to induce ion
   dehydration, thereby reducing transport resistance and enhancing energy
   conversion efficiency. A lamellar membrane with sub-nanochannel was
   fabricated via electrostatic self-assembly of oppositely charged
   graphene oxide (GO) and layered double hydroxide (LDH) nanosheets,
   followed by mild thermal annealing to further minimize the interlayer
   distance. The resulting GL2 membrane with an interlayer free spacing of
   5.0 \& Aring;, exhibits a power density of 18.6 W m- 2 under a 50-fold
   NaCl concentration gradient, significantly outperforming pristine GO
   membranes (2.9 W m- 2) and other reported lamellar membranes. Both
   experimental results and theoretical simulations reveal that the reduced
   interlayer spacing enhances ion dehydration and cation selectivity while
   lowering transport resistance. This dehydrationdriven strategy is
   adaptable to a variety of 2D material combinations exhibiting strong
   interlayer interactions, including MXene/LDH, MoS2/LDH, both of which
   demonstrate excellent performance. To showcase practical application,
   the GL2 membrane was integrated with a nitrate reduction device,
   achieving an ammonia production rate of 0.89 mu mol h- 1 cm- 2 with a
   Faradaic efficiency of 98\% over 216 h. These results underscore the
   potential of this approach for developing ion-selective membranes for
   efficient osmotic energy harvesting.},
Type = {Article},
Affiliation = {Zhou, G; Wang, J (Corresponding Author), Hohai Univ, Coll Environm, Key Lab Integrated Regulat \& Resource Dev Shallow, Minist Educ, Nanjing 210098, Peoples R China.
   Tao, Weixiang; Wang, Peifang; Zhang, Bo; Zhou, Gang; Wang, Jie, Hohai Univ, Coll Environm, Key Lab Integrated Regulat \& Resource Dev Shallow, Minist Educ, Nanjing 210098, Peoples R China.},
DOI = {10.1016/j.cej.2025.166001},
EarlyAccessDate = {JUL 2025},
Article-Number = {166001},
Keywords = {Osmotic energy harvesting; Ion-selective membrane; Sub-nanochannel;
   Dehydration process; Power density},
Keywords-Plus = {HYDRATION; IONS},
Author-Email = {gangzhou@hhu.edu.cn
   wang.jie@hhu.edu.cn},
Number-of-Cited-References = {51},
Times-Cited = {1},
Unique-ID = {WOS:001541138000013},
}

@article{ WOS:001534243300001,
Author = {Zhu, Banghua and Wang, Xingcheng and Zhang, Ji and Luo, Huajie and Liu,
   Laijun and Neuefeind, Joerg C. and Liu, Hui and Chen, Jun},
Title = {Designing Pb-Free High-Entropy Relaxor Ferroelectrics with Machine
   Learning Assistance for High Energy Storage},
Journal = {JOURNAL OF THE AMERICAN CHEMICAL SOCIETY},
Year = {2025},
Volume = {147},
Number = {31},
Pages = {27912-27921},
Month = {AUG 6},
Abstract = {High-entropy tactics present exceptional promise in advancing the
   dielectric energy storage of relaxor ferroelectrics, thereby benefiting
   various pulsed-power electronic systems. However, their vast composition
   space poses challenges in the rational design of a high-performance
   system. Herein, we present a machine learning-supplemented strategy to
   design high-entropy relaxors, demonstrating an ultrahigh energy-storage
   density of 17.2 J cm-3 and high efficiency of 87\% at a high breakdown
   strength of 79 kV mm-1. By integrating six A-site and one B-site
   critical intrinsic features of constituent ions, deduced from a
   constructed random forest regression model, the
   (Bi2/5Na1/5K1/5Ba1/5)(Ti,Hf)O3 high-entropy system is identified.
   Atomic-level local structural analysis reveals that incorporating these
   certified cations, with diverse local polar and lattice construction
   characteristics, results in a highly fluctuating local polarization
   structure. This favorable structure is characterized by pronounced
   orientation disorder and a broadly distributed length of unit-cell
   polarization vectors within the expanded lattice framework.
   Macroscopically, the optimized relaxor displays high dielectric
   susceptibility and large resistance. Moreover, a large discharge energy
   density of 5.8 J cm-3 and power energy density of 447 MW cm-3, along
   with outstanding operational stability, are achieved. This study
   presents a data-driven model to explore complex intrinsic features and
   facilitate the design of high-performance relaxors.},
Type = {Article},
Affiliation = {Liu, H; Chen, J (Corresponding Author), Univ Sci \& Technol Beijing, Beijing Adv Innovat Ctr Mat Genome Engn, Dept Phys Chem, Beijing 100083, Peoples R China.
   Zhu, Banghua; Wang, Xingcheng; Luo, Huajie; Liu, Hui; Chen, Jun, Univ Sci \& Technol Beijing, Beijing Adv Innovat Ctr Mat Genome Engn, Dept Phys Chem, Beijing 100083, Peoples R China.
