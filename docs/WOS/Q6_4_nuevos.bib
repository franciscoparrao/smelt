@article{ WOS:001620421200002,
Author = {Qin, Yuhuan and Li, Jiachen and Wu, Ming and Zhao, Zihang and Lu, Dan
   and Xu, Jiayuan and Liang, Lijun},
Title = {Target-oriented design of thin-film nanocomposite (TFN) membranes for
   reverse osmosis using machine learning and genetic algorithm},
Journal = {SEPARATION AND PURIFICATION TECHNOLOGY},
Year = {2026},
Volume = {382},
Number = {3},
Month = {FEB 26},
Abstract = {Designing high-performance thin-film nanocomposite (TFN) membranes
   remains a critical challenge in reverse osmosis (RO) desalination due to
   the complex interplay between filler properties, fabrication parameters,
   and testing conditions. In this study, a comprehensive dataset
   comprising 598 TFN membranes was compiled from literature and used to
   construct predictive models for water permeability and salt rejection
   based on ensemble machine learning (ML) algorithms. Among them, XGBoost
   demonstrated the highest accuracy and was subsequently used for feature
   interpretation and design optimization. SHapley Additive exPlanations
   and Partial Dependence Plots revealed that filler loading, particle
   size, pore size, and applied pressure were the dominant factors to
   affect membrane performance. Intergrated with genetic algorithm and ML
   model, target-oriented TFN could be designed. The membrane with a
   maximum water flux of 4.82 LMH/bar and rejection of 99.47 \% was
   discovered. Finally, molecular dynamics simulations elucidated the
   enhanced transport mechanisms in high-flux membranes, highlighting the
   role of nanofiller-induced nanochannels. This work demonstrates a
   generalizable, target-oriented framework for data-driven TFN membrane
   design and offers mechanistic insights into membrane
   structure-performance relationships.},
Type = {Article},
Affiliation = {Liang, LJ (Corresponding Author), Hangzhou Dianzi Univ, Coll Automat Artificial Intelligence, Hangzhou 310018, Peoples R China.
   Qin, Yuhuan; Wu, Ming; Zhao, Zihang; Xu, Jiayuan; Liang, Lijun, Hangzhou Dianzi Univ, Coll Automat Artificial Intelligence, Hangzhou 310018, Peoples R China.
