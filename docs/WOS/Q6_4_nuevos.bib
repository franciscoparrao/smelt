   Zou, Zhigang, Macau Univ Sci \& Technol, Macau Inst Syst Engn, Macau, Peoples R China.},
DOI = {10.1039/d5ta08532b},
EarlyAccessDate = {JAN 2026},
Keywords-Plus = {NITROGEN-DOPED CARBON; BIFUNCTIONAL ELECTROCATALYST; EVOLUTION REACTION;
   HIGH-EFFICIENCY; GRAPHENE LAYER; REDUCTION; METAL; SHELL; NANOPARTICLES;
   NANOTUBES},
Author-Email = {qingyuwu@smail.nju.edu.cn
   yaoyingfang@nju.edu.cn},
