}

@article{ WOS:001586764400001,
Author = {Ahmad, Sher and Emmery, Daniel and Gallucci, Fausto and van der Schaaf,
   John},
Title = {Neural network based molecular dynamics simulations for oxide ion
   transport in solid oxide electrolysis cell materials},
Journal = {INTERNATIONAL JOURNAL OF HYDROGEN ENERGY},
Year = {2025},
Volume = {180},
Month = {OCT 21},
Abstract = {Solid oxide electrolysis cells (SOECs) based hydrogen production is
   regarded as one of the most efficient methods for sustainable energy
   conversion. Brownmillerite-type oxides, such as Ca2Fe2O5, have recently
   gained significant interest due to their inherent oxygen vacancy
   channels that facilitate oxide ion transport through the structure. In
   this research work, neural network-based interatomic potentials
   (ML-IAPs) were employed in molecular dynamics (MD) simulations to study
   the oxide ion transport in Co-doped brownmillerites. The simulation
   results and experimental data aligned within 98 \% accuracy. Parametric
   analysis revealed that temperature, Co doping, and oxygen vacancies
   enhances oxide ionic conductivity in these materials. Co doping leads to
   a 2-3 fold increase in diffusion coefficient compared to undoped
   Ca2Fe2O5 structure. From the trajectory analysis, oxygen pathways, and
   anisotropic nature of ionic diffusion in brownmillerites is observed.
   The findings of this research provide a strong data-driven framework for
   accelerating material selection strategies, paving the way for
   next-generation high-performance electrolysis technologies.},
Type = {Article},
Affiliation = {Ahmad, S (Corresponding Author), Tech Univ Tue Eindhoven, Dept Chem \& Chem Engn, Sustainable Proc Engn, Eindhoven, Netherlands.
   Ahmad, Sher; Emmery, Daniel; Gallucci, Fausto; van der Schaaf, John, Tech Univ Tue Eindhoven, Dept Chem \& Chem Engn, Sustainable Proc Engn, Eindhoven, Netherlands.},
DOI = {10.1016/j.ijhydene.2025.151714},
EarlyAccessDate = {OCT 2025},
Article-Number = {151714},
Keywords = {Machine learning potentials; Molecular dynamics; Brownmillerites; Solid
   oxide electrolysis cell; Hydrogen; Green technology},
Author-Email = {s.ahmad@tue.nl},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001586764400001},
}

@article{ WOS:001604696600039,
Author = {Wei, Longxiao and Xue, Rurui and Hao, Wengang and Wang, Baoyue and Gong,
   Ping and Wang, Lei},
Title = {System modelling and multi-objective optimization of a
   photovoltaic-thermal assisted dual-source heat pump integrated with PCM},
Journal = {ENERGY},
Year = {2025},
Volume = {338},
Month = {NOV 30},
Abstract = {The application of solar-assisted heat pumps in cold regions is
   beneficial to carbon reduction but faces challenges in balancing
   performance with economic viability. Therefore, a novel
   photovoltaic-thermal assisted dual-source heat pump integrated with
   phase change materials (PVTHP-PCM) was designed and optimized to
   identify system configuration. The comprehensive multi-objective
   optimization framework that integrates TRNSYS simulations with machine
   learning was employed to identify the optimal solution. Four machine
   learning algorithms were used to develop surrogate models based on a
   dataset of 300 samples generated by Latin hypercube sampling. The
   results revealed that four key design variables were determine including
   PV/T area, mass of PCM, ASHP rated heating capacity and TES tank volume
   through orthogonal experimental design. The XGBoost exhibited superior
   prediction accuracy with highest R2 value and lowest RMSE and MAE value.
   Under the Entropy allocation optimal solution, the values for SF, COP,
   and AC were determined to be 43.43 \%, 4.06 and 4808.81CNY. Furthermore,
   SF-optimal and COP-optimal using the subjective weighting method showed
   comprehensive superiority over the initial design. These findings will
   provide design guidance for implementing cost-effective and
   high-performance PVTHP-PCM systems in cold climates.},
Type = {Article},
Affiliation = {Hao, WA (Corresponding Author), Yantai Univ, Sch Ocean, Yantai 264005, Shandong, Peoples R China.
   Wei, Longxiao; Hao, Wengang; Wang, Baoyue; Wang, Lei, Yantai Univ, Sch Ocean, Yantai 264005, Shandong, Peoples R China.
   Xue, Rurui; Gong, Ping, Yantai Inst Technol, Sch Informat Engn, Yantai 264003, Shandong, Peoples R China.},
DOI = {10.1016/j.energy.2025.138917},
EarlyAccessDate = {OCT 2025},
Article-Number = {138917},
Keywords = {Photovoltaic/thermal; Dual-source heat pump; Multi-objective
   optimization; Machine learning; Latin hypercube sampling},
Keywords-Plus = {HOT-WATER SYSTEM; DYNAMIC SIMULATION; NSGA-II; PERFORMANCE; COLLECTOR;
   DRIVEN},
Author-Email = {hwgang@ytu.edu.cn},
