   Mukhametkarimov, Yerzhan, Al Farabi Kazakh Natl Univ, Dept Phys \& Technol, 71 Al-Farabi Ave, Alma Ata 050040, Kazakhstan.},
DOI = {10.1002/adfm.202506672},
EarlyAccessDate = {JUL 2025},
Keywords = {machine learning; molecular scaffold classifier; molecule screening;
   organic molecular additives; perovskite solar cells},
Keywords-Plus = {INORGANIC HYBRID PEROVSKITES; DEFECT PASSIVATION; HIGHLY EFFICIENT; BASE
   ADDUCT; PERFORMANCE; STABILITY; SURFACE; DESIGN; IODIDE; LAYERS},
Author-Email = {rhchen@nwpu.edu.cn
