@article{ WOS:001605628700008,
Author = {Anthimopoulos, Theologos and Keramidas, Georgios and Kelefouras,
   Vasilios and Stamoulis, Iakovos},
Title = {Register Blocking: A Source-to-Source Analytical Modelling Approach for
   Affine Loop Kernels},
Journal = {ACM TRANSACTIONS ON EMBEDDED COMPUTING SYSTEMS},
Year = {2025},
Volume = {24},
Number = {5},
Month = {SEP},
Abstract = {Register Blocking (RB), also known as `Register-level Tiling' or
   `unroll-and-jam,' is a key compiler optimization for developing
   efficient micro-kernels. However, applying RB effectively is a complex
   task due to several challenges. First, the exploration space of possible
   RB configurations is vast. Second, RB and loop permutation are
   interdependent; therefore, addressing both optimizations simultaneously
   further inflates the exploration space. Third, the effectiveness of RB
   is highly dependent on the target hardware platform and the specific
   loop kernel being optimized. As a result, an extensive and
   time-consuming fine-tuning process is necessary for achieving an
   efficient implementation. To address these challenges, a
   source-to-source analytical modelling approach is proposed. The RB
   factors, the loops to apply RB, the number of allocated
   variables/registers per array reference, and the loops' ordering are
   generated by an analytical model, leveraging the target hardware
   architecture details and loop kernel characteristics. The proposed
   methodology has been evaluated on both embedded and general-purpose
   CPUs, using seven well-known loop kernels and three machine learning
   applications. The results show significant speedups over the GCC
   compiler, the Pluto tool, and related work.},
Type = {Article},
Affiliation = {Anthimopoulos, T (Corresponding Author), Aristotle Univ Thessaloniki, Sch Informat, Thessaloniki, Greece.
   Anthimopoulos, Theologos; Keramidas, Georgios, Aristotle Univ Thessaloniki, Sch Informat, Thessaloniki, Greece.
   Kelefouras, Vasilios, Univ Plymouth, Sch Engn Comp \& Math, Plymouth, Devon, England.
   Stamoulis, Iakovos, Think Silicon SA, Appl Mat Co, Patras, Greece.},
DOI = {10.1145/3747183},
Article-Number = {80},
Keywords = {Compiler optimizations; register blocking; register tiling;
   unroll-and-jam; high performance computing; data reuse; CPUs},
Author-Email = {tanthimop@csd.auth.gr
   gkeramidas@csd.auth.gr
   vasilios.kelefouras@plymouth.ac.uk
   i.stamoulis@think-silicon.com},
Number-of-Cited-References = {34},
Times-Cited = {1},
Unique-ID = {WOS:001605628700008},
}

@article{ WOS:001561956800035,
Author = {Alimi, Fathi and Khan, Adnan and Ali, Hameed and Bouzidi, Mohamed and
   Alshammari, Abdulrahman Obaid and Ahmad, Bakhtiyar},
Title = {M-estimation activation functions for high-performance extreme learning
   machine ensemble classification},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {15},
Number = {1},
Month = {SEP 1},
Abstract = {Machine learning plays a pivotal role in addressing real-world
   challenges across domains such as cybersecurity, where AI-driven
   methods, especially in Software-Defined Networking, enhance traffic
   monitoring and anomaly detection. Contemporary networks often employ
   models like Random Forests, Neural Networks, and Support Vector Machines
   to identify threats early and reinforce security. Ensemble learning
   further improves predictive accuracy and stability, yet many frameworks
   falter when confronted with noisy or contaminated data. In this study,
   we propose a robust ensemble framework for Extreme Learning Machines
   (ELMs) that integrates a family of redescending psi-activation functions
   grounded in M-estimation theory. Each psi-function yields a distinct
   base classifier, initialized with random weights, and the optimal
   hidden-node count is selected via grid search minimizing the Brier
   score. Rather than traditional voting, ensemble outputs are combined
   through a least-squares optimization, allowing precise parameter
   estimation and enhanced stability. We validate our method on five
   benchmark datasets, SatImage, Email-Spamdexing, Breast Cancer, Musk, and
   Iris, demonstrating consistently superior accuracy and reduced variance
   compared to existing ELM ensembles. Rigorous statistical testing
   (Kruskal-Wallis with Dunn's post-hoc comparisons) confirms these gains.
   Our results show that embedding robust M-estimator-based activations
   within a controlled ensemble yields marked improvements in
   generalization, predictive precision, and resilience to data
   irregularities, offering a significant advancement in the design of
   efficient neural classifiers.},
Type = {Article},
Affiliation = {Ali, H (Corresponding Author), Univ Agr Peshawar, Dept Math Stat \& Comp Sci, Peshawar, Pakistan.
   Ahmad, B (Corresponding Author), Higher Educ Dept, Kabul, Afghanistan.
   Alimi, Fathi, Univ Hail, Coll Sci, Dept Chem, POB 2440, Hail 81441, Saudi Arabia.
   Khan, Adnan, Islamia Coll Peshawar, Dept Stat, Peshawar, Pakistan.
   Ali, Hameed, Univ Agr Peshawar, Dept Math Stat \& Comp Sci, Peshawar, Pakistan.
   Bouzidi, Mohamed, Univ Hail, Coll Sci, Dept Phys, POB 2440, Hail, Saudi Arabia.
   Alshammari, Abdulrahman Obaid, Jouf Univ, Coll Sci, Dept Math, Sakaka 72388, Saudi Arabia.
   Ahmad, Bakhtiyar, Higher Educ Dept, Kabul, Afghanistan.},
DOI = {10.1038/s41598-025-16798-5},
