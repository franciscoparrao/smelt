}

@article{ WOS:001605286400001,
Author = {Zhang, Xiaoliang and Li, Cong and Wu, Weibing and Li, Weiwei},
Title = {High-entropy electrocatalysts toward high-performance oxygen evolution
   reaction: a perspective from atomic-scale electronic structure
   modulation},
Journal = {ELECTRONIC STRUCTURE},
Year = {2025},
Volume = {7},
Number = {4},
Month = {DEC 31},
Abstract = {Water electrolysis represents a critical pathway towards sustainable
   hydrogen production within the global green energy landscape. The oxygen
   evolution reaction (OER), the kinetically limiting anodic process,
   necessitates the development of highly active and durable
   electrocatalysts. High-entropy materials, offering unparalleled
   compositional diversity and inherent multi-component synergistic
   effects, have emerged as promising candidates to address the OER
   bottleneck. While recent reviews have explored various aspects of
   high-entropy electrocatalysts (HECs), a comprehensive understanding of
   the atomic-level design and modulation strategies that govern their
   exceptional OER performance remains a critical gap. This review aims to
   bridge this gap by focusing on the atomic-level insights crucial for
   designing and optimizing HECs. We first examine advancements in machine
   learning-assisted atomic-level design strategies for OER HECs.
   Subsequently, we delve into five key atomic-level modulation approaches:
   tailoring local atomic coordination environments, engineering atomic
   interface architectures, manipulating intrinsic lattice strain,
   controlled introduction of atomic-scale defects, and exploiting
   synergistic multi-site atomic interactions. Finally, we delineate future
   research directions to accelerate the rational design and practical
   implementation of efficient and robust HECs under demanding operating
   conditions.},
Type = {Review},
Affiliation = {Zhang, XL (Corresponding Author), Tongling Univ, Sch Elect Engn, Tongling 244061, Peoples R China.
   Li, WW (Corresponding Author), Hainan Univ, Sch Mat Sci \& Engn, State Key Lab Trop Ocean Engn Mat \& Mat Evaluat, Haikou 570228, Peoples R China.
   Zhang, Xiaoliang; Wu, Weibing, Tongling Univ, Sch Elect Engn, Tongling 244061, Peoples R China.
   Li, Cong, Suzhou Univ Sci \& Technol, Sch Phys Sci \& Technol, Jiangsu Key Lab Micro \& Nano Heat Fluid Flow Techn, Suzhou 215009, Peoples R China.
   Li, Weiwei, Hainan Univ, Sch Mat Sci \& Engn, State Key Lab Trop Ocean Engn Mat \& Mat Evaluat, Haikou 570228, Peoples R China.},
DOI = {10.1088/2516-1075/ae164c},
Article-Number = {043001},
Keywords = {high-entropy materials; oxygen evolution reaction; electrocatalysts;
   atomic-level modulation; machine learning},
Keywords-Plus = {EFFICIENT; NITROGEN; NITRATE},
Author-Email = {xiaoliang.zhang@tlu.edu.cn
   weiwei.li@hainanu.edu.cn},
Number-of-Cited-References = {78},
