@article{ WOS:001570532000004,
Author = {Wang, Junling and Sun, Ao and Wang, Chenchen and Zhang, Xianguo and
   Huang, Jinyu},
Title = {Improved deep learning-based detection of drainage pipeline defects
   using an enhanced YOLOv8 framework},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2025},
Volume = {78},
Month = {OCT},
Abstract = {The YOLOv8\_XMAE model is a dependable machine learning technique that
   is suggested for identifying sewer pipe flaws. The present YOLOv8 base
   model still has some shortcomings, even though it has comparable
   capabilities. The limitations of the current model include the need to
   increase the model's robustness and detection accuracy for complex sewer
   pipe defects, limitations in multi-scale feature fusion, direction
   awareness, bounding box regression, and attention mechanisms, as well as
   challenges in completely adapting to complex defect detection scenarios
   like sewer pipes. Four novel optimizations of the YOLOv8 base model are
   carried out in this thesis: 1) incorporating XIoU loss to improve
   regression accuracy; 2) designing a Multi-Branch Auxiliary Fusion (MAF);
   3) constructing an adaptive rotation-aware detection head (ARHead); 4)
   integrating the EMA attention mechanism to enhance key feature
   extraction. Test results show that on a multi-class drainage defect
   dataset, the model achieves a precision of 0.898, a recall of 0.796, and
   a mAP50 of 0.831, representing improvements of 2.9, 8.5, and 8.0
   percentage points, respectively. This work presents a high-performance
   and scalable system for intelligent drainage pipeline inspection,
   offering substantial theoretical value and application potential through
   major advancements in model architecture design, detection performance,
   and engineering adaptability.},
Type = {Article},
Affiliation = {Wang, JL (Corresponding Author), Beijing Univ Civil Engn \& Architecture, Sch Environm \& Energy Engn, Beijing 100044, Peoples R China.
   Wang, Junling; Sun, Ao; Wang, Chenchen, Beijing Univ Civil Engn \& Architecture, Sch Environm \& Energy Engn, Beijing 100044, Peoples R China.
   Zhang, Xianguo; Huang, Jinyu, Beijing Capital Ecoenvironm Protect Grp Co Ltd, Beijing 100044, Peoples R China.},
DOI = {10.1016/j.jwpe.2025.108605},
EarlyAccessDate = {SEP 2025},
Article-Number = {108605},
Keywords = {ARHead detection head; Drainage pipeline defect detection; EMA attention
   mechanism; MAF architecture; XIoU loss function},
Author-Email = {wangjunling@bucea.edu.cn},
Number-of-Cited-References = {38},
