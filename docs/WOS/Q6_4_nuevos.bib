@article{ WOS:001699861800001,
Author = {Ishaq, Muhammad and Guastella, Dario Calogero and Sutera, Giuseppe and
   Muscato, Giovanni},
Title = {A Systematic Review of Fall Detection and Prediction Technologies for
   Older Adults: An Analysis of Sensor Modalities and Computational Models},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2026},
Volume = {16},
Number = {4},
Month = {FEB 14},
Abstract = {Background: Falls are a leading cause of morbidity and mortality among
   older adults, creating a need for technologies that can automatically
   detect falls and summon timely assistance. The rapid evolution of sensor
   technologies and artificial intelligence has led to a proliferation of
   fall detection systems (FDS). This systematic review synthesizes the
   recent literature to provide a comprehensive overview of the current
   technological landscape. Objective: The objective of this review is to
   systematically analyze and synthesize the evidence from the academic
   literature on fall detection technologies. The review focuses on three
   primary areas: the sensor modalities used for data acquisition, the
   computational models employed for fall classification, and the emerging
   trend of shifting from reactive detection to proactive fall risk
   prediction. Methods: A systematic search of electronic databases was
   conducted for studies published between 2008 and 2025. Following the
   PRISMA guidelines, 130 studies met the inclusion criteria and were
   selected for analysis. Information regarding sensor technology,
   algorithm type, validation methods, and key performance outcomes was
   extracted and thematically synthesized. Results: The analysis identified
   three dominant categories of sensor technologies: wearable systems
   (primarily Inertial Measurement Units), ambient systems (including
   vision-based, radar, WiFi, and LiDAR), and hybrid systems that fuse
   multiple data sources. Computationally, the field has shown a
   progression from threshold-based algorithms to classical machine
   learning and is now dominated by deep learning architectures, such as
   Convolutional Neural Networks (CNNs), Recurrent Neural Networks (RNNs),
   and Transformers. Many studies report high performance, with accuracy,
   sensitivity, and specificity often exceeding 95\%. An important trend is
   the expansion of research from post-fall detection to proactive fall
   risk assessment and pre-impact fall prediction, which aim to prevent
   falls before they cause injury. Conclusions: The technological
   capabilities for fall detection are well-developed, with deep learning
   models and a variety of sensor modalities demonstrating high accuracy in
   controlled settings. However, a critical gap remains; our analysis
   reveals that 98.5\% of studies rely on simulated falls, with only two
   studies validating against real-world, unanticipated falls in the target
   demographic. Future research should prioritize real-world validation,
   address practical implementation challenges such as energy efficiency
   and user acceptance, and advance the development of integrated,
   multi-modal systems for effective fall risk management.},
Type = {Review},
Affiliation = {Ishaq, M (Corresponding Author), Univ Catania, Dept Elect Elect \& Informat Engn, I-95123 Catania, Italy.
   Ishaq, Muhammad; Guastella, Dario Calogero; Sutera, Giuseppe; Muscato, Giovanni, Univ Catania, Dept Elect Elect \& Informat Engn, I-95123 Catania, Italy.},
DOI = {10.3390/app16041929},
Article-Number = {1929},
Keywords = {fall detection; older adults; systematic review; wearable sensors;
   ambient assisted living; deep learning; pre-impact fall prediction; fall
   risk assessment},
Keywords-Plus = {ELDERLY-PEOPLE; MONITORING-SYSTEM; RADAR; RISK; FUSION; IOT},
Author-Email = {muhammad.ishaq@unict.it
   dario.guastella@unict.it
   giuseppe.sutera@unict.it
   giovanni.muscato@unict.it},
Number-of-Cited-References = {130},
Times-Cited = {0},
Unique-ID = {WOS:001699861800001},
}

@article{ WOS:001693387600001,
Author = {Cui, Zhenjie and Pang, Sheng and Ren, Xinying and Guo, Jianwei and Yue,
   Hong and Wang, Dong and Wang, Zhi},
Title = {Bridging the gap between empirical and rational design: machine learning
   framework for lithium ion-sieve performance prediction},
Journal = {DESALINATION},
Year = {2026},
Volume = {626},
Month = {MAY 15},
Abstract = {With the rapid development of the global new energy industry, salt-lake
   lithium extraction has emerged as a critical technological pathway to
   meet lithium resource demands, in which lithium ion-sieve (LIS)
   materials serving as the core adsorbents. However, the development of
   high-performance lithium ion-sieve materials is constrained by complex
   nonlinear multi-parameter coupling effects, with empirical
   trial-and-error methods resulting in lengthy development cycles and high
   costs. This study integrates 948 experimental data points (spanning 130
   independent studies) to construct a large-scale data-driven framework
   that systematically applies machine learning to lithium adsorption
   performance prediction and interpretable analysis of feature-performance
   relationships. By introducing innovative continuous stoichiometric
   descriptors to replace conventional one-hot encoding, a quantitative
   system encompassing 15 engineering features across three dimensions
   including material composition, synthesis protocols, and adsorption
   conditions was established. Based on systematic comparison and
   evaluation of 12 traditional algorithms, a Stacking ensemble framework
   was innovatively constructed by integrating three top-performing models
   (XGBoost, LightGBM, and CatBoost), achieving competitive performance
   with R2 = 0.911 and RMSE = 4.107 mg \& sdot;g-1 on the test set under
   random split with outlier removal, with external validation mean MAE as
   low as 2.400 mg center dot g-1, supporting the model's utility for
   cross-study screening. SHAP interpretability analysis quantified the
   contribution patterns of features to adsorption performance, providing a
   data-driven and statistically informed pathway that bridges empirical
   exploration with rational, decision-guided material design.},
Type = {Article},
Affiliation = {Wang, D; Wang, Z (Corresponding Author), 1 BeiErJie, Beijing 100190, Peoples R China.
   Cui, Zhenjie; Pang, Sheng; Ren, Xinying; Guo, Jianwei; Yue, Hong; Wang, Dong; Wang, Zhi, Chinese Acad Sci, Inst Proc Engn, Natl Engn Res Ctr Green Recycling Strateg Met Reso, Beijing 100190, Peoples R China.
   Cui, Zhenjie; Pang, Sheng; Ren, Xinying; Guo, Jianwei; Yue, Hong; Wang, Dong; Wang, Zhi, Chinese Acad Sci, Innovat Acad Green Manufacture, Beijing 100190, Peoples R China.
