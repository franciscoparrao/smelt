@article{ WOS:001633873300001,
Author = {Liu, Hui and Wu, Yanfeng and Xue, Tingting and Du, Zhe and Xu, Jun and
   Jiang, Tao},
Title = {Machine learning-assisted parametric analysis and multi-criteria
   optimization of building performance: A case study on indoor
   environmental quality and energy efficiency},
Journal = {ENERGY CONVERSION AND MANAGEMENT},
Year = {2026},
Volume = {349},
Month = {FEB 1},
Abstract = {Aligned with China's ``Healthy Building{''} and ``Dual Carbon{''}
   strategies, this study advances daylight health and energy-efficient
   carbon reduction in building design through a novel machine learning
   (ML)-assisted framework for parametric analysis and multi-criteria
   optimization (MCO). A high-performance simulation-optimization platform
   is developed by integrating the Julia programming language with
   EnergyPlus, employing Gradient Boosting with Neural Trees (GBNT) for
   accurate, intelligent, and high-fidelity building performance
   assessment. A calibrated case study in Shenzhen, China validates the
   framework, evaluating Indoor Environmental Quality (IEQ)
   indicators-Predicted Percentage of Dissatisfied (PPD) (PPD),
   Concentration of Carbon Dioxide (CCD), Relative Humidity (RH), and
   Daylight Glare Index (DGI)-alongside Annual Total Energy Demand (ATED)
   as an energy performance criterion. Parametric analysis is performed via
   a GBNT-driven one-variable-at-a-time (OVAT) method, supported by a novel
   formula that determines the maximum required GBNT sample size for
   building applications. The subsequent GBNT-EnergyPlus based MCO
   identifies Pareto-optimal solutions balancing IEQ and ATED, with the
   Analytic Hierarchy Process (AHP) applied to select the final optimal
   design. Results reveal strong nonlinear and oscillatory responses of IEQ
   and ATED to design variables, highlighting the importance of precise
   factor selection. The optimized design achieves ATED of 153.1 GJ (5.7 \%
   reduction from the baseline 162.3 GJ), PPD of 9.5 \% (<10 \% acceptable
   threshold), DGI of 17 (optimal visual comfort), RH between 30-50 \%, and
   CCD < 1000 ppm. Compared with benchmark tools (Honeybee for parametric
   analysis and Octopus for MCO), the proposed GBNT-EnergyPlus framework
   reduces computational time by 85 \% while keeping prediction errors
   below 2 \%, demonstrating superior accuracy and efficiency. In addition,
   to evaluate the efficacy of the proposed approach for optimizing
   building performance, a comparative analysis was conducted against the
   established Octopus, ModeFRONTIER, and jEPlus + EA platforms using the
   non-parametric Wilcoxon rank-sum test. The results revealed that the
   GBNT-EnergyPlus framework outperformed these commercial optimization
   tools in both solution quality and computational efficiency.
   Collectively, the findings indicate that the proposed AI-driven
   optimization approach is characterized by robustness, as accurate and
   computationally efficient solutions are delivered, thereby facilitating
   informed, data-driven design decisions during the initial phases of
   building performance optimization.},
Type = {Article},
Affiliation = {Liu, H (Corresponding Author), Guodian Nanjing Automat Co Ltd, Nanjing, Peoples R China.
   Liu, H; Xu, J (Corresponding Author), Nanjing Univ Informat Sci \& Technol, Sch Artificial Intelligence Future Technol, Jiangsu Key Lab Intelligent Med Image Comp, Nanjing, Peoples R China.
