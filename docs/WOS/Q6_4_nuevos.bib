@article{ WOS:001633408600001,
Author = {Li, Yaning and Bai, Yan},
Title = {Magnetic nanomaterial-mediated conversion of construction waste into
   high-performance recycled building materials},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2026},
Volume = {220},
Month = {JAN},
Abstract = {In this study, a novel composite material, Fe3O4@SiO2@Cys, was
   synthesized using magnetite nanoparticles coated with a silica shell and
   functionalized with cysteine to remove heavy metals from mine tailings.
   Detailed characterization revealed its uniform morphology, excellent
   dispersibility, and abundant functional groups. Adsorption experiments
   showed the material's outstanding Pb (II) removal performance under pH
   5, with a maximum adsorption capacity of 125.25 mg/g. Kinetic and
   isotherm analyses indicated that the adsorption process followed
   pseudo-second-order kinetics and fit well with the Langmuir model,
   suggesting a monolayer chemisorption mechanism. The material exhibited
   excellent reusability, maintaining over 80 \% efficiency after five
   cycles. Following purification, the treated tailings were reused to
   prepare recycled concrete, showing marked improvements in compressive
   strength. A key innovation of this work lies in the integration of an
   AI-based LightGBM predictive framework, which not only achieved
   high-accuracy predictions (R-2 > 0.97) of the mechanical properties of
   purified tailings concrete, but also, through feature importance
   analysis, revealed that Si and Fe contents were the most influential
   factors driving performance enhancement. These results demonstrate a
   comprehensive and intelligent pathway integrating magnetic
   nanomaterials, solid waste purification, and machine learning to promote
   high-performance, eco-friendly recycled concrete.},
Type = {Article},
Affiliation = {Bai, Y (Corresponding Author), Shenzhen Univ, Coll Civil \& Transportat Engn, Shenzhen 518060, Peoples R China.
   Li, Yaning; Bai, Yan, Shenzhen Univ, Coll Civil \& Transportat Engn, Shenzhen 518060, Peoples R China.
   Li, Yaning, Shenzhen Univ, Logist Support Dept, Shenzhen 518060, Peoples R China.},
DOI = {10.1016/j.microc.2025.116243},
EarlyAccessDate = {NOV 2025},
Article-Number = {116243},
Keywords = {Magnetic nanoparticles; Mine tailings; Pb(II) adsorption; Recycled
   concrete; LightGBM; Heavy metal removal; AI prediction; Fe3O4@SiO2@Cys},
Keywords-Plus = {NANOPARTICLES; REMOVAL},
Author-Email = {YanBaii@outlook.com},
Number-of-Cited-References = {30},
Times-Cited = {0},
Unique-ID = {WOS:001633408600001},
}

@article{ WOS:001635063200001,
Author = {Xiang, Pengting and Liu, Xian and Chen, Xiang and Liu, Chuang},
Title = {Tailoring Energy Absorption of Curved-Beam Lattices Through a
   Data-Driven Approach},
Journal = {MATERIALS},
Year = {2025},
Volume = {18},
Number = {23},
Month = {NOV 28},
Abstract = {Programmable mechanical metamaterials demonstrate significant potential
   for realizing high-performance mechanical responses, particularly in the
   field of energy absorption. In this study, a novel curved-beam thickness
   gradient lattice structure (CBTGLS) is proposed. Based on an intelligent
   inverse design framework integrating deep learning and genetic
   algorithms, the beam thickness and curved-beam control points of the
   CBTGLS were optimized to maximize its total energy absorption (EA) and
   specific energy absorption (SEA). Furthermore, this research employed
   interpretability methods, such as Shapley Additive Explanations (SHAP)
   and Partial Dependence Plot (PDP), to analyze the influence mechanism of
   geometric parameters on energy absorption performance, aiming to enhance
   design efficiency and establish a clear design rationale. The results
   indicate that the optimized CBTGLS exhibits significant improvements in
   both EA and SEA. Specifically, compared to a baseline straight-beam
   lattice structure possessing an identical thickness gradient, SEA of the
   optimized CBTGLS was enhanced by 49.12\%. Among the investigated
   parameters, beam thickness was identified as having a particularly
   significant impact on performance. Furthermore, it was observed that a
   curvature profile bending more towards the outer side of the unit cell
   is more beneficial for enhancing the energy absorption capabilities of
   the lattice structure.},
Type = {Article},
Affiliation = {Liu, C (Corresponding Author), Nanjing Tech Univ, Coll Civil Engn, Nanjing 211816, Peoples R China.
   Xiang, Pengting; Liu, Xian; Chen, Xiang; Liu, Chuang, Nanjing Tech Univ, Coll Civil Engn, Nanjing 211816, Peoples R China.},
DOI = {10.3390/ma18235377},
Article-Number = {5377},
Keywords = {lattice structure; machine learning; energy absorption; sensitivity
