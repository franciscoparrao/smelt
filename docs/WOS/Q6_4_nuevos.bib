@article{ WOS:001551761600001,
Author = {Hussain, Saddam and Arshad, Muhammad and Cheema, Muhammad Jehanzeb Masud
   and Qamar, Muhammad Uzair and Wajid, Syed Aftab and Daccache, Andre},
Title = {Advancing Soil Moisture Prediction Using Satellite and UAV-based Imagery
   Using Moisture Indices with Machine Learning Models},
Journal = {EARTH SYSTEMS AND ENVIRONMENT},
Year = {2025},
Month = {2025 AUG 18},
Abstract = {Crop yields in Pakistan are significantly lower than their potential,
   primarily due to limited water availability and the reliance on rotation
   water delivery instead of demand-based water supply. The absence of
   spatially explicit information on water stress at the farm level further
   constrains overall crop productivity. Therefore, it is essential to map
   soil moisture availability and monitor moisture stress to enhance the
   efficiency of water delivery at the district level and promote precision
   in on-farm irrigation application. To continuously monitor soil moisture
   availability and identify moisture stress hotspots, peanut crops were
   cultivated during the 2021 and 2022 growing seasons at PMAS-Arid
   Agriculture University Research Center, Koont Farm, Rawalpindi.
   Experimental trials were conducted in both irrigated (drip irrigation)
   and rainfed fields to address soil moisture variability in the context
   of precision irrigation management. Soil moisture monitoring was
   performed using a combination of proximal soil moisture sensors,
   satellite data (Landsat 8/9 and Sentinel-2), and Unmanned Aerial
   Vehicles (UAVs) equipped with multispectral sensors. Satellite data and
   UAV imagery were processed to calculate soil moisture indices, including
   the Normalized Difference Water Index (NDWI), Moisture Vegetation Index
   (MVI), Water Stress Index (WSI), and Drought Stress Water Index
   (DSWI-4). Ground-truth data, including in situ soil moisture
   measurements at 15 cm depth and crop yield observations, were recorded
   for validation. A machine learning (ML) model, Random Forest (RF), was
   employed to accurately predict soil moisture content at 15 cm depth. The
   spatial maps were generated using satellite data and UAV-based imagery
   to identify the specific areas experiencing moisture stress. Among the
   moisture stress indices, WSI demonstrated a strong positive correlation
   with soil moisture (R-2 = 0.95 in 2022 and 0.85 in 2021) in the drip
   irrigated field. The RF model predicted soil moisture with a high
   accuracy (R-2 = 0.97 to 0.99 and RMSE = 0.00) using UAV-based moisture
   indices as input parameters. Furthermore, the improved surveillance of
   moisture stress enabled the identification of hotspot areas, allowing
   for the targeted implementation of protective measures for precision
   irrigation at the farm level.Graphical AbstractThis study presents a
   significant advancement in precision agriculture through the integration
   of satellite data, unmanned aerial vehicle (UAV)-based remote sensing,
   and machine learning (ML) models for high-resolution soil moisture
   estimation in water-scarce agricultural systems. Conventional soil
   moisture monitoring methods often fall short in spatial and temporal
   resolution, limiting their applicability for site-specific irrigation
   management. In this research, multispectral UAV imagery and moisture
   indices, including the Water Stress Index (WSI), Moisture Vegetation
   Index (MVI), Normalized Difference Water Index (NDWI), and Drought
   Stress Water Index (DSWI-4) were derived and correlated with
   ground-truth measurements, yielding highly promising results. These
   indices, extracted from remote sensing platforms of varying spatial
   resolutions (Landsat as low, Sentinel-2 as medium, and UAV as very
   high), were subsequently used as input variables in a Random Forest (RF)
   machine learning model for soil moisture prediction. The RF model
   significantly enhanced prediction accuracy by capturing nonlinear
   relationships between spectral indices and in situ soil moisture
   observations, achieving R-2 values as high as 0.
   99. This high-performance framework demonstrates the effectiveness of
   combining multi-resolution remote sensing with advanced ML techniques
   for operational soil moisture mapping. The approach not only facilitates
   precise soil moisture estimation but also supports targeted irrigation
   planning, contributing to improved water-use efficiency and sustainable
   crop production in semi-arid regions like Pakistan. Ultimately, this
   scalable and cost-effective strategy holds great potential for
   addressing food security challenges in water-limited agricultural
   systems.},
Type = {Article; Early Access},
Affiliation = {Hussain, S (Corresponding Author), Univ Agr Faisalabad, Dept Irrigat \& Drainage, Faisalabad 38000, Pakistan.
   Hussain, Saddam; Arshad, Muhammad; Qamar, Muhammad Uzair, Univ Agr Faisalabad, Dept Irrigat \& Drainage, Faisalabad 38000, Pakistan.
   Cheema, Muhammad Jehanzeb Masud, Int Water Management Inst, 12km Multan Rd,Chowk Thokar Niaz Baig Rd, Lahore 53700, Pakistan.
   Cheema, Muhammad Jehanzeb Masud, PMAS Arid Agr Univ, Fac Agr Engn \& Technol, Dept Land \& Water Conservat Engn, Rawalpindi 46000, Pakistan.
   Wajid, Syed Aftab, Univ Agr Faisalabad, Dept Agron, Faisalabad 38000, Pakistan.
   Daccache, Andre, Univ Calif Davis, Dept Biol \& Agr Engn, Davis, CA 95616 USA.},
DOI = {10.1007/s41748-025-00761-5},
EarlyAccessDate = {AUG 2025},
Keywords = {Surveillance; Hot spot; Random forest; NDWI; Water supply; Water stress},
Keywords-Plus = {AGRICULTURE; SYSTEM},
Author-Email = {s.hussain@ufl.edu},
