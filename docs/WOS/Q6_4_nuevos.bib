@article{ WOS:001542622300003,
Author = {Han, Bo and Chakraborty, Anutosh},
Title = {Machine learning optimized adsorption heat transformations from
   adsorbents screening to enhanced performances},
Journal = {ENERGY CONVERSION AND MANAGEMENT},
Year = {2025},
Volume = {344},
Month = {NOV 15},
Abstract = {Adsorption heat transformation (AHT) systems leverage porous adsorbents
   such as metal-organic frameworks (MOFs), zeolites, and silica gel to
   enable sustainable cooling and water production. However, the expansive
   design space of adsorbent-adsorbate pairs and system-level interactions
   complicates conventional optimization approaches. This review
   systematically evaluates the application of machine learning (ML) in AHT
   systems, covering adsorbent design, adsorption thermodynamics, cycle
   optimization, and techno-economic analysis. Key findings highlight the
   efficacy of ML models including random forests, neural networks, and
   gradient boosting in predicting adsorption isotherms, screening
   high-performance materials, and optimizing system efficiency. In this
   paper, the random forests and neural networks (with R2 values up to
   0.99) have facilitated the screening of over 96,000 adsorbent
   combinations, optimization of water diffusion coefficients, and
   prediction of adsorption thermodynamics. ML-guided cascaded chillers
   employing MOF-based working pairs have demonstrated coefficients of
   performance (COP) exceeding 1.6, while XGBoost and artificial neural
   network (ANN) models have predicted water diffusion and material
   performance with errors below 5\%. This review synthesizes ML
   applications across five AHT domains: adsorption heat pumps (AHP),
   adsorption cooling (AC), adsorption desalination (AD), atmospheric water
   harvesting (AWH), and thermal energy storage (TES), as well as ten major
   adsorbent classes. Despite these advances, persistent challenges include
   data scarcity, model interpretability, and scalability. Future research
   directions are proposed, emphasizing the integration of active learning,
   explainable AI,},
Type = {Article},
Affiliation = {Chakraborty, A (Corresponding Author), Nanyang Technol Univ, Sch Mech \& Aerosp Engn, 50 Nanyang Ave, Singapore 639798, Singapore.
   Han, Bo; Chakraborty, Anutosh, Nanyang Technol Univ, Sch Mech \& Aerosp Engn, 50 Nanyang Ave, Singapore 639798, Singapore.},
DOI = {10.1016/j.enconman.2025.120272},
EarlyAccessDate = {JUL 2025},
Article-Number = {120272},
Keywords = {Adsorption-assisted heat transformation (AHT); Machine learning (ML);
   Porous adsorbents; Active learning; Explainable AI},
Keywords-Plus = {METAL-ORGANIC FRAMEWORKS; WATER-ADSORPTION; TECHNOECONOMIC ANALYSIS;
   MOLECULAR SIMULATION; SILICA},
Author-Email = {AChakraborty@ntu.edu.sg},
Number-of-Cited-References = {210},
Times-Cited = {22},
Unique-ID = {WOS:001542622300003},
}

@article{ WOS:001541279800001,
Author = {Meng, Jun},
Title = {Understanding and design of interstitial oxygen conductors},
Journal = {COMPUTATIONAL MATERIALS SCIENCE},
Year = {2025},
Volume = {259},
Month = {SEP},
Abstract = {Highly efficient oxygen-active materials that react with, absorb, and
   transport oxygen is essential for fuel cells, electrolyzers and related
   applications. While vacancy-mediated oxygen-ion conductors have long
   been the focus of research, they are limited by high migration barriers
   at intermediate temperatures (400-600 degrees C), which hinder their
   practical applications. In contrast, interstitial oxygen conductors
   exhibit significantly lower migration barriers enabling higher ionic
   conductivity at lower temperatures. This review systematically examines
   both well-established and recently identified families of interstitial
   oxygen-ion conductors, focusing on how their unique structural motifs
   such as corner-sharing polyhedral frameworks, isolated polyhedral, and
   cage-like architectures, facilitate low migration barriers through
   interstitial and/or interstitialcy diffusion mechanisms. A central
   discussion of this review focuses on the evolution of design strategies,
   from targeted donor doping, element screening, to physical-intuition
   descriptor material screening and machine learning approach, which
   leverage computational tools to explore vast chemical spaces in search
   for new interstitial conductors. The success of these strategies
   demonstrates that a significant, largely unexplored space remains for
   discovering highperforming interstitial oxygen conductors. Crucial
   features enabling high-performance interstitial oxygen diffusion include
   the availability of electrons for oxygen reduction and sufficient
   structural flexibility with accessible volume for interstitial
   accommodation and migration. This review concludes with a
   forward-looking perspective, proposing a knowledge-driven methodology
   that integrates current understanding with data-centric approaches to
   identify promising interstitial oxygen conductors outside traditional
   search paradigms. These approaches are expected to significantly
   accelerate the development of high-performance interstitial oxygen
   conductors for a variety of oxygen-active applications, ultimately
   paving the way for more efficient and sustainable energy technologies.},
Type = {Article},
Affiliation = {Meng, J (Corresponding Author), Univ Wisconsin Madison, Dept Mat Sci \& Engn, Madison, WI 53706 USA.
   Meng, Jun, Univ Wisconsin Madison, Dept Mat Sci \& Engn, Madison, WI 53706 USA.},
DOI = {10.1016/j.commatsci.2025.114110},
EarlyAccessDate = {JUL 2025},
Article-Number = {114110},
Keywords = {Interstitial oxygen conductors; Structure-property relationships;
   Knowledge-driven material design; Solid oxide fuel cell},
Keywords-Plus = {OXIDE-ION CONDUCTIVITY; APATITE-TYPE PHASES; HIGH-TEMPERATURE PHASE;
