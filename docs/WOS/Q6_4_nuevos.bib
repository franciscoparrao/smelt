   Sridharan, Naveen Venkatesh, Lulea Univ Technol, Div Operat \& Maintenance Engn, Lulea, Sweden.
   Balaji, Parameshwaran Arun, Joy Univ, Sch Computat Intelligence, Kanyakumari, India.},
DOI = {10.1177/00202940251372860},
EarlyAccessDate = {SEP 2025},
Keywords = {internal combustion engine misfire; decision tree; micro
   electromechanical system (MEMS); accelerometer; vibration signals;
   on-board misfire detection},
Keywords-Plus = {FAULT-DIAGNOSIS},
Author-Email = {naveen.venkatesh@associated.ltu.se},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001571715200001},
}

@article{ WOS:001651453800004,
Author = {Madhavan, Pramoth Varsan and Zeng, Xin and Shahgaldi, Samaneh and Mitra,
   Sushanta K. and Li, Xianguo},
Title = {Optimization of catalyst composition and performance for PEM fuel cells:
   A data-driven approach},
Journal = {ARTIFICIAL INTELLIGENCE CHEMISTRY},
Year = {2025},
Volume = {3},
Number = {2},
Month = {DEC},
Abstract = {Transportation's rising negative environmental impacts and energy
   demands highlight the urgent need for clean alternative power sources
   such as proton exchange membrane (PEM) fuel cells. However, the high
   cost of platinum catalysts hinders its commercialization, making the
   development of low-platinum, high-performance catalysts essential for
   achieving net-zero targets. This study employs a data-driven machine
   learning approach to optimize the oxygen reduction reaction (ORR)
   catalyst composition and predict its long-term performance using extreme
   gradient boosting (XGB), artificial neural networks (ANN), and genetic
   algorithm (GA). Linear sweep voltammetry (LSV) data is collected for
   three distinct catalyst compositions and divided into separate datasets.
   Data is preprocessed and model hyperparameters are fine-tuned to enhance
   model accuracy. XGB models trained on these datasets accurately
   predicted LSV polarization plots for unseen data, as evidenced by R-2
   values > 0.99. To further optimize ORR catalyst design, an ANN model
   trained on data from three different catalyst compositions is integrated
   with a genetic algorithm. This predictive framework effectively
   identified optimal catalyst composition by maximizing the mass activity
   of the catalyst. Experimental validation of this optimized composition
   yielded strong agreement with predicted LSV current values, confirming
   the reliability of the ANN-GA approach. This research underscores the
   potential of machine learning-based predictive frameworks to accelerate
   the development of advanced ORR catalysts for PEM fuel cells.},
Type = {Article},
Affiliation = {Li, XG (Corresponding Author), Univ Waterloo, Mech \& Mechatron Engn, Waterloo, ON, Canada.
   Madhavan, Pramoth Varsan; Zeng, Xin; Mitra, Sushanta K.; Li, Xianguo, Univ Waterloo, Mech \& Mechatron Engn, Waterloo, ON, Canada.
   Zeng, Xin; Mitra, Sushanta K.; Li, Xianguo, Univ Waterloo, Waterloo Inst Nanotechnol, Waterloo, ON, Canada.
   Shahgaldi, Samaneh, Univ Quebec Trois Rivieres, Hydrogen Res Inst, Quebec City, PQ, Canada.},
DOI = {10.1016/j.aichem.2025.100095},
EarlyAccessDate = {SEP 2025},
Article-Number = {100095},
Keywords = {Fuel cell; Pt-Co core-shell; Machine learning; Extreme gradient
   boosting; Artificial neural networks; Genetic algorithm},
Keywords-Plus = {OXYGEN REDUCTION REACTION; ELECTROCATALYSTS},
Author-Email = {xianguo.li@uwaterloo.ca},
Number-of-Cited-References = {51},
Times-Cited = {4},
Unique-ID = {WOS:001651453800004},
}

@article{ WOS:001598275900033,
Author = {Mekki, Kawther and Neffati, Syrine and Ghezaiel, Nadia and Rmili, Hatem
   and Gharsallah, Ali},
Title = {Machine-Learning-Enhanced Chipless RFID Tag Localization Using UWB-IR
   Backscatter Analysis for IoT Applications},
Journal = {IEEE INTERNET OF THINGS JOURNAL},
Year = {2025},
Volume = {12},
Number = {18},
Pages = {38723-38735},
Month = {SEP 15},
Abstract = {This study presents a machine learning (ML)-enhanced framework for the
   detection, decoding, and localization of chipless radio-frequency
   identification (RFID) tags using cost-efficient ultrawideband impulse
   radio (UWB-IR) readers. By combining frequency-domain backscatter
   analysis with round-trip time-of-flight (RTOF) measurements, we propose
   an advanced signal processing architecture that significantly improves
   localization accuracy. To further enhance system robustness in noisy or
   multipath environments, a supervised ML classifier is integrated into
   the identification pipeline. Key features extracted from antenna mode
   backscatter signals, such as resonant amplitudes, signal-to-noise ratio
   (SNR) metrics, and temporal characteristics are used to train a support
   vector machine (SVM), achieving over 96\% identification accuracy at 10
   dB SNR, and maintaining high performance even under challenging
   conditions. This design improves resonance stability, environmental
   durability, and omnidirectional readability, making it highly suitable
   for real-time Internet of Things (IoT) applications, such as asset
   tracking and smart infrastructure monitoring. The proposed system is
   validated through comprehensive electromagnetic simulations in CST
   Studio Suite and MATLAB, as well as experimental measurements in
   anechoic chamber setups. Results demonstrate consistent performance,
   with a detection range of 30 cm and angular resolution of 60 degrees,
   even under varying environmental conditions.},
Type = {Article},
Affiliation = {Mekki, K (Corresponding Author), Univ Hail, Dept Comp Engn, Coll Comp Sci \& Engn, Hail 2440, Saudi Arabia.
   Mekki, Kawther; Neffati, Syrine; Ghezaiel, Nadia, Univ Hail, Dept Comp Engn, Coll Comp Sci \& Engn, Hail 2440, Saudi Arabia.
   Rmili, Hatem, Univ Tunis El Manar, Natl Engn Sch Tunis, Lab Commun Syst, Tunis 2092, Tunisia.
   Gharsallah, Ali, Univ Tunis El Manar, Dept Phys, Lab Res Microwave Elect, Fac Sci, Tunis 2092, Tunisia.},
DOI = {10.1109/JIOT.2025.3587013},
Keywords = {Backscatter analysis; chipless radio-frequency identification (RFID);
   Internet of Things (IoT); localization; machine learning (ML);
   round-trip time-of-flight (RTOF); support vector machine (SVM);
   ultrawideband impulse radio (UWB-IR)},
Keywords-Plus = {ANTENNA; DESIGN; MINIATURIZATION; IDENTIFICATION},
Author-Email = {kawther.mekki@gmail.com},
Number-of-Cited-References = {54},
Times-Cited = {3},
Unique-ID = {WOS:001598275900033},
}

@article{ WOS:001584863100006,
Author = {Song, Yongpeng and Zhang, Jinxi and Wu, Hansong and Yang, Ce and Jia,
   Dexu and Wei, Wei},
Title = {All-solid-waste alkali-activated materials: A critical review of
   multi-waste synergy, heavy metal stabilization, and sustainable
   engineering applications},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {6},
Month = {DEC},
Abstract = {The cement industry's substantial carbon emissions and the increasing
   accumulation of industrial solid waste pose significant challenges to
   achieving sustainable development in the construction sector.
   Alkali-activated materials (AAMs) have emerged as promising low-carbon
   alternatives that offer high mechanical performance and reduced
   environmental impact. However, their widespread adoption is limited by
   the high cost and environmental risks associated with conventional
   strong alkali activators. All-solid-waste alkali-activated materials
   (ASW-AAMs) provide an innovative ``waste-treats-waste{''} strategy
   through the synergistic substitution of conventional strong alkalis with
   alkaline industrial byproducts. This approach aligns with principles of
   resource efficiency and environmental protection. Despite its promise,
   the development of ASW-AAMs faces several critical challenges, including
   variability in raw material composition, incomplete understanding of
   reaction mechanisms, and inadequate long-term performance data. To
   address these issues in a systematic manner, this review investigates
   three key research domains, namely, the synergistic optimization of
   multi-source solid waste co-processing, the mechanisms that govern the
   regulation of mechanical properties, and the micro-scale elucidation of
   hydration reaction dynamics. Furthermore, the study emphasizes the
   indispensable role of molecular dynamics simulations in unraveling
   atomic-scale reaction mechanisms. It also explores the potential of
   machine learning-based approaches for predictive modeling. These
   insights contribute to the establishment of a foundational framework for
   the industrial implementation of ASW-AAMs. By enabling the
   transformation of industrial byproducts into high-performance
   construction materials, ASW-AAMs offer a viable pathway toward
   decarbonization and the advancement of circular economy objectives in
   the construction industry.},
Type = {Article},
Affiliation = {Zhang, JX (Corresponding Author), Beijing Univ Technol, Beijing Key Lab Traff Engn, Beijing 100124, Peoples R China.
   Zhang, JX (Corresponding Author), Beijing Univ Technol, Beijing Engn Res Ctr Urban Transport Operat Guaran, Beijing 100124, Peoples R China.
   Song, Yongpeng; Zhang, Jinxi; Wu, Hansong; Yang, Ce; Jia, Dexu; Wei, Wei, Beijing Univ Technol, Beijing Key Lab Traff Engn, Beijing 100124, Peoples R China.
   Song, Yongpeng; Zhang, Jinxi; Wu, Hansong; Yang, Ce; Jia, Dexu; Wei, Wei, Beijing Univ Technol, Beijing Engn Res Ctr Urban Transport Operat Guaran, Beijing 100124, Peoples R China.},
DOI = {10.1016/j.jece.2025.119204},
EarlyAccessDate = {SEP 2025},
Article-Number = {119204},
Keywords = {All solid waste; Multi-waste synergy; Mechanisms; Molecular dynamics;
   Machine learning; Heavy metal stabilization},
Keywords-Plus = {CALCIUM; GEOPOLYMERS; METAKAOLIN; SIMULATION; DYNAMICS},
