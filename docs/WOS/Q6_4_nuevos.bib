@article{ WOS:001599769700003,
Author = {Roh, Emily Jimin and Kim, Joongheon and Jung, Soyi and Park, Soohyun},
Title = {Joint scalable quantum convolutional neural network and reverse fidelity
   training for high-accurate recognition in unmanned aerial vehicle
   surveillance},
Journal = {JOURNAL OF SUPERCOMPUTING},
Year = {2025},
Volume = {81},
Number = {16},
Month = {OCT 25},
Abstract = {Unmanned aerial vehicles (UAVs) have demonstrated considerable potential
   in surveillance tasks, primarily owing to their high mobility and
   adaptability. However, these vehicles are often constrained by the
   extensive number of parameters required in conventional neural networks,
   which poses significant challenges under wireless communication
   conditions. To address these limitations, quantum neural networks (QNNs)
   have emerged as a promising solution, demonstrating capabilities that
   classical neural networks are unable to fully realize. Specifically,
   quantum convolutional neural networks (QCNNs) have garnered significant
   attention due to their capacity to process high-dimensional vector
   inputs. However, the capabilities of QCNNs in feature extraction are
   currently constrained by the limitations of quantum computing. In
   response to these challenges, a scalable quantum convolutional neural
   network (sQCNN) is proposed, accompanied by a reverse fidelity-Train
   (RF-Train). This algorithm utilizes quantum fidelity to enhance the
   performance of the sQCNN. In the context of UAV surveillance systems,
   the sQCNN and RF-train framework offer a lightweight, high-performance
   approach that is specifically optimized for UAV applications, ensuring
   efficient operation under demanding conditions.},
Type = {Article},
Affiliation = {Kim, J (Corresponding Author), Korea Univ, Dept Elect \& Comp Engn, Seoul 02841, South Korea.
   Jung, S (Corresponding Author), Ajou Univ, Dept Elect \& Comp Engn, Suwon 16499, South Korea.
