@article{ WOS:001687466200001,
Author = {Bao, Ziming and Wu, Jiaqi and Li, Xinyue and Lian, Lixian and Hu, Wang
   and Huang, Ke and Liu, Ying},
Title = {Data-driven parameters design for laser powder bed fusion of
   high-performance nickel-based superalloys},
Journal = {ADDITIVE MANUFACTURING},
Year = {2026},
Volume = {118},
Month = {FEB 25},
Abstract = {In this study, high-throughput (HT) mechanical testing was coupled with
   machine learning (ML) to guide process-parameter selection for additive
   manufacturing, high-performance nickel-based superalloys. Using laser
   powder bed fusion (LPBF) integrated with an HT room-temperature tensile
   platform, we rapidly fabricated and tested 70 distinct parameter sets,
   establishing a high-quality database that links the principal process
   variables-laser power, scanning speed, and hatch distance-to tensile
   properties (yield strength, ultimate tensile strength, and strain). By
   tuning the hyperparameters of the neural-network model, a high-accuracy
   predictor that maps LPBF parameters to room-temperature performance was
   obtained. Pareto multi-objective optimization was then applied to
   identify parameter windows that balance strength and ductility, selected
   parameters were built and experimentally validated, confirming the
   reliability of the proposed HT-ML workflow. Deep microstructural
   characterization provides a mechanistic basis for the observed
   properties: the alloy's intrinsically low stacking-fault energy and the
   activation of dense a/2 < 110 > dislocations gliding on \{111\}
   planes-particularly the a/2{[}0 1 -1](1 -1 1) system-account for the
   high ductility, whereas the strength is dominated by solid-solution
   strengthening, grain-boundary strengthening due to refined grains, and
   dislocation strengthening. Overall, the framework delivers
   interpretable, mechanism-informed guidance for selecting LPBF parameters
   to achieve nickel-based superalloy components with a good balance of
   high strength and high ductility.},
Type = {Article},
Affiliation = {Lian, LX (Corresponding Author), Sichuan Univ, Sch Mat Sci \& Engn, Chengdu 610065, Peoples R China.
   Bao, Ziming; Wu, Jiaqi; Lian, Lixian; Huang, Ke; Liu, Ying, Sichuan Univ, Sch Mat Sci \& Engn, Chengdu 610065, Peoples R China.
   Li, Xinyue; Hu, Wang, Univ Elect Sci \& Technol China, Sch Comp Sci \& Engn, Chengdu 610065, Peoples R China.},
DOI = {10.1016/j.addma.2026.105104},
EarlyAccessDate = {FEB 2026},
Article-Number = {105104},
