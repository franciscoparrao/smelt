@article{ WOS:001666686200003,
Author = {Li, Longjian and Liu, Gaojie and Yu, Hongrui and Chen, Zeyuan and Kang,
   Huijun and Chen, Zongning and Guo, Enyu and Jie, Jinchuan and Wang,
   Tongmin},
Title = {A machine learning strategy to achieve strength-conductivity-ductility
   synergy of high-performance Cu-Ni-Co-Si alloys via rolling and aging
   process},
Journal = {JOURNAL OF MATERIALS SCIENCE \& TECHNOLOGY},
Year = {2026},
Volume = {267},
Pages = {184-197},
Month = {OCT 1},
Abstract = {The alloying elements and rolling/aging parameters have a critical
   influence on the microstructure and properties of
   precipitation-strengthened Cu-Ni-Co-Si alloys. Nevertheless, the
   complexity of alloy composition, variability in processing parameters,
   and conflicting relationships among material properties impede the
   concurrent improvement of overall performance characteristics. To
   address this, we developed a machine learning design strategy and
   explored the complex effects of key features through feature engineering
   and SHapley Additive exPlanations (SHAP) analysis. Subsequently, the
   NSGA-II algorithm was used to optimize alloy composition, and a
   multi-step rolling and aging process was developed to further tailor
   microstructure and performance. The results demonstrate that the alloy
   exhibits exceptional properties after multi-step rolling and aging. The
   new alloy achieves ultimate tensile strength, electrical conductivity,
   and elongation of the values of 911.4 MPa, 44.37 \% IACS, and 7.3 \%,
   respectively. The remarkable properties of Cu-Ni-Co-Si-Mg-Ti alloys are
   primarily ascribed to the retention of specific crystallographic
   textures, notably Brass and S, alongside the precipitation of alloying
   elements such as Ni, Co, and Si. Preserving these cold-rolled textures
   is crucial for maintaining high strength. Additionally, the formation of
   nanoscale delta-(Ni, Co)2 Si precipitates, enriched with Mg at the
   interfaces, significantly contributed to precipitation strengthening and
   dislocation pinning, promoting enhanced conductivity and uniform plastic
   deformation. These findings establish an interpretable and effective
   framework for the integrated ``composition-process-property{''} design
   of precipitation-strengthened copper alloys, providing quantitative
   insights into the precipitation behavior and texture characteristics of
   Cu-Ni-Co-Si alloys during rolling and aging. (c) 2026 Published by
   Elsevier Ltd on behalf of The editorial office of Journal of Materials
   Science \& Technology.},
Type = {Article},
Affiliation = {Kang, HJ; Wang, TM (Corresponding Author), Dalian Univ Technol, Sch Mat Sci \& Engn, Key Lab Solidificat Control \& Digital Preparat Tec, Dalian 116024, Peoples R China.
   Kang, HJ; Wang, TM (Corresponding Author), Dalian Univ Technol, Ningbo Inst, Ningbo 315000, Peoples R China.
   Li, Longjian; Liu, Gaojie; Yu, Hongrui; Chen, Zeyuan; Kang, Huijun; Chen, Zongning; Guo, Enyu; Jie, Jinchuan; Wang, Tongmin, Dalian Univ Technol, Sch Mat Sci \& Engn, Key Lab Solidificat Control \& Digital Preparat Tec, Dalian 116024, Peoples R China.
   Kang, Huijun; Chen, Zongning; Guo, Enyu; Jie, Jinchuan; Wang, Tongmin, Dalian Univ Technol, Ningbo Inst, Ningbo 315000, Peoples R China.},
DOI = {10.1016/j.jmst.2025.12.040},
EarlyAccessDate = {JAN 2026},
Keywords = {Cu-Ni-Co-Si alloys; Machine learning; Microstructure; Mechanical
   properties; Electrical conductivity},
Keywords-Plus = {ELECTRICAL-CONDUCTIVITY; MECHANICAL-PROPERTIES; TEXTURE EVOLUTION;
   MICROSTRUCTURE EVOLUTION; CR; DEFORMATION; PLASTICITY; BEHAVIOR},
Author-Email = {kanghuijun@dlut.edu.cn
   tmwang@dlut.edu.cn},
Number-of-Cited-References = {60},
Times-Cited = {2},
Unique-ID = {WOS:001666686200003},
}

@article{ WOS:001665257200001,
Author = {Wu, Qingyu and Yao, Yingfang and Wang, Bing and Zou, Zhigang},
Title = {Carbon-encapsulated electrocatalysts for oxygen electrocatalysis},
Journal = {JOURNAL OF MATERIALS CHEMISTRY A},
Year = {2026},
Volume = {14},
Number = {14},
Pages = {7848-7882},
Month = {MAR 3},
Abstract = {Oxygen electrocatalysis, which underpins key energy conversion
   technologies through the oxygen evolution reaction (OER) and oxygen
   reduction reaction (ORR), is plagued by inherently sluggish kinetics
   arising from its four-electron-proton coupled mechanism. This bottleneck
   necessitates the development of high-performance electrocatalysts to
   surmount energy barriers and advance practical device efficiency.
   Carbon-encapsulated electrocatalysts (CEECs), a class of materials
   comprising carbon-based outer layers (OCLs) and metal-based inner
   components (IMCs), have emerged as a transformative solution, leveraging
   synergistic IMCs-OCLs interfaces to simultaneously enhance activity,
   stability, and electrical conductivity. This review synthesizes recent
   progress in CEECs design for oxygen electrocatalysis, focusing on three
   interconnected pillars: (1) mechanistic insights into active sites,
   where debates over the dominant role of OCLs versus IMCs are addressed
   through advanced in situ characterization and density functional theory
   (DFT) simulations, unraveling critical phenomena such as interfacial
   charge redistribution and d-p orbital hybridization; (2) quantitative
   structure-performance relationships, which reveal how OCLs and IMCs
   modulate electron transfer and mass transport; (3) scalable synthesis
   strategies with a focus on parameter control to tailor IMCs-OCLs
   architecture. Despite these advances, unresolved challenges persist,
   including ambiguous active-site localization and poorly understood
   dynamic interfacial behavior under operating conditions. Addressing
   these requires next-generation operando characterization tools and
   machine-learning-guided modeling frameworks. Future directions must
   prioritize scalable synthesis of defect-engineered CEECs, integration of
   in situ techniques to decode reaction mechanisms, and establishment of
   robust quantitative structure-performance relationships. By bridging
   molecular-level insights with macroscopic performance, this review
   provides a blueprint for rational CEECs design, accelerating their
   deployment in next-generation energy devices with unprecedented
   efficiency and durability.},
Type = {Review},
Affiliation = {Yao, YF; Wang, B; Zou, ZG (Corresponding Author), Nanjing Univ, Coll Engn \& Appl Sci, Ecomat \& Renewable Energy Res Ctr ERERC, Jiangsu Key Lab Nano Technol, Nanjing, Peoples R China.
