   Jung, Soyi, Ajou Univ, Dept Elect \& Comp Engn, Suwon 16499, South Korea.
   Park, Soohyun, Sookmyung Womens Univ, Div Comp Sci, Seoul 04310, South Korea.},
DOI = {10.1007/s11227-025-07948-7},
Article-Number = {1495},
Keywords = {Quantum computing; Quantum convolutional neural network; Quantum machine
   learning},
Author-Email = {emilyjroh@korea.ac.kr
