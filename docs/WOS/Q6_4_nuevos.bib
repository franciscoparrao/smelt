}

@article{ WOS:001661512000001,
Author = {Movahedi-Rad, A. Vahid and Ritter, Maximilian and Colmant, Alan and
   Vivas Glaser, Dan and Stucki, Sandro and Burgert, Ingo and Panzarasa,
   Guido},
Title = {Combined Experimental and Machine Learning Study on the Interplay
   between Delignification and Mechanical Properties for Improved Poplar
   Wood Reconstruction},
Journal = {ACS APPLIED MATERIALS \& INTERFACES},
Year = {2026},
Volume = {18},
Number = {3},
Pages = {5882-5895},
Month = {JAN 28},
Abstract = {Structure-retaining delignification of wood is widely used to obtain
   scaffolds suitable for the preparation of high-performance biobased
   composites. However, this often comes at the expense of sustainability
   and large-scale production potential. To address these issues, we
   reconstructed poplar wood via room-temperature partial delignification,
   followed by delignification and densification. Compared to fully
   delignified samples, those obtained with partial delignification have
   superior mechanical properties at 45 degrees and 90 degrees fiber
   directions with respect to the loading direction, but lower ones at 0
   degrees. Working at room temperature facilitated sample up-scaling and
   allowed reuse of the delignification solution multiple times without
   compromising product quality. As shown by life cycle assessment (LCA),
   the possibility of repeatedly reusing the delignification solution led
   to a significant reduction in the global warming potential (GWP) and
   ecosystem quality (EQ) impacts. We then developed an `unsupervised,
   supervised classification, supervised regression' (USS) learning
   framework to accurately predict the mechanical properties of
   reconstructed poplar on the basis of structural and process-related
   features, followed by feature importance analysis to determine the key
   parameters influencing material performance. With our approach, we were
   able to estimate the mechanical performance of the reconstructed samples
   and gain insight into the most relevant material-fabrication parameters.},
Type = {Article},
Affiliation = {Movahedi-Rad, AV; Panzarasa, G (Corresponding Author), Swiss Fed Inst Technol, Inst Bldg Mat, Wood Mat Sci, CH-8093 Zurich, Switzerland.
   Movahedi-Rad, A. Vahid; Ritter, Maximilian; Colmant, Alan; Vivas Glaser, Dan; Stucki, Sandro; Burgert, Ingo; Panzarasa, Guido, Swiss Fed Inst Technol, Inst Bldg Mat, Wood Mat Sci, CH-8093 Zurich, Switzerland.
   Ritter, Maximilian; Stucki, Sandro; Burgert, Ingo, Empa Swiss Fed Labs Mat Sci \& Technol, Lab Cellulose \& Wood Mat, Grp WoodTec, CH-8600 Dubendorf, Switzerland.},
DOI = {10.1021/acsami.5c20194},
EarlyAccessDate = {JAN 2026},
Keywords = {biocomposite; delignification; mechanical properties; water uptake; life
   cycle assessment (LCA); machine learning},
Keywords-Plus = {POLYMERIC BIOCOMPOSITES; LIGNIN; PERFORMANCE},
Author-Email = {avahidmovahedirad@ethz.ch
   guidop@ethz.ch},
Number-of-Cited-References = {55},
