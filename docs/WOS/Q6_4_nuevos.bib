   Harashima, Yosuke; Fujii, Mikiya, Nara Inst Sci \& Technol, Data Sci Ctr, Ikoma, Nara 6300192, Japan.},
DOI = {10.1021/acscatal.5c02536},
EarlyAccessDate = {JUL 2025},
Keywords = {machine learning; data analysis; photoelectrochemicalwater splitting;
   doping; hematite; photocatalysts; photoelectrodes},
