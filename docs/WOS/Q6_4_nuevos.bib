DOI = {10.1007/s11306-025-02333-0},
Article-Number = {137},
Keywords = {Oligoasthenozoospermia; Seminal plasma; Metabolomics; Biomarker; Machine
   learning},
Author-Email = {tengxiaoming@51mch.com
   gy\_guoyi@tongji.edu.cn},
Number-of-Cited-References = {25},
