   Zou, Guangrong, Sun Yat Sen Univ, Affiliated Hosp 7, Dept Clin Lab, Shenzhen 518107, Guangdong, Peoples R China.},
DOI = {10.1016/j.talanta.2025.129298},
EarlyAccessDate = {JAN 2026},
