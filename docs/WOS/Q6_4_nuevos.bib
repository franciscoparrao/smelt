DOI = {10.3390/polym18040470},
Article-Number = {470},
Keywords = {fused deposition modeling; polylactic acid; fracture energy; Taguchi
   method; grey wolf optimizer; ensemble learning; optimization; machine
   learning},
Keywords-Plus = {IMPACT STRENGTH; 3D},
Author-Email = {volkanates@tarsus.edu.tr
