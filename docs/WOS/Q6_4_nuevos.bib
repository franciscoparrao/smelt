@article{ WOS:001598757200003,
Author = {Han, Jufeng and Wei, Shu and Ren, Xiangyu and Yu, Lina and Sun, Linjun
   and Yue, Shizhong and Li, Weijun and Wu, Min and Qin, Hong},
Title = {Bandgap prediction for perovskite materials based on symbolic-neural
   hybrid modeling},
Journal = {MATERIALS TODAY ENERGY},
Year = {2025},
Volume = {54},
Month = {DEC},
Abstract = {Rapid and accurate prediction of the bandgap in perovskite materials is
   essential for the accelerated discovery of high-performance energy
   materials and the advancement of photovoltaic technologies. In this
   work, we propose a hybrid modeling framework that integrates symbolic
   regression (SR) with neural networks (NN), effectively combining the
   physical interpretability of symbolic expressions with the powerful
   nonlinear representation capability of neural networks. This approach
   overcomes the limitations of conventional single-model methods and
   achieves high-precision bandgap prediction for perovskite materials.
   Symbolic regression is employed to automatically extract symbolic
   expressions from compositional features, and the structural skeleton of
   the expression is retained as a structured encoder. Building upon this,
   a Symbolically Encoded Neural Network (SENN) is constructed, enabling
   the neural network to robustly learn the mapping between composition and
   bandgap under structural guidance. Comparative experiments demonstrate
   that SENN outperforms traditional machine learning methods in terms of
   prediction accuracy and model stability, thereby achieving both high
   precision and strong generalization capability. This method not only
   provides a quantitative analytical tool for elucidating the
   composition-bandgap structure-property relationship, but also offers a
   practical pathway for developing intelligent material models that are
