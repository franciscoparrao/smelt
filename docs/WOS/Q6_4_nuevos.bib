Keywords-Plus = {ACCELERATED DESIGN; ALUMINUM-ALLOYS; PREDICTION; STRENGTH;
   MICROSTRUCTURE; TEMPERATURE; PERFORMANCE; TOUGHNESS; PROPERTY; PURE},
Author-Email = {sylvanasama@gmail.com},
