@article{ WOS:001563949800007,
Author = {Xu, Ting and Li, Sheng and Chai, Zheng and Yu, Qiuming and Li, Bo and
   Tian, Weichen},
Title = {Overcoming local compression challenges in UHPC-CA anchorage zones: A
   robust machine learning approach},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2025},
Volume = {48},
Month = {SEP},
Abstract = {Ultra-high performance concrete with coarse aggregates (UHPC-CA)
   demonstrates significant potential for overcoming current technical
   limitations in long-span concrete bridges, owing to its exceptional
   strength-to-weight ratio and superior durability. However, the reduced
   cross-sectional dimensions of UHPC-CA components amplify local
   compression effects, presenting critical challenges including highly
   concentrated stresses, non-uniform strain distributions, and pronounced
   nonlinear behavior. Existing calculation models failed to adapt to these
   UHPC-CA-specific complexities adequately. To address this gap, an
   innovative solution integrating machine learning (ML) and optimization
   algorithms was proposed. A comprehensive LBC database containing 208
   data samples was constructed to systematically evaluate the prediction
   performance of five representative ML algorithms: Random Forest, Support
   Vector Regression, Gaussian Process Regression, XGBoost, and Multilayer
   Perceptron (MLP). Results demonstrated that all ML models (R-2>0.94)
   substantially outperformed traditional regression models and existing
   specification formulations in both accuracy and reliability. Notably,
   the MLP model achieved the most exceptional performance (R-2=0.9958). To
   mitigate issues of local optima entrapment, limited generalization
   inherent and computational efficiency in ML models, a Particle Swarm
   Optimization (PSO) algorithm was further introduced for hyperparameter
   tuning coupled with collinearity analysis for feature pruning. This
   optimization strategy yielded remarkable results, with the PSO-optimized
   MLP model exhibiting enhanced prediction robustness (R-2=0.9986).
   Furthermore, feature pruning implementation achieved a 28.6 \% reduction
   in input dimensionality while maintaining superior predictive capability
   (R-2=0.9978). This data-driven ML framework established an effective
   approach for bridge anchorage zone design and local compression
   prediction, facilitating a civil engineering paradigm shift from
   experience-dependent practices toward intelligent prediction methods.},
Type = {Article},
Affiliation = {Li, S (Corresponding Author), Jiangxi Univ Sci \& Technol, Sch Software Engn, Nanchang 330000, Peoples R China.
   Xu, Ting; Li, Sheng; Chai, Zheng; Yu, Qiuming; Li, Bo, Jiangxi Univ Sci \& Technol, Sch Software Engn, Nanchang 330000, Peoples R China.
   Tian, Weichen, Nanchang Univ, Sch Infrastruct Engn, Nanchang 330031, Peoples R China.},
DOI = {10.1016/j.mtcomm.2025.113646},
EarlyAccessDate = {AUG 2025},
Article-Number = {113646},
Keywords = {UHPC-CA; Local compression capacity; Machine learning; Prediction model;
   Algorithm optimization},
Keywords-Plus = {OPTIMIZATION; PREDICTION; ALGORITHMS},
Author-Email = {shengli@jxust.edu.cn},
Number-of-Cited-References = {61},
Times-Cited = {0},
Unique-ID = {WOS:001563949800007},
