   Ma, Yan, Delft Univ Technol, Dept Mat Sci Engn, NL-2628 CD Delft, Netherlands.},
DOI = {10.1073/pnas.2530922123},
Article-Number = {e2530922123},
Keywords = {multi-principal-element alloys; machine learning; strength; ductility},
Keywords-Plus = {MECHANICAL-PROPERTIES; ENTROPY ALLOY; MICROSTRUCTURE; PHASE},
Author-Email = {ziyuanrao@sjtu.edu.cn
   chang.liu@xjtu.edu.cn},
