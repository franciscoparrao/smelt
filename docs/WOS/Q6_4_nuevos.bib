   rajkumar7.v@gmail.com},
Number-of-Cited-References = {61},
Times-Cited = {1},
Unique-ID = {WOS:001632077000001},
}

@article{ WOS:001637399900001,
Author = {Bharti, Chandan and Puklath, Varsha and Ghosh, Debraj},
Title = {Fragility analysis of dam-reservoir systems under seismic loading using
   LSTM-integrated model order reduction},
Journal = {RELIABILITY ENGINEERING \& SYSTEM SAFETY},
Year = {2026},
Volume = {269},
Month = {MAY},
Abstract = {Seismic analysis of dam-reservoir systems considering fluid-structure
   interactions and nonlinear material behavior is crucial for safety
   assessment. It requires a three-dimensional full-scale model capable of
   capturing various failure modes, considering various uncertainties.
   Fragility analysis, routinely used in a probabilistic framework, is
   computationally very expensive because of the size and need for repeated
   simulations. This issue is addressed here using a combination of reduced
   order modeling (ROM), machine learning, and high-performance computing
   using CPU and GPU. Accordingly, a proper orthogonal decomposition (POD)
   based non-intrusive ROM is integrated with LSTM for high dimensional
   regression. Two new modifications to an existing framework are proposed
   here. First, force-feeding system parameter information in the LSTM, and
   second, adopting two-step singular value decomposition for large
   systems. A model of the Koyna dam of varying complexities - from 2D
   linear to 3D nonlinear models with more than 105 degrees of freedom -
   under non-stationary excitations is considered for numerical studies.
   The nonlinearity is modeled using a continuum plasticity-based damage
   model. The proposed methodology is scalable, and achieves a
   computational speed-up of three orders of magnitude compared to the
   full-scale analysis. The non-intrusive nature of the method allows usage
   of any black box or commercial code.},
Type = {Article},
Affiliation = {Ghosh, D (Corresponding Author), Indian Inst Sci, Dept Civil Engn, Bangalore, India.
   Bharti, Chandan; Puklath, Varsha; Ghosh, Debraj, Indian Inst Sci, Dept Civil Engn, Bangalore, India.},
DOI = {10.1016/j.ress.2025.111983},
EarlyAccessDate = {DEC 2025},
Article-Number = {111983},
Keywords = {Dam; Non-intrusive reduced order model; Uncertainty quantification;
   Fragility; Machine learning},
Keywords-Plus = {GRAVITY DAM; EARTHQUAKE},
Author-Email = {cbharti@iisc.ac.in
   pvarsha@iisc.ac.in
   dghosh@iisc.ac.in},
Number-of-Cited-References = {61},
Times-Cited = {1},
Unique-ID = {WOS:001637399900001},
}

@article{ WOS:001631432500001,
Author = {Lu, Xuefeng and Bai, Meng and Shi, Yajie and Zhang, Zhijian and Ren,
   Junqiang and Tang, Xingchang and Guo, Xin},
Title = {Challenging the electrochemical properties of
   Nb2CO2/Si3N4 heterojunction
   by first principles combined with machine learning},
Journal = {JOURNAL OF SOLID STATE ELECTROCHEMISTRY},
Year = {2026},
Volume = {30},
Number = {3},
Pages = {1347-1359},
Month = {MAR},
Abstract = {Two-dimensional ceramics-based materials exhibit fascinating performance
   in the electrochemical field in recent years. In the present
   contribution, the electronic performance of the Nb2CO2/Si3N4
   heterojunction as an anode material are systematically investigated by
   the first principles calculations. The structural stability of the
   Nb2CO2/Si3N4 heterostructure is verified by a negative binding energy,
   indicating favorable energetic stability. Moreover, the heterostructure
   demonstrates excellent electrochemical kinetics, with ultra-low
   diffusion energy barriers of 0.231 eV for Li ion and 0.316 eV for Na
   ion. With the increase of Li and Na ions concentrations, the average
   adsorption energy of the heterostructure is -0.12 eV and -0.53 eV,
   respectively. The theoretical specific capacity reaches 429.73 mAh/g for
   Li and 330.46 mAh/g for Na, surpassing that of conventional graphite
   anodes. Furthermore, the average open-circuit voltage (OCV) at maximum
   loading is 0.41 V and 0.35 V, which is within the reasonable expected
   range, thus ensuring the safety of the electrode material. These results
   show that Nb2CO2/Si3N4 has great potential as anode materials for metal
   ion batteries. The gradient boosting regression (GBR) algorithm with R2
   of 0.91 is the most accurate for predicting adsorption energy by using
   the method of machine learning, followed by random forest (RF) with R2
   of 0.897 and support vector regression (SVR) with R2 of 0.848. This high
   accuracy confirms the robustness of the descriptors, providing a
   valuable framework for the accelerated design of high-performance anode
   materials.},
Type = {Article},
Affiliation = {Guo, X (Corresponding Author), Lanzhou Univ Technol, Sch Mat Sci \& Engn, State Key Lab Adv Proc \& Recycling Nonferrous Met, Lanzhou 730050, Peoples R China.
   Lu, Xuefeng; Bai, Meng; Shi, Yajie; Zhang, Zhijian; Ren, Junqiang; Tang, Xingchang; Guo, Xin, Lanzhou Univ Technol, Sch Mat Sci \& Engn, State Key Lab Adv Proc \& Recycling Nonferrous Met, Lanzhou 730050, Peoples R China.},
DOI = {10.1007/s10008-025-06489-6},
EarlyAccessDate = {DEC 2025},
Keywords = {First-principles; Anode; Machine learning; Adsorption energy;
   Heterostructure},
Keywords-Plus = {ANODE MATERIAL; ION; NA; LI; MONOLAYER; MXENE},
Author-Email = {guoguox2008@163.com},
