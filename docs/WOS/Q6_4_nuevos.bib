   Juneja, Akshay, COER Univ, Dept Comp Sci \& Engn, Roorkee, Uttarakhand, India.},
DOI = {10.1080/01969722.2026.2632344},
EarlyAccessDate = {FEB 2026},
Keywords = {Content moderation; deep learning; obscene content; privacy-preserving
   machine learning; transformer models},
Keywords-Plus = {PORNOGRAPHIC IMAGES},
Author-Email = {vijaykumarchahar@gmail.com},
Number-of-Cited-References = {55},
Times-Cited = {0},
