   Gautam, Gopalakrishnan Sai, Indian Inst Sci, Dept Mat Engn, Bengaluru 560012, India.
   Zhu, Bonan, Beijing Inst Technol, Sch Aerosp Engn, Beijing 100081, Peoples R China.
   Zhu, Bonan, State Key Lab Environm Characterist \& Effects Near, Beijing 100081, Peoples R China.},
DOI = {10.1039/d5ta05321h},
EarlyAccessDate = {SEP 2025},
Keywords-Plus = {IONIC-CONDUCTIVITY; CONDUCTORS},
