@article{ WOS:001643584700001,
Author = {Tsuzuki, Hina and Shirzadi, Mohammadreza and Rachmawati, Ika Yuni and
   Fukasawa, Tomonori and Fukui, Kunihiro and Ishigami, Toru},
Title = {Machine learning-driven fiber alignment strategies for air filter
   performance enhancement},
Journal = {CHEMICAL ENGINEERING SCIENCE},
Year = {2026},
Volume = {323},
Month = {MAR 15},
Abstract = {Understanding how fiber orientation influences the performance of
   fibrous filters is essential for advancing filtration technology. This
   study focuses on fiber orientation as a key microstructural parameter
   and presents a machine learning (ML)-driven optimization framework for
   designing high-performance fibrous filters. The framework integrates
   three-dimensional computational fluid dynamics (CFD) coupled with a
   discrete phase model (DPM), surrogate modeling using neural networks
   (NNs), and genetic algorithms (GA). Two strategies for generating the
   microstructure geometry were proposed: one based on the probability
   density function (PDF) of the fiber orientation, and the other using the
   solid volume fraction (SVF) at specific fiber orientation angles. CFDDPM
   simulations were performed to evaluate the pressure drop and particle
   collection efficiency for each design. The resulting dataset was used to
   train the NN models to accurately predict filter performance. These
   models were then embedded in a GA framework to optimize the filter
   design parameters, targeting a minimal pressure drop while achieving a
   high collection efficiency. Sensitivity analysis revealed that the fiber
   orientation had the greatest influence on the quality factor. The
   SVF-based optimization outperformed the PDF-based approach, achieving a
   higher quality factor through finer fiber diameters, increased porosity,
   and a higher proportion of fibers oriented at 70-90 degrees to the flow.
   The proposed framework enables data-driven digital prototyping for
   fibrous filter design and offers scalable solutions for next-generation
   respiratory protection and industrial filtration systems.},
Type = {Article},
Affiliation = {Shirzadi, M; Ishigami, T (Corresponding Author), Hiroshima Univ, Grad Sch Adv Sci \& Engn, Chem Engn Program, 1-4-1 Kagamiyama, Hiroshima, Hiroshima 7398527, Japan.
   Tsuzuki, Hina; Shirzadi, Mohammadreza; Rachmawati, Ika Yuni; Fukasawa, Tomonori; Fukui, Kunihiro; Ishigami, Toru, Hiroshima Univ, Grad Sch Adv Sci \& Engn, Chem Engn Program, 1-4-1 Kagamiyama, Hiroshima, Hiroshima 7398527, Japan.},
DOI = {10.1016/j.ces.2025.123169},
EarlyAccessDate = {DEC 2025},
Article-Number = {123169},
Keywords = {Air filter; Computational fluid dynamics; Discrete phase model; Fiber
   orientation optimization; Genetic algorithm; Machine learning
   optimization},
Keywords-Plus = {FIBROUS FILTER; PRESSURE-DROP; EFFICIENCY; PARTICLES; OPTIMIZATION},
Author-Email = {shirzadi@hiroshima-u.ac.jp
   ishigami@hiroshima-u.ac.jp},
Number-of-Cited-References = {61},
Times-Cited = {0},
Unique-ID = {WOS:001643584700001},
}

@article{ WOS:001644092900001,
Author = {Ansari, Mohd Zahid and Ansari, Sajid Ali and Parveen, Nazish and
   Alsulaim, Ghayah M. and Umar, Ahmad and Shaalan, Nagih M. and Kim,
   Soo-Hyun},
Title = {Exploring graphdiyne, MXene, borophene, and phosphorene as advanced 2D
   materials for next-generation metallic ion batteries},
Journal = {PROGRESS IN MATERIALS SCIENCE},
Year = {2026},
Volume = {158},
Month = {APR},
Abstract = {Metallic ion batteries such as lithium-ion batteries (LIBs), sodium-ion
   batteries (SIBs), potassiumion batteries (KIBs), and magnesium-ion
   batteries (MIBs) have gained increasing attention as alternatives to
   conventional lithium-based energy storage technologies. Advanced
   twodimensional (2D) materials, including graphdiyne (GDY), transition
   metal carbides/nitrides (MXenes), borophene, metal-organic frameworks
   (MOFs), and phosphorene, offer considerable promise as next-generation
   anode materials due to their unique physicochemical features. These
   materials exhibit large surface areas, abundant active sites, tunable
   porosity, and variable electronic structures, enabling improved ion
   storage, enhanced conductivity, and structural stability during cycling.
   Graphdiyne provides high theoretical capacities and favorable diffusion
   kinetics. MXenes deliver metallic conductivity and functionalized
   surface terminations that support rapid charge transport. Borophene
   offers exceptional charge carrier mobility but remains experimentally
   constrained due to instability. MOF-derived materials contribute
   redox-active centers and ion-accessible channels, while phosphorene
   provides high theoretical capacity and fast ion diffusion but suffers
   from environmental sensitivity. This review highlights recent advances
   in the structural design, heteroatom doping, and composite engineering
   of these materials for enhanced performance. Additionally, it outlines
   the persistent challenges related to interface degradation, structural
   collapse, and synthesis scalability, while suggesting future directions
   including in situ/ operando characterization and machine learning-guided
   material discovery for the development of stable, high-capacity metallic
   ion batteries.},
