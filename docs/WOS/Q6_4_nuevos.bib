}

@article{ WOS:001660699700001,
Author = {Paigwar, Vaibhav and Khatirkar, Rajesh and Khurana, Khushboo and
   Bhadauria, Alok},
Title = {Predicting and optimising aluminium alloy compositions for target
   mechanical properties using machine learning},
Journal = {CANADIAN METALLURGICAL QUARTERLY},
Year = {2026},
Month = {2026 JAN 14},
Abstract = {This study presents a machine learning framework for aluminium alloy
   design, solving the long-standing challenge of predicting alloy
   compositions from target properties. The prediction of alloy
   compositions is an inverse design problem, which is addressed by the use
   of machine learning approaches in the present work, reducing the
   material development time. Eight regression algorithms are benchmarked
   for forward prediction, with gradient boosting regression (GBR) emerging
   as the most accurate model. This model was then used to find the
   important alloying elements for training the forward regressor. For the
   inverse prediction, optimisation approach was utilised by using a
   genetic algorithm (GA) with GBR. The proposed inverse model successfully
   generated alloy compositions that achieve high performance, for
   properties like ultimate tensile strength (UTS) and yield strength (YS),
   with R2 values greater than 0.84 for all models. Predicted compositions
   were validated using the forward model and experimentally confirmed for
   an Al-Si alloy, demonstrating strong agreement. The results highlight
   the potential of ML-assisted inverse design to accelerate alloy
   development, reduce experimentation and enable precise optimisation of
   aluminium alloys for targeted properties.
   Cette \& eacute;tude pr \& eacute;sente un cadre d'apprentissage
   automatique (ML) pour la conception d'alliages d'aluminium, r \&
   eacute;solvant le d \& eacute;fi de longue date de la pr \&
   eacute;diction de la composition des alliages \& agrave; partir de leurs
   propri \& eacute;t \& eacute;s cibles. La pr \& eacute;diction de la
   composition des alliages est un probl \& egrave;me de conception
   inverse, que l'on aborde gr \& acirc;ce \& agrave; des approches
   d'apprentissage automatique, r \& eacute;duisant ainsi le temps de d \&
   eacute;veloppement des mat \& eacute;riaux. On a \& eacute;valu \&
   eacute; huit algorithmes de r \& eacute;gression pour la pr \&
   eacute;diction directe, la r \& eacute;gression par amplification de
   gradient (GBR) \& eacute;mergeant comme le mod \& egrave;le le plus pr
   \& eacute;cis. On a ensuite utilis \& eacute; ce mod \& egrave;le pour
   identifier les \& eacute;l \& eacute;ments d'alliage importants pour
   entra \& icirc;ner la variable descriptive directe. Pour la pr \&
   eacute;diction inverse, on a utilis \& eacute; une approche
   d'optimisation en utilisant un algorithme g \& eacute;n \& eacute;tique
   (GA) avec GBR. Le mod \& egrave;le inverse propos \& eacute; a g \&
   eacute;n \& eacute;r \& eacute; avec succ \& egrave;s des compositions
   d'alliage performantes, pour des propri \& eacute;t \& eacute;s telles
   que la r \& eacute;sistance ultime \& agrave; la traction (UTS) et la
   limite d'\& eacute;lasticit \& eacute; (YS), avec des valeurs de R2 sup
   \& eacute;rieures \& agrave; 0.84 pour tous les mod \& egrave;les. On a
   valid \& eacute; les compositions pr \& eacute;dites en utilisant le mod
   \& egrave;le direct, puis confirm \& eacute; exp \& eacute;rimentalement
   pour un alliage Al-Si, d \& eacute;montrant une forte concordance. Ces r
   \& eacute;sultats soulignent le potentiel de la conception inverse
   assist \& eacute;e par ML pour acc \& eacute;l \& eacute;rer le d \&
   eacute;veloppement des alliages, r \& eacute;duire l'exp \&
   eacute;rimentation et faciliter l'optimisation pr \& eacute;cise des
   alliages d'aluminium en vue d'obtenir les propri \& eacute;t \& eacute;s
   cibl \& eacute;es.},
