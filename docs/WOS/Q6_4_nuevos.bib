   Adamu, Haruna; Alam, Umair; Qamar, Mohammad, King Fahd Univ Petr \& Minerals, Interdisciplinary Res Ctr Hydrogen Technol \& Carbo, Dhahran 31261, Saudi Arabia.},
DOI = {10.1016/j.est.2025.119846},
EarlyAccessDate = {DEC 2025},
