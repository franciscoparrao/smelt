@article{ WOS:001700382600001,
Author = {Kundu, Kaushik and Kumar, Avan and Kodamana, Hariprasad and Pant, Kamal
   K.},
Title = {Data-driven optimization of catalyst composition and reaction
   temperature for hydrogen-rich syngas yield from biomass gasification:
   Experimental validation and characterization},
Journal = {ENERGY CONVERSION AND MANAGEMENT},
Year = {2026},
Volume = {354},
Month = {APR 15},
Abstract = {The production of hydrogen-rich syngas via catalytic biomass
   gasification is a critical sustainable strategy where efficiency is
   governed by complex interactions between material properties and process
   conditions. However, conventional trial-and-error experimental methods
   often fail to navigate the high-dimensional parameter space required to
   optimize multi-component catalysts and reaction temperatures
   simultaneously. This research is grounded to an integrated machine
   learning and Bayesian optimization framework which can autonomously
   identify synergistic bimetallic configurations to maximize hydrogen-rich
   syngas yield while minimizing process thermal energy input. A Gaussian
   Process Regression model was coupled with an active learning strategy to
   systematically explore Fe-Ni/Dolomite compositions and thermal gradients
   using a statistically robust dataset of 46 triplicate-verified
   experimental points. The framework achieved a predictive accuracy of R-2
   similar to 0.97 and identified an optimal catalyst composition
   (Fe37.5Ni12.9/Dol(50)) that delivered an experimental yield of 39.67
   m(3)/kg of biomass and a 99.4\% tar reformation efficiency at 884
   degrees C with H-2/(CO + CO2) ratio of 1.95 in a span of 3 h.
   Additionally, insightful characterization techniques were employed to
   probe the textural, morphological, and chemical properties like oxygen
   vacancies and spinel phase formation of the optimized catalysts, thereby
   substantiating their enhanced functional performance to provide a
   scalable blueprint for the rational design of high-performance
   heterogeneous catalysts. Collectively, the study underscores the
   efficacy of machine learning with Bayesian optimization as a competent
   and suitable computational framework to identify catalyst composition
   and operating conditions for achieving desired performance.},
Type = {Article},
Affiliation = {Pant, KK (Corresponding Author), Indian Inst Technol Delhi, Dept Chem Engn, New Delhi 110016, India.
   Kundu, Kaushik; Kodamana, Hariprasad; Pant, Kamal K., Indian Inst Technol Delhi, Dept Chem Engn, New Delhi 110016, India.
