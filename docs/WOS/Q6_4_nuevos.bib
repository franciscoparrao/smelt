   Fu, Yawei, Hunan Agr Univ, Coll Anim Sci \& Technol, Changsha 410128, Peoples R China.},
DOI = {10.1002/aelm.202500262},
EarlyAccessDate = {JUL 2025},
Keywords = {aerogel; machine learning; MXene; pressure sensor; wearable devices},
Keywords-Plus = {TI3C2TX MXENE; SOFT; SENSITIVITY},
