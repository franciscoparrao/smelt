   Wu, Xiongwu; Brooks, Bernard R., NHLBI, Lab Computat Biol, NIH, Bethesda, MD 20892 USA.},
DOI = {10.1021/acs.jctc.5c00598},
EarlyAccessDate = {JUL 2025},
Keywords-Plus = {FORCE-FIELD; DRUG DESIGN; INTEGRATION; VALIDATION; PREDICTION;
