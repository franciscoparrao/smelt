DOI = {10.1016/j.jece.2025.120263},
EarlyAccessDate = {NOV 2025},
Article-Number = {120263},
Keywords = {Metal-organic frameworks; Methane adsorption; Machine learning;
   Multi-task learning; Shapley additive explanations},
Keywords-Plus = {WET FLUE-GAS; HIGH-PERFORMANCE; STORAGE; DISCOVERY; PREDICTION;
   HYDROGEN; POROSITY; CAPTURE; DESIGN; MOFS},
