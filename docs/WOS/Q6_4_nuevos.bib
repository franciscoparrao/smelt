@article{ WOS:001606677500012,
Author = {Kumar, Gautam and Bhaduri, Aritra and Singh, Rishav},
Title = {Distilling Intelligence: Boosting Photonic Sensor Performance Through
   Knowledge Transfer},
Journal = {IEEE SENSORS JOURNAL},
Year = {2025},
Volume = {25},
Number = {21},
Pages = {39978-39985},
Month = {NOV 1},
Abstract = {The evolution of fiber-optic surface plasmon resonance (FO-SPR) sensors
   has significantly advanced the field of sensing, driving innovations in
   biomedical diagnostics, environmental monitoring, and industrial
   automation. However, traditional machine learning (ML) approaches used
   to enhance these sensors often suffer from high prediction errors,
   restricting their impact. In this work, we present a sensor-focused
   knowledge distillation (KD) framework aimed at improving the prediction
   error and efficiency of figure of merit (FOM) prediction, an essential
   parameter for FO-SPR sensor optimization. The proposed method leverages
   an ensemble of feedforward neural networks (FNNs) as teacher models to
   extract nonlinear relationships between structural parameters and sensor
   performance. These models generate soft labels that encapsulate
   intermodel uncertainty and latent patterns. A compact student model is
   then trained using a dual-loss function that integrates both soft
   teacher outputs and ground-truth data. The resulting distilled model
   outperforms existing methods {[}e.g., Gaussian process regression
   (GPR)], achieving high performance (mean squared error (MSE): 8223.022,
   root MSE (RMSE): 90.681, mean absolute error (MAE): 50.712, and R-2:
   0.98). Residual analysis validates its robustness under varying
   conditions. This approach enables real-time, data-driven optimization of
   photonic sensor design, particularly in selecting optimal wavelengths
   and material thicknesses, thus representing a scalable solution for
   next-generation intelligent sensor systems.},
Type = {Article},
Affiliation = {Singh, R (Corresponding Author), Indian Inst Technol Patna, Dept Comp Sci \& Engn, Patna 801106, India.
   Kumar, Gautam; Bhaduri, Aritra; Singh, Rishav, Indian Inst Technol Patna, Dept Comp Sci \& Engn, Patna 801106, India.},
DOI = {10.1109/JSEN.2025.3610225},
Keywords = {Sensors; Photonics; Intelligent sensors; Predictive models;
   Optoelectronic and photonic sensors; Computational modeling; Surface
   plasmon resonance; Sensor systems; Optimization; Training; Figure of
   merit (FOM); knowledge distillation (KD); machine learning (ML); sensor;
   thickness (lambda); wavelength (dm)},
Keywords-Plus = {OPTICAL-FIBER SENSOR; MICROWAVE PHOTONICS},
