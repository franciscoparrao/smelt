   Hassan, Dina S. M., Princess Nourah bint Abdulrahman Univ, Coll Comp \& Informat Sci, Dept Informat Technol, POB 84428, Riyadh 11671, Saudi Arabia.},
DOI = {10.1007/s12672-025-04369-z},
Article-Number = {455},
Keywords = {Prostate cancer; Hybrid RF-lightGBM; Novel graph-convolutional feature
   selection; Biomarkers; Molecular signature},
Keywords-Plus = {BIOLOGICAL FUNCTION; FUCOSYLATION; DEFICIENCY; DIAGNOSIS; FUCOSE; LEADS},
