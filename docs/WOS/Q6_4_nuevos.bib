@article{ WOS:001641026500018,
Author = {He, Tao and Gong, Xiaoya and Chen, Zhengyan and Li, Chaofan and Peng,
   Chao},
Title = {Pitting Life Optimization for Helical Gears Based on Interfacial
   Lubrication and Machine Learning},
Journal = {JOURNAL OF TRIBOLOGY-TRANSACTIONS OF THE ASME},
Year = {2026},
Volume = {148},
Number = {2},
Month = {FEB 1},
Abstract = {Helical gears play a crucial role in mechanical transmission due to
   their superior load-bearing capacity and stability. However, achieving
   high-performance lubrication and extending pitting life remain
   significant challenges. This study develops a mixed elastohydrodynamic
   lubrication (EHL) model and introduces a novel pitting life optimization
   framework with machine learning. The methodology integrates a contact
   line percentage method for meshing parameters, a discrete
   convolution-fast Fourier transform (DC-FFT) for surface deformation, and
   Zaretsky's theory for predicting pitting life. Data-driven approaches,
   including back propagation neural network (BPNN), random forest (RF),
   gradient boosting decision tree (GBDT), and non-dominated sorting
   genetic algorithm-II (NSGA-II) are employed for prediction and
   multi-parameter optimization. Comprehensive investigations reveal that
   structural parameters exhibit varying degrees of influence, and
   coordinated adjustment significantly enhances fatigue reliability while
   restricting volume, providing guidance for practical design.},
