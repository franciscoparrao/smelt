@article{ WOS:001639949500002,
Author = {Zhang, Zuoshan and Liang, Dongyang and Tang, Gongbin and Hua, Yubo and
   Dong, Bangwei and Liang, Zhongwei},
Title = {Data-driven multi-objective synergistic to targeted enhancement
   framework for high-performance aluminum alloy design},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {165},
Number = {B},
Month = {FEB 1},
Abstract = {Although machine learning demonstrates significant advantages in
   predicting material properties, major bottlenecks still exist in the
   inverse design of novel materials with breakthrough performance. To
   address this issue, this paper proposes an inverse generative design
   framework that deeply integrates the global optimization mechanism of
   the simulated annealing algorithm with the category controllability of
   auxiliary classifier generative adversarial networks, establishing a
   dynamic balance mechanism for multi-objective cooperative optimization
   and single-target directed enhancement. By dynamically optimizing the
   latent space distribution through the random perturbations of the
   simulated annealing algorithm, the framework achieves targeted control
   of a specific property while ensuring excellent overall multi-objective
   performance. Taking the design of low-density and high-strength aluminum
   alloys for aerospace as an example, gradient boosting regression tree
   evaluation shows that the inverse generative design framework can
   generate novel aluminum alloy samples: while guaranteeing a specific
   strength greater than 142 megapascal cubic centimeters per gram, the
   average density can be reduced to 2.83 grams per cubic centimeter (a 3.1
   percent decrease) or the average tensile strength enhanced to 621
   megapascals (a 110.8 percent increase), verifying the dual advantages of
   multi-objective cooperation and single-target intensification, and
   providing an effective solution for efficient inverse material design.},
