   Chen, Cheng; Stiens, Johan, Vrije Univ Brussel VUB, Dept Elect \& Informat ETRO, B-1050 Brussels, Belgium.
   Stiens, Johan, IMEC, SSET Dept, B-3001 Leuven, Belgium.},
DOI = {10.1109/JSTQE.2026.3670043},
