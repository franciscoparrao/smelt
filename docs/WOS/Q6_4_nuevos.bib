@article{ WOS:001612440200001,
Author = {Li, Jiacheng and Lin, Chuang and Zhang, Lin and Dong, Yi},
Title = {Machine learning-assisted investigation of strain effects on clustered
   anti-perovskite solid-state electrolytes: A case of study about Li3OBH4
   using DFT calculations},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2025},
Volume = {48},
Month = {SEP},
Abstract = {We have studied the influence of strain on defect formation energy,
   binding energy, lithium-ion conductivity, and migration energy barriers
   in the anti-perovskite (AP) solid-state electrolytes (SSEs) within the
   framework of density functional theory. Strain modulation effectively
   stabilizes defect structures and regulates ion migration pathways. Ab
   initio molecular dynamics (AIMD) simulations demonstrate that
   compressive strain along the xaxis combined with tensile strain along
   the y-axis markedly improves lithium-ion conductivity by reducing
   migration energy barriers, whereas the reverse strain combination
   impedes conductivity by increasing these barriers. Machine learning (ML)
   predictions, incorporated into the comprehensive analysis, identify Li+
   migration distance and y-axis strain as key determinants of migration
   energy barriers, with achieving an accuracy of 87.38 \%. By combining
   computational simulations and predictive modeling, this study provides
   valuable insights into the strain-dependent behavior of Li3OBH4,
   offering theoretical guidance for the design and optimization of
   high-performance SSEs for advanced lithium batteries.},
Type = {Article},
Affiliation = {Zhang, L (Corresponding Author), Northeastern Univ, Key Lab Anisotropy \& Texture Mat, Minist Educ, Shenyang 110819, Peoples R China.
   Dong, Y (Corresponding Author), Univ Saarland, Dept Chem, D-66123 Saarbrucken, Germany.
