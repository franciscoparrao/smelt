@article{ WOS:001664237100001,
Author = {Kumar, Tota Rakesh and Kamesh, Bodduru and Giri, Jayant and Kanan,
   Mohammad and Nagaraju, Dora and Syed, Javed},
Title = {Numerical simulation and machine learning framework approach for
   ballistic performance evaluation of aluminium structures},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {Understanding and accurately predicting the ballistic response behavior
   of structural materials is critical for the design and optimization of
   lightweight, high performance protective structures subjected to high
   velocity impact. This study presents a comprehensive numerical analysis
   of the ballistic perforation of aluminum plates impacted by rigid steel
   projectiles with blunt, hemispherical, and ogival nose geometries.
   Finite Element Method (FEM) simulations incorporating the Johnson-Cook
   constitutive and failure models were conducted in ABAQUS/Explicit scheme
   to evaluate absorbed energy during impact. The simulation results
   closely match experimental data, with an average deviation of less than
   7\% in numerically predicted absorbed energy values. To overcome
   limitations associated with computational cost and model complexity,
   supervised Machine Learning (ML) models which includes Support Vector
   Regression (SVR), Random Forest (RF), Decision Tree (DT), and
   Multi-Layer Perceptron (MLP), were developed to predict absorbed energy
   based on projectile geometry, impact velocity, and target thickness.
   Comparative assessments demonstrated that ML-based models maintained
   strong predictive accuracy. Detailed analysis of fracture patterns
   provide additional insights into failure mechanisms under different
   impact scenarios. The integrated FEM-ML framework proposed herein
   demonstrates enhanced predictive accuracy and computational efficiency,
   offering a promising tool for rapid ballistic performance evaluation and
   impact resistant design optimization.},
Type = {Article},
Affiliation = {Kumar, TR (Corresponding Author), Indian Maritime Univ, Sch Marine Engn \& Technol, Chennai 600119, Tamil Nadu, India.
