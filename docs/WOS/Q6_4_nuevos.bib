   Qin, Lang; Zeng, Yakun; Pan, Hongcheng, Guilin Univ Technol, Coll Chem \& Bioengn, Guangxi Key Lab Electrochem \& Magnetochem Funct Ma, Guilin 541006, Peoples R China.},
DOI = {10.1007/s00604-026-07956-1},
Article-Number = {200},
Keywords = {Machine learning; Composite signals; Core algorithm module; Fluorescence
   image analysis},
