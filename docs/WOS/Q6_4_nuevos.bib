@article{ WOS:001613630000003,
Author = {Potdar, Veena and Kabadi, Mohan Govindasa},
Title = {Enhancing IoT anomaly detection with the Dwarf Mongoose-Chaos optimized
   deep belief framework},
Journal = {CHEMOMETRICS AND INTELLIGENT LABORATORY SYSTEMS},
Year = {2026},
Volume = {268},
Month = {JAN 15},
Abstract = {Anomaly detection is essential for identifying deviations from normal
   patterns in data, enabling the detection of security breaches or system
   faults, particularly in Internet of Things (IoT) networks. However,
   traditional machine learning (ML) and deep learning (DL) methods often
   struggle with the dynamic and complex nature of IoT environments, where
   attack patterns are non-linear, continuously evolving, and
   context-dependent. These models typically require large labeled datasets
   and retraining to adapt to new threats, which limits their
   responsiveness and scalability. Additionally, their high computational
   demands make real-time deployment on resource-constrained IoT devices
   challenging. Furthermore, many ML/DL models exhibit poor generalization,
   performing well in controlled scenarios but failing to maintain accuracy
   across diverse, real-world IoT settings with varying devices, protocols,
   and data distributions. To address these issues, this work proposes the
   Dwarf Mongoose-Chaos Optimized Deep Belief (DCODB) Framework, which
   combines advanced preprocessing, feature selection (FS), and
   classification techniques. Initial preprocessing involves Min-Max
   Normalization and One-Hot Encoding to scale numerical features and
   transform categorical data for effective model input. FS is optimized by
   the novel Dwarf Mongoose-Chaos Fusion Optimization (DMCFO), which is a
   swarm intelligence algorithm that leverages chaotic maps to improve the
   effectiveness of the Dwarf Mongoose Optimization Algorithm (DMO),
   reducing dimensionality and improving classification accuracy. The
   refined features are then classified using a Deep Belief Network (DBN),
   which processes hierarchical feature representations to differentiate
   between normal and anomalous behaviors in the NSL-KDD dataset. The
   proposed framework has been thoroughly assessed using diverse metrics,
   demonstrating its effectiveness in anomaly detection by achieving above
   99 \% Balanced Accuracy, along with exceptional Precision, Recall, F1
   Score, Specificity, and the AUC-ROC curve. These high-performance
   metrics affirm the model's capability to deliver reliable and scalable
   anomaly detection in IoT environments, strengthening overall security.},
Type = {Article},
Affiliation = {Potdar, V (Corresponding Author), Dr Ambedkar Inst Technol, Comp Sci \& Engn, Outer Ring Rd, Bangalore 560056, Karnataka, India.
   Potdar, Veena, Dr Ambedkar Inst Technol, Comp Sci \& Engn, Outer Ring Rd, Bangalore 560056, Karnataka, India.
   Kabadi, Mohan Govindasa, GITAM Univ, Comp Sci \& Engn, NH 207, Bengaluru 561203, Karnataka, India.},
DOI = {10.1016/j.chemolab.2025.105558},
EarlyAccessDate = {NOV 2025},
Article-Number = {105558},
Keywords = {IoT; Anomaly detection; IDS; DMCFO; Feature selection; DBN},
Keywords-Plus = {LEARNING APPROACH},
Author-Email = {veenapotdar@gmail.com
   mkabadi@gitam.edu},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001613630000003},
}

@article{ WOS:001612020500010,
Author = {Fan, Zhihong and Li, Boya and Fu, Binguo and Dong, Tianshun and Li,
   Jingkun},
Title = {Composition design of Fe-containing heat-resistant cast Al-Cu alloy
   based on interpretable machine learning},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2025},
Volume = {1046},
Month = {NOV 20},
Abstract = {The increasing complexity of multi-component alloy design poses
   significant challenges for developing heat-resistant Al-Cu cast alloys.
   To address this issue, this study innovatively developed an
   interpretable machine learning method combining model optimization,
   element selection and genetic algorithm. Utilizing this method, a
   Fe-containing heat-resistant Al-Cu cast alloy was successfully designed,
   and its heat resistance mechanism was elucidated through microstructure
   analysis. The results indicated that the Voting model demonstrated
   optimal prediction accuracy (R2 = 0.931, MAE = 22.03) and robustness
   (test R2/train R2 = 0.96). In-depth analysis identified the combination
   of key elements for obtaining high-performance alloys as Cu, Mg, Si, Ti,
   Mn and Fe. Moreover, Al alloys with a high Fe content were more
   susceptible to obtain high heat resistance. Guide by the above findings,
   the Al-6.98Cu-1.82Mg-0.21Si-0.19Ti-0.53Mn-1.07Fe alloy was obtained
   through Genetic Algorithm (GA) optimization. The as-cast alloy
   demonstrated a tensile strength of 153.9 MPa at 300 degrees C, which
   increased to 179.2 MPa after T6 heat treatment. Microstructure analysis
   showed that the heat resistance of the as-cast alloy was mainly
   attributed to the Chinese script type Al6(FeMn) phase, while the
   enhancement of T6 state alloy originated from the formation of the
   ellipsoidal S-Al2CuMg phase during the heat treatment. The established
   framework also serves as a valuable reference for the efficient and
   interpretable design of other complex alloy systems.},
Type = {Article},
Affiliation = {Fu, BG (Corresponding Author), Hebei Univ Technol, Sch Mat Sci \& Engn, State Key Lab High Performance Roll Mat \& Composit, Tianjin 300401, Peoples R China.
   Li, BY (Corresponding Author), Tianjin Normal Univ, Coll Phys \& Mat Sci, Tianjin 300387, Peoples R China.
