   Omenya, Fredrick; Reed, David M.; Li, Xiaolin, Pacific Northwest Natl Lab, Richland, WA 99352 USA.},
DOI = {10.1016/j.ensm.2026.104967},
EarlyAccessDate = {FEB 2026},
