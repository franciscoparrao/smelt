@article{ WOS:001664326200001,
Author = {Huang, Xun and Yao, Rongwen and Zhang, Yunhui and Li, Xiao and Yu,
   Zhongyou and Guo, Hongyang},
Title = {A novel irrigation water quality index (PCIWQI) assessment and
   prediction: Insights into model performance and computational efficiency
   from TabPFN and tree-based models},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2026},
Volume = {14},
Number = {1},
Month = {FEB},
Abstract = {Groundwater is a vital resource for irrigation and plays a key role in
   maintaining agricultural productivity and ensuring food security. This
   study proposes a principal-component-weighted irrigation water quality
   index (PCIWQI), integrating sodium percentage (Na\%), sodium adsorption
   ratio (SAR), residual sodium carbonate (RSC), permeability index (PI),
   magnesium hazard (MH), and other hydrochemical parameters for a
   comprehensive assessment. Based on 624 groundwater samples during dry
   and wet seasons from 2011 to 2016, Lasso (baseline), XGBoost, LightGBM,
   and TabPFN models with feature selection were employed to predict
   irrigation water quality, balancing accuracy and computational
   efficiency. All groundwater samples were classified as ``Good{''} (75 <=
   PCIWQI < 150) and ``Excellent{''} (PCIWQI < 75) ranks, indicating their
   suitability for irrigation and low salinity, sodium, and alkalinity
   hazards to crops. In predictive modeling, the TabPFN model outperformed
   in precision (R-dry(2) = 0.97, R-wet(2) = 0.94, RMSEdry = 1.00, RMSEwet
   = 1.16) and hyperparameter tuning (0.1 s). SHAP (Shapley Additive
   exPlanations) analysis indicated that the TabPFN's high performance was
   attributable to the identification of salinity, sodium, permeability,
   and alkalinity hazards. In contrast, the LightGBM model excelled in
   computational efficiency, with quick training (68.9 ms), prediction (0.9
   ms), and low memory usage (similar to 395 MiB). However, it required
   substantial time (89.8 s) for hyperparameter tuning. Consequently,
   TabPFN achieved high accuracy without any hyperparameter tuning,
   offering a significant advantage in saving time and simplifying usage.
   These findings demonstrate the potential capability of prior-data-fitted
   models for groundwater-quality prediction and establish a low-cost and
   high-precision framework for rapid irrigation-water assessment},
Type = {Article},
Affiliation = {Guo, HY (Corresponding Author), Chengdu Univ Technol, Coll Environm \& Civil Engn, State Key Lab Geohazard Prevent \& Geoenvironm Prot, Chengdu 610059, Peoples R China.
