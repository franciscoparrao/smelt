   Li, Weijin, Nanjing Univ Sci \& Technol, Sch Mat Sci \& Engn, Nanjing, Peoples R China.},
DOI = {10.1002/smll.202512367},
EarlyAccessDate = {JAN 2026},
Keywords = {carbon nanocomposites; electromagnetic wave absorption; genetic
   algorithm; machine learning; performance optimization},
Author-Email = {xieaming@njust.edu.cn
   gaorr@njust.edu.cn},
Number-of-Cited-References = {33},
Times-Cited = {0},
