@article{ WOS:001599079500001,
Author = {Mahanta, Bashista Kumar and Kumar, Sanjeev and Pathak, Sunil Kumar and
   Singh, Shailesh Kumar},
Title = {Machine learning-based prediction of high-entropy alloys for hydrogen
   storage with optimized thermodynamic and kinetic parameters},
Journal = {JOURNAL OF ENERGY STORAGE},
Year = {2025},
Volume = {139},
Number = {B},
Month = {DEC 20},
Abstract = {High-entropy alloys (HEAs), characterized by their multi-principal
   element compositions, have emerged as promising candidates for
   solid-state hydrogen storage due to their tunable structures and
   potential for reversible hydrogen absorption at ambient conditions.
   However, the vast compositional space of HEAs presents a major challenge
   in identifying optimal alloys with favourable storage capacity,
   kinetics, and thermodynamics. In this work, we propose a machine
   learning-assisted framework for predicting and optimizing HEA systems
   for hydrogen storage. A Machine Learning based Evolutionary Deep Neural
   Network (EvoDN2) was trained on experimental data, and tri-objective
   optimization was performed to maximize hydrogen storage capacity,
   enhance absorption/desorption kinetics, and minimize activation energy
   for hydrogen release. Multi-objective algorithms (NSGA-II and cRVEA)
   were employed to identify promising compositions. Among the predicted
   systems, the alloy Hf34La6.81Mg21.53Ta27V10.66 demonstrated the best
   performance, with a hydrogen storage capacity of 3.05 wt\% at ambient
   conditions, an activation energy of 23.59 kJ \& sdot;mol-1H2, and a
   favourable absorption-to-desorption time ratio of 1.39. Several other
   alloys, including CoLaTaTi and FeLaNbTiV, also achieved capacities
   exceeding 3 wt\% with competitive kinetics. These results underscore the
   potential of targeted compositional optimization for achieving a
   synergistic balance between storage capacity, activation energy, and
   absorption-to-desorption time ratio, thereby accelerating the discovery
   of high-performance HEAs for hydrogen storage applications.},
Type = {Article},
Affiliation = {Mahanta, BK; Singh, SK (Corresponding Author), CSIR Indian Inst Petr, Climate Change \& Data Sci, Dehra Dun 248005, India.
   Mahanta, Bashista Kumar; Kumar, Sanjeev; Pathak, Sunil Kumar; Singh, Shailesh Kumar, CSIR Indian Inst Petr, Climate Change \& Data Sci, Dehra Dun 248005, India.
   Kumar, Sanjeev; Pathak, Sunil Kumar; Singh, Shailesh Kumar, Acad Sci \& Innovat Res AcSIR, Ghaziabad 201002, India.},
DOI = {10.1016/j.est.2025.118865},
EarlyAccessDate = {OCT 2025},
Article-Number = {118865},
Keywords = {High-entropy alloys; Hydrogen storage; Machine learning; Multi-objective
   optimization; Kinetics},
Keywords-Plus = {BEHAVIOR},
Author-Email = {bashista\_mahanta@yahoo.co.in
   shailesh.singh@csir.res.in},
Number-of-Cited-References = {91},
Times-Cited = {4},
Unique-ID = {WOS:001599079500001},
}

@article{ WOS:001598882600001,
Author = {Su, Yang and Pan, KeKe and Gu, Tiantian and Peng, Banghua and Wang, Gang
   and Yu, Feng},
Title = {Multidimensional electrode engineering for high-performance vanadium
   redox flow batteries: Bridging atomic-scale design to macroscopic
   durability},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2025},
Volume = {524},
Month = {NOV 15},
Abstract = {Vanadium redox flow batteries (VRFBs) represent a pivotal technology for
   grid-scale storage of renewable energy. However, their performance is
   constrained by the inherent limitations of conventional carbon
   electrodes, including insufficient catalytic activity, poor electrolyte
   wettability, and structural degradation. This review systematically
   analyzes recent breakthrough progress through a multidimensional
   optimization framework: atomic-scale engineering via heteroatom
   doping/defect introduction modulates electronic structures and creates
   spin-selective charge transfer pathways; hierarchically porous
   architectures achieve synergistic mass/charge transport; dynamic
   stabilization mechanisms effectively suppress side reactions and
   mechanical fatigue; and multiscale device integration bridges
   nano-active sites with macroscopic flow fields. Crucially, we establish
   cross-scale correlations linking quantum spin states, mesoscopic
   transport phenomena, and macroscopic durability, validated by in situ
   diagnostics and multi-physics modeling. These collective advances have
   enabled unprecedented performance metrics: energy efficiency exceeding
   82 \% at 200 mA cm-2, a cycle life of over 5000 cycles with a
   single-cycle efficiency decay rate below 0.0019 \%, and a peak power
   density reaching 1.1 W cm-2. Furthermore, this article proposes a
   synergistic design paradigm integrating machine learning, digital twins,
   and bio-inspired structures to transcend existing performance
   trade-offs, thereby solidifying the central role of VRFBs in grid-scale
   energy storage.},
Type = {Review},
Affiliation = {Yu, F (Corresponding Author), Shihezi Univ, Sch Chem \& Chem Engn, Key Lab Green Proc Chem Engn Xinjiang Bingtuan, Shihezi 832003, Peoples R China.
   Su, Yang; Pan, KeKe; Gu, Tiantian; Peng, Banghua; Wang, Gang; Yu, Feng, Shihezi Univ, Sch Chem \& Chem Engn, Key Lab Green Proc Chem Engn Xinjiang Bingtuan, Shihezi 832003, Peoples R China.
   Yu, Feng, Shihezi Univ, Carbon Neutralizat \& Clean Energy Technol Lab, Shihezi 832003, Peoples R China.},
DOI = {10.1016/j.cej.2025.169558},
EarlyAccessDate = {OCT 2025},
Article-Number = {169558},
Keywords = {Vanadium redox flow batteries; Carbon electrode engineering; Heteroatom
   doping; Spin-selective charge transfer; Hierarchical porosity;
   Multiphysics modeling},
Keywords-Plus = {GRAPHITE FELT; HIGH-POWER; NITROGEN; SULFUR},
Author-Email = {yufeng05@mail.ipc.ac.cn},
Number-of-Cited-References = {140},
Times-Cited = {0},
Unique-ID = {WOS:001598882600001},
}

@article{ WOS:001598802700001,
Author = {Agafonova, Ekaterina E. and Krasnikov, Dmitry V. and Nasibulin, Albert
   G.},
Title = {Perovskite solar cell efficiency prediction on the basis of structure of
   organic hole-transporting materials},
Journal = {MATERIALS \& DESIGN},
Year = {2025},
Volume = {259},
Month = {NOV},
Abstract = {Perovskite solar cells (PSCs), particularly in the n-i-p architecture,
   require high-performance hole-transporting materials (HTMs). The
   rational design of HTMs demands a systematic understanding of
   structure-property relationships. Here, we analyze a dataset of
   cross-laboratory experimental results encompassing 177 peer-reviewed
   publications to decode the impact of an HTM structure on the device
   performance. Our correlation analysis reveals the fill factor (FF) as
   the most sensitive parameter for the HTM optimization, underscoring its
   critical role in efficiency enhancement. Through feature selection, we
   identify key predictors of device performance. These include
   nitrogen-containing functional groups (amide, imide, imine), carbonyl
   oxygen content, the count of aromatic and aliphatic carbo-/heterocycles,
   and van der Waals surface area descriptors. Using these insights, we
   develop a tree model-based stacked regressor that predicts device power
   conversion efficiency (PCE) with a root mean squared error (RMSE) as low
   as 2 \%. This data-driven framework bridges molecular design with device
   physics and provides actionable guidelines for synthesizing
   next-generation HTMs via chemical space exploration.},
Type = {Article},
Affiliation = {Nasibulin, AG (Corresponding Author), Skolkovo Inst Sci \& Technol, Lab Nanomat, Nobel Str 3, Moscow 121205, Russia.
   Agafonova, Ekaterina E.; Nasibulin, Albert G., Skolkovo Inst Sci \& Technol, Lab Nanomat, Nobel Str 3, Moscow 121205, Russia.},
