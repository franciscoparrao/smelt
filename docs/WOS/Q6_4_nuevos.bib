@article{ WOS:001702442600001,
Author = {Hu, Yuqing and Huang, Jiaxing and Liu, Hanghang and Shao, Gaofeng and
   Yao, Yiming and Wang, Zuocai and Wang, Jingquan},
Title = {Full-range prediction of UHPC fiber bond-slip relationship via a
   multi-output machine learning framework},
Journal = {ENGINEERING STRUCTURES},
Year = {2026},
Volume = {354},
Month = {MAY 1},
Abstract = {In the research and application of Ultra-high performance
   concrete(UHPC), accurately capturing and characterizing the bond-slip
   relationship of single fibers is essential for elucidating its
   micromechanical mechanisms and predicting macroscopic performance.
   Although single-fiber pullout tests can provide this relationship, they
   are time-consuming and highly sensitive to material and loading
   variations, which limits their efficiency and applicability. To address
   this gap, this study proposes an machine learning(ML) model to predict
   the full range bond-slip response of steel fibers in UHPC. A dataset of
   112 single-fiber pullout tests constructed, encompassing a wide spectrum
   of geometric, material, and loading parameters. Based on this dataset, a
   multi-output extreme gradient boosting (XGBoost) model was established
   to reconstruct continuous bond-slip curves. The model integrates
   automated feature preprocessing and Bayesian hyperparameter
   optimization, whereas interpretability techniques including SHapley
   Additive exPlanations (SHAP) and partial dependence plots (PDPs) were
   employed to elucidate the influence of critical interfacial parameters
   on curve morphology. The results demonstrate that the proposed framework
   achieves high predictive accuracy (R2 > 0.9) and effectively captures
   the nonlinear evolution of interfacial stress with slip. Furthermore,
   the predicted curves were fitted with a bilinear equation to establish a
   parameterized constitutive relationship. The newly fitted curve exhibits
   a coefficient of determination (R2) of 0.98, confirming the accuracy of
   the proposed equation and providing a practical framework for finite
   element analysis and structural design.},
Type = {Article},
Affiliation = {Wang, ZC (Corresponding Author), Anhui Jianzhu Univ, Anhui Prov Key Lab Intelligent Geotech \& Disaster, Hefei 230601, Peoples R China.
   Hu, Yuqing; Huang, Jiaxing; Wang, Zuocai, Anhui Jianzhu Univ, Anhui Prov Key Lab Intelligent Geotech \& Disaster, Hefei 230601, Peoples R China.
   Hu, Yuqing; Wang, Zuocai, Natl local Joint Engn Lab Bldg Hlth Monitoring \& D, Hefei 230601, Peoples R China.
   Liu, Hanghang, Anhui Inst Bldg Res \& Design, Hefei 230031, Peoples R China.
