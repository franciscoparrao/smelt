   Yao, Guangshun; Wang, Shengxiang, Chuzhou Univ, Sch Comp \& Informat Engn, Chuzhou, Peoples R China.},
DOI = {10.1109/TC.2025.3642832},
Keywords = {Load management; Graphics processing units; Load modeling; Dynamic
   scheduling; Virtual machines; Scheduling; Resource management; Machine
   learning; Heuristic algorithms; Graph neural networks; GPU cluster;
   batch job; load balancing; graph neural network; deep reinforcement
   learning},
Keywords-Plus = {SCHEME},
