   Bin Alam, Md. Sakib, Univ Informat Technol \& Sci, Dept Informat Technol, Dhaka 1212, Bangladesh.
   Lameesa, Aiman, Amer Int Univ Bangladesh, Dept Comp Sci, Dhaka 1229, Bangladesh.},
DOI = {10.1016/j.array.2025.100500},
EarlyAccessDate = {SEP 2025},
Article-Number = {100500},
Keywords = {Federated learning; Graph neural networks; Heart disease prediction;
   Privacy-preserving machine learning; Healthcare data security},
Author-Email = {sakib.alam@uits.edu.bd},
Number-of-Cited-References = {36},
