Keywords-Plus = {TWINNING-INDUCED PLASTICITY; PHASE-STABILITY; TI ALLOY; MICROSTRUCTURE;
   DESIGN; FE; TRANSFORMATION; COMBINATION; EVOLUTION},
Author-Email = {renhai.shi.nick@gmail.com
