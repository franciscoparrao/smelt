@article{ WOS:001660780900001,
Author = {Liu, Muxin and Tang, Quan and Leng, Erwei and Deng, Yuanwang and Lv,
   Dangzhen},
Title = {Multi-staged machine learning-driven investigation of biomass-derived
   hard carbon anodes for sodium-ion batteries: Connecting precursor,
   structure, and performance},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2026},
Volume = {528},
Month = {JAN 15},
Abstract = {Biomass-derived hard carbon is a low-cost, sustainable anode candidate
   for sodium-ion batteries, yet the structural evolution mechanisms
   governing its performance remain unclear. A novel two-step predictive
   approach was developed and compared with the conventional one-step
   model. This approach not only slightly improved the prediction accuracy
   for electrochemical performance, but also established interpretable
   correlations between input features and electrochemical performance
   outputs, and further enabled the prediction and analysis of rate
   performance indicators. The framework first uses biomass three-component
   ratios and thermal parameters to infer key structural descriptors (SSA,
   d(002), I-D/I-G, L-a, L-c), which are then combined with current density
   to predict electrochemical performance. The target space extends beyond
   experimental capacity (Q(M,E)) and initial Coulombic efficiency (ICE),
   encompassing rate-related parameters (Q(M,F), tau, n) and long-cycle
   capacity (Q(M,100)) within a unified interpretable model. Trained on an
   expanded dataset covering diverse biomass compositions and carbonization
   conditions, the model captures both kinetic and durability behaviors
   across a wide compositional space. SHAP and PDP analyses reveal that
   moderate disorder (I-D/I-G similar to 1.5-1.8), narrow interlayer
   spacing (similar to 0.37-0.38 nm), and lateral domain sizes of 3.5-5.0
   nm synergistically enhance reversible capacity, while their kinetic
   response reflects a trade-off rather than optimal rate capability-a
   behavior instead observed at smaller or larger lateral domain sizes.
   These capacity-favorable structures are typically achieved using
   cellulose-rich precursors with tuned hemicellulose and lignin content
   under optimized carbonization protocols. This study offers mechanistic
   insights and practical guidance for designing high-performance hard
   carbon anodes in sodium-ion batteries.},
