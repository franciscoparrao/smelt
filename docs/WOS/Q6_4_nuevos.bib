Times-Cited = {0},
Unique-ID = {WOS:001691118800001},
}

@article{ WOS:001686791200005,
Author = {Reeves, Alexander and Zhang, Pierre and Zheng, Henry},
Title = {PyBird-JAX: Accelerated inference in large-scale structure with
   model-independent emulation of one-loop galaxy power spectra},
Journal = {JOURNAL OF COSMOLOGY AND ASTROPARTICLE PHYSICS},
Year = {2026},
Number = {2},
Month = {FEB},
Abstract = {We present PyBird-JAX, a differentiable, JAX-based implementation of
   PyBird, using internal neural network emulators to accelerate
   computationally costly operations for rapid large-scale structure (LSS)
   analysis. PyBird-JAX computes one-loop EFTofLSS predictions for
   redshift-space galaxy power spectrum multipoles in 1.2 ms on a CPU and
   0.2 ms on a GPU, achieving 3-4 orders of magnitude speed-up over PyBird.
   The emulators take a compact spline-based representation of the input
   linear power spectrum P(k) as feature vectors, making the approach
   applicable to a wide range of cosmological models. We rigorously
   validate its accuracy against large-volume simulations and on BOSS data,
   including cosmologies not explicitly represented in the training set.
   Leveraging automatic differentiation, PyBird-JAX supports Fisher
   forecasting, Taylor expansion of model predictions, and gradient-based
   searches. Interfaced with a variety of samplers and Boltzmann solvers,
   PyBird-JAX provides a high-performance, end-to-end inference pipeline.
   Combined with a symbolic-P(k) generator, a typical Stage-4 LSS MCMC
   converges in minutes on a GPU. Our results demonstrate that PyBird-JAX
   delivers the precision and speed required for upcoming LSS surveys,
   opening the door to accelerated cosmological inference with minimal
   accuracy loss and no pretraining. In a companion paper {[}1], we put
   PyBird-JAX to use in achieving LSS marginalised constraints free from
   volume projection effects through non-flat measures.},
Type = {Article},
Affiliation = {Reeves, A (Corresponding Author), Swiss Fed Inst Technol, Inst Particle Phys \& Astrophys, CH-8093 Zurich, Switzerland.
   Reeves, Alexander; Zhang, Pierre, Swiss Fed Inst Technol, Inst Particle Phys \& Astrophys, CH-8093 Zurich, Switzerland.
   Zhang, Pierre, Swiss Fed Inst Technol, Inst Theoret Phys, CH-8093 Zurich, Switzerland.
   Zhang, Pierre, Univ Milan, Dipartimento Fis Aldo Pontremoli, I-120133 Milan, Italy.
   Zheng, Henry, Stanford Univ, Stanford Inst Theoret Phys, Phys Dept, Stanford, CA 94306 USA.
   Zheng, Henry, SLAC, Kavli Inst Particle Astrophys \& Cosmol, Menlo Pk, CA 94025 USA.
   Zheng, Henry, Stanford Univ, Menlo Pk, CA 94025 USA.},
DOI = {10.1088/1475-7516/2026/02/016},
Article-Number = {016},
Keywords = {cosmological parameters from LSS; galaxy clustering; Machine learning},
Author-Email = {areeves@phys.ethz.ch
   pierre.zhang@unimi.it},
Number-of-Cited-References = {165},
Times-Cited = {0},
Unique-ID = {WOS:001686791200005},
}

@article{ WOS:001662961200007,
Author = {Sun, Hui and Fu, Yinan and Wang, Xin and Zhou, Yi and Qin, Xiao},
Title = {eCache: A Sample-Inference-Based Intelligent Cache Scheme for
   High-Performance SSDs},
Journal = {IEEE TRANSACTIONS ON COMPUTERS},
Year = {2026},
Volume = {75},
Number = {2},
Pages = {582-596},
Month = {FEB},
Abstract = {DRAM-based cache is a practical approach to enhancing the performance of
   large-capacity SSDs. Due to DRAM's limited capacity, cache sizes are
   significantly smaller than the data scale of workloads - and cache
   replacement schemes determine the cache hit ratio and SSD performance
   when a cache reaches full capacity. Prior work embarked on leveraging
   machine learning models (ML) to predict future access patterns in
   workloads, aiding cache replacement decisions for intelligent cache
   schemes inside SSDs. Unfortunately, existing ML-based cache schemes
   often overlook the impacts of data granularity - including page,
   request, and coarse granularities - of training datasets, model
   inference time overhead, and computational overhead on SSD performance.
   To address these challenges, we are motivated to propose an
   sample-inference-based int<bold>e</bold>lligent cache scheme - eCache.
   eCache accurately predicts the future reuse distance of each sampled
   requested pages, which can enhance the accuracy of decision-making for
   the cache replacement. In particular, we design a parallel framework to
   curb the time overhead caused by model inference. We advocate for a
   random-group sampling inference method that utilizes the most accurate
   model while reducing computational overhead. Moreover, we implement
   eCache on the state-of-the-art SSD simulator, MQSim, and compare it
   against alternative cache schemes (i.e., CCache, NCache, LAC, and
   VS-batch). The experimental results unveil that compared with the other
   cache schemes, eCache significantly reduces the average response time by
   up to 79.68\% with an average reduction of 44.08\%. When compared with
   the page-granularity-ML-empowered cache schemes, eCache greatly curtails
   computational overhead by up to 85.23\% with an average reduction of
   66.00\%.},
Type = {Article},
Affiliation = {Sun, H (Corresponding Author), Anhui Univ, Dept Comp Sci \& Technol, Hefei 230601, Anhui, Peoples R China.
   Sun, Hui; Fu, Yinan; Wang, Xin, Anhui Univ, Dept Comp Sci \& Technol, Hefei 230601, Anhui, Peoples R China.
   Zhou, Yi, Columbus State Univ, TSYS Sch Comp Sci, Columbus, GA 31907 USA.
   Qin, Xiao, Auburn Univ, Dept Comp Sci \& Software Engn, Auburn, AL 36849 USA.},
DOI = {10.1109/TC.2025.3628340},
Keywords = {Computational modeling; Accuracy; Flash memories; Training; Data models;
   Time factors; Spatiotemporal phenomena; Random access memory; Predictive
   models; Fluctuations; Cache management schemes; machine learning;
   extreme gradient boosting; sample-inference; NAND flash memory; solid
   state disks},
Keywords-Plus = {MANAGEMENT SCHEME},
Author-Email = {sunhuiworking@gmail.com},
Number-of-Cited-References = {39},
Times-Cited = {0},
Unique-ID = {WOS:001662961200007},
}

@article{ WOS:001653722100001,
Author = {Dong, Jingnan and Chen, Haolei and Shen, Shigen and Xu, Huibin and Liu,
   Zhiquan},
Title = {Interpretable intrusion detection for IoT security: A SHAP-enhanced
   NGBoost model},
Journal = {COMPUTER NETWORKS},
Year = {2026},
Volume = {275},
Month = {FEB},
Abstract = {As the Internet of Things evolves rapidly, network security risks have
   become more pronounced and difficult to mitigate, and intrusion
   detection systems have become a key defense. Despite the extensive use
   of both deep learning and traditional machine learning techniques in
   recent intrusion detection research, the issue of limited model
   interpretability remains unresolved. In particular, deep learning models
   are frequently criticized for their ``black-box{''} nature, as their
   non-transparent decision-making processes hinder effective security
   auditing and complicate the tracing of attack behaviors. In addition,
   the existing machine learning-based intrusion detection methods are
   still insufficient in terms of model novelty and interpretability. To
   overcome the limitations outlined above, this paper presents an
   interpretable intrusion detection method-NGSHAP-IDS, which uses NGBoost
   as a classifier to achieve high-performance traffic
   multi-classification. At the same time, the SHAP interpretation
   framework is introduced to reveal feature contributions and improve
   decision transparency, while the NGBoost uncertainty analysis module
   quantitatively assesses prediction confidence to enhance understanding
   and trust in model behavior. Experimental results on three typical IoT
   intrusion detection datasets, UNSW-NB15, CICIDS2017, and N-BaIoT, show
   that NGSHAP-IDS outperforms existing mainstream baseline methods
   regarding detection performance and interpretability.},
Type = {Article},
Affiliation = {Chen, HL (Corresponding Author), Huzhou Univ, Sch Informat Engn, Huzhou 313000, Zhejiang, Peoples R China.
   Dong, Jingnan; Chen, Haolei; Shen, Shigen; Xu, Huibin, Huzhou Univ, Sch Informat Engn, Huzhou 313000, Zhejiang, Peoples R China.
   Liu, Zhiquan, Jinan Univ, Coll Cyber Secur, Guangzhou 510632, Peoples R China.},
DOI = {10.1016/j.comnet.2025.111937},
Article-Number = {111937},
Keywords = {Intrusion detection system; Internet of Things; Cybersecurity; Machine
   learning; XAI},
Keywords-Plus = {ENSEMBLE; ATTACK},
Author-Email = {dongjingnan@zjhu.edu.cn
   2023388131@stu.zjhu.edu.cn
   shigens@zjhu.edu.cn
   xuhuibin@zjhu.edu.cn
   zqliu@jnu.edu.cn},
