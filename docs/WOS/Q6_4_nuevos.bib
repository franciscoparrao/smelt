   Miyao, Tomoyuki, Nara Inst Sci \& Technol, Grad Sch Sci \& Technol, 8916-5 Takayama Cho, Ikoma, Nara 6300192, Japan.
   Miyao, Tomoyuki, Nara Inst Sci \& Technol, Data Sci Ctr, 8916-5 Takayama Cho, Ikoma, Nara 6300192, Japan.},
DOI = {10.1016/j.jcat.2025.116537},
