   Ghoufi, Aziz, Univ Paris East Creteil, CNRS, ICMPE Inst Chim \& Mat Paris Est, UMR 7182, F-94320 Thiais, France.},
DOI = {10.1016/j.desal.2025.119338},
EarlyAccessDate = {AUG 2025},
