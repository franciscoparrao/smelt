@article{ WOS:001581073300007,
Author = {Anand, Pradyut and Pratap, Suresh},
Title = {Enhancing the mechanical performance of sustainable high-performance
   concrete using thermally treated natural fibers: Experimental evaluation
   and machine learning-based predictive modeling},
Journal = {CONSTRUCTION AND BUILDING MATERIALS},
Year = {2025},
Volume = {493},
Month = {SEP 26},
Abstract = {Sustainable alternatives to traditional concrete are urgently needed to
   reduce environmental impact while maintaining structural performance.
   This study presents an integrated experimental and data-driven framework
   for developing high-performance concrete (HPC) using agro-waste
   pozzolanic binders and thermally treated natural fibers. Fly ash and
   thermally treated coir biomass ash (TTCB) were used as partial cement
   replacements, while sisal (TTSF), banana (TTBF), and sugarcane bagasse
   fibers (TTSBF) were incorporated as reinforcement in both individual and
   hybrid forms. Thirty concrete mixes were evaluated for compressive,
   flexural, and split tensile strengths, along with the modulus of
   elasticity, over curing periods from 7 to 90 days. A tri-fiber hybrid
   mix (Batch D2) achieved superior mechanical performance 75.14 MPa
   compressive strength, 8.85 MPa flexural strength, and 6.2 MPa split
   tensile strength at 90 days. SEM analysis confirmed enhanced
   fiber-matrix bonding and matrix densification due to pozzolanic
   reactions from TTCB and fly ash. Optimal fiber dosages (1-1.5 \%) were
   critical for maintaining workability and mechanical strength, while
   higher dosages led to agglomeration and reduced performance. Predictive
   modeling using Random Forest, LightGBM, and Artificial Neural Networks
   showed high accuracy, with LightGBM achieving R2 = 0.95 for compressive
   strength. SHAP analysis provided interpretability of mix parameters, and
   multi-objective optimization using the Sparrow Search Algorithm
   identified balanced, eco-efficient mix designs. This study offers a
   scalable, performance-driven pathway for the development of sustainable
   and intelligent HPC systems.},
Type = {Article},
Affiliation = {Anand, P (Corresponding Author), Noida Int Univ, Sch Engn \& Technol, Dept Civil Engn, Greater Noida 201312, Uttar Pradesh, India.
   Anand, Pradyut, Noida Int Univ, Sch Engn \& Technol, Dept Civil Engn, Greater Noida 201312, Uttar Pradesh, India.
   Pratap, Suresh, GL Bajaj Inst Technol \& Management, Greater Noida 201306, Uttar Pradesh, India.},
DOI = {10.1016/j.conbuildmat.2025.143187},
EarlyAccessDate = {AUG 2025},
Article-Number = {143187},
Keywords = {High-performance concrete; Sustainable concrete; Thermally treated
   natural fibers; Pozzolanic materials; Machine learning; Optimization},
Keywords-Plus = {FLY-ASH; STRUCTURAL PERFORMANCE; COMPRESSIVE STRENGTH; REINFORCED
   CONCRETE; PARTIAL REPLACEMENT; CEMENT; BEHAVIOR; DURABILITY; COMPOSITES;
   FLUIDITY},
Author-Email = {pradyut.bitmesra@gmail.com
   sureshpratap@yahoo.com},
