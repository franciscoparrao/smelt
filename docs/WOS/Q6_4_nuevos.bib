DOI = {10.6180/jase.202606\_29(6).0023},
Keywords = {Sealed shrinkage; high-performance concrete; Gaussian Process
   Regression; Categorical Boosting Regression},
Keywords-Plus = {AUTOGENOUS SHRINKAGE},
