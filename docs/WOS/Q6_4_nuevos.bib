@article{ WOS:001656163300001,
Author = {Wu, Zhenlong and Li, Zihan and Li, Yiqing and Li, Ji},
Title = {Optimization of sounding rocket Tailfin aerodynamics: A surrogate-based
   machine learning approach},
Journal = {AEROSPACE SCIENCE AND TECHNOLOGY},
Year = {2026},
Volume = {170},
Month = {MAR},
Abstract = {This study tackles the optimization design of the aerodynamic tailfin of
   sounding rocket, addressing the critical need for high performance in
   near-space exploration. Conventional design methods, which separate the
   aerodynamic and structural optimization processes, are time-consuming
   and costly, often yielding suboptimal solutions. This paper leverages
   the high efficiency of machine learning techniques. More precisely, it
   adopts an Electric Eel Foraging Optimization (EEFO) algorithm combined
   with an optimized Kernel Extreme Learning Machine model to establish a
   surrogate-based optimization framework. This framework aims at
   minimizing the computational load caused by high-fidelity and
   high-accuracy Computational Fluid Dynamics simulations. A
   multi-objective EEFO is introduced to balance the drag coefficient,
   tailfin volume, and lift coefficient. A comprehensive analysis is then
   conducted, demonstrating that the optimized tailfin design significantly
   reduces the drag, slightly decreases the lift, and increases the
   lift-to-drag ratio. The obtained results demonstrate the high
   effectiveness of the proposed method in balancing conflicting objectives
   and constraints, leading to a higher aerodynamically efficient and a
   better structurally optimized design. This study contributes to the
   field by providing a robust optimization strategy that can be applied to
   other aerospace design problems, providing theoretical insights and
   practical guidance.},
Type = {Article},
Affiliation = {Li, YQ (Corresponding Author), Nanchang Hangkong Univ, Sch Power \& Energy, Nanchang 330063, Peoples R China.
   Wu, Zhenlong; Li, Yiqing, Nanchang Hangkong Univ, Sch Power \& Energy, Nanchang 330063, Peoples R China.
   Li, Zihan; Li, Ji, Nanchang Hangkong Univ, Sch Aeronaut Mfg \& Mech Engn, Nanchang 330063, Peoples R China.},
DOI = {10.1016/j.ast.2025.111507},
EarlyAccessDate = {DEC 2025},
Article-Number = {111507},
Keywords = {Kernel extreme learning machine; Computational fluid dynamic;
   Aerodynamic optimization; Sounding rocket; Multi-objective optimization},
Keywords-Plus = {GLOBAL OPTIMIZATION; SHAPE OPTIMIZATION; ALGORITHM},
Author-Email = {yiqingli@nchu.edu.cn},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001656163300001},
}

