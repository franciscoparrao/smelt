@article{ WOS:001685645500001,
Author = {Sahu, Yogesh Kumar and Tripathi, Shrivishal and Paltani, Punya Prasanna},
Title = {AI-driven bandgap engineering of Mg-Ca Co-doped HgS semiconductors: A
   hybrid ML-DL-DFT+U framework for next-generation solar energy materials},
Journal = {COMPUTATIONAL CONDENSED MATTER},
Year = {2026},
Volume = {46},
Month = {APR 1},
Abstract = {Bandgap modulation remains a cornerstone in the rational design of
   semiconductors for next-generation solar energy conversion. Here, we
   introduce a data-driven discovery framework that integrates ensemble
   machine learning-deep learning (ML-DL) models with first-principles
   DFT+U validation to predict and validate Mg-Ca co-doped HgS compounds,
   formulated as Hg1-x-yMgxCayS (x,y = 0-0.50). Our DFT+U analysis reveals
   a systematic widening of the direct r-r bandgap from 0.00 eV (HgS) to
   2.207 eV (Mg0.50Ca0.50S), attributed to synergistic cationic
   substitution. A comprehensive benchmarking of 15 regression models
   including gradient boosting, random forest, LightGBM, support vector
   machines, linear regressors, and multilayer perceptrons (MLPs) was
   performed to identify the most robust predictors. Subsequently, a
   stacking-based meta-ensemble was developed, fusing the optimal ML and DL
   models to achieve superior predictive accuracy (MAE = 0.2195 eV, R2 =
   0.779) in close agreement with DFT+U results. Optical simulations
   further confirm strong absorption in the visible range and tunable
   bandgaps lying within the optimal Shockley-Queisser bandgap window,
   highlighting the potential of these materials for photovoltaic and
   optoelectronic applications. This study presents the first AI-DFT
   exploration of Mg-Ca co-doped HgS systems and establishes a
   generalizable workflow for accelerated discovery of high-performance
   semiconductors for clean energy technologies.},
Type = {Article},
Affiliation = {Sahu, YK (Corresponding Author), IIIT Naya Raipur, Dept Sci \& Math, Raipur, Chhattisgarh, India.
   Sahu, Yogesh Kumar; Paltani, Punya Prasanna, IIIT Naya Raipur, Dept Sci \& Math, Raipur, Chhattisgarh, India.
   Tripathi, Shrivishal, IIIT Naya Raipur, Dept ECE, Raipur, Chhattisgarh, India.},
DOI = {10.1016/j.cocom.2026.e01242},
EarlyAccessDate = {FEB 2026},
