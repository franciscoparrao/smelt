   Univ Bradford, Fac Engn \& Digital Technol, Bradford BD7 1DP, England.
   Al Farqadein Univ Coll, Dept Informat \& Commun Engn, Basrah 651004, Iraq.},
DOI = {10.3390/s25206444},
