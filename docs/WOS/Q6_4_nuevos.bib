@article{ WOS:001620415700001,
Author = {Raj, Manasvi and Makhija, Advay and Kushwaha, Aditya and Goel, Neeraj},
Title = {Integrated First-Principles, SCAPS-1D, and ML Framework for Engineering
   CsAgBiBr6 based Perovskite Solar Cell for IoT-Integrated Applications},
Journal = {MATERIALS SCIENCE AND ENGINEERING B-ADVANCED FUNCTIONAL SOLID-STATE
   MATERIALS},
Year = {2026},
Volume = {324},
Number = {A},
Month = {FEB},
Abstract = {The quest for sustainable and lead-free photovoltaic materials has
   positioned halide double perovskites as promising alternatives to
   conventional lead-based absorbers. In this study, we present a novel
   Cs2AgBiBr6-based perovskite solar cell (PSC) architecture designed for
   stability, efficiency, and for IoT device applications. The device
   integrates a multilayer electron transport stack (TiO2/PCBM/SnO2) with a
   hybrid hole transport configuration (Cu2O/NiO/Spiro-MeOTAD), enabling
   efficient carrier extraction and reduced interfacial recombination.
   First-principles Density Functional Theory (DFT) calculations reveal
   favourable electronic, vibrational, harmonic and optical properties of
   Cs2AgBiBr6, confirming its suitability as a robust lead-free absorber.
   SCAPS-1D simulations optimized the device, yielding high photovoltaic
   performance with a PCE of 27.78 \%, Vocof 1.71 V, Jscof 23.33 mA/cm2,
   and FF of 76.24 \%. Machine learning (ML) analysis was further employed
   to study the combined influence of temperature and relative humidity on
   device stability and performance, providing predictive insights for
   real-world conditions. The architecture was also assessed under white
   light spectrum by SCAPS-1D, underscoring its potential for powering
   indoor IoT applications. By integrating DFT, SCAPS-1D simulations,
   ML-driven reliability studies, and IoT application assessment, this work
   introduces a novel and comprehensive pathway for advancing stable,
   non-toxic, high-performance perovskite photovoltaics.},
Type = {Article},
Affiliation = {Goel, N (Corresponding Author), Netaji Subhas Univ Technol, Dept Elect \& Commun Engn, New Delhi 110078, India.
   Raj, Manasvi; Makhija, Advay; Kushwaha, Aditya; Goel, Neeraj, Netaji Subhas Univ Technol, Dept Elect \& Commun Engn, New Delhi 110078, India.},
DOI = {10.1016/j.mseb.2025.119014},
EarlyAccessDate = {NOV 2025},
Article-Number = {119014},
Keywords = {Cs2AgBiBr6; Indoor photovoltaics; Density functional theory; IoT
   applications},
Keywords-Plus = {CS2AGBIBR6; EFFICIENCY; DESIGN},
Author-Email = {neeraj.goel@nsut.ac.in},
Number-of-Cited-References = {69},
Times-Cited = {0},
Unique-ID = {WOS:001620415700001},
}

@article{ WOS:001618385400001,
Author = {Bezabih, Tajebe and Sinkhonde, David and Mirindi, Derrick and Kiprop,
   Samson and Mirindi, Frederic and Abiodun, Oluwapelumi},
Title = {Effects of mix design parameters on workability and compressive strength
   of teff straw ash-based geopolymer mortars: Experimental evaluation and
   machine learning prediction},
Journal = {CONSTRUCTION AND BUILDING MATERIALS},
Year = {2025},
Volume = {502},
Month = {DEC 5},
Abstract = {Despite its high carbon footprint, Portland cement (PC) remains the
   dominant construction binder, prompting the search for sustainable
   alternatives. Geopolymers, formed by alkali activation of
   aluminosilicate-rich precursors, offer a low-carbon option with enhanced
   durability. While conventional precursors (like fly ash) are well
   studied, teff straw ash (TSA), a silica- and alumina-rich agricultural
   by-product, remains underexplored. Moreover, no previous study has
   systematically investigated the effects of key mix parameters on the
   fresh and hardened properties of TSA-based geopolymer mortar (TSA-GM) or
   applied machine learning (ML) for predictive modelling in this context.
   This study addresses these gaps through an experimental program that
   varied NaOH concentration (8-14 M), alkaline activator solution-to-TSA
   (AAS/TSA) ratio (0.6-0.9), Na2SiO3/NaOH ratio (1.5-3.0), and curing
   regime (ambient and heat curing at 65-80 degrees C), to evaluate
   workability and compressive strength. Four ML models (Random Forest
   (RF), Artificial Neural Network, Decision Tree, and Support Vector
   Regression) were trained to predict compressive strength and analyse
   parameter influence. Results show that an optimal mix (12 M NaOH,
   AAS/TSA = 0.7, Na2SiO3/NaOH = 2.5) achieved a compressive strength of
   36.02 MPa at 90 days under heat curing, confirming its viability as a
   high-performance binder. Furthermore, ambient curing achieved a
   comparable long-term strength of 34.68 MPa, highlighting its potential
   as an energy-efficient alternative for non-time-sensitive applications.
   Among the models, RF demonstrated the best predictive performance (R2 =
   0.95). SHapley Additive exPlanations (SHAP) analysis identified water,
   NaOH content, curing temperature, and age as the most influential
   factors. This study is among the first to establish TSA as a viable
   precursor in geopolymer technology. It introduces an integrated
   experimental-ML framework to accelerate the development of sustainable
   construction materials.},
Type = {Article},
Affiliation = {Bezabih, T (Corresponding Author), Pan African Univ, Inst Basic Sci Technol \& Innovat, Dept Civil Engn, Nairobi, Kenya.
   Bezabih, T (Corresponding Author), Univ Padua, Dept Civil Environm \& Architectural Engn, Padua, Italy.
   Bezabih, Tajebe; Sinkhonde, David; Kiprop, Samson, Pan African Univ, Inst Basic Sci Technol \& Innovat, Dept Civil Engn, Nairobi, Kenya.
   Bezabih, Tajebe, Univ Padua, Dept Civil Environm \& Architectural Engn, Padua, Italy.
