@article{ WOS:001566368200009,
Author = {Shah, Abdul Wahid and Siddique, Jabir Ali and Saif, Umar Daraz and
   Hussain, Javid and Mudassir, Ghulam and Wang, Kang and Li, Wenfang and
   Kayani, Saif Haider},
Title = {Data-driven design of Al-Fe alloys for laser powder bed fusion to
   enhance recycled aluminum utilization},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2025},
Volume = {1039},
Month = {SEP 10},
Abstract = {Recent advancements in laser powder bed fusion (LPBF) processing of
   high-iron (Fe) containing aluminum (Al) alloys have demonstrated the
   potential to develop high-strength materials using recycled Al
   feedstocks. However, despite their high yield strength (YS), these
   LPBF-built Al-Fe alloys typically suffer from limited ductility, with
   low elongation (El) values restricting their broader applicability. To
   address this challenge, the present study introduces a data-driven
   framework for the design of Al-Fe-based alloys, aimed at enhancing
   elongation without compromising strength. Trained Gradient Boosting
   Regressor (GBR) models accurately predict YS and El based-on alloy
   composition. Incorporation of SHAP analysis provides interpretability by
   quantifying the influence of individual alloying elements on the model's
   predictions. A large virtual screening of Al-Fe compositions was
   subsequently evaluated using GBR model. These models identified 95 novel
   compositions predicted to achieve YS values of 470 MPa or higher, along
   with El values of 10 \% or greater. The correlation analysis indicated
   that manganese (Mn) and titanium (Ti) contribute in a balanced manner to
   both strength and ductility. This study presents a promising approach
   for the accelerated design of high-performance Al-Fe alloys compatible
   with LPBF, while promoting the sustainable use of recycled aluminum.},
Type = {Editorial Material},
Affiliation = {Shah, AW (Corresponding Author), South China Univ Technol, Sch Mat \& Engn, Guangzhou 510640, Peoples R China.
   Li, WF (Corresponding Author), Dongguan Univ Technol, Mat Sci \& Engn, Dongguan 523808, Peoples R China.
