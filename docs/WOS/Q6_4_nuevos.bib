}

@article{ WOS:001467079200001,
Author = {Yu, Bofan and Li, Hui and Xing, Huaixue and Ge, Weiya and Zhou, Liling
   and Zhang, Jinrui and Xu, Meijun and Yu, Cheng},
Title = {Geospatial SHAP interpretability for urban road collapse susceptibility
   assessment: a case study in Hangzhou, China},
Journal = {GEOMATICS NATURAL HAZARDS \& RISK},
Year = {2025},
Volume = {16},
Number = {1},
Month = {DEC 31},
Abstract = {The issue of weak interpretability in geological disaster susceptibility
   assessments using machine learning models has been a long-standing
   concern. Although SHAP (Shapley Additive Explanations) models have been
   extensively used in recent years to interpret the decision-making
   details of models, the specialized skills required and the
   non-intuitiveness of SHAP plots make their application challenging in
   practical decision-making environments. In response, our study
   introduces a map-based SHAP visualization framework to enhance the
   interpretability of susceptibility assessment results. Utilizing Optuna
   for hyperparameter tuning, we developed a high-performance XGBoost model
   to assess the susceptibility of the most impactful disaster in Hangzhou:
   urban road collapses. In addition to interpreting the contributions of
   evaluation factors through traditional SHAP summaries and bar plots, we
   displayed the SHAP values for each evaluation factor using map
   visualizations, and discussed the model's sensitivity to different
   values. To validate the alignment between model predictions and physical
   collapse mechanisms, our study selected typical collapse cases,
   interpreted these cases combining map visualizations, SHAP force plots
   at collapse points, and the physical mechanisms of collapse. Our
   research improves the interpretability of susceptibility assessments
   with machine learning by using map visualizations, providing new
   insights into spatial effects and robust support for urban
   decision-making applications.},
Type = {Article},
Affiliation = {Xing, HX (Corresponding Author), Nanjing Ctr, China Geol Survey, Nanjing, Peoples R China.
   Xing, HX (Corresponding Author), Minist Nat Resources, Engn lnnovatian Ctr Urban Underground Space Explor, Nanjing, Peoples R China.
   Yu, Bofan; Xing, Huaixue; Ge, Weiya; Yu, Cheng, Nanjing Ctr, China Geol Survey, Nanjing, Peoples R China.
   Yu, Bofan; Xing, Huaixue; Ge, Weiya; Yu, Cheng, Minist Nat Resources, Engn lnnovatian Ctr Urban Underground Space Explor, Nanjing, Peoples R China.
   Li, Hui, China Geol Survey, Beijing, Peoples R China.
   Zhou, Liling, Zhejiang Inst Geosci, Observat \& Res Stn Zhejiang Coastal Urban Geol Sec, Minist Nat Resources, Hangzhou, Peoples R China.
   Xu, Meijun, Minist Nat Resources, Lab Geol Safety Underground Space Coastal Cities, Qingdao, Peoples R China.
   Yu, Bofan; Zhang, Jinrui, China Univ Geosci, Inst Geol Survey, Wuhan, Peoples R China.},
DOI = {10.1080/19475705.2025.2491473},
Article-Number = {2491473},
Keywords = {Urban road collapse; geospatial SHAP; susceptibility assessment; map
