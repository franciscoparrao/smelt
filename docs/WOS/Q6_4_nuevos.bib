@article{ WOS:001578947700001,
Author = {Peng, Peng and Liu, Fuguo and Long, Shuai and Zhang, Cheng and Wan, Xin
   and Tang, Aitao and Yu, Zujian and Pan, Fusheng},
Title = {Interpretable regression-based machine learning accelerates the
   discovery of hydrolysis-active Mg-based alloys with tunable
   thermodynamic and electronic properties},
Journal = {INTERNATIONAL JOURNAL OF HYDROGEN ENERGY},
Year = {2025},
Volume = {177},
Month = {OCT 13},
Abstract = {The rational design of Mg-based alloys for hydrogen generation remains
   constrained by the absence of integrated frameworks that simultaneously
   consider structural stability, electronic structure, and catalytic
   functionality. Here, we report a machine learning-enabled strategy for
   the accelerated discovery and validation of high-performance Mg-Ni-X-Y
   alloys for hydrolysis-driven hydrogen production. A dataset of 3327
   compounds was constructed from Materials Project data, incorporating
   both crystallographic descriptors and periodic-table-derived features.
   Six regression models were benchmarked, with XGBoost achieving the
   highest predictive accuracy (R-2 > 0.93 for formation energy and Fermi
   level). Feature attribution via SHAP analysis revealed that
   electronegativity, valence electron count, and unit cell compactness are
   key factors governing energy characteristics. Dual-objective Pareto
   screening identified optimal candidates exhibiting low formation energy
   and Fermi levels proximate to Mg2Ni. Guided by the model, two quaternary
   alloys were designed through stoichiometric mapping of top-ranked
   compounds, synthesized, and subsequently confirmed to exhibit
   significantly enhanced hydrogen evolution performance. This study
   demonstrates a closed-loop, interpretable machine learning framework
   that bridges computational prediction with experimental realization,
   offering a scalable pathway toward data-driven catalyst discovery in
   magnesium-based hydrogen energy systems.},
Type = {Article},
Affiliation = {Long, S; Zhang, C (Corresponding Author), Chongqing Univ Sci \& Technol, Sch Met \& Power Engn, Chongqing 401331, Peoples R China.
