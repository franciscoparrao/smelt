Number-of-Cited-References = {64},
Times-Cited = {0},
Unique-ID = {WOS:001626112700002},
}

@article{ WOS:001624343100036,
Author = {Haq, Rafiul and Zhang, Xiaowang and Yitagesu, Sofonias and Khan, Wahab
   and Feng, Zhiyong},
Title = {DeepSarc: A Transformer-Based Deep Learning Approach for Sarcasm
   Detection in Social Media Text},
Journal = {CONCURRENCY AND COMPUTATION-PRACTICE \& EXPERIENCE},
Year = {2025},
Volume = {37},
Number = {27-28},
Month = {DEC 25},
Abstract = {Sarcasm detection is a critical and challenging task in sentiment
   analysis, particularly for low-resource languages like Urdu, where
   limited annotated data, linguistic complexity, and subtle contextual
   cues hinder accurate classification. Traditional machine learning
   methods often fail to capture the nuanced and often contradictory nature
   of sarcastic expression. To address these challenges, this paper
   presents a comprehensive and computationally efficient framework for
   Urdu sarcasm detection. We first mitigate severe class imbalance through
   strategic down-sampling and back-translation-based data augmentation. We
   then conduct extensive benchmarking of traditional deep learning
   architectures against fine-tuned pre-trained language models, including
   multilingual, monolingual, and Twitter-specific variants. Building on
   these insights, we propose DeepSarc, a novel hybrid model that
   integrates the contextual embeddings from XLM-T, the multi-scale feature
   extraction capabilities of dilated convolutional neural networks
   (DCNNs), and the sequential dependency modeling of bidirectional long
   short-term memory (BiLSTM) networks. While slightly more computationally
   intensive than simpler alternatives, DeepSarc achieves a
   state-of-the-art F1-score, significantly outperforming existing
   approaches. Our results establish a new benchmark for sarcasm detection
   in low-resource languages and provide a scalable, high-performance
   framework adaptable to diverse linguistic contexts.},
Type = {Article},
Affiliation = {Yitagesu, S (Corresponding Author), Tianjin Univ, Coll Intelligence \& Comp, Tianjin, Peoples R China.
   Haq, Rafiul; Zhang, Xiaowang; Yitagesu, Sofonias; Feng, Zhiyong, Tianjin Univ, Coll Intelligence \& Comp, Tianjin, Peoples R China.
   Khan, Wahab, Univ Sci \& Technol, Dept Comp Sci, Bannu, Pakistan.},
DOI = {10.1002/cpe.70405},
Article-Number = {e70405},
Keywords = {deep learning; embeddings; fine-tuning; NLP; PLMs; sarcasm detection;
   Urdu},
Author-Email = {sofoniasyitagesu@yahoo.com},
Number-of-Cited-References = {38},
Times-Cited = {0},
Unique-ID = {WOS:001624343100036},
}

@article{ WOS:001600223600002,
Author = {Ayadi, Badreddine and Khan, Rashid and Mohsen, Ali M. and Alizadeh,
   As'ad and Singh, Narinderjit Singh Sawaran and Hussein, Zahraa Abed and
   Aich, Walid and Hajlaoui, Khalil},
Title = {Artificial intelligence-driven modeling and metaheuristic optimization
   for enhanced PEMFC performance},
Journal = {INTERNATIONAL COMMUNICATIONS IN HEAT AND MASS TRANSFER},
Year = {2025},
Volume = {169},
Number = {D},
Month = {DEC},
Abstract = {Enhancing the performance of proton exchange membrane fuel cells
   (PEMFCs) requires a comprehensive approach that simultaneously addresses
   prediction accuracy, optimization robustness, and decision-making
   flexibility. Nonetheless, current research frequently addresses these
   elements separately rather than in an integrated manner. This study
   presents a novel, unified, and data-driven framework that bridges this
   methodological gap by integrating predictive modeling, evolutionary
   multi-objective optimization, and structured decision-making. A
   multilayer perceptron neural network (MLPNN), optimized via a genetic
   algorithm, was developed and trained on 54 CFD-based data samples to
   accurately estimate key performance metrics such as net power density
   (NPD), oxygen uniformity (U-O), and temperature standard deviation
   (T-sigma), achieving R-values exceeding 0.994 and MAPE below 1.55 \%.The
   surrogate model was coupled with SPEA-II and MOPSO metaheuristic
   algorithms to generate Pareto-optimal solutions, followed by VIKOR-based
   ranking to identify application-specific optimal designs. Results showed
   that MOPSO outperformed SPEA-II in convergence and diversity,
   particularly in high-performance zones. Moderate operating conditions
   (2.47-2.74 atm, 64.18-67.90 degrees C, 60 \%-85 \% RH) and
   stoichiometries (lambda a > 1.9, lambda(c) approximate to 3) were found
   critical for balanced performance. Ten decision scenarios demonstrated
   adaptable trade-offs, with each scenario tailored to specific real-world
   application requirements. This AI-based framework offers a powerful,
   generalizable tool for high-fidelity PEMFC design adapted to diverse
