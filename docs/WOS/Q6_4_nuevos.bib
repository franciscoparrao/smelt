@article{ WOS:001722981400001,
Author = {Li, Yahui and Wang, Ying},
Title = {Machine learning-powered high-throughput designing and screening of
   electrocatalysts for nitrate reduction to ammonia},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2026},
Volume = {534},
Month = {APR 15},
Abstract = {The technology of ammonia production via electrochemical nitrate
   reduction reaction (NO3RR) offers a sustainable solution for addressing
   nitrate pollution in water bodies and recovering nitrogen resources.
   Among this technology, the design and selection of efficient catalysts
   are the key to achieving high selectivity and stable nitrogen conversion
   in NO3RR. This study employed machine learning (ML)-powered density
   functional theory (DFT) to develop a strategy for designing NO3RR
   catalysts based on geometric-electronic-adsorption properties. The
   stability and activity of 282 single-atom catalysts (SACs) with high
   carbon-nitrogen stoichiometric ratios of CxN3 (M-CxN3, M-X-CxN3, X = Cl,
   Br, I) are evaluated. Four high-performance catalysts are screened,
   among which Ru-Cl-C7N3 exhibits the optimal catalytic activity (limiting
   potential =-0.38 V). This study further extracts 15 key characteristic
   parameters of four categories through data mining and constructs eight
   ML prediction models. It is found that Random Forest Regression has the
   best predictive performance for the NO3RR activity of SACs (test set: R2
   = 0.923). The DFT-ML collaborative prediction framework not only
   significantly provides an effective strategy for designing NO3RR
   catalysts, but also offers certain guidance for the rational design of
   materials and resource recovery in sustainable energy technologies.},
Type = {Article},
Affiliation = {Wang, Y (Corresponding Author), Tongji Univ, State Key Lab Pollut Control \& Resources Reuse, Shanghai Inst Pollut Control \& Ecol Secur, Coll Environm Sci \& Engn, Shanghai 200092, Peoples R China.
   Li, Yahui; Wang, Ying, Tongji Univ, State Key Lab Pollut Control \& Resources Reuse, Shanghai Inst Pollut Control \& Ecol Secur, Coll Environm Sci \& Engn, Shanghai 200092, Peoples R China.},
DOI = {10.1016/j.cej.2026.175353},
Article-Number = {175353},
Keywords = {Single-atom catalysts; Electrocatalysis; Nitrate reduction reaction;
   Hydrogen evolution reaction; Density functional theory},
Keywords-Plus = {APPROXIMATION},
Author-Email = {yingwang@tongji.edu.cn},
Number-of-Cited-References = {66},
Times-Cited = {0},
