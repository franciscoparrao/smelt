@article{ WOS:001663228900001,
Author = {Li, Yuanhao and Zhang, Weijin and Xie, Fuyin and Zhou, Zhongru and Yang,
   Zequn and Leng, Lijian and Li, Hailong},
Title = {Automated machine learning predicting SO2 and CO2 adsorption and
   separation in metal organic frameworks},
Journal = {SEPARATION AND PURIFICATION TECHNOLOGY},
Year = {2026},
Volume = {388},
Month = {APR 22},
Abstract = {Metal organic frameworks (MOFs), renowned for their structural
   tunability and high adsorption capacity, exhibit efficient adsorption
   performance toward flue gas components (e.g., SO2 and CO2). This unique
   property makes them crucial for mitigating environmental pollution and
   alleviating climate change. However, the directional design of MOFs,
   which relies on experimental approaches, suffers from a lack of
   theoretical guidance and entails considerable consumption of time and
   various resources. In this study, we develop an automated machine
   learning (AutoML)-assisted framework for accurately predicting the
   co-adsorption performance and selectivity of SO2 and CO2 in MOFs. The
   predictive model, a Gradient Boosting Machine (GBM) identified by H2O
   AutoML, achieved high accuracy (testing R2 of 0.91-0.95) in predicting
   MOF adsorption properties from a set of 12 input features. Feature
   analysis revealed key mechanistic insights, highlighting BET surface
   area, pressure, and temperature as the dominant factors governing
   adsorption performance. The model's robust accuracy provides direct
   synthesis guidance, indicating that high-performance MOFs for
   simultaneous capture should possess large surface areas (1500-2200 m2/g)
   and be evaluated at low temperature (approximate to 273 K) with
   optimized pressure for selectivity (25 kPa) and total uptake (125 kPa).
   This work provides a robust data-driven strategy for the rapid screening
   and rational design of high-performance MOFs for simultaneous
   desulfurization and decarbonization, effectively bridging the gap
   between computational prediction and practical application in flue gas
   purification.},
Type = {Article},
Affiliation = {Leng, LJ; Li, HL (Corresponding Author), Cent South Univ, Sch Energy Sci \& Engn, Changsha 410083, Peoples R China.
   Leng, LJ (Corresponding Author), Xiangjiang Lab, Changsha 410205, Peoples R China.
