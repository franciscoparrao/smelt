@article{ WOS:001669224300048,
Author = {Gao, Cuihong and Shen, Xueyan and Qiao, Mei and Yang, Rongjuan and Pang,
   Shasha and Bian, Zhimin and Sun, Jianghui and Wang, Lina},
Title = {OsteoFGRNet: Osteopontin-Driven Expression Profiling for Early Fetal
   Growth Restriction Analysis},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {9644-9659},
Abstract = {Fetal growth restriction (FGR) poses a serious threat to maternal and
   neonatal health, and its early diagnosis remains a major clinical
   challenge due to the complex, heterogeneous nature of its biological
   mechanisms. In this study, we propose OsteoFGRNet, a novel computational
   framework designed for early FGR detection using osteopontin-driven gene
   expression profiling. Unlike conventional methods that rely on limited
   clinical markers or static models, our approach integrates
   domain-specific biological knowledge with a multimodal deep learning
   architecture to capture both temporal dynamics and molecular
   interactions. OsteoFGRNet features three key components: a hierarchical
   feature extraction pipeline tailored for high-dimensional omics data, an
   attention-driven module that highlights biologically relevant biomarkers
   and developmental windows, and a graph-based propagation mechanism that
   encodes pathway-level dependencies informed by osteopontin expression.
   We incorporate multi-task optimization and biologically constrained
   regularization to enhance model robustness and interpretability.
   Extensive experiments on four benchmark molecular datasets demonstrate
   that OsteoFGRNet consistently outperforms state-of-the-art baselines in
   terms of accuracy, precision, and recall, achieving up to 91.02\%
   accuracy on the Prenatal Growth Restriction dataset. Ablation studies
   further confirm the effectiveness of each component in improving
   predictive power and biological relevance. Beyond prediction, the
   attention mechanism provides interpretable insights into
   osteopontin-associated regulatory processes implicated in FGR
   pathogenesis. These results underscore the potential of OsteoFGRNet as a
   clinically meaningful tool for early risk stratification and mechanistic
   investigation of FGR. This work contributes a domain-aligned,
   interpretable, and high-performance solution to a critical problem in
   maternal-fetal medicine and opens new directions for multi-omics
   integration in prenatal diagnostics.},
Type = {Article},
Affiliation = {Shen, XY (Corresponding Author), Shijiazhuang Fourth Hosp, Shijiazhuang 050011, Hebei, Peoples R China.
   Gao, Cuihong; Shen, Xueyan; Qiao, Mei; Yang, Rongjuan; Pang, Shasha; Bian, Zhimin; Sun, Jianghui; Wang, Lina, Shijiazhuang Fourth Hosp, Shijiazhuang 050011, Hebei, Peoples R China.},
