@article{ WOS:001554014500002,
Author = {Cao, Xiwen and Zhang, Mengyang and Hu, Weifeng and Peng, Zhiyi and Feng,
   Zhe and Wang, Longlu},
Title = {Multiscale strategies of interfacial water modulation to enhance
   electrocatalysis performance},
Journal = {COORDINATION CHEMISTRY REVIEWS},
Year = {2026},
Volume = {546},
Month = {JAN 1},
Abstract = {Interfacial water plays a critical role in modulating the efficiency and
   selectivity of catalytic processes. However, its dynamic behavior and
   structural complexity remain subjects of ongoing exploration. This
   review systematically summarizes the fundamental properties of
   interfacial water, with a focus on the anisotropic dynamics of water
   molecules revealing through machine learning approaches and the dynamic
   reconfiguration of hydrogenbond networks. It is evident that interfacial
   water regulation has emerged as a versatile platform for controlling
   electrochemical reaction kinetics. Therefore, a comprehensive summary of
   diverse strategies for modulating interfacial water is imperative. In
   this article, we categorized various interfacial water regulation
   strategies, including multiscale approaches ranging from atomic-scale
   manipulation of coordination environments, intermediate-scale
   manipulation of microenvironmental electric double layer to regulation
   via external energy stimuli. These strategies are applied across
   multiple electrochemical reactions, such as hydrogen evolution reaction
   (HER), oxygen evolution reaction (OER), oxygen reduction reaction (ORR)
   and nitrate reduction reaction (NRR). This systematic categorization
   provides researchers in the field of interfacial water with a structured
   framework to guide the targeted design of high-performance catalysts.},
Type = {Review},
