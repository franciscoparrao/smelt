@article{ WOS:001680121300001,
Author = {Dong, Suyi and Zhang, Ruowen and Mu, Nan and Xu, Ruixin and Liu, Yanyu
   and Zhou, Wei},
Title = {Screening of chlorine evolution reaction catalysts from density
   functional theory: a study on transition metal-modified LNS-TiO2
   nanosheets},
Journal = {APPLIED SURFACE SCIENCE},
Year = {2026},
Volume = {728},
Month = {MAY 15},
Abstract = {Development of highly active and selective chlorine evolution reaction
   catalysts is crucial for enhancing the efficiency of the chlor-alkali
   industry. This study aims to screen transition metal-modified LNS-TiO2
   nanosheets for high-performance chlorine evolution reaction. To achieve
   this, a combined approach of density functional theory screening and
   machine learning-driven descriptors was utilized. The screening
   identified that Pt-anchored and Nb-doped nanosheets exhibit high
   chlorine evolution reaction activity and selectivity, surpassing
   benchmark catalysts. Key activity descriptors were identified using
   machine learning strategy, while kinetic stability assessments confirm
   practical viability. This work provides a theoretical foundation for
   rational chlorine evolution reaction catalyst design and establishes a
   framework for accelerated materials discovery.},
