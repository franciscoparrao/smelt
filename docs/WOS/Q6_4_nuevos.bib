@article{ WOS:001717472700001,
Author = {Patnaik, Rupak Kumar and Sen, Sujit},
Title = {From green routes to digital design: Two-dimensional photocatalysts at
   the interface of machine learning and environmental applications},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2026},
Volume = {14},
Number = {2},
Month = {APR},
Abstract = {Two-dimensional (2D) materials represent a significant technical
   development in addressing global challenges related to environmental
   remediation and sustainable energy conversion. This comprehensive review
   examines the synthesis, characterization, and applications of
   two-dimensional photocatalytic materials, emphasizing sustainable
   synthesis and its crucial role in advancing high-performance catalysts.
   The article also highlights the growing integration of machine learning
   in the fields of materials discovery and synthesis improvement. Green
   synthesis approaches facilitate the swift advancement of highly
   efficient, sustainable photocatalytic systems. Thus, these effective
   methods immediately enable the development of sophisticated materials
   designed to address critical environmental remediation and energy
   sustainability issues. By exploring these three interconnected domains
   within a cohesive framework, this study highlights strategic pathways
   for the integrated discovery of sustainable photocatalytic materials.},
