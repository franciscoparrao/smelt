DOI = {10.1016/j.desal.2026.119964},
EarlyAccessDate = {FEB 2026},
Article-Number = {119964},
Keywords = {Lithium ion-sieve; Machine learning; Rational design; Adsorption
   prediction; SHAP-based interpretability},
Author-Email = {wangdong@ipe.ac.cn
   zwang@ipe.ac.cn},
Number-of-Cited-References = {40},
