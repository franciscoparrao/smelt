@article{ WOS:001593138200001,
Author = {Elavunkel, Vipin Kurian and Padhan, Prahallad},
Title = {Unlocking Thermoelectric Potential: A Machine Learning Stacking Approach
   for Half-Heusler Alloys},
Journal = {ACS APPLIED ENERGY MATERIALS},
Year = {2025},
Volume = {8},
Number = {20},
Pages = {15241-15257},
Month = {OCT 27},
Abstract = {The thermoelectric properties of half-Heusler (HH) alloys are predicted
   using an ensemble modeling approach, specifically a stacking model that
   integrates random forest and XGBoost algorithms. Leveraging a diverse
   data set encompassing thermal conductivity (kappa), electrical
   conductivity (sigma), Seebeck coefficient (S), and the figure of merit
   (ZT), the study demonstrates superior accuracy with R 2 scores of 0.93
   for kappa, 0.96 for sigma, 0.99 for S, and 0.92 for ZT. Feature
   importance analysis revealed that temperature, mean covalent radius, and
   atomic volume deviations critically influence thermoelectric behavior.
   The stacking model demonstrates a clear advantage by substantially
   reducing both the mean absolute error and root-mean-square error across
   all predicted thermoelectric properties, indicating enhanced prediction
   accuracy and reliability compared to individual base models. The model
   was validated against first-principles density functional theory
   calculations for representative compounds ErNiBi, YPtBi, and YPdSb,
   showing strong agreement and capturing real-world experimental effects
   such as nonmonotonic variations and peak values prior to
   high-temperature decline-phenomena that simplified density functional
   theory struggles to encapsulate. This comprehensive approach highlights
   the effectiveness of combining machine learning with physical
   descriptors to predict complex thermoelectric properties, offering
   valuable insights for the strategic design of high-performance HH
   thermoelectric materials. The ensemble modeling framework, coupled with
   thoughtful feature selection and meticulous engineering, establishes a
   robust foundation for future research aimed at developing
   high-performance thermoelectric materials.},
Type = {Article},
Affiliation = {Padhan, P (Corresponding Author), Indian Inst Technol Madras, Dept Phys, Nanoscale Phys Lab, Chennai 600036, India.
   Padhan, P (Corresponding Author), Indian Inst Technol Madras, Funct Oxides Res Grp, Chennai 600036, India.
   Elavunkel, Vipin Kurian; Padhan, Prahallad, Indian Inst Technol Madras, Dept Phys, Nanoscale Phys Lab, Chennai 600036, India.
   Padhan, Prahallad, Indian Inst Technol Madras, Funct Oxides Res Grp, Chennai 600036, India.},
DOI = {10.1021/acsaem.5c02223},
EarlyAccessDate = {OCT 2025},
Keywords = {thermoelectric materials; half-Heusler alloy; machine learning; stacking
   model; random forest},
Keywords-Plus = {EFFICIENCY; TRANSPORT},
Author-Email = {padhan@iitm.ac.in},
Number-of-Cited-References = {60},
Times-Cited = {1},
Unique-ID = {WOS:001593138200001},
}

@article{ WOS:001603020800001,
Author = {Gao, Jerry and Gujarati, Krinal and Hegde, Meghana and Arra, Padmini and
   Gupta, Sejal and Buch, Neeraja},
Title = {Integration of UAV and Remote Sensing Data for Early Diagnosis and
   Severity Mapping of Diseases in Maize Crop Through Deep Learning and
   Reinforcement Learning},
Journal = {REMOTE SENSING},
Year = {2025},
Volume = {17},
Number = {20},
Month = {OCT 13},
Abstract = {Highlights What are the main findings? A framework combining UAV,
   satellite, and weather data to detect crop diseases. Ensemble deep
   learning and reinforcement learning improve classification and severity
   mapping. What is the implication of the main finding? Enables near
   real-time, scalable crop disease management to reduce yield losses.
   Early detection and hotspot mapping optimize water and pesticide use for
   sustainability.Highlights What are the main findings? A framework
   combining UAV, satellite, and weather data to detect crop diseases.
   Ensemble deep learning and reinforcement learning improve classification
   and severity mapping. What is the implication of the main finding?
   Enables near real-time, scalable crop disease management to reduce yield
   losses. Early detection and hotspot mapping optimize water and pesticide
   use for sustainability.Abstract Accurate and timely prediction of
   diseases in water-intensive crops is critical for sustainable
   agriculture and food security. AI-based crop disease management tools
   are essential for an optimized approach, as they offer significant
   potential for enhancing yield and sustainability. This study centers on
   maize, training deep learning models on UAV imagery and satellite
   remote-sensing data to detect and predict disease. The performance of
   multiple convolutional neural networks, such as ResNet-50, DenseNet-121,
   etc., is evaluated by their ability to classify maize diseases such as
   Northern Leaf Blight, Gray Leaf Spot, Common Rust, and Blight using UAV
   drone data. Remotely sensed MODIS satellite data was used to generate
   spatial severity maps over a uniform grid by implementing time-series
   modeling. Furthermore, reinforcement learning techniques were used to
   identify hotspots and prioritize the next locations for inspection by
   analyzing spatial and temporal patterns, identifying critical factors
   that affect disease progression, and enabling better decision-making.
   The integrated pipeline automates data ingestion and delivers farm-level
   condition views without manual uploads. The combination of multiple
   remotely sensed data sources leads to an efficient and scalable solution
   for early disease detection.},
Type = {Article},
Affiliation = {Buch, N (Corresponding Author), San Jose State Univ, Dept Comp Engn, 1 Washington Sq, San Jose, CA 95192 USA.
