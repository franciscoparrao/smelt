Keywords = {Diesel lubricity; Machine learning; Random forest regression; PySR
   symbolic regression; SHAP analysis; Industrial data},
Keywords-Plus = {RANDOM FOREST; LUBRICITY},
Author-Email = {erfan.m@nepu.edu.cn},
Number-of-Cited-References = {31},
