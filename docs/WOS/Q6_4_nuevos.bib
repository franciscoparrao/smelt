   Xue, Tingting, Nanjing Univ Informat Sci \& Technol, Sch Environm Sci \& Engn, Nanjing 210044, Peoples R China.},
DOI = {10.1016/j.enconman.2025.120825},
EarlyAccessDate = {DEC 2025},
