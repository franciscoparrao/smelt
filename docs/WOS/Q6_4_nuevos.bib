   Huerta, E. A., Argonne Natl Lab, Data Sci \& Learning Div, Lemont, IL 60439 USA.
   Huerta, E. A., Univ Chicago, Dept Comp Sci, Chicago, IL 60637 USA.
   Huerta, E. A., Univ Illinois, Dept Astron, Urbana, IL 61801 USA.
   Haas, Roland, Univ British Columbia, Dept Phys \& Astron, Vancouver, BC V6T 1Z1, Canada.},
DOI = {10.1088/2632-2153/ae054c},
Article-Number = {035057},
Keywords = {magnetohydrodynamics; turbulence; diffusion-integrated neural operators;
   high performance computing},
