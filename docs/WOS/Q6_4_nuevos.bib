@article{ WOS:001616506600002,
Author = {Thakur, Abhinav and Raj, Manasvi and Kumar, Shubham and Mehta, Miran and
   Singh, Megha and Jain, Adarsh and Goel, Neeraj},
Title = {Enhancing photovoltaic parameters through anti-reflective coatings: A
   DFT and machine learning-based study},
Journal = {JOURNAL OF PHYSICS AND CHEMISTRY OF SOLIDS},
Year = {2026},
Volume = {209},
Month = {FEB},
Abstract = {Improving light absorption in solar cells remains a critical challenge
   in advancing photovoltaic (PV) efficiency. This study explores the role
   of anti-reflective coatings (ARCs) in enhancing solar cell performance
   through a dual approach combining first-principles simulations and
   machine learning (ML) analytics. Using Density Functional Theory (DFT),
   we investigated the optical, electronic, and vibrational properties of
   five ARC materials-SiO2, Al2O3, HfO2, ZnS, and MgF2. Our simulations
   reveal that SiO2 exhibits the most favourable characteristics, including
   low reflectivity, stable refractive index, a wide electronic bandgap,
   and dynamic vibrational stability. To assess real-world performance, an
   ML model was trained on experimental and simulated solar cell data of
   4500 data point to predict the impact of ARC application on key PV
   parameters. The results showed significant improvements in short-circuit
   current (J(sc)), open-circuit voltage (V-oc), fill factor (FF), and
   power conversion efficiency (PCE) with 19.6 \%, 30.4 \%, and 14.9 \%
   increase in PCE for lead-based, cesium-based perovskite and
   non-perovskite solar cell respectively. ML model achieves a strong
   predictive correlation (R-2 = 0.85) with Root Mean Square Error (RMSE)
   of 0.021 and Mean Absolute Error (MAE) of 0.017. This integrated
   computational-simulated framework highlights SiO2 as a robust,
   high-performance ARC candidate. Results shows that SiO2 has ultra-low
   reflectivity (<0.04) and a nearly constant real refractive index
   (similar to 1.45) which makes it as a promising candidate for ARC. The
   novelty of this work lies in the dual methodology, where DFT insights
   are paired with an ML model trained on a combination of simulated and
   real-world data to predict improvements in solar cell parameters.},
Type = {Article},
Affiliation = {Goel, N (Corresponding Author), Netaji Subhas Univ Technol, Dept Elect \& Commun Engn, New Delhi 110078, India.
   Thakur, Abhinav; Raj, Manasvi; Kumar, Shubham; Mehta, Miran; Singh, Megha; Jain, Adarsh; Goel, Neeraj, Netaji Subhas Univ Technol, Dept Elect \& Commun Engn, New Delhi 110078, India.},
DOI = {10.1016/j.jpcs.2025.113320},
EarlyAccessDate = {NOV 2025},
Article-Number = {113320},
Keywords = {ARCs; Anti-reflective coatings; DFT; Density functional Theory; SiO2;
   Silicon dioxide; ML; Machine learning},
Keywords-Plus = {SOLAR-CELL; FABRICATION; DESIGN},
Author-Email = {neeraj.goel@nsut.ac.in},
Number-of-Cited-References = {52},
Times-Cited = {2},
Unique-ID = {WOS:001616506600002},
}

@article{ WOS:001626417500011,
Author = {Yang, Jie and Huang, Peilin and Zhang, Hanwen and Ren, Hongyang and
   Zhang, Jie and Chen, Hong and Wang, Xiaotian and Yuan, Hongkuan and Xie,
   Jianping and Wang, Biao},
Title = {Machine-learning-driven design of TMCs heterojunctions with
   dual-single-atom synergy for efficient photocatalytic hydrogen evolution},
Journal = {APPLIED SURFACE SCIENCE},
Year = {2026},
Volume = {719},
Month = {FEB 28},
Abstract = {Two-dimensional transition metal chalcogenides (TMCs) and their van der
   Waals (vdW) heterojunctions hold great potential for solar-driven
   photocatalytic hydrogen evolution. Here, we integrate database-driven
   highthroughput screening with crystal graph convolutional neural
   networks (CGCNN) to predict semiconductor bandgaps, identifying 156
   promising TMCs from a pool of 69,616 candidates. A dedicated database
   comprising 481 curated entries was constructed to train the CGCNN model
   using optimized feature descriptors, achieving bandgap predictions
   within 0.1 eV of DFT values for key materials such as WTe2, MoTe2, and
   PtSSe. Applying criteria of lattice matching and appropriate edge
   positions, we designed 39 potential high-performance Z-scheme
   heterojunctions like XTe2/PtSSe (X = W, Mo). We further propose a
   dual-single-atom (Pt/Ni) co-anchoring strategy across heterojunction
   layers to synergistically enhance hydrogen and oxygen evolution
   reactions while broadening the light absorption range. This
   Pt@MoTe2/Ni@PtSSe heterojunction achieves a record solarto-hydrogen
   efficiency of 29.79 \%. This work establishes a robust theoretical
   framework for photocatalyst discovery and introduces a transformative
   dual-site engineering strategy for next-generation solar-to-fuel
   systems.},
Type = {Article},
Affiliation = {Yuan, HK; Wang, B (Corresponding Author), Southwest Univ, Sch Phys Sci \& Technol, Chongqing 400715, Peoples R China.
