@article{ WOS:001630486300022,
Author = {Cao, Jingqi and He, Weikun and Tan, Chengjun and Tu, Lei and Wu, Suiwen
   and An, Jiahe and Hu, Junde and Zhao, Hua},
Title = {An interpretable deep learning framework for UHPC dry joint shear
   strength prediction under small sample regimes},
Journal = {ENGINEERING STRUCTURES},
Year = {2026},
Volume = {348},
Month = {FEB 1},
Abstract = {As precast segmental ultra-high-performance concrete bridges (PUSBs)
   become widely used in civil engineering, accurately predicting the shear
   strength of their joints is critical for ensuring structural safety. Dry
   joints have been widely used in PUSBs due to their advantages in
   construction convenience and resistance to environmental influences.
   Current predictive models of UHPC dry joints still have limitations in
   terms of accuracy and generalization ability. Although machine learning
   approaches have been applied to strength prediction, their `black-box'
   nature hinders interpretable relationships between input and target
   variables. To address these limitations, a novel framework integrating
   interpretable deep-learning techniques is employed to develop a new
   predictive model for the shear strength of UHPC dry joints. To begin, an
   experimental database comprising 81 sets of data of UHPC dry joints
   across 13 distinct features was established. Subsequently, to identify
   the key features, feature selection was applied to the initial database,
   thereby enhancing the model's accuracy and interpretability.
   Additionally, the conditional generative adversarial network (CTGAN) was
   employed to augment and expand the limited dataset, thereby exploring
   its impact on symbolic regression. Deep learning-based symbolic
   regression was then conducted on the augmented database to yield
   explicit expressions for shear strength of joints, which effectively
   improved the interpretability of the framework. The optimal model
   derived from the proposed framework achieved an R2 of 0.9241, which is
   12.0 \% higher than that of the best conventional model and 803.3 \%
   higher than that of the AASHTO model.},
Type = {Article},
Affiliation = {He, WK (Corresponding Author), Hunan Univ, Coll Civil Engn, Natl Key Lab Bridge Safety \& Resilience, Key Lab Wind \& Bridge Engn Hunan Prov, Changsha 410082, Peoples R China.
   Cao, Jingqi; He, Weikun; Tan, Chengjun; Tu, Lei; Wu, Suiwen; An, Jiahe; Hu, Junde; Zhao, Hua, Hunan Univ, Coll Civil Engn, Natl Key Lab Bridge Safety \& Resilience, Key Lab Wind \& Bridge Engn Hunan Prov, Changsha 410082, Peoples R China.},
DOI = {10.1016/j.engstruct.2025.121785},
EarlyAccessDate = {NOV 2025},
Article-Number = {121785},
Keywords = {Ultra-high-performance concrete; Dry joints; Shear strength; Deep
   learning; Symbolic regression; Prediction model},
Keywords-Plus = {PERFORMANCE},
Author-Email = {heweikun@hnu.edu.cn},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001630486300022},
}

@article{ WOS:001629405400001,
Author = {Chen, Xiaolu and Zhao, Yidong and Cao, Zihe and Sun, Youqian and Zhang,
   Wenming and Yang, Yi and Zhang, Bing and Liu, Ji and Zhang, Zhenxi and
   Lu, Qiang},
Title = {Machine learning-driven prediction of energy and band gap in FAPbI3
   perovskite using diverse structural descriptors},
Journal = {ORGANIC ELECTRONICS},
Year = {2026},
Volume = {148},
Month = {JAN},
Abstract = {Perovskite materials exhibit significant potential in optoelectronic
   applications, with system energy and band gap serving as critical
   metrics for evaluating material stability and optical characteristics.
   To accelerate the development of high-performance perovskite materials,
   this study establishes an efficient structure-property prediction
   framework through machine learning approaches. Artificial neural network
   (ANN) potential models and random forest (RF) models were established
   using Gaussian-type structure descriptors (GTSD) and powertype
   structural descriptors (PTSD) as feature inputs, based on a
   comprehensive dataset of 1000 FAPbI3 configurations with corresponding
   system energies and band gap values. The RF-based feature selection
   method was subsequently employed to identify key structural descriptors
   governing the energy landscape and electronic properties of FAPbI3.
   Furthermore, the predictive robustness of neural networks across
   datasets with varying structural perturbations was systematically
   investigated, revealing critical insights into model generalization
   capabilities. This computational framework demonstrates high-precision
   prediction of structure-property relationships while providing
   mechanistic interpretation of dominant structural factors, thereby
   offering valuable guidance for rational design of perovskite materials.},
Type = {Article},
Affiliation = {Zhang, B; Zhang, ZX (Corresponding Author), North China Elect Power Univ, Natl Engn Res Ctr New Energy Power Generat, Beijing 102206, Peoples R China.
   Chen, Xiaolu; Zhao, Yidong; Cao, Zihe; Sun, Youqian; Zhang, Wenming; Yang, Yi; Zhang, Bing; Liu, Ji; Zhang, Zhenxi; Lu, Qiang, North China Elect Power Univ, Natl Engn Res Ctr New Energy Power Generat, Beijing 102206, Peoples R China.
