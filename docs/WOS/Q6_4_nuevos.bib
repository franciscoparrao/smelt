   Li, Yan, Northwestern Polytech Univ, Sch Civil Aviat, Xian 710072, Peoples R China.
   Guan, Yongsheng, Jiangsu Sinoroad Engn Res Inst Co Ltd, Nanjing 211805, Peoples R China.},
DOI = {10.1016/j.rineng.2025.106724},
