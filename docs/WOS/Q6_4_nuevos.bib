@article{ WOS:001610225600001,
Author = {Hasanzadeh, Rezgar},
Title = {Machine learning-driven optimization of energy absorption in PLA
   composites reinforced with carbon fibers through FFF additive
   manufacturing},
Journal = {RAPID PROTOTYPING JOURNAL},
Year = {2025},
Month = {2025 NOV 12},
Abstract = {PurposeThis study aims to optimize the energy absorption capacity (EAC)
   of polylactic acid (PLA) composite materials reinforced with short micro
   carbon fibers, fabricated via fused filament fabrication (FFF) 3D
   printing. The objective is to understand how key process parameters
   influence mechanical performance and to explore the potential of machine
   learning in enhancing material property prediction and
   optimization.Design/methodology/approachA series of controlled
   experiments were conducted by varying nozzle diameter, nozzle
   temperature, and fan speed. The EAC of the 3D-printed samples was
   determined through impact testing and density measurements. Three
   regression-based machine learning models-first-order, second-order, and
   second-order with interaction terms-were developed and evaluated to
   predict EAC based on process parameters.FindingsThe second-order model
   with interaction terms showed the highest predictive accuracy (R2 =
   0.9984, adjusted R2 = 0.9955, predicted R2 = 0.9758). Optimization
   analysis identified the ideal conditions (0.4 mm nozzle diameter, 200
   degrees C nozzle temperature, 100\% fan speed), achieving a maximum EAC
   of 72.64 kJ.m/g. The study revealed the significant effect of printing
   parameters on EAC, confirming that fine-tuning these variables enhances
   composite performance.Originality/valueThis research highlights the
   effective integration of machine learning with additive manufacturing to
   predict and optimize mechanical properties of PLA composites. It
   provides a valuable framework for improving energy absorption through
   data-driven tuning of 3D printing parameters, contributing to the
   advancement of high-performance, customized polymer composites.},
Type = {Article; Early Access},
Affiliation = {Hasanzadeh, R (Corresponding Author), Kermanshah Univ Technol, Dept Mech Engn, Kermanshah, Iran.
   Hasanzadeh, Rezgar, Kermanshah Univ Technol, Dept Mech Engn, Kermanshah, Iran.},
DOI = {10.1108/RPJ-06-2025-0219},
EarlyAccessDate = {NOV 2025},
Keywords = {Additive manufacturing; Machine learning; PLA-carbon fiber composites;
   FFF 3D printing; Energy absorption capacity},
Author-Email = {r.hasanzadeh@kut.ac.ir},
Number-of-Cited-References = {50},
Times-Cited = {1},
Unique-ID = {WOS:001610225600001},
}

@article{ WOS:001619595500001,
Author = {Kou, Junhui and Liu, Tianle and Jiang, Guosheng and Zhou, Zhengwen and
   Yang, Guokun and Pan, Yuanhai and Ni, Xiaoyang and Liu, Hao},
Title = {Interpretable machine learning assisted screening of metal-organic
   frameworks for methane adsorption mechanism exploration under low and
   high pressures},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {6},
Month = {DEC},
Abstract = {Metal-organic frameworks (MOFs) are promising materials for methane
   adsorption due to their porous structures, tunable properties, and vast
   design possibilities. However, the design and screening of MOFs often
   entail substantial time and economic costs in specific applications. To
   address these challenges, this study presents a low-cost and
   interpretable machine learning framework for efficiently identifying
   MOFs with optimal methane adsorption properties. By integrating public
   structural databases and grand canonical Monte Carlo simulations, a
   training dataset containing 252,353 diverse MOFs structure-property
   pairs was constructed, incorporating 190 geometric and chemical
   descriptors and their corresponding methane adsorption performances
   under 65 bar and 5.8 bar. After hyperparameter optimization, multi-task
   learning model achieved a maximum R2 of 0.992 for methane adsorption
   predictions. Shapley additive explanations (SHAP) analysis
   systematically evaluated the influence of various descriptors on methane
   adsorption performance under both high and low pressure. The results
   indicated that ligand-related chemical descriptors dominate at low
   pressure, while geometric descriptor density plays the primary role at
   high pressure. New insights were provided into how key features affect
   methane adsorption through complex interactions, identifying optimal
   design ranges for ten key descriptors at both high and low pressures to
   enhance adsorption efficiency. Finally, through feature dimensionality
   reduction, the model was simplified to ten input features, achieving
   high predictive performance (maximum R2 of 0.987) while significantly
   reducing computational costs. This work offers a low-cost solution for
   screening high-performance MOFs for methane adsorption and provides
   valuable insights for MOFs structural design, thereby enhancing the
   efficiency of MOFs discovery.},
Type = {Article},
Affiliation = {Liu, TL (Corresponding Author), Unconvent Cementing \& Special Reinforcement Lab, Wuhan 430074, Peoples R China.
   Liu, TL (Corresponding Author), China Univ Geosci, Fac Engn, Wuhan 430074, Peoples R China.
