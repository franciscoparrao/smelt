@article{ WOS:001697028900001,
Author = {Rautela, Kamakshi and Vardhan, Harsh and Juneja, Akshay and Kumar, Vijay},
Title = {From Past Innovations to Future Prospects: Advanced Computational
   Techniques in Automated Obscenity Detection},
Journal = {CYBERNETICS AND SYSTEMS},
Year = {2026},
Month = {2026 FEB 16},
Abstract = {The expansion of digital media in recent years has created an immediate
   need for automated systems for reliable detection of obscene content.
   Such systems are essential for safeguarding users, upholding ethical
   standards, and ensuring compliance with regulatory frameworks. This
   paper surveys recent advances in deep learning methods, particularly
   convolutional neural networks (CNNs), recurrent neural networks (RNNs),
   and emerging transformer-based and vision-language models. We emphasize
   how these approaches are integrated within engineering frameworks,
   ranging from distributed cloud pipelines to edge deployments, to support
   large-scale content moderation. The reviewed methods demonstrate strong
   capabilities in learning complex visual and contextual patterns, leading
   to high performance in tasks such as obscene image and video
   classification. Computational strategies that improve accuracy,
   precision, recall, F1-score, AUC, and real-time latency are highlighted,
   along with challenges of scalability, dataset bias, adversarial attacks,
   and resource constraints. By combining technical insights with
   discussions of ethical and privacy considerations, this review proposes
   a multidisciplinary framework for building more precise, fair, and
   resilient obscenity detection systems. The work serves as a practical
   reference for engineers, developers, and policymakers while outlining
   open challenges and future opportunities, including multimodal
   moderation, deepfake detection, and privacy-preserving learning
   approaches.},
Type = {Review; Early Access},
Affiliation = {Kumar, V (Corresponding Author), Dr BR Ambedkar Natl Inst Technol, Dept Informat Technol, Jalandhar, India.
   Rautela, Kamakshi, UPES, Sch Comp Sci, Dehra Dun, India.
