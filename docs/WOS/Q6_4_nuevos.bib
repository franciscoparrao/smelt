}

@article{ WOS:001579053000003,
Author = {Saidani, Okba and Yousfi, Abderrahim and Belhadad, Yehya and Zouache,
   Rafik and Brahimi, Abdelhalim and Sahoo, Girija Shankar},
Title = {Predictive modeling of Rb2ScCuCl6-Based perovskite solar cells
   performance using neural networks-guided optimization and SHAP-based
   interpretability},
Journal = {JOURNAL OF PHYSICS AND CHEMISTRY OF SOLIDS},
Year = {2026},
Volume = {208},
Number = {1},
Month = {JAN},
Abstract = {This study presents a synergistic approach combining machine learning
   (ML) with SCAPS-1D simulations to optimize the performance of
   Rb2ScCuCl6-based perovskite solar cells (PSCS). A comprehensive dataset
   was generated to evaluate critical parameters, including electron
   transport layer (ETL) and hole transport layer (HTL) properties,
   absorber thickness, and defect-mediated effects such as doping and
   impurities in the Rb2ScCuCl6 absorber. An artificial neural network
   (ANN) model was trained on this dataset, achieving exceptional
   predictive accuracy for power conversion efficiency (PCE), as evidenced
   by a Pearson correlation coefficient 0.950 between simulated and
   ML-predicted values. Leveraging ANN-optimized parameters, SCAPS-1D
   simulations identified an optimal device configuration: a C60 ETL (100
   nm), Rb2ScCuCl6 absorber (800 nm), and Cu2O HTL (500 nm), yielding a
   theoretical PCE of 29.66 \%. This work demonstrates the transformative
   potential of integrating ML with physics-based simulations to accelerate
   the discovery of high-performance PSC architectures. The findings
   provide actionable insights for experimental validation and establish a
   robust computational framework for the rational design of
   next-generation, high-efficiency photovoltaic devices.},
Type = {Article},
Affiliation = {Saidani, O (Corresponding Author), Univ Mohamed El Bachir El Ibrahimi Bordj Bou Arrer, Fac Sci \& Technol, Dept Elect, ETA Lab, El Anceur 34030, Algeria.
