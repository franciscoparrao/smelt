@article{ WOS:001531412600001,
Author = {Abaddi, Samer},
Title = {A proposed electric/hybrid batteries recycling hub with ERP
   implementation and simulation},
Journal = {JOURNAL OF SIMULATION},
Year = {2025},
Month = {2025 JUL 21},
Abstract = {This study proposes an electric/hybrid battery management hub and
   establishes a low-cost Enterprise Resource Planning (ERP) system
   designed for managing its operations. A discrete event-based simulation
   identified critical bottlenecks in the recycling workflow and expected
   recycling/re-manufacturing \$N = 1,403\$N=1,403 batteries/year under
   continuous production. Machine learning-driven forecasting models,
   accounting for key factors like vehicle registrations and economic
   indicators, predict a substantial increase in battery supply, reaching
   \$13,721\$13,721 batteries by 2050. Three scenarios (10\%, 15\%, and
   20\%) of the sensitivity analysis highlighted the significant impact of
   vehicle registrations on future battery availability. The proposed
   system demonstrates high performance with an average response time of
   \$0.0036\$0.0036 seconds, outperforming industry benchmarks. This
   integrated approach, combining a novel ERP architecture with simulation
   and forecasting, offers a scalable and efficient solution for optimizing
   battery lifecycle management and facilitating a circular economy for EV
   batteries, with significant implications for sustainable transportation
   and resource recovery. In addition to having a direct impact on
   Sustainable Development Goals (SDG 9, 12, and 13), the findings
   highlight opportunities for future research in automation and
   sustainable practices within the evolving landscape of the automobile
   industry.},
Type = {Article; Early Access},
Affiliation = {Abaddi, S (Corresponding Author), IDent Res, Res Dept, Al Shab St, Amman, Jordan.
   Abaddi, Samer, IDent Res, Res Dept, Al Shab St, Amman, Jordan.},
DOI = {10.1080/17477778.2025.2534661},
EarlyAccessDate = {JUL 2025},
Keywords = {Enterprise resource planning; discrete event simulation; battery
   recycling; forecasting models; machine learning},
Keywords-Plus = {LITHIUM-ION BATTERIES; SYSTEM},
Author-Email = {Eng.sameralabbadi@gmail.com},
Number-of-Cited-References = {78},
Times-Cited = {2},
Unique-ID = {WOS:001531412600001},
}

@article{ WOS:001534095600001,
Author = {Wang, Hao and Zhu, Yue and Li, Junfeng and Li, Yuquan and Liu, Yong and
   Chen, Zeqiu and Liu, Xinjuan and Lu, Ting and Pan, Likun},
Title = {Recent advances in NASICON-type materials for high-performance
   capacitive deionization: design strategies and mechanistic insights},
Journal = {JOURNAL OF MATERIALS CHEMISTRY A},
Year = {2025},
Volume = {13},
Number = {34},
Pages = {27807-27818},
Month = {AUG 26},
Abstract = {Capacitive deionization (CDI) is a sustainable water treatment
   technology known for its energy efficiency. Notably, electrode materials
   are key factors influencing ion adsorption efficiency. Conventional
   carbon-based materials often exhibit limited adsorption capacity and
   poor cycling stability, which significantly hinder their effectiveness,
   especially under complex water conditions. In contrast, NASICON-type
   (sodium super ionic conductor) materials, characterized by their
   three-dimensional open framework and superior electrochemical activity,
   offer higher adsorption capacity and enhanced stability, making them
   promising candidates for CDI applications. However, comprehensive
   reviews focusing on their design principles, adsorption behavior, and
   associated challenges in the context of CDI remain scarce. This review
   systematically explores the design strategies and adsorption performance
   of NASICON-type materials, emphasizing approaches such as optimizing
   charge and electron dynamics, inhibiting structural agglomeration, and
   incorporating buffer architecture to enhance CDI performance.
   Furthermore, advanced solutions to key challenges are discussed,
   including the use of machine learning for designing high-entropy
   materials, integrating NASICON electrodes into various CDI
   architectures, and coupling CDI with complementary technologies like
   photocatalysis and electrocatalysis. By providing these perspectives,
   this review contributes to the design of high-performance NASICON
   materials and the continued evolution of efficient, long-lasting, and
   application-ready CDI technologies.},
Type = {Review},
