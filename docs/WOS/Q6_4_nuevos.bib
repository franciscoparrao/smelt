DOI = {10.1109/LRA.2026.3653326},
Keywords = {Robots; Torque; Feedforward systems; Dynamics; Computational modeling;
   Accuracy; Data models; Vectors; Robot kinematics; Neural networks;
   Machine learning for robot control; model learning for control; motion
   control},
Author-Email = {manuel.weiss@bht-berlin.de},
