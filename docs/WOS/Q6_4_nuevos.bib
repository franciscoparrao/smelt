@article{ WOS:001706111500001,
Author = {Xie, Zaipeng and Zhu, Wei and Li, Peixin and Ding, Haotian and Song,
   Wenzhan},
Title = {S2TE: Staged Scale-Free Topology Evolution for Sparse Spiking Neural
   Networks},
Journal = {MACHINE LEARNING},
Year = {2026},
Volume = {115},
Number = {3},
Month = {MAR},
Abstract = {Spiking Neural Networks (SNNs) represent a promising paradigm for
   energy-efficient machine learning. However, achieving high performance
   under significant sparsity constraints remains challenging. In this
   work, we present Staged Scale-Free Topology Evolution (S2TE), a novel
   sparse training framework for SNNs that systematically combines
   layer-wise scale-free topology initialization with a conceptually
   inspired, three-stage weight pruning and regeneration process comprising
   exploratory growth, topology refinement, and stability maintenance. S2TE
   uses the Barab \& aacute;si-Albert model to establish sparse layer-wise
   scale-free topologies from the outset, and the staged dynamic topology
   optimization approach enables efficient balance between structural
   exploration and exploitation. Experiments on CIFAR10, CIFAR100, and
   DVS-CIFAR10 benchmarks show that S2TE-trained SNNs achieve competitive
   accuracy while maintaining merely 30\% connectivity. The resulting
   networks exhibit layer-wise scale-free-like connectivity, which is
   associated with efficient and robust information flow in the evaluated
   benchmarks. These findings demonstrate the promise of staged topology
   evolution for improving sparse SNN training and motivate further study
   in broader scenarios.},
Type = {Article},
Affiliation = {Xie, ZP (Corresponding Author), Hohai Univ, Coll Comp Sci \& Software Engn, Nanjing 211100, Peoples R China.
   Xie, Zaipeng; Zhu, Wei; Li, Peixin, Hohai Univ, Coll Comp Sci \& Software Engn, Nanjing 211100, Peoples R China.
   Ding, Haotian, Hohai Univ, Dayu Coll, Nanjing 210098, Peoples R China.
   Song, Wenzhan, Univ Georgia, Ctr Cyber Phys Syst, Athens, GA 30602 USA.},
DOI = {10.1007/s10994-025-06982-z},
Article-Number = {50},
Keywords = {Spiking neural networks; Sparse training; Neuromorphic computing;
   Evolutionary dynamics},
Author-Email = {zaipengxie@hhu.edu.cn
   wzhu2@hhu.edu.cn
