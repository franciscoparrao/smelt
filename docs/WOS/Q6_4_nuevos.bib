Keywords = {Associate Editor; Coefficient of permeability; Parameter inversion;
   Surrogate model; Improved black-winged kite algorithm; Gated recurrent
   unit; Seepage calculation},
Keywords-Plus = {LATIN HYPERCUBE DESIGN; ALGORITHM; PERMEABILITY; EVOLUTION; FLOW},
