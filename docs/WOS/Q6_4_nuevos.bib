@article{ WOS:001573777100016,
Author = {Zhang, Shaoan and Lv, Yang and Li, Zhenzhang and He, Chao and Guo,
   Zonglong and An, Ximei and Sun, Shengzhi and Fang, Zaijin and Li, Yang},
Title = {Explainable machine learning-enabled discovery for high-efficiency
   red-emitting phosphor under data constraints},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2025},
Volume = {522},
Month = {OCT 15},
Abstract = {Europium(III)-activated red-emitting phosphors are critical for
   energy-efficient solid-state lighting (SSL) systems, yet optimizing
   their photoluminescence quantum yield (PLQY) and thermal quenching
   temperature (T-50) remains a significant challenge. This study presents
   an interpretable machine learning (ML) framework designed for small
   datasets to accurately predict T-50 (R-2 = 0.87) by identifying
   structural rigidity and bandgap characteristics as key determinants.
   Leveraging this model, we screened over 30,000 potential Eu3+-activated
   oxides and experimentally synthesized six candidates. Among these,
   YAl3(BO3)(4):Eu3+ demonstrated exceptional performance, achieving 23 \%
   optical absorption efficiency, 87 \% PLQY, and outstanding thermal
   stability (93 \%@450 K) under full Eu3+ substitution. This integrated
   computational-experimental approach not only accelerates the discovery
   of high-performance phosphors but also provides insights applicable to
   other rare-earth-doped SSL technologies.},
