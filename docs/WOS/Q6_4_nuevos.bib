@article{ WOS:001663929800001,
Author = {Singh, Sashwat Kumar and Kundu, Debashis},
Title = {Artificial neural networks for sodium-ion batteries: A molecular
   descriptor approach to performance prediction},
Journal = {JOURNAL OF ENERGY STORAGE},
Year = {2026},
Volume = {149},
Month = {MAR 1},
Abstract = {Sodium-ion batteries (SIBs) are essential for scalable and sustainable
   energy storage due to abundant sodium resources, cost-effectiveness, and
   superior safety compared to lithium-ion batteries. However, the
   complexity of their electrochemical behavior presents a challenge for
   accurate predictive modeling, which is crucial for efficient cathode
   material optimization. This study applies Artificial Neural Network
   (ANN) to predict key electrochemical metrics: discharge capacity (DC),
   cycle number (CN), and capacity retention (CR) across three major SIB
   cathode categories: Prussian Blue Analogues (PBAs), Layered Transition
   Metal Oxides (LTMOs), and polyanions. The ANN model build is benchmarked
   using Random Forest (RF), Extreme Gradient Boosting (XGBoost), and
   Support Vector Machine (SVM). The ANN achieves highest accuracy with a
   coefficient of determination (R2) of 0.982 and low mean squared error
   (MSE) of 1.28 x 10-6, capturing 98.2 \% of performance variance.
   Categorywise, the ANN performs best for PBAs (R2: 0.948 for DC, 0.998
   for CN, and 0.938 for CR) due to their welldefined structure and redox
   behavior, followed by polyanions (R2: 0.945 for DC, 0.996 for CN, 0.919
   for CR) having robust frameworks enhancing cycling stability, and then
   LTMOs (R2: 0.923 for DC, 0.947 for CN, 0.906 for CR) due to their
   complex structural dynamics. Across 102 cathodes, Na4Mn9O18 identifies
   as the top performer with a DC of 132.2 mAh/g and 77 \% CR after 1000
   cycles, while several PBAs and polyanion cathodes also show excellent
   long-term stability. These findings demonstrate the power of tailored
   machine learning approaches to effectively capture SIBs complex behavior
   and accelerate the design of high-performance SIB cathodes for
   next-generation energy solutions.},
Type = {Article},
Affiliation = {Kundu, D (Corresponding Author), Inst Chem Technol Marathwada Campus, Dept Chem Engn, Jalna 431203, Maharashtra, India.
   Singh, Sashwat Kumar; Kundu, Debashis, Inst Chem Technol Marathwada Campus, Dept Chem Engn, Jalna 431203, Maharashtra, India.},
DOI = {10.1016/j.est.2025.119979},
EarlyAccessDate = {JAN 2026},
Article-Number = {119979},
Keywords = {Sodium-ion battery; Artificial intelligence; Artificial neural network;
   Molecular descriptor; Discharge capacity; Cycle number; Capacity
   retention},
Keywords-Plus = {MULTILAYER FEEDFORWARD NETWORKS; CATHODE MATERIAL; ELECTROCHEMICAL
   PROPERTIES; ELECTRODE MATERIAL; CRYSTAL-STRUCTURES; LITHIUM-ION;
   LOW-COST; INTERCALATION; P2-TYPE; OPTIMIZATION},
