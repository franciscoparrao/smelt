@article{ WOS:001553134300001,
Author = {Fatemi, Amirhossein and Ganjali, Ahmad and Semiromi, Reza Babaei and
   Aminian, Pejman},
Title = {Thermal and carbonation resistance of tunnel concrete: Experimental
   evaluation and hybrid ANN-GPR modeling under fire-CO2
   exposure},
Journal = {CASE STUDIES IN CONSTRUCTION MATERIALS},
Year = {2025},
Volume = {23},
Month = {DEC},
Abstract = {This study investigates the combined effects of high-temperature fire
   exposure and CO2-induced carbonation on the mechanical and durability
   performance of concrete used in urban tunnel infrastructure.
   Experimental results indicated up to a 43.5 \% reduction in compressive
   strength after exposure to 1000 degrees C for 180 min, primarily due to
   thermal degradation and porosity increase. Carbonation depth increased
   by 24.8 \% under the same conditions, attributed to microcracking and
   enhanced CO2 ingress. Microstructural characterization using XRD
   revealed decomposition of Ca(OH)(2) and partial formation of CaCO3,
   confirming mineralogical deterioration. Ultrasonic pulse velocity (UPV)
   measurements showed strong correlation with both strength loss and
   carbonation depth, supporting UPV as a reliable non-destructive
   evaluation method. A hybrid machine learning model combining artificial
   neural networks (ANN) and Gaussian process regression (GPR) was
   developed to predict residual compressive strength and carbonation depth
   based on UPV and exposure parameters. The model achieved high predictive
   accuracy (R-2 > 0.93), offering a robust, data-driven framework for
   rapid structural assessment. These findings provide valuable insights
   into post-fire durability evaluation and support effective maintenance
   strategies in tunnel engineering.},
Type = {Article},
Affiliation = {Ganjali, A (Corresponding Author), Islamic Azad Univ, Dept Civil Engn, Shahrood, Iran.
   Fatemi, Amirhossein; Ganjali, Ahmad; Semiromi, Reza Babaei; Aminian, Pejman, Islamic Azad Univ, Dept Civil Engn, Shahrood, Iran.},
DOI = {10.1016/j.cscm.2025.e05076},
EarlyAccessDate = {JUL 2025},
Article-Number = {e05076},
Keywords = {Fire-exposed concrete; Carbonation; Ultrasonic pulse velocity; ANN-GPR
   model; High temperature; Tunnel durability; Non-destructive evaluation},
Keywords-Plus = {HIGH-STRENGTH CONCRETE; RESIDUAL MECHANICAL-PROPERTIES; HIGH-PERFORMANCE
   CONCRETE; ELEVATED-TEMPERATURES; POLYPROPYLENE FIBERS; COMPRESSIVE
   STRENGTH; BEHAVIOR; DURABILITY},
Author-Email = {Amirhossein.fatemi@iau.ac.ir
   ahmad.ganjali@iau.ac.ir
   Re.babaeisemiromy@iau.ac.ir
   Dr.aminian@iau.ac.ir},
