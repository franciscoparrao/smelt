@article{ WOS:001609678700003,
Author = {Kamarthi, Aparna and Kaliyamoorthy, Baskar},
Title = {Causal inference-informed explainable selective weighted ensemble for
   predicting ultra-high-performance concrete compressive strength},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2025},
Volume = {330},
Number = {C},
Month = {NOV 25},
Abstract = {Accurately predicting the compressive strength of concrete is essential
   for enhancing the structural performance and durability of modern
   infrastructure. To address this need, the present study proposes a novel
   framework tailored for ultra-high-performance concrete (UHPC),
   integrating causal inference via Granger causality analysis, explainable
   selective weighted ensemble learning, and hyperparameter optimization.
   Granger causality is employed to identify statistically significant
   causal relationships among input features, thereby enhancing the model
   ability to prioritize influential variables. A selective weighted
   ensemble of eight machine learning algorithms, including XGBoost,
   CatBoost, and gradient boosting, is developed, with individual model
   weights assigned based on validation performance and optimized using
   GridSearchCV. To ensure model transparency, explainable AI techniques
   offer both global and local interpretations of feature contributions.
   The proposed framework is evaluated on a UHPC dataset comprising 810
   concrete mix samples and achieving high predictive accuracy with an R2
   value of 0.968, a mean absolute error as 4.852, mean squared error of
   47.86, root mean squared error of 6.918, mean absolute percentage error
   of 3.876, Huber loss of 4.384, and root mean squared logarithmic error
   of 0.054. Explainability analysis highlights curing age, fiber content,
   and silica fume as the most influential features. This framework offers
   accurate and interpretable predictions, supporting sustainable and
   optimized concrete mix design.},
Type = {Article},
Affiliation = {Kamarthi, A (Corresponding Author), Natl Inst Technol, Dept Civil Engn, Tiruchirappalli 620015, Tamil Nadu, India.
   Kamarthi, Aparna; Kaliyamoorthy, Baskar, Natl Inst Technol, Dept Civil Engn, Tiruchirappalli 620015, Tamil Nadu, India.},
DOI = {10.1016/j.knosys.2025.114770},
EarlyAccessDate = {OCT 2025},
Article-Number = {114770},
Keywords = {Weighted ensemble model; Explainable AI; Optimisation; Granger
   causality; Ultra-high-performance concrete; Compressive strength},
Author-Email = {aparna.kamarthi@gmail.com},
Number-of-Cited-References = {65},
Times-Cited = {1},
Unique-ID = {WOS:001609678700003},
}

@article{ WOS:001608051700001,
Author = {Zhu, Hai-ming and Du, Zun-feng and Yu, Jian-xing},
Title = {Multi-graphics processing unit simulation of vortex-induced vibration of
   cylindrical structures using immersed boundary lattice Boltzmann method},
Journal = {JOURNAL OF HYDRODYNAMICS},
Year = {2025},
Volume = {37},
Number = {4},
Pages = {639-648},
Month = {AUG},
Abstract = {Vortex-induced vibration (VIV) of cylindrical structures is a critical
   fluid-structure interaction (FSI) phenomenon in ocean engineering.
   Simulating VIV accurately can be computationally expensive. This study
   presents a graphics processing unit (GPU)-accelerated simulation model
   for VIV utilizing the immersed boundary lattice Boltzmann method
   (IB-LBM), aiming to reduce computational costs while preserving
   accuracy. The program is developed using machine learning library JAX,
   which enables parallelism on GPU and multi-GPU platforms. The model
   incorporates multi-GPU parallelization and multi-block grid refinement
   strategies to enhance computational efficiency. Validation against
   existing high-fidelity simulation data demonstrates good agreement.
   Performance tests show significant speed-ups with GPU acceleration
   compared to traditional CPU-based approaches. These results underscore
   the potential of the developed simulator as an efficient and reliable
   tool for in-depth parametric studies and practical engineering analysis
   of VIV, facilitating more rapid design iterations and risk assessments
   for offshore structures.},
Type = {Article},
Affiliation = {Du, ZF (Corresponding Author), Tianjin Univ, Sch Civil Engn, State Key Lab Hydraul Engn Intelligent Construct \&, Tianjin 300350, Peoples R China.
   Zhu, Hai-ming; Du, Zun-feng; Yu, Jian-xing, Tianjin Univ, Sch Civil Engn, State Key Lab Hydraul Engn Intelligent Construct \&, Tianjin 300350, Peoples R China.
