   Hosseini, Seyed Morteza, Aalborg Univ, Dept Architecture Design \& Media Technol, Aalborg, Denmark.
   Zamani, Zahra, Univ Tehran, Coll Fine Art, Dept Arch Technol, Tehran, Iran.
   Bazazzadeh, Hassan, Swiss Fed Labs Mat Sci \& Technol Empa, Urban Energy Syst Lab, Dubendorf, Switzerland.},
DOI = {10.1016/j.csite.2025.107108},
EarlyAccessDate = {OCT 2025},
