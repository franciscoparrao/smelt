@article{ WOS:001687212900002,
Author = {Li, Tiemei and Cao, Jinbo and Wang, Yao and Chen, Hui and Gu, Shaobin
   and Li, Xinzhong},
Title = {AIEgen-regulated metal-organic framework enabled machine
   learning-assisted lateral flow immunoassay sensor for intelligent
   diagnosis of P. aeruginosa},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2026},
Volume = {530},
Month = {FEB 15},
Abstract = {Lateral flow immunoassay (LFIA), as a portable point-of-care testing
   (POCT) platform, shows significant potential for applications in
   clinical diagnostics. However, conventional LFIA sensors typically
   suffer from low sensitivity, which greatly limits their application in
   trace analyte detection. In this study, we developed a machine learning
   (ML)-assisted LFIA platform based on metal-AIEgen frameworks (MAFs) for
   ultrasensitive and intelligent detection of Pseudomonas aeruginosa (P.
   aeruginosa). By regulating the carboxyl density and arm rigidity of the
   AIE ligand, the synthesized MAF-1 exhibited outstanding luminescent
   performance and excellent biocompatibility. After integrating it into
   the LFIA system, the resulting MAF-1-LFIA achieved a detection limit
   (LOD) of 10 CFU/mL, with sensitivity enhanced by approximately 100-fold,
   100-fold, and 10-fold compared with gold nanoparticles-based LFIA
   (AuNPs-LFIA), time-resolved fluorescent microsphere-based LFIA
   (TRFM-LFIA) and Enzyme-Linked Immunosorbent Assay (ELISA), respectively.
   In addition, the MAF-1-LFIA has been successfully applied to the
   detection of P. aeruginosa in tap water and milk samples, with a
   recovery rate ranging from 98.23\% to 106.82\% and a relative standard
   deviation (RSD) of 3.11\% to 8.34\%, demonstrating excellent accuracy
   and practicality. Furthermore, the incorporation of ML algorithms
   enabled efficient classification and precise quantification of the
   detection signals, with a classification accuracy of 100\% and a
   concentration prediction accuracy of 99.04\%. In summary, this work
   proposes a promising strategy that integrates MAFs materials with
   artificial intelligence for high-performance detection in complex
   biological matrices, paving the way for the development of
   next-generation intelligent POCT biosensors.},
