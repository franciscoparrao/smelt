@article{ WOS:001705406100001,
Author = {Huang, Long and Zhang, Haoming and Zeng, Wen and Zhou, Qu},
Title = {Hetero In2O3@Co3O4 derived from MOF-on-MOF conjugate combined
   synergistically with exponential-trigonometric optimization-support
   vector regression enables high-precision quantitative detection of H2S},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2026},
Volume = {532},
Month = {MAR 15},
Abstract = {Due to the widespread application of hydrogen sulfide (H2S) in
   industries such as chemical, medical, and food, highly selective
   detection of H2S at low temperatures is of great significance.
   Chemiresistive gas sensors based on metal-oxide-semiconductor (MOS) have
   been widely used for detecting various gases; however, due to the low
   efficiency of electron transfer in individual MOSs, their gas-sensing
   performance is far from satisfactory. Herein, a porous bimetallic oxide
   In2O3@Co3O4 heterojunction has been obtained by elaborately constructing
   metal-organic framework (MOF)-on-MOF conjugate (MIL-68@ZIF-67). The
   developed In2O3@Co3O4 sensor achieves great sensing performances for H2S
   (100 ppm), exhibiting outstanding selectivity, high sensitivity (110.2),
   and rapid recovery speed (47 s) at a low working temperature (100
   degrees C), which are significantly better than that of pristine In2O3
   and Co3O4. The large mesoporous architecture, rich active sites
   generated by composite Co3O4, and formation of type II charge transfer
   pathway are primarily accountable for the improved H2S-sensing
   capabilities. Moreover, density functional theory (DFT) calculations
   show that In2O3@Co3O4 has a higher adsorption energy for H2S compared to
   other comparative gases. The optimal sensor demonstrates high-accuracy
   (R2 = 0.9907) H2S concentration prediction capability driven by Machine
   Learning. The ability to predict H2S concentration by combining
   high-performance sensor with regression prediction model provides a
   feasible approach for the next generation of devices in environmental
   monitoring and other related fields.},
Type = {Article},
Affiliation = {Zhou, Q (Corresponding Author), Southwest Univ, Coll Engn \& Technol, Chongqing 400715, Peoples R China.
