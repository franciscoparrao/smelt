@article{ WOS:001719443100001,
Author = {Chen, Yanbin and Xiao, Huahua},
Title = {Physics-constrained machine learning for the accelerated design of
   hydrogen explosion suppression materials},
Journal = {PROCESS SAFETY AND ENVIRONMENTAL PROTECTION},
Year = {2026},
Volume = {210},
Month = {APR 1},
Abstract = {The inherent explosion risk of hydrogen presents a significant challenge
   to its safe use, and developing effective suppression materials is often
   hindered by inefficient, trial-and-error research methods. To accelerate
   material discovery, this study introduces and employs a
   physics-constrained machine learning (PCML) framework. This framework
   utilizes a database of 45 materials and a set of physically derived
   features to train a highly accurate prediction model with a coefficient
   of determination (R2) above 0.93. The model is then combined with a
   multiobjective optimization algorithm to enable the inverse design of
   new hydrogen explosion suppression materials. Guided by this approach, a
   new zeolite-phosphate-urea (ZPU) composite was designed and produced.
   Experimental results confirmed that the ZPU material performs better at
   explosion suppression compared to commercial ABC and BC dry powders,
   with inhibition rates of 19.9\% for maximum explosion pressure and
   20.1\% for the pressure rise rate. Additionally, multiscale simulations
   uncovered the underlying suppression mechanism, revealing a unique
   ``gas-solid synergistic{''} process: gas-phase species from phosphate
   and urea pyrolysis scavenge free radicals through homogeneous chemical
   reactions. Meanwhile, the zeolite framework provides a microporous
   surface for effective heterogeneous capture and quenching of active
   radicals. This work introduces a new data-driven approach for innovative
   and efficient research and development of high-performance safety
   materials.},
Type = {Article},
Affiliation = {Xiao, HH (Corresponding Author), Univ Sci \& Technol China, West Campus,443 Huangshan Rd, Hefei, Anhui, Peoples R China.
   Chen, Yanbin; Xiao, Huahua, Univ Sci \& Technol China, State Key Lab Fire Sci, Hefei 230027, Anhui, Peoples R China.},
DOI = {10.1016/j.psep.2026.108699},
Article-Number = {108699},
Keywords = {Hydrogen safety; Explosion suppression; Machine learning; Materials
   discovery; Inverse design},
Keywords-Plus = {FLAME PROPAGATION; DIFFERENTIAL EVOLUTION; PREDICTION MODEL; INHIBITION;
   OPTIMIZATION; COMBUSTION; TRANSITION; ADSORPTION; SIMULATION; DETONATION},
Author-Email = {xiaoh@ustc.edu.cn},
Number-of-Cited-References = {99},
