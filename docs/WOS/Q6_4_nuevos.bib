   Xiao, Chengyu; Li, Jing; Hua, Wansu; Zhang, Yifan; Zhou, Han, Shanghai Jiao Tong Univ, Zhangjiang Inst Adv Study, Future Mat Innovat Ctr, Shanghai 201203, Peoples R China.},
DOI = {10.1039/d5cp01823d},
EarlyAccessDate = {JUL 2025},
Author-Email = {hanzhou\_81@sjtu.edu.cn},
Number-of-Cited-References = {56},
Times-Cited = {1},
Unique-ID = {WOS:001539108500001},
}

@article{ WOS:001555358700039,
Author = {Bezik, Cody T. and Akram, Mohammad Basit and Bowser, Blake and Detwiler,
   Kaitlin N. and Hilmas, Ashley M. and Balasubramanian, Ganesh and
   Varshney, Vikas},
Title = {Predicting ultimate tensile strength of SiC/SiC mini-composites via
   machine learning},
Journal = {CERAMICS INTERNATIONAL},
Year = {2025},
Volume = {51},
Number = {21, A},
Pages = {33607-33618},
Month = {SEP},
Abstract = {Silicon carbide fiber-reinforced SiC matrix (SiC/SiC) ceramic matrix
   composites are promising structural materials for aerospace and nuclear
   applications. Designing such materials requires understanding the
   relationships between composition, processing, and mechanical
   performance. This work presents a data-driven approach using machine
   learning to predict the ultimate tensile strength (UTS) of SiC/SiC
   mini-composites. A curated dataset of 131 mini-composites, extracted
   from the literature, encompassing compositional information, processing
   parameters, and mechanical properties, was assembled and used to train
   and test machine learning models. Missing data, arising from
   inconsistencies among the sources, were addressed using k-nearest
   neighbors imputation. The impact of different data sampling strategies -
   using all data, selectively undersampling to remove a sparse,
   high-strength region, and balancing via SMOGN oversampling - was
   evaluated. Three decision tree ensemble models (Random Forest, XGBoost,
   and LightGBM) were trained and evaluated. The results demonstrate the
   utility of machine learning for predicting UTS. The XGBoost model,
   trained on oversampled data, exhibited the best performance, with a mean
   absolute error of 60.1 MPa and a mean absolute percentage error of
   8.8\%. Feature importance analysis identified key determinants of UTS,
   including other tensile properties, fiber properties, interfacial
   properties, and the coefficients of thermal expansion of the materials.
   The trained model could be integrated into iterative inverse design
   frameworks for the rapid optimization and discovery of high-performance
   SiC/SiC mini-composites, reducing the experimental burden in future
   materials design.},
Type = {Article},
Affiliation = {Varshney, V (Corresponding Author), Wright Patterson Air Force Base, Mat \& Mfg Directorate, Air Force Res Lab, Dayton, OH 45433 USA.
   Bezik, Cody T., Natl Res Council Res Associate Program Fellow, Washington, DC USA.
   Bezik, Cody T.; Detwiler, Kaitlin N.; Hilmas, Ashley M.; Varshney, Vikas, Wright Patterson Air Force Base, Mat \& Mfg Directorate, Air Force Res Lab, Dayton, OH 45433 USA.
   Akram, Mohammad Basit; Balasubramanian, Ganesh, Univ New Haven, Dept Mech \& Ind Engn, West Haven, CT 06516 USA.
   Bowser, Blake, Univ Akron, Mech Engn Dept, Akron, OH 44325 USA.},
DOI = {10.1016/j.ceramint.2025.05.091},
EarlyAccessDate = {JUL 2025},
Keywords = {Composites; Nanocomposites; Mechanical properties; Strength; SiC},
Keywords-Plus = {MECHANICAL-PROPERTIES; FRACTURE-BEHAVIOR; MATRIX COMPOSITES; HI-NICALON;
   DAMAGE; MINICOMPOSITES; IMPUTATION; ROOM},
Author-Email = {vikas.varshney.2@us.af.mil},
