@article{ WOS:001632681600004,
Author = {Qin, Wenjie and Zhong, Heng and Hu, Jingping and Luo, Wei and Shao, Zhe
   and Hou, Huijie and Liu, Zhenzhen and Zhang, Xiaotong and Liang, Sha and
   Yang, Jiakuan},
Title = {Explainable AutoML-driven surface water quality classification with key
   indicators identification},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {665},
Month = {FEB},
Abstract = {Surface water quality monitoring and classification face dual
   challenges: prohibitive costs of comprehensive indicators monitoring and
   the labor-intensive process of traditional machine learning (ML)
   implementation, which jointly constrain the development of efficient
   water quality assessment systems. This study presents an automated and
   interpretable framework: Auto-sklearn automates the machine learning
   workflow to address model selection complexity, while SHAP analysis
   quantifies feature contributions to reduce water quality indicator
   requirements. Using monitoring data from major river basins of China, we
   evaluated Auto-sklearn against conventional ML algorithms and modern
   ensemble methods. Auto-sklearn achieved the highest mean performance
   (Weighted F1: 0.9633 +/- 0.0027) via an optimized ensemble. Crucially,
   this high performance proved to be robust and generalizable, as the
   framework maintained its superiority across rigorous temporal and
   spatial validation schemes. Through Kernel SHAP analysis, we identified
   CODMn, TP, and DO as the key indicators. A 3indicator Auto-sklearn model
   achieved a high Weighted F1 (0.9205 +/- 0.0097) and outperformed the
   rule-based baseline, with higher F1-scores across all classes and an
   18.9 \% relative improvement for Class WV water. This suggests that
   monitoring costs can be substantially reduced while simultaneously
   improving assessment reliability. Further regional analysis revealed
   spatial variations, with most basins aligning with the nationwide set,
   but the Song-Liao and Yellow River Basins also requiring NH3-N
   monitoring. This framework provides a practical, cost-effective solution
   for water environment management, especially in developing regions.},
Type = {Article},
Affiliation = {Hu, JP (Corresponding Author), Huazhong Univ Sci \& Technol HUST, Sch Environm Sci \& Engn, Hubei Key Lab Multimedia Pollut Cooperat Control Y, 1037 Luoyu Rd, Wuhan 430074, Peoples R China.
