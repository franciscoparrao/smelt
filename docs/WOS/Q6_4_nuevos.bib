@article{ WOS:001522799100001,
Author = {Akarsu, Oguzhan and Aydin, Abdulkadir Cueneyt},
Title = {Optimized machine learning models for predicting ultra-high-performance
   concrete compressive strength: a hyperopt-based approach},
Journal = {MULTISCALE AND MULTIDISCIPLINARY MODELING EXPERIMENTS AND DESIGN},
Year = {2025},
Volume = {8},
Number = {8},
Month = {JUL 5},
Abstract = {Predicting Ultra-High-Performance Concrete (UHPC) compressive strength
   using advanced machine learning (ML) techniques represents a paradigm
   shift in material science. This study investigates the application of
   nine ML models, including CatBoost, Extra Trees Regressor, and XGBoost,
   optimized through the Hyperopt framework to enhance predictive accuracy.
   A comprehensive dataset comprising 810 observations was employed, and
   critical performance metrics such as R2, RMSE, a20-index, Nash-Sutcliffe
   Efficiency (NSE), and sMAPE(Symmetric Mean Absolute Percentage Error)
   were analyzed to assess model efficacy. The CatBoost model, optimized
   using the Hyperopt framework, demonstrated superior predictive
   performance, achieving an R2 of 0.9742, RMSE of 6.20 MPa, a20-index of
   1.0, NSE of 0.9742, and sMAPE of 3.6445 on the test set. Feature
   interpretability was further advanced using SHAP and Partial Dependence
   Plots (PDP), which identified Age, Fiber Content (Fi), and
   Cement-to-Water Ratio (C/W) as the most influential predictors. These
   tools elucidated complex nonlinear relationships and provided actionable
   insights for optimizing UHPC mix designs. This research highlights the
   transformative potential of ML in reducing experimental overhead,
   promoting sustainable construction practices, and enhancing material
   performance. While the study focused on steel-fiber-reinforced UHPC
   under controlled conditions, future research should explore diverse
   fiber types, environmental factors, and dynamic material behaviors. By
   advancing the integration of ML with experimental methodologies, this
   study paves the way for innovative solutions in high-performance
   concrete applications.},
Type = {Article},
Affiliation = {Akarsu, O (Corresponding Author), Ataturk Univ, Engn Fac, Dept Civil Engn, TR-25030 Erzurum, Turkiye.
   Akarsu, Oguzhan; Aydin, Abdulkadir Cueneyt, Ataturk Univ, Engn Fac, Dept Civil Engn, TR-25030 Erzurum, Turkiye.},
DOI = {10.1007/s41939-025-00957-2},
Article-Number = {371},
Keywords = {CatBoost; Machine learning; Hyperparameter optimization; Concrete
   mixture; SHAP; Partial dependence plots},
Keywords-Plus = {RANDOM FORESTS; TREES},
Author-Email = {oguzhnakarsu@gmail.com},
Number-of-Cited-References = {94},
Times-Cited = {4},
Unique-ID = {WOS:001522799100001},
}

@article{ WOS:001528443300027,
Author = {Xiao, Mingjun},
Title = {Research progress of prussian blue analogues for cathode of sodium ion
   batteries},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2025},
Volume = {1036},
Month = {JUL 20},
Abstract = {The development of fast-charging sodium-ion batteries (SIBs) has become
   a key research focus in energy storage due to their potential for
   cost-effective and sustainable energy solutions. Among various cathode
   materials, prussian blue analogues (PBAs) have attracted significant
   attention owing to their unique open framework structure, high
   theoretical capacity, and low production cost. This paper provides a
   comprehensive overview of the crystal structure, electrochemical
   properties, and application progress of PBAs in SIBs. To address their
   inherent limitations, various modification strategies are systematically
   discussed, including morphological control, structural optimization,
   elemental doping, composite material design, and electrolyte
   optimization. Furthermore, the critical challenges hindering the
   practical application of PBAs are analyzed, such as structural
   instability during cycling, low electronic conductivity, and interfacial
   side reactions. Future research directions are proposed, emphasizing the
   need for advanced synthesis techniques, interface engineering, in-situ
   characterization, computational chemistry, machine learning, and
   full-cell performance evaluation. By summarizing recent advances and
   identifying key challenges, this review aims to provide valuable
   insights and guidance for the rational design of high performance
   PBA-based cathode materials, ultimately promoting the commercialization
   of SIBs for large-scale energy storage applications.},
Type = {Review},
Affiliation = {Xiao, MJ (Corresponding Author), Lanzhou Univ Technol, Sch Mat Sci \& Engn, State Key Lab Adv Proc \& Recycling Nonferrous Met, Lanzhou 730050, Peoples R China.
