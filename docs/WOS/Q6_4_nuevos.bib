@article{ WOS:001657913400001,
Author = {Nguyen, Xuanque and Nguyen, Ngoc Viet and Viet, Chien Nguyen and Luong,
   Van Su and Pham, Quang Vuong and Le, Viet Thong and Nguyen, Van Hieu and
   Le, Minhhuy},
Title = {High-fidelity embedded gas sensing: a unified deep learning framework
   for simultaneous identification and quantification},
Journal = {MEASUREMENT SCIENCE AND TECHNOLOGY},
Year = {2026},
Volume = {37},
Number = {3},
Month = {JAN 23},
Abstract = {Electronic nose systems are a transformative technology, enabling
   low-cost, real-time gas analysis for critical applications in
   environmental monitoring, industrial safety, and medical diagnostics.
   However, their practical performance is fundamentally limited by the
   computational challenge of analyzing time-series data from their sensor
   arrays. Conventional machine learning (ML) pipelines rely on lossy
   feature engineering and employ separate, inefficient models for gas
   classification and concentration regression, a methodology that
   fundamentally limits predictive accuracy. This paper presents a unified
   multitask deep learning model that solves these problems through three
   key innovations. First, the model learns features directly from the
   complete, raw sensor time-series using a convolutional neural network,
   avoiding information loss from pre-processing. Second, a novel attention
   mechanism links the classification and regression tasks, allowing the
   model to use the identified gas type to improve its concentration
   estimate. Third, a custom loss function was developed to ensure high
   accuracy across a wide range of gas concentrations, a critical challenge
   in chemical sensing. Using 5-fold cross-validation, the model achieved
   100\% accuracy in gas classification and a mean absolute percentage
   error (MAPE) of 6.61\% for concentration regression, results that
   significantly outperform classical ML benchmarks. We also demonstrated
   the model's efficiency by deploying it on 10 different STM32
   microcontrollers, confirming its suitability for real-time embedded
   applications. This work provides a robust framework for developing
   high-performance, AI-based chemical sensors and offers a foundational
   methodology for future analysis of complex gas mixtures. The source code
   and data are provided in this GitHub repo:
   https://github.com/quenx-rd/gas\_identifier\_public.},
Type = {Article},
Affiliation = {Le, M (Corresponding Author), Phenikaa Univ, Fac Elect \& Elect Engn, Phenikaa Sch Engn, Hanoi, Vietnam.
   Nguyen, Xuanque, Phenikaa Univ, Fac Informat Syst, Phenikaa Sch Comp, Hanoi, Vietnam.
   Nguyen, Ngoc Viet; Viet, Chien Nguyen; Luong, Van Su; Pham, Quang Vuong; Le, Viet Thong; Nguyen, Van Hieu; Le, Minhhuy, Phenikaa Univ, Fac Elect \& Elect Engn, Phenikaa Sch Engn, Hanoi, Vietnam.},
DOI = {10.1088/1361-6501/ae3252},
Article-Number = {035109},
Keywords = {electronic nose; multitask deep learning; cross-validation; custom loss
   function; tiny machine learning},
Keywords-Plus = {ELECTRONIC-NOSE; CLASSIFICATION},
Author-Email = {huy.leminh@phenikaa-uni.edu.vn},
Number-of-Cited-References = {47},
Times-Cited = {0},
Unique-ID = {WOS:001657913400001},
}

@article{ WOS:001683940900001,
Author = {Silva, Leticia and Floriano, Alan and Valadao, Carlos and Caldeira,
   Eliete and Krishnan, Sridhar and Bastos Filho, Teodiano},
Title = {Comparing compressive sensing and downsampling for COVID-19 diagnosis
   from cough and speech audio signals},
Journal = {FRONTIERS IN SIGNAL PROCESSING},
Year = {2026},
Volume = {5},
Month = {JAN 22},
Abstract = {Introduction Since the onset of the COVID-19 pandemic, extensive
   research has focused on developing non-invasive diagnostic approaches of
   respiratory syndrome using biomedical signals, particularly cough and
   speech audio. Time-frequency representations combined with Machine
   Learning models have shown potential in identifying acoustic biomarkers
   associated with respiratory conditions. Although many existing
   approaches demonstrate high performance, their use may be limited in
   resource-constrained environments due to processing or implementation
   demands.Methods In this study, we propose an end-to-end approach for
   COVID-19 inference based on compressed time-domain audio signals. The
   method combines temporal signal compression strategies - Downsampling
   (DS) and Compressive Sensing (CS) - with a Convolutional Neural Network
   (CNN) trained directly on the waveforms. This design eliminates the need
   for handcrafted features or spectrograms, aiming to reduce computational
   complexity while preserving classification performance.Results To
   evaluate the proposed structure, we used data from two open-access
   datasets, one for coughing and one for speech. Experimental results,
   assessed using accuracy and F1-score metrics, indicate that CS
   outperformed DS in most scenarios, particularly under high compression
   rates (e.g., 200 Hz and 100 Hz).Discussion These findings support the
   use of compressed audio-based classification in real-world embedded and
   mobile health systems, where computational efficiency is essential.},
Type = {Article},
Affiliation = {Silva, L (Corresponding Author), Univ Fed Espirito Santo, Dept Elect Engn, Postgrad Program Elect Engn, Vitoria, Brazil.
   Silva, Leticia; Caldeira, Eliete; Bastos Filho, Teodiano, Univ Fed Espirito Santo, Dept Elect Engn, Postgrad Program Elect Engn, Vitoria, Brazil.
   Floriano, Alan, Fed Inst Parana IFPR, Telemaco Borba, Brazil.
   Valadao, Carlos, Fed Inst Espirito Santo IFES, Linhares, Brazil.
   Krishnan, Sridhar, Toronto Metropolitan Univ, Dept Elect Comp \& Biomed Engn, Signal Anal Res Grp, Toronto, ON, Canada.},
DOI = {10.3389/frsip.2025.1700044},
Article-Number = {1700044},
Keywords = {COVID-19; compressive sensing; downsampling; CNN; cough; speech;
   embedded health systems},
Author-Email = {araujos.leticia@gmail.com},
Number-of-Cited-References = {58},
Times-Cited = {0},
Unique-ID = {WOS:001683940900001},
}

@article{ WOS:001676520200001,
Author = {Duval, Alexis and Robin, Eric and Houizot, Patrick and Rouxel, Tanguy},
Title = {Inverse design of high-performance glasses through an encoder-decoder
   machine learning approach toward materials discovery: Application to
   oxynitride glasses},
Journal = {ACTA MATERIALIA},
Year = {2026},
Volume = {306},
Month = {MAR 1},
Abstract = {Machine learning approaches have shown remarkable potential in
   elucidating the complex, nonlinear relationships between compositional
   effects, structural configurations, and macroscopic properties in
   materials science. Nevertheless, their application within glass science
   for guiding the inverse design of formulations with properties tailored
   for high-performance applications remains limited. In the present work,
   we report the implementation of an autoencoder within glass science. To
   address scenarios where the dimensionality of the input exceeds that of
   the output, a case study was selected wherein 34-dimensional
   formulations were projected into a 4-dimensional latent space through an
   autoencoder's encoder. This strategy thereby enabled the prediction of
   formulations (with up to 34 different elements) from four material
   parameters (Young's modulus, hardness, glass transition temperature, and
   specific mass), whereby an artificial neural network (ANN) links these
   parameters to the latent representation, and the decoder subsequently
   reconstructs the formulation in its original 34-dimensional form. Two
   promising candidate compositions generated through this framework, upon
   synthesis and experimental characterization, yield glasses that rank
   among the stiffest, hardest yet light large-scale inorganic,
   non-metallic systems amongst reported literature, exhibiting a unique
   combination of high Young's modulus (E = 155 GPa) and hardness (H = 12.2
   GPa) at a comparatively low specific mass (rho = 3.62 g.cm(-3)). These
   findings emphasize the potential of machine learning methodologies for
   the systematic quantification and subsequent rationalization of
   composition-property trends based on physicochemical descriptors,
   offering novel insights both within and across chemical systems -
   demonstrated here for oxynitride glasses, where the processing- and
   content-dependent incidence of nitrogen is revealed.},
Type = {Article},
Affiliation = {Duval, A (Corresponding Author), Univ Rennes, Inst Phys Rennes, CNRS, UMR 6251, F-35000 Rennes, France.
   Duval, A (Corresponding Author), Friedrich Schiller Univ Jena, Otto Schott Inst Mat Res, Lessingstr 14, D-07743 Jena, Germany.
   Duval, Alexis; Robin, Eric; Houizot, Patrick; Rouxel, Tanguy, Univ Rennes, Inst Phys Rennes, CNRS, UMR 6251, F-35000 Rennes, France.
   Duval, Alexis, Friedrich Schiller Univ Jena, Otto Schott Inst Mat Res, Lessingstr 14, D-07743 Jena, Germany.},
DOI = {10.1016/j.actamat.2025.121882},
EarlyAccessDate = {JAN 2026},
Article-Number = {121882},
Keywords = {Machine learning; Materials discovery; Glasses; Oxynitrides; Mechanical
   properties},
Keywords-Plus = {AL-O-N; ALUMINOSILICATE GLASSES; MECHANICAL-PROPERTIES; NITROGEN
   INCORPORATION; RHEOLOGICAL PROPERTIES; FRACTURE-TOUGHNESS;
   ELASTIC-MODULUS; SIALON GLASSES; PART I; MG},
Author-Email = {alexis.duval@uni-jena.de},
Number-of-Cited-References = {167},
Times-Cited = {0},
