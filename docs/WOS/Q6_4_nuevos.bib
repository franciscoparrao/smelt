   Tian, Xinni, Suzhou Ind Pk Monash Res Inst Sci \& Technol, Suzhou, Peoples R China.},
DOI = {10.1080/17452759.2025.2549366},
Article-Number = {e2549366},
Keywords = {Alloy design; additive manufacturing; machine learning; high
