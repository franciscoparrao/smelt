   Qureshi, Muhammad Zeeshan, Univ Engn \& Technol, Dept Civil Engn, Taxila, Pakistan.
   Kahla, Nabil Ben, King Khalid Univ, Coll Engn, Dept Civil Engn, POB 394, Abha 61411, Saudi Arabia.
   Kahla, Nabil Ben, King Khalid Univ, Ctr Engn \& Technol Innovat, Abha 61421, Saudi Arabia.
   Ghazouani, Nejib, Northern Border Univ, Min Res Ctr, Ar Ar 73213, Saudi Arabia.},
DOI = {10.1038/s41598-025-25592-2},
