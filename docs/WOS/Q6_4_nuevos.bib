@article{ WOS:001627848500001,
Author = {Patel, Rutu and Chaudhary, Mayankkumar L. and Gupta, Ram K.},
Title = {Data-driven and computational insights into borophene: Integrating
   machine learning with DFT and AI},
Journal = {COORDINATION CHEMISTRY REVIEWS},
Year = {2026},
Volume = {550},
Month = {MAR 1},
Abstract = {Borophene, a monoelemental two-dimensional (2D) boron allotrope, has
   emerged as a groundbreaking material with extraordinary potential across
   next-generation energy applications. Distinguished by its polymorphic
   structures, metallic conductivity, and unparalleled mechanical and
   electronic anisotropy, borophene has demonstrated remarkable performance
   as an electrode in lithium/sodium-ion batteries, supercapacitors, and
   electrocatalytic systems. This review highlights recent breakthroughs in
   borophene research enabled by the synergistic integration of density
   functional theory (DFT), artificial intelligence (AI), and machine
   learning (ML). Advanced computational frameworks, including
   machine-learned interatomic potentials (MLIPs) and AI-driven
   high-throughput screening (HTS), accelerate the discovery and
   optimization of borophene-based materials beyond traditional
   trial-and-error paradigms. By bridging atomic-scale simulations with
   data-driven prediction, this review reveals how ML-DFT approaches are
   unlocking previously inaccessible design spaces, identifying novel
   borophene polymorphs, and guiding experimental validation. A
   forward-looking perspective is provided on how these intelligent
   computational tools are redefining the landscape of materials
   innovation, with borophene positioned at the frontier of
   high-performance, AI-accelerated energy research.},
Type = {Review},
