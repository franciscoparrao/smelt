@article{ WOS:001598204900001,
Author = {Li, Shukai and Chen, Meng and Wei, Mingjie and Cao, Jinji and Xu,
   Zhaoqin and Wang, Jingtao and Wang, Yong},
Title = {Machine learning on solvent transport through covalent organic
   frameworks enabled by high-throughput simulations},
Journal = {JOURNAL OF MEMBRANE SCIENCE},
Year = {2026},
Volume = {738},
Number = {A},
Month = {JAN},
Abstract = {A fundamental barrier in advancing organic solvent nanofiltration lies
   in the limited understanding of how solvent-membrane interactions
   dictate transport and selectivity. This work pioneers the integration of
   high-throughput simulations and machine learning to fundamentally
   uncover mass transfer mechanisms and establish transformative design
   principles. A previously unknown, pore-size-dependent effect of membrane
   hydrophilicity: reducing hydrophilicity dramatically boosts flux in
   large-pore COFs (>15 \& Aring;) but has negligible impact in small-pore
   ones (<11 \& Aring;). Furthermore, we identify the novel phenomenon of
   ``hydrophobic channels{''} by polar protic solvents, significantly
   reducing membrane interactions and altering selectivity. A strategy for
   separating apolar solvents from other types of solvents is also
   discovered as enhancing membrane hydrophilicity (e.g., via -SO3H
   grafting) selectively suppresses other solvent fluxes, boosting apolar
   solvent selectivity. Machine learning robustly validates these
   mechanisms, and confirms D/weight as the dominant solvent descriptor.
   This work provides mechanistic insights, fundamentally shifting the
   paradigm for designing high-performance COF membranes for precise
   organic solvent separation.},
Type = {Article},
Affiliation = {Wei, MJ; Wang, Y (Corresponding Author), Nanjing Tech Univ, Key Lab Funct Polymers Sustainabil Jiangsu, Nanjing 211816, Jiangsu, Peoples R China.
