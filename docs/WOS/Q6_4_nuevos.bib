@article{ WOS:001687661000007,
Author = {Rawat, Keshav Singh and Pandey, Gaurav and Sharma, Tarun},
Title = {Mental health-aware sentiment analysis using a hybrid quantum-classical
   approach},
Journal = {JOURNAL OF SUPERCOMPUTING},
Year = {2026},
Volume = {82},
Number = {3},
Month = {FEB 11},
Abstract = {Social media offers a real-time opportunity to examine human emotions,
   behaviors, and mental health as it becomes more and more integrated into
   daily life. These platforms are rich sources of public opinions and
   expressions that provide insightful information about psychological
   health. Such data have been interpreted using traditional sentiment
   analysis. However, it frequently fails to identify subtle emotional cues
   that are important for evaluating mental health. In order to improve
   sentiment analysis for mental health detection using social media
   datasets, this study investigates a novel integration of Quantum Natural
   Language Processing (QNLP). The study proposes a hybrid
   quantum-classical framework for binary sentiment classification of
   tweets that incorporates a custom quantum layer into an LSTM network. To
   enhance the feature representation, the quantum layer employs
   variational quantum circuits with rotational and entanglement gates. The
   final classification is achieved by concatenating the results with
   classical LSTM outputs. In addition, we introduced a recency-aware
   temporal weighting mechanism to dynamically monitor mental health of
   users. Our model offers improved feature entanglement capabilities while
   achieving competitive performance (validation accuracy of 0.7707) when
   compared to a classical LSTM baseline (0.7775) on the Sentiment140
   dataset. This work illustrates the potential of quantum machine learning
   for scalable, real-time psychological analysis by mapping weighted
   sentiment scores to inferred mental health states. The suggested
   framework focuses on large-scale, real-time social media streams, where
   repeated quantum circuit simulations and training and inference over
   millions of temporally evolving textual instances require GPU
   acceleration, parallel execution, and high-performance computing (HPC)
   resources for practical deployment.},
Type = {Article},
Affiliation = {Rawat, KS (Corresponding Author), Cent Univ Haryana, Dept Comp Sci \& Informat Technol, Mahendergarh, India.
   Rawat, Keshav Singh; Pandey, Gaurav; Sharma, Tarun, Cent Univ Haryana, Dept Comp Sci \& Informat Technol, Mahendergarh, India.},
DOI = {10.1007/s11227-026-08281-3},
Article-Number = {154},
Keywords = {Mental health assessment; Sentiment analysis; Natural language
   processing},
Author-Email = {keshav@cuh.ac.in},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001687661000007},
}

@article{ WOS:001691851300002,
Author = {Song, Cancan and Zhang, Zhenlei and Gao, Pengfei and Li, Kaikai and
   Chen, Yuqiu and Xu, Quan and Gani, Rafiqul and Zhang, Xiangping},
Title = {Multiple ensemble graph neural networks for the high-throughput
   screening of ionic liquids for carbon capture: Modeling study and
   experimental validation},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2026},
Volume = {531},
Month = {MAR 1},
Abstract = {The escalating need for efficient carbon dioxide (CO2) capture has
   positioned ionic liquids (ILs) as promising candidates due to their
   tunable structures and high CO2 affinity. However, systematic strategies
   that integrate machine learning (ML) predictions with experimental
   validation remain limited, and the prediction accuracy and reliability
   of single ML methods for new ILs needs to be improved. In this study, we
   introduced four ensemble frameworks that strategically integrates five
   classical graph neural networks (GNNs), capitalizing on their
   complementary strengths to effectively mitigate the inherent limitations
   of single-model approaches. When predicting the CO2 absorption capacity
   and viscosity of novel ILs, the ensemble frameworks generally
   outperformed traditional ML methods, with the optimal ensemble model
   achieving R-2 values of 0.9258 and 0.9250, respectively. To enable
   high-throughput screening, we generated a virtual library of 7616 ILs
   via pairwise combination of 112 cations and 68 anions, and established
   multi-dimensional criteria (CO2 absorption mole fraction >0.1, viscosity
   <100 mPa \& centerdot;s at 40 degrees C and 101.325 kPa, SAScore <3.5)
   to select ILs balancing performance and synthetic feasibility. Finally,
   we screened 176 new high-performance candidates and validated four ILs
   experimentally, with close consistency between predicted and
   experimental properties (relative deviations: 4.21\%, 8.85\%, 18.32\%
   and 16.14\%, respectively). The framework accelerates the design of ILs
   with exceptional CO2 absorption capacity and reduced viscosity, thereby
   establishing a generalizable and interpretable ensemble ML approach for
   molecular materials discovery.},
