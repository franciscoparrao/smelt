   Glowacki, Gerard; Maruyama, Yoshihiro, Nagoya Univ, Sch Informat, Nagoya, Aichi, Japan.},
DOI = {10.1007/978-3-032-00686-8\_1},
Keywords = {Deep Learning Architecture; Neural Circuit Diagram; Category Theory;
   Spherical Attention; Gene Regulatory Network},
Author-Email = {vtabbott@mit.edu
