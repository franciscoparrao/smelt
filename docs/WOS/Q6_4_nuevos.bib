   Ibrahim, Shehu Adam, Binyaminu Usman Polytech, Dept Sci Lab Technol, Hadejia 731101, Nigeria.
   Li, Yang, Xi An Jiao Tong Univ, Sch Microelect, Xian 710049, Peoples R China.},
DOI = {10.1021/acs.jpcc.5c07217},
EarlyAccessDate = {MAR 2026},
Keywords-Plus = {SHORT-RANGE ORDER; DIFFUSION},
Author-Email = {tan.shi0122@xjtu.edu.cn
   suzhengxiong@xjtu.edu.cn
   chenylu@xjtu.edu.cn},
Number-of-Cited-References = {50},
