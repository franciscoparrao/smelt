@article{ WOS:001710684200001,
Author = {Tian, Weichen and Liu, Xianglong and Han, Baoguo and Dong, Sufen and
   Qiu, Ruipeng},
Title = {Stabilized electrical conductivity in nano-engineered ultra-high
   performance concrete under prolonged freezing exposure:
   Nano-reinforcement and cryo-induced water migration mechanism},
Journal = {CONSTRUCTION AND BUILDING MATERIALS},
Year = {2026},
Volume = {518},
Month = {APR 4},
Abstract = {Concrete with stable electrical conductivity is essential for critical
   intelligent infrastructure functions such as selfmonitoring and deicing,
   but its performance under long-term freezing exposure remains a major
   challenge. This study developed a multifunctional carbon fiber
   strengthened ultra-high performance concrete (CFS-UHPC) by incorporating
   nano carbon blacks (NCBs) and carbon nanofibers (CNFs), achieving
   exceptional electrical conductivity under prolonged freezing exposure
   (-7.5 degrees C). Results identified the benefits of low-content CNFs on
   improving the mechanical strength and highlighted NCBs as the pivotal
   component for electrical stability, yielding resistances of 455.5 S2 and
   533.17 S2 at 28 and 135 days, respectively. A key finding was a dramatic
   86.6\% reduction in electrical resistance after 128-day freezing
   exposure. Microstructural and electrochemical analyses revealed that
   this enhancement was due to a coarsened pore structure and a unique
   cryo-pumping effect. Furthermore, machine learning models achieved
   highly accurate predictions of the electrical resistance, with an
   R-squared value of 0.9839, and confirmed NCBs and freezing exposure as
   the dominant controlling factors. This research provides a practical and
   mechanistic framework for engineering the next generation of durable and
   intelligent concrete composites for resilient infrastructure in cold
   climates.},
Type = {Article},
Affiliation = {Qiu, RP (Corresponding Author), Hong Kong Polytech Univ, Dept Appl Math, Hung Hom, Kowloon, Hong Kong, Peoples R China.
   Tian, Weichen; Liu, Xianglong, Nanchang Univ, Sch Infrastruct Engn, Nanchang 330031, Peoples R China.
