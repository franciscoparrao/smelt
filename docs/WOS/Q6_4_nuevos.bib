@article{ WOS:001575493800001,
Author = {Nzengu, Patient D. and Hlongwa, Ntuthuko W. and Sekhosana, Kutloano E.
   and Kebede, Mesfin A.},
Title = {Enhancing vanadium pentoxide-based (V2O5) cathodes
   for high-performance aqueous zinc-ion batteries: optimization of
   interlayer spacing, ion kinetics, voltage window},
Journal = {RSC ADVANCES},
Year = {2025},
Volume = {15},
Number = {41},
Pages = {34362-34398},
Month = {SEP 17},
Abstract = {The urgent need for safe, affordable, and environmentally responsible
   energy storage has placed rechargeable aqueous zinc-ion batteries
   (AZIBs) at the centre of next-generation research. While earlier reviews
   surveyed V2O5 cathodes in broad terms, none has yet unified the latest
   insights on interlayer engineering, electrolyte coordination, and
   operando diagnostics into a coherent design framework. Focusing on
   progress from 2019 to mid-2025, this review offers three distinctive
   contributions. First, it correlates the crystallographic evolution of
   V2O5, captured by synchrotron X-ray, in situ TEM, and Raman studies,
   with voltage plateaus and capacity decay, providing a mechanistic map of
   Zn2+/H2O co-intercalation and phase transitions. Second, it compares
   emerging synthesis routes (sol-gel, hydrothermal, solid-state, and
   electrochemical deposition) through a quantitative lens, linking
   specific surface area, defect chemistry, and conductivity (10(-2) to
   10(-1) S cm(-1)) to rate capability and long-term retention. Third, it
   surveys interlayer-expansion strategies, metal-ion pre-intercalation,
   organic pillar insertion, conductive-polymer hybrids, and hierarchical
   nanostructuring, showing how each modulates Zn2+ diffusivity, lattice
   strain (<5\% with water co-insertion), and dissolution resistance. By
   integrating experimental advances with density-functional-theory, ab
   initio molecular-dynamics, and machine-learning predictions, the review
   distils actionable design principles and a forward roadmap for achieving
   >400 mAh g(-1) capacities and >90\% retention beyond 2000 cycles. These
   new perspectives position V2O5 not merely as a promising cathode, but as
   a model system for understanding and optimizing layered hosts in aqueous
   multivalent batteries.},
Type = {Review},
Affiliation = {Kebede, MA (Corresponding Author), Univ South Africa, Inst Nanotechnol \& Water Sustainabil iNanoWS, Engn \& Technol, ZA-1710 Johannesburg, Gauteng, South Africa.
   Nzengu, Patient D.; Hlongwa, Ntuthuko W.; Sekhosana, Kutloano E.; Kebede, Mesfin A., Univ South Africa, Inst Nanotechnol \& Water Sustainabil iNanoWS, Engn \& Technol, ZA-1710 Johannesburg, Gauteng, South Africa.},
DOI = {10.1039/d5ra04247j},
Keywords-Plus = {SOL-GEL SYNTHESIS; ELECTROCHEMICAL PROPERTIES; LI-ION; ELECTRODE
   MATERIALS; THIN-FILMS; HYDROTHERMAL SYNTHESIS; PHASE-TRANSFORMATION;
   ENERGY-CONVERSION; OXIDE CATHODE; INTERCALATION},
Author-Email = {mesfiak@unisa.ac.za},
Number-of-Cited-References = {269},
Times-Cited = {5},
Unique-ID = {WOS:001575493800001},
}

@article{ WOS:001576004000002,
Author = {Luo, Qiling and Cheng, Boyuan and Li, Mingchao and Long, Wujian and
   Geng, Songyuan and Zhang, Mengxi and Zhang, Jinrui},
Title = {Real-world mega-project data and particle-packing features drive AI
   design of marine high-performance concrete},
Journal = {CASE STUDIES IN CONSTRUCTION MATERIALS},
Year = {2025},
Volume = {23},
Month = {DEC},
Abstract = {The long-term durability and sustainability of marine high-performance
   concrete (HPC) are decisive for structures exposed to chloride-rich
   environments, such as sea-crossing tunnels and bridges. However, most
   AI-based mix-design studies rely on limited lab-scale mixes and omit
   aggregate gradation, limiting their applicability in real-world
   projects. To address this gap, this study develops an AI-driven
   framework that combines machine learning-based performance prediction
   with multi-objective optimization, supported by a large-scale field
   dataset comprising 939 HPC mix designs collected from major marine
   infrastructure projects, including the Shenzhen-Zhongshan Link and the
   Huangmaohai Sea-Crossing Passage. The dataset uniquely incorporates full
   particle-size distribution descriptors-eight cumulative sieve residue
   percentages and maximum aggregate size-to capture granular packing
   effects. A random forest (RF) model trained on this dataset accurately
   predicts key properties including slump, 28-day compressive strength,
   and 28-day rapid chloride penetration coefficient (R2 = 0.90-0.95). Mix
   proportions are then optimized using the NSGA-II algorithm to minimize
   cement content and carbon emissions while satisfying strength,
   workability, and durability requirements. SHAP analysis reveals that
   particle-size features rank among the top five most influential
   variables for durability prediction. Experimental validation of five
   AI-designed mixes (C40-C80) demonstrates excellent performance, with
   28-day strengths ranging from 44.4 to 80.5 MPa and chloride diffusion
   coefficients as low as 1.4 x 10-1 2 m2/s. The results highlight the
   practical value of integrating field-scale data and explicit aggregate
   gradation features into interpretable, low-carbon mix design strategies
   for marine concrete applications.},
Type = {Article},
Affiliation = {Long, WJ (Corresponding Author), Shenzhen Univ, Coll Civil \& Transportat Engn, Shenzhen 518060, Guangdong, Peoples R China.
   Luo, Qiling; Li, Mingchao; Zhang, Mengxi; Zhang, Jinrui, Tianjin Univ, State Key Lab Hydraul Engn Intelligent Construct \&, Tianjin 300350, Peoples R China.
   Luo, Qiling; Cheng, Boyuan; Long, Wujian; Geng, Songyuan, Shenzhen Univ, Coll Civil \& Transportat Engn, Shenzhen 518060, Guangdong, Peoples R China.
   Cheng, Boyuan, Dongguan Univ Technol, Sch Environm \& Civil Engn, Dongguan 523808, Guangdong, Peoples R China.},
DOI = {10.1016/j.cscm.2025.e05306},
EarlyAccessDate = {SEP 2025},
Article-Number = {e05306},
Keywords = {Marine engineering high-performance concrete; Machine learning;
   Large-scale engineering data; Particle size distribution;
   Multi-objective optimization},
Keywords-Plus = {DURABILITY},
Author-Email = {longwj@szu.edu.cn},
Number-of-Cited-References = {54},
