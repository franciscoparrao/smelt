   Sun, Yu, Natl Univ Singapore, Sch Comp, Singapore, Singapore.},
DOI = {10.1016/j.ins.2023.01.147},
EarlyAccessDate = {FEB 2023},
Keywords = {Imbalanced data; Generative adversarial networks; Roulette wheel
   selection; Transfer learning},
Keywords-Plus = {SAMPLING METHOD; DATA-SETS; SMOTE},
Author-Email = {hwding@whu.edu.cn
   sun.yu@u.nus.edu
   nanahuang@whu.edu.cn
   shenzd@whu.edu.cn
