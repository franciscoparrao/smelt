   Thompson, Sally, Univ Western Australia, Sch Engn Civil Environm \& Min Engn, Crawley, WA, Australia.
   Sun, Qian (Chayn), RMIT Univ, Sch Sci, Geospatial Sci, Melbourne, Vic, Australia.},
DOI = {10.1177/23998083251409292},
EarlyAccessDate = {DEC 2025},
Keywords = {deep learning; multi-modal models; transfer learning; infill; sprawl;
   residential development; urban growth monitoring},
Author-Email = {warin.chotirosniramit@uwa.edu.au},
