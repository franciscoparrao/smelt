   Sohaib, Rana Muhammad, Northumbria Univ, Dept Comp \& Informat Sci, Newcastle Upon Tyne NE1 8ST, England.
   Shawky, Mahmoud A., Univ Glasgow, James Watt Sch Engn, Glasgow G12 8QQ, Scotland.
   Shah, Syed Tariq, Univ Essex, Sch Comp Sci \& Elect Engn, Colchester CO4 3SQ, England.},
DOI = {10.1109/OJCOMS.2025.3569301},
Keywords = {Cyber-security; intrusion detection system (IDS); IoT; transformers;
