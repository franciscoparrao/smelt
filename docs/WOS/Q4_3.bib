   Poli-de-Figueiredo, Carlos E., Pontificia Univ Catolica Rio Grande do Sul, Escola Med, Hosp Sao Lucas, Porto Alegre, RS, Brazil.},
DOI = {10.1109/CBMS65348.2025.00011},
Keywords = {Generative Adversarial Networks; Transfer Learning; Chronic Kidney
