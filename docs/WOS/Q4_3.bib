   Li, Jinpeng, South China Univ Technol, Sch Automat Sci \& Technol, Guangzhou 510640, Peoples R China.},
DOI = {10.1109/TASLPRO.2025.3579311},
Keywords = {Information retrieval; Data mining; Computational modeling; Semantics;
   Electronic medical records; Transformers; Solids; Dictionaries; Context
   modeling; Lattices; Chinese; deep learning; electronic medical records;
