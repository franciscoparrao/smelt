@article{ WOS:001256891300001,
Author = {Feng, Bo and Zhou, Xiaoping},
Title = {Energy-informed graph transformer model for solid mechanical analyses},
Journal = {COMMUNICATIONS IN NONLINEAR SCIENCE AND NUMERICAL SIMULATION},
Year = {2024},
Volume = {137},
Month = {OCT},
Abstract = {Physics-informed neural network (PINN) exists some challenges, such as
   independent and uncorrelated drawbacks leading to convergence
   impediments, limited interpretability and lack of generalization. In
   this paper, a novel energy-informed graph transformer model is proposed
   to overcome the drawbacks of PINN. In the proposed model, the graph
   neural network-basedattention mechanism is proposed to dynamically
   calculate weight coefficients between objects of graph-structured data,
   and then to aggregate weighted combinations of the neighbor objects
   features to update features of the target objects. The loss function is
   constructed with homoscedastic uncertainty by introducing trainable
   scalar parameters, which can be optimized to achieve the best
   performance of the network as it changes dynamically the topology of the
   loss function involved in the optimization process. Numerical results
   show that the proposed method can effectively increase the efficiency,
   robustness and accuracy of the network approximation of forward and
   inverse problems of solid mechanics. Furthermore, the proposed model
   demonstrates excellent generalization capabilities when applied to new
   problem using transfer learning strategy.},
Type = {Article},
Affiliation = {Zhou, XP (Corresponding Author), Chongqing Univ, Sch Civil Engn, Chongqing 400045, Peoples R China.
   Feng, Bo; Zhou, Xiaoping, Chongqing Univ, Sch Civil Engn, Chongqing 400045, Peoples R China.},
DOI = {10.1016/j.cnsns.2024.108103},
EarlyAccessDate = {JUN 2024},
Article-Number = {108103},
Keywords = {Energy -informed graph transformer; Attention mechanism; Homoscedastic
   uncertainty; Transfer learning; Solid mechanics},
Keywords-Plus = {DEEP NEURAL-NETWORKS},
Author-Email = {zhouxiaoping@cqu.edu.cn},
Number-of-Cited-References = {57},
Times-Cited = {4},
