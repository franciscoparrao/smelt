   Yang, Qiang, Hong Kong Univ Sci \& Technol, Comp Sci \& Engn, Kowloon, Clearwater Bay, Hong Kong, Peoples R China.},
DOI = {10.1109/TBDATA.2022.3188292},
Keywords = {Adaptation models; Feature extraction; Collaborative work; Data models;
   Privacy; Computational modeling; Training; Vertical federated learning;
   privacy; domain adaptation; interpretability},
