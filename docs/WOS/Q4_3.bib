}

@incollection{ WOS:001297303200044,
Author = {Wei, Wenqi and Wang, Jianzong and Cheng, Ning and Chen, Yuanxu and Zhou,
   Bao and Xiao, Jing},
Editor = {Wang, X and Zhang, R and Lee, YK and Sun, L and Moon, YS},
Title = {Epidemic Guard: A COVID-19 Detection System for Elderly People},
