}

@article{ WOS:001590686800006,
Author = {Rajeev, Devi and Remya, S. and Nayyar, Anand},
Title = {TransplantPredictor: A deep learning framework for liver transplant
   matching and survival prediction},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {Liver transplant outcome prediction presents a complex multi-modal data
   fusion engineering challenge involving heterogeneous clinical data,
   temporal dependencies, and interpretability constraints. This paper
   presents TransplantPredictor, a novel ensemble deep learning framework
   that systematically addresses these challenges through innovative
   architectural design and algorithmic optimization. Unlike previous
   single-model approaches in transplant prediction literature, our
   framework systematically integrates multiple complementary deep learning
   architectures with progressive transfer learning to overcome the
   fundamental limitations of single-paradigm methodologies. We propose a
   three-component ensemble architecture integrating LSTM networks for
   temporal sequence modeling, RNN for clinical progression patterns, and
   Gradient Boosting for non-linear tabular relationships. The ensemble
   employs advanced stacking with engineered meta-features and implements
   progressive transfer learning to overcome limited medical data
   constraints. The framework incorporates unified explainability using
   SHAP and LIME with consistency validation, while systematic
   preprocessing handles missing data through MICE and class imbalance via
   SMOTE. Extensive evaluation on 250 liver transplantation cases
   demonstrates superior performance of the proposed framework. The final
   TransplantPredictor with transfer learning achieves AUC-ROC of 0.941,
   F1-score of 87.9\%, and accuracy of 91.2\%, significantly outperforming
   the traditional MELD scoring system (84.9\% accuracy) by 6.3\%.
   Individual component analysis shows the ensemble approach provides
   substantial improvements over single models: LSTM (84.2\%), RNN
   (82.5\%), and Gradient Boosting (85.1\%). The progressive transfer
   learning strategy contributes an additional 5.2\% F1-score improvement
   compared to existing models. Ablation studies confirm the effectiveness
   of each component and the benefits of combining multiple models with
   transfer learning. The framework provides a practical solution for
   medical AI applications requiring accurate and interpretable
   predictions.},
Type = {Article},
Affiliation = {Remya, S (Corresponding Author), Amrita Vishwa Vidyapeetham, Amrita Sch Comp, Dept CSE, Amritapuri, India.
   Rajeev, Devi; Remya, S., Amrita Vishwa Vidyapeetham, Amrita Sch Comp, Dept CSE, Amritapuri, India.
   Nayyar, Anand, Duy Tan Univ, Sch Comp Sci, Da Nang, Vietnam.},
DOI = {10.1016/j.rineng.2025.107351},
EarlyAccessDate = {SEP 2025},
Article-Number = {107351},
Keywords = {Ensemble learning; Multi-modal data fusion; Transfer learning;
   Explainable AI; Medical informatics; Deep learning optimization},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; PATIENT SELECTION; ALGORITHMS},
Author-Email = {devir@am.amrita.edu
   remyas@am.amrita.edu
   anandnayyar@duytan.edu.vn},
Number-of-Cited-References = {55},
