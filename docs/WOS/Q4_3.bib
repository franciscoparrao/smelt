DOI = {10.1016/j.cmpb.2025.109080},
EarlyAccessDate = {JAN 2025},
Article-Number = {109080},
Keywords = {Multi-morbidity; Critical illness risk prediction; Graph attention
   network; TabNet; Feature fusion; Electronic health records},
Keywords-Plus = {MULTIMORBIDITY},
Author-Email = {yl\_wang2024@163.com},
