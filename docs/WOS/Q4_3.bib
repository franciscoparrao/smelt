   Sha, Xin, Shenyang Univ Chem Technol, Coll Informat Engn, Shenyang 110142, Liaoning, Peoples R China.},
DOI = {10.1016/j.engappai.2026.114542},
Article-Number = {114542},
Keywords = {Lithology identification; Source-free domain adaptation; Graph structure
   consistency; Transfer learning},
