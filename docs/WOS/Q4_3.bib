@article{ WOS:001533629300011,
Author = {Li, Xin and Niu, Xiaotian and Liu, Ziyang and Jiang, Lulu and Ji, Xing
   and Chen, Gang},
Title = {A hybrid graph neural network-based framework for aerothermal prediction
   on hypersonic vehicles},
Journal = {PHYSICS OF FLUIDS},
Year = {2025},
Volume = {37},
Number = {7},
Month = {JUL},
Abstract = {Efficient and accurate aerothermal prediction has become a crucial
   technology for the design of hypersonic vehicles. To enhance the
   generalization capability for complex geometries and reduce the cost of
   model training, this paper introduces a novel framework for aerothermal
   prediction of complex vehicles, based on a hybrid graph neural network
   model, named hybrid-MGNN. The model consists of three main components:
   normalized aerodynamic heat distribution prediction, statistical feature
   prediction, and flow field reconstruction. Initially, the method
   constructs graph-structured data from discrete mesh information,
   enabling precise representation of intricate geometries and flow field
   structures. A graph neural network model based on a message-passing
   mechanism establishes a nonlinear mapping from incoming flow conditions
   to the surface heat flux distribution of the vehicle. The model then
   encodes the flow conditions and global geometric features, which are fed
   into a feature prediction network to accurately estimate statistical
   features of the heat flux distribution, such as maximum values. Finally,
   a de-normalization technique is applied to reconstruct the aerothermal
   flow field on the vehicle's surface. The performance of the proposed
   hybrid-MGNN was validated using hypersonic double ellipsoids, blunt
   cones, double blunt cones, and lifting body shapes. The results show
   that the predicted aerodynamic heat loads have an average error of less
   than 6\% compared to computational fluid dynamics methods, with a
   computational efficiency improvement of approximately 400 times.
   Furthermore, the hybrid-MGNN framework is highly adaptable to arbitrary
   mesh types and complex geometries, and transfer learning significantly
   reduces model training costs.},
Type = {Article},
Affiliation = {Chen, G (Corresponding Author), Xi An Jiao Tong Univ, State Key Lab Strength \& Vibrat Mech Struct, Shaanxi Key Lab Environm \& Control Flight Vehicle, Sch Aerosp Engn, Xian 710049, Peoples R China.
   Li, Xin; Niu, Xiaotian; Liu, Ziyang; Jiang, Lulu; Ji, Xing; Chen, Gang, Xi An Jiao Tong Univ, State Key Lab Strength \& Vibrat Mech Struct, Shaanxi Key Lab Environm \& Control Flight Vehicle, Sch Aerosp Engn, Xian 710049, Peoples R China.},
DOI = {10.1063/5.0278111},
Article-Number = {077163},
Keywords-Plus = {REDUCED-ORDER MODELS; HEAT-FLUX; DECOMPOSITION; AERODYNAMICS; SURROGATE},
Author-Email = {aachengang@xjtu.edu.cn},
Number-of-Cited-References = {55},
Times-Cited = {1},
Unique-ID = {WOS:001533629300011},
}

@article{ WOS:001502461700001,
Author = {Yang, Lijun and Duan, Qinglong and Pan, Baiting and Wang, Zitian},
Title = {Post-pandemic holiday load forecasting considering social factors
   influences based on TL-Informer-LightGBM model},
Journal = {ELECTRIC POWER SYSTEMS RESEARCH},
Year = {2025},
Volume = {247},
Month = {OCT},
Abstract = {After the end of the COVID-19 pandemic, the pattern of social activities
   has changed, and power load fluctuations have shown sudden and drastic
   features, especially during the holiday. To solve this problem, a TL
   (Transfer Learning) -Informer-LightGBM load forecasting method
   considering the influences of social factors is proposed in this paper.
   Firstly, two social features of shared bikes usage rate and social media
   activity are introduced. Dynamic time warping (DTW) and
   Cross-correlation function (CCF) are used to analyze the time-lag of
   social features and align the load. The social features after time-lag
   alignment can effectively characterize the changing mode of load. Then,
   a forecasting model based on TL-Informer-LightGBM is proposed. Based on
   Informer and LightGBM, the advantages of timing feature capture and
   structured data processing are combined. In addition, to improve future
   information leakage during model integration, the improved Stacking
   ensemble algorithm is used to integrate the forecasting results. TL is
   used to solve the problem of scarcity of historical holiday data. By
   taking loads with similar patterns as samples, the model parameters are
   trained and transferred, and then the target load is used as samples for
   forecasting, so as to accelerate the model convergence process and
   improve the forecasting accuracy. In order to verify the validity of the
   model, real data of a city in southeast China are used for testing. The
   experimental results show that compared with other models, the proposed
   framework has better forecasting effect on MAE, MAPE, MSE and R2.},
