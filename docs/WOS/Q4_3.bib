@incollection{ WOS:001544948000007,
Author = {Kindji, G. Charbel N. and Fromont, Elisa and Rojas-Barahona, Lina M. and
   Urvoy, Tanguy},
Editor = {Krempl, G and Puolamaki, K and Miliou, I},
Title = {Synthetic Tabular Data Detection in the Wild},
Booktitle = {ADVANCES IN INTELLIGENT DATA ANALYSIS XXIII, IDA 2025},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15669},
Pages = {81-96},
Abstract = {Detecting synthetic tabular data is essential to prevent the
   distribution of false or manipulated datasets that could compromise
   data-driven decision-making. This study explores whether synthetic
   tabular data can be reliably identified across different tables. This
   challenge is unique to tabular data, where structures (such as number of
   columns, data types, and formats) can vary widely from one table to
   another. We propose four table-agnostic detectors combined with simple
   preprocessing schemes that we evaluate on six evaluation protocols, with
   different levels of ``wildness{''}. Our results show that cross-table
   learning on a restricted set of tables is possible even with naive
   preprocessing schemes. They confirm however that cross-table transfer
   (i.e. deployment on a table that has not been seen before) is
   challenging. This suggests that sophisticated encoding schemes are
   required to handle this problem.},
Type = {Proceedings Paper},
Affiliation = {Kindji, GCN (Corresponding Author), Orange Innovat, Lannion, France.
   Kindji, GCN (Corresponding Author), Univ Rennes, CNRS, Inria, IRISA UMR 6074, Rennes, France.
   Kindji, G. Charbel N.; Rojas-Barahona, Lina M.; Urvoy, Tanguy, Orange Innovat, Lannion, France.
   Kindji, G. Charbel N.; Fromont, Elisa, Univ Rennes, CNRS, Inria, IRISA UMR 6074, Rennes, France.},
DOI = {10.1007/978-3-031-91398-3\_7},
Keywords = {Tabular Data; Tabular Generative Models; Fake Data Detection;
   Classification; Transfer learning},
Author-Email = {charbel.kindji@orange.com
   elisa.fromont@irisa.fr
   lina.rojas@orange.com
   tanguy.urvoy@orange.com},
