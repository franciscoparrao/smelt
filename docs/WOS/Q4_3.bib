@incollection{ WOS:001511158700703,
Author = {Hsu, Bay-Yuan and Chen, Yuh-Shyan and Hsia, Chung-Hsuan and Chen,
   Chun-Yi},
Book-Group-Author = {IEEE},
Title = {SMT-GGCN: Self-Supervised Multi-Task Learning for Generative Graph
   Convolutional Network},
Booktitle = {GLOBECOM 2024-2024 IEEE GLOBAL COMMUNICATIONS CONFERENCE},
Series = {IEEE Global Telecommunications Conference (Globecom)},
Year = {2024},
Pages = {4232-4237},
Abstract = {Deep learning on graphs has shown to be powerful in modeling
   graph-structured data and learning representations for graphs, which
   involves aggregating information from graph neighborhoods to derive
   effective node representations. Although graph neural networks (GNNs)
   can be trained from scratch, pre-training GNNs to learn transferable
   knowledge for downstream tasks has been used recently to improve
   performance. However, using pre-training and fine-tuning to model each
   subtask can sometimes ignore the relationships, conflicts, and
   constraints between tasks, resulting in worse performance. In this
   paper, we propose a novel framework called Self-supervised Multi-Task
   Learning for Generative Graph Convolutional Network (SMT-GGCN) to
   enhance graph-based neural network models. SMT-GGCN combines
   self-supervised learning pretext tasks with supervised learning to train
   Graph Convolutional Networks (GCN) for graph structure understanding. We
   demonstrate that self-supervised multi-task learning can improve GCN's
   generalization ability and enhance feature learning.},
Type = {Proceedings Paper},
Affiliation = {Hsu, BY (Corresponding Author), Natl Tsing Hua Univ, Dept Ind Engn \& Engn Management, Hsinchu, Taiwan.
   Hsu, Bay-Yuan; Chen, Chun-Yi, Natl Tsing Hua Univ, Dept Ind Engn \& Engn Management, Hsinchu, Taiwan.
   Chen, Yuh-Shyan; Hsia, Chung-Hsuan, Natl Taipei Univ, Dept Comp Sci \& Informat Engn, Taipei, Taiwan.},
DOI = {10.1109/GLOBECOM52923.2024.10901437},
Keywords = {Multi-task Learning; Self-Supervised Learning; Generative Graph
   Convolutional Network},
Author-Email = {byhsu@ie.nthu.edu.tw
   yschen@mail.ntpu.edu.tw
   s710883107@gm.ntpu.edu.tw
   cjy@gapp.nthu.edu.tw},
