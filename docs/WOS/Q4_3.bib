   Kurker, Faruk, Adiyaman Univ, Fac Engn, Dept Elect \& Elect Engn, TR-02040 Adiyaman, Turkiye.
   Aksoz, Ahmet, Kayseri Univ, Dept Elect \& Elect Engn, Fac Engn Architecture \& Design, TR-38280 Kayseri, Turkiye.},
DOI = {10.3390/app15137262},
