DOI = {10.1175/WAF-D-20-0093.1},
Keywords = {Cloud cover; Model output statistics; Deep learning; Neural networks;
   Other artificial intelligence/machine learning},
Keywords-Plus = {PRECIPITATION ESTIMATION; RADIATION FOG; WEATHER; MODELS; REGRESSION;
   SATELLITE; SCALE},
