   Liu, Hong; Zhang, Zijun, City Univ Hong Kong, Ctr Syst Informat Engn, Shenzhen Res Inst, Shenzhen 518057, Guangdong, Peoples R China.},
DOI = {10.1007/s10462-024-10728-z},
Article-Number = {112},
Keywords = {Wind power prediction; Deep learning methods; Spatial-temporal data;
