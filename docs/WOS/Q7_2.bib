   Wu, Jiang; Yu, Yang, Beijing Kedong Elect Power Control Syst Co Ltd, Beijing 100052, Peoples R China.},
DOI = {10.1109/ACCESS.2021.3086583},
Keywords = {Wind power generation; Forecasting; Time series analysis; Predictive
   models; Anomaly detection; Uncertainty; Probabilistic logic; Wind power;
   uncertainty; probabilistic forecasting; Gaussian process},
Keywords-Plus = {QUANTILE REGRESSION; FEATURE-SELECTION; RANDOM FOREST; SPEED;
   PREDICTION; MODEL; FARM; ALGORITHM; SYSTEM},
