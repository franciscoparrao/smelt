@article{ WOS:001709925100001,
Author = {Moulds, Simon and Slater, Louise and Arnal, Louise and Wood, Andrew w.},
Title = {Skilful probabilistic predictions of UK flood risk months ahead using a
   large-sample machine learning model trained on multimodel ensemble
   climate forecasts},
Journal = {HYDROLOGY AND EARTH SYSTEM SCIENCES},
Year = {2025},
Volume = {29},
Number = {11},
Pages = {2393-2406},
Month = {JUN 10},
Abstract = {Seasonal streamflow forecasts are an important component of flood risk
   management. Hybrid forecasting methods that predict seasonal streamflow
   using machine learning (ML) models driven by climate model outputs are
   currently underexplored, yet they have some important advantages over
   traditional approaches using hydrological models. Here we develop a
   hybrid subseasonal to seasonal (S2S) streamflow forecasting system to
   predict the monthly maximum daily streamflow up to 4 months ahead. We
   train a quantile regression forest model on dynamical precipitation and
   temperature forecasts from a multimodel ensemble of 196 members (eight
   seasonal climate forecast models) from the Copernicus Climate Change
   Service (C3S) to produce probabilistic hindcasts for 579 stations across
   the UK for the period 2004-2016, with up to 4 months' lead time. We show
   that the large-sample (multi-site) ML model trained on pooled catchment
   data together with static catchment attributes is narrowly but
   significantly more skilful compared to single-site ML models trained on
   data from each catchment individually. Considering all initialisation
   months, 60 \% of stations show positive skill (CRPSS > 0) relative to
   climatological reference forecasts in the first month after
   initialisation. This falls to 41 \% in the second month, 38 \% in the
   third month, and 33 \% in the fourth month.},
Type = {Article},
Affiliation = {Moulds, S (Corresponding Author), Univ Edinburgh, Sch Geosci, Edinburgh, Scotland.
   Moulds, S (Corresponding Author), Univ Oxford, Sch Geog \& Environm, Oxford, England.
   Moulds, Simon, Univ Edinburgh, Sch Geosci, Edinburgh, Scotland.
   Moulds, Simon; Slater, Louise, Univ Oxford, Sch Geog \& Environm, Oxford, England.
   Arnal, Louise, Ouranos, Montreal, PQ, Canada.
   Wood, Andrew w., Natl Ctr Atmospher Res, Climate \& Global Dynam, Boulder, CO USA.
   Wood, Andrew w., Colorado Sch Mines, Dept Civil \& Environm Engn, Golden, CO USA.},
DOI = {10.5194/hess-29-2393-2025},
Keywords-Plus = {STREAMFLOW; PREDICTABILITY; SYSTEM},
Author-Email = {simon.moulds@ed.ac.uk},
Number-of-Cited-References = {35},
Times-Cited = {2},
Unique-ID = {WOS:001709925100001},
}

@article{ WOS:001515596600001,
Author = {Diamantopoulou, Maria J. and Ozcelik, Ramazan and Eler, Unal and
   Koparan, Burak},
Title = {From Regression to Machine Learning: Modeling Height-Diameter
   Relationships in Crimean Juniper Stands Without Calibration Overhead},
Journal = {FORESTS},
Year = {2025},
Volume = {16},
Number = {6},
Month = {JUN 9},
Abstract = {Accurate modeling of height-diameter (h-d) relationships is critical for
   forest inventory and management, particularly in complex forest
   ecosystems such as natural and pure Crimean juniper (Juniperus excelsa
   Bieb.) stands. This study evaluates both traditional parametric and
   modern machine learning (ML) approaches to develop reliable h-d models
   based on 2135 sample trees measured in southern T \& uuml;rkiye. The
   modeling approaches include fixed-effects (FE), mixed-effects (ME),
   three quantile regression (QR) models based on three, five, and nine
   quantile levels, and non-parametric ML methods: shallow multilayer
   perceptron (S\_MLP), extreme gradient boost (XGBoost), and random forest
   (RF). According to the assessment metrics for the fitting and test
   datasets, the XGBoost modeling approach achieved the most accurate
   performance. For the fitting dataset, it achieved root mean square error
   values of 1.11 m and 1.21 m. For the test dataset, the corresponding
   error values were 1.16 m and 1.24 m, resulting in the highest accuracy
   among all models, closely followed by the RF and S\_MLP models. A key
   practical advantage of ML approaches is that they do not depend on
   calibration scenarios, meaning they can operate without the need for
   preliminary parameter configuration. In contrast, the ME model showed
   the highest accuracy among the parametric methods when calibration was
   applied. In this case, when applying ME models, the study recommends
   calibrating the model by measuring four randomly selected trees per plot
   to balance prediction accuracy and field sampling effort.},
Type = {Article},
Affiliation = {Diamantopoulou, MJ (Corresponding Author), Aristotle Univ Thessaloniki, Fac Agr Forestry \& Nat Environm, Sch Forestry \& Nat Environm, Thessaloniki 54124, Greece.
   Diamantopoulou, Maria J., Aristotle Univ Thessaloniki, Fac Agr Forestry \& Nat Environm, Sch Forestry \& Nat Environm, Thessaloniki 54124, Greece.
   Ozcelik, Ramazan; Eler, Unal; Koparan, Burak, Isparta Univ Appl Sci, Fac Forestry, Dept Forest Engn, East Campus, TR-32260 Isparta, Turkiye.},
DOI = {10.3390/f16060972},
