DOI = {10.1016/j.ejor.2019.11.029},
EarlyAccessDate = {JUN 2021},
Keywords = {Forecasting; Inventory; E-commerce; Retailing},
Keywords-Plus = {INVENTORY MANAGEMENT; SINGLE-PERIOD; BRAND SALES; PRICE; ACCURACY; STOCK},
