}

@article{ WOS:000735128100001,
Author = {Lamichhane, Sushil and Adhikari, Kabindra and Kumar, Lalit},
Title = {Use of Multi-Seasonal Satellite Images to Predict SOC from Cultivated
   Lands in a Montane Ecosystem},
Journal = {REMOTE SENSING},
Year = {2021},
Volume = {13},
Number = {23},
Month = {DEC},
Abstract = {Although algorithms are well developed to predict soil organic carbon
   (SOC), selecting appropriate covariates to improve prediction accuracy
   is an ongoing challenge. Terrain attributes and remote sensing data are
   the most common covariates for SOC prediction. This study tested the
   predictive performance of nine different combinations of topographic
   variables and multi-season remotely sensed data to improve the
   prediction of SOC in the cultivated lands of a middle mountain catchment
   of Nepal. The random forest method was used to predict SOC contents, and
   the quantile regression forest for quantifying the prediction
   uncertainty. Prediction of SOC contents was improved when remote sensing
   data of multiple seasons were used together with the terrain variables.
   Remote sensing data of multiple seasons capture the dynamic conditions
   of surface soils more effectively than using an image of a single
   season. It is concluded that the use of remote sensing images of
   multiple seasons instead of a snapshot of a single period may be more
   effective for improving the prediction of SOC in a digital soil mapping
   framework. However, an image with the right timing of cropping season
   can provide comparable results if a parsimonious model is preferred.},
Type = {Article},
Affiliation = {Lamichhane, S (Corresponding Author), Univ New England, Sch Environm \& Rural Sci, Armidale, NSW 2350, Australia.
   Lamichhane, S (Corresponding Author), Natl Soil Sci Res Ctr, Nepal Agr Res Council, Lalitpur 44700, Nepal.
