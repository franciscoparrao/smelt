   Wang, Bohui, Xi An Jiao Tong Univ, Sch Cyber Sci \& Engn, Xian 710049, Peoples R China.},
DOI = {10.3390/en18164227},
Article-Number = {4227},
Keywords = {ash fouling; economizer; cleanliness factor; subtraction-average-based
   optimizer; quantile regression; bi-directional gated recurrent units},
Keywords-Plus = {SOOT-BLOWING OPTIMIZATION; NEURAL-NETWORKS; PREDICTION; REGRESSION;
