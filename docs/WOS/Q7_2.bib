   Penagarikano, Oier, Aler Technol, Donostia San Sebastian 20009, Spain.},
DOI = {10.1016/j.engappai.2025.110246},
EarlyAccessDate = {FEB 2025},
Article-Number = {110246},
Keywords = {Convolutional Neural Networks; Dropout; Uncertainty quantification;
   Prognostics \& health management; Hybrid health monitoring; Robustness},
Keywords-Plus = {PROGNOSTICS},
