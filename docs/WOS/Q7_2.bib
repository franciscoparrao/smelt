@article{ WOS:001488761900001,
Author = {Wu, Sir Yunfa and Zhang, Bin and Meng, Anbo and Liu, Yong-Hua and Su,
   Chun-yi},
Title = {Enhancing transmission line security: Robust sag interval estimation
   under hybrid cyber attacks},
Journal = {ELECTRIC POWER SYSTEMS RESEARCH},
Year = {2025},
Volume = {247},
Month = {OCT},
Abstract = {With the development of technology, both attack and defense methods have
   been constantly evolving. Power systems have been equipped with various
   defense mechanisms to ensure safe operation. However, attackers are also
   continually designing new combinations of multiple attack methods to
   launch more powerful, complex, difficult-to-detect, and defend against
   attacks. As one of the essential safety indicators in power system
   operation, the sag of overhead transmission lines is also threatened by
   hybrid cyber attacks. In this study, we propose a hybrid attack strategy
   that combines DoS and deception attacks to enable attackers to inject
   false data successfully without being detected, and provide a more
   realistic attack environment for subsequent sag interval estimation
   research. To estimate the sag interval, we propose a sag interval
   estimation model based on Quantile Regression Extreme Gradient Boosting
   (QRXGBoost) to capture the uncertainty in the estimation values and
   provide more accurate estimation intervals under hybrid cyber attacks.
   Additionally, we introduce a Mixed Parameter Optimization (MPO) method
   combining random search and Bayesian optimization to optimize model
   parameters and improve parameter search efficiency. This method
   identifies superior parameter combinations, further improving the
   performance of the sag interval estimation model under hybrid cyber
   attacks. We verify the effectiveness of the proposed QRXGBoost model
   through comparative analysis with three improved models and validate the
   robustness of the proposed model against attack data through experiments
   considering four scenarios of training and testing with and without
   attacks. Our results demonstrate the efficacy of our proposed approach
   in transmission line sag interval estimation under the threat of hybrid
   cyber attacks.},
Type = {Article},
Affiliation = {Zhang, B (Corresponding Author), Guangdong Univ Technol, 100 Waihuanxi Rd, Guangzhou 510006, Guangdong, Peoples R China.
