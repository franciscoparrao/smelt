   Boukhobza, Jalil, Univ Bretagne Occidentale, Brest, France.},
DOI = {10.1109/CloudCom2018.2018.00030},
Keywords-Plus = {HOST LOAD PREDICTION; SHORT-TERM-MEMORY},
