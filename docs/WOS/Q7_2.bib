@article{ WOS:000601168700004,
Author = {Icke, O. and van Es, D. M. and de Koning, M. F. and Wuister, J. J. G.
   and Ng, J. and Phua, K. M. and Koh, Y. K. K. and Chan, W. J. and Tao, G.},
Title = {Performance improvement of wastewater treatment processes by application
   of machine learning},
Journal = {WATER SCIENCE AND TECHNOLOGY},
Year = {2020},
Volume = {82},
Number = {12},
Pages = {2671-2680},
Month = {DEC 15},
Abstract = {Improving wastewater treatment processes is becoming increasingly
   important, due to more stringent effluent quality requirements, the need
   to reduce energy consumption and chemical dosing. This can be achieved
   by applying artificial intelligence. Machine learning is implemented in
   two domains: (1) predictive control and (2) advanced analytics. This is
   currently being piloted at the integrated validation plant of PUB,
   Singapore's National Water Agency. (1) Primarily, predictive control is
   applied for optimised nutrient removal. This is obtained by application
   of a self-learning feedforward algorithm, which uses load prediction and
   machine learning, fine-tuned with feedback on ammonium effluent.
   Operational results with predictive control show that the load
   prediction has an accuracy of approximate to 88\%. It is also shown that
   an up to approximate to 15\% reduction of aeration amount is achieved
   compared to conventional control. It is proven that this load
   prediction-based control leads to stable operation and meeting effluent
   quality requirements as an autopilot system. (2) Additionally, advanced
   analytics are being developed for operational support. This is obtained
   by application of quantile regression neural network modelling for
   anomaly detection. Preliminary results illustrate the ability to
   autodetect process and instrument anomalies. These can be used as early
   warnings to deliver data-driven operational support to process
   operators.},
Type = {Article},
Affiliation = {Icke, O (Corresponding Author), Royal HaskoningDHV, Aquasuite, Laan 1914 35, NL-3818 EX Amersfoort, Netherlands.
   Icke, O.; van Es, D. M.; de Koning, M. F.; Wuister, J. J. G., Royal HaskoningDHV, Aquasuite, Laan 1914 35, NL-3818 EX Amersfoort, Netherlands.
   Ng, J.; Phua, K. M.; Koh, Y. K. K.; Chan, W. J.; Tao, G., Singapores Natl Water Agcy, PUB, 40 Scotts Rd, Singapore 228231, Singapore.},
DOI = {10.2166/wst.2020.382},
Keywords = {anomaly detection; autopilot; machine learning; operational support;
   predictive control; wastewater treatment},
Author-Email = {otto.icke@rhdhv.com},
Number-of-Cited-References = {11},
Times-Cited = {46},
Unique-ID = {WOS:000601168700004},
}

@article{ WOS:000596873100004,
Author = {van Steenbergen, R. M. and Mes, M. R. K.},
Title = {Forecasting demand profiles of new products},
Journal = {DECISION SUPPORT SYSTEMS},
Year = {2020},
Volume = {139},
Month = {DEC},
Abstract = {Nowadays, many companies face shorter product life cycles, increasing
   the need to properly forecast demand for newly introduced products.
   These forecasts allow them to support operational decisions, such as
   procurement and inventory control. However, forecasting the demand of
   new products is challenging compared to existing products, since
   historical sales data is not available as an indicator of future sales.
   Moreover, little attention has been paid in literature to quantitative
   methods for new product forecasting, especially with respect to
   quantifying the uncertainty in demand. In this paper, we present a novel
   demand forecasting method denoted by DemandForest, which combines
   K-means, Random Forest, and Quantile Regression Forest. This machine
   learning-based approach combines the historical sales data of previously
   introduced products and product characteristics of existing and new
   products to make prelaunch forecasts and support inventory management
   decisions for new products. DemandForest clusters and predicts demand
   patterns, and predicts the quantiles of the total demand during an
   introduction period. We validate and illustrate our approach for
   forecasting and inventory management using real-world data sets of
   several companies. Compared to several benchmark methods, DemandForest
   provides the most accurate predictions, resulting in potential inventory
   savings of around 15\% depending on lead times and service levels.},
Type = {Article},
Affiliation = {van Steenbergen, RM (Corresponding Author), Univ Twente, Fac Behav Management \& Social Sci, Dept Ind Engn \& Business Informat Syst, POB 217, NL-7500 AE Enschede, Netherlands.
   van Steenbergen, R. M.; Mes, M. R. K., Univ Twente, Fac Behav Management \& Social Sci, Dept Ind Engn \& Business Informat Syst, POB 217, NL-7500 AE Enschede, Netherlands.},
DOI = {10.1016/j.dss.2020.113401},
Article-Number = {113401},
Keywords = {New product forecasting; Pre-launch forecasting; Random Forest; Quantile
   regression Forest; Inventory management},
Keywords-Plus = {INVENTORY MANAGEMENT; PREDICTION; MACHINE; MODEL; SEGMENTATION;
   CONSTRUCTION; FORESTS; SYSTEM},
Author-Email = {r.m.vansteenbergen@utwente.nl},
Number-of-Cited-References = {52},
Times-Cited = {53},
Unique-ID = {WOS:000596873100004},
}

@article{ WOS:000602008900001,
Author = {Vivas, Eliana and Allende-Cid, Hector and Salas, Rodrigo},
Title = {A Systematic Review of Statistical and Machine Learning Methods for
   Electrical Power Forecasting with Reported MAPE Score},
Journal = {ENTROPY},
Year = {2020},
Volume = {22},
Number = {12},
Month = {DEC},
Abstract = {Electric power forecasting plays a substantial role in the
   administration and balance of current power systems. For this reason,
   accurate predictions of service demands are needed to develop better
   programming for the generation and distribution of power and to reduce
   the risk of vulnerabilities in the integration of an electric power
   system. For the purposes of the current study, a systematic literature
   review was applied to identify the type of model that has the highest
   propensity to show precision in the context of electric power
   forecasting. The state-of-the-art model in accurate electric power
   forecasting was determined from the results reported in 257 accuracy
   tests from five geographic regions. Two classes of forecasting models
   were compared: classical statistical or mathematical (MSC) and machine
   learning (ML) models. Furthermore, the use of hybrid models that have
   made significant contributions to electric power forecasting is
   identified, and a case of study is applied to demonstrate its good
   performance when compared with traditional models. Among our main
   findings, we conclude that forecasting errors are minimized by reducing
   the time horizon, that ML models that consider various sources of
   exogenous variability tend to have better forecast accuracy, and
   finally, that the accuracy of the forecasting models has significantly
   increased over the last five years.},
Type = {Review},
Affiliation = {Vivas, E (Corresponding Author), Pontificia Univ Catolica Valparaiso, Escuela Ingn Informat, Valparaiso 2950, Chile.
   Vivas, Eliana; Allende-Cid, Hector, Pontificia Univ Catolica Valparaiso, Escuela Ingn Informat, Valparaiso 2950, Chile.
   Salas, Rodrigo, Univ Valparaiso, Escuela Ingn C Biomed, Chacabuco 2092-2220, Valparaiso, Chile.},
DOI = {10.3390/e22121412},
Article-Number = {1412},
Keywords = {electric power; forecasting accuracy; machine learning},
Keywords-Plus = {TRANSFORMATION QUANTILE REGRESSION; ARTIFICIAL NEURAL-NETWORKS; FLY
   OPTIMIZATION ALGORITHM; SUPPORT VECTOR REGRESSION; ENERGY-CONSUMPTION;
   TIME-SERIES; GREY MODEL; LOAD PROFILE; DEMAND; DECOMPOSITION},
Author-Email = {eliana.vivas.r@mail.pucv.cl
