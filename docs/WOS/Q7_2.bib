   Branco, V, Univ Tecnol, ITR Ctr Sur, Lab Solar, Durazno 97000, Uruguay.},
DOI = {10.1016/j.renene.2020.05.046},
Keywords = {GHI; Probabilistic forecast; Ground measurement; Solar variability;
