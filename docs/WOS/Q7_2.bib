@incollection{ WOS:001695124500045,
Author = {Li, Mingshu and Desai, Dhruv and Sarmah, Bhaskarjit and Bhagat, Snigdha
   and Mehta, Dhagash},
Book-Group-Author = {ACM},
Title = {Similarity-based Conformal Prediciton using Random Forest Proximities},
Booktitle = {6TH ACM INTERNATIONAL CONFERENCE ON AI IN FINANCE, ICAIF 2025},
Year = {2025},
Pages = {387-395},
Abstract = {Conformal prediction has recently gained traction as a robust technique
   for constructing prediction intervals at specified confidence levels
   without assuming specific distributions. However, traditional methods
   often lack adaptability to data heteroskedasticity, resulting in
   prediction intervals of fixed width. In this paper, we present a novel
   approach, introducing random forest proximities (i.e., distance measure)
   to differentiate relevant data points when estimating empirical
   quantiles of conformity scores. This innovation, which accounts for
   pairwise distances between calibration instances and testing samples,
   aims to enhance the efficiency and informativeness of the conformal
   prediction. Our empirical investigations include numerical experiments
   across various publicly available datasets and an application to
   forecasting the average daily volume of corporate bonds, covering both
   regression and classification tasks. The results demonstrate that our
   method exhibits greater adaptability to data heteroskedasticity compared
   to regular conformal prediction and recent innovations like
   conformalized quantile regression. It delivers more precise estimations
   in low-risk areas, while providing adequately conservative predictions
   in high-uncertainty regions. These findings highlight the practical
   significance of our approach in efficiently quantifying uncertainty and
   accurately generating prediction intervals, making substantial
   contributions to both scientific research and engineering applications.},
Type = {Proceedings Paper},
Affiliation = {Li, MS (Corresponding Author), BlackRock Inc, Atlanta, GA 30306 USA.
   Li, Mingshu, BlackRock Inc, Atlanta, GA 30306 USA.
   Desai, Dhruv; Mehta, Dhagash, BlackRock Inc, New York, NY USA.
   Sarmah, Bhaskarjit; Bhagat, Snigdha, BlackRock Inc, Gurgaon, India.},
DOI = {10.1145/3768292.3770379},
Keywords = {Uncertainty Quantification; Conformal Prediction; Similarity Learning;
   Random Forest},
Keywords-Plus = {PREDICTION; INTERVALS},
Author-Email = {Mingshu.Li@blackrock.com
   dhruv.desai1@blackrock.com
   bhaskarjit.sarmah@blackrock.com
