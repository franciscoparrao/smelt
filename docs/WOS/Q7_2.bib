   Ndehedehe, Christopher E., Griffith Univ, Australian Rivers Inst, Nathan, Qld 4111, Australia.
   Ferreira, Vagner G., Hohai Univ, Sch Earth Sci \& Engn, Nanjing, Peoples R China.},
DOI = {10.1016/j.ejrh.2022.101185},
EarlyAccessDate = {AUG 2022},
