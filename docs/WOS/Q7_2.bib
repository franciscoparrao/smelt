   Jouvet, Philippe, Univ Montreal, CHU St Justine Hosp, CHU St Justine Res Ctr, Montreal, PQ, Canada.},
DOI = {10.1109/TBME.2025.3541978},
Keywords = {Heart rate; Temperature measurement; Pediatrics; Pain; Monitoring;
