@incollection{ WOS:001315771700107,
Author = {Souissi, Marwa and Njah, Mohamed and El Hamdi, Ridha and Charaabi, Hana},
Book-Group-Author = {IEEE},
Title = {Probabilistic ML based RUL prediction of a turbofan engine},
Booktitle = {2024 IEEE 7TH INTERNATIONAL CONFERENCE ON ADVANCED TECHNOLOGIES, SIGNAL
   AND IMAGE PROCESSING, ATSIP 2024},
Series = {International Conference on Advanced Technologies for Signal and Image
   Processing ATSIP},
Year = {2024},
Pages = {606-612},
Abstract = {In the last several years, Prognostics and health management (PHM) have
   benefited greatly from advancements in machine learning (ML) and deep
   learning (DL). Despite these advancements, the uncertainty in ML
   predictions is often not adequately addressed. As black boxes, ML and DL
   technologies are often employed to provide simply point estimates of
   remaining usable life (RUL) without taking uncertainties into account.
   For safer and more informed decision-making, it is crucial to precisely
   quantify the level of certainty in these estimates and present them as
   confidence intervals. This paper focuses on the issue of quantifying the
   uncertainty in ML predictions, especially RUL estimates.Two
   probabilistic ML approaches are applied in the estimation of the RUL of
   a Twin-Flow Turbojet. When estimating the turbojet RUL prediction
   uncertainty, the parametric approach seeks to maximize probability while
   lowering model variance to provide a reduced prediction uncertainty and,
   thus, a more dependable RUL prediction. The quantile regression method
   relies on minimizing the quantile loss function. The two methods
   produced similar results, in the form of a curve of estimated RUL
   confidence intervals with respect to the operating cycle number. For the
   parametric approach, this interval is determined by the compromise
   parameter; for the non-parametric approach, it is determined by the
   quantile levels.We conducted our investigation using the Train FD003
   learning base from NASA's CMAPPS (Commercial Modular Aero-Propulsion
   System Simulation) and Google Colab environment.},
Type = {Proceedings Paper},
Affiliation = {Souissi, M (Corresponding Author), Univ Sfax, Natl Engn Sch Sfax ENIS, Lab Adv Technol Med \& Signals ATMS, Sfax, Tunisia.
   Souissi, Marwa, Univ Sfax, Natl Engn Sch Sfax ENIS, Lab Adv Technol Med \& Signals ATMS, Sfax, Tunisia.
   Digital Res Ctr Sfax CRNS, Technopole Sfax, Sfax, Tunisia.},
DOI = {10.1109/ATSIP62566.2024.10638976},
Keywords = {Probabilistic machine learning; uncertainty estimation; confidence
   interval; parametric approach; non parametric approach; RUL; PHM;
   turbofan engine},
Keywords-Plus = {REMAINING USEFUL LIFE; HEALTH PROGNOSTICS},
Author-Email = {marwa.souissi@enis.tn
   mohamed.njah@enis.tn
   hamdi.ridha@univgb.tn
   hana.charaabi@enis.tn},
Number-of-Cited-References = {29},
