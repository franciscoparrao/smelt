}

@article{ WOS:001501355100001,
Author = {Zanzouri, Souleima and Kacem, Manel and Belkacem, Lotfi},
Title = {Insurance Ratemaking Using a Combined Quantile Regression Machine
   Learning Approach},
Journal = {NORTH AMERICAN ACTUARIAL JOURNAL},
Year = {2026},
Volume = {30},
Number = {1},
Pages = {32-51},
Month = {JAN 2},
Abstract = {In non-life insurance, estimating accurately the conditional quantile of
   the total claim amount is crucial for insurance ratemaking. In this
   article, we investigate the use of innovative models that combine
   quantile regression with machine learning algorithms. These models
   include quantile regression random forest (QRF), quantile regression
   gradient boosting (QRGB), quantile regression XGBoost (QRXGBoost), and
   quantile regression neural networks (QRNN). A two-part approach is
   adopted to implement the considered models where in a first step, a
   logistic regression is employed to estimate, for each policyholder
   characteristic, the probability of submitting at least one claim. In a
   second step, the claim amount is modeled using the combined models. The
   estimated quantiles are considered to determine a loaded premium based
   on the quantile premium principle. Our empirical study conducted on a
   real automobile insurance dataset reveals that the innovative QRNN model
   is the most effective in capturing policy riskiness and providing the
   most accurate premium predictions. The performance of the trained models
   is assessed using the mean squared error, the mean absolute error, and
   the quantile loss function. The implications of this study will
   contribute significantly to enhancing the ratemaking structure in the
   insurance industry.},
Type = {Article},
Affiliation = {Kacem, M (Corresponding Author), Univ Sousse, Res Lab Econ Management \& Quantitat Finance LaREMF, Sousse, Tunisia.
   Zanzouri, Souleima; Kacem, Manel; Belkacem, Lotfi, Univ Sousse, Res Lab Econ Management \& Quantitat Finance LaREMF, Sousse, Tunisia.
   Zanzouri, Souleima, Univ Claude Bernard Lyon 1, Res Lab Actuarial \& Financial Sci LSAF, Lyon, France.},
DOI = {10.1080/10920277.2025.2503744},
EarlyAccessDate = {MAY 2025},
Author-Email = {manel.kacem@ihecso.u-sousse.tn},
Number-of-Cited-References = {50},
Times-Cited = {1},
Unique-ID = {WOS:001501355100001},
}

@article{ WOS:001493061700002,
Author = {Cairoli, Francesca and Kuipers, Tom and Bortolussi, Luca and Paoletti,
   Nicola},
Title = {Conformal quantitative predictive monitoring of stochastic systems with
   conditional validity},
Journal = {NONLINEAR ANALYSIS-HYBRID SYSTEMS},
Year = {2025},
Volume = {57},
Month = {AUG},
Abstract = {We consider the problem of predictive monitoring (PM), i.e., predicting
   at runtime the satisfaction of a desired property from the current
   system's state. Due to its relevance for runtime safety assurance and
   online control, PM methods need to be efficient to enable timely
   interventions against predicted violations, while providing correctness
   guarantees. We introduce quantitative predictive monitoring (QPM), a PM
   method to support stochastic processes and rich specifications given in
   Signal Temporal Logic (STL). QPM provides a quantitative measure of
   satisfaction of some property phi by predicting its quantitative (a.k.a.
   robust) STL semantics, either spatial or temporal. QPM derives
   prediction intervals that are highly efficient to compute and with
   probabilistic guarantees, in that the intervals cover with arbitrary
   probability the STL robustness values relative to the stochastic
   evolution of the system. To do so, we take a machine-learning approach
   and leverage recent advances in conformal inference for quantile
   regression, thereby avoiding expensive Monte Carlo simulations at
   runtime to estimate the intervals. We also show how our monitors can be
   combined in a compositional manner to handle composite formulas, without
   retraining the predictors or sacrificing the guarantees. We further
   equip QPM with techniques to ensure conditional validity of the
   prediction intervals, i.e., such that the probabilistic guarantees hold
   relative to any state of the system (or any satisfaction value), thereby
   significantly enhancing the consistency and reliability of the resulting
   monitor. We demonstrate the effectiveness and scalability of QPM over a
   benchmark of five discrete-time stochastic processes with varying
   degrees of complexity, including a stochastic multi-agent system.},
Type = {Article},
Affiliation = {Cairoli, F (Corresponding Author), Univ Trieste, Dept Math Informat \& Geosci, Trieste, Italy.
   Cairoli, Francesca; Bortolussi, Luca, Univ Trieste, Dept Math Informat \& Geosci, Trieste, Italy.
   Kuipers, Tom; Paoletti, Nicola, Kings Coll London, Dept Informat, London, England.},
DOI = {10.1016/j.nahs.2025.101606},
EarlyAccessDate = {MAY 2025},
Article-Number = {101606},
Keywords = {Predictive monitoring; Stochastic process; Conformal quantile
   regression; Multi-agent; Conditional validity},
Keywords-Plus = {MODEL CHECKING; APPROXIMATION},
Author-Email = {francesca.cairoli@units.it},
