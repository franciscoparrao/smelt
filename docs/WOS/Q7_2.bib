}

@incollection{ WOS:000687839601010,
Author = {Schaufele, Daniel and Kasparick, Martin and Schwardmann, Jens and
   Morgenroth, Johannes and Stanczak, Slawomir},
Book-Group-Author = {IEEE},
Title = {Terminal-Side Data Rate Prediction For High-Mobility Users},
Booktitle = {2021 IEEE 93RD VEHICULAR TECHNOLOGY CONFERENCE (VTC2021-SPRING)},
Series = {IEEE Vehicular Technology Conference VTC},
Year = {2021},
Abstract = {The possibility of predicting Quality of Service, and particularly data
   rates, in mobile networks will enable new applications for future
   automated and connected mobility, such as teleoperated driving. Since
   network data is difficult to acquire and usually of low granularity,
   robust prediction approaches are required that need to be trained with
   data sets and measurements generated by end devices. In this paper, we
   present uplink and downlink data sets, measured in extensive drive
   tests, that are made available for the evaluation of machine learning
   methods. Based on this data, we compare the data rate prediction
   performance in uplink and downlink for neural network, random forest and
   gradient boosting approaches. Our results show a significantly higher
   achievable accuracy in uplink than in downlink, and that, even with
   reduced feature sets, gradient boosting is particularly suited for the
   prediction task. Moreover, we investigate the use of quantile estimation
   methods for predicting bounds on the achievable data rate. We show that
   conformalized approaches, both based on neural networks and random
   forests, can predict quantiles with very high accuracy.},
Type = {Proceedings Paper},
Affiliation = {Schäufele, D (Corresponding Author), Fraunhofer Heinrich Hertz Inst, Wireless Commun \& Networks, Berlin, Germany.
   Schaufele, Daniel; Kasparick, Martin; Stanczak, Slawomir, Fraunhofer Heinrich Hertz Inst, Wireless Commun \& Networks, Berlin, Germany.
   Schwardmann, Jens; Morgenroth, Johannes, Robert Bosch GmbH, Corp Res, Hildesheim, Germany.},
