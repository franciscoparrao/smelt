DOI = {10.1109/TSM.2023.3270230},
Keywords = {Index Terms-Conformal prediction; line edge roughness; machine learning;
   quantile regression; uncertainty quantification},
Author-Email = {nini16@tamu.edu},
Number-of-Cited-References = {35},
Times-Cited = {2},
