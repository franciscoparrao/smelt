@article{ WOS:001631518500001,
Author = {Xu, Yikai and Xiong, Ziyang and Lin, Bo and Chen, Zhao},
Title = {Dynamic modeling of building energy consumption using quantile-based
   feature selection and varying-coefficient models},
Journal = {ENERGY AND BUILDINGS},
Year = {2026},
Volume = {351},
Month = {JAN 15},
Abstract = {Accurate building energy prediction requires identifying key features
   and modeling their dynamic effects on energy consumption across varying
   conditions and consumption levels. This study proposes a novel framework
   combining Quantile-based Nonparametric Independent Screening (QNIS) for
   feature selection and Quantile-based Partially Linear
   Varying-Coefficient (QPLVC) model for dynamic energy modeling. QNIS
   adaptively identifies influential predictors, such as building area and
   air temperature, across quantile levels. Meanwhile QPLVC model captures
   feature effects that vary with an index feature to enhance
   interpretability. The framework is validated using both a simulated
   dataset and a real energy dataset from 20 office buildings. The results
   demonstrate the framework's competitive performance against typical
   ensemble methods. The dynamic coefficients revealed by QPLVC model show
   the U-shaped effects of building characteristics, offering actionable
   insights for retrofits planning. For computation efficiency, the QPLVC
   model has less complexity on parameter tunning and achieved 12 times
   faster than ensemble methods in training. The quantile and dynamic
   energy predictions from QPLVC model enable the building energy
   efficiency benchmarking to be dynamic, leading to more fine-grained
   evaluation with improved interpretability. The findings underscore the
   importance of selecting appropriate index features and highlight the
   framework's potential to support sustainable building operations through
   transparent, dynamic and quantile-adaptive modeling.},
Type = {Article},
Affiliation = {Chen, Z (Corresponding Author), Fudan Univ, Sch Data Sci, 220 Handan Rd, Shanghai 200433, Peoples R China.
   Lin, B (Corresponding Author), Shunde Polytech Univ, Sch Energy \& Automot Engn, East Desheng Rd, Foshan 528000, Guangdong, Peoples R China.
