Editor = {Matos, JC and Lourenco, PB and Oliveira, DV and Branco, J and Proske, D and Silva, RA and Sousa, HS},
Title = {Probabilistic Forecast of Concrete Compressive Strength Using ML},
Booktitle = {20TH INTERNATIONAL PROBABILISTIC WORKSHOP, IPW 2024},
Series = {Lecture Notes in Civil Engineering},
Year = {2024},
Volume = {494},
Pages = {281-286},
Abstract = {Concrete compressive strength is one of the critical indices of concrete
   characteristics. Researchers have developed several models to predict
   the concrete compressive strength using various machine learning
   techniques, which are considered deterministic methods. This paper aims
   to forecast the concrete compressive strength using a probabilistic
   prediction method. For this purpose, two boosting algorithms were
   selected mainly: LightGBM and XGBoost, where their combination with
   quantile regression has the ability to predict intervals and quantile
   forecasts. Quantile XGboost outperformed quantile lightGBM in all
   metrics with a lower quantile score, indicating a better quantile
   prediction and lower error values for both the RMSE and MAE for all the
   quantiles except the 0.05 quantile, where quantile lightGBM performed
   better. In the prediction of 95\% intervals, XGboost achieved better
   performance with a narrow average width equal to 0.4375 and higher
   coverage of data with a value of the prediction interval coverage
   probability equal to 0.9369.},
Type = {Proceedings Paper},
Affiliation = {Yahiaoui, A (Corresponding Author), Univ Sci \& Technol Houari Boumed USTHB, Civil Engn Fac, Dept Struct \& Mat, Built Environm Res Lab, Bp 32 El Alia, Algiers 16111, Algeria.
