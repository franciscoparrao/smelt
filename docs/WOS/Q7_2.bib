Keywords = {Combined Forecasts; LQRA; PLAQR; OPERA; Quantile Regression Neural
   Networks; COVID-19},
Keywords-Plus = {TIME-SERIES; REGRESSION},
Author-Email = {cshoko@gzu.ac.zw},
Number-of-Cited-References = {40},
Times-Cited = {5},
