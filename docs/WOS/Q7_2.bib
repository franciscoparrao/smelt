   Liu, Ying, Tianjin Univ Technol, Sch Management, Tianjin 300384, Peoples R China.},
DOI = {10.1109/ACCESS.2024.3381492},
Keywords = {Predictive models; Logic gates; Feature extraction; Long short term
   memory; Degradation; Mathematical models; Deep learning; Remaining
   useful life; eXtreme gradient boosting; multi-quantile recursive neural
   network; quantile regression; forking sequences training scheme},
Keywords-Plus = {DEGRADATION},
Author-Email = {liu@email.tjut.edu.cn},
Number-of-Cited-References = {45},
