@article{ WOS:001685854800001,
Author = {Khadka, Dinesh and Pande, Keshab Raj and Tripathi, Bhaba Prasad and
   Bajracharya, Roshan Man},
Title = {Soil Phosphatase Enzyme Activity as Influenced by Agro-Ecological Zones
   in Central Nepal},
Journal = {APPLIED AND ENVIRONMENTAL SOIL SCIENCE},
Year = {2026},
Volume = {2026},
Number = {1},
Abstract = {Soil is a dynamic ecosystem that sustains a diverse community of
   organisms, enhancing its vitality and functions. Biochemical processes
   within the soil contribute to its active nature, with enzymes produced
   by organisms and plants playing roles in reactions. Phosphatases
   hydrolyze organic phosphorus to plant-available phosphate ions. However,
   the activity of phosphatase enzymes in Nepalese soils remains poorly
   understood. To address this gap, a study was conducted to determine
   phosphatase enzyme activity variation across agro-ecological zones in
   central Nepal. A total of 225 georeferenced soil samples (75 samples
   from each zone-high-hills, mid-hills, and Terai) were collected from
   various sites within central Nepal. Standard analytical methods were
   used to assess the activity of phosphatase enzymes. Additionally, 122
   environmental covariates were collected, and a quantile regression
   random forest model was used for spatial predictions. The results showed
   variation in the activity of phosphatase enzymes, including acid
   phosphomonoesterase (AcPM), alkaline phosphomonoesterase (AlPM),
   phosphodiesterase (PD), phosphotriesterase (PT), and inorganic
   pyrophosphatase (IPP) across the agro-ecological zones. Predominance of
   AcPM (1051.55 mu g pNP g-1 dm h-1), PT (52.36 mu g pNP g-1 dm h-1), and
   IPP (916.25 mu g PO43--P g-1 dm h-1) activity was noted in the
   high-hills, while AlPM (329.14 mu g pNP g-1 dm h-1) and PD (86.08 mu g
   pNP g-1 dm h-1) activities were dominant in the mid-hills. The spatial
   distribution map, prepared using measured point data and environmental
   covariates, reflected similar patterns. The Terai region, characterized
   by longer drought periods and lower soil moisture, exhibited
   comparatively lower enzyme activity. Overall, the high-hills exhibited
   the greatest capacity to release phosphate ions (H2PO4- and HPO42-) from
   organic P pools, followed by the mid-hills and then the Terai.
   Therefore, the use of organic nutrient sources to increase phosphorus
   availability is more significant in the hilly areas compared to the
   plains.},
Type = {Article},
Affiliation = {Khadka, D (Corresponding Author), Agr \& Forestry Univ, Dept Soil Sci \& Agr Engn, Chitwan, Nepal.
   Khadka, D (Corresponding Author), Nepal Agr Res Council, Natl Soil Sci Res Ctr, Khumaltar, Lalitpur, Nepal.
   Khadka, Dinesh; Pande, Keshab Raj, Agr \& Forestry Univ, Dept Soil Sci \& Agr Engn, Chitwan, Nepal.
   Khadka, Dinesh, Nepal Agr Res Council, Natl Soil Sci Res Ctr, Khumaltar, Lalitpur, Nepal.
   Tripathi, Bhaba Prasad, Tribhuvan Univ, Inst Agr \& Anim Sci, Dept Soil Sci \& Agriengn, Kirtipur, Kathmandu, Nepal.
