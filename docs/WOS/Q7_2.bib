@article{ WOS:000471771300009,
Author = {Hepp, Tobias and Schmid, Matthias and Mayr, Andreas},
Title = {Significance Tests for Boosted Location and Scale Models with Linear
   Base-Learners},
Journal = {INTERNATIONAL JOURNAL OF BIOSTATISTICS},
Year = {2019},
Volume = {15},
Number = {1},
Month = {MAY},
Abstract = {Generalized additive models for location scale and shape (GAMLSS) offer
   very flexible solutions to a wide range of statistical analysis
   problems, but can be challenging in terms of proper model specification.
   This complex task can be simplified using regularization techniques such
   as gradient boosting algorithms, but the estimates derived from such
   models are shrunken towards zero and it is consequently not
   straightforward to calculate proper confidence intervals or test
   statistics. In this article, we propose two strategies to obtain
   p-values for linear effect estimates for Gaussian location and scale
   models based on permutation tests and a parametric bootstrap approach.
   These procedures can provide a solution for one of the remaining
   problems in the application of gradient boosting algorithms for
   distributional regression in biostatistical data analyses. Results from
   extensive simulations indicate that in low-dimensional data both
   suggested approaches are able to hold the type-I error threshold and
   provide reasonable test power comparable to the Wald-type test for
   maximum likelihood inference. In high-dimensional data, when gradient
   boosting is the only feasible inference for this model class, the power
   decreases but the type-I error is still under control. In addition, we
   demonstrate the application of both tests in an epidemiological study to
   analyse the impact of physical exercise on both average and the
   stability of the lung function of elderly people in Germany.},
Type = {Article},
Affiliation = {Hepp, T (Corresponding Author), Rheinische Friedrich Wilhelms Univ Bonn, Inst Med Biometrie Informat \& Epidemiol, Med Fak, Bonn, Germany.
   Hepp, T (Corresponding Author), Friedrich Alexander Univ Erlangen Nurnberg, Med Fak, Inst Med Informati K Biometrie \& Epidemiol, Erlangen, Germany.
   Hepp, Tobias; Schmid, Matthias; Mayr, Andreas, Rheinische Friedrich Wilhelms Univ Bonn, Inst Med Biometrie Informat \& Epidemiol, Med Fak, Bonn, Germany.
   Hepp, Tobias, Friedrich Alexander Univ Erlangen Nurnberg, Med Fak, Inst Med Informati K Biometrie \& Epidemiol, Erlangen, Germany.},
DOI = {10.1515/ijb-2018-0110},
Article-Number = {20180110},
Keywords = {boosting; GAMLSS; regularized regression; permutation test; parametric
   bootstrap},
Keywords-Plus = {VARIABLE SELECTION; LUNG-FUNCTION; PHYSICAL-ACTIVITY;
   LOGISTIC-REGRESSION; PERMUTATION TEST; ADDITIVE-MODELS; ALGORITHMS;
   MORTALITY; INFERENCE; SURVIVAL},
Author-Email = {tobias.hepp@uk-erlangen.de},
