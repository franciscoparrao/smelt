DOI = {10.1109/ACCESS.2025.3617532},
Keywords = {Forecasting; Biological system modeling; Predictive models; Renewable
   energy sources; Accuracy; Data models; Ensemble learning; Adaptation
   models; Stacking; Meteorology; STDSE-Net; geographic information systems
   (GIS); CO2 emission forecasting; spatio-temporal modeling; dynamic
   stacking ensemble; hybrid ensemble learning; particle swarm optimization
   (PSO); quantile regression; sustainable energy systems; machine
   learning; spatial-temporal cross-validation; AI for climate policy;
   renewable energy forecasting; meta-learning; XGBoost-geo},
Author-Email = {fsalamri@pnu.edu.sa},
Number-of-Cited-References = {41},
Times-Cited = {1},
Unique-ID = {WOS:001662945100015},
}

@article{ WOS:001680578600008,
Author = {Gneiting, Tilmann and Biegert, Tobias and Kraus, Kristof and Walz,
   Eva-Maria and Jordan, Alexander I. and Lerch, Sebastian},
Title = {Probabilistic Measures Afford Fair Comparisons of AIWP and NWP Model
   Output},
Journal = {ARTIFICIAL INTELLIGENCE FOR THE EARTH SYSTEMS},
Year = {2026},
Volume = {5},
Number = {1},
Month = {JAN},
Abstract = {We introduce a new measure for fair and meaningful comparisons of
   single-valued output from artificial-intelligence-based weather
   prediction (AIWP) and numerical weather prediction (NWP) models, called
   potential continuous ranked probability score (PCRPS). In a nutshell, we
   subject the deterministic backbone of physics-based and data-driven
   models post hoc to the same statistical postprocessing technique,
   namely, isotonic distributional regression (IDR). Then, we find PCRPS as
   the mean continuous ranked probability score (CRPS) of the postprocessed
   probabilistic forecasts. The nonnegative PCRPS measure quantifies
   potential predictive performance and is invariant under strictly
   increasing transformations of the model output. PCRPS attains its most
   desirable value of zero if, and only if, the weather outcome is a fixed,
   nondecreasing function of the model output. The PCRPS measure is
   recorded in the unit of the outcome, has an upper bound of one-half
   times the mean absolute difference between outcomes, and serves as a
   proxy for the mean CRPS of real-time, operational probabilistic
   products. When applied to WeatherBench 2 data, our approach demonstrates
   that the data-driven GraphCast model outperforms the leading
   physics-based European Centre for Medium-Range Weather Forecasts (ECMWF)
   high-resolution (HRES) model. Furthermore, the PCRPS measure for the
   HRES and GraphCast models aligns exceptionally well with the mean CRPS
   of the operational ECMWF ensemble and the GenCast ensemble,
   respectively. Across application domains, our approach affords
   comparisons of single-valued forecasts in settings where the
   prespecification of a loss function which is the usual, and principally
   superior, procedure in forecast contests, administrative, and benchmark
   settings places competitors on unequal footings. SIGNIFICANCE STATEMENT:
   Until recently, weather forecasts have relied on physics-based numerical
   weather prediction (NWP) models. Since late 2022, the advent of
   artificial-intelligence-based weather prediction (AIWP) models that
   learn exclusively from data, without the laws of physics being invoked,
   challenges extant practice. While AIWP models might eventually supersede
   NWP models, meaningful comparisons of forecast quality remain difficult
   due to differences in training schemes, initial conditions, and
   postprocessing. Our paper introduces a new measure, called potential
   continuous ranked probability score (PCRPS), that accounts for these
   differences and, therefore, affords fair comparisons. Using benchmark
   data, we confirm the superiority of AIWP models for gridpoint-based
   global forecasts of surface weather variables at lead times up to 10
   days.},
Type = {Article},
Affiliation = {Gneiting, T (Corresponding Author), Heidelberg Inst Theoret Studies, Computat Stat Grp, Heidelberg, Germany.
   Gneiting, T (Corresponding Author), Karlsruhe Inst Technol, Inst Stat, Karlsruhe, Germany.
   Gneiting, Tilmann; Kraus, Kristof; Walz, Eva-Maria; Jordan, Alexander I.; Lerch, Sebastian, Heidelberg Inst Theoret Studies, Computat Stat Grp, Heidelberg, Germany.
   Gneiting, Tilmann; Biegert, Tobias; Kraus, Kristof; Walz, Eva-Maria; Jordan, Alexander I.; Lerch, Sebastian, Karlsruhe Inst Technol, Inst Stat, Karlsruhe, Germany.
   Lerch, Sebastian, Univ Marburg, Dept Math \& Comp Sci, Marburg, Germany.},
DOI = {10.1175/AIES-D-25-0054.1},
Article-Number = {e250054},
Keywords = {Forecast verification/skill; Predictability; Other artificial
   intelligence/machine learning},
Keywords-Plus = {PREDICTION; WEATHER; FORECASTS},
Author-Email = {tilmann.gneiting@h-its.org},
Number-of-Cited-References = {42},
Times-Cited = {0},
Unique-ID = {WOS:001680578600008},
}

@incollection{ WOS:001596385600012,
Author = {Sangalli, Sara and Sarwin, Gary and Erdil, Ertunc and Serra, Carlo and
   Carretta, Alessandro and Staartjes, Victor and Konukoglu, Ender},
Editor = {Gee, JC and Alexander, DC and Hong, J and Iglesias, JE and Sudre, CH and Venkataraman, A and Golland, P and Kim, JH and Park, J},
Title = {Conformal Forecasting for Surgical Instrument Trajectory},
Booktitle = {MEDICAL IMAGE COMPUTING AND COMPUTER ASSISTED INTERVENTION - MICCAI
   2025, PT IX},
Series = {Lecture Notes in Computer Science},
Year = {2026},
Volume = {15968},
Pages = {117-127},
Abstract = {Forecasting surgical instrument trajectories and predicting the next
   surgical action recently started to attract attention from the research
   community. Both these tasks are crucial for automation and assistance in
   endoscopy surgery. Given the safety-critical nature of these tasks,
   reliable uncertainty quantification is essential. Conformal prediction
   is a fast-growing and widely recognized framework for uncertainty
   estimation in machine learning and computer vision, offering
   distribution-free, theoretically valid prediction intervals. In this
   work, we explore the application of standard conformal prediction and
   conformalized quantile regression to estimate uncertainty in forecasting
   surgical instrument motion, i.e., predicting direction and magnitude of
   surgical instruments' future motion. We analyze and compare their
   coverage and interval sizes, assessing the impact of multiple hypothesis
   testing and correction methods. Additionally, we show how these
   techniques can be employed to produce useful uncertainty heatmaps. To
   the best of our knowledge, this is the first study applying conformal
   prediction to surgical guidance, marking an initial step toward
   constructing principled prediction intervals with formal coverage
   guarantees in this domain (The code is available at this link).},
Type = {Proceedings Paper},
Affiliation = {Sangalli, S (Corresponding Author), Swiss Fed Inst Technol, Comp Vis Lab, Zurich, Switzerland.
   Sangalli, Sara; Sarwin, Gary; Erdil, Ertunc; Konukoglu, Ender, Swiss Fed Inst Technol, Comp Vis Lab, Zurich, Switzerland.
   Serra, Carlo; Carretta, Alessandro; Staartjes, Victor, Univ Hosp Zurich, Dept Neurosurg, Zurich, Switzerland.
   Carretta, Alessandro, Univ Bologna, Dept Biomed \& Neuromotor Sci, Bologna, Italy.},
DOI = {10.1007/978-3-032-05114-1\_12},
Keywords = {Conformal prediction; Forecasting; Robotic surgery},
Keywords-Plus = {PREDICTION},
Author-Email = {sara.sangalli@vision.ee.ethz.ch},
