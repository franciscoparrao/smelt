DOI = {10.1016/j.ijforecast.2015.11.013},
Keywords = {Probabilistic forecast; Ensemble methods; Renewable energy; Quantile
   regression; Gradient boosting regression; Quantile regression forest},
Author-Email = {nagyg@tmit.bme.hu},
Number-of-Cited-References = {9},
