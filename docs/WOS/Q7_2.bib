   Hsu, Chien-Tai; Hsu, Bo-Kai, Yungui Technol Co Ltd, 45 Xinghua Lane,Lukang Township, Changhua 505026, Taiwan.},
DOI = {10.3390/math13213460},
Article-Number = {3460},
Keywords = {RUL; availability analysis; XGBoost; NARX; survival analysis; UAV BLDC
   motor prognostics},
