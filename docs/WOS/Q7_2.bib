   Nichols, Thomas E., Univ Oxford, Oxford Big Data Inst, Nuffield Dept Populat Hlth, Li Ka Shing Ctr Hlth Informat \& Discovery, Oxford OX3 7LF, England.
   Nichols, Thomas E., Univ Oxford, Nuffield Dept Clin Neurosci, Wellcome Ctr Integrat Neuroimaging, FMRIB, Oxford OX3 9DU, England.},
DOI = {10.1016/j.neuroimage.2020.116938},
Article-Number = {116938},
Keywords = {Brain age; Scalar-on-image regression; Prediction intervals; Quantile
   regression},
Keywords-Plus = {ALZHEIMERS-DISEASE; MODELS; ESTIMATOR; LOCATION; ATROPHY},
