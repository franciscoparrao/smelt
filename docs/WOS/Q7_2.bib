   Li, Gucheng, Huazhong Agr Univ, Hubei Digital Agr Res Inst, Wuhan, Peoples R China.},
DOI = {10.22434/IFAMR1134},
Keywords = {machine learning; probability density forecasting; quantile regression
   forest; yield prediction},
Keywords-Plus = {CROP YIELD; NEURAL-NETWORK; PREDICTION; MODEL; CONSUMPTION; LASSO;
   CHINA; AREA},
