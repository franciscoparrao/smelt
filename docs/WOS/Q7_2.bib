   Gandhi, Oktoviano; Rodriguez-Gallegos, Carlos D., NUS, SERIS, Singapore 117574, Singapore.
   Sharma, Anurag, Newcastle Univ Int Singapore, Dept Elect \& Power Engn, Singapore, Singapore.},
Keywords = {Probabilistic forecasting; stochastic gradient boosting machine;
   uncertainty; photovoltaic; prediction interval; quantile regression},
Keywords-Plus = {WIND POWER-GENERATION; PREDICTION INTERVALS},
Number-of-Cited-References = {17},
