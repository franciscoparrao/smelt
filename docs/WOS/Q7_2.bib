   Xu, Bin, Hohai Univ, Key Lab Hydrol Cycle \& Hydrodynam Syst, Minist Water Resources, Nanjing 210098, Peoples R China.},
DOI = {10.1016/j.jhydrol.2025.134214},
EarlyAccessDate = {SEP 2025},
