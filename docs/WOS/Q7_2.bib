   wangjinggai01@stu.shmtu.edu.cn
   qyhu@shmtu.edu.cn
   huzhihui@jmu.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {7},
Unique-ID = {WOS:001365437100001},
}

@article{ WOS:001350964200001,
Author = {Ruiz-Abellon, Maria Carmen and Fernandez-Jimenez, Luis Alfredo and
   Guillamon, Antonio and Gabaldon, Antonio},
Title = {Applications of Probabilistic Forecasting in Demand Response},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2024},
Volume = {14},
Number = {21},
Month = {NOV},
Abstract = {Studies on probabilistic demand forecasting remain relatively limited
   compared with point forecasting, despite it being especially valuable
   for operational and planning purposes. This paper demonstrates different
   applications of probabilistic forecasting in demand response, together
   with Physical-Based Load Models. The first application shows how to
   determine the percentage of uncertainty potentially covered by demand
   response throughout a day, whereas the second application deals with
   obtaining the number of consumers that would be needed in demand
   response actions for a desired percentage of coverage. Finally, in the
   third application, a specific hourly strategy is proposed for demand
   response policies. These applications facilitate the aggregator's energy
   purchasing in the market and the planning of subsequent consumption
   adjustments through demand response to minimize deviations from the
   purchased energy. The approach is illustrated using hourly demand data
   from a small Spanish city, and two machine learning methods were used to
   produce a set of probabilistic forecasts and compare results: Linear
   Quantile Regression and a Quantile Regression Forest. Main results show
   a significant reduction in deviations from the purchased energy after
   applying the proposed strategy, especially in the case of the
   forecasting method being less accurate (40.95\% and 33.62\% of
   reduction, respectively).},
Type = {Article},
Affiliation = {Gabaldón, A (Corresponding Author), Tech Univ Cartagena, Power Syst Grp, Cartagena 30202, Spain.
   Ruiz-Abellon, Maria Carmen; Guillamon, Antonio, Tech Univ Cartagena, Dept Appl Math \& Stat, Cartagena 30202, Spain.
   Fernandez-Jimenez, Luis Alfredo, Univ La Rioja, Dept Elect Engn, Logrono 26004, Spain.
   Gabaldon, Antonio, Tech Univ Cartagena, Power Syst Grp, Cartagena 30202, Spain.},
DOI = {10.3390/app14219716},
Article-Number = {9716},
Keywords = {short-term load forecasting; probabilistic forecasting; linear quantile
   regression; quantile regression forest; demand response},
Keywords-Plus = {POWER; QUANTILE; MODEL},
Author-Email = {maricarmen.ruiz@upct.es
   luisalfredo.fernandez@unirioja.es
