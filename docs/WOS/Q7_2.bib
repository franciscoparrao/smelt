@article{ WOS:001631524300011,
Author = {La, Hung and Uddin, Minhaz and Nguyen, Tan},
Title = {Reliable inverse optimization of rice husk ash concrete via copula-based
   design spaces and conformal quantile surrogates},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {301},
Month = {MAR 10},
Abstract = {Reliable compressive strength prediction is critical for the sustainable
   design of rice husk ash concrete. Conventional machine learning studies
   often rely on Monte Carlo or naive random sampling, which overlook key
   dependencies among mix variables, leading to unrealistic designs and
   reduced model reliability. This study presents an integrated framework
   combining copula-based sampling, quantile Categorical Boosting modeling,
   and uncertainty-informed inverse optimization. A Gaussian copula
   generates synthetic rice husk ash concrete mixtures that preserve
   observed marginal distributions and inter-variable correlations. A
   quantile-based Categorical Boosting model, optimized via Tree-structured
   Parzen Estimator, predicts mean and bound estimates of strength, with
   intervals calibrated through conformal prediction to ensure statistical
   validity. Across 30 repeated random data splits, the model achieved a
   mean test R2 of 0.966 and produced valid 90 \% prediction intervals with
   an empirical coverage of 89.6 \% on the test set, confirming stable
   generalization and well-calibrated uncertainty. The inverse
   multi-objective optimization procedure identified mix designs that
   simultaneously minimize cement usage-achieving reductions exceeding 65
   kg/m3-while controlling predictive uncertainty and satisfying strength
   constraints under high-confidence lower bounds. Experimental validation
   further demonstrated that nearly all measured strengths were accurately
   captured within the predicted intervals, while external validation on an
   independent dataset from the literature achieved R2 = 0.832, with 86.7
   \% of validation samples falling within the predicted uncertainty
   interval width. These findings confirm the feasibility, reliability, and
   adaptability of the proposed framework, offering a novel pathway for
   performance-based, environmentally conscious, and high-reliability
   concrete mix optimization.},
Type = {Article},
Affiliation = {Nguyen, T (Corresponding Author), Ton Duc Thang Univ, Fac Civil Engn, Smart Comp Civil Engn Res Grp, Ho Chi Minh City, Vietnam.
   La, Hung, Ton Duc Thang Univ, Fac Civil Engn, Ho Chi Minh City, Vietnam.
   Uddin, Minhaz, Stamford Univ Bangladesh, Dept Civil Engn, Dhaka 1217, Bangladesh.
   Nguyen, Tan, Ton Duc Thang Univ, Fac Civil Engn, Smart Comp Civil Engn Res Grp, Ho Chi Minh City, Vietnam.},
DOI = {10.1016/j.eswa.2025.130582},
EarlyAccessDate = {NOV 2025},
