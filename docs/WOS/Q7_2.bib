Keywords-Plus = {PREDICTION},
Author-Email = {nadhir.alansari@ltu.se
   m.majeed@uoa.edu.iq},
Number-of-Cited-References = {59},
Times-Cited = {27},
Unique-ID = {WOS:000925067300092},
}

