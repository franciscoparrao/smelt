   combination; machine learning; neural networks; solar irradiance
   forecasting; support vector regression},
Keywords-Plus = {SUPPORT VECTOR MACHINE; HYBRID APPROACH; RADIATION; REGRESSION;
   TEMPERATURE},
Author-Email = {caston.sigauke@univen.ac.za},
