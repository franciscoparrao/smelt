   Gandhi, Oktoviano, Natl Univ Singapore, Solar Energy Res Inst Singapore, Singapore 117576, Singapore.
   Rajagopal, Ram; Tan, Chin-Woo, Stanford Univ, Dept Elect Engn, Stanford, CA 94305 USA.},
DOI = {10.1109/TSG.2020.2995777},
Keywords = {Load forecasting; Artificial neural networks; Probabilistic logic;
   Forecasting; Machine learning; Training; Natural language processing;
   Probabilistic load forecasting; skip connections; quantile regression
   neural network; ResNet; deep learning},
