@incollection{ WOS:001661448300615,
Author = {Zhang, Xuelin and Chen, Hong and Wu, Lingjuan},
Book-Group-Author = {ACM},
Title = {Interpretable Meta-weighting Sparse Neural Additive Networks for
   Datasets with Label Noise and Class Imbalance},
Booktitle = {PROCEEDINGS OF THE 34TH ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2025},
Year = {2025},
Pages = {5505-5509},
Abstract = {Black-box neural networks are inherently inscrutable, and their
   widespread use has triggered significant societal issues in crucial
   areas such as healthcare, finance and safety. In these high-stakes
   decision-making domains, the deployment of machine learning algorithms
   requires not only prediction accuracy but also their interpretability
   and robustness against data distribution shifts, such as outliers, label
   noise, and category imbalance. In this work, we propose a novel
   Meta-weighted Sparse Neural Additive Model (MSp-NAM), which offers
   robustness through an efficient bilevel weighting policy and inherits
   strong explainability and representation capabilities from the additive
   modeling strategy. Furthermore, empirical results across multiple
   synthetic and real datasets, under various distribution shifts,
   demonstrate that MSpNAM can scale effectively and achieve superior
   performance in terms of robustness, interpretability, and
   anti-forgetting compared to some of the latest baselines.},
Type = {Proceedings Paper},
Affiliation = {Wu, LJ (Corresponding Author), Huazhong Agr Univ, Wuhan, Hubei, Peoples R China.
   Zhang, Xuelin; Chen, Hong; Wu, Lingjuan, Huazhong Agr Univ, Wuhan, Hubei, Peoples R China.},
DOI = {10.1145/3746252.3760829},
Keywords = {Bilevel optimization; sparse neural additive model; data distributional
   shifts; interpretability; catastrophic forgetting},
