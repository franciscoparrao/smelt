   Adhikari, Kabindra, USDA ARS, Grassland Soil \& Water Res Lab, Temple, TX 76502 USA.
   Kumar, Lalit, EastCoast Geospatial Consultants, Armidale, NSW 2350, Australia.},
DOI = {10.1016/j.geodrs.2022.e00568},
EarlyAccessDate = {AUG 2022},
