@incollection{ WOS:000458741200013,
Author = {Dartois, Jean-Emile and Knefati, Anas and Boukhobza, Jalil and Barais,
   Olivier},
Book-Group-Author = {IEEE},
Title = {Using Quantile Regression for Reclaiming Unused Cloud Resources while
   achieving SLA},
Booktitle = {2018 16TH IEEE INTERNATIONAL CONFERENCE ON CLOUD COMPUTING TECHNOLOGY
   AND SCIENCE (CLOUDCOM 2018)},
Series = {International Conference on Cloud Computing Technology and Science},
Year = {2018},
Pages = {89-98},
Abstract = {Although Cloud computing techniques have reduced the total cost of
   ownership thanks to virtualization, the average usage of resources
   (e.g., CPU, RAM, Network, I/O) remains low. To address such issue, one
   may sell unused resources. Such a solution requires the Cloud provider
   to determine the resources available and estimate their future use to
   provide availability guarantees. This paper proposes a technique that
   uses machine learning algorithms (Random Forest, Gradient Boosting
   Decision Tree, and Long Short Term Memory) to forecast 24-hour of
   available resources at the host level. Our technique relies on the use
   of quantile regression to provide a flexible trade-off between the
   potential amount of resources to reclaim and the risk of SLA violations.
   In addition, several metrics (e.g., CPU, RAM, disk, network) were
   predicted to provide exhaustive availability guarantees. Our methodology
   was evaluated by relying on four in production data center traces and
   our results show that quantile regression is relevant to reclaim unused
   resources. Our approach may increase the amount of savings up to 20\%
   compared to traditional approaches.},
Type = {Proceedings Paper},
Affiliation = {Dartois, JE (Corresponding Author), B Com Inst Res \& Technol, Cesson Sevigne, France.
   Dartois, JE (Corresponding Author), Univ Rennes, INRIA, CNRS, IRISA, Rennes, France.
   Dartois, Jean-Emile; Knefati, Anas; Boukhobza, Jalil; Barais, Olivier, B Com Inst Res \& Technol, Cesson Sevigne, France.
