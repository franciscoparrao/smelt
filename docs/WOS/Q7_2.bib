   yuan@jlu.edu.cn},
Number-of-Cited-References = {12},
Times-Cited = {3},
Unique-ID = {WOS:000994420700325},
}

@incollection{ WOS:000854091100153,
Author = {Moews, Stefan and Ahrens, Marisa and Becker, Christian},
Book-Group-Author = {IEEE},
Title = {Comparing R-Vine Copulas and Quantile Regression Forests for Reliability
   Forecasting of Renewable Energies},
Booktitle = {2022 IEEE 21ST MEDITERRANEAN ELECTROTECHNICAL CONFERENCE (IEEE MELECON
   2022)},
Series = {IEEE Mediterranean Electrotechnical Conference-MELECON},
Year = {2022},
Pages = {872-877},
Abstract = {This work presents the comparison of R-Vine Copulas (RVCs) and Quantile
   Regression Forests (QRF) used to forecast the reliable power output of a
   pool of wind power plants (WPPs) and solar power plants (SPPs). Both
   methods have been used to forecast the probability of deviations from
   the deterministic power forecast of WPPs and SPPs but have never been
   compared using the same basic data set for the parameterization and
   validation. RVCs are a mathematical model for the description of
   stochastic dependencies, while QRF is a data-driven machine learning
   model, which describes the relation between one or more predictor
   variables and a response variable by using a combination of
   decision-trees. Both methods will be explained briefly and applied to
   predict the power of different exemplary pools of WPPs and SPPs with the
   same basic weather data set. Our paper contributes by giving a
   quantitative comparison in reliability and performance of the generated
   forecasts as well as formulating recommendations for the use cases of
   both tools. The results show that QRF forecast with a higher reliability
   but are more limited in their use case then RVCs.},
Type = {Proceedings Paper},
Affiliation = {Möws, S (Corresponding Author), Hamburg Univ Technol, Inst Elect Power \& Energy Technol, Hamburg, Germany.
   Moews, Stefan; Ahrens, Marisa; Becker, Christian, Hamburg Univ Technol, Inst Elect Power \& Energy Technol, Hamburg, Germany.},
DOI = {10.1109/MELECON53508.2022.9842990},
Keywords = {R-Vine Copula; Quantile Regression Forests; forecasting; Renewable
   Energies; stochastic dependencies},
Author-Email = {stefan.moews@tuhh.de
   marisa.ahrens@tuhh.de
   c.becker@tuhh.de},
Number-of-Cited-References = {16},
Times-Cited = {0},
Unique-ID = {WOS:000854091100153},
}

@incollection{ WOS:000851561800029,
Author = {Gemeda, Dejenie Birile and Stork, Wilhelm},
Book-Group-Author = {IEEE},
Title = {Probabilistic Ampacity Forecasting of Dynamic Line Rating Considering
   TSOs Risk-Averse},
Booktitle = {2022 6TH INTERNATIONAL CONFERENCE ON GREEN ENERGY AND APPLICATIONS
   (ICGEA 2022)},
Year = {2022},
Pages = {176-181},
Abstract = {High penetration of renewable energy resources with highly probabilistic
   loading in the emerging power transmission network is forcing
   Transmission System Operators (TSOs) to utilize their resources to the
   exhaustive extent by making use of intelligent transmission network
   management methods. The real-time ampacity of overhead conductors is
   tremendously fluctuating due to its dependence on weather conditions. As
   a result, the real-time rating of the overhead conductor is better
   exploited by using dynamic line rating (DLR) than traditional
   conservative static rating, which depends on the worst-case weather
   conditions. Since there are high uncertainties associated with point
   forecast DLR ampacity calculation, probabilistic means of DLR
   forecasting method provide the possibility for short-term planning and
   real-time overhead transmission line ampacity monitoring, thus enabling
   the transmission network to run smoothly without harm to the entire
   network. In this study, a real-time DLR overhead transmission line is
   formulated, giving 24-hour ahead ampacity prediction and loading limits
   by using quantile regression forest (QRF) machine learning model with
   different quantiles. The proposed method provides better enhancement and
   safe operation for the lowest quantiles to mitigate decision-makers
   risk-averse.},
Type = {Proceedings Paper},
Affiliation = {Gemeda, DB (Corresponding Author), Karlsruhe Inst Technol, Inst Informat Proc Technol, Karlsruhe, Germany.
   Gemeda, Dejenie Birile; Stork, Wilhelm, Karlsruhe Inst Technol, Inst Informat Proc Technol, Karlsruhe, Germany.},
DOI = {10.1109/ICGEA54406.2022.9792110},
Keywords = {dynamic line rating; quartile regression forest; overhead transmission
   lines; probabilistic forecasting; ampacity forecasting},
Author-Email = {dejenie.gemeda@kit.edu
   wilhelm.stork@kit.edu},
Number-of-Cited-References = {43},
Times-Cited = {1},
Unique-ID = {WOS:000851561800029},
