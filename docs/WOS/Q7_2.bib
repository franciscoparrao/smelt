   Tan, Falong, Hunan Univ, Dept Stat, Changsha 410006, Peoples R China.},
DOI = {10.1007/s11222-024-10414-8},
Article-Number = {92},
Keywords = {Generalized measure of correlation; Quantile correlation; Machine
   learning methods; Confidence interval},
Keywords-Plus = {GENOME-WIDE ASSOCIATION; STATISTICAL DEPENDENCE; REGRESSION;
   HERITABILITY; TRAITS},
