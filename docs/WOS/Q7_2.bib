@article{ WOS:000454935100004,
Author = {Fouedjio, Francky and Klump, Jens},
Title = {Exploring prediction uncertainty of spatial data in geostatistical and
   machine learning approaches},
Journal = {ENVIRONMENTAL EARTH SCIENCES},
Year = {2019},
Volume = {78},
Number = {1},
Month = {JAN},
Abstract = {Geostatistical methods such as kriging with external drift (KED) as well
   as machine learning techniques such as quantile regression forest (QRF)
   have been extensively used for the modeling and prediction of spatially
   distributed continuous variables when auxiliary information is available
   everywhere within the region under study. In addition to providing
   predictions, both methods are able to deliver a quantification of the
   uncertainty associated with the prediction. In this paper, kriging with
   external drift and quantile regression forest are compared with respect
   to their ability to deliver reliable predictions and prediction
   uncertainties of spatial data. The comparison is carried out through
   both synthetic and real-world spatial data. The results indicate that
   the superiority of KED over QRF can be expected when there is a linear
   relationship between the variable of interest and auxiliary variables,
   and the variable of interest shows a strong or weak spatial correlation.
   In other hand, the superiority of QRF over KED can be expected when
   there is a non-linear relationship between the variable of interest and
   auxiliary variables, and the variable of interest exhibits a weak
   spatial correlation. Moreover, when there is a non-linear relationship
   between the variable of interest and auxiliary variables, and the
   variable of interest shows a strong spatial correlation, one can expect
   QRF outperforms KED in terms of prediction accuracy but not in terms of
   prediction uncertainty accuracy.},
Type = {Article},
Affiliation = {Fouedjio, F (Corresponding Author), Stanford Univ, Dept Geol Sci, 367 Panama St, Stanford, CA 94305 USA.
   Fouedjio, Francky, Stanford Univ, Dept Geol Sci, 367 Panama St, Stanford, CA 94305 USA.
   Klump, Jens, CSIRO Mineral Resources, 26 Dick Perry Ave, Kensington, WA 6151, Australia.},
DOI = {10.1007/s12665-018-8032-z},
Article-Number = {38},
Keywords = {Auxiliary information; Prediction uncertainty; Kriging with external
   drift; Quantile regression forest; Spatial data},
Keywords-Plus = {INTERPOLATION; FOREST},
Author-Email = {francky.fouedjio@stanford.edu
   jens.klump@csiro.au},
Number-of-Cited-References = {37},
Times-Cited = {50},
Unique-ID = {WOS:000454935100004},
}

@incollection{ WOS:000618530300091,
Author = {Jardeleza, Donie S. and Aliac, Chris Jordan G. and Maravillas, Elmer A.},
Book-Group-Author = {IEEE},
Title = {Predictive Modeling of Compressive Strength composition values for
   structural studies using K-medoids clustering and Quantile Regression
   Forests},
Booktitle = {2019 IEEE 11TH INTERNATIONAL CONFERENCE ON HUMANOID, NANOTECHNOLOGY,
   INFORMATION TECHNOLOGY, COMMUNICATION AND CONTROL, ENVIRONMENT, AND
   MANAGEMENT (HNICEM)},
Series = {IEEE International Conference on Humanoid Nanotechnology Information
   Technology Communication and Control Environment and Management},
Year = {2019},
Abstract = {The determination of structural strength and reliability begins from its
   precise concrete composition mixture and appropriate material selection.
   Concrete is the primary entity in the structural industry, and requires
   competent skills and expertise to understand and attain an ideal
   compressive strength. However, in most instances nowadays, innovative
   components such as plasticizer, fly ash, and blast furnace slag have
   been found to contribute to its compactness and promote the cementitious
   property of the compound. This paper presents the combination of
   clustering and regression technique to deliver comparable values that
   will help in the conceptualization of insights from visualized results.
   By the aid of a public dataset comprising of 1030 samples, the data
   points of the dataset will be categorized and the resulting compressive
   strength will be classified and forecasted through the use of k-medoids
   clustering and quantile regression forest. Clustering through k- medoids
   minimizes noise and outliers as compared to the conventional k-means.
   Identification of medoids in every cluster promotes averaging of points
   in terms of similarity and dissimilarity. Overall, an optimal prediction
   interval is generated for all observations in predicting compressive
   strength. The 90\% interval limits was obtained by predicting the 5th
   and 95th percentile.},
Type = {Proceedings Paper},
Affiliation = {Jardeleza, DS (Corresponding Author), Cebu Inst Technol Univ, Cebu, Philippines.
   Jardeleza, Donie S.; Aliac, Chris Jordan G.; Maravillas, Elmer A., Cebu Inst Technol Univ, Cebu, Philippines.},
DOI = {10.1109/hnicem48295.2019.9072818},
Keywords = {Clustering; Data Mining; K-Medoids; Machine Learning; Quantile
   Regression Forest},
Keywords-Plus = {CONCRETE},
Author-Email = {donie.jardeleza@live.com.ph},
Number-of-Cited-References = {11},
Times-Cited = {0},
Unique-ID = {WOS:000618530300091},
}

@incollection{ WOS:000502609500058,
Author = {Molinar, Gabriela and Fan, Lintao Toni and Stork, Wilhelm},
Book-Group-Author = {IEEE},
Title = {Ampacity forecasting: an approach using Quantile Regression Forests},
Booktitle = {2019 IEEE POWER \& ENERGY SOCIETY INNOVATIVE SMART GRID TECHNOLOGIES
   CONFERENCE (ISGT)},
Series = {Innovative Smart Grid Technologies},
Year = {2019},
Abstract = {With an increasing amount of renewable energy sources, the electrical
   network should be efficiently used. In this article Quantile Regression
   Forests were implemented to forecast two days ahead the maximum amount
   of current that can be transmitted through an overhead line without
   damaging the conductor material, the so-called ampacity. The ampacity of
   an overhead line depends on its conductor temperature, which is subject
   to its surrounding weather conditions. Therefore, weather data from a
   distributed sensor network is one of the main factors when training
   ampacity forecasting models. Quantile Regression Forests show high
   accuracy for a two-day-ahead forecasting even with small training
   datasets. This corresponds to a great advantage just after installation
   of the measurement system, when historical distributed weather data are
   not available, because it reduces the wait-after-deployment time from
   years to some months.},
Type = {Proceedings Paper},
Affiliation = {Molinar, G (Corresponding Author), Karlsruhe Inst Technol, ITIV, Karlsruhe, Germany.
