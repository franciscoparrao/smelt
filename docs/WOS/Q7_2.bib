}

@article{ WOS:001032109300001,
Author = {Velthoen, Jasper and Dombry, Clement and Cai, Juan-Juan and Engelke,
   Sebastian},
Title = {Gradient boosting for extreme quantile regression},
Journal = {EXTREMES},
Year = {2023},
Volume = {26},
Number = {4},
Pages = {639-667},
Month = {DEC},
Abstract = {Extreme quantile regression provides estimates of conditional quantiles
   outside the range of the data. Classical quantile regression performs
   poorly in such cases since data in the tail region are too scarce.
   Extreme value theory is used for extrapolation beyond the range of
   observed values and estimation of conditional extreme quantiles. Based
   on the peaks-over-threshold approach, the conditional distribution above
   a high threshold is approximated by a generalized Pareto distribution
   with covariate dependent parameters. We propose a gradient boosting
   procedure to estimate a conditional generalized Pareto distribution by
   minimizing its deviance. Cross-validation is used for the choice of
   tuning parameters such as the number of trees and the tree depths. We
   discuss diagnostic plots such as variable importance and partial
   dependence plots, which help to interpret the fitted models. In
   simulation studies we show that our gradient boosting procedure
   outperforms classical methods from quantile regression and extreme value
   theory, especially for high-dimensional predictor spaces and complex
   parameter response surfaces. An application to statistical
   post-processing of weather forecasts with precipitation data in the
   Netherlands is proposed.},
Type = {Article},
Affiliation = {Engelke, S (Corresponding Author), Univ Geneva, Res Ctr Stat, Blvd Pont dArve 40, CH-1205 Geneva, Switzerland.
   Velthoen, Jasper, Delft Univ Technol, Dept Appl Math, Mekelweg 4, NL-2628 CD Delft, Netherlands.
   Dombry, Clement, Univ Bourgogne Franche Comte, Lab Math Besancon, CNRS UMR 6623, F-25000 Besancon, France.
   Cai, Juan-Juan, Vrije Univ Amsterdam, Dept Econometr \& Data Sci, Boelelaan 1105, NL-1081 HV Amsterdam, Netherlands.
   Engelke, Sebastian, Univ Geneva, Res Ctr Stat, Blvd Pont dArve 40, CH-1205 Geneva, Switzerland.},
DOI = {10.1007/s10687-023-00473-x},
EarlyAccessDate = {JUL 2023},
Keywords = {Extreme quantile regression; Gradient boosting; Generalized Pareto
   distribution; Extreme value theory; Tree-based methods},
Author-Email = {j.j.velthoen@tudelft.nl
