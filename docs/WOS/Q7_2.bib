@article{ WOS:001416225000025,
Author = {Zhu, Qingbo and Huang, Yicun and Feng Lee, Chih and Liu, Peng and Zhang,
   Jin and Wik, Torsten},
Title = {Predicting Electric Vehicle Energy Consumption From Field Data Using
   Machine Learning},
Journal = {IEEE TRANSACTIONS ON TRANSPORTATION ELECTRIFICATION},
Year = {2025},
Volume = {11},
Number = {1},
Pages = {2120-2132},
Month = {FEB},
Abstract = {This study addresses the challenge of accurately forecasting the energy
   consumption of electric vehicles (EVs), which is crucial for reducing
   range anxiety and advancing strategies for charging and energy
   optimization. Despite the limitations of current forecasting methods,
   including empirical, physics-based, and data-driven models, this article
   presents a novel machine learning (ML)-based prediction framework. It
   integrates physics-informed features and combines offline global models
   with vehicle-specific online adaptation to enhance prediction accuracy
   and assess uncertainties. Our framework is tested extensively on data
   from a real-world fleet of EVs. While the leading global model, quantile
   regression neural network (QRNN), demonstrates an average error of
   6.30\%, the online adaptation further achieves a notable reduction to
   5.04\%, with both surpassing the performance of existing models
   significantly. Moreover, for a 95\% prediction interval, the online
   adapted QRNN improves coverage probability (CP) to 91.27\% and reduces
   the average width (AW) of prediction intervals to 0.51. These results
   demonstrate the effectiveness and efficiency of utilizing physics-based
   features and vehicle-based online adaptation for predicting EV energy
   consumption.},
Type = {Article},
Affiliation = {Huang, YC (Corresponding Author), Chalmers Univ Technol, Dept Elect Engn, S-41296 Gothenburg, Sweden.
   Zhu, Qingbo; Huang, Yicun; Wik, Torsten, Chalmers Univ Technol, Dept Elect Engn, S-41296 Gothenburg, Sweden.
   Feng Lee, Chih, Polestar Performance AB, S-41878 Gothenburg, Sweden.
   Liu, Peng; Zhang, Jin, Beijing Inst Technol, Natl Engn Res Ctr Elect Vehicles, Beijing 100081, Peoples R China.},
DOI = {10.1109/TTE.2024.3416532},
Keywords = {Energy consumption; Predictive models; Adaptation models; Roads;
