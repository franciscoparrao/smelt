}

@article{ WOS:000747701600001,
Author = {Dang, Sanlei and Peng, Long and Zhao, Jingming and Li, Jiajie and Kong,
   Zhengmin},
Title = {A Quantile Regression Random Forest-Based Short-Term Load Probabilistic
   Forecasting Method},
Journal = {ENERGIES},
Year = {2022},
Volume = {15},
Number = {2},
Month = {JAN},
Abstract = {In this paper, a novel short-term load forecasting method amalgamated
   with quantile regression random forest is proposed. Comprised with point
   forecasting, it is capable of quantifying the uncertainty of power load.
   Firstly, a bespoke 2D data preprocessing taking advantage of empirical
   mode decomposition (EMD) is presented. It can effectively assist
   subsequent point forecasting models to extract spatial features hidden
   in the 2D load matrix. Secondly, by exploiting multimodal deep neural
   networks (DNN), three short-term load point forecasting models are
   conceived. Furthermore, a tailor-made multimodal spatial-temporal
   feature extraction is proposed, which integrates spatial features, time
   information, load, and electricity price to obtain more covert features.
   Thirdly, relying on quantile regression random forest, the probabilistic
   forecasting method is proposed, which exploits the results from the
   above three short-term load point forecasting models. Lastly, the
   experimental results demonstrate that the proposed method outperforms
   its conventional counterparts.},
Type = {Article},
Affiliation = {Kong, ZM (Corresponding Author), Wuhan Univ, Sch Elect Engn \& Automat, Wuhan 430072, Peoples R China.
   Dang, Sanlei; Peng, Long; Zhao, Jingming; Li, Jiajie, Meteorol Ctr Guangdong Power Grid Co Ltd, Guangzhou 510600, Peoples R China.
   Kong, Zhengmin, Wuhan Univ, Sch Elect Engn \& Automat, Wuhan 430072, Peoples R China.},
DOI = {10.3390/en15020663},
Article-Number = {663},
Keywords = {short-term load forecasting; load point forecasting; LSTM; CNN; quantile
   regression random forest},
Keywords-Plus = {NONSTATIONARY TIME-SERIES; NEURAL-NETWORK},
Author-Email = {dangsanlei@gd.csg.cn
