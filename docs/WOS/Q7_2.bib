DOI = {10.35378/gujs.1334184},
Keywords = {Newsvendor; Machine learning; Food waste},
Author-Email = {burak.gokgur@sabanciuniv.edu},
Number-of-Cited-References = {23},
Times-Cited = {0},
Unique-ID = {WOS:001375992500003},
