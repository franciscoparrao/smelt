   Zhou, Kaile; Zhang, Xiaoling, City Univ Hong Kong, Dept Publ Policy, Kowloon, Hong Kong, Peoples R China.},
DOI = {10.1016/j.energy.2018.07.090},
Keywords = {Deep learning; Probability density forecasting; Feature engineering;
   Power load forecasting},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; ELECTRICITY CONSUMPTION; NEURAL-NETWORK;
   DEMAND; PREDICTION; OPTIMIZATION; ALGORITHM},
Author-Email = {zhoukaile@hfut.edu.cn},
