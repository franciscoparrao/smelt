}

@article{ WOS:000522492700114,
Author = {Moon, Jihoon and Kim, Junhong and Kang, Pilsung and Hwang, Eenjun},
Title = {Solving the Cold-Start Problem in Short-Term Load Forecasting Using
   Tree-Based Methods},
Journal = {ENERGIES},
Year = {2020},
Volume = {13},
Number = {4},
Month = {FEB},
Abstract = {An energy-management system requires accurate prediction of the electric
   load for optimal energy management. However, if the amount of electric
   load data is insufficient, it is challenging to perform an accurate
   prediction. To address this issue, we propose a novel electric load
   forecasting scheme using the electric load data of diverse buildings. We
   first divide the electric energy consumption data into training and test
   sets. Then, we construct multivariate random forest (MRF)-based
   forecasting models according to each building except the target building
   in the training set and a random forest (RF)-based forecasting model
   using the limited electric load data of the target building in the test
   set. In the test set, we compare the electric load of the target
   building with that of other buildings to select the MRF model that is
   the most similar to the target building. Then, we predict the electric
   load of the target building using its input variables via the selected
   MRF model. We combine the MRF and RF models by considering the different
   electric load patterns on weekdays and holidays. Experimental results
   demonstrate that combining the two models can achieve satisfactory
   prediction performance even if the electric data of only one day are
   available for the target building.},
Type = {Article},
Affiliation = {Hwang, E (Corresponding Author), Korea Univ, Sch Elect Engn, 145 Anam Ro, Seoul 02841, South Korea.
   Moon, Jihoon; Hwang, Eenjun, Korea Univ, Sch Elect Engn, 145 Anam Ro, Seoul 02841, South Korea.
   Kim, Junhong; Kang, Pilsung, Korea Univ, Sch Ind Management Engn, 145 Anam Ro, Seoul 02841, South Korea.},
DOI = {10.3390/en13040886},
Article-Number = {886},
Keywords = {short-term load forecasting; building electric energy consumption
   forecasting; cold-start problem; transfer learning; multivariate random
   forests; random forest},
Keywords-Plus = {ENERGY-CONSUMPTION; RANDOM FOREST; QUANTILE REGRESSION; ELECTRICITY
   LOAD; NEURAL-NETWORK; PREDICTION; BUILDINGS; PARALLEL; MODELS; PRICE},
Author-Email = {johnny89@korea.ac.kr
