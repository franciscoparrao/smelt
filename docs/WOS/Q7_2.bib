}

@article{ WOS:000595793500009,
Author = {Hu, Liangyuan and Li, Lihua and Ji, Jiayi and Sanderson, Mark},
Title = {Identifying and understanding determinants of high healthcare costs for
   breast cancer: a quantile regression machine learning approach},
Journal = {BMC HEALTH SERVICES RESEARCH},
Year = {2020},
Volume = {20},
Number = {1},
Month = {NOV 23},
Abstract = {BackgroundTo identify and rank the importance of key determinants of
   high medical expenses among breast cancer patients and to understand the
   underlying effects of these determinants.MethodsThe Oncology Care Model
   (OCM) developed by the Center for Medicare \& Medicaid Innovation were
   used. The OCM data provided to Mount Sinai on 2938 breast-cancer
   episodes included both baseline periods and three performance periods
   between Jan 1, 2012 and Jan 1, 2018. We included 11 variables
   representing information on treatment, demography and socio-economics
   status, in addition to episode expenditures. OCM data were collected
   from participating practices and payers. We applied a principled
   variable selection algorithm using a flexible tree-based machine
   learning technique, Quantile Regression Forests.ResultsWe found that the
   use of chemotherapy drugs (versus hormonal therapy) and interval of days
   without chemotherapy predominantly affected medical expenses among
   high-cost breast cancer patients. The second-tier major determinants
   were comorbidities and age. Receipt of surgery or radiation,
   geographically adjusted relative cost and insurance type were also
   identified as important high-cost drivers. These factors had
   disproportionally larger effects upon the high-cost
   patients.ConclusionsData-driven machine learning methods provide
   insights into the underlying web of factors driving up the costs for
   breast cancer care management. Results from our study may help inform
   population health management initiatives and allow policymakers to
   develop tailored interventions to meet the needs of those high-cost
   patients and to avoid waste of scarce resource.},
Type = {Article},
Affiliation = {Hu, LY (Corresponding Author), Icahn Sch Med Mt Sinai, Dept Populat Hlth Sci \& Policy, 1425 Madison Ave,One Gustave L Levy Pl,Box 1077, New York, NY 10029 USA.
   Hu, Liangyuan; Li, Lihua; Ji, Jiayi, Icahn Sch Med Mt Sinai, Dept Populat Hlth Sci \& Policy, 1425 Madison Ave,One Gustave L Levy Pl,Box 1077, New York, NY 10029 USA.
   Sanderson, Mark, Icahn Sch Med Mt Sinai, Dept Hlth Syst Design \& Global Hlth, New York, NY 10029 USA.},
DOI = {10.1186/s12913-020-05936-6},
Article-Number = {1066},
Keywords = {Medical care costs; Cancer; Machine learning; Quantile regression},
Keywords-Plus = {HIGH-NEED; PROGRAMS; USERS},
Author-Email = {liangyuan.hu@mountsinai.org},
Number-of-Cited-References = {40},
Times-Cited = {12},
Unique-ID = {WOS:000595793500009},
}

@article{ WOS:000571421000003,
Author = {Ma, Xuejiao and Dong, Yunxuan},
Title = {An estimating combination method for interval forecasting of electrical
   load time series},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2020},
Volume = {158},
Month = {NOV 15},
Abstract = {Due to the failure of deterministic point forecasting to capture the
   uncertainty associated with the original time series, and because it can
   reflect the range of electrical load fluctuation, the importance of
   probabilistic interval forecasting has gradually increased. However, the
   existing theoretical system of interval forecasting is still incomplete,
   is a complicated process, and has relatively low accuracy. The objective
   of this study is to propose an interval forecasting approach based on
   feature selection, the optimized machine learning method, and correction
   of the Gaussian distribution. By applying this approach, the
   distribution of predictions can be established to include all the
   information of prediction intervals at each confidence level, making the
   best use of the known information. The electrical load time series of
   Australia are used to examine the effectiveness of the proposed
   approach, and compared with other models, it is proven to not only
   simplify the forecasting process and shorten the processing time, but
   also significantly improve the forecasting efficiency, flexibility, and
   accuracy. (C) 2020 Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Dong, YX (Corresponding Author), Univ Macau, Dept Elect \& Comp Engn, Macau, Peoples R China.
   Ma, Xuejiao, Dalian Univ Technol, Sch Econ \& Management, Dalian 116024, Peoples R China.
   Dong, Yunxuan, Univ Macau, Dept Elect \& Comp Engn, Macau, Peoples R China.},
DOI = {10.1016/j.eswa.2020.113498},
Article-Number = {113498},
Keywords = {Interval forecasting; Machine learning method; Distribution estimation;
