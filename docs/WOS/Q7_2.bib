   Fan, Bo, Shanghai Jiao Tong Univ, Sch Int \& Publ Affairs, Shanghai 200240, Peoples R China.},
DOI = {10.1109/ACCESS.2018.2879824},
Keywords = {Prediction interval; customized objective function; gradient boosting;
