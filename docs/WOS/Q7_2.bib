   Plassier, Vincent; Moulines, Eric, Ecole Polytech, CMAP, Paris, France.
   Rubashevskii, Aleksandr, Skolkovo Inst Sci \& Technol, Moscow, Russia.
   Rubashevskii, Aleksandr; Moulines, Eric, Mohamed Bin Zayed Univ Artificial Intelligence, Masdar City, U Arab Emirates.
   Panov, Maxim, Technol Innovat Inst, Abu Dhabi, U Arab Emirates.},
Author-Email = {vincent.plassier@polytechnique.edu
   maxim.panov@tii.ae},
