   Tipu, Rupesh Kumar, KR Mangalam Univ, Sch Engn \& Technol, Dept Civil Engn, Gurugram 122103, Haryana, India.},
DOI = {10.1016/j.asej.2026.104009},
EarlyAccessDate = {FEB 2026},
Article-Number = {104009},
Keywords = {Concrete mix design; Embodied carbon; Multi-task learning; Monotonicity
   constraints; Conformal prediction; Uncertainty quantification; Pareto
   optimization; Expected hypervolume improvement; NSGA-II; SHAP
   explainability},
