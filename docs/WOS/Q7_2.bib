@article{ WOS:001255109100011,
Author = {Wang, Xiaoyang and Sun, Yunlin and Chen, Chen and Chen, Siming and Chen,
   S. C.},
Title = {RESEARCH ON KEY FEATURE EXTRACTION METHOD OF PHOTOVOLTAIC OUTPUT
   INTERVAL PREDICTION BASED ON CONDITIONAL MUTUAL INFORMATION},
Journal = {JOURNAL OF NONLINEAR AND CONVEX ANALYSIS},
Year = {2024},
Volume = {25},
Number = {5},
Pages = {943-953},
Abstract = {In light of the issue where an excessive number of characteristics
   affecting photovoltaic output results in decreased prediction accuracy,
   this paper proposes a feature selection algorithm based on conditional
   mutual information (CMI). The algorithm extracts key features that
   significantly contribute to photovoltaic power prediction, forming an
   optimal feature subset from the dataset. The dataset is initially
   processed, followed by the utilization of three feature selection
   algorithms: CMI feature selection algorithm, Pearson feature selection
   algorithm and Random forest feature selection algorithm to extract the
   input key features of photovoltaic prediction model. Subsequently, the
   selected feature datasets from the three algorithms are inputted into
   the CNN-BiLSTM-Attention prediction model to forecast photovoltaic power
   output. Lastly, the concept of quantile regression is incorporated into
   the prediction model to enable interval prediction, thereby generating
   more accurate and comprehensive prediction results. By conducting
   experimental tests on a commercial photovoltaic power station, the
   effectiveness of the proposed method in improving prediction accuracy is
   verified.},
Type = {Article},
Affiliation = {Wang, XY (Corresponding Author), Beijing Inst Technol, Zhuhai, Guangdong, Peoples R China.
   Wang, Xiaoyang, Beijing Inst Technol, Zhuhai, Guangdong, Peoples R China.
