@article{ WOS:001649736300001,
Author = {Bhattacharyya, Anindya and Behera, Rajendra Prasad and Dasgupta, Arup
   and Chakraborty, Rajat Subhra},
Title = {Uncertainty-Aware Remaining Useful Life Estimation for Aluminium
   Electrolytic Capacitors Using Spectral Mixture Kernels and Hybrid
   Uncertainty Calibration},
Journal = {IEEE TRANSACTIONS ON RELIABILITY},
Year = {2025},
Month = {2025 DEC 23},
Abstract = {The industrial adoption of machine learning for remaining useful life
   (RUL) prediction is constrained by data, not models. Run-to-failure
   records are rare and often noisy, incomplete, irregular, or inconsistent
   because full lifecycle testing is costly and time-consuming. Deep
   learning struggles under these constraints, demanding large datasets and
   offering limited uncertainty quantification. We address robust,
   uncertainty-aware RUL prediction in data-scarce settings, using
   aluminium electrolytic capacitors (AECs) as a representative case with
   complex, nonstationary degradation. Our approach targets scenarios with
   limited lifecycle observations-often fewer than 30 data points per
   unit-where traditional models exhibit reduced performance. We propose a
   Gaussian process regression (GPR) framework offering Bayesian
   uncertainty estimates and resilience under limited data. To handle
   nonstationary behavior, we introduce spectral mixture kernels (SMKs) to
   model frequency-domain structure. For calibrated uncertainty, we
   integrate quantile regression with split-conformal prediction, utilizing
   a Mondrian phase-stratified scheme. Under this scheme, local conformal
   calibration adapts intervals within early/mid/late regimes. For
   deployment on resource-constrained platforms, we implement sparse GPR
   (SGPR) with k-means inducing points. Evaluations on two accelerated
   ageing datasets show marked improvements: in Dataset 1 (105 C-degrees,
   20 V), SMK-GPR reduces mean RMSE from 47.43 to 15.90 h (66.5\%); in
   Dataset 2 (125 C-degrees, 22 V), from 11.24 to 3.56 h (68.3\%) along
   with empirical coverage exceeding nominal targets. These results
   demonstrate robustness across degradation regimes and support accurate,
   interpretable, and deployable RUL predictions in real-world industrial
   settings.},
Type = {Article; Early Access},
Affiliation = {Bhattacharyya, A (Corresponding Author), Indira Gandhi Ctr Atom Res, Kalpakkam 603102, India.
   Bhattacharyya, A (Corresponding Author), Homi Bhabha Natl Inst, Anushaktinagar, Mumbai 400094, India.
   Bhattacharyya, Anindya; Behera, Rajendra Prasad; Dasgupta, Arup, Indira Gandhi Ctr Atom Res, Kalpakkam 603102, India.
   Bhattacharyya, Anindya; Dasgupta, Arup, Homi Bhabha Natl Inst, Anushaktinagar, Mumbai 400094, India.
   Chakraborty, Rajat Subhra, Indian Inst Technol Kharagpur, Dept Comp Sci \& Engn, Kharagpur 721302, India.},
DOI = {10.1109/TR.2025.3641587},
EarlyAccessDate = {DEC 2025},
Keywords = {Kernel; Degradation; Computational modeling; Calibration; Uncertainty;
   Predictive models; Adaptation models; Data models; Gaussian processes;
   Trajectory; Conformal prediction; Gaussian process regression (GPR);
   quantile regression (QR); remaining useful life (RUL); spectral mixture
   kernel (SMK); uncertainty quantification},
Keywords-Plus = {CONFORMAL PREDICTION; REGRESSION},
Author-Email = {anindya@igcar.gov.in
   rpb@igcar.gov.in
   arup@igcar.gov.in
   rschakraborty@cse.iitkgp.ac.in},
Number-of-Cited-References = {56},
