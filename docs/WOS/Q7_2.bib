DOI = {10.1016/j.saa.2020.118349},
Article-Number = {118349},
Keywords = {Fake drugs; Predictive models; Tuned hyperparameters; Variable selection
   algorithms},
Keywords-Plus = {VARIABLE SELECTION METHODS; PERFORMANCE; CHROMATOGRAPHY; DESIGN},
Author-Email = {dr.ahmed\_analytical@yahoo.com},
Number-of-Cited-References = {51},
