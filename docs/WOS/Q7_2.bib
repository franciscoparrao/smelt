@article{ WOS:001233795800013,
Author = {Dave, Darpit and Vyas, Kathan and Branan, Kimberly and Mckay, Siripoom
   and Desalvo, Daniel J. and Gutierrez-Osuna, Ricardo and Cote, Gerard L.
   and Erraguntla, Madhav},
Title = {Detection of Hypoglycemia and Hyperglycemia Using Noninvasive Wearable
