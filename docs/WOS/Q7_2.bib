   McDonald, Andrew J., Cornell Univ, Sch Integrat Plant Sci, Soil \& Crop Sci Sect, Ithaca, NY USA.},
DOI = {10.1016/j.aiia.2024.08.001},
Keywords = {Relative yield; Additive Main effect and multiplicative interaction
