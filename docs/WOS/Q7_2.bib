   Sigauke, Caston, Univ Venda, Dept Math \& Computat Sci, Limpopo, South Africa.
   Shoko, Claris, Univ Botswana, Dept Stat, Private Bag UB, Gaborone 00705, Botswana.},
DOI = {10.1016/j.ajic.2023.03.010},
EarlyAccessDate = {SEP 2023},
Keywords = {Hierarchical interactions; Least absolute shrinkage; Linear quantile
   regression averaging; LASSO; Generalized additive model; Support vector
   regression},
Author-Email = {shokoc@ub.ac.bw
   caston.sigauke@univen.ac.za},
Number-of-Cited-References = {32},
Times-Cited = {11},
Unique-ID = {WOS:001084680800001},
}

