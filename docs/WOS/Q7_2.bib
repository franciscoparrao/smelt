Affiliation = {Jeon, JJ (Corresponding Author), Univ Seoul, Dept Stat, 163 Seoulsiripdaero, Seoul 02504, South Korea.
   Hong, Sungchul, Changwon Natl Univ, Dept Stat, 20 Changwondaehakro, Chang Won 51140, South Korea.
   Choi, Yunjin; Jeon, Jong-June, Univ Seoul, Dept Stat, 163 Seoulsiripdaero, Seoul 02504, South Korea.},
DOI = {10.1016/j.ijforecast.2024.10.003},
EarlyAccessDate = {JUN 2025},
Keywords = {Quantile regression; Water level forecasting; Spatiotemporal dependence;
   Transformer; Interpretable AI},
Keywords-Plus = {MODEL},
Author-Email = {shong@changwon.ac.kr},
Number-of-Cited-References = {43},
Times-Cited = {5},
