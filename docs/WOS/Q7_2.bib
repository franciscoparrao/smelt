@article{ WOS:001457880200001,
Author = {Colombo, Pietro and Mattera, Raffaele and Otto, Philipp},
Title = {Simple Yet Effective: A Comparative Study of Statistical Models for
   Yearly Hurricane Forecasting},
Journal = {ENVIRONMETRICS},
Year = {2025},
Volume = {36},
Number = {3},
Month = {APR 2},
Abstract = {In this article, we study the problem of forecasting the next year's
   number of Atlantic hurricanes, which is relevant in many fields of
   applications such as land-use planning, hazard mitigation, reinsurance
   and long-term weather derivative market. Considering a set of well-known
   predictors, we compare the forecasting accuracy of both machine learning
   and classical statistical models, showing that the latter may be more
   adequate than the first. Quantile regression models, which are adopted
   for the first time for forecasting hurricane numbers, provide the best
   results. Moreover, we construct a new index showing good properties in
   anticipating the direction of the future number of hurricanes. We
   consider different evaluation metrics based on both magnitude
   forecasting errors and directional accuracy.},
Type = {Article},
Affiliation = {Colombo, P (Corresponding Author), Univ Glasgow, Dept Math \& Stat, Glasgow, Scotland.
   Colombo, Pietro; Otto, Philipp, Univ Glasgow, Dept Math \& Stat, Glasgow, Scotland.
   Mattera, Raffaele, Univ Campania Luigi Vanvitelli, Dept Math \& Phys, Caserta, Italy.},
DOI = {10.1002/env.70009},
Article-Number = {e70009},
Keywords = {count time series; directional accuracy; environmental risk; hurricanes
   prediction; probabilistic forecasting},
Keywords-Plus = {TIME-SERIES; QUANTILE REGRESSION; FREQUENCY; CLIMATE},
Author-Email = {Pietro.Colombo@glasgow.ac.uk},
Number-of-Cited-References = {56},
