Number-of-Cited-References = {47},
Times-Cited = {17},
Unique-ID = {WOS:000685648200001},
}

@article{ WOS:000654545200001,
Author = {Wang, Liang-Jie and Cheng, Hao and Yang, Liang-Cheng and Zhao, Yu-Guo},
Title = {Soil organic carbon mapping in cultivated land using model ensemble
   methods},
Journal = {ARCHIVES OF AGRONOMY AND SOIL SCIENCE},
Year = {2022},
Volume = {68},
Number = {12},
Pages = {1711-1725},
Month = {OCT 15},
Abstract = {The soil organic carbon (SOC) pool is larger than the biotic and
   atmospheric carbon pools, and understanding cultivated land SOC is
   critical for evaluating soil fertility and local agricultural
   management. Digital soil mapping (DSM) efficiently predicts soil
   properties by utilizing spatially distributed information. To date, many
   machine learning techniques have been applied in DSM, but model ensemble
   methods have rarely been used. In this study, two model ensemble
   methods, including the Granger-Ramanathan averaging and Bayesian model
   averaging, and three individual mathematical algorithms, such as the
   random forest, quantile regression forests, and multivariate adaptive
   regression splines models, were used to estimate SOC at a local level
   with limited soil samples. The prediction performances of the five
   methods were compared using an independent validation dataset composed
   of field observations of soil samples. The results showed that the
   prediction accuracy of the ensemble methods was higher than that of the
   individual methods (Delta R-2 = 0.02 to 0.21). Compared to the other
   methods, the Granger-Ramanathan method had a lower root mean square
   error (RMSE) and mean absolute error and a higher prediction
   uncertainty. Therefore, the results of this study show the effectiveness
   of using ensemble methods in mapping SOC with limited soil samples.},
Type = {Article},
Affiliation = {Zhao, YG (Corresponding Author), Chinese Acad Sci, Inst Soil Sci, State Key Lab Soil \& Sustainable Agr, Nanjing 210008, Peoples R China.
   Wang, Liang-Jie; Cheng, Hao, Nanjing Forestry Univ, Coinnovat Ctr Sustainable Forestry Southern China, Nanjing, Peoples R China.
   Wang, Liang-Jie; Zhao, Yu-Guo, Chinese Acad Sci, Inst Soil Sci, State Key Lab Soil \& Sustainable Agr, Nanjing 210008, Peoples R China.
   Cheng, Hao, Nanjing Forestry Univ, Jiangsu Prov Key Lab Soil Eros \& Ecol Restorat, Nanjing, Peoples R China.
   Yang, Liang-Cheng, Illinois State Univ, Dept Hlth Sci, Normal, IL 61761 USA.
   Zhao, Yu-Guo, Univ Chinese Acad Sci, Beijing, Peoples R China.},
DOI = {10.1080/03650340.2021.1925651},
EarlyAccessDate = {MAY 2021},
Keywords = {Digital soil mapping; soil organic carbon; random forest; model ensemble},
Keywords-Plus = {SPATIAL-DISTRIBUTION; RANDOM FORESTS; PROPERTY RASTERS; REGRESSION TREE;
   REGIONAL-SCALE; STOCKS; CLASSIFICATION; CLIMATE; MAPS},
Author-Email = {pawangwlj@outlook.com},
Number-of-Cited-References = {53},
Times-Cited = {13},
