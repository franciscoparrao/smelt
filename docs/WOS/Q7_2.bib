   Balzarini, M., Pontificia Univ Cato l Chile, Ctr Nacl Excelencia Ind Madera CENAMAD, Santiago, Chile.},
DOI = {10.1016/j.eja.2026.128016},
EarlyAccessDate = {JAN 2026},
