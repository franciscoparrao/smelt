Article-Number = {100739},
Keywords = {Random forest; Urban heat; Low-cost sensors; Crowd-sensing; Machine
   learning},
Keywords-Plus = {AIR-TEMPERATURE; CLIMATE-CHANGE; HEAT WAVES; IMPACT; PREDICTION},
