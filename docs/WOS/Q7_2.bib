   Tran, Van-Duc, Duy Tan Univ, Int Sch, Da Nang 550000, Vietnam.},
DOI = {10.3390/math12081267},
Article-Number = {1267},
Keywords = {high-performance concrete; compressive strength; gradient boosting
   machine; differential flower pollination; overestimation reduction;
   68Txx; 68Vxx},
Keywords-Plus = {SILICA FUME; MECHANICAL-PROPERTIES; SLAG; CEMENT; ENSEMBLES},
Author-Email = {hoangnhatduc@duytan.edu.vn
   tranvanduc1@dtu.edu.vn
