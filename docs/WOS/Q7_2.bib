@article{ WOS:001465030800001,
Author = {He, Song and Du, Wenli and Peng, Xin},
Title = {Uncertainty-aware optimization of zeolite particle size: Utilizing
   quantile regression and SHAP analysis},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2025},
Volume = {512},
Month = {MAY 15},
Abstract = {The particle size of zeolites significantly impacts their performance in
   practical applications. Unlike traditional trial-and-error
   experimentation, data-driven property prediction and optimization offer
   a more efficient way to synthesize zeolites with desired particle sizes.
   However, constrained by the scarcity of data and the complex
   relationship between synthesis parameters and zeolite properties,
   existing machine learning methods suffer from suboptimal performance,
   bringing high uncertainties into practical synthesis. To address these
   challenges, we develop an uncertainty-aware optimization framework that
   not only predicts particle size but also provides actionable
   optimization guidance. Specifically, we first construct an XGBoost-based
   quantile regression model to capture the nonlinear relationships between
   synthesis parameters including gel composition, crystallization
   conditions and organic structure-directing agents, and particle size,
   while returning 90\% confidence intervals to quantify prediction
   uncertainty. Further, we integrate Shapley additive explanation (SHAP)
   technique to reveal causal contributions of key synthesis parameters on
   particle size, yielding comprehensive insights for particle
   size-oriented synthesis. More importantly, a novel SHAP-driven
   optimization strategy is designed to generate precise adjustment schemes
   for desired particle sizes of individual samples. This strategy assesses
   particle size fluctuations in response to synthetic parameter
   adjustments by calculating the SHAP difference between the upper and
   lower bounds of confidence intervals. Our framework accurately predicts
   particle size with an R2 of 0.817 and rapidly screens thousands of
   synthesis routes within seconds. Compared to conventional optimization
   techniques, our framework offers enhanced computational efficiency and
   robust uncertainty quantification, accelerating zeolite synthesis
   experiments and practical applications.},
Type = {Article},
Affiliation = {Du, WL (Corresponding Author), East China Univ Sci \& Technol, State Key Lab Ind Control Technol, Shanghai 200237, Peoples R China.
