@article{ WOS:001280035100001,
Author = {Nascimento, Moyses and Nascimento, Ana Carolina Campana and Azevedo,
   Camila Ferreira and de Oliveira, Antonio Carlos Baiao and Caixeta,
   Eveline Teixeira and Jarquin, Diego},
Title = {Enhancing genomic prediction with Stacking Ensemble Learning in Arabica
   Coffee},
Journal = {FRONTIERS IN PLANT SCIENCE},
Year = {2024},
Volume = {15},
Month = {JUL 17},
Abstract = {Coffee Breeding programs have traditionally relied on observing plant
   characteristics over years, a slow and costly process. Genomic selection
   (GS) offers a DNA-based alternative for faster selection of superior
   cultivars. Stacking Ensemble Learning (SEL) combines multiple models for
   potentially even more accurate selection. This study explores SEL
   potential in coffee breeding, aiming to improve prediction accuracy for
   important traits {[}yield (YL), total number of the fruits (NF), leaf
   miner infestation (LM), and cercosporiosis incidence (Cer)] in Coffea
   Arabica. We analyzed data from 195 individuals genotyped for 21,211
   single-nucleotide polymorphism (SNP) markers. To comprehensively assess
   model performance, we employed a cross-validation (CV) scheme. Genomic
   Best Linear Unbiased Prediction (GBLUP), multivariate adaptive
   regression splines (MARS), Quantile Random Forest (QRF), and Random
   Forest (RF) served as base learners. For the meta-learner within the SEL
   framework, various options were explored, including Ridge Regression,
   RF, GBLUP, and Single Average. The SEL method was able to predict the
   predictive ability (PA) of important traits in Coffea Arabica. SEL
   presented higher PA compared with those obtained for all base learner
   methods. The gains in PA in relation to GBLUP were 87.44\% (the ratio
   between the PA obtained from best Stacking model and the GBLUP),
   37.83\%, 199.82\%, and 14.59\% for YL, NF, LM and Cer, respectively.
   Overall, SEL presents a promising approach for GS. By combining
   predictions from multiple models, SEL can potentially enhance the PA of
   GS for complex traits.},
Type = {Article},
Affiliation = {Nascimento, M (Corresponding Author), Univ Fed Vicosa, Dept Stat, Lab Intelligence Computat \& Stat Learning LICAE, Vicosa, Brazil.
   Nascimento, M; Jarquin, D (Corresponding Author), Univ Florida, Agron Dept, Gainesville, FL 32611 USA.
