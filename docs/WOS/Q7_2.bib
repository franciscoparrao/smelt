   Zhang, Kang; Zheng, Sen, Hohai Univ, Coll Water Conservancy \& Hydropower Engn, Nanjing 210098, Peoples R China.
   Zhang, Kang; Zheng, Sen, Hohai Univ, Natl Engn Res Ctr, Water Resources Efficient Utilizat \& Engn Safety, Nanjing 210098, Peoples R China.},
DOI = {10.3390/w17111661},
Article-Number = {1661},
Keywords = {displacement interval prediction; patch time series transformer; sand
   cat swarm optimization; quantile regression; shapley additive
   explanations; uncertainty quantization},
