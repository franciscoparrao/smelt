   Tian, Zhiyuan, Chinese Acad Sci, Inst Soil Sci, State Key Lab Soil \& Sustainable Agr, 298 Chuangyou Rd, Nanjing 211135, Jiangsu, Peoples R China.},
DOI = {10.1016/j.eiar.2025.107998},
EarlyAccessDate = {MAY 2025},
Article-Number = {107998},
Keywords = {Digital soil mapping; K factor; Climate projection; Soil erosion;
   Machine learning},
Keywords-Plus = {WATER EROSION; LAND-USE; UNCERTAINTY; PREDICTION; IMPACTS; DATASET;
   FOREST; USLE},
