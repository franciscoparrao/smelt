@article{ WOS:001368232300001,
Author = {Collado-Villaverde, Armando and Munoz, Pablo and Cid, Consuelo},
Title = {Operational SYM-H Forecasting With Confidence Intervals Using Deep
   Neural Networks},
Journal = {SPACE WEATHER-THE INTERNATIONAL JOURNAL OF RESEARCH AND APPLICATIONS},
Year = {2024},
Volume = {22},
Number = {10},
Month = {OCT 28},
Abstract = {In this study, we develop a robust real-time forecast system for the
   SYM-H index using Deep Neural Networks and real-time Solar Wind
   measurements along with Interplanetary Magnetic Field parameters. This
   system provides not only one-off forecasts but also quantile-based
   confidence intervals, offering a range within which the observed SYM-H
   values are expected to fall, enhancing forecast reliability and
   usability. The model is tested both on historical level 2 science-ready
   data and on preliminary observations, which are closer to the
   operational environment that the model is expected to work on,
   demonstrating the model's robustness and practical utility in real-time
   scenarios. The integration of quantile forecasts into SYM-H prediction
   models represents a significant advancement, providing decision-makers
   with more accurate and trustworthy information to manage the hazard of
   geomagnetic storms.},
Type = {Article},
Affiliation = {Collado-Villaverde, A (Corresponding Author), Univ Alcala, Dept Comp Engn, Madrid, Spain.
   Collado-Villaverde, Armando; Munoz, Pablo, Univ Alcala, Dept Comp Engn, Madrid, Spain.
   Cid, Consuelo, Univ Alcala, Dept Phys \& Math, Madrid, Spain.},
DOI = {10.1029/2024SW004039},
Article-Number = {e2024SW004039},
Keywords = {machine learning; SYM-H; forecasting; prediction interval; operational},
Keywords-Plus = {QUANTILE REGRESSION},
Author-Email = {armando.collado@uah.es},
Number-of-Cited-References = {43},
