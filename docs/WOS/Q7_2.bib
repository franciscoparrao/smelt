   Li, Shengping, Curtin Univ, Sch Design \& Built Environm, Perth, Australia.
   Jin, Haizhen, Natl Univ Singapore, Ind Syst Engn \& Management, Singapore, Singapore.},
DOI = {10.1016/j.energy.2024.132344},
EarlyAccessDate = {JUL 2024},
Article-Number = {132344},
Keywords = {Short-term load forecasting; Reinforcement learning; Online learning;
   Quantile regression; Open-source},
Author-Email = {xinlin.wang@csiro.au
   hao.wang2@monash.edu
   shengping.li@curtin.edu.au
   jinhz@nus.edu.sg},
