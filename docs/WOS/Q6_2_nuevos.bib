DOI = {10.1016/j.dib.2026.112616},
Article-Number = {112616},
Keywords = {Hygroscopicity; Water adsorption properties; Moisture stability;
   Artificial intelligence; Predictive model; Storage optimization; Quality
   management},
Keywords-Plus = {MULTILAYER ADSORPTION; GREEN},
