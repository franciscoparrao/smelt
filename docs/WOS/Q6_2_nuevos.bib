   Radoglou-Grammatiki, Panagiotis, K3Y Ltd, Sofia 55134, Bulgaria.},
DOI = {10.1109/ACCESS.2026.3663982},
Keywords = {Convolutional neural networks; Transformers; Packaging; Imaging; Energy
   states; hybrid CNN-transformer architectures; object detection;
   transformers; Imaging; Energy states; hybrid CNN-transformer
   architectures; object detection; transformers},
Keywords-Plus = {BAGGAGE INSPECTION; ALGORITHM; VISION; MODEL; YOLO},
