DOI = {10.3390/jcm14217887},
Article-Number = {7887},
Keywords = {robotic-assisted TKA; UKA revision; functional alignment; CT-based
   planning; bone grafting; primary cementless components},
Keywords-Plus = {UNICOMPARTMENTAL KNEE ARTHROPLASTY; REVISION},
Author-Email = {jaad.mahlouly@chuv.ch
   julien.wegrzyn@chuv.ch},
