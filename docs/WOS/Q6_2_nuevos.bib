}

@article{ WOS:001687406600031,
Author = {Imran, Muhammad and Lee, Yugyung},
Title = {Multimodal Vision-Language Models in Medical Imaging: A Survey of
   Retrieval, Interpretability, and Trust},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {19511-19535},
Abstract = {Medical diagnosis requires synthesizing radiological images, laboratory
   results, clinical notes, and patient history-capabilities increasingly
   supported by multimodal vision-language models (VLMs). Yet despite rapid
   advances, no general-purpose medical VLM has achieved routine clinical
   deployment. Existing surveys typically examine retrieval-augmented
   generation (RAG), interpretability, and trustworthiness in isolation,
   leaving unclear how these components jointly determine real-world
   clinical readiness. This survey analyzes 183 studies and evaluates three
   pillars essential for deployment: 1) factual accuracy enabled by RAG,
   which grounds model outputs in clinically verified evidence; 2)
   interpretability aligned with clinician reasoning, ensuring explanations
   that support diagnostic decision-making; and 3) trustworthy operation
   encompassing safety, fairness, uncertainty handling, workflow
   integration, and regulatory alignment. We show that benchmark gains
   alone are insufficient, as current VLMs still face persistent challenges
   in multimodal alignment, temporal reasoning, retrieval latency and
   scalability, explanation fidelity, and regulatory and cost-effectiveness
   constraints. Our contributions include a deployment-oriented taxonomy of
   medical VLM architectures; a comparative analysis of RAG designs and
   their clinical implications; an evaluation of interpretability methods
   grounded in clinical workflows; and an integrated framework for trust,
   uncertainty reporting, and regulatory pathways. We also curate models,
   datasets, and benchmarks that support reproducible evaluation and
   outline a roadmap toward causal, temporally aware, and computationally
   efficient VLMs suitable for real-world clinical use. To the best of
   available literature, no prior survey has jointly analyzed retrieval,
   interpretability, and trust within a unified framework for evaluating
   the clinical viability of medical VLMs.},
Type = {Article},
Affiliation = {Lee, YG (Corresponding Author), Univ Missouri Kansas City UMKC, Dept Comp Sci, Kansas City, MO 64110 USA.
   Imran, Muhammad; Lee, Yugyung, Univ Missouri Kansas City UMKC, Dept Comp Sci, Kansas City, MO 64110 USA.},
DOI = {10.1109/ACCESS.2026.3656368},
Keywords = {Retrieval augmented generation; Surveys; Medical diagnostic imaging;
   Cognition; Computational modeling; Accuracy; Visualization; Uncertainty;
   Taxonomy; Solid modeling; Medical imaging; vision-language models
   (VLMs); retrieval-augmented generation (RAG); interpretability;
   uncertainty quantification; trustworthiness; clinical decision support;
   regulatory},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; HEALTH-CARE; SYSTEMS},
Author-Email = {leeyu@umkc.edu},
Number-of-Cited-References = {183},
Times-Cited = {0},
Unique-ID = {WOS:001687406600031},
}

@article{ WOS:001687406600019,
Author = {Yelmo, Juan C. and Martin, Yod-Samuel and Perez-Acuna, Santiago},
Title = {Experimental Evaluation of AI-Augmented Cybersecurity Requirements
   Generation Leveraging LLMs' Capabilities},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {19579-19606},
Abstract = {When it comes to cybersecurity requirements, catalogs of standard
   controls are a doubleedged sword: they offer reusable resources
   applicable anywhere, yet they entail tedious, error-prone manual
   instantiation work. As the definitions of these cybersecurity controls
   are written in natural language, we analyze whether large language
   models (LLMs) may help automate that process. We conducted an empirical
   evaluation where frontier versions of LLaMa, Qwen, Mixtral, and GPT were
   asked, leveraging best prompting practices, to generate cybersecurity
   requirements for a realistic system, departing from its functional
   specification plus definitions of abstract cybersecurity controls
   extracted from ISO/IEC 27002. We compared the results to a ground truth
   created by human experts and a gold standard pooled from the aggregation
   of all human-and LLM-produced results, considering phenomena such as
   hallucinations, new requirements discovered by LLMs, or partial
   overlaps. Results show that open-weights LLMs can parallel human experts
   in coverage and help uncover additional requirements when used under
   human-in-the-loop curation. Relative F2 score against the gold standard
   (prioritizing recall over precision) reached 1.14x in the best LLM
   configuration (in comparison to human experts): a LLaMa 3.1 405B model,
   prompted with an explicit chain-of-thought pipeline made of three
   sequential steps and four parallel and coalesced runs, with moderate
   values for hyperparameters that balance diversity and determinism. Our
   work contributes a benchmark of applied capabilities of LLMs for
   security by design in non-code artifacts. Although recall values leave
   room for improvement as LLMs advance, results provide initial evidence
   that this approach is feasible in our case study.},
Type = {Article},
Affiliation = {Martín, YS (Corresponding Author), Univ Politecn Madrid, Informat Proc \& Telecommun Ctr, ETSI Telecomunicac, Madrid 28040, Spain.
   Yelmo, Juan C.; Martin, Yod-Samuel; Perez-Acuna, Santiago, Univ Politecn Madrid, Informat Proc \& Telecommun Ctr, ETSI Telecomunicac, Madrid 28040, Spain.},
DOI = {10.1109/ACCESS.2026.3658339},
Keywords = {Computer security; Large language models; Predictive models; ISO
   Standards; IEC Standards; Requirements engineering; Control systems;
   Benchmark testing; Reproducibility of results; Context modeling; large
   language models; requirements engineering; security management},
Keywords-Plus = {SECURITY REQUIREMENTS},
Author-Email = {ys.martin@upm.es},
Number-of-Cited-References = {100},
Times-Cited = {0},
Unique-ID = {WOS:001687406600019},
}

@article{ WOS:001687406600002,
Author = {Widodo, Agung Mulyo and Hsu, Shao-Hua and Huang, Mao-Hsin and Yang, Lie
   and Weng, Chien-Erh and Chen, Hsing Chung},
Title = {Robust Multi-Output AIS-Metocean Forecasting With Transformers:
   Closed-Form Weighting, Hybrid GWO-SA, and Post-Hoc Calibration},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {20049-20076},
Abstract = {Accurate multi-output forecasting for maritime navigation requires
   models that are robust to heterogeneous noise, outliers, and uncertainty
   miscalibration commonly present in Automatic Identification System (AIS)
   and meteorological-oceanographic (metocean) data. Conventional loss
   formulations and fixed weighting strategies often fail to balance
   inter-target errors and probabilistic reliability across multiple
   outputs. This paper presents a robust multi-output forecasting framework
   based on a Transformer encoder equipped with a per-target weighted Huber
   loss. To ensure stability and avoid manual tuning, an
   entropy-regularized Lagrangian formulation is first derived to obtain a
   closed-form solution for adaptive target weights, providing a
   deterministic and reproducible baseline. The per-target Huber thresholds
   are then optimized using a hybrid Grey Wolf Optimizer-Simulated
   Annealing (GWO-SA) strategy, which combines global exploration with
   stochastic local refinement on a validation objective. To further
   address regarding residual miscalibration, post-hoc calibration via
   temperature scaling and isotonic regression is applied to the predictive
   distributions. The key contribution of this work lies in the integration
   of a closed-form entropy-regularized weighting scheme with hybrid
   metaheuristic threshold optimization and post-hoc calibration. This
   integration enabling simultaneous improvements in robustness,
   inter-target balance, and probabilistic calibration for multi-output
   sequence forecasting. Comprehensive experiments on a multimodal
   AIS-metocean dataset show that the proposed approach consistently
   outperforms Gaussian NLL, fixed Huber loss, and single-metaheuristic
   baselines. The method can achieve lower MAE and MSE and significantly
   reducing NLL, CRPS, and Expected Calibration Error so can be resulting
   in accurate and well-calibrated predictive distributions. These
   experiment results demonstrate the suitability of the proposed framework
   for uncertainty-aware and safety-critical maritime decision-support
   applications.},
Type = {Article},
Affiliation = {Weng, CE (Corresponding Author), Natl Kaohsiung Univ Sci \& Technol, Dept Comp \& Commun Engn, Kaohsiung 824005, Taiwan.
   Chen, HC (Corresponding Author), Asia Univ, Dept Comp Sci \& Informat Engn, Taichung 413305, Taiwan.
