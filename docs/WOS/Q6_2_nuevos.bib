Keywords = {Long PCR; Bemisia tabaci Asia II 1; TRP channels; RYR gene; Ionotropic
   receptors; Nested PCR; Touchdown PCR; Gradient PCR},
Keywords-Plus = {5' END CDNA; TOUCHDOWN PCR; IDENTIFICATION; EXPRESSION; MARKERS;
