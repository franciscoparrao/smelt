DOI = {10.1007/s40477-025-01109-5},
Keywords = {Breast imaging; Breast cancer; Multiparametric ultrasound; CAD/AI system},
Keywords-Plus = {CLINICAL-USE; BENIGN; MASSES; DIFFERENTIATION; PREDICTOR; ACCURACY;
