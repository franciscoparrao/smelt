@article{ WOS:001670104200001,
Author = {Abdelal, Gasser and Chan, Chi-Wai and McLoone, Sean},
Title = {Critical Review of Recent Advances in AI-Enhanced SEM and EDS Techniques
   for Metallic Microstructure Characterization},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2026},
Volume = {16},
Number = {2},
Month = {JAN 18},
Abstract = {This critical review explores the transformative impact of artificial
   intelligence (AI), particularly machine learning (ML) and computer
   vision (CV), on scanning electron microscopy (SEM) and energy dispersive
   spectroscopy (EDS) for metallic microstructure analysis, spanning
   research from 2010 to 2025. It critically evaluates how AI techniques
   balance automation, accuracy, and scalability, analysing why certain
   methods (e.g., Vision Transformers for complex microstructures) excel in
   specific contexts and how trade-offs in data availability, computational
   resources, and interpretability shape their adoption. The review
   examines AI-driven techniques, including semantic segmentation, object
   detection, and instance segmentation, which automate the identification
   and characterisation of microstructural features, defects, and
   inclusions, achieving enhanced accuracy, efficiency, and reproducibility
   compared to traditional manual methods. It introduces the Microstructure
   Analysis Spectrum, a novel framework categorising techniques by task
   complexity and scalability, providing a new lens to understand AI's role
   in materials science. The paper also evaluates AI's role in chemical
   composition analysis and predictive modelling, facilitating rapid
   forecasts of mechanical properties such as hardness and fracture strain.
   Practical applications in steelmaking (e.g., automated inclusion
   characterisation) and case studies on high-entropy alloys and additively
   manufactured metals underscore AI's benefits, including reduced analysis
   time and improved quality control. Extending prior reviews, this work
   incorporates recent advancements like Vision Transformers, 3D
   Convolutional Neural Networks (CNNs), and Generative Adversarial
   Networks (GANs). Key challenges-data scarcity, model interpretability,
   and computational demands-are critically analysed, with representative
   trade-offs from the literature highlighted (e.g., GANs can substantially
   augment effective dataset size through synthetic data generation,
   typically at the cost of significantly increased training time).},
Type = {Review},
Affiliation = {Abdelal, G (Corresponding Author), Queens Univ Belfast, Sch Mech \& Aerosp Engn Belfast, Belfast BT9 5WA, North Ireland.
   Abdelal, Gasser; Chan, Chi-Wai, Queens Univ Belfast, Sch Mech \& Aerosp Engn Belfast, Belfast BT9 5WA, North Ireland.
   McLoone, Sean, Queens Univ Belfast, Sch Elect Elect Engn \& Comp Sci, Belfast BT9 5WA, North Ireland.},
DOI = {10.3390/app16020975},
Article-Number = {975},
Keywords = {machine learning; scanning electron microscopy; energy dispersive
   spectroscopy; metallic microstructure; semantic segmentation; object
   detection; instance segmentation; chemical composition analysis;
   predictive modelling},
Author-Email = {g.abdelal@qub.ac.uk
   c.w.chan@qub.ac.uk
   s.mcloone@qub.ac.uk},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001670104200001},
}

@article{ WOS:001664911000001,
Author = {Danyang, Cao and Xiaoya, Liu and Ying, Yang and Ling, Sun},
Title = {A density-adaptive denoising method for ICESat-2 photon-counting data},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2026},
Volume = {47},
Number = {4},
Pages = {1899-1921},
Month = {FEB 16},
Abstract = {The Ice, Cloud, and Land Elevation Satellite-2 (ICESat-2) is equipped
   with the Advanced Topographic Laser Altimeter System (ATLAS), which
   provides global elevation data coverage, including over polar regions,
   forests, and lakes. This high-resolution measurement capability is also
   well-suited for nearshore bathymetric mapping, which is essential for
   understanding marine ecosystems. However, the photon data collected by
   ATLAS are significantly affected by external noise, presenting
   challenges for accurate bathymetric detection. In this study, a
   density-adaptive three-stage photon denoising framework is proposed.
   First, the Density Peaks Clustering (DPC) algorithm is employed to
   distinguish underwater photons from above-water photons, thereby
   reducing misclassification. Subsequently, an Adaptive Multi-Density
   DBSCAN (AMD-DBSCAN) algorithm is applied to perform density-aware
   clustering, enabling the removal of noise photons under varying photon
   densities. Finally, the Local Outlier Factor (LOF) algorithm is utilized
   to further eliminate local-density anomalies and residual noise photons,
   enabling the precise extraction of surface and bottom signal photons. To
   enhance clarity and reproducibility, we explicitly describe the adaptive
   mechanism: the framework maintains only a small set of fixed global
   inputs, while the effective clustering parameters (\& Icirc;mu, MinPts,
   and k) are automatically derived from local photon spatial distributions
   rather than manually tuned. Bathymetric detection was conducted across
   four study areas with varying photon densities and nearshore
   environmental conditions and validated against in situ measurements.
   Moreover, the proposed method was compared with traditional OPTICS, a
   modified DBSCAN, and a two-step denoising approach. The results
   demonstrate that the proposed algorithm more effectively separates
   signal photons from noise and achieves consistently lower mean absolute
   error (MAE) across all study sites, outperforming all benchmark methods.},
Type = {Article},
Affiliation = {Ling, S (Corresponding Author), Natl Satellite Meteorol Ctr, 46 Zhongguancun South St, Beijing 100081, Peoples R China.
   Danyang, Cao; Xiaoya, Liu; Ying, Yang, North China Univ Technol, Sch Artificial Intelligence \& Comp Sci, Beijing, Peoples R China.
   Ling, Sun, Natl Ctr Space Weather, Inst Satellite Meteorol, Natl Satellite Meteorol Ctr, Beijing, Peoples R China.
   Ling, Sun, Xu Jianmin Meteorol Satellite Innovat Ctr, Beijing, Peoples R China.
   Ling, Sun, China Meteorol Adm, Natl Satellite Meteorol Ctr, Natl Ctr Space Weather, Key Lab Radiometr Calibrat \& Validat Environm Sate, Beijing, Peoples R China.},
DOI = {10.1080/01431161.2026.2612900},
EarlyAccessDate = {JAN 2026},
Keywords = {ICESat-2/ATLAS; bathymetry; density-based clustering algorithms;
   denoising},
Keywords-Plus = {SHALLOW-WATER; SENTINEL-2; BATHYMETRY},
Author-Email = {sunling@cma.gov.cn},
