   Chen, Yuting, Univ North Carolina Charlotte, Civil Engn Technol \& Construct Management, Charlotte, NC 28223 USA.
   Skitmore, Martin, Bond Univ, Fac Soc \& Design, Robina, Qld 4226, Australia.},
DOI = {10.3390/buildings16010010},
