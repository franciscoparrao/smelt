   Staes, An, VIB Prote Core, Ghent, Belgium.
   Clement, Lieven, Univ Ghent, Dept Appl Math Comp Sci \& Stat, Ghent, Belgium.},
DOI = {10.1021/acs.analchem.5c07014},
EarlyAccessDate = {FEB 2026},
Article-Number = {PMID 370536},
