   Juan, Angel A., Euncet Business Sch, ICSO Analyt, Cami Mas Rubial 1, Terrassa 08225, Spain.},
DOI = {10.3390/a19020114},
Article-Number = {114},
Keywords = {machine learning; household energy consumption; clustering; forecasting},
Author-Email = {ajuanp@upv.es},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001699774000001},
}

@article{ WOS:001697624200004,
Author = {Zhang, Xiaolin and Hou, Jue and Qi, Sumin and Wang, Zenan and Meng, Jing},
Title = {An Omni-Robust Style Transfer Model for Stem Cell Culture Systems},
Journal = {CHINESE JOURNAL OF LASERS-ZHONGGUO JIGUANG},
Year = {2026},
Volume = {53},
Number = {3},
Month = {FEB},
Abstract = {Objective Automated stem cell culture systems that utilize brightfield
   microscopy play a crucial role in regenerative medicine by enabling
   large-scale, standardized, and reproducible cell expansion, thereby
   ensuring a stable and reliable source of cells for downstream
   applications. For such systems, real-time and clear microscopic
   observation is essential, as it not only allows continuous monitoring of
   cell growth and morphological changes but also provides an objective
   basis for adjusting culture conditions, identifying the appropriate
   timing for subculturing, and guiding other experimental procedures.
   However, brightfield microscopy imaging is susceptible to variations in
   lighting conditions and suffers from low contrast and difficulty in
   accurate autofocusing, resulting in suboptimal observation outcomes.
   Style transfer technology based on deep learning can convert brightfield
   images into high-contrast phase-contrast images, but existing methods
   are generally limited by poor style transfer quality, slow imaging
   speed, and limited versatility, making it difficult to meet the needs of
   actual commercial applications. Therefore, we aim to develop a model
   that can convert brightfield images into phase-contrast images in real
   time, while simultaneously overcoming challenges such as uneven
   brightness and out-of-focus blur.
   Methods To enable high-definition, real-time monitoring in automated
   stem-cell culture systems, we proposed a lightweight
   brightfield-phase-contrast style-transfer framework composed of two core
   components: a histogram-based grayscale-normalization algorithm and a
   lightweight generative adversarial network (LW-GAN). Variations in
   illumination or device occlusion produce brightness shifts that
   significantly affect the quality of style transfer results. Fortunately,
   analysis of image histograms showed grayscale distributions
   approximately following a normal distribution with varying central
   values. Therefore, we proposed a histogram-based grayscale normalization
   algorithm that aligns each image's grayscale center to a fixed value
   (127), effectively removing brightness bias across the dataset. The
   inference speed of existing style transfer models is difficult to meet
   the frame rate requirements of real-time observation of cell culture. To
   this end, we developed a lightweight deep learning network LW-GAN, which
   is specifically used for the fast conversion of brightfield images to
   phase-contrast images. This model fully utilizes the inherent
   lightweight advantage of GANs-requiring only forward propagation of the
   generator during inference-and also makes key improvements in the model
   design: the conventional convolution and downsampling layers are
   replaced with depth-wise separable convolutions with a stride of 2. This
   optimization significantly reduces the model complexity, reducing the
   generator's parameter count by 69.7\%, and greatly improves the
   inference speed. In addition, to optimize the LW-GAN network, we
   proposed a multi-criterion loss function that combines generative
   adversarial loss, L1 loss, and multi-scale structural similarity index
   measure (MS-SSIM) loss to effectively improve the performance of style
   transfer.
   Results and Discussions Experiments show that LW-GAN produces
   phase-contrast images that closely match the ground truth in cell
   morphology, contrast, and brightness, and is highly robust to variations
   in cell density and defocus distance (Fig. 3). Quantitatively, style
   transfer results for in-focus images are slightly better than those for
   60 mu m out-of-focus images in terms of three key metrics (PSNR, SSIM,
   and LPIPS) (Table 1), but the difference is small, demonstrating the
   model's robustness to out-of-focus images. On a low-profile platform, a
   single image of size 2048 pixelx2592 pixel is processed in 0.095 s
   (similar to 10 frame/s) by the proposed LW-GAN, outperforming all
   comparative models on all reported metrics (Table 2). Furthermore,
   LW-GAN exhibits high generalizability to dermal and epidermal cell
   images (Fig. 5). In addition, to evaluate the effectiveness and
   generalizability of the grayscale-normalization algorithm, we performed
   style-transfer experiments on six cell types, including three from our
   self-built dataset and three from the public EVICAN dataset (MG-63, RKO,
   ACHN) (Fig. 6). Experimental results demonstrate that the grayscale
   normalization significantly enhances the output quality; without it,
   outputs tend to be underexposed and exhibit halo expansion, uneven
   illumination, and blurred edges.
   Conclusions To address the requirements for real-time and
   high-definition cell monitoring in automated stem-cell culture systems,
   we propose a style-transfer method based on a lightweight LW-GAN model
   that converts low-quality brightfield images into high-contrast
   phase-contrast images in real time and with high fidelity. The approach
   leverages the operational simplicity and low cost of brightfield
   microscopy while achieving clear observation of cell status through a
   lightweight network design. In addition, this method addresses the
   defocus blur issue induced by equipment jitter and effectively solves
   the problem of uneven brightness of the input image through an
   innovative grayscale normalization algorithm. Style transfer experiments
   across six cell types demonstrate the model's strong generalizability to
   diverse cellular morphologies. The network has been successfully
   deployed in the automated cell-culture system of Jinan Lingke
   Pharmaceutical Technology Co., Ltd., validating its practical utility
   and commercial value for industrial applications.},
Type = {Article},
Affiliation = {Meng, J (Corresponding Author), Qufu Normal Univ, Shandong Engn Res Ctr Med Phys Imaging Technol, Sch Comp, Shandong Key Lab Med Phys \& Image Proc, Rizhao 276826, Shandong, Peoples R China.
   Wang, ZN (Corresponding Author), Chinese Acad Sci, Inst Adv Integrat Technol, Shenzhen Inst Adv Technol, Shenzhen 518055, Guangdong, Peoples R China.
   Wang, ZN (Corresponding Author), Jinan Lingke Pharmaceut Technol Co Ltd, Jinan 250101, Shandong, Peoples R China.
   Zhang, Xiaolin; Qi, Sumin; Meng, Jing, Qufu Normal Univ, Shandong Engn Res Ctr Med Phys Imaging Technol, Sch Comp, Shandong Key Lab Med Phys \& Image Proc, Rizhao 276826, Shandong, Peoples R China.
   Hou, Jue; Wang, Zenan, Chinese Acad Sci, Inst Adv Integrat Technol, Shenzhen Inst Adv Technol, Shenzhen 518055, Guangdong, Peoples R China.
   Wang, Zenan, Jinan Lingke Pharmaceut Technol Co Ltd, Jinan 250101, Shandong, Peoples R China.},
DOI = {10.3788/CJL251049},
Article-Number = {0307109},
Keywords = {optical microscopic imaging; stem cell culture; style transfer; deep
   learning},
Keywords-Plus = {IMAGE},
