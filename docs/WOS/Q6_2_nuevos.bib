Keywords = {Building renovation; Energy performance; Parametric modelling; Building
   simulation; Decision support},
Keywords-Plus = {CONSUMPTION; REFURBISHMENT; STOCK; DEFINITION; MODELS},
Author-Email = {maryam.fakhari@ebd.lth.se},
