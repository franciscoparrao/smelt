@article{ WOS:001658246000001,
Author = {Durkin, Alex and Stolte, Jasper and Jones, Matthew and Pitchumani,
   Raghuraman and Li, Bei and Michler, Christian and Mercangoz, Mehmet},
Title = {Safe deployment of offline reinforcement learning via input convex
   action correction},
Journal = {COMPUTERS \& CHEMICAL ENGINEERING},
Year = {2026},
Volume = {206},
Month = {MAR},
Abstract = {Offline reinforcement learning (offline RL) offers a promising framework
   for developing control strategies in chemical process systems using
   historical data, without the risks or costs of online experimentation.
   This work investigates the application of offline RL to the safe and
   efficient control of an exothermic polymerisation continuous
   stirred-tank reactor. We introduce a Gymnasium-compatible simulation
   environment that captures the reactor's nonlinear dynamics, including
   reaction kinetics, energy balances, and operational constraints. The
   environment supports three industrially relevant scenarios: startup,
   grade change down, and grade change up. It also includes reproducible
   offline datasets generated from proportional-integral controllers with
   randomised tunings, providing a benchmark for evaluating offline RL
   algorithms in realistic process control tasks. We assess behaviour
   cloning and implicit Q-learning as baseline algorithms, highlighting the
   challenges offline agents face, including steady-state offsets and
   degraded performance near setpoints. To address these issues, we propose
   a novel deployment-time safety layer that performs gradient-based action
   correction using partially input convex neural networks (PICNNs) as
   learned cost models. The PICNN enables real-time, differentiable
   correction of policy actions by descending a convex, state-conditioned
   cost surface, without requiring retraining or environment interaction.
   Experimental results show that offline RL, particularly when combined
   with convex action correction, can outperform traditional control
   approaches and maintain stability across all scenarios. These findings
   demonstrate the feasibility of integrating offline RL with interpretable
   and safety-aware corrections for high-stakes chemical process control,
   and lay the groundwork for more reliable data-driven automation in
   industrial systems.},
Type = {Article},
Affiliation = {Durkin, A (Corresponding Author), Imperial Coll London, Dept Chem Engn, London SW7 2AZ, England.
   Durkin, Alex; Mercangoz, Mehmet, Imperial Coll London, Dept Chem Engn, London SW7 2AZ, England.
   Stolte, Jasper; Jones, Matthew; Li, Bei; Michler, Christian, Shell Informat Technol Int BV, NL-1031 HW Amsterdam, Netherlands.
   Pitchumani, Raghuraman, Shell Global Solut Int BV, NL-1031 HW Amsterdam, Netherlands.},
DOI = {10.1016/j.compchemeng.2025.109535},
EarlyAccessDate = {DEC 2025},
Article-Number = {109535},
Keywords = {Offline reinforcement learning; Process control; Safety; Convex neural
   networks},
Keywords-Plus = {GRADE TRANSITION; CONTROL BARRIER; OPTIMIZATION},
Author-Email = {alexander.durkin14@imperial.ac.uk
   m.mercangoz@imperial.ac.uk},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001658246000001},
}

@article{ WOS:001658225200001,
Author = {Nie, Qiyang and Liu, Tong},
Title = {Large language models for environmental modeling: Framework,
   capabilities, constraints},
Journal = {JOURNAL OF ENVIRONMENTAL MANAGEMENT},
Year = {2026},
Volume = {398},
Month = {JAN 15},
Abstract = {Environmental modeling faces growing complexity, yet practical pathways
   for integrating Large Language Models (LLMs) remained limited. We
   introduce two practical, reproducible frameworks that embed LLMs into
   core modeling workflows: a human-AI collaborative ``Copilot{''} and an
   LLM-driven automation ``Autopilot{''}. Using the
   Rainfall-Runoff-Inundation (RRI) model in Japan's Kuzuryu River basin,
   we evaluate both frameworks on parameter calibration and real-time
   correction. Copilot framework demonstrated robust performance,
   leveraging prompt engineering to guide LLMs in algorithm comprehension
   and code generation. It implemented advanced optimization and correction
   algorithms, achieving strong performance in parameter calibration
   (Nash-Sutcliffe Efficiency of 0.91 for calibration and 0.81 for
   validation) and delivering stable real-time correction. Autopilot
   framework showed competence in physics-constrained parameter calibration
   but failed in the long-sequence, data-intensive task of real-time
   correction, revealing instability caused by ``attention decay{''}. This
   stark contrast underscores the importance of strategic task design and
   human oversight. Our findings highlight that LLMs currently excel as
   powerful knowledge engines and coding assistants within human-supervised
   workflows (Copilot), whereas full automation (Autopilot) remains
   constrained by context window limitations and inherent weaknesses in
   processing long numerical sequences. This study provides a
   methodological framework, practical implementation guidance, and design
   principles (task decomposition, physics constraints, oversight
   checkpoints) to support generalizable deployment of LLMs in
   environmental modeling, and we outline testable directions for improving
   robustness, scalability, and reproducibility.},
Type = {Article},
Affiliation = {Liu, T (Corresponding Author), Hokkaido Univ, Grad Sch Environm Sci, Sapporo 0600810, Japan.
   Liu, T (Corresponding Author), Hokkaido Univ, Fac Environm Earth Sci, Sapporo 0600810, Japan.
   Nie, Qiyang; Liu, Tong, Hokkaido Univ, Grad Sch Environm Sci, Sapporo 0600810, Japan.
   Liu, Tong, Hokkaido Univ, Fac Environm Earth Sci, Sapporo 0600810, Japan.},
DOI = {10.1016/j.jenvman.2025.128417},
EarlyAccessDate = {DEC 2025},
Article-Number = {128417},
Keywords = {Large language model; Environmental modeling; Flood model; Calibration;
   Real-time correction; Copilot framework; Autopilot framework},
Keywords-Plus = {FLOOD; RUNOFF},
Author-Email = {qiyangnie@elms.hokudai.ac.jp
   liutong@ees.hokudai.ac.jp},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001658225200001},
}

@article{ WOS:001658064600001,
Author = {Mim, Juhi Jannat and Al Mamun, Abdullah and Nayem, Mahtab Hossain and
   Mahmud, Suzon and Nath, Antu and Rahman, Sm Maksudur and Fidal, Shekh
   Asraful and Hossain, Nayem},
Title = {Machine learning-driven advances in nanotechnology: From materials
   design to process optimization-A review},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2026},
Volume = {50},
Month = {JAN},
Abstract = {Nanotechnology has undergone a rapid transformation due to machine
   learning (ML), which has enabled the identification, design, and control
   of nanoscale materials and devices using data-driven approaches. It is
   an amalgam of recent advances in machine learning methods, including
   deep neural networks, reinforcement learning, Bayesian inference,
   supervised and unsupervised learning, and their potential applications
   in the synthesis, characterization, production, and quality control of
   nanomaterials. Using a variety of data (microscopy, spectroscopy,
   high-throughput simulations, and process logs), we highlight how machine
   learning (ML) expedites the identification of structure-property and
   process-outcome relationships. This paper also highlight how surrogate
   models, active learning, and Bayesian optimization reduce costly
   experimental cycles. Equivariant graph neural networks, multi-fidelity
   and hybrid mechanistic-data models, symmetry-aware and physics-inspired
   architectures, and closed-loop robots with automatic exploration
   capabilities are significant technological advancements. Applications
   that have been reviewed include catalysis, plasmonics, nanoelectronics,
   biomedical nanomaterials, and real-time process optimization in both
   top-down and bottom-up creation. Provide an overview of the remaining
   problems, such as the lack of diversity of labeled data, metadata
   standardization, domain shift, interpretability, causal inference, and
   multi-scale integration. Also present are promising avenues, such as
   inverse-design frameworks, standardized pipelines to automated
   characterization, and uncertainty-aware surrogates. Finally, discuss how
   improved data practices, hybrid models, and combining machine learning
   with automated experimentation may lead to greater reproducibility and
   transferability. This study also forecast that ML-driven approaches will
   continue to speed up the discovery and large-scale manufacturing of
   nanoscale technologies.},
Type = {Review},
Affiliation = {Mim, JJ (Corresponding Author), Int Univ Business Agr \& Technol, Miyan Res Inst, Dhaka 1230, Bangladesh.
   Mim, Juhi Jannat, Int Univ Business Agr \& Technol, Miyan Res Inst, Dhaka 1230, Bangladesh.
