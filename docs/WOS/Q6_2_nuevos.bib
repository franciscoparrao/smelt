   Cho, Kyungeun, Dongguk Univ Seoul, Coll Adv Convergence Engn, Dept Comp Sci \& Artificial Intelligence, 30 Pildongro 1 Gil, Seoul 04620, South Korea.},
DOI = {10.3390/systems14020175},
Article-Number = {175},
Keywords = {game knowledge management system; generative AI; large language models;
   schema-governed systems; engine-level application; game AI},
