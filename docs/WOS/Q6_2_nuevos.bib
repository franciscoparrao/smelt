   Cao, Wen; Guo, Ruijun, Capital Med Univ, Beijing Chaoyang Hosp, Dept Ultrasound Med, 8 Gongti South Rd, Beijing 100020, Peoples R China.
   Zhu, Xiaoyang; Yan, Zongliang, Beijing Vis Percept Artificial Intelligence Lab, Beijing, Peoples R China.},
DOI = {10.21037/qims-2025-aw-2434},
Article-Number = {199},
Keywords = {Cervical ultrasound; deep learning; medical image segmentation; nerve
   identification; You Only Look Once, version 11 (YOLOv11)},
Author-Email = {ruijunguo@126.com
   zhiyongbai@sina.com},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001715134100023},
}

@article{ WOS:001713382900001,
Author = {Boutahri, Youssef and Tilioua, Amine},
Title = {Economic model predictive control for energy-efficient residential
   heating under dynamic electricity pricing},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {This study develops and evaluates an Economic Model Predictive Control
   (EMPC) for residential heating under dynamic electricity pricing,
   benchmarked against a standard Comfort-Oriented MPC (C-MPC). An RC
   thermal model is driven by real price traces and weather data. EMPC
   embeds time-varying tariffs directly in the objective and includes a
   Delta u penalty to smooth actuation. The evaluation reports cost,
   energy, peak demand, and comfort, with bootstrap 95\% confidence
   intervals. Robustness is tested under forecast errors in prices and
   temperature (MAPE 5-20\%, bias scenarios). Computational feasibility is
   quantified through problem size, solver configuration, and per-step
   solve time relative to the sampling period. Results show -19.5\% total
   heating cost, -10\% energy use, and peak demand reduced from 3.8 to 3.4
   kW with indoor temperature held in 18-22 degrees C. Savings persist
   under moderate forecast errors, and the Delta u term lowers total
   variation in control actions. Solve times remain within the sampling
   budget, indicating real-time viability. These findings establish that
   price-aware MPC yields measurable economic and energy benefits without
   compromising comfort, while remaining implementable on typical building
   automation stacks. The approach supports demand-response readiness and
   provides a transparent, reproducible baseline for establishing the
   theoretical upper bound of economic efficiency in residential heating.},
Type = {Article},
Affiliation = {Boutahri, Y; Tilioua, A (Corresponding Author), Moulay Ismail Univ Meknes, Fac Sci \& Tech Errachidia, Res Team Thermal \& Appl Termodynam 2TA, Dept Engn Sci, BP 509, Boutalamine, Errachidia, Morocco.
   Boutahri, Youssef; Tilioua, Amine, Moulay Ismail Univ Meknes, Fac Sci \& Tech Errachidia, Res Team Thermal \& Appl Termodynam 2TA, Dept Engn Sci, BP 509, Boutalamine, Errachidia, Morocco.},
DOI = {10.1016/j.rineng.2026.109765},
Article-Number = {109765},
Keywords = {Economic model predictive control; Intelligent building energy
   management; Dynamic electricity pricing; Energy cost savings; Thermal
   comfort; Energy efficiency},
Keywords-Plus = {THERMAL COMFORT; BUILDINGS; OPTIMIZATION},
Author-Email = {yo.boutahri@edu.umi.ac.ma
   a.tilioua@umi.ac.ma},
Number-of-Cited-References = {53},
Times-Cited = {0},
Unique-ID = {WOS:001713382900001},
}

@article{ WOS:001713177300001,
Author = {El Makroum, Reda and Zwickl-Bernhard, Sebastian and Kranzl, Lukas},
Title = {Agentic AI home energy management system: A large language model
   framework for residential load scheduling},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {The electricity sector transition requires increased residential demand
   response capacity, yet Home Energy Management Systems (HEMS) adoption
   remains limited by user interaction barriers. Large language models
   (LLMs) offer potential to address these barriers through natural
   language interaction; however, existing implementations employ LLMs as
   rule generators, optimizers, or parameter extractors rather than
   autonomous coordinators for multi-appliance scheduling. This paper
   presents an agentic AI HEMS where LLMs autonomously coordinate
   scheduling from natural language requests. A hierarchical architecture
   combining one orchestrator agent with three specialist agents is
   developed using the ReAct pattern, enabling dynamic coordination.
   Evaluation across three open-source models (Llama-3.3-70B, Qwen-3-32B,
   GPT-OSS-120B) using real Austrian day-ahead electricity prices reveals
   substantial capability differences for multi-appliance coordination.
   Llama-3.3-70B successfully coordinates all three appliances across all
   evaluation scenarios to match cost-optimal benchmarks computed via
   mixed-integer linear programming, while Qwen-3-32B and GPT-OSS-120B
   struggle to coordinate all appliances simultaneously despite achieving
   perfect single-appliance performance. The demonstrated system enables
   natural-language-based scheduling without technical parameter
   specification, offering a pathway to address configuration complexity
   barriers that currently limit residential HEMS adoption. All system
   components, including complete agent prompts, orchestration logic, and
   simulation user interfaces, are released as open source to enable
   reproducibility and further development.},
Type = {Article},
Affiliation = {El Makroum, R (Corresponding Author), Tech Univ Wien, Energy Econ Grp EEG, Gusshaus Str 25-29-E370-3, A-1040 Vienna, Austria.
   El Makroum, Reda; Zwickl-Bernhard, Sebastian; Kranzl, Lukas, Tech Univ Wien, Energy Econ Grp EEG, Gusshaus Str 25-29-E370-3, A-1040 Vienna, Austria.
   Zwickl-Bernhard, Sebastian, Norwegian Univ Sci \& Technol, Dept Ind Econ \& Technol Management, Trondheim, Norway.},
DOI = {10.1016/j.rineng.2026.109857},
Article-Number = {109857},
Keywords = {Agentic AI; Home energy management systems; Large language models;
   Demand response; Load scheduling},
Author-Email = {elmakroum@eeg.tuwien.ac.at
   zwickl@eeg.tuwien.ac.at
   kranzl@eeg.tuwien.ac.at},
Number-of-Cited-References = {34},
Times-Cited = {0},
Unique-ID = {WOS:001713177300001},
}

@article{ WOS:001710831200001,
Author = {Lu, Wenjing and Tang, Yijun and Luo, Jie and Zhang, Chenhao and Zhu,
   Lihua},
Title = {Multimodal transformer-based fusion for breast ultrasound: Segmentation
   and BI-RADS classification},
Journal = {JOURNAL OF RADIATION RESEARCH AND APPLIED SCIENCES},
Year = {2026},
Volume = {19},
Number = {1},
Month = {MAR},
Abstract = {Objective: improving reproducibility and diagnostic performance in
   ultrasound BI-RADS classification using multimodal learning. Materials
   and methods: This multicenter retrospective study included 1231 internal
   and 498 external breast ultrasound examinations covering BI-RADS
   categories 1-5. Automated lesion segmentation was performed using
   advanced deep learning models and benchmarked against radiologist
   annotations. Quantitative radiomic descriptors, transformer-based deep
   imaging features, structured clinical variables, and selected genomic
   biomarkers (clinically established mutation and receptor status
   indicators) were extracted from segmented lesions. Feature robustness
   and relevance were ensured through reproducibility filtering and
   multistage selection strategies. Multimodal data were integrated using a
   transformer-based fusion architecture with dimensionality reduction.
   Model performance was evaluated on internal and external cohorts using
   discrimination, calibration, and clinical utility metrics. Results: The
   ensemble segmentation approach achieved an external Dice coefficient of
   89.9\%, comparable to radiologist inter-observer agreement.
   Radiomic-only models achieved an external accuracy of 71.0\% (AUC =
   0.717), deep ViT-based features improved accuracy to 78.9\% (AUC =
   0.808), and genomic features alone achieved 84.0\% accuracy (AUC =
   0.856). For five-class BI-RADS (categories 1-5) classification, the
   fused multi-modal FT-Transformer model achieved the best external
   performance, with an overall accuracy of 94.7\%, sensitivity of 94.2\%,
   and an area under the receiver operating characteristic curve (AUC =
   0.962). Conclusion: The proposed multimodal AI framework enables robust,
   generalizable, and clinically useful BI-RADS classification from breast
   ultrasound.},
Type = {Article},
Affiliation = {Zhu, LH (Corresponding Author), First Peoples Hosp Yibin, Dept Breast \& Thyroid, 16 Puhedong Rd, Xuzhou Ave, Yibin 644000, Peoples R China.
   Lu, Wenjing; Tang, Yijun; Luo, Jie, First Peoples Hosp Yibin, Dept Ultrasound, 16 Puhedong Rd, Xuzhou Ave, Yibin 644000, Peoples R China.
   Zhang, Chenhao; Zhu, Lihua, First Peoples Hosp Yibin, Dept Breast \& Thyroid, 16 Puhedong Rd, Xuzhou Ave, Yibin 644000, Peoples R China.},
DOI = {10.1016/j.jrras.2026.102260},
Article-Number = {102260},
Keywords = {Breast ultrasound; BI-RADS classification; Radiomic features; Deep
   learning; Transformer models; Genomic biomarkers; Multi-modal fusion;
   Machine learning; Clinical decision support},
Keywords-Plus = {RADIOMICS},
Author-Email = {xiaoqian2277@163.com},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001710831200001},
}

@article{ WOS:001710183400017,
Author = {Zahn, Andrew and Overla, Seth and Lowrie, D. J. and Zhou, Christine Y.
   and Santen, Sally A. and Zheng, Weibing and Turner, Laurah},
Title = {An artificial intelligence-driven platform for practice question
   generation},
Journal = {ACADEMIC MEDICINE},
Year = {2026},
Volume = {101},
Number = {3},
Pages = {279-283},
Month = {MAR},
Abstract = {Problem Teaser: High-stakes licensing examinations drive medical
   education, yet high-quality preparation resources remain expensive and
   unequally accessible. This Innovation Report describes the development
   and pilot of a scalable, artificial intelligence (AI)-driven platform
   designed to generate USMLE-style practice questions aligned with
   National Board of Medical Examiners (NBME) guidelines. Leveraging Large
   Language Models (LLMs) enhanced with Retrieval-Augmented Generation
   (RAG) and strict schema validation, the authors generated 565 questions
   for a preclinical hematology course. A human-in-the-loop validation
   process ensured 87\% of generated items met rigorous accuracy and
   formatting standards. When deployed via a mobile application, the tool
   saw robust student engagement and a trend toward improved exam
   performance. This report offers a reproducible technical framework for
   institutions to create cost-effective, high-quality assessment tools,
   potentially reducing financial barriers for trainees and narrowing
   equity gaps in medical education. High-stakes licensing exams such as
   the United States Medical Licensing Examination (USMLE) play a critical
   role in medical education, influencing both trainee progression and
   patient outcomes. Access to high-quality board preparation resources is
   uneven and often cost-prohibitive, disproportionately affecting students
   from underrepresented or financially disadvantaged backgrounds.Problem
   Teaser: High-stakes licensing examinations drive medical education, yet
   high-quality preparation resources remain expensive and unequally
   accessible. This Innovation Report describes the development and pilot
   of a scalable, artificial intelligence (AI)-driven platform designed to
   generate USMLE-style practice questions aligned with National Board of
   Medical Examiners (NBME) guidelines. Leveraging Large Language Models
   (LLMs) enhanced with Retrieval-Augmented Generation (RAG) and strict
   schema validation, the authors generated 565 questions for a preclinical
   hematology course. A human-in-the-loop validation process ensured 87\%
   of generated items met rigorous accuracy and formatting standards. When
   deployed via a mobile application, the tool saw robust student
   engagement and a trend toward improved exam performance. This report
   offers a reproducible technical framework for institutions to create
   cost-effective, high-quality assessment tools, potentially reducing
   financial barriers for trainees and narrowing equity gaps in medical
   education. High-stakes licensing exams such as the United States Medical
   Licensing Examination (USMLE) play a critical role in medical education,
   influencing both trainee progression and patient outcomes. Access to
   high-quality board preparation resources is uneven and often
   cost-prohibitive, disproportionately affecting students from
   underrepresented or financially disadvantaged backgrounds.Approach An
   artificial intelligence (AI)-driven system to generate USMLE-style
   practice questions aligned with National Board of Medical Examiners
   (NBME) item-writing guidelines using a Large Language Model (LLM)
   enhanced with retrieval augmented generation, chain-of-thought and
   few-shot prompting, and JavaScript Object Notation schema validation was
   developed and piloted at the University of Cincinnati College of
   Medicine between November and December 2023. Five lectures from a
   preclinical hematology course were selected, and 565 questions were
   generated for 177 first-year medical students.
   A human-in-the-loop process, led by a faculty course director, ensured
   content validity and adherence to educational standards. Validated
   questions were deployed via a mobile app, allowing students to practice,
   receive performance feedback, and access an AI tutor.Outcomes Of the 565
   questions, 490 (87\%) were deemed accurate and NBME-compliant. Eighty
   students used the question bank, completing up to 220 questions each.
   Although not statistically significant, increased use trended toward
   improved performance on related exam questions. Qualitative feedback
   highlighted enthusiasm for AI-assisted study tools, with calls for
   broader content coverage.Next Steps This pilot demonstrates that LLMs
   can generate high-quality, guideline-aligned practice questions. To
   improve scalability and reduce faculty workload, future iterations will
   incorporate AI-based review agents for pre-screening content. The
   platform is intended to be expanded to additional courses, training
   phases, and health professions. Ongoing refinement will focus on
   improving content specificity and maintaining accuracy, especially in
   advanced and subspecialty education.},
Type = {Article},
Affiliation = {Turner, L (Corresponding Author), Univ Cincinnati, Coll Med, Artificial Intelligence \& Educ Informat, 231 Albert Sabin Way, Cincinnati, OH 45267 USA.
   Zahn, Andrew, Univ Cincinnati, Coll Med, Cincinnati, OH USA.
   Overla, Seth; Turner, Laurah, Univ Cincinnati, Coll Med, Artificial Intelligence \& Educ Informat, 231 Albert Sabin Way, Cincinnati, OH 45267 USA.
   Lowrie, D. J.; Santen, Sally A.; Turner, Laurah, Univ Cincinnati, Coll Med, Dept Med Educ, Cincinnati, OH USA.
