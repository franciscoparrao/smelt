DOI = {10.3390/polym18050658},
Article-Number = {658},
Keywords = {PVC composites; ontology; circular economy; ontology-driven simulation;
   lifecycle assessment (LCA); agro-industrial waste fillers; semantic web
   technologies; sustainable manufacturing; Granta; EduPack},
