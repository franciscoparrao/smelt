   Elnakar, Haitham, King Fahd Univ Petr \& Minerals, Interdisciplinary Res Ctr Construction \& Bldg Mat, Dhahran 31261, Saudi Arabia.},
DOI = {10.1016/j.dwt.2025.101598},
EarlyAccessDate = {DEC 2025},
Article-Number = {101598},
Keywords = {Perfluorooctanoic acid (PFOA); PFAS; Electrochemical oxidation;
   Automated Machine Learning (AutoML); FLAML (Fast Lightweight AutoML);
