}

@article{ WOS:001707010500001,
Author = {Kumari, Shalini and Yadav, Geeta},
Title = {Vuln2Action: An LLM-based framework for generating vulnerability
   reproduction steps and mapping exploits},
Journal = {JOURNAL OF INFORMATION SECURITY AND APPLICATIONS},
Year = {2026},
Volume = {99},
Month = {JUN},
Abstract = {Cyber Threat Intelligence (CTI) plays a critical role in understanding
   and mitigating evolving cyber risks in modern networking environments
   Despite the availability of structured CTI sources like NVD, CWE, CAPEC,
   and Exploit-DB, penetration testing remains a largely manual process,
   especially when reproducing known vulnerabilities. Notably, only 0.4\%
   of vulnerabilities listed in the NVD have corresponding exploits in
   Exploit-DB, leaving security professionals to manually craft
   reproduction steps and exploit code, which is error-prone and
   time-consuming. LLMs such as GPT have demonstrated potential in natural
   language generation, their application to cybersecurity is limited due
   to their general-domain training, lack of structured data integration,
   and tendency to produce hallucinated responses. In this paper, we
   propose Vuln2Action, a novel LLM-based framework designed to automate
   vulnerability reproduction by generating actions and mapping
   step-by-step exploits. We first construct a semantically enriched
   dataset that aligns CVE entries with their associated CWE, CPE, CAPEC,
   and Exploit-DB records using vector-based similarity methods. Our custom
   NLP pipeline systematically maps and fuses these taxonomies to provide
   the contextual grounding needed for accurate exploit generation. We also
   developed a user-friendly graphical interface that enables researchers
   and practitioners to easily explore relevant attack patterns and mapped
   exploits. Vuln2Action fine-tunes a T5-based model on this curated
   dataset to produce deterministic and context-aware exploit flows.
   Although Vuln2Action is constrained to Exploit-DB for exploit code, this
   design choice ensures transparency, reproducibility, and reliance on
   verified community-sourced proof-of-concepts.},
Type = {Article},
Affiliation = {Yadav, G (Corresponding Author), Indian Inst Technol IIT Ropar, Dept Comp Sci \& Engn, Rupnagar, Punjab, India.
   Kumari, Shalini; Yadav, Geeta, Indian Inst Technol IIT Ropar, Dept Comp Sci \& Engn, Rupnagar, Punjab, India.},
DOI = {10.1016/j.jisa.2026.104420},
Article-Number = {104420},
Keywords = {Cyber security; Large language models; Cyber threat intelligence; CVE},
Author-Email = {geeta@iitrpr.ac.in},
Number-of-Cited-References = {53},
Times-Cited = {0},
Unique-ID = {WOS:001707010500001},
}

@article{ WOS:001706629500001,
Author = {Kumar, M. Suresh and Babu, N. Ramesh},
Title = {Underwater waste detection via quadruple neutrosophic image enhancement
   for marine environmental monitoring},
Journal = {MARINE POLLUTION BULLETIN},
Year = {2026},
Volume = {227},
Month = {JUN},
Abstract = {The increasing accumulation of waste in marine environments poses a
   serious threat to aquatic ecosystems and marine biodiversity. Effective
   detection and monitoring of this waste are crucial for environmental
   protection. However, underwater conditions such as poor lighting,
   turbidity, and color distortion make image-based detection highly
   challenging. Traditional enhancement methods often struggle to handle
   the visual inconsistency and unclear information present in underwater
   imagery, leading to reduced detection accuracy. To overcome these
   challenges, this paper introduces a novel Quadruple Neutrosophic Image
   Enhancement (QNIE) method aimed at improving both the visibility and
   accuracy of underwater waste detection. The proposed approach introduces
   four key components-truth, falsity, ignorance, and contradiction which
   enable effective handling of incomplete and conflicting visual
   information while enhancing critical image features such as edges and
   textures. Furthermore, when integrated with the YOLOv11 model, the
   proposed QNIE-YOLOv11 framework achieves 87\% precision, 79\% recall,
   and 84\% mAP@0.5 on Underwater-Garbage-Debris Dataset, whereas the
   baseline YOLOv11 without QNIE attains only 79\% precision, 64\% recall,
   and 72\% mAP@0.5. These results confirm that the proposed method
   delivers significant improvements in detection accuracy and visual
   quality over existing techniques, strengthening the reliability of
   automatic waste monitoring systems. This indicates that the proposed
   method not only advances underwater image analysis but also contributes
   to marine conservation and ecosystem protection, supporting broader
   environmental initiatives such as the United Nations Sustainable
   Development Goal 14 stating Life Below Water. All experiments were
   conducted using a fixed train-test split of the dataset, with images
   resized to a uniform resolution, standard data augmentation, and
   identical YOLOv11 training and inference settings to ensure fair and
   reproducible evaluation.},
Type = {Article},
Affiliation = {Kumar, MS (Corresponding Author), Vellore Inst Technol, Sch Adv Sci, Dept Math, Chennai 600127, Tamilnadu, India.
   Kumar, M. Suresh; Babu, N. Ramesh, Vellore Inst Technol, Sch Adv Sci, Dept Math, Chennai 600127, Tamilnadu, India.},
DOI = {10.1016/j.marpolbul.2026.119478},
Article-Number = {119478},
Keywords = {Underwater image enhancement; Quadruple neutrosophic; Object detection;
   Underwater waste},
Keywords-Plus = {SYSTEM; FUSION; COLOR},
Author-Email = {sureshkumar.m2024@vitstudent.ac.in
   n.rameshbabu@vit.ac.in},
Number-of-Cited-References = {60},
Times-Cited = {0},
Unique-ID = {WOS:001706629500001},
}

@article{ WOS:001704384600001,
Author = {Yang, Wenjie and Lin, Tiefeng and Zhang, Jinyou and Sun, Xianda and Xu,
   Chengwu and Zhao, Ling and Fu, Baizhou and Zhou, Yue and Kang, Dejiang
   and Wang, Yan and Wu, Wei and Tian, Tian},
Title = {Crude oil density prediction and visualization by CLSM fluorescence
   spectroscopy combined with chemometric methods},
Journal = {METHODS AND APPLICATIONS IN FLUORESCENCE},
Year = {2026},
Volume = {14},
Number = {2},
Month = {JUN 1},
Abstract = {This study presents a metrologically traceable, microscale measurement
   framework integrating Confocal Laser Scanning Microscopy (CLSM),
   fluorescence spectroscopy, and chemometric modeling for quantitative
   crude oil density mapping. Thirty-three samples from the Songliao Basin
   (0.764-0.9655 g cm-3) were analyzed under 488 nm excitation with
   emission spectra collected from 500-794 nm. Baseline correction,
   smoothing, and normalization improved spectral consistency, while
   principal component analysis with Hotelling's T2 removed two outliers
   prior to modeling. Support Vector Regression (SVR) outperformed Partial
   Least Squares Regression (PLSR), achieving a calibration R2\_cal of
   0.968 (RMSEC = 0.008) and a prediction R2\_pre of 0.955 (RMSEP = 0.012).
   The 737 nm wavelength exhibited the strongest correlation (r = 0.748,
   Pearson correlation coefficient) with aromatic and asphaltene content,
   linking molecular composition to density variation. Applied to CLSM
   spectral images of shale thin sections, the SVR model produced
   micrometre-scale density maps consistent with compositional
   heterogeneity-light fractions along fracture walls and heavy fractions
   within fracture interiors. A standalone desktop tool has been developed
   to enable spectral import, automated processing, and density
   visualization. This non-destructive, high-resolution approach addresses
