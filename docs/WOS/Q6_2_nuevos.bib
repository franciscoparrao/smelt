   Suda, Shuya; Ikuta, Koji, Univ Tokyo, Grad Sch Informat Sci \& Technol, Tokyo 1138657, Japan.},
DOI = {10.3390/biomedicines14020445},
Article-Number = {445},
Keywords = {embryoid body; differentiation; 3D-CNN; microwell; time-lapse;
   label-free},
Keywords-Plus = {CELL-CULTURE; STEM-CELLS; DIFFERENTIATION},
