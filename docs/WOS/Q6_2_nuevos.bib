}

@incollection{ WOS:001592466600026,
Author = {Rajenthiram, Keerthiga and Delporte, Pauline and Lago, Patricia},
Editor = {Bianculli, D and Sartaj, H and Andrikopoulos, V and Pautasso, C and Mikkonen, T and Perez, J and Bures, T and DeSanctis, M and Muccini, H and Navarro, E and Soliman, M and Zdun, U},
Title = {AutoML: A Tertiary Study of Phases, Methods, Tools, and Frameworks},
Booktitle = {SOFTWARE ARCHITECTURE. ECSA 2025 TRACKS AND WORKSHOPS},
Series = {Lecture Notes in Computer Science},
Year = {2026},
Volume = {15982},
Pages = {313-328},
Abstract = {Automated Machine Learning (AutoML) plays a pivotal role in making
   machine learning more accessible by automating key steps in the model
   development process. Over the past decade, an increasing number of
   literature reviews (LRs) have examined specific components of AutoML,
   including data preparation, feature engineering, model generation,
   neural architecture search, hyperparameter optimization, and evaluation.
   However, a unified synthesis that consolidates findings across these
   reviews is missing. This paper presents a tertiary review of 32 LRs to
   provide a comprehensive and up-to-date overview of the AutoML landscape.
   We systematically analyze the core AutoML phases, categorize AutoML
   methods used across different stages of the machine learning (ML)
   pipeline, and compile a set of AutoML frameworks and tools. The
   synthesis offers a panoramic view of the techniques and tools supporting
   automation across ML phases. Our findings aim to serve as a reference
   for researchers and practitioners seeking to understand the current
   state of AutoML, the extent of automation achieved across pipeline
   stages, and the tools and platforms that support these capabilities.},
Type = {Proceedings Paper},
Affiliation = {Rajenthiram, K (Corresponding Author), Vrije Univ Amsterdam, Amsterdam, Netherlands.
   Rajenthiram, Keerthiga; Lago, Patricia, Vrije Univ Amsterdam, Amsterdam, Netherlands.
   Delporte, Pauline, CS Grp, Le Plessis Robinson, France.},
DOI = {10.1007/978-3-032-04403-7\_26},
Keywords = {Automated Machine Learning (AutoML); Tertiary Study; Literature Review
   (LR); AutoML Tools and Frameworks; Automation in Machine Learning (ML)},
Author-Email = {k.rajenthiram@vu.nl
   pauline.delporte@cs-soprasteria.com
   p.lago@vu.nl},
Number-of-Cited-References = {67},
Times-Cited = {0},
Unique-ID = {WOS:001592466600026},
}

@incollection{ WOS:001579298700036,
Author = {Pintz, Maximilian and Becker, Daniel and Mock, Michael},
Editor = {Torngren, M and Gallina, B and Schoitsch, E and Troubitsyna, E and Bitsch, F},
Title = {A Modular AI Testing Framework for Trustworthy AI: Proof-of-Concept
   Implementation},
Booktitle = {COMPUTER SAFETY, RELIABILITY, AND SECURITY. SAFECOMP 2025 WORKSHOPS,
   COC3CPS, DECSOS, SASSUR, SENSEI, SRTOITS, AND WAISE},
Series = {Lecture Notes in Computer Science},
Year = {2026},
Volume = {15955},
Pages = {459-471},
Abstract = {While independent and reproducible software testing is widely
   established in safety-critical systems and also supported by development
   and testing infrastructures, there is still no adequate counterpart for
   testing of AI systems. In contrast, current AI tests tend to be tightly
   integrated into the development framework and are not modular in the
   sense that testing code and system-under-test (SUT) are strictly
   separable in terms of their software environments. In this paper, we
   present an AI testing framework for trustworthy AI that aims to support
   independent, reproducible and auditable AI testing by providing a
   design-pattern of computational testing workflows, which strongly
   promotes that individual tests are modular, reproducible, and
   automatable while maintaining a high-degree of auditablility. To
   demonstrate the viability and usefulness of this framework, we use it to
   create a workflow template for the case of metric-based testing of AI
   models using test datasets and implement a proof-of-concept (PoC) for
   the specific case of performance tests of visual object detectors. This
   PoC is publicly available on the AI on demand platform (Demo and code
   accessible from https://bit.ly/4meYnNo).},
Type = {Proceedings Paper},
Affiliation = {Pintz, M (Corresponding Author), Fraunhofer IAIS, St Augustin, Germany.
   Pintz, M (Corresponding Author), Univ Bonn, Bonn, Germany.
   Pintz, Maximilian; Becker, Daniel; Mock, Michael, Fraunhofer IAIS, St Augustin, Germany.
   Pintz, Maximilian, Univ Bonn, Bonn, Germany.},
DOI = {10.1007/978-3-032-02018-5\_33},
Keywords = {AI testing; Computational workflows; Proof-of-Concept implementation},
Author-Email = {maximilian.alexander.pintz@iais.fraunhofer.de},
Number-of-Cited-References = {36},
Times-Cited = {0},
Unique-ID = {WOS:001579298700036},
}

