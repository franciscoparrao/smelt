   Yu, Sunjin, Changwon Natl Univ, Sch Meta Convergence Content Major, Dept Artificial Intelligence Convergence Engn, Chang Won 51140, South Korea.},
DOI = {10.3390/app152111801},
Article-Number = {11801},
Keywords = {digital twin; DEM super-resolution; distributional shift;
   application-centric evaluation; instance segmentation; procedural
   modeling},
Author-Email = {dhwoo1119@gs.cwnu.ac.kr
   20257555@gs.cwnu.ac.kr
   20247633@gs.cwnu.ac.kr
   jrkim@changwon.ac.kr
   sjyu@changwon.ac.kr},
Number-of-Cited-References = {53},
