   Rollins, Caitlin, Harvard Med Sch, Boston Childrens Hosp, Dept Neurol, Boston, MA 02115 USA.
   Gholipour, Ali, Univ Calif Irvine, Dept Radiol Sci, Irvine, CA 92868 USA.},
DOI = {10.1109/TMI.2025.3619809},
Keywords = {Fetal brain; segmentation; diffusion MRI; deep learning; multi-task
   learning; Fetal brain; segmentation; diffusion MRI; deep learning;
   multi-task learning},
Keywords-Plus = {WHITE-MATTER; REGISTRATION; RECONSTRUCTION; CONNECTIVITY; TRACTOGRAPHY;
