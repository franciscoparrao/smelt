   Baraldi, Ana Cyntia; Souza, Joao Paulo, Pan Amer Hlth Org, Evidence \& Intelligence Act Hlth, BIREME, Brasilia, Brazil.},
DOI = {10.1186/s13643-025-02842-y},
Article-Number = {82},
Keywords-Plus = {SYSTEMATIC LITERATURE-REVIEWS; EXTRACTION; WORKLOAD; LANGUAGE;
   CLASSIFICATION; AUTOMATION; ALGORITHM; ARTICLES; TERMS; RISK},
