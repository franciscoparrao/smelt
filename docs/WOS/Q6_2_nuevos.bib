@article{ WOS:001637091700001,
Author = {Carro, N. and Diaz, N. and Cobas, J. and Garcia, I. and Mouteira, A. and
   Ignacio, M.},
Title = {Automated solid phase extraction combined with gas chromatography-mass
   spectrometry methods for plastic and tire additives in surface waters:
   development, validation and greenness assessment},
Journal = {GREEN ANALYTICAL CHEMISTRY},
Year = {2026},
Volume = {16},
Month = {MAR},
Abstract = {Automated solid phase extraction (SPE) combined with gas
   chromatography-mass spectrometry (GC-MS) methods were proposed for
   determination of plastic and tire additives in surface water. The
   plastic additives studied were phthalates (PAEs) and bisphenols (BPs),
   and the tire additives were diphenylamine derivatives (tire additives).
   These chemicals represent a serious hazard for the marine environment.
   BPs were derivatized prior to GC determination. The optimized and
   validated methods for seawater samples proved to be accurate (recoveries
   of 56-112 \% for PAEs, 60-116 \% for BPs and 60-110 \% for tire
   additives), reproducible (relative standard deviation of 6-11 \% for
   PAEs, 1-14 \% for BPs and 4-13 \% for tire additives) and sensitive for
   target analytes (detection limits of 0.015-0.142 mu g/L for PAEs,
   0.0010-0.0094 mu g/L for BPs, 0.028-0.055 mu g/L for tire additives).
   The methods were also validated for freshwater samples, showing
   satisfactory analytical parameters results. Finally, the validated
   methodologies were evaluated for environmental and occupational hazards
   using AGREE and successfully applied to the analysis of two types of
   surface water samples, influents and effluents from four sewage
   treatment plants (WWTPs) in Galicia. From the results obtained, a
   reduction of the compounds studied after passing through the WWTPs was
   observed. In fact, an influent surface water sample exceeded the MAC-EQS
   of Directive 2013/39/EU, this level was reduced when passing through the
   treatment plant.},
Type = {Article},
Affiliation = {Carro, N (Corresponding Author), Xunta Galicia, INTECMAR, Conselleria do mar, Peirao Vilaxoan S-N, Vilagarcia De Arousa 36611, Spain.
   Carro, N.; Diaz, N.; Cobas, J.; Garcia, I.; Mouteira, A.; Ignacio, M., Xunta Galicia, Inst Tecnolox Para Control Medio Marino Galicia, INTECMAR, Conselleria Mar, Peirao Vilaxoan S-N, Vilagarcia De Arousa 36611, Spain.},
DOI = {10.1016/j.greeac.2025.100316},
EarlyAccessDate = {DEC 2025},
Article-Number = {100316},
Keywords = {SPE; GC-MS; Plastic and tire additives; Surface water},
Keywords-Plus = {BISPHENOL-A},
Author-Email = {ncarro@intecmar.gal},
Number-of-Cited-References = {30},
Times-Cited = {0},
Unique-ID = {WOS:001637091700001},
}

@article{ WOS:001636941500001,
Author = {Kim, Chul Ho and Jung, Da Woon},
Title = {AI-based dynamic predictive control and energy optimization for
   semiconductor FAB HVAC systems through digital twin technology},
Journal = {JOURNAL OF BUILDING ENGINEERING},
Year = {2026},
Volume = {117},
Month = {JAN 1},
Abstract = {Semiconductor demand has expanded fabrication (FAB) facilities and their
   energy use, with heating, ventilation, and air-conditioning (HVAC)
   systems forming a dominant load. Improving HVAC efficiency is crucial
   for cost, reliability, and decarbonization. This study aims to reduce
   HVAC energy use in an operating FAB by coupling a high-fidelity digital
   twin with artificial intelligence (AI)-driven predictive control. We
   develop a calibrated digital twin using the EnergyPlus simulation engine
   and Isight; automated calibration integrates Optimal Latin Hypercube
   Sampling in a design-of-experiments stage and a pointer-based
   data-matching routine to converge parameters. The model reproduces
   measured energy with strong agreement (R2 = 0.98; CVRMSE = 1.22 \%),
   comfortably satisfying ASHRAE Guideline 14 limits. Real-time prediction
   is implemented through MATLAB-Building Controls Virtual Test Bed
   integration, where a deep neural network forecasts HVAC energy 1 h ahead
   (R2 = 0.99). Using these forecasts, a dynamic control algorithm
   proactively adjusts cooling-water temperature and flow to minimize
   energy use. Relative to conventional static control, the strategy yields
   approximately 9.4 \% energy savings without degrading operation. These
   results show that a calibrated digital twin combined with AI prediction
   can deliver measurable, real-time efficiency gains in semiconductor HVAC
   systems. The key contribution is an end-to-end, reproducible
   workflow-from automated calibration to deployment-ready predictive
   control-that shortens calibration effort and operationalizes data-driven
   optimization in a live FAB. This study demonstrates a digital twin-AI
   framework that achieves verified energy savings in a semiconductor FAB
   HVAC system, providing a meaningful case study and a practical template
   for scale-out and future integration with multi-objective supervisory
   control.},
Type = {Article},
Affiliation = {Jung, DW (Corresponding Author), Samsung Elect Co Ltd, Global Mfg \& Infrastructure Dept, 114 Samsung Ro, Pyeongtaek Si, Gyeonggi Do, South Korea.
   Kim, Chul Ho; Jung, Da Woon, Samsung Elect Co Ltd, Global Mfg \& Infrastructure Dept, 114 Samsung Ro, Pyeongtaek Si, Gyeonggi Do, South Korea.
   Jung, Da Woon, Seoul Natl Univ Sci \& Technol, Sch Architecture, Architectural Engn Program, Seoul 01811, South Korea.},
DOI = {10.1016/j.jobe.2025.114824},
EarlyAccessDate = {DEC 2025},
Article-Number = {114824},
Keywords = {Digital twin; HVAC energy optimization; Real-time co-simulation;
   Automated calibration; Semiconductor fabrication},
Author-Email = {kchcd.kim@samsung.com
   daun2.jung@samsung.com},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001636941500001},
}

@article{ WOS:001631262200001,
Author = {Luechtefeld, Thomas and Hartung, Thomas},
Title = {Navigating the AI Frontier in Toxicology: Trends, Trust, and
   Transformation},
Journal = {CURRENT ENVIRONMENTAL HEALTH REPORTS},
Year = {2025},
Volume = {12},
Number = {1},
Month = {DEC 5},
Abstract = {Purpose of ReviewThe integration of artificial intelligence (AI) into
   toxicology marks a profound paradigm shift in chemical safety science.
   No longer limited to automating traditional workflows, AI is redefining
   how we assess risk, interpret complex biological data, and inform
   regulatory decision-making. This article explores the convergence of AI
   and other new approach methodologies (NAMs), emphasizing key trends such
   as multimodal learning, causal inference, explainable AI (xAI),
   generative modeling, and federated learning.Recent FindingsThese
   technologies enable more human-relevant, mechanistically grounded, and
   ethically aligned toxicological predictions-surpassing the
   reproducibility and scalability of animal-based methods. However, the
   dynamic nature of AI models challenges traditional validation paradigms.
   To address this, we introduced the e-validation framework, which
   operationalizes the TREAT principles (Trustworthiness, Reproducibility,
   Explainability, Applicability, Transparency) and incorporates AI-powered
   modules for reference chemical selection, virtual study simulation,
   mechanistic cross-validation, and post-validation surveillance through
   companion agents. Ethical considerations-including bias audits, equity
   audits, and participatory governance-are also foregrounded as critical
   elements for responsible AI adoption. The emergence of a co-pilot model,
   where AI augments but does not replace human judgment, offers a
   pragmatic path forward. Supported by evidence from the 2025 Stanford AI
   Index and recent regulatory advances, we argue that the infrastructure,
   economics, and policy momentum are now aligned for global-scale
   deployment of AI-based toxicology.SummaryThe future of the field lies
   not in replicating legacy practices, but in reinventing toxicology as an
   adaptive, transparent, and ethically grounded science that delivers more
   accurate, inclusive, and human-centric safety assessments.Lay
   SummaryArtificial intelligence (AI) is changing how we test chemicals
   for safety. Instead of using animals, new computer-based tools can
   predict how substances affect human health more quickly, accurately, and
   ethically. This article looks at how these technologies-like smart data
   systems, models that explain their reasoning, and even AI ``agents{''}
   that run simulations-can improve toxicology. We also introduce a new
   idea called ``e-validation{''}, which uses AI to help validate these
   methods in real-time, not just once. This ensures the models stay up to
   date and reliable. But using AI safely means tackling big questions: Can
   we trust results we don't fully understand? How do we prevent unfairness
   or bias in the data? We suggest a ``co-pilot{''} model, where AI
   supports, but doesn't replace, human experts. With better data sharing,
   strong ethics, and smarter oversight, AI can help make chemical safety
   testing more human-focused, fair, and effective.},
Type = {Review},
Affiliation = {Hartung, T (Corresponding Author), Ctr Alternat Anim Testing CAAT, Baltimore, MD 21205 USA.
   Hartung, T (Corresponding Author), Johns Hopkins Bloomberg Sch Publ Hlth, Doerenkamp Zbinden Chair Evidence Based Toxicol, 615 N Wolfe St,W7032, Baltimore, MD 21201 USA.
   Hartung, T (Corresponding Author), Univ Konstanz, CAAT Europe, D-78464 Constance, Germany.
   Hartung, T (Corresponding Author), CAATevents, D-42651 Solingen, Germany.
   Luechtefeld, Thomas, ToxTrack LLC, Bethesda, MD 20894 USA.
   Luechtefeld, Thomas, Insilica Inc, Rockville, MD 20848 USA.
   Luechtefeld, Thomas; Hartung, Thomas, Ctr Alternat Anim Testing CAAT, Baltimore, MD 21205 USA.
   Hartung, Thomas, Johns Hopkins Bloomberg Sch Publ Hlth, Doerenkamp Zbinden Chair Evidence Based Toxicol, 615 N Wolfe St,W7032, Baltimore, MD 21201 USA.
   Hartung, Thomas, Univ Konstanz, CAAT Europe, D-78464 Constance, Germany.
   Hartung, Thomas, CAATevents, D-42651 Solingen, Germany.},
DOI = {10.1007/s40572-025-00514-6},
Article-Number = {51},
Keywords = {Artificial Intelligence (AI); Toxicology; New Approach Methodologies
   (NAM); e-Validation; Explainable AI (xAI); Chemical risk assessment;
   Regulatory science; Bias audit; Digital twins; Causal modeling;
   Responsible AI; Human relevance; TREAT principles; Ethical toxicology;
   Federated learning},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; VALIDATION; DRUG},
