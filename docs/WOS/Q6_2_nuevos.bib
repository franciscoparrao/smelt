@article{ WOS:001639651300001,
Author = {Di Leo, Danilo and Nilsson, Emelie and Krinos, Arianna and Pinhassi,
   Jarone and Lundin, Daniel},
Title = {The Nextflow nf-core/metatdenovo pipeline for reproducible annotation of
   metatranscriptomes, and more},
Journal = {PEERJ},
Year = {2025},
Volume = {13},
Month = {DEC 5},
Abstract = {Metatranscriptomics-the sequencing of community RNA-has become a popular
   tool in microbial ecology, proving useful for both in situ surveys and
   experiments. However, annotating raw sequence data remains challenging
   for many research groups with limited computational experience.
   Standardized and reproducible analyses are important to enhance
   transparency, comparability across studies, and long-term
   reproducibility. To simplify metatranscriptome processing for
   biologists, and to promote reproducible analyses, we introduce
   nf-core/metatdenovo, a Nextflow-based workflow. Nextflow pipelines run
   on different computing platforms, from standalone systems to
   high-performance computing clusters and cloud platforms (e.g., AWS,
   Google Cloud, Azure) and use container technology such as Docker or
   Singularity to reproducibly provision software. Biologists can access
   the pipeline using either the command line or the Seqera platform, which
   provides a web browser-based interface to Nextflow pipelines.
   Collaborating with nf-core ensures high-quality, documented,
   reproducible workflows. Our nf-core/metatdenovo pipeline adheres to
   these established standards, enabling FAIR metatranscriptome de novo
   assembly, quantification, and annotation.},
Type = {Article},
Affiliation = {Lundin, D (Corresponding Author), Linneuniversitetet, Dept Biol \& Environm Sci, Kalmar, Sweden.
   Di Leo, Danilo; Nilsson, Emelie; Pinhassi, Jarone; Lundin, Daniel, Linneuniversitetet, Dept Biol \& Environm Sci, Kalmar, Sweden.
   Krinos, Arianna, Brown Univ, Dept Earth Environm \& Planetary Sci, Providence, RI USA.},
DOI = {10.7717/peerj.20328},
Article-Number = {e20328},
Keywords = {Metatranscriptomics; Denovoassembly; Microbiology; Bioinformatics; Omics},
Keywords-Plus = {GENE-EXPRESSION; ALIGNMENT; BACTERIAL},
Author-Email = {daniel.lundin@lnu.se},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001639651300001},
}

@article{ WOS:001637273800001,
Author = {Hong, Jia-Yi and Chio, Chung-Ching and Chang, Ching-Ping and Ma, Jui-Ti
   and Tseng, Chung-Hsin and Chen, Chi-Chun and Kuo, Shu-Chun},
Title = {System for the automatic segmentation of retinal layers and the
   quantification of individual layer thicknesses and areas},
Journal = {BIOMEDICAL SIGNAL PROCESSING AND CONTROL},
Year = {2026},
Volume = {114},
Month = {APR 1},
Abstract = {We developed and validated an automated optical coherence tomography
   (OCT) image analysis system that performs retinal layer segmentation and
   quantifies the thickness and area of each layer from clinician-acquired
   OCT scans. The goal is to extract layer-resolved structural metrics that
   can serve as rapid and precise diagnostic and prognostic indicators,
   while mitigating inter-observer variability and subjective bias inherent
   to manual interpretation. A U-Net-based deep learning pipeline was
   trained separately for each of the nine retinal layers and integrated
   into a graphical user interface (GUI). Given a raw OCT image acquired by
   standard clinical procedures, the GUI outputs layer-wise segmentation
   maps and corresponding thickness/area metrics. Automated results were
   benchmarked against manual annotations by two expert graders using Dice
   similarity coefficient (DSC), Intersection over Union (IoU), and
   Hausdorff distance, alongside precision, recall, F1-score, and
   specificity. Thickness agreement was evaluated within the Early
   Treatment Diabetic Retinopathy Study (ETDRS) regions. Relative to expert
   manual segmentation, the analysis system achieved a mean DSC of 89.86
   \%, an IoU of 88.41 \%, and a Hausdorff distance of 17.22 mu m. Mean
   precision, recall, F1-score, and specificity were each >= 90 \% across
   layers. Automated ETDRS-based thickness values showed absolute
   differences of <= 100 mu m compared to manual measurements; notably, the
   outer plexiform layer differed by 2.15-8.93 mu m. This automated OCT
   image analysis approach provides accurate, reproducible, layer-resolved
   quantification directly from clinician-acquired scans, enhancing
   diagnostic precision and reducing human interpretation bias. The system
   shows strong potential for clinical integration to support rapid
   diagnosis and prognosis in retinal disease.},
Type = {Article},
Affiliation = {Chen, CC (Corresponding Author), Natl Chin Yi Univ Technol, Dept Elect Engn, Taichung, Taiwan.
   Kuo, SC (Corresponding Author), Chi Mei Med Ctr, Dept Ophthalmol, Tainan, Taiwan.
   Kuo, SC (Corresponding Author), Chung Hwa Univ Med Technol, Dept Optometry, Tainan, Taiwan.
   Hong, Jia-Yi; Chang, Ching-Ping; Ma, Jui-Ti; Tseng, Chung-Hsin, Chi Mei Med Ctr, Dept Med Res, Tainan, Taiwan.
