@article{ WOS:001665561800001,
Author = {Antonio, Marcelo Augusto and Ramos, Sergio Lopes Fernandes and Marson,
   Fernando Augusto Lima and Toro, Mariana Dalbo Contrera and Sakano,
   Eulalia},
Title = {An affordable and optimized 3D biomodel for sinonasal surgery training},
Journal = {BRAZILIAN JOURNAL OF OTORHINOLARYNGOLOGY},
Year = {2026},
Volume = {92},
Number = {2},
Month = {MAR-APR},
Abstract = {Objectives: To develop and evaluate the anatomical accuracy and haptic
   fidelity of an affordable kit consisting of a silicone head, a foam
   support, and a 3D-printed biomodel of the paranasal sinuses for surgical
   training. Methods: This single-center, technological, and interventional
   study detailed the development of a human sinus biomodel. Its anatomical
   and haptic evaluation was conducted by ten senior rhinologists, who
   performed 37 standard surgical tasks. Participants rated similarity to
   fresh cadaveric dissection on a 5-point Likert scale. Computed
   tomographic images were converted into a standard tessellation file
   through a combination of automatic and manual segmentation. This file
   was then used in a 3D printer to create the biomodel, which was
   customized with a red silicone coating to emulate mucosa, as well as
   silicone-insulated wire and acrylic yarn to simulate arteries and
   nerves. The model was mounted onto a silicone head and foam support,
   with a total production cost of US\$ 43.37. Results: The similarity of
   anatomic landmarks scored a mean above 4.0 f SD on both sides. The
   lacrimal bone drilling/debulking procedure was somewhat suboptimal for
   exposing the lacrimal sac, scoring a mean of 3.1 f 1.04 on the left side
   but 4.3 f 0.64 on the right. Likewise, uncinectomy was rated 3.4 f 1.02
   on the left and 3.7 f 0.90 on the right, while the periorbit incision
   received scores of 3.5 f 0.92 on the left and 4.5 f 0.50 on the right.
   All other steps received ratings above 4.0 f SD. Conclusion: This study
   presents a fully reproducible and cost-effective method for constructing
   a 3D sinus biomodel. The model demonstrated high anatomical and haptic
   fidelity, as validated by senior rhinologists, making it a valuable tool
   for surgical training in sinonasal procedures. Level of evidence: This
   study provides Level 2 evidence.},
Type = {Article},
Affiliation = {Antonio, MA (Corresponding Author), Univ Estadual Campinas, Dept Oftalmol \& Otorrinolaringol, Campinas, SP, Brazil.
   Antonio, Marcelo Augusto; Toro, Mariana Dalbo Contrera; Sakano, Eulalia, Univ Estadual Campinas, Dept Oftalmol \& Otorrinolaringol, Campinas, SP, Brazil.
   Ramos, Sergio Lopes Fernandes, Univ Estadual Campinas, Fac Engn Mecan, Campinas, SP, Brazil.
   Marson, Fernando Augusto Lima, Univ Sao Francisco, Lab Microbiol Clin \& Mol, Lab Biol Mol \& Genet, LunGuardian Res Grp Epidemiol Resp \& Infect Dis, Braganca Paulista, SP, Brazil.},
DOI = {10.1016/j.bjorl.2025.101750},
EarlyAccessDate = {JAN 2026},
Article-Number = {101750},
Keywords = {3D printing; Surgical simulation; Training model; Paranasal sinuses},
Keywords-Plus = {ENDOSCOPIC SINUS; MODEL; VALIDATION},
Author-Email = {renova@unicamp.br},
Number-of-Cited-References = {17},
Times-Cited = {0},
