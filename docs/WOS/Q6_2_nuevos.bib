@article{ WOS:001630871300006,
Author = {Kugunavar, Sowrabh and Sangwan, Kuldip Singh},
Title = {Development of models to reduce measurement uncertainties induced by
   surface orientation, multi-source illumination and glossiness in optical
   metrology},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {260},
Month = {FEB 10},
Abstract = {The research aims to determine the optimal surface orientation and the
   optimal combination of multi-source illumination for a given surface
   glossiness, in order to improve measurement reliability by enhancing
   featureedge detection accuracy. The methodology includes: (i) hypothesis
   testing to ensure the statistical significance of the factors
   influencing measurement results, (ii) development of a heuristic model
   for orientation optimization and a meta-heuristic AI model for optimal
   multi-source illumination, and (iii) experimental validation of the
   proposed models. The novelty of the paper is the estimation of the
   optimum orientation for reliable and robust measurements, whereas the
   existing research is limited to current orientation estimation. The
   illumination model optimizes a combination of multi-source illumination
   tailored to user-given gloss values. The proposed model enhances the
   measurement quality by improving the consistency in the measurement
   results. The experimental results show that the proposed model for
   surface orientation optimization reduced the feature size variation
   range from 23.6 to 5.6 mu m. Further tests with the illumination
   optimization model improved the repeatability of feature size
   measurement results. The validation of the proposed model shows that
   results (reproducibility and repeatability) are consistently similar and
   are not sensitive to the sample size. The proposed models can be readily
   deployed in precision metrology environments such as semiconductor and
   electronic part inspection, where micron-scale dimensional verification
   is critical. The models are adaptable to diverse scenarios of automated
   vision inspection systems and can be integrated into Industry 4.0
   quality control frameworks for adaptive measurement optimization.},
Type = {Article},
Affiliation = {Sangwan, KS (Corresponding Author), Birla Inst Technol \& Sci Pilani, Pilani Campus, Pilani 333031, India.
   Sangwan, KS (Corresponding Author), Manipal Univ Jaipur, Jaipur 303007, India.
   Kugunavar, Sowrabh; Sangwan, Kuldip Singh, Birla Inst Technol \& Sci Pilani, Pilani Campus, Pilani 333031, India.
   Sangwan, Kuldip Singh, Manipal Univ Jaipur, Jaipur 303007, India.},
DOI = {10.1016/j.measurement.2025.119850},
EarlyAccessDate = {NOV 2025},
Article-Number = {119850},
Keywords = {Heuristic model; Meta-heuristic model; Edge detection; Surface
   orientation optimization; Illumination optimization; Vision measurement
   system},
Author-Email = {kss@pilani.bits-pilani.ac.in},
Number-of-Cited-References = {38},
Times-Cited = {0},
Unique-ID = {WOS:001630871300006},
}

@article{ WOS:001651015600004,
Author = {Zhong, Chen and Zhou, Zhengzi and Aslam, Nilufer Sari and Wang, Yikang
   and Enaya, Adham},
Title = {Anonymised human location data in England for urban mobility research},
Journal = {SCIENTIFIC DATA},
Year = {2025},
Volume = {12},
Number = {1},
Month = {NOV 26},
Abstract = {The rapid expansion of sensor technologies and location-enabled mobile
   applications has greatly advanced the study of human mobility. Recently
   emerged sources like mobile app data offer outputs similar to
   traditional datasets-trip chains, flows, and indicators-but the methods
   and decisions used to process such data often vary across location,
   time, and policy context and remain poorly documented and insufficiently
   transparent. This variability necessitates tailored data processing and
   validation approaches, which remain underexplored in existing
   literature. This study aims to provide a reproducible and replicable
   framework for processing location-points data, using a case study of
   anonymised mobility records collected in November 2021 across England.
   We describe a modular workflow and multi-stage validation techniques
   that enhance the reproducibility of stay-point detection and activity
   labelling. Furthermore, we demonstrate how the proposed framework can
   generate reliable mobility indicators and origin-destination flow
   matrices for broader research applications. The resulting
   datasets-including sampled anonymised trajectories and full
   origin-destination flow matrices-are publicly available for research
   purposes, with updates to code and methodology hosted on GitHub and
   Zenodo.},
Type = {Article},
Affiliation = {Zhong, C (Corresponding Author), UCL, Ctr Adv Spatial Anal, London W1T 4TJ, England.
   Zhong, Chen; Zhou, Zhengzi; Aslam, Nilufer Sari; Wang, Yikang; Enaya, Adham, UCL, Ctr Adv Spatial Anal, London W1T 4TJ, England.},
DOI = {10.1038/s41597-025-06323-8},
Article-Number = {2040},
Author-Email = {c.zhong@ucl.ac.uk},
Number-of-Cited-References = {30},
Times-Cited = {0},
Unique-ID = {WOS:001651015600004},
}

@article{ WOS:001646859600001,
Author = {Pan, Jiahang and Zhou, Rui and Feng, Jie and Wu, Mincheng and Wu, Xiang
   and Dong, Hui},
Title = {Unordered Stacked Pillbox Detection Algorithm Based on Improved YOLOv8},
Journal = {BIG DATA AND COGNITIVE COMPUTING},
Year = {2025},
Volume = {9},
Number = {12},
Month = {NOV 26},
Abstract = {To enable fully automated medicine warehousing in intelligent pharmacy
   systems, accurately detecting disordered, stacked pillboxes is
   essential. This paper proposes a high-precision detection algorithm for
   such scenarios based on an improved YOLOv8 framework. The proposed
   method integrates a novel convolutional module that replaces traditional
   stride convolutions and pooling layers, enhancing the detection of
   small, low-resolution targets in computer vision tasks. To further
   enhance detection accuracy, the Bi-Level Routing Attention (BiFormer)
   Vision Transformer is incorporated as a Cognitive Computing module.
   Additionally, the circular Smooth Label (CSL) technique is employed to
   mitigate boundary discontinuities and periodic anomalies in angle
   prediction, which often arise in the detection of rotated objects. The
   experimental results demonstrate that the proposed method achieves a
   precision of 94.24\%, a recall of 90.39\%, and a mean average precision
   (mAP) of 94.16\%-improvements of 3.34\%, 2.53\%, and 3.35\%,
   respectively, over the baseline YOLOv8 model. Moreover, the enhanced
   detection model outperforms existing rotated-object detection methods
   while maintaining real-time inference speed. To facilitate
   reproducibility and future benchmarking, the full dataset and source
   code used in this study have been released publicly. Although no
   standardized benchmark currently exists for pillbox detection, our
   self-constructed dataset reflects key industrial variations in pillbox
   size, orientation, and stacking, thereby providing a foundation for
   future cross-domain validation.},
Type = {Article},
Affiliation = {Wu, MC (Corresponding Author), Zhejiang Univ Technol, Coll Informat Engn, Hangzhou 310023, Peoples R China.
   Pan, Jiahang; Zhou, Rui; Wu, Mincheng; Wu, Xiang; Dong, Hui, Zhejiang Univ Technol, Coll Informat Engn, Hangzhou 310023, Peoples R China.
   Feng, Jie, China Mobile Hangzhou Informat Technol Co Ltd, Hangzhou 311121, Peoples R China.},
DOI = {10.3390/bdcc9120300},
Article-Number = {300},
Keywords = {deep learning; rotating target detection; YOLOv8; pillbox detection;
