@article{ WOS:001640673100001,
Author = {Yinusa, Ahmeed and Faezipour, Misa},
Title = {Enhancing the robustness of CNN-based lung cancer detection models
   against label-flipping poison attacks using defensive distillation},
Journal = {ARRAY},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {Deep learning has significantly advanced automated medical imaging,
   particularly in lung cancer detection, yet vulnerability to adversarial
   manipulation continues to limit clinical reliability. This study
   investigates the impact of a 30\% random-uniform label-flipping
   poisoning attack on Convolutional Neural Network (CNN) models trained
   using the IQ-OTH/NCCD dataset comprising 1190 CT images. A
   multi-strategy defense pipeline is proposed, integrating defensive
   distillation, Isolation Forest data sanitization, and a noise-tolerant
   loss function to enhance robustness against training data corruption. To
   ensure a valid evaluation framework, Synthetic Minority Oversampling
   Technique (SMOTE) was applied only to the clean training subset before
   any poisoning was introduced, preventing the propagation of corrupted
   labels and establishing a balanced and uncontaminated foundation for
   teacher training. A high-accuracy teacher model trained on this clean
   SMOTE-balanced dataset produces temperature-scaled soft labels that
   guide the Student model. The Student is then trained on a sanitized
   dataset filtered to remove anomalous or inconsistent samples, using
   Symmetric Cross-Entropy loss to reduce sensitivity to mislabeled data.
   Experimental results show that the pipeline maintains strong
   performance, achieving 99\% accuracy on clean data and 95 to 96\%
   accuracy under poisoning, while preserving stable precision, recall, and
   confidence calibration across all classes. These findings demonstrate
   that the proposed strategy effectively mitigates label-flipping
   poisoning, offering a reproducible path toward secure and trustworthy AI
   systems for medical imaging applications.},
Type = {Article},
Affiliation = {Faezipour, M (Corresponding Author), Middle Tennessee State Univ, Dept Engn Technol, Murfreesboro, TN 37132 USA.
   Yinusa, Ahmeed, Middle Tennessee State Univ, Dept Computat \& Data Sci, Murfreesboro, TN 37132 USA.
   Faezipour, Misa, Middle Tennessee State Univ, Dept Engn Technol, Murfreesboro, TN 37132 USA.},
DOI = {10.1016/j.array.2025.100637},
EarlyAccessDate = {DEC 2025},
Article-Number = {100637},
Keywords = {Label-flipping attacks; Defensive distillation; Adversarial robustness;
   Data sanitization; Symmetric cross-entropy loss; Lung cancer detection;
   Medical image analysis; Deep learning security},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {misa.faezipour@mtsu.edu},
Number-of-Cited-References = {40},
Times-Cited = {0},
Unique-ID = {WOS:001640673100001},
}

@article{ WOS:001640521200001,
Author = {Hu, Dingkun and Ma, Changda and Rakha, Tarek},
Title = {An integrated framework for rooftop solar viability assessment:
   Enhancing building reuse and urban sustainability through UAV-Derived 3D
   modeling and performance simulation},
Journal = {ENERGY AND BUILDINGS},
Year = {2026},
Volume = {352},
Month = {FEB 1},
Abstract = {Rooftop solar photovoltaic (PV) systems play a key role in reducing
   reliance on grid-supplied electricity, therefore contributing to lower
   net energy demand and greater urban energy resilience. However, current
   assessment methods relying on satellite imagery, GIS datasets, or manual
   3D modeling often lack geometric precision, leading to large
   uncertainties in estimating rooftop solar potential. To address this
   gap, this study proposes an integrated UAV-based framework that combines
   high-resolution photogrammetry, 3D modeling, solar-radiation simulation,
   and economic analysis to evaluate rooftop PV feasibility with improved
   reproducibility. The workflow was demonstrated through a case study of a
   historic multi-story structure in Binghamton, New York. UAV-derived
   models captured detailed roof morphology and surrounding obstructions,
   informing simulations of solar irradiance, PV performance, and financial
   return. Results indicate that the UAV-based workflow reduced geometry
   preparation time by 77 \% and simulation duration by 71 \% compared with
   manual methods, while improving roof-area accuracy by 1.5 \%. The system
   achieved an annual generation potential of 96 MWh, an effective
   efficiency of 17.9 \%, and a payback time of 5.8 years. By integrating
   geometric fidelity, performance simulation, and economic evaluation,
   this framework bridges the gap between traditional satellite-based
   assessments and dynamic building-scale analyses, providing a scalable
   decision-support tool for adaptive reuse and climate-responsive urban
   energy planning.},
Type = {Article},
Affiliation = {Hu, DK (Corresponding Author), Georgia Inst Technol, Sch Architecture, Atlanta, GA 30332 USA.
   Hu, Dingkun; Ma, Changda; Rakha, Tarek, Georgia Inst Technol, Sch Architecture, Atlanta, GA 30332 USA.},
DOI = {10.1016/j.enbuild.2025.116847},
EarlyAccessDate = {DEC 2025},
Article-Number = {116847},
Keywords = {UAV; 3D Modeling; Solar Simulation; Building Retrofit; Energy Modeling},
Author-Email = {dhu301@gatech.edu},
Number-of-Cited-References = {64},
Times-Cited = {1},
Unique-ID = {WOS:001640521200001},
}

@article{ WOS:001640537300001,
Author = {Dharmasivam, Mahendiran and Maya, Busra and Akinware, Adedoyin and Azad,
   Mahan Gholam and Richardson, Des R.},
Title = {Leading artificial intelligence-driven drug discovery platforms: 2025
   landscape and global outlook},
Journal = {PHARMACOLOGICAL REVIEWS},
Year = {2026},
Volume = {78},
Number = {1},
Month = {JAN},
Abstract = {Artificial intelligence (AI) has progressed from experimental curiosity
   to clinical utility, with AI-designed therapeutics now in human trials
   across diverse therapeutic areas. This review critically compares 5
   leading AI-driven discovery platforms: generative chemistry,
   phenomics-first systems, integrated target-to-design pipelines,
   knowledge-graph repurposing, and physics-plus-machine learning design.
   Key developments since 2024 include positive phase IIa results for
   Insilico Medicine's Traf2-and Nck-interacting kinase inhibitor,
   ISM001-055, in idiopathic pulmonary fibrosis. Another key development
   was the Recursion-Exscientia merger, which integrated phenomic screening
   with automated precision chemistry into a full end-to-end platform. In
   addition, advancement of the Nimbus-originated tyrosine kinase 2
   inhibitor, zasocitinib (TAK-279), into phase III clinical trials
   exemplifies Schro<euro>dinger's physics-enabled design strategy reaching
   late-stage clinical testing. Emerging platforms such as Insitro,
   Isomorphic Labs, Atomwise, and XtalPi illustrate the field's expanding
   geographic and technical footprint. Significance Statement: Artificial
   intelligence (AI) is reshaping pharmacology by shortening discovery
   timelines, potentially reducing attrition, and expanding the design
   space of therapeutic candidates. Alongside technical milestones,
   regulatory and ethical frameworks from the US Food and Drug
   Administration and European Medicines Agency are beginning to address
   transparency, bias, accountability, intellectual property, and data
   privacy. Robotics tightly integrated with AI now enables self-driving
   laboratories that accelerate design-make-test-learn cycles and improve
   reproducibility. Together, these advances chart a forward-looking
   roadmap in which multimodal foundation models, robotics-led platforms,
   and hybrid physics-AI strategies are poised to accelerate translation,
   derisk development, and establish trustworthy AI as a cornerstone of
   modern drug discovery. (c) 2025 American Society for Pharmacology and
   Experimental Therapeutics. Published by Elsevier Inc. All rights are
   reserved, including those for text and data mining, AI training, and
   similar technologies.},
Type = {Review},
Affiliation = {Dharmasivam, M; Richardson, D (Corresponding Author), Griffith Univ, Inst Biomed \& Glyc, Ctr Canc Cell Biol \& Drug Discovery, Southport, Qld 4215, Australia.
   Dharmasivam, Mahendiran; Maya, Busra; Akinware, Adedoyin; Azad, Mahan Gholam; Richardson, Des R., Griffith Univ, Inst Biomed \& Glyc, Ctr Canc Cell Biol \& Drug Discovery, Southport, Qld 4215, Australia.},
DOI = {10.1016/j.pharmr.2025.100102},
EarlyAccessDate = {DEC 2025},
Article-Number = {100102},
Keywords-Plus = {PYRIDOXAL ISONICOTINOYL HYDRAZONE; EFFECTIVE ANTIPROLIFERATIVE AGENTS;
   SELECTIVE ANTITUMOR-ACTIVITY; IRON CHELATORS; 2-ACETYLPYRIDINE
   THIOSEMICARBAZONES; REDOX ACTIVITY; POTENT; AI; INHIBITOR;
