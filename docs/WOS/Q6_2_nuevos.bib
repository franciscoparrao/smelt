@article{ WOS:001616760500001,
Author = {Courvoisier, Delphine S. and Buitrago-Garcia, Diana and Buclin, Clement
   P. and Burgisser, Nils and Iudici, Michele and Mongin, Denis},
Title = {Beyond human gold standards: A multimodel framework for automated
   abstract classification and information extraction},
Journal = {RESEARCH SYNTHESIS METHODS},
Year = {2025},
Month = {2025 NOV 17},
Abstract = {Meta-research and evidence synthesis require considerable resources.
   Large language models (LLMs) have emerged as promising tools to assist
   in these processes, yet their performance varies across models, limiting
   their reliability. Taking advantage of the large availability of small
   size (<10 billion parameters) open-source LLMs, we implemented an
   agreement-based framework in which a decision is taken only if at least
   a given number of LLMs produce the same response. The decision is
   otherwise withheld. This approach was tested on 1020 abstracts of
   randomized controlled trials in rheumatology, using 2 classic literature
   review tasks: (1) classifying each intervention as drug or nondrug based
   on text interpretation and (2) extracting the total number of randomized
   patients, a task that sometimes required calculations. Re-examining
   abstracts where at least 4 LLMs disagreed with the human gold standard
   (dual review with adjudication) allowed constructing an improved gold
   standard. Compared to a human gold standard and single large LLMs (>70
   billion parameters), our framework demonstrated robust performance:
   several model combinations achieved accuracies above 95\% exceeding the
   human gold standard on at least 85\% of abstracts (e.g., 3 of 5 models,
   4 of 6 models, or 5 of 7 models). Performance variability across
   individual models was not an issue, as low-performing models contributed
   fewer accepted decisions. This agreement-based framework offers a
   scalable solution that can replace human reviewers for most abstracts,
   reserving human expertise for more complex cases. Such frameworks could
   significantly reduce the manual burden in systematic reviews while
   maintaining high accuracy and reproducibility.},
Type = {Article; Early Access},
Affiliation = {Mongin, D (Corresponding Author), Geneva Univ Hosp, Rheumatol, Geneva, Switzerland.
   Mongin, D (Corresponding Author), Univ Geneva, Rheumatol, Geneva, Switzerland.
   Courvoisier, Delphine S.; Iudici, Michele; Mongin, Denis, Geneva Univ Hosp, Rheumatol, Geneva, Switzerland.
   Courvoisier, Delphine S.; Buitrago-Garcia, Diana; Iudici, Michele; Mongin, Denis, Univ Geneva, Rheumatol, Geneva, Switzerland.
   Buclin, Clement P.; Burgisser, Nils, Geneva Univ Hosp, Internal Med, Geneva, Switzerland.},
DOI = {10.1017/rsm.2025.10054},
EarlyAccessDate = {NOV 2025},
Keywords = {classification; data extraction; evidence synthesis; large language
   model; meta-analysis},
Author-Email = {denis.mongin@unige.ch},
Number-of-Cited-References = {50},
Times-Cited = {0},
Unique-ID = {WOS:001616760500001},
}

@article{ WOS:001621673700001,
Author = {Kim, Hyehyun and Kim, Jimin and Choi, Sangdo and Park, Jiyoung and Noh,
   Young Su and Choi, Yong Nam and Kim, Hyuncheol},
Title = {Proton exchange membrane electrolytic enrichment system and tritium
   residual ratio curve method for analysis of tritium concentration in
   seawater},
Journal = {ANALYTICA CHIMICA ACTA},
Year = {2026},
Volume = {1383},
Month = {JAN 15},
Abstract = {Background: Tritium monitoring in seawater has become increasingly
   important for environmental safety assessment, particularly following
   Japan's radioactive wastewater discharge. However, extremely low tritium
   concentrations in Korean coastal waters (0.09-0.45 Bq center dot L-1)
   are below detection limits of conventional liquid scintillation counting
   methods. While alkaline electrolysis can concentrate tritium, it
   requires about 20 days processing time, making it unsuitable for rapid
   environmental monitoring. Conventional spike-proxy methods for
   determining initial concentrations assume identical conditions across
   multiple samples, leading to potential analytical errors. There is an
   urgent need for rapid tritium enrichment technology with accurate
   concentration determination methods for environmental monitoring.
   Results: A Tritium PEM electrolytic enrichment multiprocessor system was
   developed, capable of processing four samples simultaneously using
   commercial stacks with Ru0.55Ir0.45O2 mixed anode catalysts. The system
   incorporated automated controls including infrared sensors, pumps, and
   cooling systems to minimize operator intervention and ensure
   reproducible results. Optimal operating conditions were determined
   through systematic evaluation of ion exchange resin quantity, anode
   catalyst type, cell configuration, and cooling temperature. Tritium
   residual ratio curves (TRRC) were derived as individual stack
   characteristics to account for tritium loss during electrolysis,
   enabling more accurate initial concentration determination than
   conventional methods. Validation using standard solutions at
   environmentally relevant concentrations (1-10 Bq center dot L- 1) showed
   relative standard deviations below 8.5 \%. Natural seawater analysis
   demonstrated tritium concentrations of 0.27 +/- 0.09 Bq center dot L-1
   with enrichment factors exceeding 22-fold and processing times of 94 h.
   Interlaboratory comparison with ASNR yielded satisfactory results
   (c-score = 0.4), confirming method reliability. Significance: The
   PEM-based system achieved 1.5-fold higher enrichment factors and an 80
   \% reduction in percell processing time (from 20 to 4 days) compared to
   alkaline electrolysis, while maintaining comparable throughput. The
   tritium residual ratio curve approach significantly improved analytical
   accuracy for unknown samples. This system enhances enables faster
   response times and more frequent sampling for marine environmental
   monitoring.},
Type = {Article},
Affiliation = {Kim, H (Corresponding Author), 111 Daedeok Daero 989 Beon Gil, Daejeon 34057, South Korea.
   Kim, Hyehyun; Choi, Sangdo; Park, Jiyoung; Kim, Hyuncheol, Korea Atom Energy Res Inst, Nucl Emergency \& Environm Protect Div, Environm Radioact Assessment Team, Daejeon, South Korea.
   Kim, Jimin, Korea Inst Nucl Safety, Dept Environm Radioact Assessment, Daejeon, South Korea.
   Noh, Young Su; Choi, Yong Nam, Korea Atom Energy Res Inst, High Temp Reactor Dev Div, Daejeon, South Korea.},
DOI = {10.1016/j.aca.2025.344898},
EarlyAccessDate = {NOV 2025},
Article-Number = {344898},
Keywords = {Tritium; PEM electrolysis; Seawater analysis; Electrolytic enrichment},
Keywords-Plus = {WATER; SAMPLES},
Author-Email = {hhkim0501@kaeri.re.kr},
Number-of-Cited-References = {23},
Times-Cited = {1},
Unique-ID = {WOS:001621673700001},
}

@article{ WOS:001614497400001,
Author = {Candito, Antonio and Blackledge, Matthew D. and Holbrey, Richard and
   Porta, Nuria and Ribeiro, Ana and Zugni, Fabio and D'Erme, Luca and
   Castagnoli, Francesca and Dragan, Alina and Donners, Ricardo and
   Messiou, Christina and Tunariu, Nina and Koh, Dow-Mu},
Title = {AI-driven software for automated quantification of skeletal metastases
   and treatment response evaluation using whole-body diffusion-weighted
   MRI (WB-DWI) in advanced prostate cancer},
Journal = {PHYSICS IN MEDICINE AND BIOLOGY},
Year = {2025},
Volume = {70},
Number = {22},
Month = {NOV 16},
Abstract = {Objective. Quantitative assessment of treatment response in advanced
   prostate cancer (APC) with bone metastases remains an unmet clinical
   need. Whole-body diffusion-weighted MRI (WB-DWI) provides two response
   biomarkers: total diffusion volume (TDV) and global apparent diffusion
   coefficient (gADC). However, tracking post-treatment changes of TDV and
   gADC from manually delineated lesions is cumbersome and increases
   inter-reader variability. We developed a software to automate this
   process. Approach. Core technologies include: (i) a weakly-supervised
   Residual U-Net model generating a skeleton probability map to isolate
   bone; (ii) a statistical framework for WB-DWI intensity normalisation,
   obtaining a signal-normalised b = 900 s mm-2 (b900) image; and (iii) a
   shallow convolutional neural network that processes outputs from (i) and
   (ii) to generate a mask of suspected bone lesions, characterised by
   higher b900 signal intensity due to restricted water diffusion. This
   mask is applied to the gADC map to extract TDV and gADC statistics. We
   tested the tool using expert-defined metastatic bone disease
   delineations on 66 datasets, assessed repeatability of imaging
   biomarkers (N = 10), and compared software-based response assessment
   with a construct reference standard, defined as multidisciplinary
   consensus based on >= 12 months of imaging, clinical, and laboratory
   follow-up (N = 118). Main results. Average dice score between manual and
   automated delineations was 0.6 for lesions within pelvis and spine, with
   an average surface distance of 2 mm. Relative differences for
   log-transformed TDV (log-TDV) and median gADC were 8.8\% and 5\%,
   respectively. Repeatability analysis showed coefficients of variation of
   4.6\% for log-TDV and 3.5\% for median gADC, with intraclass correlation
   coefficients of 0.94 or higher. The software achieved 80.5\% accuracy,
   84.3\% sensitivity, and 85.7\% specificity in assessing response to
   treatment. Average computation time was 90 s per scan. Significance. Our
   software enables reproducible TDV and gADC quantification from WB-DWI
   scans for monitoring metastatic bone disease response, thus providing
   potentially useful measurements for clinical decision-making in APC
   patients.},
Type = {Article},
Affiliation = {Candito, A (Corresponding Author), Inst Canc Res, London, England.
   Candito, Antonio; Blackledge, Matthew D.; Holbrey, Richard; Porta, Nuria; Castagnoli, Francesca; Dragan, Alina; Messiou, Christina; Tunariu, Nina; Koh, Dow-Mu, Inst Canc Res, London, England.
   Ribeiro, Ana; Castagnoli, Francesca; Dragan, Alina; Messiou, Christina; Tunariu, Nina; Koh, Dow-Mu, Royal Marsden NHS Fdn Trust, London, England.
   Zugni, Fabio, IRCCS, IEO European Inst Oncol, Dept Radiol, Milan, Italy.
   D'Erme, Luca, Univ Sacro Cuore, Rome, Italy.
   Donners, Ricardo, Univ Hosp Basel, Basel, Switzerland.},
DOI = {10.1088/1361-6560/ae19c5},
Article-Number = {225021},
Keywords = {AI-driven imaging analysis; whole-body diffusion-weighted MRI (WB-DWI);
   quantitative imaging biomarkers; metastatic bone disease; treatment
   response assessment},
Keywords-Plus = {BONE-SCINTIGRAPHY; DISEASE; COEFFICIENT; CRITERIA; MARROW},
Author-Email = {antonio.candito@icr.ac.uk},
Number-of-Cited-References = {56},
Times-Cited = {2},
Unique-ID = {WOS:001614497400001},
}

@article{ WOS:001626466300011,
Author = {Lin, I, Hsien- and Lai, Chun-Chia and Chen, Po-Yuan and Chang, Ying-Chih
   and Che, Ting-Fang},
Title = {An End-to-End Sensor Signal Processing Framework for Automated
   Enumeration of Circulating Tumor Cells in Multichannel
   Immunofluorescence Microscopy},
Journal = {IEEE SENSORS JOURNAL},
Year = {2025},
Volume = {25},
Number = {22},
Pages = {41811-41820},
Month = {NOV 15},
Abstract = {Manual enumeration of cells in immunofluorescence (IF) microscopy is
   time-consuming and subjective, hindering reproducibility in biomedical
   analysis. Circulating tumor cells (CTCs), rare yet vital indicators of
   cancer metastasis, are difficult to detect due to their low prevalence
   and imaging noise. We propose an end-to-end automated pipeline
   integrating Gaussian mixture model (GMM)-based noise reduction,
   gradient-based radial intensity enhancement, YOLOv7 detection, and
   multichannel marker aggregation. Applied to CTC detection, our system
   improves the F1 score from 61.6\% to 89.8\% and reduces analysis time
