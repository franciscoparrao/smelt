Unique-ID = {WOS:001720727300001},
}

@article{ WOS:001708059400001,
Author = {Khalid, Muhammad Usman and Nauman, Malik Muhammad and Rehman, Shafiq Ur
   and Zaini, Juliana Hj and Alsagri, Hatoon S. and Shafqat, Sheikh Naeem},
Title = {CCMH: An intelligent system for cross-condition mental health text
   analysis via semantic dictionary learning},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {316},
Month = {JUN 15},
Abstract = {Blind source separation (BSS) methods, successful in biomedical signal
   processing, remain unapplied to mental health text due to data
   incompatibility. This paper presents CCMH, an intelligent system for
   cross-condition mental health text analysis that enables BSS application
   by converting text into continuous 384-dimensional semantic
   representations using sentence transformers. The intelligent system
   automates pattern discovery through unsupervised decomposition,
   quantifying cross-condition activation patterns and discovering
   interpretable semantic structures without requiring labeled training
   data. Unlike supervised classifiers requiring labeled data or large
   language models (LLMs) lacking reproducibility and systematic
   cross-condition quantification frameworks, our approach provides
   reproducible metrics with explicit statistical validation through matrix
   decomposition and bootstrap testing, addressing gaps in existing
   black-box approaches. This makes it suitable for mental health research
   and clinical decision support applications. We propose shared dictionary
   learning (SDL), which pools dictionaries from multiple conditions with
   orthogonal pursuit refinement, achieving 40-79\% improved
   discriminability over single-baseline methods (K-SVD, ODL, ACSD).
   Analyzing eight mental health conditions across three time periods
   (seasonal 2019, pre-pandemic, mid-pandemic; 57,597 Reddit posts), we
   demonstrate robust cross-algorithm correlation (r=0.57-0.84, P<.001) and
   temporal stability (variation <10\%). Depression, anxiety, bipolar, BPD,
   and PTSD exhibit semantic overlap with baseline mental health discourse,
   whereas ADHD, eating disorders, and addiction show distinct profiles.},
