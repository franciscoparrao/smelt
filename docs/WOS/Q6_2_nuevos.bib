   Ribeiro, Ana; Garot, Elsa; Couture, Christine; Decaup, Pierre-hadrien, Univ Bordeaux, Minist Culture, CNRS, PACEA,UMR 5199, Pessac, France.
   Ribeiro, Ana; Garot, Elsa; Decaup, Pierre-hadrien, Univ Bordeaux, UFR Sci Odontol, Bordeaux, France.
   Ribeiro, Ana; Garot, Elsa; Decaup, Pierre-hadrien, CHU Bordeaux, Pole Med \& Chirurg Bucco Dentaire, Bordeaux, France.},
DOI = {10.1002/ar.70154},
EarlyAccessDate = {FEB 2026},
Keywords = {cortical bone; elliptic Fourier analysis; mandibular symphysis; ontogeny},
Keywords-Plus = {INFANT GROWTH-PATTERNS; FUNCTIONAL-SIGNIFICANCE; BIOMECHANICS;
   MORPHOLOGY; STRAIN; CHIMPANZEES; MANDIBLES; FORCES; IMAGE; SHAPE},
