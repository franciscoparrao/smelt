@article{ WOS:001723472800001,
Author = {Darvishnezhad, Mohsen and Sebt, Mohammad Ali},
Title = {EnSSNet: An advanced ensemble self-supervised learning framework with
   mini batch-graph convolutional network and deep curriculum learning for
   robust PolSAR image classification},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2025},
Volume = {330},
Number = {C},
Month = {NOV 25},
Abstract = {PolSAR image classification plays a crucial role in remote sensing by
   offering detailed surface information for various applications,
   including environmental monitoring and agricultural management. A major
   challenge in this field is the severe scarcity of high-quality labeled
   training samples, which greatly limits the performance of deep learning
   models. To address this challenge, a novel strategy named Ensemble-based
   Self-Supervised Network (EnSSNet) is presented in this study. This
   method mitigates the dependency on large annotated datasets by
   automatically learning robust and discriminative features without
   requiring annotation. In the proposed EnSSNet, the model autonomously
   discovers deep features that are highly conducive to classification
   tasks. This capability is realized through a synergistic integration of
   an innovative Mini Batch-Graph Convolutional Network (MB-GCN) and a
   Convolutional Neural Network (CNN)-based architecture. Specifically,
   EfficientNet-B0 is used as a CNN backbone of the EnSSNet. So, to extract
   discriminative features from PolSAR images, initially, a deep neural
   network is crafted by fusing the strengths of the MB-GCN and
   EfficientNet-B0. This design ensures both local structural awareness and
   global pattern abstraction. In fact, the GCN excels at capturing local
   relationships and intricate contextual interactions among pixels, while
   EfficientNet-B0, a CNN-based model, is adept at extracting hierarchical
   patterns from spatial and polarimetric information. The simultaneous use
   of these two networks results in a unified framework that combines local
   structure awareness with multi-scale feature abstraction, thus enhancing
   the overall performance of the classification system. Notably, the
   MB-GCN is specifically designed to be trained alongside the CNN-based
   network. Following the joint feature extraction, a cross correlation
   matrix is computed across different distortions of identical input
   samples. By constraining this matrix to approximate an identity matrix,
   the model is guided to cluster features of similar samples together.
   Simultaneously, it pushes apart those of dissimilar samples. This
   Self-Supervised Learning (SSL) strategy ensures that the latent
   representations capture the intrinsic relationships within the data,
   facilitating the learning of more consistent and separable feature
   spaces. In essence, this method enables the network to autonomously
   differentiate between homogeneous and heterogeneous samples in a
   self-organizing manner. Additionally, optimizing such a sophisticated
   network architecture necessitates an advanced learning paradigm. To that
   end, a novel Deep Curriculum Learning (DCL) optimization approach is
   incorporated, which demonstrates better convergence than conventional
   methods such as Stochastic Gradient Descent (SGD). The proposed DCL
   strategy, augmented by novel update function for each stage of training,
   not only accelerates convergence but also avoids the pitfalls of local
   minima. Moreover, to further reinforce the robustness of feature
   learning and enhance the classification performance, the proposed
   EnSSNet integrates two novel Ensemble Learning (EL) strategies: a
   feature-level ensemble and a view-level ensemble. The proposed
   feature-level ensemble is driven by the idea of combining outputs from
   various feature extractors to form a refined feature space, while the
   proposed view-level ensemble leverages spatial contextual information
   from multiple scales and polarimetric bands.
   By integrating both EL strategies, the model effectively harnesses the
   complete polarimetric and spatial information, including both local
   details and global context. This leads to a more resilient and accurate
   classification model. Also, within the feature-level ensemble framework,
   a new feature selection strategy is proposed that further refines the
   learned feature space. Feature selection techniques are critical as they
   reduce redundancy and mitigate the curse of dimensionality, ultimately
   enhancing the classifier's performance. It intelligently selects the
   most pertinent features, reducing the overall feature space while
   reinforcing the discriminative properties relevant to classification.
   This reduction leads to improved classification accuracy while also
   enhancing the efficiency of the system. In the final stage of the
   classification process, the selected feature vectors are fed into
   traditional classifiers, such as Random Forest (RF) or Support Vector
   Machines (SVM), for final label prediction. This hybrid approach
   combines the strengths of deep feature extraction and conventional
   classification algorithms, ensuring a robust prediction mechanism.
   Comprehensive experiments on the widely-used PolSAR datasets verify the
   superiority of EnSSNet in learning highly discriminative features under
   small-sample constraints, even under limited training samples,
   addressing one of the most critical challenges in PolSAR image
   classification. Specifically, the proposed EnSSNet demonstrates
   exceptional performance, achieving classification accuracies of 99.36 \%
   on the Flevoland dataset and 99.63 \% on the San Francisco PolSAR
   dataset. These results affirm the effectiveness and robustness of the
   proposed EnSSNet approach in addressing core challenges of PolSAR image
   classification, consistently outperforming several state-of-the-art
   methods under small sample constraints. In fact, the concurrent training
   of the MB-GCN and EfficientNet-B0 networks, combined with a
   self-supervised strategy based on cross-correlation constraints and a
   curriculum learning-based optimization scheme, forms a unified framework
   that effectively addresses the fundamental challenges of PolSAR image
   classification. Also, to promote transparency and reproducibility, the
   source code and experimental setup are publicly available at:
   https://github.com/mohsenda rvishnezhad/EnSSNet.},
Type = {Article},
Affiliation = {Sebt, MA (Corresponding Author), KN Toosi Univ Technol, Dept Elect Engn, Tehran, Iran.
   Darvishnezhad, Mohsen; Sebt, Mohammad Ali, KN Toosi Univ Technol, Dept Elect Engn, Tehran, Iran.},
DOI = {10.1016/j.knosys.2025.114744},
Article-Number = {114744},
Keywords = {Polarimetric synthetic aperture radar; Small sample classification;
   Self-supervised learning; Ensemble learning; Deep learning; Deep
   curriculum learning; Mini batch-graph convolutional network},
Keywords-Plus = {SCATTERING MODEL; NEURAL-NETWORK; DECOMPOSITION; SELECTION; FEATURES},
Author-Email = {darvishnezhad@email.kntu.ac.ir
   sebt@kntu.ac.ir},
Number-of-Cited-References = {172},
Times-Cited = {0},
Unique-ID = {WOS:001723472800001},
}

@article{ WOS:001646985900001,
Author = {Makrinsky, Kiril and Shendrikov, Valery and Makhonko, Anna and
   Merkushkin, Dmitry and Batishchev, Oleg V.},
Title = {LLM-Based Pipeline for Structured Knowledge Extraction from Scientific
   Literature on Heavy Metal Hyperaccumulation},
Journal = {MACHINE LEARNING AND KNOWLEDGE EXTRACTION},
Year = {2025},
Volume = {7},
Number = {4},
Month = {NOV 25},
Abstract = {The rapid growth of the body of literature on heavy metal
   hyperaccumulation in plants has created a critical bottleneck in data
   synthesis. Manual curation is slow, labor-intensive, and not scalable.
   To address this issue, we developed an artificial intelligence pipeline
   that automatically transforms unstructured scientific papers, including
   text, tables, and figures, into a structured knowledge database. Our
   system recovers numerical data and extracts key experimental parameters,
   such as plant species, metal types, concentrations, and growing
   conditions. This enables on-demand dataset generation. We validated our
   pipeline by replicating a recently published, manually curated dataset
   that required seven months of expert effort. Our tool achieved
   comparable accuracy in minutes per article. We implemented a
   dual-validation strategy combining standard extraction metrics with a
   qualitative ``LLM-as-a-Judge{''} fact-checking layer to assess
   contextual correctness. This revealed that high extraction performance
   does not guarantee factual reliability, underscoring the necessity of
   semantic validation in scientific knowledge extraction. The resulting
   open, reproducible framework accelerates evidence synthesis, supports
   trend analysis (e.g., metal-plant co-occurrence networks), and provides
   a scalable solution for data-driven environmental research.},
Type = {Article},
Affiliation = {Batishchev, OV (Corresponding Author), Russian Acad Sci, Frumkin Inst Phys Chem \& Electrochem, 31-4 Leninskiy Pr, Moscow 119071, Russia.
   Makrinsky, Kiril; Shendrikov, Valery; Makhonko, Anna; Merkushkin, Dmitry; Batishchev, Oleg V., Russian Acad Sci, Frumkin Inst Phys Chem \& Electrochem, 31-4 Leninskiy Pr, Moscow 119071, Russia.},
DOI = {10.3390/make7040152},
Article-Number = {152},
