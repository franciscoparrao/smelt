}

@article{ WOS:001717581500032,
Author = {Mamun, Abdullah Al and Herndon, Nic},
Title = {UACE-IF-AD: Unsupervised Tail-Mass Calibration for Isolation Forest
   Under Unknown Contamination},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {38908-38926},
Abstract = {Isolation Forest (IF) remains widely used for unsupervised anomaly
   detection in financial and cybersecurity applications, but its
   effectiveness is highly sensitive to the contamination hyperparameter,
   which is rarely known in practice. We propose UACE-IF-AD (Unsupervised
   Automatic Calibration Engine for Isolation Forest-based Anomaly
   Detection), a fully unsupervised framework for automatic operational
   tail-mass (alert-rate) calibration under unknown contamination. The
   proposed approach derives candidate operating points from the
   one-dimensional IF score distribution using three complementary
   diagnostics: Gaussian Mixture Modeling (GMM), Kernel Density Estimation
   (KDE), and Extreme Value Theory (EVT). A principled consensus rule
   reconciles the candidate operating points produced by the KDE, EVT, and
   GMM diagnostics, selecting a stable operating level when agreement is
   observed and reverting to a robust median fallback otherwise. Because
   UACE-IF-AD modifies only the decision threshold and not anomaly scores,
   ranking-based metrics (AUROC and average precision) remain invariant by
   design, while the resulting operating thresholds are stable,
   label-agnostic, and auditable. Experiments on three contrasting
   benchmarks (CreditCard2013, NSL-KDD, CICIDS2018) show that the proposed
   calibration yields consistent and interpretable alert rates across
   regimes ranging from extreme class imbalance (0.173\% fraud rate) to
   moderate ( approximate to 11.9\% ) and high-contamination ( approximate
   to 48\% ) intrusion scenarios. The framework produces reproducible
   diagnostics, tail-mass summaries, and auditable threshold records
   suitable for high-volume, label-scarce environments. Overall, the
   proposed approach enables fully unsupervised operational threshold
   calibration for Isolation Forest without labeled validation data, while
   maintaining stable alerting behavior across datasets.},
Type = {Article},
Affiliation = {Mamun, AA (Corresponding Author), East Carolina Univ, Dept Comp Sci, Greenville, NC 27858 USA.
   Mamun, Abdullah Al; Herndon, Nic, East Carolina Univ, Dept Comp Sci, Greenville, NC 27858 USA.},
DOI = {10.1109/ACCESS.2026.3671614},
Keywords = {Calibration; Contamination; Forestry; Benchmark testing; Anomaly
   detection; Fraud; Estimation; Tuning; Robustness; Reproducibility of
   results; Unsupervised anomaly detection; isolation forest; contamination
   estimation; threshold calibration; anomaly score calibration; density
   and tail modeling; imbalanced data learning; financial fraud and network
   intrusion detection},
Author-Email = {mamuna24@students.ecu.edu},
Number-of-Cited-References = {30},
Times-Cited = {0},
Unique-ID = {WOS:001717581500032},
}

@article{ WOS:001719526900006,
Author = {Helaly, Abdelrahman and Madkour, Kareem and Torunoglu, Ilhami and Sakr,
   Nourhan},
Title = {Unsupervised Graph Neural Network Framework for Balanced Multipatterning
   in Advanced Electronic Design Automation Layouts},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {41764-41781},
Abstract = {Multipatterning is an essential decomposition strategy in electronic
   design automation (EDA) that overcomes lithographic limitations when
   printing dense circuit layouts. Although heuristic-based backtracking
   and SAT solvers can address these challenges, they often struggle to
   simultaneously handle both complex constraints and secondary objectives.
   In this study, we present a hybrid workflow that casts multipatterning
   as a variant of a constrained graph coloring problem with the primary
   objective of minimizing feature violations and a secondary objective of
   balancing the number of features on each mask. Our pipeline integrates
   two main components: 1) A GNN-based agent, trained in an unsupervised
   manner to generate initial color predictions, which are refined; and 2)
   refinement strategies (a GNN-based heuristic and simulated annealing)
   that together enhance solution quality and balance. Experimental
   evaluation on both proprietary data sets and publicly available
   open-source layouts demonstrates effective minimization of feature
   conflicts and consistent color balancing. Conflict-free decompositions
   are achieved in cases where a feasible solution exists. The proposed
   framework provides a reproducible, data-efficient and deployable
   baseline for scalable layout decomposition in EDA workflows.},
Type = {Article},
Affiliation = {Helaly, A (Corresponding Author), Siemens EDA, Plano, TX 75024 USA.
   Helaly, A (Corresponding Author), Amer Univ Cairo, Cairo 11835, Egypt.
   Helaly, Abdelrahman; Madkour, Kareem; Torunoglu, Ilhami, Siemens EDA, Plano, TX 75024 USA.
   Helaly, Abdelrahman; Sakr, Nourhan, Amer Univ Cairo, Cairo 11835, Egypt.},
DOI = {10.1109/ACCESS.2026.3673032},
Keywords = {Layout; Image color analysis; Graph neural networks; Manufacturing;
   Training; Design automation; Physical design; Optimization;
   Minimization; Industries; Electronic design automation; graph neural
   networks; multipatterning; layout decomposition; design for
   manufacturability; machine learning; graph coloring},
Keywords-Plus = {DECOMPOSITION},
Author-Email = {abdelrahman.helaly@siemens.com},
Number-of-Cited-References = {23},
Times-Cited = {0},
Unique-ID = {WOS:001719526900006},
}

@article{ WOS:001719526900043,
Author = {Zhao, Wenyu and Chen, Tingjie and Yang, Jie Si and Qiu, Lei},
Title = {AutoML-Pipeline: A RAG-Enhanced Code Generation Framework With
   Pre-Validation for Cloud-Native Machine Learning Workflows},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {41932-41945},
Abstract = {The proliferation of cloud-native machine learning platforms has
   significantly accelerated model development and deployment cycles.
   However, constructing and maintaining heterogeneous pipeline code
   spanning multiple languages (Python, YAML, Spark SQL) and cloud-specific
   configurations remains labor-intensive and error-prone. Existing
   LLM-based code generation tools lack awareness of runtime constraints
   and historical execution patterns, frequently producing code with
   resource misconfigurations or dependency conflicts that fail upon
   deployment. To address these challenges, we propose AutoML-Pipeline, a
   closed-loop code generation framework that integrates
   Retrieval-Augmented Generation (RAG) with reinforcement learning
   feedback mechanisms. Our approach leverages a knowledge base constructed
   from successful pipeline execution logs to guide GPT-4 in generating
   deployment-ready code that adheres to platform-specific constraints. The
   key innovation lies in a novel Pre-validation Agent that employs
   simulated execution environments to predict resource consumption and
   detect dependency conflicts before actual deployment. This agent
   iteratively refines generated code through a feedback loop informed by
   predicted execution profiles and dependency graphs. We evaluate our
   framework on the CodeSearchNet dataset augmented with Azure ML pipeline
   specifications, demonstrating a 43.7\% improvement in first-submission
   success rate and 31.2\% reduction in resource over-provisioning compared
   to vanilla GPT-4 baselines. Ablation studies confirm that both the RAG
   retrieval mechanism and pre-validation agent contribute substantially to
   performance gains. Our work establishes a practical paradigm for
   integrating large language models with domain-specific runtime
   intelligence, with potential applications extending to other
   infrastructure-as-code generation tasks.},
Type = {Article},
Affiliation = {Zhao, WY (Corresponding Author), Microsoft, Beijing 100080, Peoples R China.
   Zhao, Wenyu, Microsoft, Beijing 100080, Peoples R China.
   Chen, Tingjie, Intel, Shanghai 200131, Peoples R China.
   Yang, Jie Si, Univ Utah, Salt Lake City, UT 84112 USA.
   Qiu, Lei, Ningbo Univ Technol, Ningbo 315104, Peoples R China.},
DOI = {10.1109/ACCESS.2026.3673923},
Keywords = {Codes; Pipelines; Retrieval augmented generation; Machine learning;
   Large language models; Knowledge based systems; Training; Reinforcement
   learning; Programming; Iterative methods; Code generation;
   retrieval-augmented generation; cloud computing; automated optimization;
   large language models},
Author-Email = {wenyuzhao@stu.xidian.edu.cn},
Number-of-Cited-References = {60},
Times-Cited = {0},
Unique-ID = {WOS:001719526900043},
}

@article{ WOS:001719534900017,
Author = {Eon, Rehman S. and Gerace, Aaron and Montanaro, Matthew},
Title = {A Forward Modeling Approach for the Vicarious Validation of the Thermal
   Infrared Sensor On-Board Landsat 8 and 9},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {9020-9031},
Abstract = {The Landsat program has maintained a continuous, global thermal record
   for over 40 years, supporting various long-term Earth observation
   scientific studies. We present an in-flight validation of Landsat 8 and
   Landsat 9 thermal infrared sensor (TIRS) data using a physics-based
   forward-modeling approach that converts in situ measurements from
   open-water buoys distributed across the Continental United States
   (CONUS) into predicted at-sensor radiance. Previous vicarious validation
   approaches relied on radiosonde atmospheric profiles that are sparsely
   sampled in time and space, often mismatched to Landsat overpass
   conditions, and typically lacked a comprehensive, end-to-end uncertainty
   characterization, which limited quantitative assessment of radiometric
   accuracy. Unlike these approaches, the framework presented here uses
   high spatiotemporal resolution GEOS-5 Forward Processing (FP) reanalysis
   data to accurately represent the atmospheric column at the time of
   satellite overpass. We detail this improved forward-modeling framework
   and develop a comprehensive uncertainty budget for the process in
   accordance with the Guide to the Expression of Uncertainty in
   Measurement (GUM) guidelines. Our results confirm that Landsat 8/9
   performance from the vicarious validation remain within each sensor's
   absolute radiometric uncertainty, with Landsat 8 mean biases of -0.020
   and 0.013 {[}W/m(2)/sr/mu m] for Bands 10 and 11, and Landsat 9 mean
   biases of -0.002 and -0.009 {[}W/m(2)/sr/mu m], demonstrating continued
   radiometric stability across successive missions. Although our
   open-access workflow is demonstrated here using the Landsat thermal
   bands, the underlying process and uncertainty methodology provide a
   reproducible vicarious validation/calibration framework applicable to
   current and future thermal sensors, including NASA missions (e.g.,
   Landsat Next) and emerging commercial platforms that may rely heavily on
   external validation of their data products.},
Type = {Article},
Affiliation = {Eon, RS (Corresponding Author), Rochester Inst Technol, Rochester, NY 14623 USA.
   Eon, Rehman S.; Gerace, Aaron; Montanaro, Matthew, Rochester Inst Technol, Rochester, NY 14623 USA.},
DOI = {10.1109/JSTARS.2026.3670640},
Keywords = {Ocean temperature; Temperature measurement; Landsat; Atmospheric
   modeling; Atmospheric measurements; Temperature sensors; Sea surface;
   Sea measurements; Sensors; Skin; Forward modeling; thermal infrared
   sensor (TIRS); uncertainty analysis; vicarious validation},
Keywords-Plus = {RADIOMETRIC CALIBRATION; TEMPERATURE; ALGORITHM; EVAPOTRANSPIRATION;
   IMAGERY; FIELD; LAW},
Author-Email = {eoncis@rit.edu
   adgpci@cis.rit.edu
   mxmpci@rit.edu},
Number-of-Cited-References = {51},
Times-Cited = {0},
Unique-ID = {WOS:001719534900017},
}

@article{ WOS:001721310300001,
Author = {Guillen, Pablo and Frias-Martinez, Enrique},
Title = {Enhancing SHAP Explainability for Diagnostic and Prognostic ML Models in
   Alzheimer's Disease},
Journal = {CMC-COMPUTERS MATERIALS \& CONTINUA},
Year = {2026},
Volume = {87},
Number = {2},
Abstract = {Alzheimer's disease (AD) diagnosis and prognosis increasingly rely on
   machine learning (ML) models. Although these models provide good
   results, clinical adoption is limited by the need for technical
   expertise and the lack of trustworthy and consistent model explanations.
   SHAP (SHapley Additive exPlanations) is commonly used to interpret AD
   models, but existing studies tend to focus on explanations for isolated
   tasks, providing little evidence about their robustness across disease
   stages, model architectures, or prediction objectives. This paper
   proposes a multilevel explainability framework that measures the
   coherence, stability and consistency of explanations by integrating: (1)
   within-model coherence metrics between feature importance and SHAP, (2)
   SHAP stability across AD boundaries, and (3) SHAP cross-task consistency
   between diagnosis and prognosis. Using AutoML to optimize classifiers on
   the NACC dataset, we trained four diagnostic and four prognostic models
   covering the standard AD progression stages: normal-control (NC),
   mild-cognitive impairment (NCI) and AD. For each model, we generated
   SHAP and feature importance (FI) plots. Stability was then evaluated
   using correlation metrics (Spearman, Kendall), top-k feature overlap
   (Jaccard@10/20), SHAP sign consistency, and domain-level contribution
   ratios. Results show that cognitive and functional markers (e.g.,
   MEMORY, JUDGMENT, ORIENT, PAYATTN) dominate SHAP explanations in both
   diagnosis and prognosis. SHAP-SHAP consistency between diagnostic and
   prognostic models was high across all classifiers (rho = 0.61-0.94),
   with 100\% sign stability and minimal shifts in explanatory magnitude
   (mean Delta divided by SHAP divided by<0.03). Domain-level contributions
   also remained stable, with only minimal increases in genetic features
   for prognosis. These results demonstrate that SHAP explanations can be
   quantitatively validated for robustness and transferability, providing
   clinicians with more reliable interpretations of ML predictions. The
   proposed framework provides a reproducible methodology for evaluating
   explainability stability and coherence, supporting the deployment of
   trustworthy ML systems in AD clinical settings.},
Type = {Article},
Affiliation = {Frias-Martinez, E (Corresponding Author), Univ Int La Rioja UNIR, Res Inst UNIR iTED, La Rioja, Spain.
   Guillen, Pablo, MIU City Univ, Miami, FL USA.
   Frias-Martinez, Enrique, Univ Int La Rioja UNIR, Res Inst UNIR iTED, La Rioja, Spain.},
DOI = {10.32604/cmc.2026.076400},
Article-Number = {95},
Keywords = {Alzheimer's disease (AD); automated machine learning (AutoML); Pycaret;
   SHAP},
Author-Email = {enrique.frias@unir.net},
Number-of-Cited-References = {37},
Times-Cited = {0},
Unique-ID = {WOS:001721310300001},
}

@article{ WOS:001721308400001,
Author = {Makumbura, Randika K. and Wijesundara, Hasanthi and Sajindra, Hirushan
   and Rathnayake, Upaka and Kumar, Vikram and Duraibabu, Dineshbabu and
   Sen, Sumit},
Title = {QPred: A Lightweight Deep Learning-Based Web Pipeline for Accessible and
   Scalable Streamflow Forecasting},
Journal = {CMC-COMPUTERS MATERIALS \& CONTINUA},
Year = {2026},
Volume = {87},
Number = {2},
Abstract = {Accurate streamflow prediction is essential for flood warning, reservoir
   operation, irrigation scheduling, hydropower planning, and sustainable
   water management, yet remains challenging due to the complexity of
   hydrological processes. Although data-driven models often outperform
   conventional physics-based hydrological modelling approaches, their
   real-world deployment is limited by cost, infrastructure demands, and
   the interdisciplinary expertise required. To bridge this gap, this study
   developed QPred, a regional, lightweight, cost-effective, web-delivered
   application for daily streamflow forecasting. The study executed an
   end-to-end workflow, from field data acquisition to accessible web-based
   deployment for on-demand forecasting. High-resolution rainfall data were
   recorded with tipping-bucket gauges and loggers, while river water depth
   in the Aglar and Paligaad watersheds was converted to discharge using
   site-specific rating curves, resulting in a daily dataset of
   precipitation, river water level and discharge. Four DL architectures
   were trained, including vanilla Long Short-Term Memory (LSTM), stacked
   LSTM, bidirectional LSTM, and Gated Recurrent Unit (GRU), and evaluated
   using Nash-Sutcliffe Efficiency (NSE), Coefficient of Determination
   (R-2), Root-Mean-Square-Error-Standard-Deviation Ratio (RSR), and
   Percentage Bias (PBIAS) metrics. Performance was watershed-specific, as
   the vanilla LSTM demonstrated the best generalisation for the Aglar
   watershed (R-2 = 0.88, NSE = 0.82, RMSE = 0.12 during validation), while
   the GRU achieved the highest validation accuracy in Paligaad (R-2 =
   0.88, NSE = 0.88, RMSE = 0.49). All models achieved satisfactory to
   excellent performance during calibration (R-2 > 0.91, NSE > 0.91 for
   both watersheds), demonstrating strong capability to capture streamflow
   dynamics. The highest performing models were selected and embedded into
   the QPred application. QPred was developed as a lightweight web
   pipeline, utilising Google Colab as the primary execution environment,
   Flask as the backend inference framework, Google Drive for artefact
   storage, and Ngrok for secure HTTPS tunnelling. A user-friendly front
   end utilises range sliders (bounded by observed minima and maxima) to
   gather inputs and provides discharge data along with metadata, thereby
   enhancing transparency. This work demonstrates that accurate,
   context-aware deep learning models can be delivered through low-cost,
   web-based platforms, providing a reproducible and scalable pipeline for
   hydrological applications in other watersheds and for practitioners.},
Type = {Article},
Affiliation = {Rathnayake, U (Corresponding Author), Atlantic Technol Univ, Fac Engn \& Design, Sligo F91YW50, Ireland.
   Makumbura, Randika K.; Sajindra, Hirushan; Rathnayake, Upaka; Duraibabu, Dineshbabu, Atlantic Technol Univ, Fac Engn \& Design, Sligo F91YW50, Ireland.
   Wijesundara, Hasanthi, Sri Lanka Inst Informat Technol, Dept Civil Engn, Malabe 10115, Sri Lanka.
   Kumar, Vikram; Sen, Sumit, Indian Inst Technol, Dept Hydrol, Roorkee 247667, India.},
DOI = {10.32604/cmc.2026.075539},
Article-Number = {45},
Keywords = {Deep learning; GRU; LSTM; Ngrok; sreamflow prediction; web-based
   application},
Author-Email = {upaka.rathnayake@atu.ie},
Number-of-Cited-References = {31},
Times-Cited = {0},
Unique-ID = {WOS:001721308400001},
}

@article{ WOS:001721463500004,
Author = {Chang, Ke-Vin and Wu, Wei-Ting and Tsai, Yuan-Yuan and Chi, Shao-Yu and
   Mezian, Kamal and Ricci, Vincenzo and Boudier-Reveret, Mathieu and
   Ozcakar, Levent},
Title = {USMSIT/NMUSIT Fundamental Guide on Diagnostic and Interventional
   Shoulder Ultrasonography},
Journal = {JOURNAL OF MEDICAL ULTRASOUND},
Year = {2026},
Volume = {34},
Number = {1},
Pages = {1-8},
Month = {JAN-MAR},
Abstract = {High-resolution ultrasound (US) has become an indispensable tool in
   evaluating and managing shoulder pain. It offers real-time visualization
   of tendons, ligaments, bursae, and joint recesses while enabling dynamic
   assessment and image-guided intervention. Building on the
   EURO-MUSCULUS/USPRM framework, this guideline presents a standardized,
   anatomy-based approach to diagnostic and interventional shoulder
   ultrasonography. Developed under the educational mission of the
   Ultrasound and Musculoskeletal/Neuromuscular Sonography Initiative in
   Taiwan - through its flagship programs Ultrasound Musculoskeletal
   Workshop in Taiwan (USMSIT) and Neuromuscular Ultrasound Workshop in
   Taiwan (NMUSIT) - the protocol integrates didactic instruction, live
   demonstration, and structured hands-on training to ensure reproducible
   and clinically relevant examinations. The guideline details systematic
   scanning of the long head of the biceps, subscapularis,
   acromioclavicular joint, supraspinatus, infraspinatus, teres minor, and
   posterior glenohumeral joint. It is also supplemented by tripartite
   visual documentation comprising cadaveric dissection, regional
   illustrations, and paired US images from both high-end and handheld
   devices. Characteristic sonographic findings for common shoulder
   pathologies - including biceps peritendinous effusion, acromioclavicular
   arthropathy, calcific tendinopathy, rotator cuff tears, and
   subacromial-subdeltoid bursitis - are described. In addition, practical
   pearls for US-guided interventions such as the long head of the biceps
   tendon, acromioclavicular joint, subdeltoid bursa, and posterior
   glenohumeral injections are provided. Emphasizing the principle of
   ``diagnosis ahead of intervention,{''} this guideline bridges
   educational precision and procedural application-fostering consistent
   training as well as safer and more effective management of shoulder
   disorders. Its standardized image - anatomy framework further
   facilitates integration into artificial intelligence - assisted systems
   for automated view recognition and measurement. Therefore, it aims to
   advance clinical, educational, and research endeavors in musculoskeletal
   ultrasonography.},
Type = {Review},
Affiliation = {Chang, KV (Corresponding Author), Natl Taiwan Univ Hosp, Dept Phys Med \& Rehabil, Bei Hu Branch, 87 Nei Jiang Rd, Taipei 108, Taiwan.
   Chang, Ke-Vin; Wu, Wei-Ting; Tsai, Yuan-Yuan; Chi, Shao-Yu, Natl Taiwan Univ Hosp, Dept Phys Med \& Rehabil, Bei Hu Branch, 87 Nei Jiang Rd, Taipei 108, Taiwan.
   Chang, Ke-Vin; Wu, Wei-Ting, Natl Taiwan Univ, Coll Med, Dept Phys Med \& Rehabil, Taipei, Taiwan.
   Chang, Ke-Vin, Taipei Med Univ, Wang Fang Hosp, Ctr Reg Anesthesia \& Pain Med, Taipei, Taiwan.
   Mezian, Kamal, Charles Univ Prague, Fac Med 1, Dept Rehabil Med, Prague, Czech Republic.
   Mezian, Kamal, Gen Univ Hosp Prague, Prague, Czech Republic.
   Ricci, Vincenzo, ASST Fatebenefratelli Sacco, Luigi Sacco Univ Hosp, Phys \& Rehabil Med Unit, Milan, Italy.
   Boudier-Reveret, Mathieu, Ctr Hosp Univ Montreal, Phys Med \& Rehabil Serv, Montreal, PQ, Canada.
   Ozcakar, Levent, Hacettepe Univ, Med Sch, Dept Phys \& Rehabil Med, Ankara, Turkiye.},
DOI = {10.4103/jmu.JMU-D-25-00156},
Keywords = {Diagnosis; intervention; pain; rotator cuff; ultrasound},
