}

@article{ WOS:001686820100001,
Author = {Burkhardt, Micha and Giessing, Carsten},
Title = {The Comet Toolbox: Improving robustness in network neuroscience through
   multiverse analysis},
Journal = {IMAGING NEUROSCIENCE},
Year = {2026},
Volume = {4},
Month = {FEB 10},
Abstract = {In network neuroscience, a broad range of methods for estimating dynamic
   functional connectivity from fMRI data and subsequent analyses using
   network-based approaches have been introduced in recent years. However,
   in the absence of ground truths about the validity of analytical steps
   in capturing true brain dynamics, researchers are often faced with a
   multitude of arbitrary yet defensible choices, raising concerns about
   the robustness of results. Here, we aim to address this issue by
   implementing a comprehensive suite of dynamic functional connectivity
   methods in a unified Python software package, allowing for a diverse
   exploration of brain dynamics. Anchored in the framework of multiverse
   analysis, the present work introduces a workflow for systematically
   exploring different methodological choices. The developed toolbox
   includes a graphical user interface to enhance ease of use and
   accessibility for those who prefer to work outside a script-based
   pipeline. Comprehensive documentation and demo scripts are included to
   support adoption and usability. By promoting transparency and
   robustness, Comet aims to advance best practices in the study of brain
   dynamics.},
Type = {Article},
Affiliation = {Burkhardt, M (Corresponding Author), Carl von Ossietzky Univ Oldenburg, Dept Psychol Psychol Methods \& Stat, Oldenburg, Germany.
   Burkhardt, Micha, Carl von Ossietzky Univ Oldenburg, Dept Psychol Psychol Methods \& Stat, Oldenburg, Germany.
   Giessing, Carsten, Carl von Ossietzky Univ Oldenburg, Dept Psychol, Biol Psychol, Oldenburg, Germany.},
DOI = {10.1162/IMAG.a.1122},
Article-Number = {IMAGa1122},
Keywords = {dynamic functional connectivity; multiverse analysis; graph analysis;
   fMRI; toolbox},
Keywords-Plus = {TIME-VARYING CONNECTIVITY; FUNCTIONAL CONNECTIVITY; FMRI;
   REPRODUCIBILITY; CRISIS},
Author-Email = {micha.burkhardt@uol.de},
