DOI = {10.3390/buildings15244556},
Article-Number = {4556},
Keywords = {generative design; performance-driven building; multi-objective
   optimization; surrogate/Bayesian optimization; machine learning},
Keywords-Plus = {MULTIOBJECTIVE OPTIMIZATION DESIGN; THERMAL COMFORT; DAYLIGHT
   PERFORMANCE; ENERGY-CONSUMPTION; SIMULATION; METRICS},
Author-Email = {aryyang\_huang@mail.scut.edu.cn
   zhangzhh@scut.edu.cn},
Number-of-Cited-References = {189},
