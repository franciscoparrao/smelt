@article{ WOS:001711223200001,
Author = {Klaseboer, Gerrit and Naghinejad, Maysam and Van Tijum, Redmer and Zhou,
   Yadong and Lu, Kegu and Post, Jan and Pei, Yutao},
Title = {A novel stress manipulation method for robust and reliability-based
   optimization of multi-step forming processes},
Journal = {MATERIALS \& DESIGN},
Year = {2026},
Volume = {264},
Month = {APR},
Abstract = {In this study, a novel framework is developed that treats local
   stressregion parameters (size, location, type, and timing) as explicit
   design variables for robust, reliabilitybased optimization of multistep
   metalforming processes. Addressing the gap that current workflows either
   rely on global process controls or manual adjustments and are
   computationally prohibitive for systematic robustness design, our
   approach couples an automated FEM-DoE pipeline with surrogate metamodels
   and screening techniques to reduce the number of full finiteelement
   evaluations. The workflow integrates meshsensitivity analysis, automatic
   multistep simulation and output extraction, a stressmanipulation
   algorithm, and downstream Pareto, stability, and spread analyses, and
   supports both robust and reliabilitybased optimization to select
   stressmanipulation size, location, type, and flattening depth according
   to user objectives. In a representative multistep forming case study,
   targeted stress manipulations combined with optimization reduced
   springback variability and improved robustness by up to about 60\%
   relative to the unmodified baseline. Permitting flattening depth as an
   unconstrained design variable produced robustness gains up to around
   80\% in unconstrained scenarios, though with measurable reductions in
   reliability in those cases. Fullthickness, pretools opening
   interventions consistently outperformed partialthickness or posttools
   opening adjustments. These results demonstrate that local stress
   manipulation is an effective lever for improving robustness and that the
   insights gained from this research based on the proposed automated
   pipeline enables reproducible, computationally tractable,
   reliabilityaware decision making for industrial metalforming design
   where controlling parameters is critical to ensuring the accuracy and
   robustness of products.},
Type = {Article},
Affiliation = {Naghinejad, M; Post, J (Corresponding Author), Univ Groningen, Engn \& Technol Inst Groningen, Fac Sci \& Engn, Adv Prod Engn, Nijenborgh 3, NL-9747 AG Groningen, Netherlands.
   Klaseboer, Gerrit; Naghinejad, Maysam; Van Tijum, Redmer; Zhou, Yadong; Lu, Kegu; Post, Jan; Pei, Yutao, Univ Groningen, Engn \& Technol Inst Groningen, Fac Sci \& Engn, Adv Prod Engn, Nijenborgh 3, NL-9747 AG Groningen, Netherlands.},
DOI = {10.1016/j.matdes.2026.115740},
Article-Number = {115740},
Keywords = {Stress manipulation; Optimization; Robustness; Reliability; Multi-step
   forming process; Metamodeling},
Keywords-Plus = {CONTINUUM STRUCTURES; RESIDUAL-STRESSES; STRATEGY},
Author-Email = {m.naghinejad@rug.nl
   jan.post@rug.nl},
Number-of-Cited-References = {47},
Times-Cited = {0},
Unique-ID = {WOS:001711223200001},
}

@article{ WOS:001709532500001,
Author = {Stoupis, Dimitrios and Assecondi, Sara},
Title = {Anatomy-informed recommendations for electrode montage and shape in
   electrical stimulation methods: a tDCS case study},
Journal = {JOURNAL OF NEURAL ENGINEERING},
Year = {2026},
Volume = {23},
Number = {2},
Month = {APR 1},
Abstract = {Objective. Transcranial direct current stimulation (tDCS) shows
   potential for cognitive enhancement and neuromodulation, yet its
   efficacy is limited by substantial inter-individual variability in the
   induced electric field (E-field) distribution in targeting brain areas
   and functional networks. This study aims to develop an anatomy-informed
   framework to select electrode montage and geometry that optimizes
   network-level E-field delivery. Approach. Using high-resolution
   T1-weighted/T2-weighted MRI from 590 participants (ages 36-80) in the
   Human Connectome Project-Aging, we extracted anatomical features,
   including cortical, skull, and cerebrospinal fluid (CSF) thickness, and
   sulcal depth. We simulated E-fields with finite-element models (SimNIBS
   4.1) across multiple commonly used montages in working memory research.
   Network-level analyses, based on the Schaefer atlas, were performed to
   assess the spatial distribution and intensity of tDCS-induced E-fields.
   Main results. Montage configuration and individual anatomy strongly
   shape the spatial distribution and intensity of tDCS-induced E-fields.
   For montages targeting the dorsolateral prefrontal cortex, the resulting
   fields extended beyond the intended site and exhibited considerable
   variability in their cortical focality and magnitude. Principal
   component and feature importance analyses indicated local gyrification
   index, cortical thickness, skull thickness, CSF thickness, and sulcal
   depth as primary determinants of network-level E-field distribution,
   with executive and default mode networks most consistently receiving
   suprathreshold E-field magnitudes. Importantly, peak induced E-field
   varied markedly between individuals even under standardized protocols,
   highlighting substantial inter-individual variability in both dosing and
   targeting outcomes. Significance. We present a practical workflow for
   anatomy-guided montage selection that addresses the need for
   personalized approaches in tDCS. This framework has the potential to
   improve the efficacy and reproducibility of tDCS in both research and
   clinical practice by accounting for individual anatomical differences in
   stimulation planning.},
Type = {Article},
Affiliation = {Stoupis, D (Corresponding Author), Aristotle Univ Thessaloniki, Dept Appl \& Environm Phys, Thessaloniki, Greece.
   Stoupis, D (Corresponding Author), Univ Trento, Ctr Mind Brain Sci CIMeC, Rovereto, TN, Italy.
   Stoupis, Dimitrios, Aristotle Univ Thessaloniki, Dept Appl \& Environm Phys, Thessaloniki, Greece.
   Stoupis, Dimitrios; Assecondi, Sara, Univ Trento, Ctr Mind Brain Sci CIMeC, Rovereto, TN, Italy.
   Assecondi, Sara, Univ Trento, Dept Psychol \& Cognit Sci DiPSCo, Rovereto, TN, Italy.},
DOI = {10.1088/1741-2552/ae4a4e},
Article-Number = {026005},
Keywords = {transcranial direct current stimulation; electric field modeling;
   anatomical variability; network neuroscience; personalized
   neuromodulation},
Keywords-Plus = {HUMAN CEREBRAL-CORTEX; BRAIN-STIMULATION; COGNITIVE NEUROSCIENCE; FIELD;
   VARIABILITY; SIMULATION; THICKNESS; OUTCOMES; IMPACT},
