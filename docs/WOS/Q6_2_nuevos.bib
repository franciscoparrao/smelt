@article{ WOS:001693832200001,
Author = {Ali, Malek and Alsoud, Ammar and Mohammed, Yusof A. Y. A. and Daradkeh,
   Samer I. and Mousa, Marwan S. and Eliasova, Pavla and Knapek, Alexandr
   and Sobola, Dinara and Marsalek, Roman},
Title = {Automated dielectric property analysis in composite materials: Toward
   reproducible application mapping and machine-learning integration},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {Dielectric spectroscopy provides critical insight into relaxation
   dynamics and charge-transport mechanisms in functional polymer
   composites, yet its analysis relies on manual fitting, subjective
   parameter selection, and poor reproducibility. Here, we introduce an
   automated, physics-informed framework that transforms raw broadband
   dielectric spectra E{*}(f,T) (1 Hz-10 MHz) into validated models,
   uncertainty-aware parameters, and application-relevant performance
   indicators. The workflow integrates automated quality assurance,
   physics-based seeding, multi-start bounded Havriliak-Negami fitting,
   objective model selection, and cross-domain consistency checks across
   E{*}, M{*}, and Z{*} representations. The approach is demonstrated on
   PVDF/zeolite Na-X composites (0-50 wt.\% filler) measured from 30 to 120
   degrees C, where it resolves low-and high-frequency relaxation
   processes, extracts activation energies and equivalent-circuit
   parameters, and achieves Arrhenius interpolation errors below 5 \%
   within the measured domain. By systematically mapping dielectric
   permittivity, loss, transport parameters, and interfacial polarization
   to composition, the framework enables quantitative comparison of
   materials across application targets such as high-k dielectrics,
   solid-state electrolytes, and sensing layers. By enforcing reproducible
   analysis, explicit uncertainty propagation, and machine-readable outputs
   compatible with data-science and graph-based learning models, this work
   advances dielectric spectroscopy from manual curve fitting toward a
   transparent, scalable, and data-driven materials-design methodology for
   sustainable energy applications.},
Type = {Article},
Affiliation = {Ali, M (Corresponding Author), Brno Univ Technol, Fac Elect Engn \& Commun, Dept Radio Elect, Brno 61600, Czech Republic.
   Alsoud, A (Corresponding Author), Brno Univ Technol, Fac Elect Engn \& Commun, Dept Phys, Tech 2848-8, Brno 61600, Czech Republic.
