}

@article{ WOS:001683852700001,
Author = {Shi, Yingbo},
Title = {Automatic optimization design of the in-focus varied line space
   plane-grating monochromator beamline for soft X-ray applications},
Journal = {NUCLEAR INSTRUMENTS \& METHODS IN PHYSICS RESEARCH SECTION
   A-ACCELERATORS SPECTROMETERS DETECTORS AND ASSOCIATED EQUIPMENT},
Year = {2026},
Volume = {1086},
Month = {JUN},
Abstract = {Optimizing an in-focus varied line space plane-grating monochromator
   (VLS-PGM) beamline is challenging due to many interdependent parameters,
   including grating line density, cosine ratio, groove depth, duty ratio,
   premirror deviation angle, and monochromator length. In our earlier
   work, we demonstrated automatic optimization for plane-grating
   monochromators with collimated illumination. Here, we extend the
   framework to infocus VLS-PGM designs, systematically comparing swarm
   intelligence (SI) and evolutionary algorithms (EAs)-Differential
   Evolution, Immune Algorithm, Particle Swarm Optimization, and Artificial
   Bee Colony. The approach identifies parameter sets achieving 100,000
   energy resolution at 1000 eV with high transmission and quantifies the
   impact of grating and monochromator length variations. This study
   provides both a methodological advance in optimization and a practical,
   reproducible workflow for future soft X-ray beamline design.},
Type = {Article},
Affiliation = {Shi, YB (Corresponding Author), ChongQing Univ, Lab Ultrafast Transient Facil, Chongqing 400044, Peoples R China.
   Shi, Yingbo, ChongQing Univ, Lab Ultrafast Transient Facil, Chongqing 400044, Peoples R China.},
DOI = {10.1016/j.nima.2026.171325},
EarlyAccessDate = {FEB 2026},
Article-Number = {171325},
Keywords = {Plane-grating monochromator; Soft X-ray beamline; Intelligence
   optimization algorithms},
Keywords-Plus = {ENERGY-RESOLUTION; SCATTERING},
