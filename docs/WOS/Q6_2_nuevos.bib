}

@article{ WOS:001673133000001,
Author = {Fonseca, Pedro Dobroes and Antunes, Wilson and Cardoso, Susana},
Title = {Characterisation of bacterial-nanoparticle interactions via STORM and
   SEM: Optimising magnetic labelling strategies for biosensor integration},
Journal = {SENSORS AND ACTUATORS REPORTS},
Year = {2026},
Volume = {11},
Month = {JUN},
Abstract = {Magnetic nanoparticles are critical components in biosensors for
   pathogen detection, enabling magnetic capture, signal amplification, and
   integration with microfluidic systems. However, the nanoscale mechanisms
   underlying magnetic nanoparticle-bacteria interactions remain poorly
   characterised, limiting labelling reproducibility and biosensor
   sensitivity. This study employed super-resolution stochastic optical
   reconstruction microscopy (STORM) and scanning electron microscopy (SEM)
   to investigate the spatial distribution of magnetic nano-particles on 2
   mu m polystyrene beads and Bacillus cereus spores, used as a safe
   surrogate for Bacillus anthracis. STORM imaging revealed clustered
   antibody binding at the spore periphery, consistent with structured
   epitope presentation in the exosporium. Over 80\% of localisations were
   assigned to nanoclusters, confirming nonrandom antigen distribution. SEM
   analysis demonstrated that 100 nm dextran-coated iron oxide magnetic
   nanoparticles provided superior surface dispersion and lower aggregation
   compared to 250 nm dextran-coated iron oxide magnetic nanoparticles. A
   vacuum-assisted filtration protocol significantly enhanced magnetic
   nanoparticle uniformity and specificity while removing loosely
   associated aggregates. These findings support the use of 100 nm magnetic
   nanoparticles for biosensor integration and establish a robust
   image-based workflow for assessing nanoparticle binding at single-cell
   resolution. This work provides mechanistic insight into bacterial
   surface labelling and offers a framework for optimising magnetic
   labelling strategies for future biosensing and diagnostic applications.},
Type = {Article},
Affiliation = {Fonseca, PD (Corresponding Author), INESC MN, Rua Alves Redol 9, P-1000029 Lisbon, Portugal.
   Fonseca, PD (Corresponding Author), Univ Lisbon, Dept Bioengn, Inst Super Tecn, Lisbon, Portugal.
   Fonseca, Pedro Dobroes, INESC MN, Rua Alves Redol 9, P-1000029 Lisbon, Portugal.
   Fonseca, Pedro Dobroes, Univ Lisbon, Dept Bioengn, Inst Super Tecn, Lisbon, Portugal.
   Antunes, Wilson, Inst Univ Mil, Ctr Invest Acad Mil CINAMIL, Lisbon, Portugal.
   Antunes, Wilson, Unidade Mil Lab Def Biol \& Quim, Lisbon, Portugal.
   Cardoso, Susana, Univ Lisbon, Dept Phys, Inst Super Tecn, Lisbon, Portugal.},
DOI = {10.1016/j.snr.2025.100430},
EarlyAccessDate = {JAN 2026},
Article-Number = {100430},
Keywords = {STORM; SEM; Biosensors; Magnetic nanoparticles; Microparticles;
   Bacterial spores; Bacillus cereus; Bacillus anthracis},
Keywords-Plus = {LOCALIZATION; SURFACE; EXOSPORIUM; PROTEINS; SPORES; FAMILY; LAYER; BCLA},
Author-Email = {dobroesfonseca@tecnico.ulisboa.pt},
