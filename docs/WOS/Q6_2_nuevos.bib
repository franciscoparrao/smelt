@article{ WOS:001659190700003,
Author = {Zhang, Jiannan and Cho, Younho},
Title = {Automated Assessment of the Adhesion of Underwater Coatings Using Lamb
   Waves and Ensemble Learning},
Journal = {JOURNAL OF THE KOREAN SOCIETY FOR NONDESTRUCTIVE TESTING},
Year = {2025},
Volume = {45},
Number = {6},
Pages = {457-466},
Month = {DEC},
Abstract = {In this study, we propose a physics-guided machine learning framework to
   assess the adhesion of underwater coatings using S3-mode Lamb waves.
   Line-scan measurements were conducted on coated steel specimens
   containing bonded and debonded regions. In the proposed method, two
   amplitude-based descriptors are extracted to characterize
   adhesion-related response differences, namely the average amplitude
   change (AAC) and maximum amplitude (MaxAmp). To mitigate sensitivity to
   acquisition variability in underwater environments, all amplitude
   descriptors are converted into specimen-wise normalized quantities using
   a bonded reference on the same specimen. We evaluated the classification
   performance of the proposed framework using a stratified 5-fold
   cross-validation (k = 5) and a leave-one-out validation across three
   specimens, and we report the results in terms of the mean +/- standard
   deviation of accuracy and the area under the receiver operating
   characteristic curve (AUC). We also conducted a finite element
   simulation to support physics-based interpretation of mode selectivity
   and qualitative response trends; however, all reported classification
   results were obtained exclusively from experimental measurements. The
   results of the stratified 5-fold validation showed that ensemble-based
   classifiers demonstrated more stable discrimination performance than
   linear baselines in the overlapped feature space, especially
   gradient-boosting models. Thus, the proposed framework provides a
   reproducible and statistically interpretable approach for automated
   assessments of the adhesion of coatings on metal surfaces in an
   underwater environment under controlled laboratory conditions.},
Type = {Article},
Affiliation = {Cho, Y (Corresponding Author), Pusan Natl Univ, Sch Mech Engn, Busan, South Korea.
   Zhang, Jiannan, Pusan Univ, Sch Mech Engn, Busan, South Korea.
   Cho, Younho, Pusan Natl Univ, Sch Mech Engn, Busan, South Korea.},
DOI = {10.7779/JKSNT.2025.45.6.457},
Keywords = {Underwater Nondestructive Testing; Coating Adhesion; Acoustic Features;
   Machine Learning Classifiers; Automated AI System},
Author-Email = {mechcyh@pusan.ac.kr},
Number-of-Cited-References = {20},
Times-Cited = {0},
Unique-ID = {WOS:001659190700003},
}

@article{ WOS:001659036900021,
Author = {Liu, Yongdong and Liu, Yufang and Li, Aiwu},
Title = {Ferroptosis Induction in Glioma by Calceolarioside A via Modulation of
   the PI3K/Akt/ Nrf2 Pathway},
Journal = {JOVE-JOURNAL OF VISUALIZED EXPERIMENTS},
Year = {2025},
Number = {226},
Month = {DEC},
Abstract = {This protocol demonstrates the experimental workflow used to investigate
   the effects of Calceolarioside A (CaA) on ferroptosis induction and
   modulation of the Phosphatidylinositol 3-kinase (PI3K)/Protein Kinase B
   (Akt)/Nuclear factor erythroid 2-related factor 2 (Nrf2) pathway in
   glioma models. The procedures include a series of cell-based assays in
   U251 and U87 human glioma lines to evaluate cell viability,
   proliferation, and chemosensitivity following CaA treatment.
   Ferroptosis-associated changes are assessed by measuring reactive oxygen
   species (ROS), glutathione (GSH), malondialdehyde (MDA), and labile iron
   levels, along with expression of ferroptosisrelated proteins such as
   glutathione peroxidase 4 (GPX4), cysteine/glutamate antiporter subunit
   (xCT), and ferritin via western blot. To assess pathway involvement, the
   protocol details qRT-PCR, western blot, and immunoprecipitation-based
   assays for Nrf2 expression and ubiquitination. Nrf2 overexpression
   experiments are included to confirm its role in ferroptosis regulation.
   The protocol further demonstrates the use of a mouse xenograft model,
   where U87 cells are implanted subcutaneously, followed by
   intraperitoneal CaA administration to evaluate in vivo tumor growth and
   toxicity. Histological analysis of major organs is performed to assess
   systemic safety. Additionally, molecular docking is used to predict
   direct binding between CaA and the PI3K p110 alpha subunit (PIK3CA).
   Together, these procedures provide a reproducible framework to examine
   ferroptosis mechanisms and the therapeutic efficacy of natural compounds
   in glioma research.},
Type = {Article},
Affiliation = {Li, AW (Corresponding Author), Shandong Univ, Dept Pediat Surg, Qilu Hosp, Jinan, Peoples R China.
   Liu, Yongdong; Li, Aiwu, Shandong Univ, Dept Pediat Surg, Qilu Hosp, Jinan, Peoples R China.
