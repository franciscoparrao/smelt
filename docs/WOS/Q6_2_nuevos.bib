@article{ WOS:001698032600001,
Author = {Patel, Rajneesh and Rajput, Porika Abidsingh and Prabhu, G. and Sharma,
   Pawan and Karthik, G. M.},
Title = {Deep learning-driven automated microstructural quantification in
   tungsten heavy alloys using U-net segmentation and image processing},
Journal = {INTERNATIONAL JOURNAL OF REFRACTORY METALS \& HARD MATERIALS},
Year = {2026},
Volume = {138},
Month = {AUG},
Abstract = {Tungsten heavy alloys (WHAs) are widely used in defence, aerospace, and
   radiation shielding applications due to their exceptional density and
   mechanical properties. The properties of WHAs are inherently governed by
   their microstructure. Therefore, accurate quantification of
   microstructural parameters is essential for reliable material evaluation
   and design. This study develops a comprehensive framework that
   integrates digital image processing techniques, such as U-Net
   segmentation, and image augmentation, with deep learning algorithms for
   the automated extraction and quantification of key microstructural
   parameters in WHAs. The developed algorithm automatically processes
   scanning electron microscope images and outputs the corresponding image
   features and WHA microstructural parameters such as contiguity, dihedral
   angle, W grain size and distribution, W volume fraction, and W
   precipitate size and distribution in statistical form, without requiring
   any manual intervention. The proposed approach significantly improves
   microstructural analysis accuracy, efficiency, and reproducibility,
   offering a scalable solution.},
Type = {Article},
Affiliation = {Karthik, GM (Corresponding Author), Indian Inst Technol BHU, Dept Mech Engn, Varanasi 221005, India.
