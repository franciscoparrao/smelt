   Sanchez-Carro, Miguel Angel; Bruschi, Viola, Univ Cantabria, Escuela Ingn Caminos Canales \& Puertos, Int Inst Prehist Res Cantabria IIIPC, Santander 39005, Spain.},
DOI = {10.3390/drones10010073},
Article-Number = {73},
Keywords = {confined-space UAV; LiDAR SLAM; videogrammetry; structural monitoring;
   digital twin; rock wall stability in Paleolithic caves; cultural
   heritage conservation; Cave of Altamira; deep learning crack detection},
Author-Email = {j.angas@unizar.es},
