Unique-ID = {WOS:001707177200001},
}

@article{ WOS:001703656000001,
Author = {Xu, Yang and Chen, Xin and Liu, Gong-Wen and Huang, Wei-Nan and Li,
   Xi-Yu and Lian, Song-You and Yan, Xin-Liang and Wang, Jiang-Yong},
Title = {Automated extraction of physical parameters from depth profiling data
   using the MRI model},
Journal = {CHEMOMETRICS AND INTELLIGENT LABORATORY SYSTEMS},
Year = {2026},
Volume = {272},
Month = {MAY 15},
Abstract = {Adjusting the parameters of the quantitative model to fit the data is
   the first step in the quantitative analysis of depth profiles. However,
   this process is very tedious and time-consuming. This study proposes a
   method for automatically fitting depth profiling data and extracting the
   corresponding physical parameters. And the method demonstrates strong
   applicability to high-resolution depth profiling data. The proposed
   method employs a multi-strategy collaborative particle swarm
   optimization (MSC-PSO) algorithm, which enhances parameter estimation
   accuracy and robustness against noise. Notably, the model maintains
   stability and physical relevance even when the Gaussian noise (standard
   deviation = 0.1) or sputtering-induced roughness is present in the data.
   Experimental tests on multilayer thin films-including a 4 \& times;
   Si(15 nm)/Al (15 nm)/Si(100) Auger Electron Spectroscopy (AES) depth
   profile and a 4 \& times; Ni/Cu time-of-flight secondary-ion mass
   spectrometry (TOF-SIMS) depth profile-confirm the model's reliability in
   accurately determining physical parameters. Finally, a global
   sensitivity analysis based on the Morris method was conducted for all
   model parameters, indicating that the model exhibits strong robustness
   to parameter perturbations and a stable internal structure. These
   results underscore the framework's potential for advancing quantitative
   depth profiling in complex and noisy experimental environments. In
   addition, all codes used in this work have been open-sourced and are
   publicly available on GitHub, ensuring reproducibility and facilitating
   further research.},
Type = {Article},
Affiliation = {Lian, SY (Corresponding Author), Shantou Univ, Dept Phys, Shantou 515063, Guangdong, Peoples R China.
