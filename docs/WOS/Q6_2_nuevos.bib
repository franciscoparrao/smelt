DOI = {10.1016/j.ipm.2026.104616},
EarlyAccessDate = {JAN 2026},
Article-Number = {104616},
Keywords = {Fact-checking; Large language models; Cross-language unfairness; Prompt
   engineering; Model fine-tuning},
Keywords-Plus = {PSYCHOLOGY},
