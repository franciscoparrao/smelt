   Leplaideur, Stephanie, Ctr Kerpape, Ploemeur, France.},
DOI = {10.1016/j.patrec.2025.11.017},
EarlyAccessDate = {NOV 2025},
Keywords = {Sub-acute stroke; Chronic stroke; MRI; Lesion segmentation; Deep
