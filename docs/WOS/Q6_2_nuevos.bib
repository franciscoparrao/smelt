DOI = {10.1186/s41181-026-00426-2},
Article-Number = {16},
Keywords = {Automated radiosynthesis; Pentixafor; DOTATATE; FAPI-46; Gallium-68},
Keywords-Plus = {DOTA-PEPTIDES; GE-68/GA-68 GENERATOR; CLINICAL-APPLICATIONS; GA-68;
   RADIOPHARMACEUTICALS; BIODISTRIBUTION; GA-68-DOTATATE; VALIDATION;
   LU-177},
