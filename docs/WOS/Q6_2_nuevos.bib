   Wang, Siqin, Univ Queensland, Sch Environm, Brisbane, Australia.
   Huang, Xiao, Emory Univ, Dept Environm Sci, Atlanta, GA USA.
   Biljecki, Filip, Natl Univ Singapore, Dept Architecture, Singapore, Singapore.
   Biljecki, Filip, Natl Univ Singapore, Dept Real Estate, Singapore, Singapore.
   Rowe, Francisco, Univ Liverpool, Geog Data Sci Lab, Liverpool, England.
   Muccione, Veruska, Univ Zurich, Dept Geog, Zurich, Switzerland.
   Muccione, Veruska, Swiss Fed Res Inst WSL, Birmensdorf, Switzerland.},
DOI = {10.1016/j.jag.2026.105239},
