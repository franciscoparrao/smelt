@article{ WOS:001710276700001,
Author = {Martinez, Sanja and Hudec, Bojan and Martinez, Izabela and Soic, Ivana},
Title = {Unsupervised clustering of EIS spectra for distinguishing degradation
   states of polymer coatings},
Journal = {PROGRESS IN ORGANIC COATINGS},
Year = {2026},
Volume = {215},
Month = {JUN},
Abstract = {Electrochemical impedance spectra (EIS) from 38 weathered industrial
   coating systems were analyzed using a fully data-driven, unsupervised
   machine learning (ML) pipeline to reveal coating degradation patterns,
   water uptake sensitivity, and to cluster the coatings by barrier
   integrity. The study systematically compared 30 pipeline configurations
   comprising normalization, dimensional reduction, and cluster number to
   identify the feature space for pattern discovery and clustering. The
   best-performing configuration, per-block normalization of log |Z| and
   phase combined with three-component principal component analysis (PCA),
   with t-distributed stochastic neighbor embedding (t-SNE) used for
   visualization, produced a linear trajectory terminating in the region of
   the carbon steel (CS) spectra. Most importantly, the unsupervised
   analysis revealed a medium-frequency (similar to 1 Hz) phase maximum
   embedded in the non-curated, real-life, coated-sample EIS dataset,
   aligned with the time constant of the independently measured carbon
   steel spectra, confirming that the observed trajectory represents a
   genuine degradation pattern driven by loss of coating integrity and the
   emergence of the substrate response. Across the coatings tested,
   hierarchical clustering primarily resolves two degradation-related log
   |Z| groups, corresponding to coating-dominated (10.746 +/- 0.712) and
   substrate-influenced (7.453 +/- 1.024) responses. Finer, but less
   robust, clustering further distinguishes among carbon steel (4.457 +/-
   0.012) and, based on analogy with literature classifications, to
   ``poor{''} (5.705 +/- 0.487), ``intermediate{''} (7.548 +/- 0.616), and
   ``good{''} (10.381 +/- 0.760) barrier performance states. The applied
   framework demonstrates that it can act as a sophisticated, fully
   unsupervised clustering tool by which coating degradation state can be
   identified automatically and in an unbiased manner.},
Type = {Article},
Affiliation = {Martinez, S (Corresponding Author), Univ Zagreb, Fac Chem Engn \& Technol, Marulicev trg 19, Zagreb 10000, Croatia.
   Martinez, Sanja; Hudec, Bojan; Soic, Ivana, Univ Zagreb, Fac Chem Engn \& Technol, Marulicev trg 19, Zagreb 10000, Croatia.
   Martinez, Izabela, Univ Zagreb, Fac Mech Engn \& Naval Architecture, Ivana Lucica 5, Zagreb 10002, Croatia.},
DOI = {10.1016/j.porgcoat.2026.110082},
Article-Number = {110082},
Author-Email = {sanja.martinez@fkit.unizg.hr},
Number-of-Cited-References = {25},
Times-Cited = {0},
Unique-ID = {WOS:001710276700001},
}

@article{ WOS:001707011100001,
Author = {Nettey-Oppong, Ezekiel Edward and Mensah, Emmanuel Essel and Badasu, Per
   Peter and Akromah, Stefania and Asare, Eric and Nartey, Martinson Addo},
Title = {Structured Entropy Analysis (SEA): A computational framework for latent
   biomolecular insights beyond conventional descriptors in molecular
   dynamics simulations},
Journal = {JOURNAL OF MOLECULAR GRAPHICS \& MODELLING},
Year = {2026},
Volume = {145},
Month = {JUN},
Abstract = {Molecular dynamics (MD) simulations are widely employed to study
   biomolecular systems, yet conventional feature-based analyses such as
   the radius of gyration (Rg), root-mean-square deviation (RMSD), and
   root-meansquare fluctuation (RMSF) often provide only descriptive trends
   without fully capturing the underlying complexity of structural
   dynamics. In this study, we introduce Structured Entropy Analysis (SEA),
   a novel entropy-based framework designed to quantify the latent
   informational content of MD trajectories. Using ubiquitin (1UBQ), the
   amyloid beta (A beta 42) peptide fragment (1IYT), and T4 lysozyme (3LZM)
   as representative systems, we demonstrate the application of SEA through
   a multi-step pipeline encompassing feature normalization, binary
   encoding, entropy evaluation, and statistical testing. Entropy metrics,
   including Shannon entropy, min-entropy, bit balance, runs test,
   chi-square analysis, and serial correlation, were applied to
   characterize structured randomness within the feature-derived sequences.
   Our results reveal that while conventional analyses highlight global
   stability and flexibility trends, SEA uncovers non-random entropic
   patterns, correlations, and constrained fluctuations that are strongly
   indicative of underlying physical and functional characteristics.
   Quantitatively, SEA consistently detected pronounced deviations from
   randomness across all systems, with observed runs substantially lower
   than expected (Rg: 6519 vs 10677 in 1UBQ; RMSD: 4517 vs 10677 across
   systems; RMSF: 2823 vs 6687 in 1IYT and 11921 vs 28192 in 3LZM), large
   chi-square statistics (7.98 \& times; 104 - 3.37 \& times; 105), and
   persistent non-zero serial correlations (0.051 - 0.264), confirming
   structured temporal ordering in MD-derived descriptors that is not
   captured by standard feature plots alone. To facilitate reproducibility
   and broader application, we developed a dedicated Structured Entropy
   Analysis (SEA) software pipeline. This tool automates the entire
   workflow while simultaneously exporting data and figures. The software
   enables streamlined integration of SEA into molecular dynamics
   workflows, offering both accessibility and consistency across analyses.
   By bridging information theory and biomolecular modeling, this framework
   offers a lightweight, datadriven, and generalizable approach for
   enriching the interpretation of MD simulations, providing new
   opportunities for biomolecular classification, system comparison, and
   the development of entropy-informed descriptors.},
Type = {Article},
Affiliation = {Nettey-Oppong, EE (Corresponding Author), Yonsei Univ, Dept Biomed Engn, Wonju, South Korea.
   Nettey-Oppong, Ezekiel Edward, Yonsei Univ, Dept Biomed Engn, Wonju, South Korea.
   Mensah, Emmanuel Essel, Egypt Japan Univ Sci \& Technol, Dept Mat Sci \& Engn, Alexandria, Egypt.
   Badasu, Per Peter, Kwame Nkrumah Univ Sci \& Technol, Dept Comp Sci, Kumasi, Ghana.
   Akromah, Stefania, Univ Bristol, Bristol Composites Inst, Sch Civil Aerosp \& Design Engn, Bristol, England.
   Asare, Eric; Nartey, Martinson Addo, Kwame Nkrumah Univ Sci \& Technol, Dept Mat Engn, Kumasi, Ghana.},
DOI = {10.1016/j.jmgm.2026.109338},
Article-Number = {109338},
Keywords = {Structured entropy analysis (SEA); Molecular dynamics simulation;
   Information theory; Biomolecular modeling; Entropy metrics},
Author-Email = {ezekieledward@yonsei.ac.kr},
Number-of-Cited-References = {34},
Times-Cited = {0},
Unique-ID = {WOS:001707011100001},
}

@article{ WOS:001708782600001,
Author = {Zheng, Yan-Na and Ma, Li-Bin and Huang, Yuan},
Title = {A comprehensive workflow for resolving Gryllidea phylogeny using
   universal single-copy orthologs},
Journal = {MOLECULAR PHYLOGENETICS AND EVOLUTION},
Year = {2026},
Volume = {219},
Month = {JUN},
Abstract = {The Gryllidea exhibits remarkable species diversity, yet the
   higher-level phylogenetic relationships have long been contentious. This
   study aims to develop and validate a reproducible phylogenetic analysis
   workflow using Universal Single-Copy Ortholog genes (USCOs) as a
   scalable genomic backbone to resolve key phylogenetic disputes within
   Gryllidea. We performed low-coverage whole-genome sequencing (10X) on
   representative species representing all families of extant crickets.
   Using an optimized workflow, we performed genome assembly, USCO
   extraction, and the construction of multiple data matrices with rigorous
   control of compositional heterogeneity and quality filtering. We
   reconstructed phylogenies using a multi-model comparison framework. The
   robustness of key topologies was further assessed through statistical
   tests including AU, WKH and WSH, and FcLM test. Topology tests
   consistently and robustly support the division of the Gryllidea into two
   major clades: Gryllotalpoidea (containing Gryllotalpidae and
   Myrmecophilidae) and Grylloidea, with internal relationships were
   resolved as: (Mogoplistidae, (Trigonidiidae, (Phalangopsidae,
   (Oecanthidae, Gryllidae)))). Our analyses further reveal the
   non-monophyly of Nemobiinae within Trigonidiidae and clarify the
   phylogenetic positions of multiple subfamilies. Based on the most
   reliable topology, divergence time estimates indicate major
   diversification events began in the Early Jurassic and accelerated
   during the Cretaceous, coinciding with the rise of angiosperms. Overall,
   this study provides robust molecular evidence and an evolutionary
   timescale for resolving long-standing phylogenetic controversies in
   Gryllidea. Our results emphasize that robust phylogenetic inference
   requires integrating and comparing multiple complementary datasets and
   analytical approaches. Within this context, the proposed ``matrix
   optimization-model comparison-topology validation{''} framework offers a
   reproducible and extensible foundation for phylogenetic studies.},
Type = {Article},
Affiliation = {Ma, LB; Huang, Y (Corresponding Author), Shaanxi Normal Univ, Coll Life Sci, Xian 710119, Peoples R China.
   Ma, LB (Corresponding Author), Shaanxi Normal Univ, Zool \& Bot Museum, Xian 710119, Peoples R China.
