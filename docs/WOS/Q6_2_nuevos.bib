DOI = {10.1007/s00066-025-02489-7},
EarlyAccessDate = {DEC 2025},
Article-Number = {PMID 8603469},
Keywords = {Effective field size; Effective penetration depth; Electric field
   measurement; Microwave hyperthermia systems; Repeatability evaluation},
Keywords-Plus = {FLEXIBLE MICROSTRIP APPLICATORS; REGIONAL HYPERTHERMIA; CFMA-434
   APPLICATORS; RADIATION-THERAPY; EUROPEAN-SOCIETY; RANDOMIZED-TRIAL;
