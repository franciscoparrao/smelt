   Tiznado-Vazquez, H., Univ Nacl Autonoma Mexico, Ctr Nanociencias \& Nanotecnol, Carr Tijuana Ensenada Km 107, Ensenada 22860, Mexico.},
DOI = {10.3390/pr14030399},
Article-Number = {399},
