@article{ WOS:001688039100001,
Author = {Sonoda, Hiroaki and Kuriyama, Hikari and Tomiyoshi, Kouki and Koutaki,
   Gou},
Title = {Semi-Automatic Artificial Lips Device for Brass Instruments with
   Real-Time Pitch Feedback Control},
Journal = {SENSORS},
Year = {2026},
Volume = {26},
Number = {3},
Month = {FEB 3},
Abstract = {We propose a semi-automatic artificial lips control device that allows a
   human performer to produce sound on a brass instrument without the need
   to vibrate their own lips. The device integrates position control that
   presses artificial lips toward the mouthpiece and aperture control via
   wire traction, together with a pre-calibrated motor table and acoustic
   feedback for pitch stabilization. In evaluations using a euphonium, we
   verified timbre, pitch range, and pitch stabilization, including
   harmonic modes. The results showed that the harmonic structure of tones
   produced by a human using the device can be comparable to those produced
   by a human player in the conventional manner. Pitch-range and
   pitch-stabilization tests confirmed that the system can generate
   practical musical intervals and achieve reliable harmonic mode changes.
   Furthermore, real-time acoustic feedback improved pitch stability during
   performance. These findings demonstrate that, rather than fully
   automating human performance, the proposed system provides a compact and
   reproducible framework for controllable brass sound generation and pitch
   stabilization using only three actuators.},
Type = {Article},
Affiliation = {Koutaki, G (Corresponding Author), Kumamoto Univ, Dept Comp Sci \& Elect Engn, Kumamoto 8608555, Japan.
   Sonoda, Hiroaki; Kuriyama, Hikari; Tomiyoshi, Kouki, Kumamoto Univ, Grad Sch Sci \& Technol, Kumamoto 8608555, Japan.
