@article{ WOS:001696447800001,
Author = {Ye, Zheyuan and Yi, Jia and Luo, Jiu and Xian, Jun and Heng, Yi},
Title = {Optimal design of a bio-inspired feed spacer for high-permeance reverse
   osmosis desalination via an improved Bayesian approach},
Journal = {DESALINATION},
Year = {2026},
Volume = {626},
Month = {MAY 15},
Abstract = {High-permeance reverse osmosis (RO) desalination increases water
   production efficiency but intensifies concentration polarization and
   fouling, limiting stable long-term operation. This study builds upon our
   previously proposed bio-inspired V-shaped feed-spacer geometry, inspired
   by the `V' formation of migrating birds, and performs a multi-objective
   optimization of feed-spacer/channel geometries in RO channels, targeting
   minimization of pressure drop and maximization of mass-transfer
   coefficient. We couple high-fidelity computational fluid dynamics with a
   Gaussian-process-based multi-objective Bayesian optimization (CFD-MOBO)
   framework and adopt a sampling strategy to improve convergence and
   numerical stability. The computed Pareto front yields three
   representative designs-low pressure-drop, high mass-transfer, and a
   compromise solution. Relative to a commercial spacer, the low
   pressure-drop design reduces pressure drop by about 61\%, the high
   mass-transfer design increases the mass-transfer coefficient by about
   161\%, and the compromise design increases mass transfer by about 103\%
   at a roughly 47\% higher pressure drop. Optimized geometries enhance
   near-wall mixing and thin the concentration boundary layer, suggesting
   potential improvements in water production efficiency. The integrated
   CFD-MOBO workflow provides an automated, reproducible route for
   designing energy-efficient, high-permeance RO modules.},
Type = {Article},
Affiliation = {Yi, J (Corresponding Author), Sun Yat Sen Univ, Sch Syst Sci \& Engn, Guangzhou 510006, Peoples R China.
   Ye, Zheyuan; Heng, Yi, Sun Yat Sen Univ, Sch Comp Sci \& Engn, Guangzhou 510006, Peoples R China.
   Yi, Jia; Heng, Yi, Sun Yat Sen Univ, Sch Syst Sci \& Engn, Guangzhou 510006, Peoples R China.
   Luo, Jiu, Soochow Univ, Sch Future Sci \& Engn, Suzhou 215222, Peoples R China.
   Xian, Jun, Sun Yat Sen Univ, Sch Math, Guangzhou 510006, Peoples R China.},
DOI = {10.1016/j.desal.2026.119956},
EarlyAccessDate = {FEB 2026},
Article-Number = {119956},
Keywords = {reverse osmosis; water desalination; multi-objective optimization;
   enhancement of mass transfer; concentration polarization},
Keywords-Plus = {CONCENTRATION POLARIZATION; MEMBRANES; SELECTION},
Author-Email = {yijia6@mail2.sysu.edu.cn},
Number-of-Cited-References = {56},
