   So, Byung-Dal, Kangwon Natl Univ, Dept Geophys, Chuncheon Si 24341, South Korea.
   Hong, Jong Kuk, Korea Polar Res Inst, Div Glacier \& Earth Sci, Incheon 21990, South Korea.},
DOI = {10.1016/j.aiig.2026.100191},
Article-Number = {100191},
Keywords = {Ice-rafted debris; Core sediment; Deep learning; Lithology; YOLOv11},
