DOI = {10.1109/ACCESS.2026.3656919},
Keywords = {Forecasting; Accuracy; Calibration; Artificial intelligence; Predictive
   models; Trajectory; Robustness; Uncertainty; Marine vehicles;
   Reliability; Maritime navigation forecasting AIS-metocean interactions;
   multi-output deep learning; Transformer deep neural networks; Gaussian
   negative log-likelihood (NLL); uncertainty Huber loss; Grey Wolf
