@article{ WOS:001676245200001,
Author = {Li, Yibo and Li, Juan and Guo, Simin and Sun, Mei},
Title = {Provincial policy simulation for steel decarbonization in China: a
   modular CGE-3E3S coupling framework},
Journal = {ENVIRONMENTAL MODELLING \& SOFTWARE},
Year = {2026},
Volume = {198},
Month = {MAR},
Abstract = {This article has developed a modular framework that integrates a
   provincial-level computable general equilibrium (CGE) model with a 3E3S
   (Energy, Economy, Environment, Sustainability, Strategy, Socio-Economic
   Stability) assessment to quantify the policy-driven low-carbon
   transition in Chinas iron and steel industry. The architecture of the
   framework separates data, scenarios, and solvers, incorporates
   mechanisms such as learning-by-doing, carbon tax, and tax-rebate
   instruments, and supports reproducible scenario management. When applied
   to policy shocks, the framework generates a composite, multi-dimensional
   transition impact at the provincial level. The results reveal
   significant spatial heterogeneity, with Hebei exhibiting the largest
   aggregate impact across all dimensions. In a carbon-tax and
   global-slowdown scenario, the transition impact reaches 0.852. This
   study presents detailed descriptions of the model components, I/O
   schemas, and workflow to facilitate reuse and adaptation for other
   regions or sectors. This approach demonstrates how integrated
   economy-wide modeling and indicator analytics can guide region-specific
   decarbonization strategies.},
Type = {Article},
Affiliation = {Sun, M (Corresponding Author), Jiangsu Univ, Inst Carbon Neutral Dev, Zhenjiang 212013, Jiangsu, Peoples R China.
   Li, Yibo; Li, Juan; Guo, Simin; Sun, Mei, Jiangsu Univ, Inst Carbon Neutral Dev, Zhenjiang 212013, Jiangsu, Peoples R China.},
DOI = {10.1016/j.envsoft.2026.106868},
EarlyAccessDate = {JAN 2026},
Article-Number = {106868},
Keywords = {Computable general equilibrium (CGE); Model coupling; Iron and steel;
   Provincial heterogeneity; Low-carbon transition},
Keywords-Plus = {INDUSTRY; IMPACT},
Author-Email = {sunm@ujs.edu.cn},
Number-of-Cited-References = {56},
