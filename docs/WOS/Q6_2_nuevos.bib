@article{ WOS:001669715300001,
Author = {Xinlan, Kuang and Ruiyi, Li and Miao, Wang and Zaijun, Li},
Title = {Orchestrating a Bi0.1MnFeCoNi high-entropy alloy electrocatalyst via
   functional graphene quantum dot for ultrasensitive microRNA-200a-3p
   biosensor},
Journal = {JOURNAL OF ALLOYS AND COMPOUNDS},
Year = {2026},
Volume = {1052},
Month = {JAN 31},
Abstract = {MicroRNA-200a-3p, a critical regulator in endometrial carcinogenesis,
   presents significant detection challenges due to the limitations in
   sensitivity and selectivity of analytical methods. To address this
   issue, a novel electrochemical sensing platform has been developed based
   on Bi0.1MnFeCoNi high-entropy alloy nanoparticles synthesized through a
   facile approach with glutamate- and histidine-cofunctionalized graphene
   quantum dots (EH-GQDs) serve as structural and electronic modulators.
   The synthesis process involves coordination of metal ions with EH-GQDs
   followed by two-stage thermal annealing under nitrogen atmosphere. The
   resulting material exhibits a well-defined crystallinity with coexistent
   face-centered cubic (FCC) and body-centered cubic (B2) phases uniformly
   dispersed on three-dimensional conductive graphene framework. This
   unique architecture endows the material with exceptional electron/ion
   transport properties, strong affinity for polar electrolytes, and
   markedly enhanced electrocatalytic activity-surpassing that of
   conventional gold nanoparticles by more than fivefold. The developed
   sensor demonstrates ultrasensitive response to microRNA-200a-3p,
   exhibiting a wide linear detection range from 1 x 10-9 M to 5 x 10-1 5 M
   with detection limit of 1.7 x 10-1 5 M (S/N = 3). Furthermore, the
   sensor exhibits high selectivity, reproducibility, and reliable
   performance in human serum samples, providing a robust tool for early
   cancer diagnostics while paving the way for multifunctional highentropy
   alloy-based nanomaterials in biosensing applications.},
Type = {Article},
Affiliation = {Ruiyi, L (Corresponding Author), Jiangnan Univ, Sch Life Sci \& Hlth Engn, Sch Chem \& Mat Engn, Wuxi 214122, Peoples R China.
   Xinlan, Kuang; Ruiyi, Li; Zaijun, Li, Jiangnan Univ, Sch Life Sci \& Hlth Engn, Sch Chem \& Mat Engn, Wuxi 214122, Peoples R China.
   Miao, Wang, Wuxi Hosp Tradit Chinese Med, Reprod Med Dept, Wuxi 214000, Peoples R China.},
DOI = {10.1016/j.jallcom.2026.186140},
EarlyAccessDate = {JAN 2026},
Article-Number = {186140},
Keywords = {MicroRNA-200a-3p; High-entropy alloy nanoparticles; Electrochemical
   biosensor; Graphene quantum dots; Ultrasensitive detection},
Author-Email = {ruiyili@jiangnan.edu.cn},
Number-of-Cited-References = {43},
Times-Cited = {1},
Unique-ID = {WOS:001669715300001},
}

@article{ WOS:001669927900001,
Author = {Pi, Yifei and Wang, Haiyang and Zhang, Yawei and Peng, Zhao and Zeng,
   Xianhu and Guo, Yuexin and Liu, Chunbo},
Title = {A novel automated framework for multi-engine Monte Carlo model
   commissioning in proton therapy},
Journal = {PHYSICS \& IMAGING IN RADIATION ONCOLOGY},
Year = {2026},
Volume = {37},
Month = {JAN},
Abstract = {Background and purpose: Accurate commissioning of proton beam models
   remained a major challenge in pencil beam scanning (PBS) proton therapy.
   This study presented an automated Monte Carlo (MC) modeling framework
   that was designed to automate and standardize beam model commissioning.
   Materials and methods: This framework supported commissioning workflows
   by optimizing beam parameters based on user-supplied data including
   integrated depth dose curves, lateral profiles, measured absolute dose
   per energy, etc. It incorporated optimization algorithms including
   particle swarm optimization and Nelder-Mead, and followed a modular
   pipeline including data preparation, phase space parameter fitting,
   energy spectrum tuning, and dose calibration. Validation was performed
   using 20 clinical cases and over 100 measurement 2D planes in
   water-based patient-specific quality assurance (QA) plans. The framework
   was commissioned with TOol for PArticle Simulation (TOPAS) and Monte
   Carlo square (MCsquare). Results: After tuning, both MC engines
   reproduced maximum range errors of 0.3 \% (TOPAS) and 0.6 \% (MCsquare)
   at depths corresponding to 80 \% and 20 \% of the maximum dose, and
   similarly small deviations in the full width at half maximum and peak
   dose. For QA plans, the median gamma pass rate was 100.0 \% for TOPAS
   under the 3 \%/3 mm criterion (range: 95.3 \%-100.0 \%, mean: 99.9 \%),
   with MCsquare achieved comparable results with minimum pass rates above
   94.3 \%. Conclusions: This open-source, Python-based framework provided
   a robust and extensible solution for automated multi-engine MC beam
   commissioning in proton therapy. It enhanced reproducibility and
   efficiency, facilitating both clinical and research applications in
   medical physics.},
Type = {Article},
Affiliation = {Liu, CB (Corresponding Author), Zhengzhou Univ, Dept Radiat Oncol, Affiliated Hosp 1, Zhengzhou 450001, Henan, Peoples R China.
   Pi, Yifei; Wang, Haiyang; Guo, Yuexin; Liu, Chunbo, Zhengzhou Univ, Dept Radiat Oncol, Affiliated Hosp 1, Zhengzhou 450001, Henan, Peoples R China.
   Zhang, Yawei, Univ Florida, Hlth Proton Therapy Inst, Jacksonville, FL USA.
   Zhang, Yawei, Univ Florida, Dept Radiat Oncol, Gainesville, FL USA.
   Peng, Zhao, Cent South Univ, Xiangya Hosp, Dept Radiat Oncol, Changsha, Hunan, Peoples R China.
   Zeng, Xianhu, Sichuan Univ, West China Hosp, Dept Radiotherapy Phys \& Technol, Chengdu, Sichuan, Peoples R China.},
DOI = {10.1016/j.phro.2026.100903},
EarlyAccessDate = {JAN 2026},
Article-Number = {100903},
Keywords = {Monte Carlo; Proton therapy; Model commissioning; Automated framework},
Keywords-Plus = {DOSE CALCULATION; SIMULATION},
Author-Email = {ancewer@mail.ustc.edu.cn},
Number-of-Cited-References = {26},
