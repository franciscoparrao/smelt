DOI = {10.1016/j.ijrmms.2026.106489},
Article-Number = {106489},
Keywords = {Shale; Segmentation; X-ray computed tomography; Deep learning;
   Volumetric strain},
Keywords-Plus = {SPONTANEOUS IMBIBITION; GAS SHALES; WATER; PERMEABILITY; ANISOTROPY;
