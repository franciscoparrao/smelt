Volume = {347},
Month = {MAR 6},
Abstract = {Epoxy resins are widely used in energy storage devices, electronic
   encapsulation, and structural adhesives owing to their excellent
   adhesion and electrical insulation properties. However, conventional
   epoxy systems still face challenges related to mechanical robustness and
   long-term service reliability. Molecular dynamics (MD) simulations
   provide an effective means to investigate structure-property
   relationships in crosslinked epoxy networks, yet their application is
   often hindered by the complexity of curing reactions and the limited
   efficiency and reproducibility of traditional atomistic modeling
   workflows. In this work, a lightweight graphical user interface (GUI)
   was developed to facilitate automatic and user-friendly generation of
   reaction-mapping templates for reactive molecular dynamics simulations
   based on the AutoMapper-LAMMPS fix bond/react framework. Using this
   platform, a ternary epoxy system comprising epoxy resin, curing agent,
   and a mesogenic comonomer was established. By systematically varying the
   crosslinking degree and comonomer content, the effects of network
   topology and local molecular ordering on mechanical behavior were
   elucidated. The results provide molecularlevel insight into strategies
   for enhancing epoxy toughness without significantly compromising
   stiffness and demonstrate a generalizable and efficient methodology for
   simulating complex crosslinked polymer systems.},
Type = {Article},
Affiliation = {Zhu, CH; Zhao, JH (Corresponding Author), Jiangnan Univ, Jiangsu Key Lab Adv Food Mfg Equipment \& Technol, Wuxi 214122, Peoples R China.
   Zhu, CH; Zhao, JH (Corresponding Author), Jiangnan Univ, Inst Strength \& Multiscale Mech Mech Struct, Sch Mech Engn, Wuxi 214122, Peoples R China.
