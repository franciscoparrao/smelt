   Chen, Chi-Chun, Natl Chin Yi Univ Technol, Dept Elect Engn, Taichung, Taiwan.
   Kuo, Shu-Chun, Chi Mei Med Ctr, Dept Ophthalmol, Tainan, Taiwan.
   Kuo, Shu-Chun, Chung Hwa Univ Med Technol, Dept Optometry, Tainan, Taiwan.},
DOI = {10.1016/j.bspc.2025.109271},
EarlyAccessDate = {DEC 2025},
Article-Number = {109271},
Keywords = {Optical coherence tomography; U-Net; Retinal layers; Automatic;
