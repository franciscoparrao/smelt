   Bourdel, N.; Bartoli, A., Univ Clermont Auvergne, Inst Pascal, EnCoV, CNRS,UMR 6602, F-63000 Clermont Ferrand, France.
   Bourdel, N.; Bartoli, A., Clermont Ferrand Univ Hosp, Dept Clin Res \& Innovat, F-63000 Clermont Ferrand, France.},
DOI = {10.1007/s11701-026-03255-2},
