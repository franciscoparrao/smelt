@article{ WOS:001695340900001,
Author = {Beribisky, Alexander V. and Sarne, Victoria and Huber, Anna and
   Hengstschlager, Markus and Laccone, Franco and Steinkellner, Hannes},
Title = {Cell-Penetrating Peptides and Supercharged Proteins: A Comprehensive
   Protocol from Isolation to Cellular Uptake},
Journal = {MOLECULAR PHARMACEUTICS},
Year = {2026},
Volume = {23},
Number = {3},
Pages = {1845-1857},
Month = {MAR 2},
Abstract = {Cell-penetrating peptides (CPPs) and supercharged proteins (SPs) enable
   efficient intracellular delivery of macromolecules, with expanding
   applications in basic research and in therapeutic development. Despite
   their potential, reproducible workflows for isolation, biochemical
   characterization, and quantitative uptake analysis remain limited. Here,
   we present a comprehensive and replicable protocol for the isolation,
   characterization, and cellular uptake analysis of CPP-fusion proteins
   (CPP-FPs) and SPs using methyl-CpG-binding protein 2 (MeCP2) constructs
   as a proof-of-principle model. This workflow combines native protein
   purification with dynamic light scattering (DLS)-based buffer
   optimization. Cellular uptake is then assessed and quantified under
   live-cell conditions using high-content imaging and imaging flow
   cytometry, with additional assays to probe endocytic trafficking routes,
   identify CPP-like motifs in SPs, and validate transducing CPP-FP/SP
   functionality. The protein isolation and DLS-guided buffer screen yield
   samples with long-term stability. Live-cell fluorescence microscopy and
   imaging flow cytometry enable discrimination between membrane-bound and
   internalized signal, providing higher accuracy compared to plate-based
   readouts. MeCP2 sequence probing has revealed the presence of a CPP-like
   motif that is critical to its internalization. Finally, validation
   assays clearly demonstrated CPP-FP/SP activity. This protocol integrates
   advances in protein biochemistry, structural analysis, and live-cell
   imaging into a reproducible pipeline adaptable to a wide range of CPP-
   and SP-based protein constructs and provides a practical framework for
   downstream mechanistic and therapeutic interventions.},
Type = {Article},
Affiliation = {Steinkellner, H (Corresponding Author), Med Univ Vienna, Inst Med Genet, Ctr Pathobiochem \& Genet, A-1090 Vienna, Austria.
   Beribisky, Alexander V.; Sarne, Victoria; Huber, Anna; Hengstschlager, Markus; Laccone, Franco; Steinkellner, Hannes, Med Univ Vienna, Inst Med Genet, Ctr Pathobiochem \& Genet, A-1090 Vienna, Austria.
   Sarne, Victoria, Univ Vienna, Vienna Doctoral Sch Pharmaceut Nutr \& Sport Sci Ph, A-1090 Vienna, Austria.},
DOI = {10.1021/acs.molpharmaceut.5c01560},
EarlyAccessDate = {FEB 2026},
Keywords = {cell-penetrating peptides; supercharged proteins; intracellular protein
   delivery; protein characterization; live-cell imaging; imaging flow
   cytometry},
Keywords-Plus = {ARGININE-RICH PEPTIDES; TAT FUSION PROTEINS; INTRACELLULAR DELIVERY;
   MAMMALIAN-CELLS; FUNCTIONAL PROTEINS; NUCLEAR DELIVERY; IN-VITRO;
   TRANSDUCTION; MECP2; PHENOTYPES},
Author-Email = {hannes.steinkellner@meduniwien.ac.at},
