   Waknis, Pushkar P., Dr DY Patil Vidyapeeth, Dr DY Patil Dent Coll \& Hosp, Saishree Hosp Pune, Pune 411018, India.},
DOI = {10.1007/s12663-026-02939-4},
EarlyAccessDate = {FEB 2026},
Keywords = {Segmental mandibulectomy; Oral squamous cell carcinoma; Temporalis
   muscle release; Coronoid process; Mandibular resection technique;
   Intraoperative bleeding control},
