   Blessy, V. A., ICAR Indian Inst Soil \& Water Conservat, Res Ctr, Fernhill PO, Udagamandalam 643004, Tamil Nadu, India.},
DOI = {10.1007/s12355-025-01714-y},
EarlyAccessDate = {JAN 2026},
Keywords = {Sugarcane pests; Image-based pest diagnosis; Transfer learning; Deep
   learning; Ensemble convolutional neural networks; Smart agriculture},
