   Li, Yanpeng; Xiao, Wen, Dali Univ, Prov Innovat Team Biodivers Conservat \& Util Three, Dali 671003, Peoples R China.
   Li, Yanpeng; Xiao, Wen, Collaborat Innovat Ctr Biodivers \& Conservat Three, Dali 671003, Peoples R China.},
DOI = {10.3390/toxics14010105},
