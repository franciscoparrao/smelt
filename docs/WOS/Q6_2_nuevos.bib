@article{ WOS:001620293900011,
Author = {Bitra, Venkat Suprabath and Verma, Shweta and Rao, B. Tirumala},
Title = {HiT-IP Raman: An innovative high-throughput spectra acquisition system
   with interactive PCA combined machine learning for instant
   classification of various analytes and mixtures},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2025},
Volume = {219},
Month = {DEC},
Abstract = {The development of machine learning (ML) driven Raman spectroscopy is
   hindered by the need for extensive datasets and complex data analysis.
   Also, conventional ML analysis demands expert programming and is not
   flexible for dynamic data visualizations. We introduce an innovative
   system design combining low-cost hardware and open-source software to
   enable rapid, human-free high-throughput (HiT) collection of labeled
   spectra, sample raster scanning and auto-focusing for enhanced signal
   reproducibility. We implemented a novel interactive-principal components
   analysis (IP) facilitating dynamic 2D/3D visualizations in selectable
   spectral ranges, pre-implemented data normalizations and ML models
   enabling rapid, data pre-processing for outlier removal and instant
   classification of test spectra of different samples without programming.
   We generated labeled spectral datasets of pharmaceuticals and
   dye-pesticide binary mixtures and analyzed them with data augmentation
   and various ML models. Classification accuracy >99 \% was achieved with
   standard-normal-variate (SNV) normalization and optimum number of PCs,
   which depends on the dataset. Use of limited spectral range with high
   variability in spectral features can effectively identify the
   composition of binary mixtures. Support vector machine (SVM) exhibited
   superior performance for SNV normalized dye-pesticides and
   pharmaceutical mixture datasets. With statistical analysis of prediction
   accuracies, correlation among different ML-classifiers is presented. The
   system's broader applications are shown by applying PCA to identify
   composition of solvent mixtures, quantifying the dilution of a solvent
   with use of an internal standard and analyte quantification. This
   cost-effective system offers an easily adaptable method for seamless
   integration with all computer-operated spectrometers, without requiring
   any change in the operating software. It also enables automatic rapid
   collection of spectra (similar to 250 per hour) from different samples
   and provides real-time data analysis, thereby expanding the
   possibilities for ML-based spectroscopic applications in various
   domains.},
Type = {Article},
Affiliation = {Bitra, VS; Rao, BT (Corresponding Author), Raja Ramanna Ctr Adv Technol, CO2 Laser Technol Sect, Room 203,Block-B, Indore 452013, Madhya Pradesh, India.
   Bitra, Venkat Suprabath, Int Inst Informat Technol Bangalore, Bengaluru 560100, Karnataka, India.
   Bitra, Venkat Suprabath; Verma, Shweta; Rao, B. Tirumala, Raja Ramanna Ctr Adv Technol, CO2 Laser Technol Sect, Room 203,Block-B, Indore 452013, Madhya Pradesh, India.},
DOI = {10.1016/j.microc.2025.116054},
EarlyAccessDate = {NOV 2025},
Article-Number = {116054},
Keywords = {Automated Raman spectroscopy; Interactive principal components analysis;
   Machine learning; Raster scan mode; Pharmaceuticals mixtures; Dyes and
   pesticides},
Keywords-Plus = {SERS; IBUPROFEN},
