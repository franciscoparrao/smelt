@article{ WOS:001711276600001,
Author = {Shapira, Avishag and Shigol, Simon and Shabtai, Asaf},
Title = {FRAME: Comprehensive risk assessment framework for adversarial machine
   learning threats},
Journal = {APPLIED SOFT COMPUTING},
Year = {2026},
Volume = {194},
Month = {MAY},
Abstract = {The widespread adoption of machine learning (ML) systems has intensified
   concerns about their security and the rise of adversarial machine
   learning (AML) techniques that exploit inherent model vulnerabilities.
   This high lights the need for comprehensive risk-assessment methods
   specifically tailored to ML-based systems. Traditional cybersecurity
   frameworks are not equipped to address the distinctive challenges of
   adversarial threats, while existing AML evaluations focus mainly on
   technical robustness and often overlook real-world factors such as
   deployment environments, system dependencies, and attack feasibility.
   Previous efforts toward comprehensive AML risk assessment have remained
   domain-specific, limiting their applicability across diverse systems. To
   ad dress these gaps, we present FRAME, a comprehensive framework for
   assessing AML risks in ML systems. FRAME quantifies adversarial risk
   across three dimensions: the target system's deployment environment, the
   character istics of AML techniques, and empirical findings from prior
   research. It integrates a structured dataset of AML attacks, enabling
   context-aware and reproducible evaluation, and includes a semi-automated
   scoring process with LLM-assisted customization for system-specific
   assessments. Validated across six real-world use cases, including
   e-commerce feedback scoring and email malware detection, FRAME achieved
   an average overall accuracy of 9/10, with expert assessments indicating
   high attack-specific accuracy (9.2/10) and relevance (8.9/10), demon
   strating strong alignment with expert analyses. By enabling
   organizations to identify and prioritize adversarial risks, FRAME
   provides a practical and scalable foundation for secure and informed
   deployment of ML systems.},
Type = {Article},
Affiliation = {Shapira, A (Corresponding Author), Ben Gurion Univ Negev, Software \& Informat Syst Engn, IL-8410501 Beer Sheva, Israel.
   Shapira, Avishag; Shigol, Simon; Shabtai, Asaf, Ben Gurion Univ Negev, Software \& Informat Syst Engn, IL-8410501 Beer Sheva, Israel.},
DOI = {10.1016/j.asoc.2026.114930},
Article-Number = {114930},
Keywords = {Machine learning; Risk assessment; Adversarial learning},
Author-Email = {shavish@post.bgu.ac.il
   shigols@post.bgu.ac.il
   shabtaia@bgu.ac.il},
Number-of-Cited-References = {101},
Times-Cited = {0},
Unique-ID = {WOS:001711276600001},
}

@article{ WOS:001709302300001,
Author = {Navia-Pesantes, Oscar and Sanoja-Lopez, Kelvin A. and Luque, Rafael},
Title = {Analytical techniques for identifying bacterial communities in the
   plastisphere: Advances and challenges},
Journal = {JOURNAL OF HAZARDOUS MATERIALS ADVANCES},
Year = {2026},
Volume = {22},
Month = {MAY},
Abstract = {Plastic waste accumulation across ecosystems has led to the emergence of
   the plastisphere, a unique microbial habitat formed on plastic surfaces.
   This environment harbors diverse bacterial communities, including
   pathogens and plastic-degrading microbes, that form resilient biofilms
   and contribute to health-related concerns such as the dissemination of
   antibiotic resistance. Understanding the composition and behavior of
   these microbial communities is essential for evaluating the ecological
   and public health risks of microplastics (MPs). This review provides a
   critical synthesis of analytical techniques for identifying bacteria in
   the plastisphere, ranging from traditional culture-based methods to
   advanced molecular and imaging approaches. Beyond summarizing available
   tools, we introduce a benchmarking framework that compares methods in
   terms of resolution, biomass requirements, throughput, cost, and quality
   assurance/quality control (QA/QC) considerations. We also propose a
   workflow linking taxonomic, functional, and spatial analyses to
   hazard-relevant endpoints, including pathogen detection, antibiotic
   resistance surveillance, and viability assessment. By integrating these
   perspectives, the review offers practical guidance for researchers and
   regulators to improve the accuracy, reproducibility, and hazard-focused
   interpretation of plastisphere studies.},
Type = {Article},
Affiliation = {Sanoja-Lopez, KA; Luque, R (Corresponding Author), Univ ECOTEC, Km 13-5 Samborondon, EC-092302 Samborondon, Ecuador.
   Navia-Pesantes, Oscar; Sanoja-Lopez, Kelvin A.; Luque, Rafael, Univ ECOTEC, Km 13-5 Samborondon, EC-092302 Samborondon, Ecuador.},
DOI = {10.1016/j.hazadv.2026.101094},
Article-Number = {101094},
Keywords = {Plastisphere; Microplastics; Biofilms; Bacterial identification; 16S
   rRNA sequencing; Metagenomics; Environmental microbiology;
   Polymer-bacteria interactions},
Keywords-Plus = {MICROPLASTICS},
Author-Email = {ksanoja@ecotec.edu.ec
   rluque@ecotec.edu.ec},
Number-of-Cited-References = {78},
