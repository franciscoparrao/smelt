@article{ WOS:001658273200001,
Author = {Velasco-Teran, Iris G. and Ancheyta-Palacios, Monserrat and
   Diaz-Jimenez, Lourdes and Castelan, Mario and Carreon, Yojana J. P. and
   Gonzalez-Gutierrez, Jorge},
Title = {Humidity-regulated drying kinetics and morphological control of protein
   droplets: Quantitative imaging and classification approaches},
Journal = {COLLOIDS AND SURFACES A-PHYSICOCHEMICAL AND ENGINEERING ASPECTS},
Year = {2026},
Volume = {734},
Month = {APR 5},
Abstract = {Controlling humidity during droplet drying is essential for engineering
   reproducible deposition patterns and understanding evaporation-driven
   film formation in biopolymeric systems. In this study, we examine the
   influence of relative humidity (RH) on the drying kinetics and
   morphology of bovine serum albumin (BSA) droplets (1 wt\% with 0.1-1
   wt\% NaCl) under four controlled RH conditions (20 \%, 40 \%, 60 \%, 90
   \%). Optical microscopy revealed that low RH (20-40 \%) favored
   well-defined coffee-ring deposits with peripheral crystallization for
   folded proteins, whereas unfolded samples formed irregular aggregates
   with cruciform crystals. At intermediate RH (60 \%), folded droplets
   produced compact dendritic networks, while unfolded samples exhibited
   mixed amorphous-crystalline morphologies. Under high RH (90 \%), both
   conformations yielded homogeneous films: folded droplets developed
   continuous dendritic layers, whereas unfolded samples formed amorphous
   domains with reduced edge crystallization. Drying mode analysis
   indicated RH-dependent transitions (Modes I, III, IV) with Mode II
   observed exclusively at high RH (90 \%), reflecting a shift from
   capillary-driven to diffusion-controlled regimes. Quantitative
   evaluation of radial intensity profiles, I(r), confirmed
   humidity-regulated solute redistribution and deposit uniformity, with
   maximal divergence between protein states at low RH (MAE = 0.292 +/-
   0.002; Pearson r = -0.19) and convergence at high RH (MAE = 0.091; r =
   0.87). Image-based classification using a convolutional neural network
   achieved 92-100 \% accuracy across RH levels, with peak separability
   (99-100 \%) under both low and high humidity conditions. These findings
   establish RH as a critical parameter in drying kinetics, governing
   solute transport and final deposit morphology, and demonstrate the value
   of automated image analysis as a robust tool for quantifying
   humidity-dependent morphological outcomes in dried protein droplets.
   This integration of humidity control and image-based metrics provides a
   reproducible framework for optimizing drying processes in proteinaceous
   and biopolymeric systems.},
Type = {Article},
