   Peng, Syu-Jyun, Taipei Med Univ, Taipei Med Univ Hosp, Clin Big Data Res Ctr, Taipei, Taiwan.},
DOI = {10.1016/j.acra.2025.08.020},
EarlyAccessDate = {NOV 2025},
Keywords = {Renal Tumor; Computed Tomography; Deep Learning; Segmentation},
