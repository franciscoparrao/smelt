@article{ WOS:001708871100001,
Author = {Liu, Yeqin and Wang, Wenlei and Cheng, Qiuming and Fu, Yong},
Title = {A nonlinear quantitative analysis framework for investigating detrital
   zircon U-Pb geochronological data},
Journal = {JOURNAL OF GEOCHEMICAL EXPLORATION},
Year = {2026},
Volume = {285},
Month = {JUN},
Abstract = {Detrital zircon geochronology is pivotal for provenance analysis, yet
   interpreting large, heterogeneous datasets remains challenging. This
   study integrates Local Singularity Analysis (LSA) from fractal theory
   with conventional Multidimensional Scaling (MDS) to establish a
   nonlinear quantitative framework, enhancing interpretative precision.
   Applied to the central Guizhou bauxite province, this methodology
   analyzes U-Pb age populations from aluminum-bearing sequences across its
   northern and southern margins. The LSA techniques is employed to
   identifiy localized age spectrum anomalies and quantify the
   contributions from the Neoproterozoic basement, Paleozoic igneous
   provinces, and reworked Paleoproterozoic sources. The MDS visualization
   serves to further clarify the layered material transfer process, showing
   the significant contribution of the northern central Guizhou to the
   southern central Guizhou (North-to-South System). Meanwhile, it reveals
   the secondary input from the Duyun Uplift to the southern central
   Guizhou (West-to-East Corridor). This study advances understanding of
   the tectono-magmatic controls on bauxite-bearing strata in the central
   Guizhou, while underscoring the value of hybrid analytical approaches in
   addressing multi-scale geological problems. This interdisciplinary
   approach bridges statistical rigor with geological process
   interpretation, providing a reproducible workflow for resolving complex
   provenance in multi-stage orogens with cryptic source-to-sink
   relationships.},
Type = {Article},
Affiliation = {Wang, WL (Corresponding Author), Chinese Acad Geol Sci, State Key Lab Deep Earth \& Mineral Explorat, Beijing 100094, Peoples R China.
   Liu, Yeqin; Wang, Wenlei, Chinese Acad Geol Sci, State Key Lab Deep Earth \& Mineral Explorat, Beijing 100094, Peoples R China.
