   Kwon, Hyeonuk; Seo, Dong-Hwa, Korea Adv Inst Sci \& Technol, Grad Sch Green Growth \& Sustainabil, Daejeon 34141, South Korea.
   Park, Jooha; Hah, Hoe Jin, LG Energy Solut, Seoul 07796, South Korea.},
DOI = {10.1039/d5dd00580a},
EarlyAccessDate = {MAR 2026},
Keywords-Plus = {IMPEDANCE},
Author-Email = {dseo@kaist.ac.kr},
Number-of-Cited-References = {32},
