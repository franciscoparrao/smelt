   Qayyum, Junaid, Jinhua Univ Vocat Technol, Waikato Int Coll, Jinhua, Zhejiang, Peoples R China.},
DOI = {10.1007/s12672-025-04185-5},
Article-Number = {2213},
Keywords = {Artificial intelligence; Deep learning; Tumour-infiltrating lymphocytes;
   Breast cancer prognosis; Digital pathology; Medical imaging;
   Convolutional neural networks; Statistical validation},
