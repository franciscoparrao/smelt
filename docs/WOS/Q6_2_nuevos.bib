@article{ WOS:001660991800001,
Author = {Silva, Bruno Marques and Trindade, Fernanda De Jesus and Canesin, Lucas
   Eduardo Costa and Souza, Giordano and Aleixo, Alexandre and Nunes,
   Gisele and Moreira-Oliveira, Renato Renison},
Title = {Pipeasm: a tool for automated large chromosome-scale genome assembly and
   evaluation},
Journal = {BIOINFORMATICS ADVANCES},
Year = {2026},
Volume = {6},
Number = {1},
Abstract = {Motivation Although high-quality chromosome-scale genome assemblies are
   feasible, assembling large ones remains complex and resource-intensive.
   This demands reproducible and automated workflows that not only
   implement current best practices efficiently but also allow for
   improvement alongside future updates to those standards.Results We
   present Pipeasm, a Snakemake-based genome assembly pipeline
   containerized with Singularity. Pipeasm can use HiFi, ONT, and Hi-C
   data, automating read trimming, nuclear and mitogenome assembly,
   scaffolding, decontamination, and quality evaluation. Applied to four
   vertebrate species with distinct genomic characteristics, starting from
   a single command line and configuration file, it produced assemblies
   with scaffold L50 proportional to the expected chromosome and genome
   length, and up to 99.6\% BUSCO completeness. Its output also includes
   detailed reports for each step, genome statistics, Hi-C maps, and files
   ready for curation.Availability and implementation Pipeasm is available
   at https://github.com/itvgenomics/pipeasm, implemented in
   Python/Snakemake with Singularity, and runs on Unix-based systems.},
Type = {Article},
Affiliation = {Moreira-Oliveira, RR (Corresponding Author), Inst Tecnol Vale, Environm Genom, Rua Boaventura Silva 955, BR-66055090 Belem, PA, Brazil.
   Silva, Bruno Marques; Trindade, Fernanda De Jesus; Canesin, Lucas Eduardo Costa; Souza, Giordano; Aleixo, Alexandre; Nunes, Gisele; Moreira-Oliveira, Renato Renison, Inst Tecnol Vale, Environm Genom, Rua Boaventura Silva 955, BR-66055090 Belem, PA, Brazil.},
DOI = {10.1093/bioadv/vbaf326},
Article-Number = {vbaf326},
Author-Email = {renato.oliveira8@itv.org},
Number-of-Cited-References = {48},
Times-Cited = {0},
Unique-ID = {WOS:001660991800001},
