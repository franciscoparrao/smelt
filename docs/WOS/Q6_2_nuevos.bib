Unique-ID = {WOS:001714476500001},
}

@article{ WOS:001713225000001,
Author = {de Trizio, Federica and Sciddurlo, Giancarlo and Piro, Giuseppe and
   Boggia, Gennaro},
Title = {TETREES: Trade-off Evaluation Through Refined Exact Epsilon-Constraint
   Solver},
Journal = {SOFTWARE IMPACTS},
Year = {2026},
Volume = {28},
Month = {JUL},
Abstract = {TETREES is an open-source Python framework for multi-objective
   optimization that implements the exact epsilon-constraint method to
   compute complete and deterministic Pareto-optimal sets. Its modular
   architecture decouples objective definition, constraint modeling, and
   solver configuration, enabling reproducible workflows and seamless
   integration of new metrics or optimization modules. Built on Gurobi,
   TETREES supports fine-grained control over branching, heuristics, and
   search strategies, facilitating scalable exploration of complex decision
   spaces. A service-to-resource assignment case study illustrates how the
   framework exposes performance-value trade-offs and enables systematic
   evaluation of alternative solver configurations, providing a robust
   software environment for optimization research and decision-support tool
   development.},
Type = {Article},
Affiliation = {de Trizio, F (Corresponding Author), Politecn Bari, Dept Elect \& Informat Engn, Bari, Italy.
   de Trizio, Federica, Politecn Bari, Dept Elect \& Informat Engn, Bari, Italy.
   Consorzio Nazl Interuniv Telecomunicaz, CNIT, Parma, Italy.},
DOI = {10.1016/j.simpa.2026.100828},
Article-Number = {100828},
Keywords = {Multi-objective optimization; Solver configuration; Decision support
   systems; Network orchestration; Sustainability aware resource allocation},
Author-Email = {f.detrizio@phd.poliba.it},
Number-of-Cited-References = {5},
Times-Cited = {0},
Unique-ID = {WOS:001713225000001},
}

@article{ WOS:001712455700001,
Author = {Sharifaldin, Hesam Nejati and Pour, Farnoush Nayebi},
Title = {Middleware-enforced Timed Causal Consistency for Apache Cassandra: An
   energy-performance-consistency evaluation against static consistency
   levels using YCSB},
Journal = {SOFTWARE IMPACTS},
Year = {2026},
Volume = {28},
Month = {JUL},
Abstract = {We present a reproducible and open-source middleware-enforced
   consistency model - Strict Timed Causal Consistency (STCC) - designed as
   an external consistency layer for Cassandra, systematically compared
   against built-in static levels (ALL, QUORUM, ONE) in terms of energy,
   performance, and consistency trade-offs under YCSB workloads.
   Cassandra's default consistency levels (e.g., ALL, QUORUM, ONE) are
   statically configured and unable to adapt to runtime variations in
   workload intensity or network conditions. To address this limitation, we
   introduce a fully functional middleware implementing Strict Timed Causal
   Consistency (STCC) - a hybrid model that combines client-and server-side
   causal guarantees with a configurable freshness bound Delta. STCC is
   non-intrusive and integrates seamlessly with unmodified Cassandra
   deployments, enabling adaptive consistency at runtime. The middleware
   integrates seamlessly with unmodified Cassandra instances, offering
   tunable freshness bounds (Delta) and causal guarantees across
   geo-replicated nodes without modifying the core database engine. The
   package includes automation tools for YCSB-based workload execution, CPU
   frequency control via cpupower, and energy monitoring using SNMP-enabled
   PDUs and dstat. This framework targets cloud engineers, distributed
   systems researchers, and middleware designers seeking to analyze or
   optimize consistency-latency-energy trade-offs under realistic
   deployment conditions. Our experiments validated on a 24-node Cassandra
   cluster distributed across three Cassandra's data centers, the system is
   publicly released with full documentation to support reproducible and
   extensible experimentation.},
Type = {Article},
Affiliation = {Sharifaldin, HN (Corresponding Author), Islamic Azad Univ, Dept Comp Engn, Mashhad Branch, Mashhad, Iran.
   Sharifaldin, Hesam Nejati; Pour, Farnoush Nayebi, Islamic Azad Univ, Dept Comp Engn, Mashhad Branch, Mashhad, Iran.},
DOI = {10.1016/j.simpa.2026.100817},
Article-Number = {100817},
Keywords = {Apache Cassandra; Consistency; Replication; Frequency-scaling;
   Energy-performance; Tools and monitoring},
Author-Email = {hesam.nejati@gmail.com
   Farnoush.nayebi@mshdiau.ac.ir},
Number-of-Cited-References = {34},
Times-Cited = {0},
Unique-ID = {WOS:001712455700001},
}

@article{ WOS:001699849500001,
Author = {Wang, Yongkun and Xia, Ding and Shi, Yang and Song, Wenlong and Fu,
   Qiang and Yang, XiaoXu and Zhang, Ruoshi and Huang, Zhizhuo},
Title = {Thermal analysis and structural optimization for SiC power modules based
   on thermal-fluid coupling},
Journal = {INTERNATIONAL JOURNAL OF THERMAL SCIENCES},
Year = {2026},
Volume = {225},
Month = {JUL},
Abstract = {To mitigate the thermal bottleneck caused by the ultra-high power
   density of silicon carbide (SiC) power modules, this study presents a
   junction-temperature-oriented optimization framework for liquid-cooled
   pin-fin cold plates. A three-dimensional conjugate thermo-fluid coupling
   model is employed to realistically capture package-level heat spreading
   and flow maldistribution effects; combined with an orthogonal
   experimental design, it enables efficient multi-parameter collaborative
   optimization; by directly linking cold-plate design to
   junction-temperature metrics, it bridges the gap from component-level
   cooling to system-level thermal reliability. Five geometric factors
   (pin-fin height, diameter, pitch, bottom clearance, and baseplate
   thickness) are screened using an L16(45) orthogonal array to quantify
   their contributions to the maximum junction temperature and identify an
   engineering-feasible optimum, reducing the maximum junction temperature
   from 94.85 degrees C to 82.91 degrees C (12.6\%). On this optimized
   baseline, morphology comparisons show that the teardrop fin offers the
   best thermal-hydraulic balance, achieving a maximum junction temperature
   of 80.95 degrees C, a thermal resistance of 0.0698 K/W, an average
   Nusselt number of 678, and the highest overall performance index (2.72),
   outperforming circular, diamond, and square fins. Notably, low friction
   does not guarantee good cooling: the diamond pin fin has the lowest
   friction factor (0.0126) but still performs poorly (Nu = 420; Rth =
   0.0986 K/W). Flow-rate effects further reveal a clear trade-off:
   increasing the flow rate from 6 to 16 L/min lowers the junction
   temperature from 85.0 degrees C to 81.55 degrees C while increasing the
   pressure drop from 3.0 to 17.0 kPa, indicating diminishing thermal
   benefits at higher flow rates. The proposed workflow provides a
   reproducible and computationally efficient route for thermal design of
   SiC module cold plates by linking geometric screening, morphology
   selection, and operating-condition guidance within a realistic conjugate
   framework.},
Type = {Article},
Affiliation = {Shi, Y (Corresponding Author), Xidian Univ, Sch Mechanoelect Engn, Xian 710071, Peoples R China.
   Wang, Yongkun; Xia, Ding; Shi, Yang; Song, Wenlong; Fu, Qiang, Xidian Univ, State Key Lab Electromech Integrated Mfg High Perf, Xian 710071, Peoples R China.
   Wang, Yongkun; Xia, Ding; Shi, Yang; Song, Wenlong; Fu, Qiang; Yang, XiaoXu; Zhang, Ruoshi; Huang, Zhizhuo, Xidian Univ, Sch Mechanoelect Engn, Xian 710071, Peoples R China.},
DOI = {10.1016/j.ijthermalsci.2026.110779},
Article-Number = {110779},
Keywords = {Silicon carbide power module; Liquid-cooled cold plate; Pin-fin;
   Junction temperature; Thermal-fluid coupling; Orthogonal experimental
   design},
Keywords-Plus = {HEAT-TRANSFER; FLOW RESISTANCE; PIN-FINS; CHANNEL; PERFORMANCE; CROSS},
Author-Email = {shiyang@xidian.edu.cn},
Number-of-Cited-References = {46},
Times-Cited = {0},
Unique-ID = {WOS:001699849500001},
}

@article{ WOS:001720727300001,
Author = {Yang, Yi-Wen and Chang, Che-Yuan and Lin, Yu-Zu and Cheng, Hou-Hsuan and
   Huang, Sheng-Chieh and Lin, Hung-Hsin and Lin, Chun-Chi and Lan,
   Yuan-Tzu and Wang, Huann-Sheng and Chang, Shih-Ching and Yang,
   Shung-Haur and Chen, Wei-Shone and Jiang, Jeng-Kai},
Title = {Automated Flow and local LLM-Driven clinical Context Engineering:
   Precision colorectal cancer recurrence registry},
Journal = {INTERNATIONAL JOURNAL OF MEDICAL INFORMATICS},
Year = {2026},
Volume = {213},
Month = {JUN 15},
Abstract = {Objective This study develops and validates a deployable,
   privacy-preserving automated tool to address the labor-intensive nature
   of colorectal cancer (CRC) recurrence registration. Our tool utilizes a
   reproducible, two-stage `Clinical Context Engineering' workflow to mimic
   expert clinical reasoning and overcome the limitations of handling
   longitudinal clinical data ambiguity. Methods We retrospectively studied
   3053 CRC patients (2010-2018). A local Large Language Model (LLM)
   (Qwen3:14B) analyzed similar to 19,900 pathology and similar to 43,900
   imaging reports using iterative, patch-based analysis ({''}raw LLM{''}).
   Clinical validation rules were applied to generate ``rule-based LLM{''}
   output, enhancing explainability and trustworthiness. Both automated
   methods and the manual Taiwan Cancer Registry (TCR) database were
   compared against a 20\% manual reference standard (N = 602). Full
   prompts and validation code are provided for complete reproducibility.
   Results Under a strict 60-day temporal tolerance, the Rule-Based LLM
   achieved 90.7\% accuracy, comparable to standard TCR processes (92.0\%),
   and 77.2\% sensitivity. The application of clinical validation rules
   significantly improved specificity from 87.7\% (Raw LLM) to 93.9\%
   (Rule-Based LLM). In time window analysis, the Rule-Based LLM identified
   87.1\% of recurrences within 60 days of the reference date. Conclusion
   Our locally deployed, privacy-preserving, and explainable Clinical
   Context Engineering framework offers a viable, non-inferior alternative
   to standard TCR processes, reducing workload while maintaining data
   quality and fostering trust in AI-assisted cancer registry automation.},
Type = {Article},
Affiliation = {Yang, YW (Corresponding Author), Taipei Vet Gen Hosp, Dept Surg, Div Colon \& Rectal Surg, 201 Sec 2,Shipai Rd, Taipei City 11217, Taiwan.
   Yang, Yi-Wen; Chang, Che-Yuan; Lin, Yu-Zu; Cheng, Hou-Hsuan; Huang, Sheng-Chieh; Lin, Hung-Hsin; Lin, Chun-Chi; Lan, Yuan-Tzu; Wang, Huann-Sheng; Chang, Shih-Ching; Jiang, Jeng-Kai, Taipei Vet Gen Hosp, Dept Surg, Div Colon \& Rectal Surg, 201 Sec 2,Shipai Rd, Taipei City 11217, Taiwan.
   Huang, Sheng-Chieh; Lin, Hung-Hsin; Lin, Chun-Chi; Lan, Yuan-Tzu; Wang, Huann-Sheng; Chang, Shih-Ching; Yang, Shung-Haur; Chen, Wei-Shone; Jiang, Jeng-Kai, Natl Yang Ming Chiao Tung Univ, Fac Med, Sch Med, 155 Sec 2,Linong St, Taipei City 11221, Taiwan.
   Yang, Shung-Haur; Chen, Wei-Shone, En Chu Kong Hosp, 399 Fusing St, New Taipei City 23702, Taiwan.},
DOI = {10.1016/j.ijmedinf.2026.106383},
Article-Number = {106383},
Keywords = {Colorectal Cancer; Cancer Recurrence; Large Language Model (LLM);
   Context Engineering; Natural Language Processing; Cancer Registry;
   Artificial Intelligence},
Author-Email = {ywyang2@vghtpe.gov.tw},
Number-of-Cited-References = {36},
