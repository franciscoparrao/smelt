   Yerushkin, Anastasia; Berkowitz, Shani; Golderman, Valery; Goldberg, Zehavit; Shavit-Stein, Efrat; Dori, Amir, Chaim Sheba Med Ctr, Dept Neurol, Ramat Gan, Israel.
   Goldberg, Zehavit; Dori, Amir, Chaim Sheba Med Ctr, Neuromuscular Unit, Ramat Gan, Israel.
   Eshed-Eisenbach, Yael, Weizmann Inst Sci, Dept Mol Cell Biol, Rehovot, Israel.
   Shavit-Stein, Efrat, Chaim Sheba Med Ctr, TELEM Rubin Excellence Biomed Res Program, Ramat Gan, Israel.},
DOI = {10.21769/BioProtoc.5528},
Article-Number = {e5528},
Keywords = {Intraepidermal nerve fiber density (IENFD); PGP9.5; Small fiber;
   Neuropathy; Skin; Mouse model; Immunofluorescence; IENFD quantification},
Keywords-Plus = {NEUROPATHY},
Author-Email = {amirdori@tauex.tau.ac.il
   shavitef@tauex.tau.ac.il},
