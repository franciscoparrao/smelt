@article{ WOS:001628347300001,
Author = {Peters, Josh P. and Assaf, Charbel D. and Cote, Mathis and Hovener,
   Jan-Bernd and Pravdivtsev, Andrey N.},
Title = {Field Cycling from 10 nT to 9.4 T: A Flexible Gear Rod Design for
   Nuclear Spin Relaxation and Hyperpolarization Studies},
Journal = {ACS MEASUREMENT SCIENCE AU},
Year = {2026},
Volume = {6},
Number = {1},
Pages = {81-95},
Month = {FEB 18},
Abstract = {We present a flexible gear rod-based magnetic field cycling (MFC) system
   for high-resolution NMR spectrometers. The system enables the transfer
   of the sample from the NMR B 0 field of 9.4 T to similar to nT and all
   fields in between within 1 s. A flexible gear rod was essential for
   reducing the total height to approximately the height required for
   filling the NMR with liquid helium. Due to its reduced height, it can be
   installed in average-size NMR laboratories (the height of the NMR with
   MFC is only 3.32 m). Only off-the-shelf components and 3D-printed parts
   were used for the system assembly, lowering the costs for replication.
   An automated shimming procedure for ultralow fields is presented to
   achieve homogeneous fields of a few nanotesla. The system utility is
   exemplified by measuring T 1 relaxation dispersion of the most common
   liquid state hyperpolarization tracer-{[}1-13C]pyruvate-and magnetic
   field dependences of signal amplification by reversible exchange,
   enabling alignment transfer to heteronuclei (SABRE-SHEATH)
   hyperpolarization of {[}15N]pyridine. Using the system, we uncovered the
   exact relaxation dispersion of pyruvate for a standard preclinical dDNP
   sample composition and provided quantitative estimates for the retained
   polarization after sample transfer. We modified the observation protocol
   of SABRE-SHEATH polarization, which, with the high reproducibility of
   the MFC, provided us with a method to measure the chemical exchange
   rates of hyperpolarized compounds.},
Type = {Article},
Affiliation = {Peters, JP; Pravdivtsev, AN (Corresponding Author), Univ Kiel, Univ Hosp Schleswig Holstein, Mol Imaging North Competence Ctr MOINCC, Dept Radiol \& Neuroradiol,Sect Biomed SBMI, D-24118 Kiel, Germany.
   Peters, Josh P.; Assaf, Charbel D.; Cote, Mathis; Hovener, Jan-Bernd; Pravdivtsev, Andrey N., Univ Kiel, Univ Hosp Schleswig Holstein, Mol Imaging North Competence Ctr MOINCC, Dept Radiol \& Neuroradiol,Sect Biomed SBMI, D-24118 Kiel, Germany.
   Cote, Mathis, Polytech Montreal, Dept Engn Phys, 2500 Chem Polytech, Montreal, PQ H3T 1J4, Canada.},
DOI = {10.1021/acsmeasuresciau.5c00131},
EarlyAccessDate = {DEC 2025},
Keywords = {magnetic field cycling; hyperpolarization; relaxation; SABRE; chemical
   exchange; nuclear magnetic resonance},
Keywords-Plus = {HETEROCYCLIC CARBENE COMPLEXES; LEVEL ANTI-CROSSINGS; N-15
   HYPERPOLARIZATION; PARA-HYDROGEN; POLARIZATION TRANSFER; NMR; SABRE;
   PARAHYDROGEN; DEPENDENCE; DYNAMICS},
