Keywords-Plus = {REAL-TIME PCR; GENE-EXPRESSION; MINIMUM INFORMATION; HOUSEKEEPING GENES;
   RNA QUALITY; RT-QPCR; GUIDELINES; NORMALIZATION; IDENTIFICATION; TOOL},
Author-Email = {natascha-ingrid.drude@bih-charite.de
