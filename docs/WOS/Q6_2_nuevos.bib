   Jimenez-Castillo, Gabino; Munoz-Rodriguez, Francisco Jose; Rus-Casas, Catalina, Univ Jaen, Ctr Adv Studies Energy \& Environm CEACTEMA, Jaen 23071, Spain.},
DOI = {10.3390/app152312656},
