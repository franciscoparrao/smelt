   Bielecka, Marzena, AGH Univ Krakow, Fac Geol Geophys \& Environm Protect, Dept Algorithm, PL-30059 Krakow, Poland.},
DOI = {10.3390/diagnostics16030396},
Article-Number = {396},
Keywords = {artificial intelligence; medicine; radiology; large language models;
   physical examination; out of distribution generalization; legal
   liability; clinical augmentation},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; IMPLEMENTATION; ONCOLOGY; HEALTH; WATSON; BIAS},
