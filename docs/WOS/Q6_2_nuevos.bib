@article{ WOS:001635088200001,
Author = {Seo, Jiseok and Lee, Jun and Lee, Bongchun},
Title = {Automated Evaluation of Layer Thickness Uniformity in 3D-Printed
   Cementitious Composites Using Deep Learning and Comparison with Manual
   Tracing Methods},
Journal = {BUILDINGS},
Year = {2025},
Volume = {15},
Number = {23},
Month = {NOV 25},
Abstract = {Layer thickness uniformity critically influences the dimensional
   accuracy and mechanical performance of large-scale cementitious
   structures produced by material extrusion 3D printing. This study
   introduces a computer vision workflow that couples traditional
   preprocessing with a ResNet-50 convolutional neural network to
   automatically detect interlayer boundaries and quantify thickness
   variation. Hollow 50 x 50 x 50 mm specimens, printed from mixes
   optimized by void ratio (0.6-0.7) for fluidity and stackability,
   supplied 25 labeled RGB images for training and validation. The network
   achieved 96\% training and 95\% validation accuracy, generating boundary
   maps that required minimal linear interpolation. Pixel-based analysis
   yielded uniformity indices of 0.857-0.924, closely matching those from
   manual tracing (0.819-0.919) but with smaller standard deviations,
   indicating higher measurement stability and reduced sensitivity to
   lighting artifacts. The proposed method therefore provides an objective,
   reproducible alternative to labor-intensive manual evaluation and
   supports real-time prediction and control of dimensional errors during
   construction-scale 3D printing, advancing the precision and industrial
   applicability of additive manufacturing with cementitious composites.
   However, since this study was conducted under limited variable
   conditions, such as a simplified and repetitive experimental
   environment, a larger number of images will be required for model
   training to enable application under more general conditions.},
Type = {Article},
Affiliation = {Lee, BC (Corresponding Author), Korea Conform Lab KCL, Smart Construct Mat Ctr, 73 Yangcheong 3 Gil,Ochang Eup, Cheongju 28115, South Korea.
   Seo, Jiseok; Lee, Jun, Daejeon \& Chungnam Ctr, Korea Conform Lab KCL, 26-34 Gajeongbuk Ro, Daejeon 34113, South Korea.
   Lee, Bongchun, Korea Conform Lab KCL, Smart Construct Mat Ctr, 73 Yangcheong 3 Gil,Ochang Eup, Cheongju 28115, South Korea.},
DOI = {10.3390/buildings15234253},
Article-Number = {4253},
Keywords = {3D printing; material extrusion; cementitious composite; deep learning;
   ResNet-50; image processing; Automated Defect Detection},
Author-Email = {jscivil@kcl.re.kr
   lj4923@kcl.re.kr
   leebc@kcl.re.kr},
Number-of-Cited-References = {37},
