   analysis; Curvature-based metrics; Euclidean distance; Field of view
   (FOV); Glaucoma; Diabetic retinopathy},
Keywords-Plus = {CHRONIC KIDNEY-DISEASE; CARDIOVASCULAR-DISEASE; VESSEL SEGMENTATION;
   RETINOPATHY; COHORT},
Author-Email = {wmdiyana@ukm.edu.my},
