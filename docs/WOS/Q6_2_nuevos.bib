DOI = {10.3390/dj13110524},
Article-Number = {524},
Keywords = {complete denture; digital workflow; CAD/CAM; maxillary edentulism; 3D
   printing; intraoral scanning; prosthodontics; PMMA},
Keywords-Plus = {CAD-CAM; ADAPTATION; RETENTION; BASES},
Author-Email = {cldominguez@uat.edu.mx
