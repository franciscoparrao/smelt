@article{ WOS:001676093100001,
Author = {Shi, Lei and Fu, Yichen and Kojiro, Watanabe and Kakehi, Yasuaki and
   Tsuda, Tetsuya and Ono, Kenta},
Title = {Quantitative evaluation of human and machine readability of
   laser-engraved markings under accelerated corrosion},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {266},
Month = {MAR 24},
Abstract = {Laser engraving is widely used for the permanent marking of metallic
   components in industrial traceability and quality control. However, in
   corrosive environments, surface degradation progressively reduces
   contrast and clarity, leading to information loss for both human and
   automated readers. This study introduces a dual-channel measurement
   framework for quantitatively evaluating the functional readability
   lifetime of laser-engraved markings subjected to accelerated corrosion.
   A 2 x 2 factorial design was implemented to examine the influence of
   letter spacing (monospaced vs. proportional) and stroke contrast (low
   vs. high) on readability persistence. Both human perceptual ratings and
   Optical Character Recognition (OCR) accuracy were recorded throughout
   the corrosion process at 1.5-minute intervals, with 54 uniformly
   distributed time points subsequently selected from each font sequence
   for statistical analysis to capture time-dependent readability decay.
   Through the empirical mapping between simulated and natural corrosion,
   112.5 min of accelerated exposure was found to correspond approximately
   to 28-37 days in real environments; further statistical analysis
   (two-way repeated-measures ANOVA) revealed that larger letter spacing
   and higher stroke contrast significantly delayed readability failure.
   These results establish a quantitative correlation between human
   perception and machine recognition, providing a reproducible measurement
   approach for evaluating marking durability and information retention
   under progressive degradation.},
Type = {Article},
Affiliation = {Shi, L (Corresponding Author), Chiba Univ, Grad Sch Sci \& Engn, Chiba, Japan.
   Shi, Lei; Fu, Yichen; Kojiro, Watanabe, Chiba Univ, Grad Sch Sci \& Engn, Chiba, Japan.
   Kakehi, Yasuaki, Univ Tokyo, Grad Sch Interdisciplinary Informat Studies, Emerging Design \& Informat, Tokyo, Japan.
   Tsuda, Tetsuya, Chiba Univ, Grad Sch Sci \& Engn, Dept Mat Sci, Chiba, Japan.
   Ono, Kenta, Chiba Univ, Design Res Inst, Grad Sch Engn, Chiba, Japan.},
DOI = {10.1016/j.measurement.2026.120503},
EarlyAccessDate = {JAN 2026},
Article-Number = {120503},
Keywords = {Laser-engraved markings; Readability evaluation; Corrosion-induced
   degradation; Optical character recognition (OCR); Quantitative
   measurement; Human-machine perception; Information retention},
Author-Email = {slei.hz@gmail.com},
Number-of-Cited-References = {25},
