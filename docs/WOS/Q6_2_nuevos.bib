   Jang, Junghee, Inst Adv Engn, Plant Engn Ctr, 633-2 Goan Ri, Yongin 17528, Gyeonggi Do, South Korea.},
DOI = {10.3390/w17243586},
Article-Number = {3586},
Keywords = {water quality monitoring; total organic carbon; nitrate nitrogen;
   optical analysis; UV absorption spectroscopy; optical sensor; real-time
   measurement},
