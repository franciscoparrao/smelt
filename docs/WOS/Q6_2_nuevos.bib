   Huang, Shuo, Xidian Univ, Coll Comp Sci \& Technol, Xian 710071, Peoples R China.},
DOI = {10.3390/smartcities9010013},
Article-Number = {13},
Keywords = {large language models (LLMs); parameter-efficient fine-tuning (LoRA);
   point-of-interest (POI) data; label expansion; residual-hotspot
   analysis; urban cultural diversity},
Author-Email = {arhuangzhuo@mail.scut.edu.cn
   arguoyixing@mail.scut.edu.cn
