DOI = {10.5194/hess-29-6901-2025},
Keywords-Plus = {WATER-RESOURCES; LAND-USE; CLIMATE; IMPACT; SIMULATION; QUALITY; ENERGY;
   UNCERTAINTY; CALIBRATION; VERSION},
Author-Email = {celray.chawanda@tamu.edu},
