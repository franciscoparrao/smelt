   Ibraheem, Ismael M., Univ Cologne, Inst Geophys \& Meteorol, Pohligstr 3,Off 3, D-50969 Cologne, Germany.},
DOI = {10.1007/s41748-025-01005-2},
EarlyAccessDate = {JAN 2026},
Keywords = {Soil quality; Soil mapping; Soil fertility; MEDALUS; Remote sensing;
   Nile delta, egypt},
