   Nguyen, Quan D.; Sepah, Yasir J., Stanford Univ, Byers Eye Inst, Sch Med, Palo Alto, CA 94303 USA.},
DOI = {10.1016/j.xops.2026.c},
Article-Number = {108118},
Keywords = {Stargardt disease (STGD1); Decreased autofluorescence (DAF); Automated
   image quantification; Image analysis},
Keywords-Plus = {GEOGRAPHIC ATROPHY; PROGRESSION},
