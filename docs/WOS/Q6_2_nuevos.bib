   Wang, Rongxin, Tianjin Municipal Engn Design \& Res Inst, Tianjin, Peoples R China.},
DOI = {10.1038/s41598-025-24835-6},
Article-Number = {40950},
Keywords = {Fracture grouting; Image segmentation; Graph theory; Post-grouting
   evaluation; Width measurement},
Keywords-Plus = {AUTOMATIC CRACK DETECTION; DEEP; REINFORCEMENT; COMPOSITES; BEHAVIORS;
