@article{ WOS:001617745700001,
Author = {Etri, Talal and Seyed-Djawadi, Mohammad Hosein and Nikoo, Mohammad Reza
   and Nazari, Rouzbeh and Al-Rawas, Ghazi},
Title = {A causal diagnostic framework for artificial intelligence-driven risk
   assessment and decision support in complex marine environments},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {163},
Number = {4},
Month = {JAN 1},
Abstract = {Operational management of complex marine environments is often hindered
   by the failure of traditional forecasting models, leading to significant
   risks for important decisions such as vessel loading schedules and berth
   evacuations. In this paper, a paradigm shift is introduced from fallible
   prediction to robust diagnosis. A new, end-to-end causal diagnostic
   workflow is presented that uses systematic model failure as a tool for
   detecting unobserved confounding in such non-stationary systems. In this
   framework, physics-informed feature engineering, time-series causal
   discovery, and rigorous modeling experiments are integrated to identify
   directional pathways of influence. A consistent and reproducible
   predictive failure on unseen data has been observed, which is not
   interpreted as a limitation of the model, but as a powerful diagnostic
   confirming the presence of unobserved physical processes. It is
   noteworthy that formal sensitivity analyses demonstrate the exceptional
   robustness of the causal link between local wind speed and nearshore
   wave height despite this systemic unpredictability. Using this validated
   knowledge, a Causal Attribution Decision Support System (DSS) was
   developed, which was validated across 62 storm events. The results of
   this study provide a generalizable blueprint for building intelligent
   systems that provide actionable, real-time diagnostic insight. These
   results demonstrate that valuable insights can still be gained even when
   perfect prediction is not possible.},
Type = {Article},
Affiliation = {Nikoo, MR (Corresponding Author), Sultan Qaboos Univ, Dept Civil \& Architectural Engn, POB 33, Muscat, Oman.
   Etri, Talal; Seyed-Djawadi, Mohammad Hosein; Nikoo, Mohammad Reza; Al-Rawas, Ghazi, Sultan Qaboos Univ, Dept Civil \& Architectural Engn, POB 33, Muscat, Oman.
   Nazari, Rouzbeh, Univ Memphis, Dept Civil Engn, 3815 Cent Ave, Memphis, TN 38152 USA.},
DOI = {10.1016/j.engappai.2025.113066},
EarlyAccessDate = {NOV 2025},
Article-Number = {113066},
Keywords = {Causal inference; Decision support system; Sensitivity analysis; Causal
   discovery; Coastal engineering; Wave dynamics},
Keywords-Plus = {SENSITIVITY-ANALYSIS; MODELS},
