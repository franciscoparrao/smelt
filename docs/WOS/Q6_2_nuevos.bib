EarlyAccessDate = {JAN 2026},
Keywords = {Clonality; FACS; Heterogeneity},
Keywords-Plus = {MINIMAL RESIDUAL DISEASE; PLASMA-CELLS; VALIDATION; ANTIBODIES},
Author-Email = {gazitroi@bgu.ac.il},
