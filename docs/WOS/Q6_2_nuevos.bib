DOI = {10.1016/j.polymer.2026.129675},
EarlyAccessDate = {MAR 2026},
Article-Number = {129675},
Keywords = {Graphical user interface (GUI); Molecular dynamics simulation; Epoxy
   resin; Mesogenic co-curing agent; Structure-property relationship},
Keywords-Plus = {TOUGHNESS; KINETICS},
Author-Email = {zhuchunhua@jiangnan.edu.cn
   junhua.zhao@163.com},
