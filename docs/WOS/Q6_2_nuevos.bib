@article{ WOS:001692221300001,
Author = {Ben Said, Mourad and Kratou, Myriam and Belkahia, Hanene},
Title = {Tick mitogenomes: Structural characteristics, phylogenetic implications,
   and a critical synthesis from sequencing to systematics},
Journal = {ACTA TROPICA},
Year = {2026},
Volume = {275},
Month = {MAR},
Abstract = {Ticks (Acari: Ixodida) are obligate hematophagous ectoparasites that
   play a pivotal role in transmitting a wide array of pathogens to humans
   and animals. However, their traditional morphology-based identification
   has long been challenged by subtle interspecific differences and
   intraspecific variability, particularly among soft ticks (Argasidae),
   which has resulted in conflicting taxonomic arrangements. In recent
   years, complete mitochondrial genomes (mitogenomes) have emerged as a
   powerful and informative tool, providing a rich, maternally inherited
   marker set comprising 13 protein-coding genes, 22 tRNAs, and two rRNAs.
   These genomic features make mitogenomes ideally suited for resolving
   both deep and recent divergences across tick lineages. The advent and
   widespread adoption of high-throughput sequencing platforms (e.g.,
   Illumina and Oxford Nanopore), together with specialized bioinformatic
   pipelines such as SPAdes, MitoZ, MITOS, and ARWEN, have now
   revolutionized the field by enabling the routine recovery of full
   mitogenomes from both fresh and archival specimens. This technological
   progress has effectively overcome earlier challenges associated with DNA
   degradation and repetitive control regions. Furthermore, comparative
   annotation workflows that integrate automated gene prediction with
   careful manual curation now ensure accurate gene-order mapping and
   precise delineation of tRNA boundaries. As a result, phylogenomic
   analyses based on concatenated mitochondrial protein-coding genes and
   rRNAs robustly support the monophyly of major tick families such as
   Argasidae, Ixodidae, and Nuttalliellidae and clarify evolutionary
   relationships within several medically important genera, including
   Ixodes, Rhipicephalus, Amblyomma, Dermacentor, Hyalomma and
   Haemaphysalis. Nevertheless, an overreliance on mitochondrial DNA alone
   carries inherent risks, including potential misinterpretation of hybrid
   taxa, incomplete lineage sorting, and maternal introgression. To address
   these limitations, integrative phylogenomic frameworks that combine
   mitochondrial and nuclear datasets such as 18S-28S rRNA, ITS2, and
   ultraconserved elements are essential for reconciling conflicting
   evolutionary signals and achieving robust species delimitations. Despite
   these advances, several critical gaps remain, including the
   under-sampling of African and Southeast Asian tick lineages, limited
   integration of nuclear genomic data, and an incomplete understanding of
   the functional roles of control-region duplications and tick-box motifs.
   Thus, this review aims to address current challenges in tick
   mitochondrial genomics by outlining best-practice guidelines that ensure
   accuracy, reproducibility, and data integrity. These include
   dual-platform sequencing for assembly validation, standardized
   quality-control reporting (e.g., DNA Integrity Numbers and per-gene
   coverage), partitioned model testing in phylogenetics, rigorous
   morphological verification, and open sharing of raw reads and annotated
   assemblies. By expanding taxon and population-level sampling and
   integrating genome-scale nuclear markers, the review seeks to build
   comprehensive evolutionary frameworks that advance both vector-borne
   disease control and fundamental tick systematics and evolutionary
   biology.},
Type = {Article},
Affiliation = {Ben Said, M (Corresponding Author), Univ Manouba, Natl Sch Vet Med Sidi Thabet, Lab Parasitol, Manouba 2010, Tunisia.
   Ben Said, M (Corresponding Author), Univ Manouba, Natl Sch Vet Med Sidi Thabet, Lab Microbiol, Manouba 2010, Tunisia.
   Ben Said, M (Corresponding Author), Univ Manouba, Higher Inst Biotechnol Sidi Thabet, Dept Basic Sci, Manouba 2010, Tunisia.
   Ben Said, Mourad, Univ Manouba, Natl Sch Vet Med Sidi Thabet, Lab Parasitol, Manouba 2010, Tunisia.
   Ben Said, Mourad; Kratou, Myriam, Univ Manouba, Natl Sch Vet Med Sidi Thabet, Lab Microbiol, Manouba 2010, Tunisia.
   Ben Said, Mourad, Univ Manouba, Higher Inst Biotechnol Sidi Thabet, Dept Basic Sci, Manouba 2010, Tunisia.},
DOI = {10.1016/j.actatropica.2026.108015},
EarlyAccessDate = {FEB 2026},
