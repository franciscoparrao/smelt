@article{ WOS:001714747300001,
Author = {Ko, Kayla and Rodriguez, Christian and Yatawara, Anjana},
Title = {Income-based exposure disparities across California counties, 2000 to
   2023: a generalizable statistical framework},
Journal = {ENVIRONMENTAL RESEARCH: HEALTH},
Year = {2026},
Volume = {4},
Number = {1},
Month = {MAR 1},
Abstract = {Environmental justice studies have long documented disparities in air
   pollution exposure, yet few provide a generalizable framework to
   quantify these disparities across time, pollutants, and spatial scales.
   We develop a reproducible, population-weighted framework to quantify
   income-based disparities in air pollution exposure across California
   counties from 2000 to 2023. Daily regulatory measurements of PM2.5, NO2,
   O-3, SO2, and CO are aggregated to county-day means and then to
   group-level exposures using county-year population weights, yielding the
   estimated exposure of an average individual in each income group.
   Counties are assigned to low, middle, and high income strata using fixed
   statewide thresholds derived from 2019 to 2023 median household income
   (MHI) percentiles, and disparities are summarized through absolute gaps
   (low minus high), relative ratios, and the share of days with low-income
   exposure exceeding high-income exposure. Statewide, PM2.5 and O-3
   exposures generally experienced higher PM2.5 and O-3 in low-income
   counties, while NO2 and CO concentrations are consistently higher in
   high-income areas. SO2 transitions from a high-income advantage in early
   years to a low-income advantage later. Trend analysis indicates a
   significant narrowing of disparities for PM2.5 (-0.172 mu gm(-3) yr(-1),
   95\% CI: -0.279, -0.065), O-3 (-3.06 \& times;10(-4) ppm yr(-1), 95\%
   CI: -3.76 \& times;10(-4), -2.35 \& times;10(-4)), and NO2 (+0.114ppb
   yr(-1), 95\% CI: +0.076, +0.152). CO disparities intensify in favor of
   high-income counties ( yr(-1), 95\% CI: -0.0087, -0.0015), while SO2
   shows a positive trend (+0.083ppb yr(-1), 95\% CI: +0.052, +0.115),
   consistent with a flipped gradient. Sensitivity analyses using an
   alternative income definition based on 2014-2018 MHI and 25th and 75th
   percentile cut points yield the same qualitative gradient patterns and
   trend signs, demonstrating robustness to income-group specification. All
   data, code, and a versioned one-command workflow are publicly available
   to facilitate reuse for other states or for alternative socioeconomic
   stratifiers such as race or education.},
Type = {Article},
Affiliation = {Yatawara, A (Corresponding Author), Calif State Univ, Dept Math, Bakersfield, CA 80523 USA.
   Ko, Kayla; Yatawara, Anjana, Calif State Univ, Dept Math, Bakersfield, CA 80523 USA.
   Rodriguez, Christian, Calif State Univ, Dept Comp \& Elect Engn \& Comp Sci, Bakersfield, CA USA.},
DOI = {10.1088/2752-5309/ae4134},
Article-Number = {011002},
Keywords = {environmental justice; air pollution disparities; multi-pollutant
   analysis; income inequality; PM2.5; exposure modeling; socioeconomic
   gradients},
Keywords-Plus = {AMBIENT AIR-POLLUTION; BIRTH-WEIGHT},
Author-Email = {ayatawara@csub.edu},
Number-of-Cited-References = {22},
Times-Cited = {0},
Unique-ID = {WOS:001714747300001},
}

@article{ WOS:001715134100023,
Author = {Zhang, Zheyuan and Cao, Wen and Luan, Haomei and Lin, Jie and Zhu,
   Xiaoyang and Yan, Zongliang and Wang, Jichen and Zhang, Huabin and Guo,
   Ruijun and Bai, Zhiyong},
Title = {Automated segmentation and quantitative measurement of cervical nerves
   in ultrasound images using an SZJ-SEG-based deep learning framework},
Journal = {QUANTITATIVE IMAGING IN MEDICINE AND SURGERY},
Year = {2026},
Volume = {16},
Number = {3},
Month = {MAR},
Abstract = {Background: Accurate recognition and quantitative assessment of cervical
   nerves are essential for ultrasound-guided nerve block, preoperative
   evaluation, and diagnosis of peripheral neuropathies. However, manual
   interpretation and measurement of nerve structures remain time-consuming
   and operator dependent. This study aimed to develop an intelligent,
   fully automated system for precise segmentation and quantitative
   measurement of cervical nerves in ultrasound images using a deep
   learning-based approach. Methods: Ultrasound images from 200 healthy
   volunteers were collected and meticulously annotated to construct a
   large-scale standardized dataset comprising 117,729 images. A fully
   automated analysis framework was designed, incorporating a YOLOv11
   network for precise localization of the effective imaging region {[}mean
   intersection over union (mIoU) =0.99] and an optical character
   recognition (OCR) module for automatic extraction of depth scale
   information. The proposed segmentation network, termed SZJ-SEG, combines
   a Deconv Block and an efficient upsampling convolution block (EUCB)
   based on a ResNet50 backbone to achieve high segmentation accuracy with
   low computational cost. Quantitative analysis of the C5-C7 nerve roots
   was performed through pixel-to-physical scale calibration for
   cross-sectional area (CSA) and perimeter calculation. Results: On a
   clinical dataset comprising 117,729 images (training/validation/test
   =94,183/11,773/11,773), SZJ-SEG achieved mIoU values of 0.9124, 0.9109,
   and 0.9041 for the C5, C6, and C7 nerves, respectively, and 0.9227 for
   the continuous brachial plexus section. The mean absolute error (MAE) of
   CSA measurement ranged from 0.278 to 0.442 mm2, with mean absolute
   percentage error (MAPE) between 2.43\% and 6.16\%, and Pearson
   correlation coefficients exceeding 0.96. For perimeter measurements, MAE
   ranged from 0.374 to 0.471 mm, MAPE from 3.05\% to 4.49\%, and Pearson R
   from 0.84 to 0.91, indicating excellent consistency with manual
   annotations. Conclusions: The proposed SZJ-SEG-based system enables
   accurate, efficient, and reproducible segmentation and quantitative
   analysis of cervical ultrasound images. With strong performance and high
   clinical relevance, it provides a reliable tool for ultrasound-guided
   nerve block localization and preoperative assessment. Its modular
   architecture offers scalability for extension to other anatomical
   regions, highlighting broad potential in intelligent ultrasound
   diagnosis.},
Type = {Article},
Affiliation = {Bai, ZY (Corresponding Author), Tsinghua Univ, Beijing Tsinghua Changgung Hosp, Sch Clin Med, Dept Ultrasound,Tsinghua Med, 168 Litang Rd, Beijing 102218, Peoples R China.
   Guo, RJ (Corresponding Author), Capital Med Univ, Beijing Chaoyang Hosp, Dept Ultrasound Med, 8 Gongti South Rd, Beijing 100020, Peoples R China.
