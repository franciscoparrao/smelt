@article{ WOS:001716988400005,
Author = {Lin, Pei-Yu and Lin, Guan-Jun and Chen, Kuan-Lin and Huang, Shiang-Chin
   and Chen, Pao-Yang},
Title = {Computational Workflow for Genome-Wide DNA Methylation Profiling and
   Differential Methylation Analysis},
Journal = {BIO-PROTOCOL},
Year = {2025},
Volume = {15},
Number = {21},
Month = {NOV 5},
Abstract = {DNA methylation is a crucial epigenetic modification that influences
   gene expression and plays a role in various biological processes.
   High-throughput sequencing techniques, such as bisulfite sequencing
   (BS-seq) and enzymatic methyl sequencing (EM-seq), enable genome-wide
   profiling of DNA methylation patterns with single-base resolution. In
   this protocol, we present a bioinformatics pipeline for analyzing
   genome-wide DNA methylation. We outline the step-by-step process of the
   essential analyses, including quality control using FASTQ for BS- and
   EM-seqs raw reads, read alignment with commonly used aligners such as
   Bowtie2 and BS-Seeker2, DNA methylation calling to generate CGmap files,
   identification of differentially methylated regions (DMRs) using tools
   including MethylC-analyzer and HOME, data visualization, and
   post-alignment analyses. Compared to existing workflows, this pipeline
   integrates multiple steps into a single protocol, lowering the technical
   barrier, improving reproducibility, and offering flexibility for both
   plant and animal methylome studies. To illustrate the application of
   BS-seq and EM-seq, we demonstrate a case study on analyzing a mutant in
   Arabidopsis thaliana with a mutation in the met1 gene, which encodes a
   DNA methyltransferase, and results in global CG hypomethylation and
   altered gene regulation. This example highlights the biological insights
   that can be gained through systematic methylome analysis. Our workflow
   is adaptable to any organism with a reference genome and provides a
   robust framework for uncovering methylation-associated regulatory
   mechanisms. All scripts and detailed instructions are provided in GitHub
   repository: https://github.com/PaoyangLab/Methylation\_Analysis.},
Type = {Article},
Affiliation = {Chen, PY (Corresponding Author), Acad Sinica, Inst Plant \& Microbial Biol, Taipei, Taiwan.
   Chen, PY (Corresponding Author), Acad Sinica \& Natl Taiwan Univ, Genome \& Syst Biol Degree Program, Taipei, Taiwan.
   Lin, Pei-Yu; Lin, Guan-Jun; Chen, Kuan-Lin; Huang, Shiang-Chin; Chen, Pao-Yang, Acad Sinica, Inst Plant \& Microbial Biol, Taipei, Taiwan.
   Lin, Guan-Jun; Chen, Pao-Yang, Acad Sinica \& Natl Taiwan Univ, Genome \& Syst Biol Degree Program, Taipei, Taiwan.
   Huang, Shiang-Chin, Natl Taiwan Univ, Inst Plant Biol, Taipei, Taiwan.},
DOI = {10.21769/BioProtoc.5506},
Article-Number = {e5506},
Keywords = {Bisulfite sequencing; DNA methylation; Bioinformatics pipeline; BS-seq;
   EM-seq; NGS; DMR; Bioinformatics; CGmap},
Keywords-Plus = {SEQUENCE; ALIGNMENT},
Author-Email = {paoyang@gate.sinica.edu.tw},
Number-of-Cited-References = {46},
Times-Cited = {1},
Unique-ID = {WOS:001716988400005},
}

@article{ WOS:001615912400007,
Author = {Sarwar, Munib and Melhus, Bjorn},
Title = {Automated linear buckling analysis of space frame structures},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {This article presents a streamlined procedure for assessing the capacity
   of space frame structures by incorporating geometric (stress) stiffness
   directly into the structural analysis. The procedure, implemented in the
   software SeaWare, employs novel techniques for handling hydrostatic
   pressure and assessing initial imperfections. It ensures full compliance
   with NORSOK design standards while accounting for second-order effects.
   Unlike conventional approaches that rely on the buckling length factor k
   and moment reduction factor Cm, the proposed procedure derives
   equivalent imperfections directly from the eigenvalue solution,
   calibrated against the governing buckling curve. This eliminates the
   need for manual parameter estimation and enables fully automated
   evaluation of all components across numerous load cases. The formulation
   combines the elastic and geometric stiffness matrices, F = (Ke + Kg)d,
   and applies an eigenmode-based scaling of imperfections consistent with
   design code principles. It provides a transparent and computationally
   efficient alternative to geometrically and materially nonlinear analyses
   (GMNA). By integrating these elements into a unified framework, it
   establishes a consistent and computationally robust foundation for
   code-compliant analysis of complex offshore structures and is presented
   in sufficient detail to enable direct implementation and
   reproducibility.},
Type = {Article},
Affiliation = {Sarwar, M (Corresponding Author), Aker Solut Jacket Technol, POB 94, N-1325 Lysaker, Norway.
   Sarwar, Munib; Melhus, Bjorn, Aker Solut Jacket Technol, POB 94, N-1325 Lysaker, Norway.},
DOI = {10.1016/j.rineng.2025.107926},
EarlyAccessDate = {NOV 2025},
Article-Number = {107926},
Keywords = {Second order bending moments; Geometric stiffness; NORSOK; SeaWare;
   Column buckling; Initial imperfection; LBIA},
Keywords-Plus = {NONLINEAR-ANALYSIS; PORTAL FRAMES; IMPERFECTIONS; DEFLECTIONS; COLUMNS;
   DESIGN},
Author-Email = {munibsar@gmail.com},
Number-of-Cited-References = {54},
Times-Cited = {0},
Unique-ID = {WOS:001615912400007},
}

@article{ WOS:001616601600011,
Author = {Cheung, Yee-Ting and Leung, Hoi-Shan and Tseung, Jeremiah Sik-Bit and
   Yu, Kelvin Yat-Chung and Leung, Mei-Tik Stella and Ching, Chor-Kwan and
   Chong, Yeow-Kuan},
Title = {Supervised machine learning model for serum protein electrophoresis data
   interpretation},
Journal = {PATHOLOGY},
Year = {2025},
Volume = {57},
Number = {7},
Pages = {912-916},
Month = {DEC},
Abstract = {Serum protein electrophoresis (SPE) is a frequently employed laboratory
   test in clinical settings, with over 10,000 requests per annum in our
   centre. It is primarily utilised for the diagnosis and monitoring of
   paraproteinaemia. Interpretation on SPE is time-consuming and relies on
   the expertise of pathologists, with potential interobserver variability.
   Assistance from machine learning algorithms could improve efficiency and
   objectiveness. Digitised capillary electrophoresis (CE) tracings
   acquired using the Sebia Minicap Protein(E) 6 kit were extracted from
   the analyser, and corresponding reports for SPE were obtained from the
   laboratory information systems of Princess Margaret Hospital (PMH) and
   Tuen Mun Hospital (TMH). Three artificial neural networks (for
   fractionation, classification and location plus quantification) were
   trained and evaluated against reference interpretations from one to two
   pathologists. Samples from PMH constitute the training datasets. Trained
   models were subsequently evaluated with samples from TMH. A total of
   41,448 and 24,501 CE tracings and corresponding reports for SPE,
   spanning from October 2014 to November 2022, were obtained from PMH and
   TMH, respectively; 25,661-41,014 samples from PMH constituted the
   training datasets. Trained models were subsequently evaluated with
   24,238 samples from TMH. The classification model achieved an area under
   the receiver operating characteristic curve of 0.976 in the testing
   dataset, with an agreement rate of 93.8\%. The fractionation model had
   mean and standard deviation difference from reported manual fractioning
   of -0.0884 to 0.155 g/L and 0.315 to 2.04 g/L, respectively, across the
   six serum protein bands. Peak quantification by the location plus
   quantification model correlated with manual quantification, with
   Spearman's r of 0.976. The machine learning models achieved near-human
   performances. They enabled high-throughput SPE analyses and
   interpretation and improved objectiveness and reproducibility of
   results.},
Type = {Article},
Affiliation = {Chong, YK (Corresponding Author), Princess Margaret Hosp, Dept Pathol, Chem Pathol Lab, Lai Chi Kok,Kowloon, 2-10 Princess Margaret Hosp Rd, Hong Kong, Peoples R China.
   Cheung, Yee-Ting; Leung, Hoi-Shan; Tseung, Jeremiah Sik-Bit; Yu, Kelvin Yat-Chung; Ching, Chor-Kwan; Chong, Yeow-Kuan, Princess Margaret Hosp, Dept Pathol, Chem Pathol Lab, Hong Kong, Peoples R China.
   Leung, Mei-Tik Stella, Tuen Mun Hosp, Dept Clin Pathol, Chem Pathol Lab, Hong Kong, Peoples R China.},
DOI = {10.1016/j.pathol.2025.05.010},
EarlyAccessDate = {NOV 2025},
Keywords = {protein electrophoresis; machine learning; artificial intelligence;
   automation},
Author-Email = {cyk280a@ha.org.hk},
Number-of-Cited-References = {9},
Times-Cited = {0},
Unique-ID = {WOS:001616601600011},
}

@article{ WOS:001615801000002,
Author = {Eftimie, Sorana and Ileni, Tudor and Iacob, Liviu and Hedesiu, Mihaela
   and Diosan, Laura},
Title = {Tooth-level detection and mapping of dental pathologies on panoramic
   radiographs using YOLOv11 and RT-DETR},
Journal = {METHODSX},
Year = {2025},
Volume = {15},
Month = {DEC},
Abstract = {This article describes a reproducible method for automated tooth-level
   detection and mapping of dental pathologies on panoramic radiographs.
   The workflow integrates two deep learning stages: (1) segmentation of
   individual teeth and (2) detection and classification of dental lesions.
   Outputs are combined to assign pathologies to specific teeth, supporting
   comprehensive radiological assessment. The method was implemented and
   tested using two datasets: a collection of 1,628 panoramic radiographs
   annotated with 12 pathology categories, and the public Tufts Dental
   Database. Several model architectures were evaluated, including YOLOv11
   and RT-DETR configurations. The influence of image formatting and
   preprocessing strategies on performance was also assessed. Results
   showed that RT-DETR-x achieved the highest mean average precision
   (mAP@50) for pathology detection, while YOLOv11x produced the most
   accurate tooth segmentation. The integrated system demonstrated high
   precision in linking lesions to the corresponding teeth. This method
   offers a practical framework for developing AI-assisted diagnostic tools
   in dentistry and can be adapted to other imaging datasets. center dot
   Development of a fully automated dental diagnostic tool that segments
   individual teeth and maps detected pathologies to their corresponding
   tooth center dot YOLOv11 and RT-DETR variants are extensively tested for
   segmentation and detection tasks center dot Preprocessing and image
   formatting strategies are systematically compared},
Type = {Article},
Affiliation = {Ileni, T (Corresponding Author), Babes Bolyai Univ, Comp Sci Fac, 1 Mihail Kogalniceanu, Cluj Napoca, Romania.
   Eftimie, Sorana; Hedesiu, Mihaela, Iuliu Hatieganu Univ Med \& Pharm, Dept Oral \& Maxillofacial Surg \& Radiol, 32 Clinicilor St, Cluj Napoca 400006, Romania.
