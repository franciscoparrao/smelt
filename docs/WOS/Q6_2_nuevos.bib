   Li, Shujin, Yonsei Univ, Taste Res Ctr, Oral Sci Res Ctr BK21 FOUR Project, Dept Oral Biol,Div Anat \& Dev Biol,Coll Dent, Seoul 03722, South Korea.},
DOI = {10.1016/j.rineng.2026.109755},
