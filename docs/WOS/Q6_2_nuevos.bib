   Ulsen, Carina, Univ Sao Paulo, Dept Min \& Petr Engn, Escola Politecn, Technol Characterizat Lab, Sao Paulo, SP, Brazil.},
DOI = {10.1111/1365-2478.70159},
Article-Number = {e70159},
Keywords = {borehole geophysical; geochemical characterization; geometallurgy;
   niobium; self-organizing maps; unsupervised models},
