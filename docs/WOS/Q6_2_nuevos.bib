   Contreras, Jorge, Univ Complutense Madrid, Fac Phys, Dept Struct Matter Thermal Phys \& Elect, Avda Complutense S-N, Madrid 28040, Spain.},
DOI = {10.3390/electronics15010105},
Article-Number = {105},
Keywords = {surrogate modelling; multi-objective optimization;
