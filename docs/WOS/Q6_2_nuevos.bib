}

@article{ WOS:001702190600001,
Author = {Decrette, Mathieu and Osselin, Jean-Francois and Walther, Julie and
   Drean, Jean-Yves},
Title = {Motorised jacquard technology for interlock weaving damages reduction:
   Effect of shed geometry and yarn density},
Journal = {JOURNAL OF ENGINEERED FIBERS AND FABRICS},
Year = {2026},
Volume = {21},
Abstract = {Woven composite reinforcements usually have very specific and high
   performances. However, the weaving process may be aggressive and damage
   warp tows, due to the flexion and friction sensitivity of the used
   materials, for example, carbon and glass. This is a crucial point as
   damages, which consist of filament breakages, material loss or bonding
   errors, tend to cause a loss of mechanical properties and/or a bad
   visual aspect. Stages from tensioning to reed were quite widely studied
   and optimised. Nevertheless, recently since density is high the impact
   of yarn-to-yarn and yarn to heddle wires friction at the shedding step
   have been clearly established. The weaving devices used are a loom
   specifically adapted to interlock weaving and a UNIVAL 100 Jacquard
   shedding system. A UNIVAL Jacquard from St \& auml;ubli, which is a
   motorised technology, enables any shed geometry and individual yarn
   motion thanks to special parameters. Such yarn movements, which are
   hardly reproducible with standard shedding devices, may help towards a
   better understanding of yarn interactions and wear mechanisms inside the
   shed. To understand the damage phenomenon and to reduce it, a
   methodology would consist in counting damage events which occur on yarns
   and hamper a correct shedding according to time. Several yarn
   interactions were set up in order to understand the effect of shedding
   parameter configuration on yarn damage generation. The results clearly
   show the several damage evolutions in time are different according to
   shedding configurations and that some configurations can help to reduce
   warp yarn damages for high-density multilayer weaving. In addition, an
   algorithm for weave pattern reading and processing has also been set up
   to manage automatically shed geometry and tow density in the shed.},
Type = {Article},
Affiliation = {Osselin, JF (Corresponding Author), Univ Haute Alsace, Ecole Natl Super Ingn Sud Alsace, Lab Phys \& Mecan Text LPMT, UR 4365, Mulhouse F-68093, France.
   Decrette, Mathieu; Osselin, Jean-Francois; Walther, Julie; Drean, Jean-Yves, Univ Haute Alsace, Ecole Natl Super Ingn Sud Alsace, Lab Phys \& Mecan Text LPMT, UR 4365, Mulhouse F-68093, France.
   Walther, Julie, Univ Haute Alsace, Ecole Natl Super Ingn Sud Alsace, Inst Rech Informat Math Automatique \& Signal IRIMA, EA 7499, Mulhouse, France.},
DOI = {10.1177/15589250261422391},
Article-Number = {15589250261422391},
Keywords = {weaving process; tow damages; interlock weaving; yarn-to-yarn friction},
Keywords-Plus = {CARBON-FIBER TOWS; TENSILE PROPERTIES; COMPOSITES; FABRICS;
   DELAMINATION; PERFORMANCE},
Author-Email = {mathieu.decrette@uha.fr},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001702190600001},
}

@article{ WOS:001698484500001,
Author = {Jiang, Weiwei and Zhu, Ruisheng and Zhou, Yipeng and Ma, Zipeng},
Title = {Integrating UAV remote sensing and field ecology for fine-scale mapping
   of riparian herbaceous vegetation},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {Dominant populations of riparian vegetation are early indicators of
   river ecosystem change and provide key information for ecological
   stewardship. However, timely and accurate methods to obtain data on
   dominant riparian species are scarce, especially in dammed rivers where
   herbaceous plants predominate. The traditional quadrat method accurately
   captures herbaceous species at sampling points but cannot reveal spatial
   patterns and entails long acquisition cycles. UAV (Unmanned Aerial
   Vehicle) remote sensing expands observations from points to landscapes,
   but even with centimeter-level resolution, identifying herbaceous
   species still requires ground-based observations. This study proposes an
   automatic extraction framework for riparian dominant species by
   integrating ecological information from quadrat surveys into UAV-based
   multispectral remote sensing classification. Using stacking models (ST)
   that combine Decision Tree (DT), XGBoost (XGB), Random Forest (RF), and
   Catboost, overall accuracy increased by 1.4\%-21.2\% over base models.
   We introduce RF-Y-RFE (Dominance Weighted Random Forest Recursive
   Feature Elimination); within the ST framework, the RF-Y-RFE feature
   combination achieved the highest performance, with overall accuracy of
   93.1\%. SHAP-PROBABILITY analysis indicated that spectral, index,
   geographic, and texture features contributed most, while geometric
   features contributed less. Notably, Mean\_DSM (Digital Surface Model)
   shows the highest average attribution in our analysis, underscoring the
   value of incorporating field-based ecological knowledge into remote
   sensing. Overall, the proposed framework provides a reproducible,
   operational workflow for obtaining information on dominant riparian
   species in dam-regulated rivers and contributes to the advancement of
   remote sensing applications in ecology.},
Type = {Article},
Affiliation = {Jiang, WW (Corresponding Author), Hubei Univ Technol, Sch Civil Engn Architecture \& Environm, Wuhan 430068, Peoples R China.
   Jiang, Weiwei; Zhu, Ruisheng; Zhou, Yipeng; Ma, Zipeng, Hubei Univ Technol, Sch Civil Engn Architecture \& Environm, Wuhan 430068, Peoples R China.
   Jiang, Weiwei; Zhu, Ruisheng; Zhou, Yipeng; Ma, Zipeng, Hubei Univ Technol, Key Lab Hlth Intelligent Percept \& Ecol Restorat, Minist Educ, Wuhan, Peoples R China.
   Jiang, Weiwei; Zhu, Ruisheng; Zhou, Yipeng; Ma, Zipeng, Hubei Univ Technol, Innovat Demonstrat Base Ecol Environm Geotech \&, Wuhan 430068, Peoples R China.},
DOI = {10.1016/j.rsase.2026.101925},
Article-Number = {101925},
Keywords = {riparian zone; Dominant species; UAV; SHAP method; Feature selection},
Author-Email = {626834986@qq.com},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001698484500001},
}

@article{ WOS:001697499500001,
Author = {Bai, Yang and Nie, Zhaoxin and Lin, Hai and Li, Tiechuan and Duan,
   Xuexin},
Title = {Pulsed acoustofluidic pipetting: An automated platform mimicking manual
   pipetting for accelerated cell staining},
Journal = {BIOMICROFLUIDICS},
Year = {2026},
Volume = {20},
Number = {1},
Month = {JAN},
Abstract = {Accurate and efficient cell staining is a fundamental prerequisite for
   reliable cell analyses. Conventional antibody labeling methods primarily
   rely on passive diffusion or manual pipetting-a widely used yet
   labor-intensive and inconsistent mixing technique. Manual pipetting,
   while effective in refreshing the local concentration gradient, suffers
   from operator dependency, poor reproducibility, and potential cell
   damage due to uncontrolled shear forces. To overcome these limitations,
   we developed a Pulsed Acoustofluidic Pipetting (PAP) method that mimics
   and automates the manual pipetting process using localized
   acoustofluidic actuation within standard microcentrifuge tubes. The
   system employs programmable acoustic pulses to generate periodic
   micro-vortices that actively refresh the concentration boundary layer,
   thereby accelerating antibody-antigen binding while maintaining a gentle
   microenvironment. A compact acoustofluidic module was built to integrate
   automated staining and washing in a single step. Compared with static
   incubation and manual pipetting, PAP achieved over a twofold increase in
   staining efficiency within one quarter of the time, with superior
   uniformity and reproducibility. The method demonstrated consistent
   enhancement across cell models with high, medium, and low antigen
   expression, while fully preserving cell viability and fluorescence
   integrity.},
Type = {Article},
Affiliation = {Li, TC; Duan, XX (Corresponding Author), Tianjin Univ, State Key Lab Precis Measuring Technol \& Instrumen, Tianjin 300072, Peoples R China.
   Bai, Yang; Nie, Zhaoxin; Lin, Hai; Li, Tiechuan; Duan, Xuexin, Tianjin Univ, State Key Lab Precis Measuring Technol \& Instrumen, Tianjin 300072, Peoples R China.},
DOI = {10.1063/5.0307698},
Article-Number = {014104},
Keywords-Plus = {MASS-TRANSPORT; BINDING-KINETICS; ANTIGEN; IMMUNOHISTOCHEMISTRY;
   ANTIBODY},
Author-Email = {leetch@tju.edu.cn
   xduan@tju.edu.cn},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001697499500001},
}

@article{ WOS:001697182400001,
Author = {Suo, Liqiu and Xia, Lin and Chung, Yoona and Kim, Eunchan},
Title = {Layered Feature Engineering for E-Commerce Purchase Prediction: A
   Hierarchical Evaluation on Taobao User Behavior Datasets},
Journal = {CMC-COMPUTERS MATERIALS \& CONTINUA},
Year = {2026},
Volume = {87},
Number = {1},
Abstract = {Accurate purchase prediction in e-commerce critically depends on the
   quality of behavioral features. This paper proposes a layered and
   interpretable feature engineering framework that organizes user signals
   into three layers: Basic, Conversion \& Stability (efficiency and
   volatility across actions), and Advanced Interactions \& Activity
   (cross-behavior synergies and intensity). Using real Taobao (Alibaba's
   primary e-commerce platform) logs (57,976 records for 10,203 users; 25
   November-03 December 2017), we conducted a hierarchical, layer-wise
   evaluation that holds data splits and hyperparameters fixed while
   varying only the feature set to quantify each layer's marginal
   contribution. Across logistic regression (LR), decision tree, random
   forest, XGBoost, and CatBoost models with stratified 5-fold
   cross-validation, the performance improved monotonically from Basic to
   Conversion \& Stability to Advanced features. With LR, F1 increased from
   0.613 (Basic) to 0.962 (Advanced); boosted models achieved high
   discrimination (0.995 AUC Score) and an F1 score up to 0.983.
   Calibration and precision-recall analyses indicated strong ranking
   quality and acknowledged potential dataset and period biases given the
   short (9-day) window. By making feature contributions measurable and
   reproducible, the framework complements model-centric advances and
   offers a transparent blueprint for production-grade behavioral modeling.
   The code and processed artifacts are publicly available, and future work
   will extend the validation to longer, seasonal datasets and hybrid
   approaches that combine automated feature learning with domain-driven
   design.},
Type = {Article},
