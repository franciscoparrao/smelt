@article{ WOS:001627727700007,
Author = {Kamat, Milind and Jagasia, Jyoti and Vaidya, Akhil and Surve, Omkar},
Title = {Embedding-Based decision support framework for large-scale content
   analysis},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2025},
Volume = {332},
Month = {DEC 15},
Abstract = {Contemporary knowledge-based decision support systems face unparalleled
   challenges in analysing large quantities of unstructured data and
   maintaining the interpretive rigor that is essential for strategic
   intelligence. The traditional qualitative content analysis methods
   encounter scalability limitations creating analytical bottlenecks.
   Organizations require rapid, and reliable knowledge extraction
   capabilities. Our research presents a novel solution by using an
   embedding-based qualitative coding framework that transforms semantic
   similarity assessment into systematic knowledge representation
   processes. This enables large-scale content analysis while preserving
   interpretive depth. The methodology leverages Large Language Model
   embeddings to represent textual meaning as geometric relationships
   within high-dimensional semantic spaces, facilitating quantitative
   similarity assessment through cosine similarity calculation. Our
   framework combines deductive and inductive coding approaches through
   systematic reference vector construction enhanced by corpus-driven
   clustering analysis, creating robust semantic anchors for automated
   classification. We validated our framework across three diverse domains:
   CSR disclosures, technical knowledge classification, and sentiment
   analysis. Our results show consistent performance nearing human expert
   reliability with F1-scores above 0.95 in formal document analysis,
   showing substantial improvements over traditional machine learning
   approaches. We achieved scalable processing speeds reducing analysis
   time from weeks to minutes while maintaining classification accuracy
   comparable to expert human coding. Cross-model evaluations using GPT,
   Gemini, and MiniLM embeddings confirmed the framework's reliability
   across multiple embedding model architectures. Our algorithmic approach
   ensures systematic transformation of unstructured content into clear,
   actionable insights supporting strategic positioning, regulatory
   assessment, and organizational decision-making with reproducible
   outcomes.},
Type = {Article},
Affiliation = {Vaidya, A (Corresponding Author), Sardar Patel Inst Technol, Mumbai, India.
   Kamat, Milind; Jagasia, Jyoti, SP Jain Inst Management \& Res, Mumbai, India.
   Vaidya, Akhil; Surve, Omkar, Sardar Patel Inst Technol, Mumbai, India.},
DOI = {10.1016/j.knosys.2025.114926},
EarlyAccessDate = {NOV 2025},
Article-Number = {114926},
Keywords = {Knowledge-based systems; Decision support systems; Semantic similarity;
   Knowledge representation; Intelligent systems; LLM embeddings},
Keywords-Plus = {INFORMATION-CONTENT},
Author-Email = {akhil.vaidya22@spit.ac.in},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001627727700007},
}

@article{ WOS:001626303200001,
Author = {Billimoria, Kharmen and Menero-Valdes, Paula and Lee, William and Shard,
   Alex and Infante, Heidi Goenaga},
Title = {Towards improved workflows for the production and metrological
   characterization of LA-ICP-MS calibration standards for quantitative
   bioimaging},
Journal = {JOURNAL OF ANALYTICAL ATOMIC SPECTROMETRY},
Year = {2026},
Volume = {41},
Number = {1},
Pages = {164-172},
Month = {JAN 14},
Abstract = {The lack of suitable calibration standards is a persistent bottleneck
   for quantitative bioimaging by LA-ICP-MS. Widespread use of in-house
   calibration approaches has led to a lack of harmonisation limiting the
   potential of LA-ICP-MS in clinical or biomedical fields. This work
   addresses this challenge by utilising automation via a bioprinting
   approach to produce re-usable gelatin-droplet standards, doped with
   multiple elements for both instrument tuning and quantitative analysis.
   The resulting standards were systematically characterized in terms of
   thickness, elemental homogeneity, and long-term stability. Droplets were
   doped with Ti, Ce, Au, Th and U (used for instrument tuning) as well as
   increasing concentrations of lanthanides such as Gd and Yb (typically
   used in bio-clinical applications). Variation of thickness (measured by
   ellipsometry) between droplets, after printing and dehydration, was 5\%
   (RSD, n = 12). Intra- and inter-droplet elemental homogeneity were less
   than 6\% (RSD, n = 10) and 8\% (RSD, n = 9), respectively for all
   elements. Due to the reproducibility of both physical characteristics
   (thickness and size) and elemental distribution, there is no need of
   ablating the entire droplet. Instead, ablation of an area as small as 1
   line across a droplet produced elemental data which is representative of
   the entire droplet. This feature enables the same droplet to be used
