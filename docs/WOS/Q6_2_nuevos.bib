}

@article{ WOS:001650471000001,
Author = {Papp, Daniel and Wen, Hanrong and Scheich, David and Lingg, Nico and
   Mitulovic, Goran and Eeltink, Sebastiaan},
Title = {A Protocol for Robust Discovery Proteomics Using Nano Liquid
   Chromatography Using Pillar-Array Column Technology and High-Resolution
   Mass Spectrometry With Data-Independent Acquisition},
Journal = {JOURNAL OF SEPARATION SCIENCE},
Year = {2025},
Volume = {48},
Number = {12},
Month = {DEC 28},
Abstract = {Nano liquid chromatography-mass spectrometry has come to be a key
   enabling technology in shotgun proteomics due to the combination of
   exceptional separation power, sensitivity, and comprehensiveness.
   However, the know-how of setting up proteomics methods to deliver
   robust, reliable, and meaningful results to large-scale life science
   experiments has remained somewhat ambiguous. This protocol outlines
   guidance for establishing nano-LC-MS/MS workflows focusing on
   comprehensive and untargeted deep proteome profiling, using
   state-of-the-art column technology and mass spectrometry. Employing a
   second-generation micropillar-array column, a trade-off is demonstrated
   between analysis time and chromatographic resolving power, which in turn
   impacts peptide and protein identification scores from a commercial HeLa
   reference standard. Furthermore, a straightforward workflow to develop a
   data-independent acquisition (DIA)-parallel accumulation-serial
   fragmentation (PASEF) analytical method is proposed, with a special
   focus on the optimization of the ESI source settings. Besides the method
   development, the study discusses the use of segmented gradients, and an
   MS-compatible surfactant in the sample diluent is also explored.
   Finally, the robustness of the developed method is demonstrated through
   consistently identifying 7558 protein groups (CV = 0.3\%) as maintaining
   high repeatability peptide retention times (mean CV = 0.2\%) and system
   pressure (CV = 0.4\%) over 21 consecutive analyses.},
Type = {Article},
Affiliation = {Eeltink, S (Corresponding Author), Vrije Univ Brussel VUB, Dept Chem Engn, Brussels, Belgium.
   Papp, Daniel; Wen, Hanrong; Eeltink, Sebastiaan, Vrije Univ Brussel VUB, Dept Chem Engn, Brussels, Belgium.
   Scheich, David; Lingg, Nico, BOKU Univ, Inst Bioproc Sci \& Engn, Dept Biotechnol \& Food Sci, Vienna, Austria.
   Mitulovic, Goran, Bruker Daltonics Inc, Vienna, Austria.},
DOI = {10.1002/jssc.70340},
Article-Number = {e70340},
Keywords = {biomarker discovery; nano liquid chromatography coupled with mass
   spectrometry (LC-MS); pillar-array column; proteomics; tims-TOF},
Keywords-Plus = {REPRODUCIBILITY; PERFORMANCE; OPTIMIZATION; SENSITIVITY; FABRICATION;
   PROTEINS},
Author-Email = {seeltink@vub.be},
Number-of-Cited-References = {41},
Times-Cited = {0},
Unique-ID = {WOS:001650471000001},
}

@article{ WOS:001673703900001,
Author = {Barough, Siavash Shirzadeh and Bilgel, Murat and Ventura, Catalina and
   An, Lucas and Moghekar, Ameya and Albert, Marilyn S. and Miller, Michael
   I. and Luciano, Mark G. and Moghekar, Abhay},
Title = {Automated deep learning pipeline for callosal angle quantification},
Journal = {FLUIDS AND BARRIERS OF THE CNS},
Year = {2025},
Volume = {23},
Number = {1},
Month = {DEC 27},
Abstract = {Background Normal pressure hydrocephalus (NPH) is a potentially
   treatable neurodegenerative disorder that remains underdiagnosed due to
   its clinical overlap with other conditions and the labor-intensive
   nature of manual imaging analyses. Imaging biomarkers, such as the
   callosal angle (CA), Evans Index (EI), and Disproportionately Enlarged
   Subarachnoid Space Hydrocephalus (DESH), play a crucial role in NPH
   diagnosis but are often limited by subjective interpretations. To
   address these challenges, we developed a fully automated and robust deep
   learning framework for measuring the CA directly from raw T1 MPRAGE
   scans. Methods Our method integrates two complementary modules. First, a
   BrainSignsNET model is employed to accurately detect key anatomical
   landmarks, notably the anterior commissure (AC) and posterior commissure
   (PC). Preprocessed 3D MRI scans, reoriented to the Right Anterior
   Superior (RAS) system and resized to standardized cubes while preserving
   aspect ratios, serve as input for landmark localization. After detecting
   these landmarks, a coronal slice, perpendicular to the AC-PC line at the
   PC level, is extracted for subsequent analysis. Second, a UNet-based
   segmentation network, featuring a pretrained EfficientNetB0 encoder,
   generates multiclass masks of the lateral ventricles from the coronal
   slices which then used for calculation of the CA. Results Training and
   internal validation were performed using datasets from the Baltimore
   Longitudinal Study of Aging (BLSA) and BIOCARD, while external
   validation utilized 376 clinical MRI scans from Johns Hopkins Bayview
   Hospital, as well as PENS trial. Our framework achieved high concordance
   with manual measurements, demonstrating a strong correlation (r = 0.98,
   p < 0.001) and a mean absolute error (MAE) of 3.26 (SD 1.89) degrees.
   Moreover, error analysis confirmed that CA measurement performance was
   independent of patient age, gender, and EI, underscoring the broad
   applicability of this method. Conclusions These results indicate that
   our fully automated CA measurement framework is a reliable and
   reproducible alternative to manual methods, outperforms reported
   interobserver variability in assessing the CA, and offers significant
   potential to enhance early detection and diagnosis of NPH in both
   research and clinical settings.},
Type = {Article},
Affiliation = {Moghekar, A (Corresponding Author), Johns Hopkins Univ, Sch Med, Dept Neurol, Baltimore, MD 21218 USA.
   Barough, Siavash Shirzadeh; Ventura, Catalina; An, Lucas; Moghekar, Ameya; Albert, Marilyn S.; Moghekar, Abhay, Johns Hopkins Univ, Sch Med, Dept Neurol, Baltimore, MD 21218 USA.
   Bilgel, Murat, NIA, Lab Behav Neurosci, NIH, Baltimore, MD 21224 USA.
   Miller, Michael I., Johns Hopkins Univ, Dept Biomed Engn, Baltimore, MD USA.
   Luciano, Mark G., Johns Hopkins Univ, Sch Med, Dept Neurosurg, Baltimore, MD USA.},
DOI = {10.1186/s12987-025-00750-w},
Article-Number = {17},
Keywords = {Callosal angle; Normal pressure hydrocephalus; Neuroimaging; Deep
   learning},
Keywords-Plus = {NORMAL-PRESSURE HYDROCEPHALUS; DIAGNOSIS},
Author-Email = {am@jhmi.edu},
Number-of-Cited-References = {26},
Times-Cited = {0},
Unique-ID = {WOS:001673703900001},
}

@article{ WOS:001655327100001,
Author = {Modirshanechi, Mohammad Javad and Moein-Jahromi, Mahbod and Asghari,
   Saeed and Wei, Lin and Jiang, Fangming and Kermani, M. J.},
Title = {A design framework for parallel serpentine flow fields in PEM fuel
   cells: an integral part of integrated energy solutions},
Journal = {INTERNATIONAL JOURNAL OF HYDROGEN ENERGY},
Year = {2026},
Volume = {203},
Month = {JAN 23},
Abstract = {Proton exchange membrane fuel cells (PEMFCs) are key components of
   integrated energy solutions targeting global carbon neutrality by 2050.
   As the world transitions toward the hydrogen era, PEMFC technology
   cannot remain overlooked; its efficient and durable operation is
   essential for renewable electricity utilization, hydrogen storage, and
   distributed power generation. This study develops a structured,
   filter-based procedure for designing parallel-serpentine flow fields
   (FFs). The workflow, combining eight physical filters, half-cell
   evaluations, and full-cell validation, eliminates over 90 \% of
   non-promising geometries before computationally intensive simulations.
   Out of 9600 anode and 8232 cathode candidates, only three anode-cathode
   configurations (C1-A1, C2-A1, C4-A3) passed an explicit overlapping
   check-up step, a novel methodological addition that ensures geometric
   and hydraulic compatibility between anode and cathode flow fields,
   preventing MEA damage. Full 3-D CFD simulations show that the optimized
   designs enhance limiting current density by 15-38.5 \%, improve reactant
   uniformity, and reduce flooding tendency. The proposed framework
   provides a transparent and reproducible roadmap for rational PEMFC
   flow-field design within integrated renewable-hydrogen systems.},
Type = {Article},
Affiliation = {Kermani, MJ (Corresponding Author), Amirkabir Univ Technol AUT, Tehran Polytech, Dept Mech Engn, 424 Hafez Ave, Tehran 158754413, Iran.
