@article{ WOS:001723626300001,
Author = {Hijjawi, Ula and Lakshminarayana, Subhash and Xu, Tianhua and Rahman,
   Mostafizur},
Title = {A benchmarking study of instance segmentation methods for photovoltaic
   cell defect detection using electroluminescence images},
Journal = {SOLAR ENERGY},
Year = {2026},
Volume = {303},
Month = {JAN},
Abstract = {The efficiency of Photovoltaic (PV) panels is often reduced by defects,
   leading to performance and lifespan issues, and increased financial
   losses. Manual inspection methods are labour-intensive and depend on
   extensive data analysis. Automated defect detection using
   Electroluminescence (EL) imaging has been investigated in the
   literature. However, to the best of the authors' knowledge, no previous
   instance segmentation-based analysis was conducted on PV EL images.
   Moreover, no benchmarking studies have compared instance segmentation
   models using a standardised dataset for PV defect detection. This study
   conducts a comprehensive benchmarking analysis of four instance
   segmentation models, Mask R-CNN, ConvNeXt, ConvNeXt-V2, and Mask2Former
   against all prior works that utilised the same benchmarking dataset. For
   the first time, it pioneers the use of ConvNeXt, ConvNeXt-V2, and
   Mask2Former for PV cell defect detection analysing their architectural
   innovations and performance. Utilising UCF EL Defect as a benchmarking
   dataset (one of the largest pixel-level annotated EL datasets), the
   research categorises defects into cracks, interconnection issues,
   contact defects, and corrosions. Experiments were conducted using the
   MMDetection toolbox, providing a modular and reproducible framework for
   model implementation and evaluation. While instance segmentation was not
   adopted by prior works, results show that ConvNeXt-V2 outperforms all
   other models, achieving a segmentation mean Average Precision (mAP)
   (Intersection over Union (IoU) = 50 \%) of 0.602, segmentation mean IoU
   (mIoU) of 0.650, and bounding box mAP (IoU = 50 \%) of 0.629 making it a
   promising candidate for PV cell defect detection. The code for this work
   has been made public to ensure transparency and reproducibility of the
   results.},
Type = {Article},
Affiliation = {Hijjawi, U (Corresponding Author), Univ Warwick, Sch Engn, Coventry CV4 7AL, England.
   Hijjawi, U (Corresponding Author), Mfg Technol Ctr MTC, Ansty Pk, Coventry CV7 9JU, England.
   Hijjawi, Ula; Lakshminarayana, Subhash; Xu, Tianhua, Univ Warwick, Sch Engn, Coventry CV4 7AL, England.
   Hijjawi, Ula; Rahman, Mostafizur, Mfg Technol Ctr MTC, Ansty Pk, Coventry CV7 9JU, England.},
DOI = {10.1016/j.solener.2025.114083},
Article-Number = {114083},
Keywords = {Defect detection; Photovoltaic; Instance segmentation; Machine learning;
   Artificial intelligence; Image-based analysis; Electroluminescence;
   Benchmarking; Solar module},
Keywords-Plus = {SEMANTIC SEGMENTATION; CLASSIFICATION},
Author-Email = {ula.hijjawi@warwick.ac.uk},
Number-of-Cited-References = {52},
Times-Cited = {1},
