@article{ WOS:001716510500001,
Author = {Mashaka, Gwaliwa P. and Macheyeki, Athanas S.},
Title = {Hybrid GIS-machine learning approach for base metal prospectivity
   mapping in the Gawler Craton, South Australia},
Journal = {JOURNAL OF APPLIED GEOPHYSICS},
Year = {2026},
Volume = {249},
Month = {JUN},
Abstract = {The Gawler Craton in South Australia hosts significant mineral
   resources, yet large areas remain underexplored due to deep cover and
   complex geological architecture. In response to the 2020 Gawler
   Challenge launched by the Government of South Australia, this study
   developed an integrated, data-driven mineral prospectivity framework to
   identify concealed mineralized zones. The primary objective was to
   delineate favorable areas for copper-gold (Cu-Au) mineralization, which
   represents the dominant modelling target and calibration dataset in both
   GIS and machine learning stages. Secondary mineral systems, including
   Fe-Ni-Cu sulfide mineralization and high field strength rare earth
   elements (HFS-REE) enrichment, were incorporated primarily to evaluate
   polymetallic associations and structural overlap rather than as
   independent optimization targets. A hybrid workflow was implemented,
   integrating expert-driven GIS-based multi-criteria decision analysis
   (MCDA) with supervised machine learning classifiers, specifically Random
   Forest (RF) and Support Vector Machine (SVM). High-resolution total
   magnetic intensity (TMI) data, lithological and structural datasets from
   the South Australian Resources Information Gateway (SARIG), and recorded
   mineral occurrences were analyzed using raster-based weighted overlay
   and probabilistic classification techniques. Spatial processing was
   conducted in ArcGIS Pro, whereas data preprocessing and model training
   were implemented in Python. The resulting favorability map delineates a
   dominant N-S-NNE-SSW trending corridor, with the highest-priority zones
   covering approximately 11.6\% of the study area. Three principal
   mineralization models are proposed: (i) Fe-Ni-Cu sulfide systems
   associated with mafic-granitic contacts; (ii) structurally controlled
   Fe-Cu-Au +/- As mineralization along granite margins; and (iii) HFS-REE
   enrichment linked to Neoproterozoic Delamerian granitic intrusions. The
   RF classifier achieved an overall accuracy of 93.3\% and an AUC of 0.97,
   indicating excellent predictive capability. The strong spatial
   convergence between GIS-derived suitability and ML-based probability
   outputs demonstrates the robustness of the hybrid framework. This
   approach provides a reproducible, quantitatively validated
   decision-support tool for mineral exploration targeting in the Gawler
   Craton and comparable data-rich terrains.},
Type = {Article},
Affiliation = {Mashaka, GP (Corresponding Author), Geomira LLC, New York, NY 11214 USA.
   Mashaka, Gwaliwa P., Geomira LLC, New York, NY 11214 USA.
   Mashaka, Gwaliwa P., Tanzania Women Energy, Extract \& Energy, Dar Es Salaam, Tanzania.
   Macheyeki, Athanas S., Univ Dodoma, Dept Geol, Dodoma, Tanzania.},
DOI = {10.1016/j.jappgeo.2026.106183},
EarlyAccessDate = {MAR 2026},
Article-Number = {106183},
Keywords = {Mineral prospectivity mapping; South Australia; Gawler Craton; Machine
   learning; GIS; Random forest; Structural geology; REE; Gold exploration},
Keywords-Plus = {DISTRICT},
Author-Email = {gwaliwa2010@gmail.com},
Number-of-Cited-References = {40},
Times-Cited = {0},
Unique-ID = {WOS:001716510500001},
}

@article{ WOS:001711853200015,
Author = {dos Santos, Anne Caroline Mascarenhas and Liang, Pingdong and Juarez,
   Oscar X. and Pombert, Jean-Francois and Tuz, Karina},
Title = {In vitro culture of human-infecting Encephalitozoon spp.
   for genome sequencing with minimal host contaminant},
Journal = {PLOS ONE},
Year = {2026},
Volume = {21},
Number = {3},
Month = {MAR 11},
Abstract = {Microsporidia are obligate intracellular parasites infecting a wide
   range of hosts, including humans. They can cause severe infectious
   diseases if left untreated, particularly in immunocompromised
   individuals. The propagation of the human-infecting microsporidian
   species in vitro is essential for generating sufficient material for
   genomics studies, yet existing protocols often lack detail,
   accessibility, or strategies to minimize host DNA contamination. Here,
   we present an optimized, reproducible protocol for culturing
   Encephalitozoon spp. in human foreskin fibroblasts (HFF-1), designed to
   produce high-yield and high-quality genomic DNA with minimal host DNA
   for downstream sequencing experiments. In one month, our method yielded
   approximately one billion spores, which were purified using mechanical
   disruption, filtration, detergent treatment, and DNase I treatment to
   remove free host DNA. The reduction of host DNA was validated through
   PCR, and next-generation sequencing - with Illumina, PacBio and Oxford
   Nanopore - revealing that 83-97\% of the reads mapped to microsporidian
   genomes. This protocol enabled the generation of the first
   telomere-to-telomere assemblies for E. cuniculi, E. hellem, and E.
   intestinalis. Our workflow provides a robust framework for producing
   microsporidian genomic material suitable for advanced genomics
   applications, with potential adaptability to other intracellular
   pathogens.},
Type = {Article},
Affiliation = {Tuz, K (Corresponding Author), IIT, Biol Dept, Chicago, IL 60616 USA.
   dos Santos, Anne Caroline Mascarenhas; Liang, Pingdong; Juarez, Oscar X.; Pombert, Jean-Francois; Tuz, Karina, IIT, Biol Dept, Chicago, IL 60616 USA.},
DOI = {10.1371/journal.pone.0344468},
Article-Number = {e0344468},
Keywords-Plus = {CUNICULI},
Author-Email = {ktuz@illinoistech.edu},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001711853200015},
