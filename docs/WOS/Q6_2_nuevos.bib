@article{ WOS:001628371600001,
Author = {Hasan, Md Nazmul and Sharma, Shilpa and Mallen, Justice Josiah and Saha,
   Arjun},
Title = {MnM-W-MMGBSA: A Computational Strategy to Improve Relative Binding Free
   Energies of Protein-Protein Interaction Systems},
Journal = {JOURNAL OF PHYSICAL CHEMISTRY B},
Year = {2025},
Volume = {129},
Number = {49},
Pages = {12685-12701},
Month = {DEC 11},
Abstract = {Protein-protein interactions (PPIs) have become increasingly attractive
   as therapeutic targets due to their central role in regulating cellular
   functions. Despite computational advancements, accurately estimating
   binding free energies for PPIs remains challenging due to the dynamic
   and critically solvent-exposed nature of their interfaces. In this
   study, we present MnM-W-MMGBSA (i.e., MM-GBSA with Mix-and-Match
   sampling and water inclusion), a method that addresses these challenges
   by incorporating both conformational flexibility and interfacial
   solvation effects. We thoroughly demonstrated the applicability of
   MnM-W-MMGBSA across a diverse set of 20 PPI systems and validated its
   robustness using two distinct and rigorous simulation schemes. We
   demonstrate that our protocol improves correlation with experimental
   binding affinities-from 47\% to 70\% with MnM sampling alone for
   standard MM-GBSA, and up to 89\% when interfacial water molecules are
   included. Our approach underscores the pivotal role of individual
   protein dynamics in validating the concept of ``destabilization of
   individual proteins in the unbound form.{''} Specifically, we show that
   in explicit solvent, such destabilization leads to a loss of native
   structure, suggesting that excessive conformational sampling may
   compromise the accuracy of binding affinity predictions. Furthermore,
   the critical role of intrinsically disordered regions in the interface
   of PPIs, as well as the impact of the MnM approach in the pairwise
   per-residue energy decomposition, were also investigated. Finally, our
   implementation overcomes the limitations of the gmx\_MMPBSA tool for
   incorporating explicit solvent molecules from MD simulation trajectories
   into the complex/receptor during MM-GBSA calculation, providing an
   automated and reproducible workflow using GROMACS with AmberTools to
   enable efficient high-throughput screening of protein-protein complexes.
   The protocol is robust, computationally efficient, and applicable to a
   broad range of PPIs. Overall, our protocol offers a practical and
   physically meaningful alternative for estimating the binding affinities
   of PPIs and provides a valuable tool for advancing peptide-based drug
   discovery.},
Type = {Article},
Affiliation = {Saha, A (Corresponding Author), Univ Wisconsin Milwaukee, Dept Chem \& Biochem, Milwaukee, WI 53211 USA.
   Hasan, Md Nazmul; Sharma, Shilpa; Mallen, Justice Josiah; Saha, Arjun, Univ Wisconsin Milwaukee, Dept Chem \& Biochem, Milwaukee, WI 53211 USA.},
DOI = {10.1021/acs.jpcb.5c04085},
EarlyAccessDate = {NOV 2025},
Keywords-Plus = {BOLTZMANN SURFACE-AREA; STRUCTURAL BASIS; MOLECULAR-DYNAMICS;
   CRYSTAL-STRUCTURE; WATER-MOLECULES; X-RAY; COMPLEX; INHIBITOR;
   RECOGNITION; PERFORMANCE},
Author-Email = {saha6@uwm.edu},
Number-of-Cited-References = {109},
Times-Cited = {2},
Unique-ID = {WOS:001628371600001},
}

@article{ WOS:001632134700004,
Author = {Chang, Yen-Wei and Kuo, Keona P. and Lu, Yen-Wen},
Title = {In-line monitoring permeation assays using a wax-sealed SPE-integrated
   microfluidic device},
Journal = {SENSORS AND ACTUATORS B-CHEMICAL},
Year = {2026},
Volume = {450},
Month = {MAR 1},
Abstract = {In-line monitoring of microfluidic devices often requires manual sensor
   integration, limiting scalability for industrial applications. To
   address this challenge, this study presents an automatable wax sealing
   method for integrating screen-printed electrodes (SPEs) into 3D-printed
   microfluidic devices. Molten wax fills the gap between the SPE and
   device body, while a meniscus pinning mechanism prevents wax intrusion
   into the microchannels. As the wax cools, it forms a secure and
   reversible seal, enabling real-time electrochemical monitoring within
   the microfluidic platform. The device shows a limit of detection (LOD)
   of 1.06 mu g/mL when sensing K3{[}Fe (CN)6], comparable to the open
   environment LOD of 1.92 mu g/mL. In permeation assays, the system yields
   a release profile consistent with a theoretical mass transport model,
   achieving a relative standard deviation (RSD) as low as 2.1 \%,
   demonstrating high reproducibility. The platform is relevant for
   transdermal drug testing and quality control, but can also be adapted
   for diagnostic or environmental monitoring applications. The device
   shows the potential to enhance real-time analysis and accelerate product
   development in various sensing domains.},
Type = {Article},
Affiliation = {Lu, YW (Corresponding Author), Natl Taiwan Univ, Dept Biomechatron Engn, Taipei, Taiwan.
   Lu, YW (Corresponding Author), Natl Taiwan Univ, Inst Biotechnol, Taipei, Taiwan.
   Chang, Yen-Wei; Lu, Yen-Wen, Natl Taiwan Univ, Dept Biomechatron Engn, Taipei, Taiwan.
   Lu, Yen-Wen, Natl Taiwan Univ, Inst Biotechnol, Taipei, Taiwan.
   Kuo, Keona P., MIT, Dept Biol Engn, Cambridge, MA USA.},
DOI = {10.1016/j.snb.2025.139205},
EarlyAccessDate = {NOV 2025},
Article-Number = {139205},
Keywords = {In-line monitoring; Meniscus pinning; Wax sealing; Electrochemical
   sensing; Permeation assay},
Keywords-Plus = {TORTUOSITY; DIFFUSION; PLATFORM},
Author-Email = {yenwenlu@ntu.edu.tw},
Number-of-Cited-References = {49},
