   Ma, Yingjie, Zhejiang Univ, Sch Literature, Hangzhou, Peoples R China.
   Bao, Shuming, China Data Inst, Ann Arbor, MI USA.},
DOI = {10.1080/19475683.2026.2617239},
EarlyAccessDate = {FEB 2026},
