   Batool, Razia; Singh, Rukmani; Sterman, Raquel G.; Lechuga, Laura M.; Soler, Maria, Catalan Inst Nanosci \& Nanotechnol ICN2, CSIC, BIST, Nanobiosensors \& Bioanalyt Applicat Grp NanoB2A, Barcelona 08193, Spain.
   Batool, Razia; Singh, Rukmani; Sterman, Raquel G.; Lechuga, Laura M.; Soler, Maria, CIBER BBN, Barcelona 08193, Spain.},
DOI = {10.1088/2515-7647/ae3ec0},
Article-Number = {015056},
Keywords = {nanophotonic sensor; photonic resonators; colloidal lithography;
   nanofabrication; label-free detection; supported lipid bilayer},
Keywords-Plus = {INDEX},
Author-Email = {maria.soler@icn2.cat},
