   Yi, Won-Jin; Heo, Min-Suk, Seoul Natl Univ, Dept Oral \& Maxillofacial Radiol, 101 Daehak Ro, Seoul 03080, South Korea.},
DOI = {10.1016/j.identj.2025.109381},
