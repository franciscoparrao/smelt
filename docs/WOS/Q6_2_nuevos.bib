@article{ WOS:001617880400001,
Author = {Tian, Shuo and Li, Sainan and Park, Jisu and Bae, Jong-sup and Na,
   Minkyun},
Title = {Integrated Extraction Optimization and HPLC-based Quality Evaluation of
   Thiophenes from Tagetes erecta Roots},
Journal = {ANALYTICAL SCIENCE ADVANCES},
Year = {2025},
Volume = {6},
Number = {2},
Month = {NOV 17},
Abstract = {Tagetes erecta L. is widely studied for its flower-derived lutein, which
   is known for promoting eye health. However, its roots contain uniquely
   thiophenes-absent from the flowers and leaves-which exhibit valuable
   bioactivity. Our recent study has reported on patent applications
   related to their efficacy in modulating benign prostatic hyperplasia,
   underscoring their pharmaceutical and functional potential. Despite
   this, no optimized extraction or quality evaluation of thiophene-rich T.
   erecta roots has been reported. This study aimed to establish a reliable
   extraction strategy for thiophene-rich T. erecta roots and to ensure
   chemical consistency through validated HPLC quantification and
   chromatographic fingerprint similarity analysis. Three major
   thiophenes-5-(4-hydroxybut-1-ynyl)-2,2'-bithiophene (1),
   5-(4-acetoxybut-1-ynyl)-2,2'-bithiophene (2) and
   5-(3-buten-1-ynyl)-2,2'-bithiophene (3)-were isolated and structurally
   confirmed. The extraction variables (solvent, plant part, method, sample
   amount and time) were optimized. Quantification was performed via
   validated HPLC-PDA using in-house purified standards (>= 98\%), and
   fingerprint similarity was evaluated. Ultrasonic extraction for 2 h with
   5 g of root powder in 95\% ethanol gave optimal yield and
   reproducibility. The HPLC method exhibited excellent linearity (R-2 >
   0.999), precision (RSD < 1\%) and recovery (93.20\%-105.24\%).
   Fingerprint analysis of 13 common peaks revealed high similarity
   (0.984-1.000), indicating stable chemical profiles. This study provides
   a validated workflow for thiophene-rich T. erecta roots, highlights the
   significance of root-derived thiophenes and offers a practical basis for
   process development, quality control and future standardization of
   thiophenes and related constituents.},
Type = {Article},
Affiliation = {Na, M (Corresponding Author), Chungnam Natl Univ, Coll Pharm, Daejeon, South Korea.
   Tian, Shuo; Li, Sainan; Park, Jisu; Na, Minkyun, Chungnam Natl Univ, Coll Pharm, Daejeon, South Korea.
   Bae, Jong-sup, Kyungpook Natl Univ, Coll Pharm, Daegu, South Korea.},
DOI = {10.1002/ansa.70055},
Article-Number = {e70055},
Keywords = {chromatographic fingerprint; extraction optimization; HPLC
   quantification; Tagetes erecta; thiophenes},
Keywords-Plus = {ESSENTIAL OIL},
Author-Email = {mkna@cnu.ac.kr},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001617880400001},
}

@article{ WOS:001616094000001,
Author = {Bruhlmann, Santiago Andres and Walther, Martin and Zhutova, Nadiya and
   Kopka, Klaus and Kreller, Martin},
Title = {From bench to batch: scaling up copper-67 production via the
   70Zn(p,α)67Cu nuclear reaction},
Journal = {RADIOCHIMICA ACTA},
Year = {2026},
Volume = {114},
Number = {2},
Pages = {85-94},
Month = {FEB 24},
Abstract = {In this work, we present a novel radiochemical separation method for
   isolating radiocopper from zinc targets, in particular optimized for use
   in compact cyclotron systems for Cu-67 production from Zn-70. We further
   report - for the first time using compact cyclotrons - Cu-67 yields in
   the GBq range, with molar activities reaching 5-35 \% of the theoretical
   maximum. In addition, high radionuclidic purities comparable to
   previously described values are presented (>99 \%). The complete
   workflow, including target preparation, irradiation parameters,
   post-irradiation handling, and quality control, is described in detail,
   offering a robust and reproducible framework for advancing a reliable
   Cu-67 production in decentralized settings.},
