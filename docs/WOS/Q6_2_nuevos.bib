   Zhou, Tingting, Jinan Univ, Inst Hydrobiol, Guangzhou, Peoples R China.
   He, Dekui, Chinese Acad Sci, Inst Hydrobiol, Museum Aquat Organisms, Wuhan 430072, Hubei, Peoples R China.},
DOI = {10.1111/jbi.70181},
Article-Number = {e70181},
Keywords = {cryptic species; genetic diversity; Lumbriculus variegatus; MaxEnt;
   niche divergence},
Keywords-Plus = {GENETIC-VARIATION; PHYLOGEOGRAPHY; TUBIFEX},
Author-Email = {wujy@ihb.ac.cn
   ydcui@ihb.ac.cn},
