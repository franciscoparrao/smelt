   Cheng, Rui; Zhang, Zijie Scott; Yang, Wei, Yunnan Vaccine Lab, Kunming, Yunnan, Peoples R China.
   Li, Jingxin, Nanjing Med Univ, Sch Publ Hlth, Natl Vaccine Innovat Platform, 101 Longmian Ave, Nanjing 211166, Jiangsu, Peoples R China.
   Li, Jingxin, Jiangsu Prov Acad Prevent Med, Jiangsu Prov Med Innovat Ctr, Jiangsu Prov Ctr Dis Control \& Prevent, Natl Hlth Commiss Key Lab Enter Pathogen Microbiol, Nanjing, Jiangsu, Peoples R China.},
DOI = {10.1080/21645515.2025.2610068},
