Keywords = {Multiple sclerosis; Artificial intelligence; Brain atrophy; Lesion
   dynamics; Radiological phenotyping; Quantitative MRI},
Keywords-Plus = {FOLLOW-UP; RELAPSE ONSET; MRI; MS; DISABILITY; ATROPHY; SEVERITY},
