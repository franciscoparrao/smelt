   Burgess, Steven, Univ Illinois, Dept Plant Sci, Urbana, IL 61801 USA.
   Burgess, Steven, Univ Illinois, Carl R Woese Inst Genom Biol, Urbana, IL 61801 USA.},
DOI = {10.1186/s41073-026-00188-0},
Article-Number = {6},
Keywords = {QPCR; Plant science; Genetics; Reporting standards; Meta-research;
