@article{ WOS:001707182300001,
Author = {Adamson, Morgan N. and Cottle, John M. and Kylander-Clark, Andrew R. C.},
Title = {A Mechanistic study of matrix effects in zircon U-Th/Pb geochronology
   using single-particle laser ablation time-of-flight mass spectrometry},
Journal = {CHEMICAL GEOLOGY},
Year = {2026},
Volume = {707},
Month = {APR 20},
Abstract = {Uncorrected elemental fractionation during ablation or `matrix effects'
   limit the reproducibility of laser ablation zircon U-Th/Pb geochronology
   to similar to 2\%. Single-particle laser ablation inductively coupled
   plasma time-of-flight mass spectrometry (SP-LA-ICP-ToF-MS) directly
   tracks particle size and composition during laser ablation, offering a
   new approach to characterize particle generation and transport
   processes, both of which significantly contribute to matrix effects.
   Using SP-LA-ICP-ToF-MS, we compared untreated and chemically abraded
   reference zircons, Plesovice and 91,500, to evaluate particle-dependent
   fractionation during static ablation. We find that Hf-bearing
   (zircon-proxy) and Hf-lacking (oxide-proxy) particles exhibit distinct
   transport behaviors. Zircon particles are depleted in volatile elements
   and selectively transmitted to the ICP-MS, while oxide particles are
   enriched in volatile elements and preferentially deposited on the sample
   surface. We attribute this differential behavior between particle types
   to contrasting particle ejection and transport efficiencies, with small,
   volatile-rich particles more likely to condense onto the sample surface.
   We estimate that generated zircon particles are on average 0.366 +/-
   0.173 (1 sigma) mu m and oxide particles are on average 0.031 +/- 0.011
   (1 sigma) mu m in diameter. Although both reference zircons are
   nominally ZrSiO4, under identical ablation conditions they generate
   distinct particle compositions and particle size distributions. These
   contrasting laser-induced elemental fractionation behaviors bias
   measured dates by sequestering lead to the sample surface, manifesting
   as apparent `Pb loss', even in chemically abraded zircons. The workflow
   presented here establishes a new framework for studying internal and
   external particle-controlled elemental fractionation during laser
   ablation U-Th/Pb geochronology and presents a pathway to reduce the 2\%
   reproducibility barrier.},
Type = {Article},
Affiliation = {Adamson, MN (Corresponding Author), Univ Calif Santa Barbara, Dept Earth Sci, 1006 Webb Hall, Santa Barbara, CA 93106 USA.
   Adamson, Morgan N.; Cottle, John M.; Kylander-Clark, Andrew R. C., Univ Calif Santa Barbara, Dept Earth Sci, 1006 Webb Hall, Santa Barbara, CA 93106 USA.},
DOI = {10.1016/j.chemgeo.2026.123325},
Article-Number = {123325},
Keywords = {U-Th/Pb geochronology; Laser ablation; Single-particle; Zircon;
   LA-ICP-ToF-MS},
Keywords-Plus = {INDUCTIVELY-COUPLED PLASMA; ICP-MS; ELEMENTAL FRACTIONATION; ISOTOPIC
   FRACTIONATION; SIZE DISTRIBUTION; 266 NM; HIGH-RESOLUTION; HIGH-SPEED;
   PB; ACCURACY},
Author-Email = {mna@ucsb.edu},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001707182300001},
}

@article{ WOS:001700416100001,
Author = {Norouzi, Saber and Alavi-Rad, Hosein and Amiri, Seyed Saleh Ghoreishi
   and Yousefi, Reza and Dehbovid, Hadi},
Title = {Patterned graphene absorber for toxic gas sensing: Machine learning
   approach},
Journal = {SENSORS AND ACTUATORS A-PHYSICAL},
Year = {2026},
Volume = {401},
Month = {APR 16},
Abstract = {The detection of toxic gases like methane (CH4) is critical for
   environmental and industrial safety, yet current sensors often lack the
   sensitivity, speed, or form factor for next-generation applications.
   This work presents a unified, physics-informed framework for the rapid
   design and optimization of a flexible, multi-layer patterned graphene
   absorber for high-sensitivity toxic gas sensing in the terahertz (THz)
   regime. The proposed structure, comprising stacked graphene disks on a
   Kapton spacer backed by a gold reflector, is analytically modeled using
   an equivalent circuit, validated with full-wave electromagnetic
   simulation, and leveraged within a machine learning (ML) pipeline for
   inverse design. We systematically benchmark seven regression models on a
   large synthetic dataset (>50,000 points) to predict absorption
   performance, identifying the Extra Trees (ET) regressor as the most
   robust predictor (Adjusted-R \& sup2; > 0.9995). This integrated
   ECM-FEM-ML workflow demonstrates a dramatic reduction in design
   iteration time compared to conventional simulation-heavy approaches. The
   absorber exhibits near-unity absorption, high tunability, and
   exceptional sensitivity to the surrounding refractive index. As a
   concrete application, we demonstrate the sensor's capability to detect
   CH4 concentrations from 10 to 500 ppm, observed through measurable
   absorption band broadening and frequency red-shifts. The corrected
   sensitivity is quantified as 0.3 GHz/ppm (300 MHz/ppm), which aligns
   with recent experimental demonstrations of graphene-based THz gas
   sensors. ML accelerates absorber design and emulates FEM; gas detection
   is achieved via demonstrated refractive index sensitivity (10-500 ppm
   CH4). This study establishes an efficient, data-driven methodology for
   developing high-performance, application-specific graphene-based THz
   sensors for wearable and environmental monitoring.},
Type = {Article},
Affiliation = {Alavi-Rad, H (Corresponding Author), Islamic Azad Univ, Dept Elect Engn, Lan C, Langarud, Iran.
   Norouzi, Saber; Amiri, Seyed Saleh Ghoreishi; Yousefi, Reza; Dehbovid, Hadi, Islamic Azad Univ, Dept Elect Engn, No C, Nour, Iran.
   Alavi-Rad, Hosein, Islamic Azad Univ, Dept Elect Engn, Lan C, Langarud, Iran.},
DOI = {10.1016/j.sna.2026.117622},
Article-Number = {117622},
Keywords = {Graphene; Machine Learning (ML); Wave Absorption; Toxic gas detection;
   Methane sensing; Refractive index sensor},
Author-Email = {SaberNorouzi@iau.ac.ir
   Ho.Alavirad@iau.ac.ir
   Ss.Ghoreishi@iau.ac.ir
   R.Yousefi@iau.ac.ir
   Hadi.Dehbovid@iau.ac.ir},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001700416100001},
}

@article{ WOS:001718365400001,
Author = {Jali, Vidishaa and Li, Lucia and Qi, Toh An and Tanaka, Tomotaka and
   Hilal, Saima and Gyanwali, Bibek and Chen, Christopher Li-Hsian and
   Ngam, Pei Ing},
Title = {Comparative analysis of Heuron Brain PET and FreeSurfer software in
   automated amyloid quantification: Toward reproducible and clinically
   applicable brain PET imaging},
Journal = {NEUROIMAGE},
Year = {2026},
Volume = {330},
Month = {APR 15},
Abstract = {Purpose: Beta-amyloid (A beta) plaque accumulation is a hallmark of
   Alzheimer's disease (AD) and can be evaluated using positron emission
   tomography (PET). While visual assessment is standard in clinical
   settings, quantitative methods such as standardized uptake value ratios
   (SUVR) may improve diagnostic accuracy and reproducibility. This study
   aimed to compare the quantification and diagnostic performance of Heuron
   Brain PET, a recently developed clinical tool, with FreeSurfer, a
   well-validated research platform, in assessing A beta deposition.
   Methods: A total of 205 amyloid PET scans (176 {[}\& sup1;\& sup1;C]PiB
   + 29 {[}\& sup1;F-8]Flutafuranol) were analyzed using both Heuron Brain
   PET and FreeSurfer. SUVRs were calculated using cerebellar grey matter
   as the reference region. Diagnostic thresholds were determined, and
   regional/global SUVRs were compared using paired t-tests and correlation
   analysis. Diagnostic performance was evaluated using receiver operating
   characteristic (ROC) analysis. Reproducibility was assessed on a
   randomly selected subset (n = 50) using intraclass correlation
   coefficients (ICC). Results: For {[}\& sup1;\& sup1;C]PiB, Heuron Brain
   PET yielded slightly lower global SUVRs than FreeSurfer (1.32 +/- 0.34
   vs. 1.40 +/- 0.41; p < 0.001), but showed very strong correlation (r =
   0.960, p < 0.001). AUCs were comparable (Heuron: 0.988; FreeSurfer:
   0.979; p = 0.401). ICC for reproducibility was perfect across all
   regions (ICC = 1.00, 95\% CI {[}1.00, 1.00], p < 0.001). Results for
   {[}\& sup1;F-8]Flutafuranol were less consistent due to small sample
   size. Conclusion: Heuron Brain PET demonstrates comparable SUVR
   quantification and diagnostic performance to FreeSurfer for {[}\&
   sup1;\& sup1;C]PiB PET, with excellent reproducibility and rapid
   analysis, supporting its potential for routine clinical application.},
Type = {Article},
Affiliation = {Ngam, PI (Corresponding Author), Natl Univ Singapore Hosp, Dept Diagnost Imaging, Singapore, Singapore.
   Jali, Vidishaa; Li, Lucia; Qi, Toh An; Tanaka, Tomotaka; Hilal, Saima; Gyanwali, Bibek; Chen, Christopher Li-Hsian, Natl Univ Singapore, Yong Loo Lin Sch Med, Dept Pharmacol, Singapore, Singapore.
   Tanaka, Tomotaka, Natl Cerebral \& Cardiovasc Ctr, Dept Neurol, 6-1 Kishibe Shimmachi, Suita, Osaka 5648565, Japan.
   Hilal, Saima, Natl Univ Singapore, Saw Swee Hock Sch Publ Hlth, Singapore, Singapore.
   Hilal, Saima, Natl Univ Hlth Syst, Singapore, Singapore.
   Ngam, Pei Ing, Natl Univ Singapore Hosp, Dept Diagnost Imaging, Singapore, Singapore.},
DOI = {10.1016/j.neuroimage.2026.121844},
Article-Number = {121844},
Keywords = {Amyloid PET; SUVR quantification; Heuron brain PET; FreeSurfer;
   Diagnostic reproducibility},
Keywords-Plus = {ALZHEIMERS-DISEASE; C-11-PIB PET; DEPOSITION; MODEL},
Author-Email = {pei\_ing\_ngam@nuhs.edu.sg},
Number-of-Cited-References = {27},
