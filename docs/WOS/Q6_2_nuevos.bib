@article{ WOS:001666951900008,
Author = {Miyaji, Renato Okabayashi and Valencia De Almeida, Felipe and Luiz
   Pizzigatti Correa, Pedro},
Title = {Standardized ML and XAI Workflow for Presence-Only Species Distribution
   Modeling: A Case Study in the Amazon},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {8344-8353},
Abstract = {The convergence of Machine Learning (ML) and ecology has provided
   powerful tools for Species Distribution Modeling (SDM). However, the
   application of complex algorithms to presence-only data often lacks
   methodological standardization and interpretability. This study proposes
   a comprehensive and standardized workflow that integrates robust
   pseudo-absence generation strategies with Explainable Artificial
   Intelligence (XAI) to enhance the reliability of SDMs. We evaluated four
   distinct pseudo-absence selection methods-Random, Spatially Constrained,
   Environmentally Dissimilar, and a Three-Step Methodology-across
   different classifiers, utilizing a dual-metric framework that
   prioritizes the False Negative Rate (FNR) for consistency and the True
   Skill Statistic (TSS) for discriminatory power. The workflow was
   validated through a case study involving Tyrannidae and Thraupidae bird
   families in the Amazon, incorporating anthropogenic variables from the
   GoAmazon campaign. Our results demonstrate that the choice of
   pseudo-absence strategy is a critical determinant of model performance,
   with the Three-Step Methodology combined with Support Vector Machines
   achieving the optimal balance between sensitivity and specificity.
   Furthermore, the application of post-hoc XAI techniques, including SHAP
   and LIME, confirmed the ecological validity of the models by revealing
   biologically meaningful relationships between species distribution and
   environmental predictors, such as atmospheric pollutants. This work
   provides a reproducible pipeline that mitigates the closed box nature of
   ML models, offering a transparent and effective tool for biodiversity
   conservation and environmental planning.},
Type = {Article},
Affiliation = {Miyaji, RO (Corresponding Author), Univ Sao Paulo, Escola Politecn, Dept Comp Engn \& Digital Syst, BR-05508010 Sao Paulo, SP, Brazil.
   Miyaji, Renato Okabayashi; Valencia De Almeida, Felipe; Luiz Pizzigatti Correa, Pedro, Univ Sao Paulo, Escola Politecn, Dept Comp Engn \& Digital Syst, BR-05508010 Sao Paulo, SP, Brazil.},
DOI = {10.1109/ACCESS.2026.3652949},
Keywords = {Biological system modeling; Measurement; Predictive models; Standards;
   Accuracy; Explainable AI; Data models; Environmental management;
   Atmospheric modeling; Closed box; Species distribution modeling; machine
   learning; explainable artificial intelligence},
Keywords-Plus = {PSEUDO-ABSENCES; SUPPORT},
Author-Email = {re.miyaji@usp.br},
Number-of-Cited-References = {27},
Times-Cited = {0},
Unique-ID = {WOS:001666951900008},
}

@article{ WOS:001682700300030,
Author = {Biswas, Ayan and Turton, Terece L. and Ranasinghe, Nishath Rajiv and
   Jones, Shawn and Love, Bradley and Jones, William and Hagberg, Aric and
   Shen, Han-Wei and Debardeleben, Nathan and Lawrence, Earl},
Title = {VizGenie: Toward Self-Refining, Domain-Aware Workflows for
   Next-Generation Scientific Visualization},
Journal = {IEEE TRANSACTIONS ON VISUALIZATION AND COMPUTER GRAPHICS},
Year = {2026},
Volume = {32},
Number = {1},
Pages = {1021-1031},
Month = {JAN},
Abstract = {We present VizGenie, a self-improving, agentic framework that advances
   scientific visualization through large language model (LLM) by
   orchestrating of a collection of domain-specific and dynamically
   generated modules. Users initially access core functionalities-such as
   threshold-based filtering, slice extraction, and statistical
   analysis-through pre-existing tools. For tasks beyond this baseline,
   VizGenie autonomously employs LLMs to generate new visualization scripts
   (e.g., VTK Python code), expanding its capabilities on-demand. Each
   generated script undergoes automated backend validation and is
   seamlessly integrated upon successful testing, continuously enhancing
   the system's adaptability and robustness. A distinctive feature of
   VizGenie is its intuitive natural language interface, allowing users to
   issue high-level feature-based queries (e.g., ``visualize the skull{''}
   or ``highlight tissue boundaries{''}). The system leverages image-based
   analysis and visual question answering (VQA) via fine-tuned vision
   models to interpret these queries precisely, bridging domain expertise
   and technical implementation. Additionally, users can interactively
   query generated visualizations through VQA, facilitating deeper
   exploration. Reliability and reproducibility are further strengthened by
   Retrieval-Augmented Generation (RAG), providing context-driven responses
   while maintaining comprehensive provenance records. Evaluations on
   complex volumetric datasets demonstrate significant reductions in
   cognitive overhead for iterative visualization tasks. By integrating
   curated domain-specific tools with LLM-driven flexibility, VizGenie not
   only accelerates insight generation but also establishes a sustainable,
   continuously evolving visualization practice. The resulting platform
   dynamically learns from user interactions, consistently enhancing
   support for feature-centric exploration and reproducible research in
   scientific visualization.},
Type = {Article},
Affiliation = {Biswas, A (Corresponding Author), Los Alamos Natl Lab, Los Alamos, NM 87545 USA.
   Biswas, Ayan; Turton, Terece L.; Ranasinghe, Nishath Rajiv; Jones, Shawn; Love, Bradley; Hagberg, Aric; Debardeleben, Nathan; Lawrence, Earl, Los Alamos Natl Lab, Los Alamos, NM 87545 USA.
   Jones, William, Coastal Carolina Univ, Conway, SC 29528 USA.
   Shen, Han-Wei, Ohio State Univ, Chillicothe, OH USA.},
DOI = {10.1109/TVCG.2025.3634655},
Keywords = {Data visualization; Natural languages; Iterative methods;
   Reproducibility of results; Codes; Question answering (information
   retrieval); Large language models; Visual analytics; Three-dimensional
   displays; Robustness; Scientific data; Agentic workflows; Natural
   language; Feature-based visualization},
Keywords-Plus = {OF-THE-ART; VOLUME VISUALIZATION; VEGA},
