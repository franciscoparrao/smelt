   Kolek, Stefan; Stewart, Patrick D. Shaw, Douglas Instruments Ltd, East Garston, Hungerford RG17 7HD, England.},
DOI = {10.1107/S2052252526000448},
Keywords = {serial crystallography; sample preparation; phase diagrams;
   microcrystals; microbatch-under-oil; seeding; optimization},
Keywords-Plus = {PROTEIN CRYSTALLIZATION; DATA-COLLECTION; SYNCHROTRON; NUCLEATION;
   MICROCRYSTALS; OPTIMIZATION; CRYSTALS},
