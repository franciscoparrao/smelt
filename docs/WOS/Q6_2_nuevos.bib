@article{ WOS:001631079200001,
Author = {Schroeter, Christina B. and Wei, Ting-Yu and Paulo, Joao A.},
Title = {Evaluating the Robustness of Micro-Pillar Array Columns for Quantitative
   Proteomics Applications},
Journal = {JOURNAL OF PROTEOME RESEARCH},
Year = {2026},
Volume = {25},
Number = {1},
Pages = {498-505},
Month = {JAN 2},
Abstract = {Nanoflow liquid chromatography capable of delivering consistent and
   reliable results across extensive sample sets is essential for the
   advancement of mass spectrometry-based proteomics. Micro-Pillar Array
   Columns (mu PACs) represent a significant breakthrough, offering
   durability and performance stability. Here, we evaluate the robustness
   of mu PACs by comparing a column used continuously for over 16 months
   with more than 7000 injections (mu PAC1) to a nearly new column (mu
   PAC2). Analysis of two TMT-labeled yeast TKO standards (TKOpro10u, a
   10-plex unit-resolved standard; and TKOpro12, a 12-plex
   isotopolog-inclusive standard) showed that mu PAC1 and mu PAC2 yielded
   comparable numbers of unique peptides and proteins, exhibited similar
   reproducibility, and delivered equivalent chromatographic and spectral
   quality. Notably, these data showed that mu PAC1 maintained high
   performance with minimal degradation of data quality, highlighting the
   exceptional durability of the mu PAC technology. These findings
   underscore that mu PAC can contribute to reducing workflow disruptions
   in high-throughput analytical workflows, particularly in proteomics
   workflows that utilize mass spectrometry.},
Type = {Article},
Affiliation = {Paulo, JA (Corresponding Author), Harvard Med Sch, Dept Cell Biol, Boston, MA 02115 USA.
   Schroeter, Christina B.; Wei, Ting-Yu; Paulo, Joao A., Harvard Med Sch, Dept Cell Biol, Boston, MA 02115 USA.
   Schroeter, Christina B., Heinrich Heine Univ, Med Fac, Dept Neurol, D-40225 Dusseldorf, Germany.
   Schroeter, Christina B., Heinrich Heine Univ, Univ Hosp Dusseldorf, D-40225 Dusseldorf, Germany.},
DOI = {10.1021/acs.jproteome.5c00892},
EarlyAccessDate = {DEC 2025},
Keywords = {mu PAC; LC-MS/MS; TMTpro; columndurability; chromatography},
Keywords-Plus = {DECOY SEARCH STRATEGY; MASS},
Author-Email = {joao\_paulo@hms.harvard.edu},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001631079200001},
}

@article{ WOS:001630676200001,
Author = {Feng, Zikang and Zheng, Lina and Liu, Dou},
Title = {Analytical performance and calibration strategies of low-cost
   particulate matter sensors for indoor and workplace monitoring-a review},
Journal = {ANALYTICAL METHODS},
Year = {2026},
Volume = {18},
Number = {1},
Pages = {39-52},
Month = {JAN 9},
Abstract = {This review summarizes current evidence on low-cost particulate matter
   (PM) sensors for indoor and occupational environments and proposes a
   framework that links performance evaluation, calibration, and
   uncertainty to decision-making. Results from laboratory and field
   co-locations are synthesized to define reporting standards-accuracy,
   precision, dynamic range, detection capability, and temporal
   response-and to compare calibration strategies. Optical sensors
   consistently capture temporal dynamics of indoor sources but show mass
   bias that depends on concentration range, aerosol composition, and
   humidity. Context-specific reporting, with conditioning on environmental
   state and source regime, is therefore essential. Calibration practices
   range from simple linear corrections, often adequate at low to moderate
   concentrations, to multivariate or nonlinear models incorporating
   humidity, temperature, or volatile organic compounds, which reduce
   residual bias under high or mixed-source loadings. A staged quality
   assurance and quality control workflow-including procurement screening,
   bench checks, co-location with blocked validation, external validation
   for transportability, and rotating ``gold-node{''} drift checks-ensures
   reproducibility and decision-relevant uncertainty. Deployment studies
   demonstrate that event-aware sensor networks can support targeted
   ventilation and filtration, reducing exceedance time and cumulative
   exposure without unnecessary energy use. Standardized reporting tables,
   model versioning, applicability limits, and anomaly-handling rules
   further enhance reliability and governance. Overall, low-cost PM sensors
   can provide decision-relevant data when embedded in calibrated,
   uncertainty-aware pipelines with explicit scope statements. While
   reference-grade methods remain necessary for compliance, calibrated
   networks are well suited to hotspot detection, intervention design, and
   operational optimization in buildings and workplaces.},
Type = {Review},
Affiliation = {Zheng, LA (Corresponding Author), China Univ Min \& Technol, Jiangsu Engn Res Ctr Dust Control \& Occupat Protec, Xuzhou, Peoples R China.
   Zheng, LA (Corresponding Author), China Univ Min \& Technol, Sch Safety Engn, Xuzhou, Peoples R China.
   Zheng, LA (Corresponding Author), China Univ Min \& Technol, Inst Occupat Hlth, Xuzhou, Peoples R China.
   Zheng, Lina, China Univ Min \& Technol, Jiangsu Engn Res Ctr Dust Control \& Occupat Protec, Xuzhou, Peoples R China.
   Feng, Zikang; Zheng, Lina; Liu, Dou, China Univ Min \& Technol, Sch Safety Engn, Xuzhou, Peoples R China.
   Zheng, Lina, China Univ Min \& Technol, Inst Occupat Hlth, Xuzhou, Peoples R China.},
DOI = {10.1039/d5ay01554e},
EarlyAccessDate = {DEC 2025},
Keywords-Plus = {AIR; PARTICLES; DEPOSITION; AEROSOL; PM2.5; INFLAMMATION; HUMIDITY;
   EXPOSURE},
Author-Email = {zhenglina@cumt.edu.cn},
Number-of-Cited-References = {89},
