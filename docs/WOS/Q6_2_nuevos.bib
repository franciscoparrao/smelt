@article{ WOS:001688315600001,
Author = {Lighittha, Pr and Prithivraj, S. and Sangeetha, Rg},
Title = {FireAntGA-ImmunoModel: An explainable bio-inspired hybrid framework for
   optimized immunodiagnostic classification},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {Drug-induced autoimmunity (DIA) remains difficult to screen reliably due
   to three persistent challenges: (i) severe class imbalance between
   DIA-positive and DIA-negative compounds, (ii) high-dimensional and
   highly collinear molecular descriptors, and (iii) the need for
   transparent, auditor-grade decision support in biomedical settings.
   While recent bio-inspired deep learning frameworks such as
   DeepAIPs-SFLA, pACPs-DNN, pNPsCapsNet, and TargetCLP have achieved
   strong performance on peptide- and protein-sequence prediction tasks,
   their architectures assume feature modalities fundamentally different
   from small-molecule DIA data, often emphasize model depth over
   interpretability, and typically lack robustness and computational
   complexity reporting.To address these gaps, the proposed
   FireAntGA-ImmunoModel, a unified, explainable, bio-inspired pipeline is
   tailored for small-molecule DIA prediction. The framework integrates
   Firefly-guided SMOTE to generate biologically plausible minority-class
   samples, SHAP-informed Ant Colony Optimization to derive compact and
   discriminative subsets from 196 RDKit molecular descriptors, and a
   multi-objective Genetic Algorithm to jointly optimize Random Forest
   hyperparameters with respect to F1-score, ROC-AUC, and feature
   sparsity.Evaluated on the InterDIA benchmark, the proposed method
   achieves a ROC-AUC of 0.945 and an F1score of 0.854, outperforming
   classical descriptor-based feature selection approaches including PCA,
   mRMR, and L1-regularization, particularly in minority-class recall. In
   addition, the framework reports multi-seed performance statistics (mean,
   standard deviation, and best-worst outcomes) and stage-wise runtime
   analysis, ensuring methodological transparency and reproducibility.While
   peptide-centric deep learning models remain highly effective in
   sequence-based settings, FireAntGA-ImmunoModel demonstrates that a
   computationally efficient, interpretable, descriptor-based framework can
   achieve competitive performance for small-molecule DIA prediction. The
   proposed approach provides end-to-end explainability and is well suited
   for deployment in clinical and regulatory screening workflows. Code and
   protocols are publicly available at: https://github.com/Lig17/F
   ireANTGAImmunoModel.},
Type = {Article},
Affiliation = {Sangeetha, R (Corresponding Author), Vellore Inst Technol, Sch Elect Engn, Chennai, India.
   Lighittha, Pr; Prithivraj, S.; Sangeetha, Rg, Vellore Inst Technol, Sch Elect Engn, Chennai, India.},
DOI = {10.1016/j.rineng.2026.109267},
EarlyAccessDate = {FEB 2026},
Article-Number = {109267},
Keywords = {Automatic Classification; Immunodiagnosis; FireAntGA-ImmunoModel;
   Immunotoxicity Prediction; Cheminformatics; Firefly Algorithm; Ant
   Colony Optimization; Genetic Algorithm; Class Balancing; SMOTE;
   Dimensionality Reduction; Feature Selection; RDKit Descriptors},
Author-Email = {sangeetha.rg@vit.ac},
Number-of-Cited-References = {18},
