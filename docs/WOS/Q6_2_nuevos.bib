   Serra, Romain; Kim, Eishi; Fiorentino, Andrea, Exotrail, 2 Esplanade Compans Caffarelli, F-31000 Toulouse, France.},
DOI = {10.1016/j.asr.2025.11.115},
EarlyAccessDate = {JAN 2026},
Keywords = {Station keeping; Convex optimization; Semi-infinite programming},
Keywords-Plus = {THRUST TRAJECTORY OPTIMIZATION},
Author-Email = {romain.serra@exotrail.com
