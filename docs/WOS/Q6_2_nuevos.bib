   Setyawan, U. A.; Chozin, I. N., Saiful Anwar Gen Hosp, Dept Pulmonol \& Resp Med, Malang, Indonesia.},
DOI = {10.56042/ijbb.v63i2.22387},
Keywords = {Antibody-drug conjugates; Artificial intelligence; Bioinformatics
   pipeline; Lung adenocarcinoma; Translational oncology},
Keywords-Plus = {PHASE-I; PHARMACOKINETICS; SAFETY},
Author-Email = {anthony.chrismd@gmail.com},
Number-of-Cited-References = {24},
