}

@article{ WOS:001720332500001,
Author = {Costa, Fabrizzio R. and Nishimura, Livia Namie S. and Antonio Filho, R.
   Reginaldo and Milanezi, Bruno P. and Yaosong, Dong and Carneiro, Cleyton
   de C. and Ulsen, Carina},
Title = {Borehole Logging Lithological Classification in Carbonatite-Hosted
   Niobium Deposit Integrating Geophysical and Geochemical Data With
   Self-Organizing Maps},
Journal = {GEOPHYSICAL PROSPECTING},
Year = {2026},
Volume = {74},
Number = {3},
Month = {MAR 17},
Abstract = {Lithological classification from borehole data remains challenging in
   geologically complex alkaline-carbonatite systems, where compositional
   overlap and gradual transitions between lithotypes limit conventional
   interpretation methods. This study presents an integrated and automated
   workflow for drill-core lithological classification using
   self-organizing maps (SOMs), an unsupervised artificial neural network,
   applied to a carbonatite-hosted niobium deposit. The approach integrates
   17 variables, including major-element geochemistry (e.g., Nb2O5, Fe2O3,
   P2O5 and SiO2), physical properties (bulk density) and downhole
   geophysical logs (gamma radiation, magnetic susceptibility, resistivity
   and neutron porosity), enabling multivariate analysis of more than
   40,000 drill-core samples. Principal component analysis (PCA)
   highlighted robust associations between mineralization-related
   variables, whereas inverse correlations of SiO2, K2O and resistivity
   enhanced host-rock discrimination. SOM modelling defined five clusters
   validated against reference lithologies, including nelsonites,
   carbonatite breccias, calcitic and barite-rich carbonatites and host
   rocks. The model accurately classified more than 95\% of nelsonite and
   barite-rich carbonatite samples, with errors below +/- 5\% for key
   variables such as Nb2O5 and Fe2O3, whereas partial overlap between
   breccias and host rocks reflected natural geological transitions.
   Overall, the results demonstrate that SOM-based unsupervised learning
   provides a robust, objective and reproducible framework for lithological
   domain definition, offering strong potential to enhance geological
   interpretation, exploration targeting and geometallurgical modelling in
   complex ore systems.},
Type = {Article},
Affiliation = {Costa, FR (Corresponding Author), Univ Sao Paulo, Dept Min \& Petr Engn, Escola Politecn, Sao Paulo, SP, Brazil.
   Costa, FR (Corresponding Author), CMOC Brasil Min Tech Serv Management, Catalao, GO, Brazil.
   Costa, Fabrizzio R.; Nishimura, Livia Namie S., Univ Sao Paulo, Dept Min \& Petr Engn, Escola Politecn, Sao Paulo, SP, Brazil.
