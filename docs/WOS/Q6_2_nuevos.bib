DOI = {10.1016/j.dib.2025.112193},
EarlyAccessDate = {DEC 2025},
Article-Number = {112193},
Keywords = {Aquaculture; Computer vision; Ecological monitoring; Image processing;
   Machine learning; Marine Biology; Object Detection},
Author-Email = {hasanul.ferdaus@ewubd.edu},
Number-of-Cited-References = {11},
