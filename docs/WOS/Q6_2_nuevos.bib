   Gil-Gomez, Gabriel, IMIM Hosp Mar Med Res Inst, Gastroesophageal Carcinogenesis Grp, Carrer Doctor Aiguader 88, Barcelona 08003, Spain.},
DOI = {10.1016/j.trac.2025.118529},
