@article{ WOS:001649791600001,
Author = {Ke, Shiying and Guo, Hengyuan and Wang, Yulin and Zhang, Jichang and Xu,
   Pengfei and Zheng, Jianjun and Chen, Bin and Yao, Chendie and Meersmann,
   Thomas and Wang, Chengbo},
Title = {Posture-dependent assessment of whole-spine curvature with a rotatable
   cryogen-free 1.5T MRI and automated Cobb angle analysis},
Journal = {EUROPEAN SPINE JOURNAL},
Year = {2025},
Month = {2025 DEC 26},
Abstract = {Purpose To evaluate posture-dependent spinal curvature in adolescents
   using a novel rotatable cryogen-free 1.5T MRI system and to establish a
   fully automated analysis pipeline for quantitative Cobb angle
   measurement. Methods Thirty-two healthy adolescents (15 males, 17
   females; mean age 15.0 +/- 2.2 years) underwent whole-spine MRI in both
   supine (0 degrees) and upright (90 degrees) postures. Imaging was
   performed with a 3D coronal LAVA sequence. A custom pipeline integrated
   structural-similarity-based image stitching, deep learning-assisted
   segmentation and annotation, and Cobb angle computation from coronal
   projections. Cobb angles were compared between postures using paired
   t-tests with Bonferroni correction, and effect sizes were reported as
   Cohen's d. Results Imaging and automated analysis were successfully
   completed for all participants. Upright Cobb angles were significantly
   larger than supine across most regions: thoracic (6.5 +/- 2.3 degrees
   vs. 8.4 +/- 3.1 degrees, d = 0.65, corrected p = 0.003), lumbar (6.7 +/-
   3.9 degrees vs 8.7 +/- 4.9 degrees, d = 0.43, corrected p = 0.060),
   cervicothoracic (5.0 +/- 2.2 degrees vs 6.3 +/- 2.9 degrees, d = 0.53,
   corrected p = 0.030), and thoracolumbar (8.1 +/- 3.6 degrees vs. 11.3
   +/- 4.6 degrees, d = 0.74, corrected p < 0.001). Maximum Cobb angle
   increased from 9.1 +/- 3.3 degrees to 12.4 +/- 3.9 degrees (d = 0.83,
   corrected p < 0.001). Using the clinical threshold of 10 degrees, 13 of
   32 (41\%) subjects were classified as negative in supine but positive in
   upright, indicating that supine imaging may underestimate spinal
   curvature magnitude in posture-dependent assessments. Conclusion This
   study demonstrates the feasibility and clinical potential of a rotatable
   upright MRI system for radiation-free, posture-dependent assessment of
   spinal curvature. Upright imaging consistently revealed greater Cobb
   angles than supine imaging, particularly in the thoracolumbar region,
   and identified cases that would be underestimated with conventional
   methods. Combined with a fully automated analysis pipeline, this
   approach provides a reproducible and physiologically relevant framework
   for characterizing spinal curvature under natural loading conditions.},
Type = {Article; Early Access},
Affiliation = {Wang, CB (Corresponding Author), Univ Nottingham Ningbo China, Fac Sci \& Engn, Dept Elect \& Elect Engn, Ningbo, Zhejiang, Peoples R China.
   Ke, Shiying; Xu, Pengfei; Zheng, Jianjun; Chen, Bin, Ningbo 2 Hosp, Zhejiang Engn Res Ctr New Technol \& Applicat Heliu, Ningbo, Zhejiang, Peoples R China.
