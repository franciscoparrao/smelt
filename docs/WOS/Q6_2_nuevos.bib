}

@article{ WOS:001659174400001,
Author = {Hsu, Yu-Hsun},
Title = {Hardy-Weinberg Equilibrium Filtering in Population Genomics: Empirical
   Review and Decision Framework for Improved Practice},
Journal = {ECOLOGY AND EVOLUTION},
Year = {2026},
Volume = {16},
Number = {1},
Month = {JAN 9},
Abstract = {Hardy-Weinberg equilibrium (HWE) filtering remains widely used in
   population genomics, but its application remains inconsistent, often
   lacking detailed justification, and not always aligned with biological
   context. To evaluate whether conceptual awareness has translated into
   methodological change, we review empirical studies citing Pearman et al.
   (2022), a representative study testing the impacts of different grouping
   approaches for HWE filtering. While pooled filtering is becoming rare,
   we found a decreasing but still considerable heterogeneity in the
   decision of filtering schemes, limited reporting of thresholds, and few
   explicit justifications for applied approaches. These patterns suggest
   that awareness of HWE filtering limitations is increasing but has not
   yet led to consistent practice. We synthesise the biological and
   technical causes of HWE deviation, review recent advances, including
   population-aware and structure-informed filtering tools, and propose a
   transparent decision framework for population genomic studies. Rather
   than a default quality-control step, HWE filtering should be applied as
   a hypothesis-aware decision that reflects study aims and biological
   context. A citation-based mini-survey and decision workflow are provided
   to support biologically informed and reproducible applications.},
Type = {Review},
Affiliation = {Hsu, Y-H (Corresponding Author), Natl Cheng Kung Univ, Dept Life Sci, Tainan, Taiwan.
   Hsu, Yu-Hsun, Natl Cheng Kung Univ, Dept Life Sci, Tainan, Taiwan.},
DOI = {10.1002/ece3.72688},
Article-Number = {e72688},
Keywords = {Hardy-Weinberg; population genomics; population structure; SNP filtering},
Keywords-Plus = {RADSEQ},
Author-Email = {yuhsunhsu@ncku.edu.tw},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001659174400001},
}

@article{ WOS:001656993600001,
Author = {Avellaneda, Lucio L. and Gutierrez, Ryan M. and Johnson, Damani T. and
   Kalafut, Tim and Houston, Rachel M.},
Title = {Evaluation of the ForenSeq™ MainstAY workflow for forensic DNA samples},
Journal = {JOURNAL OF FORENSIC SCIENCES},
Year = {2026},
Volume = {71},
Number = {2},
Pages = {709-720},
Month = {MAR},
Abstract = {This study evaluated the performance and limitations of the ForenSeq
   (TM) MainstAY chemistry on the MiSeq FGx (R) Sequencing System, which is
   approved for National DNA Index System (NDIS) use. This study included
   baseline performance, sensitivity and reproducibility studies,
   challenging casework samples, assessments of library plexities,
   comparisons with capillary electrophoresis (CE), standard versus
   enhanced PCR1 buffers, manual versus automated library preparation, and
   different flow cell types. To assess reproducibility across users, 33
   samples were prepared by both an experienced and a novice user. Overall,
   the ForenSeq (TM) MainstAY Kit demonstrated high reliability with
   pristine samples and consistent performance across users, with minimal
   locus dropout until 62 pg. The kit outperformed CE for low-input and
   degraded samples, but limitations were observed at higher plexities.
   Increased sample numbers on a single flow cell disproportionately
   reduced read counts and locus recovery in degraded casework samples,
   while pristine samples were less affected. Strategic adjustments, such
   as batching degraded samples together or lowering plexity, may help
   mitigate these effects. Casework samples, including blood, touched
   items, bone, hair, and tissue, were tested with both standard and
   enhanced PCR1 buffers. In a 64-sample run (32 per buffer type),
   increased multiplexing reduced locus recovery in standard buffer
   samples, while the enhanced buffer improved recovery in 16 samples.
   Automated library preparation on the Opentrons OT-2 produced comparable
   or improved recovery relative to manual preparation, with no evidence of
   cross-contamination. These findings provide practical guidance for
   forensic laboratories adopting the MainstAY Kit, particularly in
   optimizing workflows for challenging samples and high-throughput
   sequencing environments.},
Type = {Article},
Affiliation = {Houston, RM (Corresponding Author), Sam Houston State Univ, Coll Criminal Justice, Dept Forens Sci, 1003 Bowers Blvd, Huntsville, TX 77340 USA.
   Avellaneda, Lucio L.; Gutierrez, Ryan M.; Johnson, Damani T.; Kalafut, Tim; Houston, Rachel M., Sam Houston State Univ, Coll Criminal Justice, Dept Forens Sci, 1003 Bowers Blvd, Huntsville, TX 77340 USA.},
DOI = {10.1111/1556-4029.70263},
EarlyAccessDate = {JAN 2026},
Keywords = {automation; degraded DNA; ForenSeq (TM) MainstAY Kit; MiSeq FGx (R)
   Sequencing System; next-generation sequencing; plexity; short tandem
   repeats},
Keywords-Plus = {DEVELOPMENTAL VALIDATION; DIRECT AMPLIFICATION; PCR AMPLIFICATION;
   IDENTIFICATION; CASEWORK; SYSTEM; BONE; KIT},
Author-Email = {rmh034@shsu.edu},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001656993600001},
}

@article{ WOS:001656768000001,
Author = {Li, Lingbo and Mathrani, Anuradha and Susnjak, Teo},
Title = {Transforming evidence synthesis: A systematic review of the evolution of
   automated meta-analysis in the age of AI},
Journal = {RESEARCH SYNTHESIS METHODS},
Year = {2026},
Month = {2026 JAN 9},
Abstract = {Exponential growth in scientific literature has heightened the demand
   for efficient evidence-based synthesis, driving the rise of the field of
   automated meta-analysis (AMA) powered by natural language processing and
   machine learning. This PRISMA systematic review introduces a structured
   framework for assessing the current state of AMA, based on screening
   13,216 papers (2006-2024) and analyzing 61 studies across diverse
   domains. Findings reveal a predominant focus on automating data
   processing (52.5\%), such as extraction and statistical modeling, while
   only 16.4\% address advanced synthesis stages. Just one study
   (approximately 2\%) explored preliminary full-process automation,
   highlighting a critical gap that limits AMA's capacity for comprehensive
   synthesis. Despite recent breakthroughs in large language models and
   advanced AI, their integration into statistical modeling and
   higher-order synthesis, such as heterogeneity assessment and bias
   evaluation, remains underdeveloped. This has constrained AMA's potential
   for fully autonomous meta-analysis (MA). From our dataset spanning
   medical (67.2\%) and non-medical (32.8\%) applications, we found that
   AMA has exhibited distinct implementation patterns and varying degrees
   of effectiveness in actually improving efficiency, scalability, and
   reproducibility. While automation has enhanced specific meta-analytic
   tasks, achieving seamless, end-to-end automation remains an open
   challenge. As AI systems advance in reasoning and contextual
   understanding, addressing these gaps is now imperative. Future efforts
   must focus on bridging automation across all MA stages, refining
   interpretability, and ensuring methodological robustness to fully
   realize AMA's potential for scalable, domain-agnostic synthesis.},
Type = {Review; Early Access},
Affiliation = {Li, LB (Corresponding Author), Massey Univ, Sch Math \& Computat Sci, Auckland, New Zealand.
   Li, Lingbo; Mathrani, Anuradha; Susnjak, Teo, Massey Univ, Sch Math \& Computat Sci, Auckland, New Zealand.},
DOI = {10.1017/rsm.2025.10065},
EarlyAccessDate = {JAN 2026},
Keywords = {AI-driven meta-analysis; automated evidence synthesis; automated
   meta-analysis (AMA); large language models for meta-analysis; scalable
   meta-analysis; systematic reviews},
Keywords-Plus = {TASK-TECHNOLOGY FIT; INFORMATION-TECHNOLOGY; DATABASE; ACCEPTANCE;
   STATEMENT; PACKAGE; MODELS; ONLINE; TOOL},
Author-Email = {l.li5@massey.ac.nz},
Number-of-Cited-References = {112},
Times-Cited = {1},
Unique-ID = {WOS:001656768000001},
}

@article{ WOS:001723688300001,
Author = {Machado, Caio C. S. and da Mota, Yugo S. N. and Petruci, Joao Flavio da
   Silveira and Silva, Sidnei G.},
Title = {Smart-PAD: A multi-channel mechanized approach for high-throughput
   paper-based colorimetric analysis: Determination of ammonia via the
   Berthelot reaction},
Journal = {ANALYTICA CHIMICA ACTA},
Year = {2026},
Volume = {1382},
Month = {JAN 8},
Abstract = {Background: Paper-based analytical devices (PADs) have gained widespread
   use in (bio)analytical colorimetric assays due to their portability,
   affordability, ease of use, and compatibility with point-of-care
   testing. Typical detection involves digital imaging or
   single/multi-channel light sensors to extract color data. However, these
   methods often require manual handling and operator intervention, leading
   to significant operator-dependent variability, reduced throughput, and
   limited reproducibility. Furthermore, these challenges limit the
   practical deployment of PADs for large-scale or automated analysis. The
   problem addressed here is the lack of fully automated, high-throughput
   PAD platforms capable of delivering precise, reproducible, and
   time-efficient colorimetric measurements with minimal human
   intervention. Results: We developed Smart-PAD, an automated analytical
   system integrating a 17-position 3D-printed sample wheel and an
   8-channel digital light sensor (AS7341) controlled by an ESP-32
   microcontroller. The platform performs sequential reflectance
   measurements every 19.4 s with precise timing and synchronization,
   achieving a relative standard deviation (RSD) of 3.2 \% in tests with
   sunset yellow-impregnated PADs. We determined that a 15-min drying time
   is necessary for stable and accurate signals, ensuring measurement
   reliability. The system allows automated analysis of 17 spots,
   significantly improving throughput over manual procedures. Validation
   via the Berthelot reaction for ammonium quantification in fertilizer
   samples demonstrated high accuracy, reproducibility, and robustness in
   complex matrices under realistic analytical conditions. The platform's
   modularity and low cost also facilitate easy adaptation for diverse
   analytical applications. Significance: Smart-PAD advances PAD-based
   colorimetric analysis by combining mechanized sample handling with
   multi-wavelength sensing technology, enabling high-throughput, precise,
   and reliable measurements. This platform offers a scalable, low-cost
   solution for automated, miniaturized analytical systems with broad
   potential applications across environmental monitoring, agricultural
   analysis, and biomedical diagnostics. Its innovation sets a new standard
   for automation and analytical performance in paper-based chemistry.},
Type = {Article},
Affiliation = {Silva, SG (Corresponding Author), Univ Fed Uberlandia, Inst Chem, 2121 Joao Naves De Avila Ave, BR-38400902 Uberlandia, MG, Brazil.
   Machado, Caio C. S.; da Mota, Yugo S. N.; Petruci, Joao Flavio da Silveira; Silva, Sidnei G., Univ Fed Uberlandia, Inst Chem, 2121 Joao Naves De Avila Ave, BR-38400902 Uberlandia, MG, Brazil.},
DOI = {10.1016/j.aca.2025.344843},
Article-Number = {344843},
Keywords = {Color sensor; Smartphone-based; Portable analysis; Do it yourself},
Keywords-Plus = {ANALYTICAL-CHEMISTRY; WATER},
Author-Email = {sidgon@ufu.br},
Number-of-Cited-References = {48},
Times-Cited = {1},
Unique-ID = {WOS:001723688300001},
}

@article{ WOS:001671382100001,
Author = {Tadi Uppala, Padma P. and Rivera, Elmer C. and Kwon, Hyun J. and Lum,
   Sharon S.},
Title = {Serum Protein Signatures for Breast Cancer Detection in Treatment-Naïve
   African American Women Using Integrated Proteomics and Pattern Analysis},
Journal = {SENSORS},
Year = {2026},
Volume = {26},
Number = {2},
Month = {JAN 8},
Abstract = {Breast cancer is the leading cause of cancer-related mortality in
   African American (AA) women. In this study we evaluated the serum
   proteomic profile of AA women with breast cancer using an integrated
   proteomic framework with multivariate pattern analysis. Using 2D-DIGE,
   thousands of serum protein spots were detected across 33 gels; 46 spots
   met criteria for presence, statistical significance, and differential
   expression. Proteins from the spots were identified by MALDI-TOF/TOF and
   matched in curated databases, highlighting serum biomarkers including
   ceruloplasmin, alpha-2-macroglobulin, complement component C3 and C6,
   alpha-1-antitrypsin, alpha-1B-glycoprotein, alpha-2-HS-glycoprotein and
   haptoglobin-related protein. LC-MS/MS analysis revealed 163
   differentiating peptides after imputing and filtering 286 peptides.
   These were evaluated using cumulative distribution function (CDF)
   analysis, a nonparametric method suited for limited sample sizes.
   Peptide patterns were explored with Random Forest, showing concordance
   with CDF. The model achieved an AUC of 0.85 at the peptide level. This
   workflow identified differentiating proteins (CERU, A2MG, CO3, VTDB,
   HEMO, APOB, APOA4, CFAH, CO4A, AACT, K1C10, ITIH2, ITIH4), highlighting
   CERU, A2MG, and CO3 with overexpression and reproducible identification
   across platforms. We present an integrated, non-invasive serum protein
   biomarker signature panel specific to AA women, through reproducible
   proteomic sensor framework to support early detection and breast cancer
   prevention.},
Type = {Article},
Affiliation = {Uppala, PPT (Corresponding Author), Andrews Univ, Sch Populat Hlth Nutr \& Wellness, Berrien Springs, MI 49104 USA.
   Tadi Uppala, Padma P., Andrews Univ, Sch Populat Hlth Nutr \& Wellness, Berrien Springs, MI 49104 USA.
   Rivera, Elmer C.; Kwon, Hyun J., Andrews Univ, Dept Engn, Berrien Springs, MI 49104 USA.
   Lum, Sharon S., Loma Linda Univ Hlth, Dept Surg, Loma Linda, CA 92354 USA.},
DOI = {10.3390/s26020403},
