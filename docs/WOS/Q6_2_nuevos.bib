   Maple, Carsten, Univ Warwick, Cyber Secur Ctr, WMG, Coventry, England.
   Atefi, Kayvan, Univ Hull, Fac Sci \& Engn, Sch Digital \& Phys Sci, Comp Sci, Kingston Upon Hull, England.},
DOI = {10.3389/fcomp.2026.1735919},
Article-Number = {1735919},
Keywords = {agentic AI; AI bill of materials (AIBOM); CVE automation; CycloneDX;
