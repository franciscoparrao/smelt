   Abd El-Latif, Ahmed A., Prince Sultan Univ, Ctr Excellence Quantum \& Intelligent Comp, Riyadh 11586, Saudi Arabia.
   Abd El-Latif, Ahmed A., Menoufia Univ, Fac Sci, Dept Math \& Comp Sci, Shibin Al Kawm 32511, Egypt.},
DOI = {10.1038/s41598-025-24936-2},
