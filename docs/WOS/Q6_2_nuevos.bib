}

@article{ WOS:001720056500002,
Author = {Chernova, A. S. and Meshchaninov, F. P. and Zhevnenko, D. A. and Gornev,
   E. S.},
Title = {Automation of Input Control of Transistors Using Deep Learning Models
   and Analysis of Their Latent Space},
Journal = {DOKLADY MATHEMATICS},
Year = {2025},
Volume = {112},
Number = {3},
Pages = {489-498},
Month = {DEC},
Abstract = {Reliable automation of the input control of transistors in
   microelectronics requires detection of deviations in multichannel
   volt-ampere characteristics; however, threshold and simple statistical
   methods are poorly generalized to new and experimental structures and do
   not detect previously unseen defects and ignore nonlinear interchannel
   dependences. We offer a framework for detecting anomalies based on
   neural network models trained on the results of monitoring normal
   devices. Within the framework, we compare the family of autoencoders
   (MLP/LSTM/CAE) and specialized methods (USAD, GBAD), as well as explore
   the obtained latent spaces for interpreting the work of neural networks.
   The developed framework was verified on the basis of 14 200 180 nm VAC
   field-effect transistors with expert marking. The GBAD (F1 = 0.857) and
   regularized CAE (F1 = 0.857) models showed the best results in the test.
   The results set reproducible baselines for detecting anomalies in
   multichannel I-V transistor data and highlight the advantage of explicit
   modeling of the interchannel structure and latent representation
   analysis to enhance portability and interpretability.},
Type = {Article},
Affiliation = {Chernova, AS (Corresponding Author), Mol Elect Res Inst, Moscow, Russia.
   Chernova, AS (Corresponding Author), Natl Res Univ, Moscow Inst Phys \& Technol, Dolgoprudnyi, Moscow Oblast, Russia.
   Chernova, A. S.; Meshchaninov, F. P.; Zhevnenko, D. A.; Gornev, E. S., Mol Elect Res Inst, Moscow, Russia.
   Chernova, A. S.; Gornev, E. S., Natl Res Univ, Moscow Inst Phys \& Technol, Dolgoprudnyi, Moscow Oblast, Russia.
   Zhevnenko, D. A., Lobachevsky Nizhny Novgorod State Univ, Nizhnii Novgorod, Russia.
   Zhevnenko, D. A., Artificial Intelligence Res Inst, Moscow, Russia.},
DOI = {10.1134/S1064562425700644},
Keywords = {input control; transistors; volt-ampere characteristic; automation;
   anomaly; deep learning},
