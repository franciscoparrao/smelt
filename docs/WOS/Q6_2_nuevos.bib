Unique-ID = {WOS:001699215800001},
}

@article{ WOS:001699360300001,
Author = {Jiang, Peihe and Li, Shaoqi and Lu, Yanfen and Song, Xiaogang},
Title = {An improved RT-DETR with multi-scale feature fusion for automated BALF
   cell detection},
Journal = {BIOMEDICAL SIGNAL PROCESSING AND CONTROL},
Year = {2026},
Volume = {119},
Number = {B},
Month = {JUN 15},
Abstract = {Cells in bronchoalveolar lavage fluid (BALF) provide critical diagnostic
   and pathological insights in clinical practice, especially in the
   assessment of various pulmonary conditions such as infections,
   interstitial lung diseases, and malignancies. Traditionally, BALF cell
   analysis relies heavily on manual microscopy, which is laborintensive,
   time-consuming, and highly dependent on the expertise of pathologists.
   This manual process introduces variability, limits reproducibility, and
   reduces scalability in routine clinical workflows. To address these
   challenges, we propose an automated object detection framework based on
   an improved Real-Time DEtection TRansformer (RT-DETR), which is designed
   for the rapid and accurate detection and classification of BALF cells.
   The model focuses on identifying four major cell types commonly found in
   BALF samples: macrophages, lymphocytes, neutrophils, and eosinophils.
   Extensive experimental evaluations demonstrate that the proposed
   approach achieves a high mean Average Precision (mAP) of 85.7\% and a
   recall rate of 79.1\%, indicating its robustness, accuracy, and
   potential applicability in real-world clinical cytology settings. This
   method may significantly reduce workload while enhancing diagnostic
   consistency.},
Type = {Article},
Affiliation = {Lu, YF; Song, XG (Corresponding Author), Yantai Yuhuangding Hosp, Dept Pulm \& Crit Care Med, Yantai 264000, Peoples R China.
   Jiang, Peihe; Li, Shaoqi, Yantai Univ, Sch Phys \& Elect Informat, Yantai 264005, Peoples R China.
   Lu, Yanfen; Song, Xiaogang, Yantai Yuhuangding Hosp, Dept Pulm \& Crit Care Med, Yantai 264000, Peoples R China.},
DOI = {10.1016/j.bspc.2026.109865},
EarlyAccessDate = {FEB 2026},
Article-Number = {109865},
Keywords = {BALF cytology; RT-DETR; Object detection; Cell classification},
Keywords-Plus = {BRONCHOALVEOLAR LAVAGE; CLINICAL UTILITY},
Author-Email = {luyanfen71@163.com
