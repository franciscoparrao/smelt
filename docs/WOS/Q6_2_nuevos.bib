DOI = {10.1016/j.ympev.2026.108580},
Article-Number = {108580},
Keywords = {Phylogenomics; USCOs; Cricket; Low-coverage genomes; Topological tests},
Keywords-Plus = {MALE GENITALIA; ORTHOPTERA; EVOLUTION; ENSIFERA; PERFORMANCE; INSECTS;
   GENERA; TOOL},
Author-Email = {libinma@snnu.edu.cn
   yuanh@snnu.edu.cn},
