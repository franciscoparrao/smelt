   Danelatos, Dionysios; Garces, Sara, Inst Terra \& Mem, Geosci Ctr, P-6120750 Macao, Portugal.},
DOI = {10.1109/ACCESS.2026.3663085},
Keywords = {Pigments; Rocks; Art; Information filters; Painting; Documentation; Deep
