   Yen, Jiun-Yee; Chen, Jia-Hong, Natl Dong Hwa Univ, Dept Nat Resources \& Environm Studies, Hualien, Taiwan.
   Chyi, Shyh-Jeng; Chen, Jia-Hong, Natl Kaohsiung Normal Univ, Dept Geog, Kaohsiung, Taiwan.},
DOI = {10.1007/s44195-025-00117-6},
Article-Number = {3},
