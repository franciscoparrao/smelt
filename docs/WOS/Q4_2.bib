Keywords = {Lamb wave; imbalanced data; damage detection; SMOTE; fatigue crack},
Keywords-Plus = {PIEZOELECTRIC SENSOR/ACTUATOR NETWORK; MACHINE LEARNING APPROACH;
   FAULT-DETECTION; SAMPLING METHOD; PREDICTION; SMOTE; CLASSIFICATION;
   PLATES; QUANTIFICATION; DIAGNOSIS},
Author-Email = {liujie805@buaa.edu.cn},
Number-of-Cited-References = {63},
Times-Cited = {13},
Unique-ID = {WOS:000677409300001},
}

@article{ WOS:000660646500001,
Author = {Wang, Jia-Bao and Zou, Chun-An and Fu, Guang-Hui},
Title = {AWSMOTE: An SVM-Based Adaptive Weighted SMOTE for Class-Imbalance
   Learning},
Journal = {SCIENTIFIC PROGRAMMING},
Year = {2021},
Volume = {2021},
Month = {MAY 13},
Abstract = {In class-imbalance learning, Synthetic Minority Oversampling Technique
   (SMOTE) is a widely used technique to tackle class-imbalance problems
   from the data level, whereas SMOTE blindly selects neighboring minority
   class points when performing an interpolation among them and inevitably
   brings collinearity between the generated new points and the original
   ones. To combat these problems, we propose in this study an
   adaptive-weighting SMOTE method, termed as AWSMOTE. AWSMOTE applies two
   types of SVM-based weights into SMOTE. A kind of weight is used in
   variable space to combat the drawbacks of collinearity, while another
   weight is utilized in sample space to purposefully choose those support
   vectors from the minority class as the neighboring points in the
   interpolation. AWSMOTE is compared with SMOTE and its improved versions
   with six simulated datasets and 22 real-world datasets. The results
   demonstrate the effectiveness and advantages of the proposed approach.},
Type = {Article},
Affiliation = {Fu, GH (Corresponding Author), Kunming Univ Sci \& Technol, Sch Sci, Kunming 650500, Yunnan, Peoples R China.
   Wang, Jia-Bao; Zou, Chun-An; Fu, Guang-Hui, Kunming Univ Sci \& Technol, Sch Sci, Kunming 650500, Yunnan, Peoples R China.},
DOI = {10.1155/2021/9947621},
Article-Number = {9947621},
Keywords-Plus = {SUPPORT VECTOR MACHINES; CLASSIFICATION; CLASSIFIERS; ENSEMBLE},
Author-Email = {jiabaowang@stu.kust.edu.cn
   20192111012@stu.kust.edu.cn
   guanghuifu@kust.edu.cn},
Number-of-Cited-References = {55},
