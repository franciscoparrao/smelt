   Shin, Yeongjae; Kim, Myeongkil; Kim, Howon, Pusan Natl Univ, Sch Comp Sci \& Engn, Busan 609735, South Korea.
   Kim, Myeongkil, Smart2M2, Busan 48058, South Korea.},
DOI = {10.1016/j.asoc.2024.111517},
EarlyAccessDate = {MAR 2024},
