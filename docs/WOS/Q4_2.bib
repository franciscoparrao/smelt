DOI = {10.2196/28039},
Article-Number = {e28039},
Keywords = {wrist pulse; ensemble learning; support vector machine; deep
   convolutional neural network; pulse signal; machine learning;
   traditional Chinese medicine; pulse classification; pulse analysis;
   fully connected neural network; synthetic minority oversampling
   technique; feature extraction},
Author-Email = {jjyan@ecust.edu.cn},
