@article{ WOS:000971175100001,
Author = {Garcia-Vicente, Clara and Chushig-Muzo, David and Mora-Jimenez,
   Inmaculada and Fabelo, Himar and Gram, Inger Torhild and Lochen,
   Maja-Lisa and Granja, Conceicao and Soguero-Ruiz, Cristina},
Title = {Evaluation of Synthetic Categorical Data Generation Techniques for
   Predicting Cardiovascular Diseases and Post-Hoc Interpretability of the
   Risk Factors},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2023},
Volume = {13},
Number = {7},
Month = {APR},
Abstract = {Machine Learning (ML) methods have become important for enhancing the
   performance of decision-support predictive models. However, class
   imbalance is one of the main challenges for developing ML models,
   because it may bias the learning process and the model generalization
   ability. In this paper, we consider oversampling methods for generating
   synthetic categorical clinical data aiming to improve the predictive
   performance in ML models, and the identification of risk factors for
   cardiovascular diseases (CVDs). We performed a comparative study of
   several categorical synthetic data generation methods, including
   Synthetic Minority Oversampling Technique Nominal (SMOTEN), Tabular
   Variational Autoencoder (TVAE) and Conditional Tabular Generative
   Adversarial Networks (CTGANs). Then, we assessed the impact of combining
   oversampling strategies and linear and nonlinear supervised ML methods.
   Lastly, we conducted a post-hoc model interpretability based on the
   importance of the risk factors. Experimental results show the potential
   of GAN-based models for generating high-quality categorical synthetic
   data, yielding probability mass functions that are very close to those
   provided by real data, maintaining relevant insights, and contributing
   to increasing the predictive performance. The GAN-based model and a
   linear classifier outperform other oversampling techniques, improving
   the area under the curve by 2\%. These results demonstrate the
   capability of synthetic data to help with both determining risk factors
   and building models for CVD prediction.},
Type = {Article},
Affiliation = {Soguero-Ruiz, C (Corresponding Author), Rey Juan Carlos Univ, Dept Signal Theory \& Commun Telemat \& Comp Syst, Madrid 28943, Spain.
   Garcia-Vicente, Clara; Chushig-Muzo, David; Mora-Jimenez, Inmaculada; Soguero-Ruiz, Cristina, Rey Juan Carlos Univ, Dept Signal Theory \& Commun Telemat \& Comp Syst, Madrid 28943, Spain.
   Fabelo, Himar, Fdn Canaria Inst Invest Sanitaria Canarias, Las Palmas Gran Canaria 35019, Spain.
   Fabelo, Himar, Univ Las Palmas Gran Canaria, Res Inst Appl Microelect, Las Palmas Gran Canaria 35017, Spain.
   Gram, Inger Torhild; Granja, Conceicao, Univ Hosp North Norway, Norwegian Ctr E Hlth Res, N-9019 Tromso, Norway.
   Gram, Inger Torhild; Lochen, Maja-Lisa, UiT Arctic Univ Norway, Fac Hlth Sci, Dept Community Med, N-9019 Tromso, Norway.
   Granja, Conceicao, Nord Univ, Fac Nursing \& Hlth Sci, N-8026 Bodo, Norway.},
DOI = {10.3390/app13074119},
Article-Number = {4119},
Keywords = {synthetic categorical data generation; generative adversarial networks;
   imbalance learning; CTGAN; interpretable machine learning;
   cardiovascular disease},
Keywords-Plus = {FEATURE-SELECTION; SMOTE; EVENT},
