DOI = {10.1007/s10489-018-1314-z},
Keywords = {Imbalanced learning; Lazy decision tree; Hellinger distance; K-L
   divergence; SMOTE},
Keywords-Plus = {STATISTICAL COMPARISONS; DATA SETS; CLASSIFIERS; SMOTE},
