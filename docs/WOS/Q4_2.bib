   Zhao, Kun, Beijing Wuzi Univ, Sch Logist, Beijing 101149, Peoples R China.
   Tian, Yingjie, Univ Chinese Acad Sci, Sch Econ \& Management, Beijing 100190, Peoples R China.},
DOI = {10.1109/ACCESS.2020.3015954},
Keywords = {Support vector machines; Optimization; Machine learning algorithms;
