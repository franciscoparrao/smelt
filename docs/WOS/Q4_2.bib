DOI = {10.1007/s13042-021-01321-9},
EarlyAccessDate = {APR 2021},
Keywords = {Imbalanced data classification; Oversampling; Generative adversarial
   network; Diverse sample generation; Classifier fusion},
Keywords-Plus = {MINORITY OVERSAMPLING TECHNIQUE; VECTOR MACHINE; SMOTE; ENSEMBLE;
   CHALLENGES; ALGORITHM; DISTANCE},
Author-Email = {mczjh@126.com},
