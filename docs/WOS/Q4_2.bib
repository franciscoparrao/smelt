   Hussain, Muhammad, Univ Wollongong, Northfields Ave Wollongong, Wollongong, NSW 2522, Australia.
   Palli, Abdul Sattar, Univ Teknol PETRONAS, Comp \& Informat Sci Dept, Seri Iskandar 32610, Perak Darul, Malaysia.},
DOI = {10.1016/j.rineng.2024.103233},
EarlyAccessDate = {NOV 2024},
Article-Number = {103233},
Keywords = {Burst pressure prediction; Machine learning; SMOTE; Data augmentation;
   Oil and gas pipelines; Safety},
Keywords-Plus = {FAILURE PRESSURE; CORROSION DEFECTS; RELIABILITY; SIGNALS; CHARGE;
   PIPES; STEEL; STATE},
Author-Email = {afzal\_20000277@utp.edu.my},
