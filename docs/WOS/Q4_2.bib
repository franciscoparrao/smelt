Keywords = {Overfitting; Prediction algorithms; Boosting; Training data; Switches;
   Neural networks; Data models; Vectors; Training; Timing; Imbalanced
   data; XGBoost; influence-balanced loss; over-specialization},
Keywords-Plus = {SMOTE; CLASSIFICATION},
Author-Email = {w225702b@yokohama-cu.ac.jp},
