@incollection{ WOS:000361490700028,
Author = {Lakshmi, T. Jaya and Prasad, Ch. Siva Rama},
Editor = {Kishore, KVK and Kumar, KH and Venkatramaphanikumar, S},
Title = {A Study on Classifying Imbalanced Datasets},
Booktitle = {2014 FIRST INTERNATIONAL CONFERENCE ON NETWORKS \& SOFT COMPUTING
   (ICNSC)},
Year = {2014},
Pages = {141-145},
Abstract = {Many problems in the real world are, in general modeled as binary
   classification problems and often one class samples outnumber other
   class samples. This imbalance causes the reduction in accuracy of
   prediction in minority class samples but give overall high accuracy.
   Ignoring misclassification rate of minority class causes severe problems
   in many cases such as fraudulent credit card transactions, medical
   diagnosis and e-mail foldering. Many classification algorithms existing
   in literature are designed for balanced datasets and these algorithms
   treat majority and minority class samples equal. In this study, the
   existing solutions for class imbalance problem and common evaluation
   techniques used for class imbalance are reviewed. The solutions were
   applied on three real world datasets. It is observed that a combination
   of SMOTE and Bagging with Random Forest produced the best overall
   accuracy of minority class.},
Type = {Proceedings Paper},
Affiliation = {Lakshmi, TJ (Corresponding Author), Vasireddy Venkatadri Inst Technol, Guntur, India.
   Lakshmi, T. Jaya, Vasireddy Venkatadri Inst Technol, Guntur, India.
