Keywords = {Belief rule base; Imbalanced classification; Diversity; Inconsistency;
   Oversampling},
Keywords-Plus = {SMOTE; PREDICTION; DIVERSITY; INFERENCE; MACHINE; SYSTEM},
Author-Email = {13075810934@163.com},
Number-of-Cited-References = {47},
