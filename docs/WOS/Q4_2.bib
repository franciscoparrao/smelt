   Yu, Zhiwen, South China Univ Technol, Sch Comp Sci \& Engn, Guangzhou 510006, Guangdong, Peoples R China.},
DOI = {10.1007/s00521-022-07534-5},
EarlyAccessDate = {JUL 2022},
Keywords = {Broad learning system; Imbalance learning; Kernel learning; Binary
   classification},
Keywords-Plus = {MACHINE; CLASSIFICATION; SMOTE; ALGORITHMS; REGRESSION; STRATEGY; MODEL;
