   Nicholl, Peter, Ulster Univ, Sch Comp, Coleraine, Londonderry, North Ireland.
   Lu, Haitian, Hong Kong Polytech Univ, Sch Accounting \& Finance, Hong Kong, Peoples R China.},
DOI = {10.1016/j.knosys.2022.108410},
EarlyAccessDate = {FEB 2022},
