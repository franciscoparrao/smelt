   Ren, Siqi; Liao, Bo; Wang, Peng; Li, Keqin; Chen, Min; Li, Zejun, Hunan Univ, Coll Informat Sci \& Engn, Changsha 410082, Hunan, Peoples R China.
   Zhu, Wen; Liao, Bo, Hainan Normal Univ, Sch Math \& Stat, Haikou, Hainan, Peoples R China.
   Ren, Siqi, Zhejiang Gongshang Univ, Sch Comp \& Informat Engn, Hangzhou 310016, Zhejiang, Peoples R China.
   Li, Zeng, Univ Sci \& Technol China, Sch Comp Sci \& Technol, Hefei 230027, Anhui, Peoples R China.
   Li, Keqin, SUNY Coll New Paltz, Dept Comp Sci, New Paltz, NY 12561 USA.
   Chen, Min; Li, Zejun, Hunan Inst Technol, Coll Comp \& Informat Sci, Hengyang 421000, Peoples R China.},
DOI = {10.1016/j.knosys.2018.09.032},
Keywords = {Data stream classification; Concept drift; Class imbalance; Ensemble},
Keywords-Plus = {LISTING STATUS; CONCEPT DRIFT; SMOTE},
