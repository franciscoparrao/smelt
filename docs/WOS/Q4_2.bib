   Asha, S., Avinashilingam Inst Home Sci \& Higher Educ Women, Coimbatore, India.},
DOI = {10.1016/j.compeleceng.2022.108519},
EarlyAccessDate = {DEC 2022},
Article-Number = {108519},
Keywords = {Anomaly detection; Cloud security; Malicious insider; Machine learning;
   Performance evaluation; Sampling techniques},
Author-Email = {20phcsf005@avinuty.ac.in
   shanmugapriya\_it@avinuty.ac.in
   padmavathi\_cs@avinuty.ac.in},
Number-of-Cited-References = {30},
Times-Cited = {17},
Unique-ID = {WOS:000898785500009},
}

@article{ WOS:000866680200001,
Author = {Almuayqil, Saleh Naif and Humayun, Mamoona and Jhanjhi, N. Z. and
   Almufareh, Maram Fahaad and Javed, Danish},
Title = {Framework for Improved Sentiment Analysis via Random Minority
   Oversampling for User Tweet Review Classification},
Journal = {ELECTRONICS},
Year = {2022},
Volume = {11},
Number = {19},
Month = {OCT},
Abstract = {Social networks such as twitter have emerged as social platforms that
   can impart a massive knowledge base for people to share their unique
   ideas and perspectives on various topics and issues with friends and
   families. Sentiment analysis based on machine learning has been
   successful in discovering the opinion of the people using redundantly
   available data. However, recent studies have pointed out that imbalanced
   data can have a negative impact on the results. In this paper, we
   propose a framework for improved sentiment analysis through various
   ordered preprocessing steps with the combination of resampling of
   minority classes to produce greater performance. The performance of the
   technique can vary depending on the dataset as its initial focus is on
   feature selection and feature combination. Multiple machine learning
   algorithms are utilized for the classification of tweets into positive,
   negative, or neutral. Results have revealed that random minority
   oversampling can provide improved performance and it can tackle the
   issue of class imbalance.},
Type = {Review},
