DOI = {10.1007/s44196-025-00760-4},
Article-Number = {47},
Keywords = {High glucose; Diabetes mellitus; Gestational diabetes prediction;
   Machine learning; Healthcare analytics; Predictive modelling;
   Explainable artificial intelligence},
Keywords-Plus = {DIAGNOSIS},
