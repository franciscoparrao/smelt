Unique-ID = {WOS:000546913800014},
}

@article{ WOS:000289843500013,
Author = {Khoshgoftaar, Taghi M. and Van Hulse, Jason and Napolitano, Amri},
Title = {Comparing Boosting and Bagging Techniques With Noisy and Imbalanced Data},
Journal = {IEEE TRANSACTIONS ON SYSTEMS MAN AND CYBERNETICS PART A-SYSTEMS AND
   HUMANS},
Year = {2011},
Volume = {41},
Number = {3},
Pages = {552-568},
Month = {MAY},
Abstract = {This paper compares the performance of several boosting and bagging
   techniques in the context of learning from imbalanced and noisy
   binary-class data. Noise and class imbalance are two well-established
   data characteristics encountered in a wide range of data mining and
   machine learning initiatives. The learning algorithms studied in this
   paper, which include SMOTEBoost, RUSBoost, Exactly Balanced Bagging, and
   Roughly Balanced Bagging, combine boosting or bagging with data sampling
   to make them more effective when data are imbalanced. These techniques
   are evaluated in a comprehensive suite of experiments, for which nearly
   four million classification models were trained. All classifiers are
   assessed using seven different performance metrics, providing a complete
   perspective on the performance of these techniques, and results are
   tested for statistical significance via analysis-of-variance modeling.
   The experiments show that the bagging techniques generally outperform
   boosting, and hence in noisy data environments, bagging is the preferred
   method for handling class imbalance.},
Type = {Article},
Affiliation = {Khoshgoftaar, TM (Corresponding Author), Florida Atlantic Univ, Boca Raton, FL 33431 USA.
   Khoshgoftaar, Taghi M.; Van Hulse, Jason; Napolitano, Amri, Florida Atlantic Univ, Boca Raton, FL 33431 USA.},
DOI = {10.1109/TSMCA.2010.2084081},
Keywords = {Bagging; binary classification; boosting; class imbalance; class noise},
Keywords-Plus = {SMOTE},
Author-Email = {taghi@cse.fau.edu
   jvanhulse@gmail.com
   amrifau@gmail.com},
Number-of-Cited-References = {45},
Times-Cited = {236},
