@article{ WOS:000414204400007,
Author = {Migueis, Vera L. and Camanho, Ana S. and Borges, Jose},
Title = {Predicting direct marketing response in banking: comparison of class
   imbalance methods},
Journal = {SERVICE BUSINESS},
Year = {2017},
Volume = {11},
Number = {4},
Pages = {831-849},
Month = {DEC},
Abstract = {Customers' response is an important topic in direct marketing. This
   study proposes a data mining response model supported by random forests
   to support the definition of target customers for banking campaigns.
   Class imbalance is a typical problem in telemarketing that can affect
   the performance of the data mining techniques. This study also
   contributes to the literature by exploring the use of class imbalance
   methods in the banking context. The performance of an undersampling
   method (the EasyEnsemble algorithm) is compared with that of an
   oversampling method (the Synthetic Minority Oversampling Technique) in
   order to determine the most appropriate specification. The importance of
   the attribute features included in the response model is also explored.
   In particular, discriminative performance was enhanced by the inclusion
   of demographic information, contact details and socio-economic features.
   Random forests, supported by an undersampling algorithm, presented very
   high prediction performance, outperforming the other techniques
   explored.},
Type = {Article},
Affiliation = {Miguéis, VL (Corresponding Author), Univ Porto, Fac Engn, Rua Dr Roberto Frias, P-4200465 Oporto, Portugal.
   Migueis, Vera L.; Camanho, Ana S.; Borges, Jose, Univ Porto, Fac Engn, Rua Dr Roberto Frias, P-4200465 Oporto, Portugal.},
DOI = {10.1007/s11628-016-0332-3},
Keywords = {Direct marketing; Response modelling; Customer targeting; Random
   forests; Class imbalance},
Keywords-Plus = {DATA MINING TECHNIQUES; LOGISTIC-REGRESSION; DECISION-SUPPORT; CUSTOMER;
