   Abdulganiyu, Oluwadamilare Harazeem, Univ Maiduguri, Maiduguri, Nigeria.
   Saheed, Yakub Kayode, Amer Univ Nigeria, Sch IT \& Comp, Yola, Nigeria.},
DOI = {10.1016/j.iswa.2025.200519},
EarlyAccessDate = {APR 2025},
Article-Number = {200519},
Keywords = {Intrusion detection system; Artificial intelligence; Imbalanced network
   traffic; Attention mechanism; Variational autoencoder; Class wise focal
   loss; Extreme gradient boosting},
Author-Email = {h.abdulganiyuoluwadamilare@ueuromed.org
   t.ait-tchakoucht@ueuromed.org
   a.elhilali-alaoui@ueuromed.org
   yakubu.saheed@aun.edu.ng},
Number-of-Cited-References = {32},
