   Tanimoto, Akira; Takenouchi, Takashi; Sugiyama, Masashi; Kashima, Hisashi, RIKEN AIP, Chuo ku, Nihonbashi 1-chome Mitsui Bldg,15th floor,1-4-1 Ni, Tokyo 1030027, Japan.
   Takenouchi, Takashi, Natl Grad Inst Policy Studies, Minato ku, 7-22-1 Roppongi, Tokyo 1068677, Japan.
   Sugiyama, Masashi, Univ Tokyo, Bunkyo ku, 7-3-1 Hongo, Tokyo 1130033, Japan.},
DOI = {10.1016/j.eswa.2022.117130},
EarlyAccessDate = {APR 2022},
Article-Number = {117130},
Keywords = {Imbalanced classification; Learning using privileged information;
   Generalized distillation},
