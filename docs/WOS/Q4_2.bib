   Wang, Li, Beihang Univ, Sch Econ \& Management, Beijing Key Lab Emergency Support Simulat Technol, Beijing 100191, Peoples R China.},
DOI = {10.1007/s11518-022-5545-5},
Keywords = {Imbalance classification; credit classification; class overlap;
   evolutionary under-sampling; genetic algorithm},
Keywords-Plus = {SMOTE; RISK; TRENDS},
