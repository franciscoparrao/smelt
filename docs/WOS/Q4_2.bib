Keywords = {geopolymer concrete; compressive strength prediction; machine learning;
   deep learning; data augmentation; tabular GAN},
Keywords-Plus = {ALKALI-ACTIVATED SLAG; FLY-ASH; MECHANICAL-PROPERTIES; CONCRETE;
