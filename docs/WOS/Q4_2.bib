DOI = {10.1109/TEM.2014.2384513},
Keywords = {Default prediction; fuzzy instance based classifier; swarm intelligence;
   synthetic minority over-sampling technique},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; IMBALANCED CLASSIFICATION; DIFFERENTIAL
