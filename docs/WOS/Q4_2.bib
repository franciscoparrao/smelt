   Khattak, Sohaib Bin Altaf; Farman, Haleem; Nasralla, Moustafa M., Prince Sultan Univ, Coll Engn, Dept Commun \& Networks, Smart Syst Engn Lab, Riyadh 11586, Saudi Arabia.},
DOI = {10.3390/app13137488},
