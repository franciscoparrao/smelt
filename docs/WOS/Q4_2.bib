@article{ WOS:000390567700023,
Author = {Amin, Adnan and Anwar, Sajid and Adnan, Awais and Nawaz, Muhammad and
   Howard, Newton and Qadir, Junaid and Hawalah, Ahmad and Hussain, Amir},
Title = {Comparing Oversampling Techniques to Handle the Class Imbalance Problem:
   A Customer Churn Prediction Case Study},
Journal = {IEEE ACCESS},
Year = {2016},
Volume = {4},
Pages = {7940-7957},
Abstract = {Customer retention is a major issue for various service-based
   organizations particularly telecom industry, wherein predictive models
   for observing the behavior of customers are one of the great instruments
   in customer retention process and inferring the future behavior of the
   customers. However, the performances of predictive models are greatly
   affected when the real-world data set is highly imbalanced. A data set
   is called imbalanced if the samples size from one class is very much
   smaller or larger than the other classes. The most commonly used
   technique is over/under sampling for handling the class-imbalance
   problem (CIP) in various domains. In this paper, we survey six
   well-known sampling techniques and compare the performances of these key
   techniques, i.e., mega-trend diffusion function (MEDF), synthetic
   minority oversampling technique, adaptive synthetic sampling approach,
   couples top-N reverse k-nearest neighbor, majority weighted minority
   oversampling technique, and immune centroids oversampling technique.
   Moreover, this paper also reveals the evaluation of four
   rules-generation algorithms (the learning from example module, version 2
   (LEM2), covering, exhaustive, and genetic algorithms) using publicly
   available data sets. The empirical results demonstrate that the overall
   predictive performance of MEDF and rules generation based on genetic
   algorithms performed the best as compared with the rest of the evaluated
   oversampling methods and rule-generation algorithms.},
Type = {Article},
Affiliation = {Amin, A (Corresponding Author), Inst Management Sci, Ctr Excellence Informat Technol, Peshawar 25000, Pakistan.
   Amin, Adnan; Anwar, Sajid; Adnan, Awais; Nawaz, Muhammad, Inst Management Sci, Ctr Excellence Informat Technol, Peshawar 25000, Pakistan.
   Howard, Newton, Univ Oxford, Nuffield Dept Surg Sci, Oxford OX3 9DU, England.
   Qadir, Junaid, Informat Technol Univ, Arfa Software Technol Pk, Lahore 54000, Pakistan.
   Hawalah, Ahmad, Taibah Univ, Coll Comp Sci \& Engn, Medina 344, Saudi Arabia.
   Hussain, Amir, Univ Stirling, Div Comp Sci \& Maths, Stirling FK9 4LA, Scotland.},
DOI = {10.1109/ACCESS.2016.2619719},
Keywords = {SMOTE; ADASYN; mega trend diffusion function; class imbalance; rough
   set; customer churn; mRMR. ICOTE; MWMOTE; TRkNN},
Keywords-Plus = {CLASSIFICATION; ATTRITION; SERVICES; MODELS; SMOTE; CRM},
Author-Email = {adnan.amin@live.co.uk},
Number-of-Cited-References = {80},
