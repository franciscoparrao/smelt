   Soares, Carlos, Univ Porto, Fac Engn, LIACC, Porto, Portugal.
   Wilk, Szymon, Poznan Univ Tech, Inst Comp Sci, Poznan, Poland.
   Santos, Joao, IPO Porto Res Ctr CI IPOP, Porto, Portugal.
   Santos, Joao, Univ Porto, Inst Ciencias Biomed Abel Salazar, Porto, Portugal.},
DOI = {10.1007/s10462-022-10150-3},
EarlyAccessDate = {MAR 2022},
Keywords = {Class imbalance; Class overlap; Data intrinsic characteristics; Class
   overlap complexity measures; Class overlap-based approaches; Class
   overlap representations},
Keywords-Plus = {SUPPORT VECTOR MACHINES; MINORITY OVERSAMPLING TECHNIQUE; VS-ONE
   STRATEGY; CLASSIFICATION PROBLEMS; COMPLEXITY-MEASURES; SAMPLING METHOD;
   SMOTE; PREDICTION; NOISY; CHALLENGES},
Author-Email = {miriams@dei.uc.pt
   pha@dei.uc.pt
   nathalie.japkowicz@american.edu
   alberto@decsai.ugr.es
   csoares@fe.up.pt
   szymon.wilk@cs.put.poznan.pl
   joao.santos@ipoporto.min-saude.pt},
Number-of-Cited-References = {152},
Times-Cited = {80},
