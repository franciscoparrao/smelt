Keywords = {Class imbalance; Cost sensitive; Linear-exponential loss; v-support
   vector machine; ADMM; GD},
Keywords-Plus = {CLASSIFICATION; SVM; PARAMETER; ENSEMBLE; ROBUST; SMOTE},
