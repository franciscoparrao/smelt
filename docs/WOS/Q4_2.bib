DOI = {10.1016/j.neucom.2018.01.039},
Keywords = {Multi-class problems; Imbalanced datasets; Ensemble learning; Binary
   decomposition; Synthetic samples generation},
Keywords-Plus = {VS-ONE STRATEGY; MULTIPLE CLASSES; CLASSIFICATION; AGGREGATION;
