   Muneer, Amgad; Taib, Shakirah Mohd; Aziz, Izzatdin Abdul, Univ Teknol PETRONAS, Ctr Res Data Sci CERDAS, Seri Iskandar 32610, Perak, Malaysia.
   Fati, Suliman Mohamed, Prince Sultan Univ, Informat Syst Dept, Riyadh 11586, Saudi Arabia.},
DOI = {10.32604/cmc.2022.021113},
Keywords = {Anomaly detection; outlier detection; unsupervised learning;
   autoencoder; deep learning; hybrid model},
Keywords-Plus = {OUTLIER DETECTION; MINING OUTLIERS; SUBSPACES},
Author-Email = {amgad\_20001929@utp.edu.my},
