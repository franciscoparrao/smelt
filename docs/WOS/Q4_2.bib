   Ding, Shusheng, Ningbo Univ, Sch Business, 818 Fenghua Rd Ningbo, Ningbo 315211, Peoples R China.},
DOI = {10.3390/math12050701},
Article-Number = {701},
Keywords = {credit risk prediction; resampling; class imbalance},
Keywords-Plus = {BANKRUPTCY PREDICTION; ENSEMBLE MODEL; SMOTE; PERFORMANCE; ALGORITHMS},
Author-Email = {zz1937@ynufe.edu.cn
