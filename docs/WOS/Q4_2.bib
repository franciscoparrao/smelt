@article{ WOS:000393662500006,
Author = {Bunkhumpornpat, Chumphol and Sinapiromsaran, Krung},
Title = {DBMUTE: density-based majority under-sampling technique},
Journal = {KNOWLEDGE AND INFORMATION SYSTEMS},
Year = {2017},
Volume = {50},
Number = {3},
Pages = {827-850},
Month = {MAR},
Abstract = {Class imbalance is a challenging problem that demonstrates the
   unsatisfactory classification performance of a minority class. A trivial
   classifier is biased toward minority instances because of their tiny
   fraction. In this paper, our density function is defined as the distance
   along the shortest path between each majority instance and a
   minority-cluster pseudo-centroid in an underlying cluster graph. Ashort
   path implies highly overlapping dense minority instances. In contrast, a
   long path indicates a sparsity of instances. A new under-sampling
   algorithm is proposed to eliminate majority instances with low distances
   because these instances are insignificant and obscure the classification
   boundary in the overlapping region. The results show predictive
   improvements on a minority class from various classifiers on different
   UCI datasets.},
Type = {Article},
Affiliation = {Bunkhumpornpat, C (Corresponding Author), Chiang Mai Univ, Dept Comp Sci, Theoret \& Empir Res Grp, Fac Sci, Chiang Mai 50200, Thailand.
