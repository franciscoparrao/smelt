   Medeiros, Ana Margarida; Alves, Ana Catarina; Bourbon, Mafalda, Univ Lisbon, Fac Ciencias, Inst Biossistemas \& Ciencias Integrat, Lisbon, Portugal.
   Antunes, Marilia, Univ Lisbon, Fac Ciencias, Dept Estat \& Invest Operac, Lisbon, Portugal.},
DOI = {10.1371/journal.pone.0269713},
