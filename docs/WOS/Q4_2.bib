   Bergeles, Christos},
Editor = {DeBruijne, M and Cattin, PC and Cotin, S and Padoy, N and Speidel, S and Zheng, Y and Essert, C},
Title = {Effective Semantic Segmentation in Cataract Surgery: What Matters Most?},
Booktitle = {MEDICAL IMAGE COMPUTING AND COMPUTER ASSISTED INTERVENTION - MICCAI
   2021, PT IV},
Series = {Lecture Notes in Computer Science},
Year = {2021},
Volume = {12904},
Pages = {509-518},
Abstract = {Our work proposes neural network design choices that set the
   state-of-the-art on a challenging public benchmark on cataract surgery,
   CaDIS. Our methodology achieves strong performance across three semantic
   segmentation tasks with increasingly granular surgical tool class sets
   by effectively handling class imbalance, an inherent challenge in any
   surgical video. We consider and evaluate two conceptually simple data
   oversampling methods as well as different loss functions. We show
   significant performance gains across network architectures and tasks
   especially on the rarest tool classes, thereby presenting an approach
   for achieving high performance when imbalanced granular datasets are
   considered. Our code and trained models are available at
   is://github.com/RViMLab/MICCAI2021\_Cataract\_semantic\_segmentation and
   qualitative results on unseen surgical video can be found at
   http://youtu.be/twVIPUj1WZM.},
