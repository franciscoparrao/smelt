   Kamaleswaran, Rishikesan, Georgia Inst Technol, Dept Biomed Engn, Atlanta, GA USA.},
DOI = {10.1016/j.compbiomed.2023.107749},
EarlyAccessDate = {NOV 2023},
Article-Number = {107749},
Keywords = {Critical care; Fluid overload; GAN; Machine learning; Mixed-integer
   temporal modeling; Synthetic data},
