DOI = {10.1016/j.inffus.2019.07.006},
Keywords = {Dynamic financial distress prediction; Class imbalance; SMOTE; Time
   weighting; Adaboost; Support vector machine},
Keywords-Plus = {CLASSIFICATION; ALGORITHMS; SELECTION; FAILURE; RATIOS; DISTANCE;
   MACHINE},
