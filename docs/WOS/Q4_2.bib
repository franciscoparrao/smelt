   Tao, Jiaqing, Bohai Univ, Coll Informat Sci \& Technol, Jinzhou 121013, Peoples R China.
   Wang, Changzhong, Bohai Univ, Coll Math Sci, Jinzhou 121013, Peoples R China.},
DOI = {10.1007/s40747-024-01399-y},
EarlyAccessDate = {APR 2024},
Keywords = {Class imbalance problem; Oversampling; Borderline instance; Tomek link;
   Data cleaning},
Keywords-Plus = {ALGORITHM; SEARCH},
Author-Email = {qkleng@126.com
   jm\_guo@tom.com},
Number-of-Cited-References = {55},
