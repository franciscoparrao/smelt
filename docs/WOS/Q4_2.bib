   Wu, Chase Q., New Jersey Inst Technol, Dept Comp Sci, Newark, NJ 07102 USA.},
DOI = {10.1016/j.comnet.2020.107315},
Article-Number = {107315},
Keywords = {Network intrusion detection; Deep learning; Class imbalance; Gaussian
   mixture model; Convolutional neural network},
Keywords-Plus = {RANDOM FOREST; MACHINE},
Author-Email = {zhp@zzu.edu.cn
   llhuang@ha.edu.cn
   chase.wu@njit.edu
   lzb@zzu.edu.cn},
Number-of-Cited-References = {50},
