   Li, Xianxian; Li, Qiyu; Li, De; Qian, Haodong; Wang, Jinyan, Guangxi Normal Univ, Sch Comp Sci \& Engn, Guilin 541004, Peoples R China.},
DOI = {10.1016/j.neunet.2024.106113},
EarlyAccessDate = {JAN 2024},
Article-Number = {106113},
Keywords = {Graph neural networks; Noisy labels; Contrastive learning},
Keywords-Plus = {NETWORKS},
