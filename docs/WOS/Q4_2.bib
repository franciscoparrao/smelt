Keywords = {multi-modal deep learning; time and frequency domain features; fast
   fourier transform; stress detection; wearable devices},
Keywords-Plus = {WEARABLE SENSORS},
Author-Email = {19096240@zjcst.edu.cn
   13106002@zjcst.edu.cn},
Number-of-Cited-References = {33},
Times-Cited = {18},
