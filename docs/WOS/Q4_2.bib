   Ou, Chubin, Weizhi Meditech Foshan Co Ltd, Foshan 528200, Guangdong, Peoples R China.
   Zhang, Junpeng, Dali Univ, Sch Engn, Dali, Peoples R China.},
DOI = {10.1007/s10489-022-03389-4},
EarlyAccessDate = {APR 2022},
Keywords = {K-means plus plus; SMOTE; CNN; Bi-LSTM; End-to-end Learning; Text
   Sentiment Classification},
Keywords-Plus = {CLASSIFICATION},
