   Nematollahi, Mohammad Ali, Fasa Univ, Dept Comp Sci, Fasa 7461686131, Iran.
   Oyelere, Solomon Sunday, Lulea Univ Technol, Dept Comp Sci Elect \& Space Engn, S-93187 Skelleftea, Sweden.
   Hussain, Sadiq, Dibrugarh Univ, Examinat Branch, Dibrugarh 786004, Assam, India.},
DOI = {10.3390/app13064006},
Article-Number = {4006},
Keywords = {imbalanced data; resampling; normalization; deep neural network;
   convolutional neural network},
Keywords-Plus = {CORONARY-ARTERY-DISEASE; CLASSIFICATION; DIAGNOSIS; CLASSIFIERS;
   ALGORITHMS},
Author-Email = {solomon.oyelere@ltu.se},
