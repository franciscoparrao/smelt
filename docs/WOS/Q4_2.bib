   Dasari, Siva Krishna; Palmquist, Jonatan, GKN Aerosp Engine Syst Sweden, Proc Engn Dept, Dept 9635-TL3, SE-46181 Trollhattan, Sweden.},
DOI = {10.1007/s00521-022-07347-6},
EarlyAccessDate = {MAY 2022},
Keywords = {Class-imbalance; Melt-pool defects classification; Aerospace
   application; Additive manufacturing; Polar transformation; Random
   forests},
