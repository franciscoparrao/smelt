}

@article{ WOS:000680240700001,
Author = {Xie, Yalong and Li, Aiping and Gao, Liqun and Liu, Ziniu},
Title = {A Heterogeneous Ensemble Learning Model Based on Data Distribution for
   Credit Card Fraud Detection},
Journal = {WIRELESS COMMUNICATIONS \& MOBILE COMPUTING},
Year = {2021},
Volume = {2021},
Month = {JUL 22},
Abstract = {Credit card fraud detection (CCFD) is important for protecting the
   cardholder's property and the reputation of banks. Class imbalance in
   credit card transaction data is a primary factor affecting the
   classification performance of current detection models. However, prior
   approaches are aimed at improving the prediction accuracy of the
   minority class samples (fraudulent transactions), but this usually leads
   to a significant drop in the model's predictive performance for the
   majority class samples (legal transactions), which greatly increases the
   investigation cost for banks. In this paper, we propose a heterogeneous
   ensemble learning model based on data distribution (HELMDD) to deal with
   imbalanced data in CCFD. We validate the effectiveness of HELMDD on two
   real credit card datasets. The experimental results demonstrate that
   compared with current state-of-the-art models, HELMDD has the best
   comprehensive performance. HELMDD not only achieves good recall rates
   for both the minority class and the majority class but also increases
   the savings rate for banks to 0.8623 and 0.6696, respectively.},
Type = {Article},
Affiliation = {Li, AP (Corresponding Author), Natl Univ Def Technol, Coll Comp, Changsha 410073, Hunan, Peoples R China.
   Xie, Yalong; Li, Aiping; Gao, Liqun; Liu, Ziniu, Natl Univ Def Technol, Coll Comp, Changsha 410073, Hunan, Peoples R China.},
DOI = {10.1155/2021/2531210},
Article-Number = {2531210},
