DOI = {10.1109/ACCESS.2022.3185129},
Keywords = {Heart; Random forests; Diseases; Feature extraction; Training; Radio
   frequency; Classification tree analysis; CVD detection; heart disease
   classification; feature selection; random forest; imbalance; Bayesian
   optimization},
Keywords-Plus = {PREDICTION; FRAMEWORK; SMOTE; SYSTEM},
Author-Email = {jievan@um.edu.my},
