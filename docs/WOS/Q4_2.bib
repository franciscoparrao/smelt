   Rahman, M. Sohel, Bangladesh Univ Engn \& Technol, Dept Comp Sci \& Engn, Dhaka 1205, Bangladesh.},
DOI = {10.1109/TSMC.2020.3016283},
Keywords = {Task analysis; Noise measurement; Neurons; Machine learning algorithms;
   Computer science; Genetic algorithms; Autoencoder; class imbalance;
   classification; neural network; undersampling},
Keywords-Plus = {CLASSIFICATION; IMBALANCE; FRAUD; SMOTE},
