@article{ WOS:000413127200002,
Author = {Ozturk, Muhammed Maruf},
Title = {Which type of metrics are useful to deal with class imbalance in
   software defect prediction?},
Journal = {INFORMATION AND SOFTWARE TECHNOLOGY},
Year = {2017},
Volume = {92},
Pages = {17-29},
Month = {DEC},
Abstract = {Context: There are various ways to cope with class imbalance problem
   which is one of the main issues of software defect prediction. Sampling
   algorithms are implemented on both industrial and open-source software
   defect prediction data sets by practitioners to wipe out imbalanced data
   points. Sampling algorithms, up-to-date, have been employed either
   static or process code metrics.
   Objective: In this study, sampling algorithms including Virtual, SMOTE,
   and HSDD (hybrid sampling for defect data sets) are explored using
   static code and quality metrics together. Our goal is not only to lead
   practitioners to decide the type of the metrics in defect prediction but
   also provide useful information for developers to design less defective
   software projects.
   Method: We ran sampling experiments with three sampling algorithms on
   ten data sets (from GitHub). Feature selection is applied on large
   features of the data sets. Using five classifiers, the performance of
   the data sets after sampling is compared with initial data sets.
   Regression analyzes are implemented on quality metrics to find the most
   influential metrics for detecting defect proneness.
   Results: Regardless of the type of the sampling, prediction performances
   are similar. Quality metrics surpassed static code metrics with respect
   to training times and prediction accuracies.
   Conclusion: Using quality metrics yields better prediction results
   rather than static code metrics in imbalanced data sets. As the count of
   project cloning increases, the number of defects decreases. Thus,
   approaches, related to the class imbalance, should be evaluated not only
   in terms of static code metrics but also for quality metrics. (C) 2017
   Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Öztürk, MM (Corresponding Author), Suleyman Demirel Univ, Fac Engn, Dept Comp Engn, Isparta, Turkey.
   Ozturk, Muhammed Maruf, Suleyman Demirel Univ, Fac Engn, Dept Comp Engn, Isparta, Turkey.},
DOI = {10.1016/j.infsof.2017.07.004},
Keywords = {Static code metrics; Process metrics; Class imbalance; Defect prediction},
Keywords-Plus = {SUITE},
Author-Email = {muhammedorturk@sdu.edu.tr},
Number-of-Cited-References = {70},
Times-Cited = {29},
Unique-ID = {WOS:000413127200002},
}

@article{ WOS:000405607000010,
Author = {Boonchuay, Kesinee and Sinapiromsaran, Krung and Lursinsap, Chidchanok},
Title = {Decision tree induction based on minority entropy for the class
   imbalance problem},
Journal = {PATTERN ANALYSIS AND APPLICATIONS},
Year = {2017},
Volume = {20},
Number = {3},
Pages = {769-782},
Month = {AUG},
Abstract = {Most well-known classifiers can predict a balanced data set efficiently,
   but they misclassify an imbalanced data set. To overcome this problem,
   this research proposes a new impurity measure called minority entropy,
   which uses information from the minority class. It applies a local range
   of minority class instances on a selected numeric attribute with
   Shannon's entropy. This range defines a subset of instances
   concentrating on the minority class to be constructed by decision tree
   induction. A decision tree algorithm using minority entropy shows
   improvement compared with the geometric mean and F-measure over C4.5,
   the distinct class-based splitting measure, asymmetric entropy, a
   top-down decision tree and Hellinger distance decision tree on 24
   imbalanced data sets from the UCI repository.},
Type = {Article},
Affiliation = {Boonchuay, K (Corresponding Author), Chulalongkorn Univ, Dept Math \& Comp Sci, Fac Sci, Bangkok 10330, Thailand.
   Boonchuay, Kesinee; Sinapiromsaran, Krung; Lursinsap, Chidchanok, Chulalongkorn Univ, Dept Math \& Comp Sci, Fac Sci, Bangkok 10330, Thailand.},
DOI = {10.1007/s10044-016-0533-3},
Keywords = {Decision tree; Minority entropy; Minority range; Geometric mean;
   F-measure},
Keywords-Plus = {SMOTE},
Author-Email = {bkasinee@hotmail.com
   Krung.S@chula.ac.th
   lchidcha@chula.ac.th},
Number-of-Cited-References = {32},
