   Roncoli, Claudio, Aalto Univ, Sch Engn, Dept Built Environm, Helsinki, Finland.
   Liu, Pan, Jiangsu Key Lab Urban ITS, Nanjing, Jiangsu, Peoples R China.},
DOI = {10.1016/j.trc.2022.103584},
EarlyAccessDate = {FEB 2022},
Article-Number = {103584},
Keywords = {Ramp metering; Reinforcement learning; Data-driven approach; Traffic
   control},
Keywords-Plus = {MODEL-PREDICTIVE CONTROL; OPTIMIZATION; CONGESTION; ALGORITHM; NETWORKS},
Author-Email = {yuhan@seu.edu.cn
   liupan@seu.edu.cn},
Number-of-Cited-References = {52},
Times-Cited = {64},
Unique-ID = {WOS:000777755900005},
}

@incollection{ WOS:000722006801004,
Author = {Zhang, Zhikun and Wang, Tianhao and Li, Ninghui and Honorio, Jean and
   Backes, Michael and He, Shibo and Chen, Jiming and Zhang, Yang},
Book-Group-Author = {USENIX Assoc},
Title = {PrivSyn: Differentially Private Data Synthesis},
Booktitle = {PROCEEDINGS OF THE 30TH USENIX SECURITY SYMPOSIUM},
Year = {2021},
Pages = {929-946},
Abstract = {In differential privacy (DP), a challenging problem is to generate
   synthetic datasets that efficiently capture the useful information in
   the private data. The synthetic dataset enables any task to be done
   without privacy concern and modification to existing algorithms. In this
   paper, we present PrivSyn, the first automatic synthetic data generation
   method that can handle general tabular datasets (with 100 attributes and
   domain size > 2(500)). PrivSyn is composed of a new method to
   automatically and privately identify correlations in the data, and a
   novel method to generate sample data from a dense graphic model. We
   extensively evaluate different methods on multiple datasets to
   demonstrate the performance of our method.},
