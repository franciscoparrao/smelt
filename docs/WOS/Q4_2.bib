   Zhou, Changjun, Zhejiang Normal Univ, Coll Math \& Comp Sci Phys \& Informat Engn, Jinhua 321004, Zhejiang, Peoples R China.},
DOI = {10.1109/ACCESS.2019.2917920},
Keywords = {Classification; ensemble learning; imbalanced datasets; oversampling},
