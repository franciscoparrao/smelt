   Li, Jie, Southern Med Univ, Nan Fang Hosp, Dept Hematol, Guangzhou 510515, Peoples R China.},
DOI = {10.1016/j.bspc.2021.103296},
EarlyAccessDate = {NOV 2021},
Article-Number = {103296},
Keywords = {Deep learning; Bone marrow cell classification; Class-balanced method;
   Long-tail distribution},
Author-Email = {maqx@m.scnu.edu.cn
   ljjean@163.com},
Number-of-Cited-References = {35},
Times-Cited = {22},
