   ensemble; Feature-level fusion},
Keywords-Plus = {HUMAN ACTIVITY RECOGNITION; WEARABLE SENSOR NETWORKS; PHYSICAL-ACTIVITY;
   MULTIVIEW STACKING; VITAL SIGN; ENSEMBLE; CONTEXT; MOBILE; ACCELERATION;
   ALGORITHM},
