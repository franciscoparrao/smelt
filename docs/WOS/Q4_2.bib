}

@incollection{ WOS:000432603300003,
Author = {Andermatt, Simon and Pezold, Simon and Cattin, Philippe C.},
Editor = {Crimi, A and Bakas, S and Kuijf, H and Menze, B and Reyes, M},
Title = {Automated Segmentation of Multiple Sclerosis Lesions Using
   Multi-dimensional Gated Recurrent Units},
Booktitle = {BRAINLESION: GLIOMA, MULTIPLE SCLEROSIS, STROKE AND TRAUMATIC BRAIN
   INJURIES, BRAINLES 2017},
Series = {Lecture Notes in Computer Science},
Year = {2018},
Volume = {10670},
Pages = {31-42},
Abstract = {We analyze the performance of multi-dimensional gated recurrent units on
   automated lesion segmentation in multiple sclerosis. The segmentation of
   these pathologic structures is not trivial, since location, shape and
   size can be arbitrary. Furthermore, the inherent class imbalance of
   about 1 lesion voxel to 10 000 healthy voxels further exacerbates the
   correct segmentation. We introduce a new MD-GRU setup, using established
   techniques from the deep learning community as well as our own
   adaptations. We evaluate these modifications by comparing them to a
   standard MD-GRU network. We demonstrate that using data augmentation,
   selective sampling, residual learning and/or DropConnect on the RNN
   state can produce better segmentation results. Reaching rank \#1 in the
   ISBI 2015 longitudinal multiple sclerosis lesion segmentation challenge,
   we show that a setup which combines these techniques can outperform the
   state of the art in automated lesion segmentation.},
Type = {Proceedings Paper},
Affiliation = {Andermatt, S (Corresponding Author), Univ Basel, Dept Biomed Engn, Allschwil, Switzerland.
   Andermatt, Simon; Pezold, Simon; Cattin, Philippe C., Univ Basel, Dept Biomed Engn, Allschwil, Switzerland.},
DOI = {10.1007/978-3-319-75238-9\_3},
Keywords = {MD-GRU; MDGRU; Automatic MS lesion segmentation},
Author-Email = {simon.andermatt@unibas.ch},
Number-of-Cited-References = {12},
Times-Cited = {49},
Unique-ID = {WOS:000432603300003},
}

@article{ WOS:000966205100001,
Author = {Ding, Hongwei and Sun, Yu and Huang, Nana and Shen, Zhidong and Wang,
   Zhenyu and Iftekhar, Adnan and Cui, Xiaohui},
Title = {RVGAN-TL: A generative adversarial networks and transfer learning-based
   hybrid approach for imbalanced data classification},
Journal = {INFORMATION SCIENCES},
Year = {2023},
Volume = {629},
Pages = {184-203},
Month = {JUN},
Abstract = {Imbalanced data distribution is the main reason for the performance
   degradation of most supervised classification algorithms. When dealing
   with imbalanced learning problems, prediction of traditional classifiers
   tends to favor the majority class and ignore the minority class which is
   often much more important. Therefore, it is necessary to balance
   majority data and minority data before classification. A popular
   strategy for balancing the two data classes is synthesizing minority
   data. In recent years, generative adversarial networks (GAN) have shown
   great potential in fitting sample distributions. Based on this, this
   paper proposes a model combining improved GAN and transfer learning,
   RVGAN-TL, to solve the imbalanced learning problem of tabular data. As
   for the improvement of GAN, variational autoencoder (VAE) is used
   generate latent variables with a posterior distribution as the input of
   GAN, and similarity measure loss is introduced into the generator to
   improve the quality of the minority data generated GAN. In addition, a
   roulette wheel selection method is applied to the training data
   selection GAN to rebalance data in the overlapping area. When data is
   balanced, the generated data is used as the source domain and the
   original data as the target domain, and the transfer learning method is
   used to train the final classifier. Experiments on 20 real datasets show
   that the classification performance of the proposed method is
   significantly improved compared with other popular methods.},
Type = {Article},
Affiliation = {Cui, XH (Corresponding Author), Wuhan Univ, Sch Cyber Sci \& Engn, Key Lab Aerosp Informat Secur \& Trusted Comp, Minist Educ, Wuhan, Peoples R China.
