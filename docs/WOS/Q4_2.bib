Affiliation = {Nguyen, T (Corresponding Author), Graz Univ Technol, Signal Proc \& Speech Commun Lab, A-8010 Graz, Austria.
   Truc Nguyen; Pernkopf, Franz, Graz Univ Technol, Signal Proc \& Speech Commun Lab, A-8010 Graz, Austria.},
