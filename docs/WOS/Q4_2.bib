   Li, Xiaojian, Guangxi Normal Univ, Coll Comp Sci \& Informat Technol, Guilin 541004, Guangxi, Peoples R China.
   Zhang, Song, KunLun Digital Technol Co Ltd, Beijing, Peoples R China.},
DOI = {10.1016/j.cose.2024.104155},
EarlyAccessDate = {OCT 2024},
