   Quang Thang Do, Nha Trang Univ, Dept Naval Architecture \& Ocean Engn, 02 Nguyen Dinh Chieu, Nha Trang 650000, Vietnam.},
DOI = {10.1016/j.asoc.2022.108628},
EarlyAccessDate = {MAR 2022},
