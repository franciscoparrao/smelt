Affiliation = {Devi, D (Corresponding Author), Natl Inst Technol, Silchar, Assam, India.
   Devi, Debashree, Natl Inst Technol, Silchar, Assam, India.
   Namasudra, Suyel, Natl Inst Technol Patna, Patna, Bihar, India.
   Kadry, Seifedine, Beirut Arab Univ, Beirut, Lebanon.},
DOI = {10.4018/IJDWM.2020070104},
Keywords = {AdaBoost; Class Imbalance; Cluster-Based Undersampling; Data Mining;
