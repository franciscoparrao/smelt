   Pacheco-Sanchez, J. H., Inst Tecnol Toluca, Metepec 52140, Mexico.},
DOI = {10.1007/s11063-014-9376-3},
Keywords = {High multi-class imbalance; Sequential back-propagation algorithm; Mean
   square error; Dynamic over-sampling technique; SMOTE},
Keywords-Plus = {NEURAL-NETWORKS; CLASSIFICATION; ALGORITHM},
Author-Email = {ralejoll@hotmail.com
