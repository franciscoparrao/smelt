   Garcia-Borroto, Milton, Inst Super Politecn Jose Antonio Echeverria, Havana 19390, Cuba.},
DOI = {10.1016/j.neucom.2015.04.120},
Keywords = {Supervised classification; Resampling methods; Imbalanced databases;
   Contrast patterns},
Keywords-Plus = {EMERGING PATTERNS; SOFTWARE TOOL; DATA SETS; CLASSIFICATION;
   EVOLUTIONARY; SMOTE; INTELLIGENCE; ALGORITHMS; TESTS; KEEL},
Author-Email = {octavioloyola@bioplantas.cu
