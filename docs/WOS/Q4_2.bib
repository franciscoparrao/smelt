DOI = {10.1109/TBCAS.2021.3137646},
Keywords = {Anomaly detection; edge computing; IoT sensors; LSTM; MLP; neural
   networks; power reduction},
Keywords-Plus = {ON-CHIP; CLASSIFICATION; LSTM},
