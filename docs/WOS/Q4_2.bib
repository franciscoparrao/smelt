   Ding, Hongliang, Southwest Jiaotong Univ, Inst Smart City \& Intelligent Transportat, Chengdu, Sichuan, Peoples R China.},
DOI = {10.1016/j.trc.2024.104642},
EarlyAccessDate = {MAY 2024},
