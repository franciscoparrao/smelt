   Tuan, Tong Anh; Long, Hoang Viet, Univ Technol Logist Publ Secur, Bac Ninh, Vietnam.
   Trung, Pham Duy, Acad Cryptog Tech, Hanoi, Vietnam.},
DOI = {10.1016/j.cose.2024.104233},
EarlyAccessDate = {DEC 2024},
