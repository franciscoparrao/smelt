   Lakshminarayanan, Vasudevan, Univ Waterloo, Dept Syst Design Engn, Waterloo, ON N2L 3G1, Canada.},
DOI = {10.1109/ACCESS.2024.3432741},
Keywords = {Robots; Manipulators; Service robots; Robot sensing systems; Software
