   Wu, Jei-Zheng, Soochow Univ, Dept Business Adm, Taipei 100, Taiwan.
   Chakrabortty, Ripon K., UNSW Canberra, Sch Engn \& IT, Capabil Syst Ctr, ADFA, Canberra, ACT 2612, Australia.},
DOI = {10.3390/pr9101713},
