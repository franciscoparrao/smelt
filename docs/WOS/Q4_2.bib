@article{ WOS:000354824900004,
Author = {Jiang, Liangxiao and Qiu, Chen and Li, Chaoqun},
Title = {A Novel Minority Cloning Technique for Cost-Sensitive Learning},
Journal = {INTERNATIONAL JOURNAL OF PATTERN RECOGNITION AND ARTIFICIAL INTELLIGENCE},
Year = {2015},
Volume = {29},
Number = {4},
Month = {JUN},
Abstract = {In many real-world applications, it is often the case that the class
   distribution of instances is imbalanced and the costs of
   misclassiffication are different. Thus, the class-imbalanced
   cost-sensitive learning has attracted much attention from researchers.
   Sampling is one of the widely used techniques in dealing with the
   class-imbalance problem, which alters the class distribution of
   instances so that the minority class is well represented in the training
   data. In this paper, we propose a novel Minority Cloning Technique (MCT)
   for class-imbalanced cost-sensitive learning. MCT alters the class
   distribution of training data by cloning each minority class instance
   according to the similarity between it and the mode of the minority
   class. The experimental results on a large number of UCI datasets show
   that MCT performs much better than Minority Oversampling with
   Replacement Technique (MORT) and Synthetic Minority Oversampling
   TEchnique (SMOTE) in terms of the total misclassiffication costs of the
   built classifiers.},
Type = {Article},
Affiliation = {Jiang, LX (Corresponding Author), China Univ Geosci, Dept Comp Sci, Wuhan 430074, Hubei, Peoples R China.
   Jiang, Liangxiao; Qiu, Chen, China Univ Geosci, Dept Comp Sci, Wuhan 430074, Hubei, Peoples R China.
   Li, Chaoqun, China Univ Geosci, Dept Math, Wuhan 430074, Hubei, Peoples R China.},
DOI = {10.1142/S0218001415510040},
Article-Number = {1551004},
Keywords = {Instance cloning; similarity; cost-sensitive learning;
   misclassiffication cost},
Author-Email = {ljiang@cug.edu.cn
   qiuchen1114@gmail.com
   chqli@cug.edu.cn},
Number-of-Cited-References = {39},
Times-Cited = {43},
