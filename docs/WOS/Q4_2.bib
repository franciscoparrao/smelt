   Juez-Gil, Mario; Arnaiz-Gonzalez, Alvar; Rodriguez, Juan J.; Lopez-Nozal, Carlos; Garcia-Osorio, Cesar, Univ Burgos, Dept Ingn Informat, Escuela Politecn Super, Burgos 09006, Spain.},
DOI = {10.1016/j.neucom.2021.08.086},
EarlyAccessDate = {SEP 2021},
Keywords = {SMOTE; Imbalance; Spark; Big data; Data mining},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {mariojg@ubu.es
   alvarag@ubu.es
   jjrodriguez@ubu.es
   clopezno@ubu.es
   cgosorio@ubu.es},
Number-of-Cited-References = {21},
