@article{ WOS:001207576000001,
Author = {Bai, Lin and Ju, Tong and Wang, Hao and Lei, Mingzhu and Pan, Xiaoying},
Title = {Two-step ensemble under-sampling algorithm for massive imbalanced data
   classification},
Journal = {INFORMATION SCIENCES},
Year = {2024},
Volume = {665},
Month = {APR},
Abstract = {Imbalanced data classification is a challenging problem in the field of
   machine learning. Class imbalance, class overlap, and large data volume
   significantly affect classification performance. Focusing on the impact
   of class overlap on classification effectiveness, we propose a two-step
   ensemble under -sampling algorithm based on boundary information mining
   (TSSE-BIM) with the goal of reducing the information loss from under
   -sampling methods on large-scale imbalanced data. In the first stage,
   the proposed method applies an improved equalization under -sampling
   strategy to mine sample contribution information and quickly obtains the
   distribution information of data relative to the decision boundary. In
   the second stage, based on the boundary information, a weighted boundary
   sampling is performed to remove noisy and highly overlapping samples. It
   is easy to retain samples with high contribution and effectively
   suppress the information loss caused by under -sampling. Then, the
   overall framework is designed based on a serial ensemble similar to
   boosting, where the weights of each base classifier are assigned to
   achieve a more powerful performance based on the false positive rate and
   false negative rate on the original data. Finally, extensive experiments
   indicate that TSSE-BIM outperforms state-of-the-art methods and ranks
   first on average under four metrics, especially F1 and MCC.},
Type = {Article},
Affiliation = {Bai, L (Corresponding Author), Xian Univ Posts \& Telecommun, Sch Comp Sci \& Technol, Xian 710121, Peoples R China.
   Bai, Lin; Ju, Tong; Wang, Hao; Lei, Mingzhu; Pan, Xiaoying, Xian Univ Posts \& Telecommun, Sch Comp Sci \& Technol, Xian 710121, Peoples R China.
   Bai, Lin; Pan, Xiaoying, Xian Univ Posts \& Telecommun, Shaanxi Key Lab Network Data Anal \& Intelligent Pr, Xian 710121, Peoples R China.},
DOI = {10.1016/j.ins.2024.120351},
EarlyAccessDate = {FEB 2024},
Article-Number = {120351},
Keywords = {Imbalanced data classification; Ensemble learning; Under-sampling;
   Large-scale data; Overlapping data},
Keywords-Plus = {SMOTE},
Author-Email = {bailin@xupt.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {25},
Unique-ID = {WOS:001207576000001},
}

@article{ WOS:000990585000001,
Author = {Kumari, Ritika and Singh, Jaspreeti and Gosain, Anjana},
Title = {SmS: SMOTE-stacked hybrid model for diagnosis of polycystic ovary
   syndrome using feature selection method},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2023},
Volume = {225},
Month = {SEP 1},
Abstract = {Polycystic Ovary syndrome (PCOS) is the most common serious health
   problem in women worldwide. It affects the women's fertility and may
   lead to various health problems like type 2 diabetes, cardiovascular
   diseases, etc. Early diagnosis of PCOS is recommended for proper
   treatment. In this paper, we propose SmS: SMOTE-Stacked hybrid model,
   for the early diagnosis of PCOS. In the proposed model, we combine the
   ensemble technique `stacking' with oversampling technique `SMOTE' i.e.,
   Synthetic minority oversampling technique. In the Stacking ensemble
   technique, training is performed at two levels: base level and meta
   level. We use six classifiers Logistic Regression (LR), Support Vector
   Machine (SVM), Decision Tree (DT), Random Forest (RF), Naive Bayes (NB)
   and AdaBoost (AdaB) as base leaners at the base level and consider each
   of these classifiers separately at the meta -level to implement SmS
   hybrid models: Stack-LR, Stack-SVM, Stack-DT, Stack-RF, Stack-NB and
   Stack-AdaB. Standardization, SMOTE and Backward Feature Elimination
   (BFE) are performed before training the classi-fiers. We evaluate the
   performance of the individual classifiers and hybrid models on PCOS
   dataset (Imbalanced) taken form the Kaggle Repository and observe that
   Stack-AdaB shows the most promising results.},
Type = {Article},
Affiliation = {Kumari, R (Corresponding Author), Guru Gobind Singh Indraprastha Univ, USICT, New Delhi, India.
   Kumari, Ritika; Singh, Jaspreeti; Gosain, Anjana, Guru Gobind Singh Indraprastha Univ, USICT, New Delhi, India.
