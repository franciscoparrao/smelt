@article{ WOS:000527301700035,
Author = {Li, Min and Xiong, An and Wang, Lei and Deng, Shaobo and Ye, Jun},
Title = {ACO Resampling: Enhancing the performance of oversampling methods for
   class imbalance classification},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2020},
Volume = {196},
Month = {MAY 21},
Abstract = {Many sampling-based preprocessing methods have been proposed to solve
   the problem of unbalanced dataset classification. The fundamental
   principle of these methods is rebalancing an unbalanced dataset by a
   concrete strategy. Herein, we introduce a novel hybrid proposal named
   ant colony optimization resampling (ACOR) to overcome class imbalance
   classification. ACOR primarily includes two steps: first, it rebalances
   an imbalanced dataset by a specific oversampling algorithm; next, it
   finds an (sub)optimal subset from the balanced dataset by ant colony
   optimization. Unlike other oversampling techniques, ACOR does not focus
   on the mechanics of generating new samples. The main advantage of ACOR
   is that existing oversampling algorithms can be fully utilized and an
   ideal training set can be obtained by ant colony optimization.
   Therefore, ACOR can enhance the performance of existing oversampling
   algorithms. Experimental results on 18 real imbalanced datasets prove
   that ACOR yields significantly better results compared with four popular
   oversampling methods in terms of various assessment metrics, such as
   AUC, G-mean, and BACC. (C) 2020 Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Li, M (Corresponding Author), Nanchang Inst Technol, Sch Informat Engn, Nanchang 330099, Jiangxi, Peoples R China.
   Li, Min; Xiong, An; Wang, Lei; Deng, Shaobo; Ye, Jun, Nanchang Inst Technol, Sch Informat Engn, Nanchang 330099, Jiangxi, Peoples R China.
   Xiong, An; Wang, Lei; Deng, Shaobo; Ye, Jun, Jiangxi Prov Key Lab Water Informat Cooperat Sens, Nanchang 330099, Jiangxi, Peoples R China.},
DOI = {10.1016/j.knosys.2020.105818},
Article-Number = {105818},
Keywords = {Machine learning; Imbalanced learning; Oversampling; Ant colony
   optimization resampling},
Keywords-Plus = {CLASSIFIERS; PREDICTION; SELECTION; DATASETS; CANCER; TUMOR; SMOTE},
Author-Email = {liminghuadi@hotmail.com},
Number-of-Cited-References = {59},
