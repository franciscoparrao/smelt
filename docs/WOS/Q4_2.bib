@article{ WOS:001127580400001,
Author = {Tian, Jilun and Jiang, Yuchen and Zhang, Jiusi and Luo, Hao and Yin,
   Shen},
Title = {A novel data augmentation approach to fault diagnosis with
   class-imbalance problem},
Journal = {RELIABILITY ENGINEERING \& SYSTEM SAFETY},
Year = {2024},
Volume = {243},
Month = {MAR},
Abstract = {Data-driven fault diagnosis techniques are frequently applied to ensure
   the reliability and safety of industrial systems. However, as a common
   challenge, the class-imbalance problem reduces the performance of data
   -driven methods due to the lack of data information. We propose a
   weighted modified conditional variational auto-encoder (WM-CVAE) as a
   novel data augmentation technique to tackle the issue. The modified
   structure can alleviate the existing Kullback-Leibler (KL) divergence
   vanishing by an adaptive loss. Meanwhile, kernel mean matching (KMM) is
   proposed on weight computation to reduce the negative effect of
   dissimilar generated samples. Constructing the WM-CVAE data augmentation
   framework can effectively improve the data quality and learning
   capability in class-imbalance fault diagnosis. To validate the proposed
   WM-CVAE model, three real-world industrial datasets are used as study
   objects, and the random forest is used as the base learner in the fault
   classification tasks. The diagnostic results demonstrate that the
   proposed WM-CVAE data augmentation framework can improve learning
   results in class-imbalance fault diagnosis.},
Type = {Article},
Affiliation = {Luo, H (Corresponding Author), Harbin Inst Technol, Sch Astronaut, Dept Control Sci \& Engn, Harbin 150000, Peoples R China.
   Tian, Jilun; Jiang, Yuchen; Zhang, Jiusi; Luo, Hao, Harbin Inst Technol, Sch Astronaut, Dept Control Sci \& Engn, Harbin 150000, Peoples R China.
   Yin, Shen, Norwegian Univ Sci \& Technol, Fac Engn, Dept Mech \& Ind Engn, N-7034 Trondheim, Norway.},
DOI = {10.1016/j.ress.2023.109832},
EarlyAccessDate = {NOV 2023},
Article-Number = {109832},
Keywords = {Class imbalance; Fault diagnosis; Conditional variational auto-encoder;
   Kullback-Leibler Divergence Vanishing; Kernel mean matching},
Author-Email = {yc.jiang@hit.edu.cn
   hao.luo@hit.edu.cn},
