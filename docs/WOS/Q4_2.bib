}

@article{ WOS:000732910300001,
Author = {Xu, Yuhong and Yu, Zhiwen and Chen, C. L. Philip and Liu, Zhulin},
Title = {Adaptive Subspace Optimization Ensemble Method for High-Dimensional
   Imbalanced Data Classification},
Journal = {IEEE TRANSACTIONS ON NEURAL NETWORKS AND LEARNING SYSTEMS},
Year = {2023},
Volume = {34},
Number = {5},
Pages = {2284-2297},
Month = {MAY},
Abstract = {It is hard to construct an optimal classifier for high-dimensional
   imbalanced data, on which the performance of classifiers is seriously
   affected and becomes poor. Although many approaches, such as resampling,
   cost-sensitive, and ensemble learning methods, have been proposed to
   deal with the skewed data, they are constrained by high-dimensional data
   with noise and redundancy. In this study, we propose an adaptive
   subspace optimization ensemble method (ASOEM) for high-dimensional
   imbalanced data classification to overcome the above limitations. To
   construct accurate and diverse base classifiers, a novel adaptive
   subspace optimization (ASO) method based on adaptive subspace generation
   (ASG) process and rotated subspace optimization (RSO) process is
   designed to generate multiple robust and discriminative subspaces. Then
   a resampling scheme is applied on the optimized subspace to build a
   class-balanced data for each base classifier. To verify the
   effectiveness, our ASOEM is implemented based on different resampling
   strategies on 24 real-world high-dimensional imbalanced datasets.
   Experimental results demonstrate that our proposed methods outperform
   other mainstream imbalance learning approaches and classifier ensemble
   methods.},
Type = {Article},
Affiliation = {Yu, ZW (Corresponding Author), South China Univ Technol, Sch Comp Sci \& Engn, Guangzhou 510006, Peoples R China.
   Xu, Yuhong; Yu, Zhiwen; Chen, C. L. Philip; Liu, Zhulin, South China Univ Technol, Sch Comp Sci \& Engn, Guangzhou 510006, Peoples R China.},
DOI = {10.1109/TNNLS.2021.3106306},
EarlyAccessDate = {AUG 2021},
Keywords = {Learning systems; Optimization; Training; Feature extraction; Data
   mining; Boosting; Bagging; Adaptive subspace selection; class imbalance;
   ensemble learning; high-dimensional data; resampling},
Keywords-Plus = {FEATURE-SELECTION; SAMPLING APPROACH; NEURAL-NETWORKS; DATA SETS;
   ALGORITHM; SMOTE; SYSTEM; FOREST},
Author-Email = {zhwyu@scut.edu.cn},
