Keywords = {autism spectrum disorder (ASD); brain-computer interface (BCI); P300
   electroencephalogram (EEG) signal; machine learning (ML); variational
   mode decomposition (VMD)},
Keywords-Plus = {WAVELET TRANSFORM; SYSTEM; AMPLITUDE; LATENCY},
Author-Email = {santhosh@students.vnit.ac.in},
Number-of-Cited-References = {54},
