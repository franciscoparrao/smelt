   Khairy, Marwa, Minia Univ, Fac Comp \& Informat, El Minia, Egypt.
   Mahmoud, Tarek M., Univ Sadat City, Fac Comp \& Artificial Intelligence, Comp Sci Dept, Sadat City, Egypt.
   Abd-El-Hafeez, Tarek, Minia Univ, Fac Sci, Comp Sci Dept, El Minia, Egypt.
   Abd-El-Hafeez, Tarek, Deraya Univ, El Minia, Egypt.},
DOI = {10.1007/s00521-023-09084-w},
EarlyAccessDate = {NOV 2023},
Keywords = {Classification; Cyberbullying; Undersampling; Oversampling; SMOTE; TOMEK},
Author-Email = {Marwa.kh.mohamed@mu.edu.eg
   tarek@fcai.usc.edu.eg
   tarek@mu.edu.eg},
