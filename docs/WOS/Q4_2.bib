DOI = {10.1109/LGRS.2021.3104506},
Article-Number = {3003905},
Keywords = {Strain; Task analysis; Training; Pipelines; Observatories; Convolutional
   neural networks; Volcanic activity; Contrastive learning; deep learning
   (DL); Fagradalsfjall eruption; interferometric synthetic aperture
   radar\~{}(InSAR); self-supervised; SimCLR; volcano},
Author-Email = {ipapoutsis@noa.gr},
Number-of-Cited-References = {17},
