   R-value; class-imbalance; feature selection; fraud detection;
   overlapping},
Keywords-Plus = {CLASSIFICATION; CLASSIFIERS; SYSTEM; CHALLENGES; ALGORITHM; SMOTE},
Author-Email = {castchoi@ynu.ac.kr},
Number-of-Cited-References = {56},
