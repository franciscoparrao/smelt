DOI = {10.1109/ACCESS.2018.2865383},
Keywords = {Software fault prediction; data preprocessing; feature selection; rough
   set theory; class imbalance; noise filter; easy ensemble},
Keywords-Plus = {FEATURE-SELECTION; CLASS-IMBALANCE; DEFECT PREDICTION; SAMPLING
