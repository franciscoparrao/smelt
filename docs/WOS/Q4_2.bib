}

@article{ WOS:000815676900042,
Author = {Manalastas, Marvin and Bin Farooq, Muhammad Umar and Zaidi, Syed
   Muhammad Asad and Abu-Dayya, Adnan and Imran, Ali},
Title = {A Data-Driven Framework for Inter-Frequency Handover Failure Prediction
   and Mitigation},
Journal = {IEEE TRANSACTIONS ON VEHICULAR TECHNOLOGY},
Year = {2022},
Volume = {71},
Number = {6},
Pages = {6158-6172},
Month = {JUN},
Abstract = {With 5G already deployed, challenges related to handover exacerbate due
   to the dense base station deployment operating on a motley of
   frequencies. In this paper, we present and evaluate a novel data-driven
   solution, to reduce inter-frequency handover failures (HOFs), hereafter
   referred to as TORIS (Transmit Power Tuning-based Handover Success Rate
   Improvement Scheme). TORIS is designed by developing and integrating two
   sub-solutions. First sub-solution consists of an Artificial Intelligence
   (AI)-based model to predict inter-frequency HOFs. In this model, we
   achieve higher than the state-of-the-art accuracy by leveraging two
   approaches. First, we devise a novel feature set by exploiting domain
   knowledge gathered from extensive drive test data analysis. Second, we
   exploit an extensive set of data augmentation techniques to address the
   class imbalance in training the HOF prediction model. The data
   augmentation techniques include Chow-Liu Bayesian Network and Generative
   Adversarial Network further improved by focusing the sampling only on
   the borderline. We also compare the performance of state-of-the-art AI
   models for predicting HOFs with and without augmented data. Results show
   that AdaBoost yields best performance for predicting HOFs. The second
   sub-solution is a heuristic scheme to tune the transmit (Tx) power of
   serving and target cells. Unlike the state-of-the-art approaches for HOF
   reduction that tune cell individual offset, TORIS targets the main cause
   of HOFs i.e., poor signal quality and propagation condition, by
   proactively varying the Tx power of the cells whenever a HOF is
   anticipated. Results show that TORIS outperforms the state-of-the-art
   HOF reduction solution and yields 40\%-75\% reduction in HOFs.},
Type = {Article},
Affiliation = {Manalastas, M (Corresponding Author), Univ Oklahoma, AI4Networks Res Ctr, Sch Elect \& Comp Engn, Norman, OK 73019 USA.
   Manalastas, Marvin; Bin Farooq, Muhammad Umar; Zaidi, Syed Muhammad Asad; Imran, Ali, Univ Oklahoma, AI4Networks Res Ctr, Sch Elect \& Comp Engn, Norman, OK 73019 USA.
   Abu-Dayya, Adnan, Qatar Univ, Dept Elect Engn, Doha 2713, Qatar.},
DOI = {10.1109/TVT.2022.3157802},
Keywords = {Handover; Predictive models; Tuning; Data models; Prediction algorithms;
   Analytical models; Standards; Handover failure prediction; handover
   failure mitigation; inter-frequency handover; handover success rate
   improvement},
Keywords-Plus = {OPTIMIZATION; NETWORKS; SMOTE; 5G},
Author-Email = {marvin@ou.edu
   umar.farooq@ou.edu
   asad@ou.edu
   adnan@qu.edu.qa
   ali.imran@ou.edu},
Number-of-Cited-References = {42},
