Keywords = {Cloud-based malware dataset; Cloud-based malware detection; Integrated
   deep learning; Static analysis; Dynamic analysis},
Keywords-Plus = {NEURAL-NETWORKS},
Author-Email = {longhv08@gmail.com},
Number-of-Cited-References = {76},
Times-Cited = {15},
