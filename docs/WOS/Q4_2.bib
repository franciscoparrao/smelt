@article{ WOS:000579349700001,
Author = {Mukhtar, Naila and Fournaris, Apostolos P. and Khan, Tariq M. and
   Dimopoulos, Charis and Kong, Yinan},
Title = {Improved Hybrid Approach for Side-Channel Analysis Using Efficient
   Convolutional Neural Network and Dimensionality Reduction},
Journal = {IEEE ACCESS},
Year = {2020},
Volume = {8},
Pages = {184298-184311},
Abstract = {Deep learning-based side channel attacks are burgeoning due to their
   better efficiency and performance, suppressing the traditional
   side-channel analysis. To launch the successful attack on a particular
   public key cryptographic (PKC) algorithm, a large number of samples per
   trace might need to be acquired to capture all the minor useful details
   from the leakage information, which increases the number of features per
   instance. The decreased instance-feature ratio increases the
   computational complexity of the deep learning-based attacks, limiting
   the attack efficiency. Moreover, data class imbalance can be a hindrance
   in accurate model training, leading to an accuracy paradox. We propose
   an efficient Convolutional Neural Network (CNN) based approach in which
   the dimensionality of the large leakage dataset is reduced, and then the
   data is processed using the proposed CNN based model. In the proposed
   model, the optimal number of convolutional blocks is used to build
   powerful features extractors within the cost limit. We have also
   analyzed and presented the impact of using the Synthetic Minority
   Over-sampling Technique (SMOTE) on the proposed model performance. We
   propose that a data-balancing step should be mandatory for analysis in
   the side channel attack scenario. We have also provided a
   performance-based comparative analysis between proposed and existing
   deep learning models for unprotected and protected Elliptic curve (ECC)
   Montgomery Power ladder implementations. The reduced network complexity,
   together with an improved attack efficiency, promote the proposed
   approach to be effectively used for side-channel attacks.},
Type = {Article},
Affiliation = {Mukhtar, N (Corresponding Author), Macquarie Univ, Sch Engn, Sydney, NSW 2109, Australia.
   Mukhtar, Naila; Kong, Yinan, Macquarie Univ, Sch Engn, Sydney, NSW 2109, Australia.
   Fournaris, Apostolos P., Res Ctr ATHENA, Ind Syst Inst, Maroussi 26504, Greece.
   Khan, Tariq M., Deakin Univ, Sch Informat Technol, Waurn Ponds Campus, Geelong, Vic 3216, Australia.
   Dimopoulos, Charis, Univ Patras, Dept Elect \& Comp Engn, Patras 26500, Greece.},
DOI = {10.1109/ACCESS.2020.3029206},
Keywords = {Side-channel attacks; Machine learning; Elliptic curve cryptography;
   Feature extraction; Machine learning algorithms; Side-channel attacks;
   machine learning analysis; elliptic curve security; embedded system
   security},
Keywords-Plus = {ELLIPTIC CURVE CRYPTOGRAPHY; POWER ANALYSIS; AUTHENTICATION SCHEME;
   DIFFERENTIAL POWER; ATTACKS; ALGORITHM},
Author-Email = {naila.mukhtar@students.mq.edu.au},
Number-of-Cited-References = {56},
Times-Cited = {16},
Unique-ID = {WOS:000579349700001},
}

@incollection{ WOS:000475555800007,
Author = {Kumar, Lov and Satapathy, Shashank Mouli and Murthy, Lalita Bhanu},
Editor = {Naik, R and Sarkar, S and Hildebrandt, T and Kumar, A and Sharma, R},
Title = {Method Level Refactoring Prediction on Five Open Source Java Projects
   using Machine Learning Techniques},
Booktitle = {PROCEEDINGS OF THE 12TH INNOVATIONS ON SOFTWARE ENGINEERING CONFERENCE
   (ISEC)},
Year = {2019},
Abstract = {Introduction : Identifying code segments in large and complex systems in
   need of refactoring is non-trivial for software developers. Our research
   aim is to develop recommendation systems for suggesting methods which
   require refactoring. Materials and Methods : Previous research shows
   that source code metrics for object-oriented software systems are
   indicators of complexity of a software system. We compute 25 different
   source code metrics at the method level and use it as features in a
   machine learning framework to predict the need of refactoring. We
   conduct a series of experiments on a publicly available annotated
   dataset of five software systems to investigate the performance of our
   proposed approach. In this proposed solution, ten different machine
   learning classifiers have been considered. In order to handle issues
   related to class imbalance, three different data sampling methods are
   also considered during implementation. Conclusion : Our analysis reveals
   that the mean accuracy for the SMOTE and RUSBoost data sampling
   technique is 98.47\% respectively. The mean accuracy for the classifier
   AdaBoost is 98.16\% and the mean accuracy for the classifier ANN+GD is
   98.17\% respectively. Hypothesis testing results reveals that the
   performance of different classifiers and data sampling techniques are
   statistically significant in nature.},
Type = {Proceedings Paper},
Affiliation = {Kumar, L (Corresponding Author), BITS Pilani Hyderabad, Hyderbad, India.
   Kumar, Lov; Murthy, Lalita Bhanu, BITS Pilani Hyderabad, Hyderbad, India.
   Satapathy, Shashank Mouli, Vellore Inst Technol, Vellore, Tamil Nadu, India.},
DOI = {10.1145/3299771.3299777},
Keywords = {Empirical Software Engineering and Measurements (ESEM); Machine
   Learning; Software Refactoring; Software Maintenance; Source Code
   Analysis and Measurement},
Author-Email = {lovkumar505@gmail.com
   shashankamouli@gmail.com
   bhanu@hyderabad.bits-pilani.ac.in},
Number-of-Cited-References = {21},
Times-Cited = {16},
Unique-ID = {WOS:000475555800007},
}

@incollection{ WOS:000579452200159,
Author = {Krawczyk, Bartosz},
Editor = {Altintas, I and Norman, M and Dongarra, J and Krzhizhanovskaya, VV and Lees, M and Sloot, PMA},
Title = {GPU-Accelerated Extreme Learning Machines for Imbalanced Data Streams
   with Concept Drift},
Booktitle = {INTERNATIONAL CONFERENCE ON COMPUTATIONAL SCIENCE 2016 (ICCS 2016)},
Series = {Procedia Computer Science},
Year = {2016},
Volume = {80},
Pages = {1692-1701},
Abstract = {Mining data streams is one of the most vital fields in the current era
   of big data. Continuously arriving data may pose various problems,
   connected to their volume, variety or velocity. In this paper we focus
   on two important difficulties embedded in the nature of data streams:
   non-stationary nature and skewed class distributions. Such a scenario
   requires a classifier that is able to rapidly adapt itself to concept
   drift and displays robustness to class imbalance problem. We propose to
   use online version of Extreme Learning Machine that is enhanced by an
   efficient drift detector and method to alleviate the bias towards the
   majority class. We investigate three approaches based on undersampling,
   oversampling and cost-sensitive adaptation. Additionally, to allow for a
   rapid updating of the proposed classifier we show how to implement
   online Extreme Learning Machines with the usage of GPU. The proposed
   approach allows for a highly efficient mining of high-speed, drifting
   and imbalanced data streams with significant acceleration offered by GPU
   processing.},
Type = {Proceedings Paper},
Affiliation = {Krawczyk, B (Corresponding Author), Wroclaw Univ Technol, Dept Syst \& Comp Networks, Wyb Wyspianskiego 27, PL-50370 Wroclaw, Poland.
   Krawczyk, Bartosz, Wroclaw Univ Technol, Dept Syst \& Comp Networks, Wyb Wyspianskiego 27, PL-50370 Wroclaw, Poland.},
DOI = {10.1016/j.procs.2016.05.509},
Keywords = {Data streams; Imbalanced data; Concept drift; Big data; Extreme learning
   machines; GPU},
Keywords-Plus = {ALGORITHM},
Author-Email = {bartosz.krawczyk@pwr.edu.pl},
Number-of-Cited-References = {21},
