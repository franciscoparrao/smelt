@article{ WOS:001705661000001,
Author = {Huang, Yucong and Xu, Feng and Zhang, Chao and Lyu, Xin and Xu, Zhennan
   and Chen, Jiale},
Title = {TranCAD: Transforming tabular data into color images for deep
   semi-supervised anomaly detection},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {315},
Month = {JUN 10},
Abstract = {Semi-supervised anomaly detection aims to train an anomaly detector from
   abundant unlabeled data and a small number of labeled anomalies.
   However, due to the nature of tabular data, existing methods commonly
   employ shallow and small models with limited capacity, which struggle to
   capture latent distribution differences to separate normal and abnormal
   data when the distributions of both classes overlap. To overcome this
   limitation, a novel data transformation framework that transforms
   tabular data into color images is proposed, enabling the application of
   deeper and larger models. Specifically, the framework generates hybrid
   feature matrices by blending unlabeled and labeled samples, assigns
   pseudo-labels to the matrices as fine-grained supervisory signals, and
   then transforms the matrices into three-channel color images. To enhance
   the inter-class separability of images and provide discriminative
   features for downstream model, the three channels are encoded with raw
   features and their deviations from the centroids of normal and abnormal
   data. The transformed color images exhibit richer data representation
   and superior compatibility with deep computer vision models. A deep
   semi-supervised anomaly detection method is proposed based on the
   framework, named TranCAD. Interestingly, most of the mainstream deep
   image classification models can be plugged into TranCAD for feature
   extraction and anomaly scoring. Extensive experiments on 15 real-world
   datasets and nine deep image classification models show that TranCAD
   significantly outperforms state-of-the-art semi-supervised anomaly
   detection methods, achieving average improvements of 9\% in Area Under
   the Precision-Recall Curve (AUC-PR) and 10\% in F1-Score.},
