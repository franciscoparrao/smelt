   Cho, Nam-Wook, Seoul Natl Univ Sci \& Technol, Dept Ind \& Informat Syst Engn, Seoul 01811, South Korea.},
DOI = {10.3390/systems13111040},
Article-Number = {1040},
Keywords = {graph convolutional networks; graph neural network; graph diffusion;
   link prediction; classification},
Author-Email = {ztor2@seoultech.ac.kr
   nwcho@seoultech.ac.kr},
Number-of-Cited-References = {25},
