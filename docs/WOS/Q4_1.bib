DOI = {10.1007/978-3-030-59051-2\_16},
Keywords = {Graph structured data; Semi-supervised learning; Graph Convolutional
   Networks; Node classification},
Author-Email = {yaowenbin@bupt.edu.cn},
Number-of-Cited-References = {19},
