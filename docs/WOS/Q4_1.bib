DOI = {10.1109/TNET.2024.3482356},
EarlyAccessDate = {OCT 2024},
Keywords = {Training; Servers; Collaboration; Costs; Convergence; Social networking
   (online); Data centers; Data models; Approximation algorithms; Graph
   convolutional networks; Federated graph learning; collaboration
   framework; client selection; cross-client edge selection},
