   Bao, Chenglong; Shi, Zuoqiang, Yanqi Lake Beijing Inst Math Sci \& Applicat, Beijing 101408, Peoples R China.},
DOI = {10.1109/TPAMI.2023.3272341},
Keywords = {Diffusion; residual neural network; ordinary differential equation;
   semi-supervised learning; few-shot learning},
Keywords-Plus = {BOUNDARY-VALUE-PROBLEMS; REGULARIZATION; LAPLACIAN},
Author-Email = {wangtj20@mails.tsinghua.edu.cn
