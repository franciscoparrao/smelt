@incollection{ WOS:001413988900075,
Author = {Zhu, Junhao and Gao, Pengbo and Hu, Feng and Yu, Hong},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Deep Learning-Based Recurrence Risk Prediction for Differentiated
   Thyroid Cancer Using Local Clustering Contrastive Learning},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON MEDICAL ARTIFICIAL INTELLIGENCE,
   MEDAI 2024},
Year = {2024},
Pages = {580-587},
Abstract = {Thyroid cancer incidence in women has risen sharply in China from 2000
   to 2016. Differentiated thyroid cancer has a relatively low mortality
   rate but a higher recurrence rate. The American Thyroid Association
   (ATA) risk model, based on traditional clinical and pathological
   parameters, may not fully capture all factors affecting recurrence risk.
   Deep learning technology has shown potential in predicting recurrence in
   patients with well-differentiated thyroid cancer, but its application to
   heterogeneous tabular medical data remains challenging. We propose a
   local clustering contrastive learning method to address the challenges
   of applying deep learning to tabular medical data. This method divides
   features into random subsets, performs clustering within each subset,
   generates positive and negative sample pairs, and trains encoders and a
   decoder to maximize the InfoNCE output. The learned feature
   representation is used for downstream classification tasks. The proposed
   method was applied to a retrospective cohort of 383 patients diagnosed
   with thyroid cancer at a medical center. Experimental verification on
   this dataset and ten public tabular datasets demonstrated the
   effectiveness of the method in risk-stratifying patients with
   well-differentiated thyroid cancer. The proposed local clustering
   contrastive learning method effectively leverages the complexity of
   tabular medical data, enhancing the learned feature representation and
   enabling accurate recurrence risk prediction for well-differentiated
   thyroid cancer. This approach can assist doctors in making personalized
   treatment decisions, such as the necessity, dosage, and frequency of
   radioactive iodine treatment, ultimately improving patient care.},
Type = {Proceedings Paper},
Affiliation = {Hu, F (Corresponding Author), Chongqing Univ Posts \& Telecommun, Chongqing Key Lab Computat Intelligence, Key Lab Big Data Intelligent Comp, Chongqing, Peoples R China.
   Zhu, Junhao; Gao, Pengbo, Chongqing Univ Posts \& Telecommun, Chongqing Key Lab Computat Intelligence, Chongqing, Peoples R China.
