@article{ WOS:001425388300001,
Author = {An, Shuai and Hong, Binsheng and Guo, Zhaori and Zhu, Shunzhi and Lin,
   Kaibiao and Yang, Fan},
Title = {Simultaneously local and global contrastive learning of graph
   representations},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2025},
Volume = {145},
Month = {APR 1},
Abstract = {Graph Representation Learning (GRL) is crucial for understanding complex
   graph-structured data. This is a hot topic in Artificial Intelligence
   research, particularly due to its wide applicability in various
   engineering contexts, such as social network analysis, bioinformatics,
   and recommender systems. However, existing methods often overlook the
   multi-scale properties of graphs and the integration of semantic
   information, which limits the ability to capture the deeper information
   of the data. To address this issue, we propose a novel approach,
   Simultaneously Local and Global Contrastive Learning of Graph
   Representations (SLGGCL), for the graph-node classification problem.
   Specifically, SLGGCL generates subgraphs for local views and diffusion
   graphs for global views by leveraging a combination of strategies,
   including edge perturbation, attribute masking, and graph diffusion.
   Then, we apply a contrastive learning model to capture the information
   among multi-scale graphs to improve the classification accuracy. In
   addition, experimental results on multiple real- world datasets show
   that SLGGCL outperforms ten state-of-the-art methods, achieving a 1.01\%
   improvement inaccuracy on Cora compared to the best-performing method.},
Type = {Article},
Affiliation = {Lin, KB (Corresponding Author), Xiamen Univ Technol, Sch Comp \& Informat Engn, 600 Ligong Rd, Xiamen 361024, Fujian, Peoples R China.
   Yang, F (Corresponding Author), Xiamen Univ, Dept Automat, Xiamen, Fujian, Peoples R China.
