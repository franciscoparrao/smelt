@incollection{ WOS:000509687900040,
Author = {Jung, A. and Vesselinova, N.},
Editor = {Chaudhuri, K and Sugiyama, M},
Title = {Analysis of Network Lasso for Semi-Supervised Regression},
Booktitle = {22ND INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE AND STATISTICS,
   VOL 89},
Series = {Proceedings of Machine Learning Research},
Year = {2019},
Volume = {89},
Pages = {380-387},
Abstract = {We apply network Lasso to semi-supervised regression problems involving
   network-structured data. This approach lends quite naturally to highly
   scalable learning algorithms in the form of message passing over an
   empirical graph which represents the network structure of the data. By
   using a simple non-parametric regression model, which is motivated by a
   clustering hypothesis, we provide an analysis of the estimation error
   incurred by network Lasso. This analysis reveals conditions on the
   network structure and the available training data which guarantee
   network Lasso to be accurate. Remarkably, the accuracy of network Lasso
   is related to the existence of sufficiently large network flows over the
   empirical graph. Thus, our analysis reveals a connection between network
   Lasso and maximum flow problems.},
Type = {Proceedings Paper},
Affiliation = {Jung, A (Corresponding Author), Aalto Univ, Dept Comp Sci, Espoo, Finland.
   Jung, A.; Vesselinova, N., Aalto Univ, Dept Comp Sci, Espoo, Finland.},
Number-of-Cited-References = {23},
Times-Cited = {4},
Unique-ID = {WOS:000509687900040},
}

