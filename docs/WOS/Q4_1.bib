DOI = {10.1016/j.ins.2024.120831},
EarlyAccessDate = {JUN 2024},
Article-Number = {120831},
Keywords = {Granular-ball sampling; Graph convolutional networks; Incremental
   training; Node classification; Semi-supervised learning},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {221110702104@stu.just.edu.cn
   sunqiguo1992@gmail.com
   jsjxy\_yxb@just.edu.cn
   just\_liukeyu@163.com
