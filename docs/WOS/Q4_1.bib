   Zhong, Lujia; Shi, Yonggang, Univ Southern Calif USC, Viterbi Sch Engn, Ming Hsieh Dept Elect \& Comp Engn, Los Angeles, CA 90089 USA.},
DOI = {10.1007/978-3-032-05182-0\_37},
Keywords = {Multimodal; Multiclass; Alzheimer's disease; Diagnosis; Feature
   alignment},
