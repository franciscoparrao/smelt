   Pan, Xuran; Song, Shiji; Chen, Yiming; Huang, Gao, Beijing Natl Res Ctr Informat Sci \& Technol BNRis, Beijing, Peoples R China.
   Wang, Liejun, Xinjiang Univ, Urumqi, Xinjiang, Peoples R China.},
DOI = {10.1016/j.neucom.2022.01.045},
EarlyAccessDate = {FEB 2022},
Keywords = {Graph-based learning; Graph convolutional networks; Self-attention;
   Semi-supervised node classification},
Keywords-Plus = {SEGMENTATION},
Number-of-Cited-References = {82},
Times-Cited = {2},
