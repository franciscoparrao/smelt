@article{ WOS:001447150200001,
Author = {Li, Shuangjie and Zhang, Baoming and Song, Jianqing and Ruan, Gaoli and
   Wang, Chongjun and Xie, Junyuan},
Title = {Graph Neural Networks with Coarse- and Fine-Grained Division for
   mitigating label noise and sparsity},
Journal = {NEURAL NETWORKS},
Year = {2025},
Volume = {187},
Month = {JUL},
Abstract = {Graph Neural Networks (GNNs) have gained considerable prominence in
   semi-supervised learning tasks in processing graph-structured data,
   primarily owing to their message-passing mechanism, which largely relies
   on the availability of clean labels. However, in real-world scenarios,
   labels on nodes of graphs are inevitably noisy and sparsely labeled,
   significantly degrading the performance of GNNs. Exploring robust GNNs
   for semi-supervised node classification in the presence of noisy and
   sparse labels remains a critical challenge. Therefore, we propose a
   novel Graph Neural Network with Coarse- and Fine-Grained Division for
   mitigating label sparsity and noise, namely GNN-CFGD. The key idea of
   GNN-CFGD is reducing the negative impact of noisy labels via coarse- and
   fine-grained division, along with graph reconstruction. Specifically, we
   first investigate the effectiveness of linking unlabeled nodes to
   cleanly labeled nodes, demonstrating that this approach is more
   effective in combating labeling noise than linking to potentially noisy
   labeled nodes. Based on this observation, we introduce a Gaussian
   Mixture Model (GMM) based on the memory effect to perform a
   coarse-grained division of the given labels into clean and noisy labels.
   Next, we propose a clean labels oriented link that connects unlabeled
   nodes to cleanly labeled nodes, aimed at mitigating label sparsity and
   promoting supervision propagation. Furthermore, to provide refined
   supervision for noisy labeled nodes and additional supervision for
   unlabeled nodes, we fine-grain the noisy labeled and unlabeled nodes
   into two candidate sets based on confidence, respectively. Extensive
   experiments on various datasets demonstrate the superior effectiveness
   and robustness of GNN-CFGD.},
Type = {Article},
Affiliation = {Wang, CJ (Corresponding Author), Nanjing Univ, Dept Comp Sci \& Technol, 163 Xianlin Ave, Nanjing 210023, Peoples R China.
   Nanjing Univ, State Key Lab Novel Software Technol, Nanjing 210023, Peoples R China.
   Wang, Chongjun, Nanjing Univ, Dept Comp Sci \& Technol, 163 Xianlin Ave, Nanjing 210023, Peoples R China.},
DOI = {10.1016/j.neunet.2025.107338},
EarlyAccessDate = {MAR 2025},
Article-Number = {107338},
Keywords = {Graph Neural Network; Semi-supervised node classification; Label noise},
Keywords-Plus = {CLASSIFICATION; MODELS},
Author-Email = {shuangjieli@smail.nju.edu.cn
   chjwang@nju.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {0},
Unique-ID = {WOS:001447150200001},
}

@incollection{ WOS:001576278800103,
Author = {Abbasi, Mahmoud and Prieto, Javier and Corchado, Juan M.},
Book-Group-Author = {IEEE},
Title = {Autoencoding-based self-supervised learning for enhanced representation
   of network traffic patterns},
Booktitle = {2025 IEEE INTERNATIONAL CONFERENCE ON MACHINE LEARNING FOR COMMUNICATION
   AND NETWORKING, ICMLCN},
Year = {2025},
Abstract = {Network Traffic Monitoring and Analysis (NTMA) is crucial in today's
   digital age, especially given the increasing volume of network data and
   associated cyber threats. Effective NTMA involves analyzing data packets
   for performance optimization, security, and policy compliance. However,
   traditional NTMA machine learning methods rely heavily on labeled data,
   which is costly and scarce. The objective of this work is to develop a
   self-supervised learning framework, VAE-SSL, that improves network
   traffic classification by leveraging unlabeled data. Specifically, we
   aim to enhance network traffic representation learning by designing
   novel pretext tasks tailored for tabular data, enabling better
   generalization across classification models. The VAE-SSL employs
   innovative pretext tasks tailored to tabular data, improving the
   performance of various classification models, including AdaBoost, SVC,
   Logistic Regression, and SGD. Our experiments demonstrate that VAE-SSL
   significantly improves classification metrics compared to traditional
   supervised learning approaches.},
Type = {Proceedings Paper},
Affiliation = {Abbasi, M (Corresponding Author), Univ Salamanca, BISITE Res Grp, Salamanca, Spain.
   Abbasi, Mahmoud; Prieto, Javier, Univ Salamanca, BISITE Res Grp, Salamanca, Spain.
   Corchado, Juan M., Univ Salamanca, Salamanca, Spain.},
DOI = {10.1109/ICMLCN64995.2025.11140475},
Keywords = {network management; traffic classification; machine learning},
