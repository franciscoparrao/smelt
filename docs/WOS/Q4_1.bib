   Li, Jinbo, China Unicom Res Inst, Beijing 100176, Peoples R China.},
DOI = {10.1016/j.knosys.2024.112389},
EarlyAccessDate = {AUG 2024},
Article-Number = {112389},
Keywords = {Graph convolutional network; Heterophilous graph; Semi-supervised
   classification; Contrastive learning},
