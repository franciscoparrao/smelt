   Cui, Zhen, Nanjing Univ Sci \& Technol, Sch Comp Sci \& Engn, Nanjing 210094, Peoples R China.
   Hu, Guyu; Pan, Zhisong, Army Engn Univ PLA, Inst Command \& Control Engn, Nanjing 210007, Peoples R China.},
DOI = {10.1016/j.knosys.2021.106891},
EarlyAccessDate = {MAY 2021},
Article-Number = {106891},
Keywords = {Graph Convolutional Networks (GCN); Graph signal processing; Infinite
   impulse response (IIR); Node classification; Low-pass filter},
Author-Email = {panzs@nuaa.edu.cn},
Number-of-Cited-References = {47},
