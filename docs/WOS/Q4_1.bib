@article{ WOS:001651590300006,
Author = {Meng, Lei and Li, Mingyuan and Yang, Yanlin and Ye, Zhonglin and Zhao,
   Haixing},
Title = {GLPACO: Global and local perspective adaptive collaborative optimisation
   for graph contrastive learning},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {305},
Month = {APR 5},
Abstract = {Graph-structured data are pervasive in domains such as social networks,
   biological systems and recommendation engines; however, most graph
   contrastive learning (GCL) approaches are constrained by their inability
   to simultaneously capture micro-level interactions and macro-level
   structural regularities. This challenge was addressed using global and
   local perspective adaptive collaborative optimisation (GLPACO) for GCL-a
   principled self-supervised framework that unified multi-channel subgraph
   perturbation, dual-perspective representation learning and adaptive loss
   calibration into a single, end-to-end pipeline. GLPACO generated
   complementary subgraph views through diversified stochastic
   augmentations and encoded them using a three-channel architecture to
   produce semantically enriched node embeddings. A dual-stage extractor
   then disentangled local finegrained semantics via non-linear
   transformations and aggregated holistic global patterns with a
   self-attention mechanism, yielding representations that were
   simultaneously discriminative and structurally coherent. Crucially, a
   learnable cooperative optimisation mechanism dynamically balanced local
   and global contrastive objectives during training, enabling data-driven
   adaptation across graphs of varying scales and structures. We evaluated
   GLPACO via linear-probe node classification on six public benchmarks,
   namely Cora, Citeseer, PubMed, WikiCS, Amazon-Photo and
   Amazon-Computers. The method delivered considerable improvements on four
   datasets with absolute gains of 0.29\%-25.22\%, matched strong baselines
   on Amazon-Photo and was below several state-of-the-art baselines on
   Amazon-Computers. The results substantiated the ability of GLPACO to
   deliver richly expressive, generalisable graph representations for
   complex real-world applications.},
Type = {Article},
Affiliation = {Zhao, HX (Corresponding Author), Qinghai Minzu Univ, Coll Intelligent Sci \& Engn, Xining 810000, Qinghai, Peoples R China.
