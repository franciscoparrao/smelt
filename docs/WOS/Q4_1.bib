   Liu, Yuxiao; Zhang, Yuanwang; Sun, Kaicong; Shen, Dinggang, ShanghaiTech Univ, Sch Biomed Engn, Shanghai 201210, Peoples R China.
   Liu, Yuxiao; Zhang, Yuanwang; Sun, Kaicong; Shen, Dinggang, ShanghaiTech Univ, State Key Lab Adv Med Mat \& Devices, Shanghai 201210, Peoples R China.
   Liu, Mianxin, Shanghai Artificial Intelligence Lab, Shanghai 200232, Peoples R China.
   Shen, Dinggang, Shanghai United Imaging Intelligence Co Ltd, Shanghai 200230, Peoples R China.
   Shen, Dinggang, Shanghai Clin Res \& Trial Ctr, Shanghai 201210, Peoples R China.},
DOI = {10.1007/978-3-031-78761-4\_12},
Keywords = {Alzheimer's disease; Multi-modality fusion; Contrastive learning;
   Explanation analysis; Multi-stage framework},
Author-Email = {dgshen@shanghaitech.edu.cn},
