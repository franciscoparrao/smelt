@article{ WOS:001705880000001,
Author = {Wang, Seunghyeon},
Title = {Class-aware temporal and contextual contrastive framework for
   semi-supervised automated fault detection and diagnosis in air handling
   units},
Journal = {ENERGY AND BUILDINGS},
Year = {2026},
Volume = {358},
Month = {MAY 1},
Abstract = {Automated Fault Detection and Diagnosis (AFDD) for Air Handling Units
   (AHUs) has largely relied on supervised learning, which is difficult to
   deploy when labeled data are scarce and fault classes are imbalanced.
   Existing label-efficient AFDD studies often evaluate self-supervised
   schemes on simulated or laboratory datasets, frequently in tabular form,
   and therefore do not fully capture the temporal structure and noise
   characteristics of real operational logs. This study proposes
   Class-Aware Temporal and Contextual Contrasting (CA-TCC) for
   labelefficient AHU AFDD on real buildings. CA-TCC is a semi-supervised
   framework that first performs self-supervised temporal/contextual
   contrastive pretraining on unlabeled operational logs and then performs
   class-aware semisupervised refinement using limited labels together with
   unlabeled data via confidence-filtered pseudo-labels; a lightweight
   classifier head is subsequently trained for fault classification.
   Experiments on six datasets-three synthetic AHU benchmarks and three
   real operational datasets from an auditorium, a hospital, and an office
   building-show that CA-TCC consistently outperforms alternative
   self-supervised backbones across label budgets. With only 5\% labeled
   data, CA-TCC improves macro F1 score and accuracy by approximately 5-10
   and 5-9 points, respectively, while remaining within about 1-1.5 points
   of strong fully supervised models Cross-building transfer experiments
   demonstrate reliable source-to-target generalization across all building
   pairs under consistent label budgets. Additional analyses evaluate
   backbone fine-tuning policies, sensitivity to CA-TCCspecific
   hyperparameters, per-class behavior under different label fractions, and
   ablations of temporal, contextual, and class-aware components.
   Comparisons with representative baselines and inference-speed
   measurements further characterize suitability for near real-time AFDD.},
Type = {Article},
Affiliation = {Wang, S (Corresponding Author), UCL, Inst Environm Design \& Engn, London WC1H 0NN, England.
   Wang, Seunghyeon, UCL, Inst Environm Design \& Engn, London WC1H 0NN, England.},
DOI = {10.1016/j.enbuild.2026.117233},
Article-Number = {117233},
Keywords = {Air handling units; Automated fault detection and diagnosis;
   Self-supervised learning; Semi-supervised learning; Contrastive learning},
Keywords-Plus = {BUILDING ENERGY-CONSUMPTION; REGRESSION-MODELS},
Author-Email = {seung-hyun.wang@ucl.ac.uk},
Number-of-Cited-References = {68},
Times-Cited = {0},
Unique-ID = {WOS:001705880000001},
}

@article{ WOS:001722996700003,
Author = {Sahu, Thaneshwar Kumar and Mishra, Pankaj Kumar and Gupta, Saurabh},
Title = {A Prototype-Aware Sparse Residual MLP for Robust Hand Gesture
   Recognition From Multichannel EMG},
Journal = {IEEE SENSORS LETTERS},
Year = {2026},
Volume = {10},
Number = {4},
Month = {APR},
Abstract = {Automated recognition of hand gestures from multichannel
   electromyography (MEMG) data is critical to intuitive human-machine
   interaction and prosthetic control. However, most current approaches are
   based on computationally intensive time-frequency transformations or
   transformer-based architectures, which restrict real-time deployment.
   MEMG classification remains challenging due to sensor noise,
   intersubject variability, channel degradation, and difficulties in
   learning discriminative representations from high-dimensional tabular
   features of EMG. In this letter, we propose the lightweight residual
   multilayer perceptron framework that combines prototype-aware
   classification with supervised contrastive embedding learning,
   structured channel grouping, and a sparse gating mechanism to
   dynamically prune redundant neurons during training. Our model
   integrates channel-aware augmentation for enhanced robustness,
   GroupSE-based feature recalibration to enhance muscle activation
   selectivity, and a prototype distance-based head to provide stable class
   separation in the embedding space. A supervised contrastive loss
   encourages clustering of gesture representations while enforcing
   interclass separability. The SparseGate module progressively shuts off
   up to 70\% of the hidden units, substantially reducing the computational
   cost without degrading accuracy. Extensive experiments conducted on a
   large MEMG dataset attains an overall accuracy of 98.26\%, outperforming
   conventional multilayer perceptrons (MLPs), convolutional neural network
   (CNN), and transformer architectures. Additional evaluations highlight
   strong robustness to channel dropout and noise corruption, making the
   proposed approach suitable for real-time, resource-constrained EMG
   interfaces.},
Type = {Letter},
Affiliation = {Sahu, TK (Corresponding Author), Chhattisgarh Swami Vivekanand Tech Univ CSVTU, Univ Teaching Dept UTD, Dept Biomed Engn, Bhilai 490006, India.
