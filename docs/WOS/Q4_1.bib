DOI = {10.1002/widm.70012},
Article-Number = {e70012},
Keywords = {Attention Mechanism; Factorizable GCN; Graph Convolution Network;
   Spatial Feature; Spectral Feature},
Keywords-Plus = {NEURAL-NETWORKS; PREDICTION},
Author-Email = {joe.dhanith@gmail.com},
