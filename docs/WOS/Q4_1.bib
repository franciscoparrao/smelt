@article{ WOS:000841076700003,
Author = {Wei, Quanmin and Wang, Jinyan and Hu, Jun and Li, Xianxian and Yi, Tong},
Title = {OGT: optimize graph then training GNNs for node classification},
Journal = {NEURAL COMPUTING \& APPLICATIONS},
Year = {2022},
Volume = {34},
Number = {24, SI},
Pages = {22209-22222},
Month = {DEC},
Abstract = {Graph Neural Networks (GNNs) have shown excellent performance in
   graph-related tasks and have arisen widespread attention. However, most
   existing works on GNNs mainly focus on proposing a novel GNN model or
   modifying the models to improve performance in various graph-related
   tasks and seldom consider possible problems in the graph data as model
   input data. This paper studies that low-degree nodes, accounting for
   most of the real-world graphs, naturally have message passing
   insufficiency problem due to too little information from other nodes
   when generating node embedding, which will affect the performance of the
   GNNs. To solve this problem, we propose a simple but practical
   method-Optimize Graph Then Training (OGT), which adds edges between
   low-degree nodes and some nodes with the same predicted label based on
   the GNNs prediction results and the inherent information in the graph.
   The OGT aims to improve the performance of GNNs in semi-supervised node
   classification tasks by augmenting the input data. More importantly, the
   OGT is regarded as a data preprocessing technique and can be used
   naturally with baseline GNN models (e.g., GCN, GAT, GraphSAGE, and SGC)
   to improve the performance of these models without making other
   modifications. Extensive experiments on three benchmark citation
   datasets with five typical GNN models verify that OGT consistently
   improves the performance of various GNNs to a great extent, where 1.9\%
   (Cora), 1.0\% (Citeseer), and 1.3\% (Pubmed) average accuracy
   improvement on the node classification task.},
Type = {Article},
Affiliation = {Wang, JY; Yi, T (Corresponding Author), Guangxi Normal Univ, Guangxi Key Lab Multisource Informat Min \& Secur, Guilin 541004, Guangxi, Peoples R China.
   Wang, JY; Yi, T (Corresponding Author), Guangxi Normal Univ, Sch Comp Sci \& Engn, Guilin 541004, Guangxi, Peoples R China.
   Wei, Quanmin; Wang, Jinyan; Li, Xianxian; Yi, Tong, Guangxi Normal Univ, Guangxi Key Lab Multisource Informat Min \& Secur, Guilin 541004, Guangxi, Peoples R China.
   Wei, Quanmin; Wang, Jinyan; Hu, Jun; Li, Xianxian; Yi, Tong, Guangxi Normal Univ, Sch Comp Sci \& Engn, Guilin 541004, Guangxi, Peoples R China.},
DOI = {10.1007/s00521-022-07677-5},
EarlyAccessDate = {AUG 2022},
Keywords = {Graph neural networks; Semi-supervised node classification;
   Graph-structured data; Node embedding generation},
Keywords-Plus = {DISTRIBUTIONS; NETWORKS},
Author-Email = {wangjy612@gxnu.edu.cn
   yitong@gxnu.edu.cn},
Number-of-Cited-References = {46},
Times-Cited = {4},
Unique-ID = {WOS:000841076700003},
}

@article{ WOS:000649887100001,
Author = {Liu, Zhewei and Zhang, Zijia and Cai, Yaoming and Miao, Yilin and Chen,
   Zhikun},
Title = {Semi-Supervised Classification via Hypergraph Convolutional Extreme
   Learning Machine},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2021},
Volume = {11},
Number = {9},
Month = {MAY},
Abstract = {Extreme Learning Machine (ELM) is characterized by simplicity,
   generalization ability, and computational efficiency. However, previous
   ELMs fail to consider the inherent high-order relationship among data
   points, resulting in being powerless on structured data and poor
   robustness on noise data. This paper presents a novel semi-supervised
   ELM, termed Hypergraph Convolutional ELM (HGCELM), based on using
   hypergraph convolution to extend ELM into the non-Euclidean domain. The
   method inherits all the advantages from ELM, and consists of a random
   hypergraph convolutional layer followed by a hypergraph convolutional
   regression layer, enabling it to model complex intraclass variations. We
   show that the traditional ELM is a special case of the HGCELM model in
   the regular Euclidean domain. Extensive experimental results show that
   HGCELM remarkably outperforms eight competitive methods on 26
   classification benchmarks.},
Type = {Article},
Affiliation = {Chen, ZK (Corresponding Author), Beibu Gulf Univ, Guangxi Key Lab Marine Disaster Beibu Gulf, Qinzhou 535011, Peoples R China.
   Liu, Zhewei; Zhang, Zijia; Cai, Yaoming; Miao, Yilin, China Univ Geosci, Sch Comp Sci, Wuhan 430078, Peoples R China.
   Chen, Zhikun, Beibu Gulf Univ, Guangxi Key Lab Marine Disaster Beibu Gulf, Qinzhou 535011, Peoples R China.},
DOI = {10.3390/app11093867},
Article-Number = {3867},
Keywords = {graph convolutional network; extreme learning machine; semi-supervised
   learning; hypergraph learning},
Author-Email = {zhewei.liu@cug.edu.cn
