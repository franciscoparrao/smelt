@incollection{ WOS:001447151900136,
Author = {Wu, Longxue and Jiang, Yuan and Li, Junliang and Jia, Jie},
Book-Group-Author = {IEEE},
Title = {Directed Adaptive Multi-Channel Graph Convolutional Network},
Booktitle = {2024 5TH INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE AND
   COMPUTER ENGINEERING, ICAICE},
Year = {2024},
Pages = {755-758},
Abstract = {Compared with traditional neural networks, graph convolutional networks
   are very suitable for processing graph structured data. However, common
   graph convolutional network methods often have unsatisfactory results
   when dealing with directed network structures. Because common graph
   convolutional network methods are mostly applied in the field of
   undirected graphs, they tend to symmetrize the network structure,
   resulting in the loss of relevant information about asymmetry. In order
   to improve the performance of graph neural networks on directed graphs,
   this paper proposes a semi supervised classification adaptive
   multi-channel graph convolutional network for directed graphs. The core
   idea of the method is to use the directed triangle counting algorithm to
   extract similar features of in degree and out degree in the topology
   structure, and combine node features and topology features to extract
   special and common embeddings in a multichannel fusion manner, and use
   attention mechanism to learn the adaptive important weights of
   embeddings. Experiments were conducted using multiple benchmark datasets
   in both directed and undirected scenarios, and the results showed that
   the model can be effectively applied in both directed and undirected
   graphs. The loss is minimal when transitioning from undirected to
   directed, and the classification accuracy is improved.},
Type = {Proceedings Paper},
Affiliation = {Jiang, Y (Corresponding Author), Nanchang Hangkong Univ, Sch Informat Engn, Nanchang, Jiangxi, Peoples R China.
   Wu, Longxue; Jiang, Yuan; Li, Junliang; Jia, Jie, Nanchang Hangkong Univ, Sch Informat Engn, Nanchang, Jiangxi, Peoples R China.},
