   Stevanoska, Sintija; Dzeroski, Saso, Jozef Stefan Int Postgrad Sch, Jamova Cesta 39, Ljubljana 1000, Slovenia.},
DOI = {10.1007/s10994-025-06898-8},
Article-Number = {246},
Keywords = {Semi-supervised learning; Tabular data; Representation learning;
   Meta-analysis},
Author-Email = {sintija.stevanoska@ijs.si},
