@article{ WOS:001354743800136,
Author = {Wang, Yizhou and Qin, Can and Wei, Rongzhe and Xu, Yi and Bai, Yue and
   Fu, Yun},
Title = {SLA2P: Self-Supervised Anomaly Detection With Adversarial
   Perturbation},
Journal = {IEEE TRANSACTIONS ON KNOWLEDGE AND DATA ENGINEERING},
Year = {2024},
Volume = {36},
Number = {12},
Pages = {9282-9293},
Month = {DEC},
Abstract = {Anomaly detection is a foundational yet difficult problem in machine
   learning. In this work, we propose a new and effective framework, dubbed
   as SLA (2) P, for unsupervised anomaly detection. Following the
   extraction of delegate embeddings from raw data, we implement random
   projections on the features and consider features transformed by
   disparate projections as being associated with separate pseudo-classes.
   We then train a neural network for classification on these transformed
   features to conduct self-supervised learning. Subsequently, we introduce
   adversarial disturbances to the modified attributes, and we develop
   anomaly scores built on the classifier's predictive uncertainties
   concerning these disrupted features. Our approach is motivated by the
   fact that as anomalies are relatively rare and decentralized, 1) the
   training of the pseudo-label classifier concentrates more on acquiring
   the semantic knowledge of regular data instead of anomalous data; 2) the
   altered attributes of the normal data exhibit greater resilience to
   disturbances compared to those of the anomalous data. Therefore, the
   disrupted modified attributes of anomalies can not be well classified
   and correspondingly tend to attain lesser anomaly scores. The results of
   experiments on various benchmark datasets for images, text, and
   inherently tabular data demonstrate that SLA (2) P achieves
   state-of-the-art performance consistently.},
Type = {Article},
Affiliation = {Wang, YZ (Corresponding Author), Northeastern Univ, Dept Elect \& Comp Engn, Boston, MA 02115 USA.
   Wang, Yizhou; Qin, Can; Xu, Yi; Bai, Yue, Northeastern Univ, Dept Elect \& Comp Engn, Boston, MA 02115 USA.
   Wei, Rongzhe, Georgia Inst Technol, Atlanta, GA 30332 USA.
   Fu, Yun, Northeastern Univ, Khoury Coll Comp Sci, Dept Elect \& Comp Engn, Boston, MA 02115 USA.},
DOI = {10.1109/TKDE.2024.3448473},
Keywords = {Feature extraction; Anomaly detection; Perturbation methods; Task
   analysis; Training; Uncertainty; Unsupervised learning; Data mining-
   anomaly detection; machine learning- deep learning; representation
   learning},
Author-Email = {wyzjack990122@gmail.com
   qin.ca@northeastern.edu
   rwei42@gatech.edu
   xu.yi@northeastern.edu
   bai.yue@northeastern.edu
   yunfu@ece.neu.edu},
