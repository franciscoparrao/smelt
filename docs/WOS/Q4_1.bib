   Yang, Beining; Cen, Yukuo; Zhang, Chenhui, Zhipu AI, Beijing, Peoples R China.
   Kharlamov, Evgeny, Bosch Ctr Artificial Intelligence, Renningen, Germany.
   Zhao, Shu, Anhui Univ, Hefei, Anhui, Peoples R China.},
DOI = {10.1145/3637528.3671952},
Keywords = {graph self-supervised learning; text-attributed graphs; few-shot node
