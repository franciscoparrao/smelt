   Yuan, Jinliang; Cao, Meng; Cheng, Hao; Yu, Hualei; Xie, Junyuan; Wang, Chongjun, Nanjing Univ, Dept Comp Sci \& Technol, Nanjing 210046, Peoples R China.},
DOI = {10.1016/j.neucom.2022.01.064},
EarlyAccessDate = {MAY 2022},
Keywords = {Graph attention networks; Graph structure learning; Semi-supervised
   classification},
Author-Email = {chjwang@nju.edu.cn},
