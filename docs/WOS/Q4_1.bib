   Cai, Jia, Guangdong Univ Finance \& Econ, Sch Digital Econ, Guangzhou, Peoples R China.
   Yan, Ranhui, Guangdong Univ Finance \& Econ, Sch Math \& Stat, Guangzhou, Peoples R China.
   Huang, Xiaolin, Shanghai Jiao Tong Univ, Inst Image Proc \& Pattern Recognit, Shanghai, Peoples R China.},
DOI = {10.1109/IJCNN60899.2024.10650206},
Keywords = {Graph neural networks; Noise perturbation; Contrastive learning;
   Flexible filters},
Author-Email = {zhilongxiong98@outlook.com
