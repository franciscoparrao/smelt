   Zhang, Zichao; Zhang, Yihao; Wang, Yu; Ma, Mingyuan; Xu, Jin, Peking Univ, Sch Comp Sci, Yiheyuan Rd 5, Beijing 100871, Peoples R China.},
DOI = {10.1016/j.ins.2023.119041},
EarlyAccessDate = {MAY 2023},
Article-Number = {119041},
Keywords = {Graph Fourier transformation; Graph convolutional network; Node
   classification; Semi-supervised learning},
