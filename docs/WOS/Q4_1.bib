Book-Group-Author = {ACM},
Title = {Pseudo Triplet Networks for Classification Tasks with Cross-Source
   Feature Incompleteness},
Booktitle = {PROCEEDINGS OF THE 32ND ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2023},
Year = {2023},
Pages = {4079-4083},
Abstract = {Cross-source feature incompleteness - a scenario where certain features
   are only available in one data source but missing in another - is a
   common and significant challenge in machine learning. It typically
   arises in situations where the training data and testing data are
   collected from different sources with distinct feature sets. Addressing
   this challenge has the potential to greatly improve the utility of
   valuable datasets that might otherwise be considered incomplete and
   enhance model performance. This paper introduces the novel Pseudo
   Triplet Network (PTN) to address cross-source feature incompleteness.
   PTN fuses two Siamese network architectures - Triplet Networks and
   Pseudo Networks. By segregating data into instance, positive, and
   negative subsets, PTN facilitates effectively contrastive learning
   through a hybrid loss function design. The model was rigorously
   evaluated on six benchmark datasets from the UCI Repository, in
   comparison with five other methods for managing missing data, under a
   range of feature overlap and missing data scenarios. The PTN
   consistently exhibited superior performance, displaying resilience in
   high missing ratio situations and maintaining robust stability across
   various data scenarios.},
Type = {Proceedings Paper},
Affiliation = {Liow, C (Corresponding Author), Natl Taiwan Univ, Taipei, Taiwan.
   Liow, Cayon; Yang, Chun-Pai; Lin, Shou-De, Natl Taiwan Univ, Taipei, Taiwan.
   Li, Cheng-Te, Natl Cheng Kung Univ, Tainan, Taiwan.},
DOI = {10.1145/3583780.3615154},
Keywords = {Pseudo Triplet Networks; Feature Incompleteness; Cross Data Source;
   Classification Tasks; Tabular Data},
Author-Email = {cayon.1318.96@hotmail.com
   chengte@ncku.edu.tw
   d05922017@ntu.edu.tw
   sdlin@csie.ntu.edu.tw},
