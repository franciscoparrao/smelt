   Li, Daniel Z., Univ Durham, Business Sch, Durham DH1 3LB, England.
   Ford, Tamsin, Univ Cambridge, Dept Psychiat, Cambridge CB2 0AH, England.
   Higgins, Steve, Univ Durham, Sch Educ, Durham DH1 1TA, England.
   Hauser, Oliver; Kirkwood, Charlie, Univ Exeter, Inst Data Sci \& Artificial Intelligence, Exeter EX4 4QF, England.},
DOI = {10.1038/s41598-024-73714-z},
Article-Number = {22606},
Keywords = {Causal inference; Data science; Evaluation; Free school meal pupils;
   RCT; Subgroup analysis},
Keywords-Plus = {RANDOMIZED-TRIALS; SUBGROUP ANALYSIS; SCALE},
Author-Email = {zhimin.xiao@essex.ac.uk},
Number-of-Cited-References = {60},
