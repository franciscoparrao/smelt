   Zhou, Xiang, Harvard Univ, Dept Sociol, Cambridge, MA USA.
   Xie, Yu, Princeton Univ, Dept Sociol, Princeton, NJ USA.},
DOI = {10.1146/annurev-soc-030420-015345},
Keywords = {causal inference; counterfactuals; machine learning; treatment effect
