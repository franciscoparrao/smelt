@article{ WOS:001157253900001,
Author = {Poulos, Jason and Horvitz-Lennon, Marcela and Zelevinsky, Katya and
   Cristea-Platon, Tudor and Huijskens, Thomas and Tyagi, Pooja and Yan,
   Jiaju and Diaz, Jordi and Normand, Sharon-Lise},
Title = {Targeted learning in observational studies with multi-valued treatments:
   An evaluation of antipsychotic drug treatment safety},
Journal = {STATISTICS IN MEDICINE},
Year = {2024},
Volume = {43},
Number = {8},
Pages = {1489-1508},
Month = {APR 15},
Abstract = {We investigate estimation of causal effects of multiple competing
   (multi-valued) treatments in the absence of randomization. Our work is
   motivated by an intention-to-treat study of the relative cardiometabolic
   risk of assignment to one of six commonly prescribed antipsychotic drugs
   in a cohort of nearly 39 000 adults with serious mental illnesses.
   Doubly-robust estimators, such as targeted minimum loss-based estimation
   (TMLE), require correct specification of either the treatment model or
   outcome model to ensure consistent estimation; however, common TMLE
   implementations estimate treatment probabilities using multiple binomial
   regressions rather than multinomial regression. We implement a TMLE
   estimator that uses multinomial treatment assignment and ensemble
   machine learning to estimate average treatment effects. Our multinomial
   implementation improves coverage, but does not necessarily reduce bias,
   relative to the binomial implementation in simulation experiments with
   varying treatment propensity overlap and event rates. Evaluating the
   causal effects of the antipsychotics on 3-year diabetes risk or death,
   we find a safety benefit of moving from a second-generation drug
   considered among the safest of the second-generation drugs to an
   infrequently prescribed first-generation drug known for having low
   cardiometabolic risk.},
Type = {Article},
Affiliation = {Poulos, J (Corresponding Author), Brigham \& Womens Hosp, Div Endocrinol, 221 Longwood Ave, Boston, MA 02115 USA.
   Poulos, Jason; Zelevinsky, Katya; Normand, Sharon-Lise, Harvard Med Sch, Dept Hlth Care Policy, Boston, MA USA.
   Horvitz-Lennon, Marcela, RAND Corp, Boston, MA USA.
   Cristea-Platon, Tudor; Huijskens, Thomas; Tyagi, Pooja; Yan, Jiaju; Diaz, Jordi, QuantumBlack, London, England.
   Normand, Sharon-Lise, Harvard Chan Sch Publ Hlth, Dept Biostat, Boston, MA USA.
   Poulos, Jason, Brigham \& Womens Hosp, Div Endocrinol, 221 Longwood Ave, Boston, MA 02115 USA.},
DOI = {10.1002/sim.10003},
EarlyAccessDate = {FEB 2024},
Keywords = {antipsychotic drugs; cardiometabolic risk; causal inference;
   multi-valued treatments; serious mental illness; targeted minimum-loss
   based estimation},
Keywords-Plus = {PROPENSITY-SCORE; CAUSAL INFERENCE; MULTIPLE TREATMENTS; SCHIZOPHRENIA;
   MORTALITY; ASSOCIATION; ROBUSTNESS; NATIONWIDE; MODELS; RISK},
Author-Email = {poulos@berkeley.edu},
Number-of-Cited-References = {78},
Times-Cited = {3},
Unique-ID = {WOS:001157253900001},
}

@incollection{ WOS:001430744700006,
Author = {Ben Tamo, J. and Nnamdi, Micky C. and Hornback, Andrew and Chen, Matthew
   and Shi, Wenqi and Zhu, Yuanda and Iwinski, Henry J. and Wang, May D.},
Book-Group-Author = {ACM},
Title = {Heterogeneous Treatment Effects of Spinal Fusion Surgery for Adolescent
   Idiopathic Scoliosis Patients},
Booktitle = {15TH ACM CONFERENCE ON BIOINFORMATICS, COMPUTATIONAL BIOLOGY, AND HEALTH
   INFORMATICS, ACM-BCB 2024},
Year = {2024},
Abstract = {Adolescent Idiopathic Scoliosis (AIS) is a prevalent spinal deformity
   affecting a significant number of adolescents worldwide. Surgical
   interventions like spinal fusion surgery are common treatments for
   severe cases, but variability in patient responses necessitates a deeper
   understanding of heterogeneous treatment effects (HTEs). In this study,
   we estimate the HTEs of surgical intervention in AIS patients using
   advanced causal machine learning techniques. We utilize a comprehensive
   dataset comprising demographic and radiographic parameters, as well as
   patient-reported outcomes (PROs), to identify factors influencing
   treatment effects. Our approach employs two primary paradigms within the
   potential outcomes framework: (1) counterfactual prediction (T-learner)
   and (2) direct effect estimation (X-learner). We first perform balance
   checks to ensure comparability between treated and control groups, using
   standardized mean differences (SMD) and the Kolmogorov-Smirnov test to
   assess covariate balance. We then conduct regression analyses to
   investigate the influence of individual covariates on the estimated
   treatment effects. Estimating HTEs can inform personalized treatment
   strategies, potentially improving patient satisfaction and clinical
   outcomes. By applying causal inference methods to surgical treatments,
   this study provides a robust framework for personalized medicine in
   scoliosis care, potentially facilitating more effective AIS patient
   management.},
Type = {Proceedings Paper},
Affiliation = {Ben Tamo, J (Corresponding Author), Georgia Inst Technol, Atlanta, GA 30332 USA.
   Ben Tamo, J.; Nnamdi, Micky C.; Hornback, Andrew; Chen, Matthew; Shi, Wenqi; Zhu, Yuanda; Wang, May D., Georgia Inst Technol, Atlanta, GA 30332 USA.
   Iwinski, Henry J., Shriners Childrens Lexington, Lexington, KY USA.},
DOI = {10.1145/3698587.3701493},
Keywords = {causal inference; heterogeneous treatment effects; adolescent idiopathic
   scoliosis; spinal fusion surgery},
