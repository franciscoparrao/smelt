@incollection{ WOS:001597093800029,
Author = {Wang, Hongyuan},
Book-Group-Author = {IEEE},
Title = {Green Transformation and New Quality Productivity: A Triple Difference
   Approach with Double Machine Learning},
Booktitle = {2025 IEEE 34TH WIRELESS AND OPTICAL COMMUNICATIONS CONFERENCE, WOCC},
Series = {Wireless and Optical Communication Conference},
Year = {2025},
Pages = {149-154},
Abstract = {This paper proposes an integrated causal inference framework combining
   triple difference (DDD) and double machine learning (DML) to evaluate
   the impact of green technological innovation on new quality productivity
   growth. Grounded in Porter's hypothesis and technological innovation
   theory, the study addresses key challenges in environmental policy
   evaluation by merging quasi-experimental designs with machine learning
   techniques. The methodology employs propensity score matching to
   construct comparable treatment and control groups, followed by DDD
   estimation to identify causal effects across multiple dimensions, while
   leveraging DML to control for high-dimensional co-founders and uncover
   heterogeneous treatment effects. Focusing on China's manufacturing
   sector, the analysis demonstrates that green technology adoption
   significantly enhances productivity, with substantial variation across
   firm ownership structures and regional characteristics. The
   methodological contribution lies in demonstrating how machine learning
   augments traditional difference-in-differences approaches through
   improved co-variate balancing, detection of nonlinear treatment effects,
   and refined subgroup analysis. The findings offer theoretical insights
   into the mechanisms of green productivity growth and provide empirical
   evidence for policymakers to design targeted environmental innovation
   strategies.},
Type = {Proceedings Paper},
Affiliation = {Wang, HY (Corresponding Author), Guangdong Univ Sci \& Technol, DongGuan 523083, Peoples R China.
   Wang, Hongyuan, Guangdong Univ Sci \& Technol, DongGuan 523083, Peoples R China.},
DOI = {10.1109/WOCC63563.2025.11082238},
Keywords = {Triple difference model; machine learning; Green transformation},
Keywords-Plus = {INNOVATION; TECHNOLOGIES},
Author-Email = {wanghongyuan@gdust.edu.cn},
Number-of-Cited-References = {12},
Times-Cited = {0},
Unique-ID = {WOS:001597093800029},
}

@incollection{ WOS:001565029100029,
Author = {Yin, Naiyu and Yu, Yue and Gao, Tian and Ji, Qiang},
Editor = {Antonacopoulos, A and Chaudhuri, S and Chellappa, R and Liu, CL and Bhattacharya, S and Pal, U},
Title = {Efficient Nonlinear DAG Learning Under Projection Framework},
Booktitle = {PATTERN RECOGNITION, ICPR 2024, PT VI},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15306},
Pages = {445-460},
Abstract = {Directed Acyclic Graphs (DAGs) are foundational in machine learning,
   causal inference, and probabilistic modeling. Recovering the underlying
   DAG structure from observational data is crucial in these areas. The DAG
   learning can be approached as a constrained optimization problem with a
   continuous acyclicity constraint, often solved iteratively through
   sub-problem optimization. A recent breakthrough has shown that the set
   of DAGs can be represented as the weighted gradients of graph potential
   functions. Hence, one may search for a DAG in the equivalent space,
   whereby the acyclicity constraint is guaranteed to be satisfied.
   However, the original work, DAG-NoCurl, is limited to (generalized)
   linear structural equation models (SEMs) where explicit weighted
   adjacency matrices are defined. Herein, we theoretically derive a
   nonlinear projection formulation and propose an efficient two-step
   nonlinear DAG learning method, which we coined DAG-NCMLP. The proposed
   approach first obtains a non-acyclic graph and then projects it to the
   equivalent space of DAGs to obtain the acyclic graph. Experimental
   studies on benchmark datasets demonstrate that our proposed method
   provides similar accuracy, if not better, compared to state-of-the-art
   non-parametric DAG learning methods with hard-constrained optimization,
   while substantially reducing the computational time.},
Type = {Proceedings Paper},
Affiliation = {Yin, NY (Corresponding Author), Rensselaer Polytech Inst, Troy, NY 12180 USA.
   Yin, Naiyu; Ji, Qiang, Rensselaer Polytech Inst, Troy, NY 12180 USA.
   Yu, Yue, Lehigh Univ, Bethlehem, PA 18015 USA.
   Gao, Tian, IBM Res, Yorktown Heights, NJ 10598 USA.},
DOI = {10.1007/978-3-031-78172-8\_29},
Keywords = {Causal Discovery; Structure Learning; Directed Acyclic Graphs},
Keywords-Plus = {BAYESIAN NETWORKS; CAUSAL DISCOVERY},
Author-Email = {yinn2@rpi.edu
   yuy214@lehigh.edu
   tgao@us.ibm.com
   jiq@rpi.edu},
