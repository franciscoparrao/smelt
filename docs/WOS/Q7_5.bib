   Jiang, Hanfeng; Chen, Haoming; Huo, Zongli, Jiangsu Prov Acad Prevent Med, Jiangsu Prov Ctr Dis Control \& Prevent, Nanjing, Peoples R China.
   Chen, Haoming; Huo, Zongli, Nanjing Univ Sci \& Technol, Sch Environm \& Biol Engn, Nanjing 210094, Jiangsu, Peoples R China.},
DOI = {10.1016/j.jece.2025.120295},
