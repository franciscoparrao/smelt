   Fang, Shenying, Univ Texas MD Anderson Canc Ctr, Dept Surg Oncol, Houston, TX 77030 USA.
   Guo, Shicheng, Univ Wisconsin, Dept Med Genet, Madison, WI 53706 USA.},
DOI = {10.3389/fgene.2020.585804},
Article-Number = {585804},
Keywords = {causal inference; generative adversarial networks; counterfactuals;
   treatment estimation; precision medicine},
Keywords-Plus = {VORINOSTAT; LEUKEMIA},
Author-Email = {xlhuang@mdanderson.org
   momiao.xiong@uth.tmc.edu},
