   Michelini, Sidney, Peace Res Inst Frankfurt, Darmstadter Landstr 112, D-60598 Frankfurt, Germany.
   Michelini, Sidney, Tech Univ Berlin, Str 17 Juni 152, D-10623 Berlin, Germany.},
DOI = {10.1088/1748-9326/ae16c0},
Article-Number = {114088},
Keywords = {climate; conflict; violence; machine learning},
Keywords-Plus = {FOOD-ENERGY-WATER; CLIMATE-CHANGE; VARIABILITY; BOOTSTRAP; MODELS},
