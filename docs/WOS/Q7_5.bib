}

@article{ WOS:001442889800047,
Author = {Demeter, Gabriel and Delina, Radoslav and Urminsky, Jaroslav and
   Zajarosova, Marketa},
Title = {Assessing the Impact of Supplier Group Stability on Public Procurement
   Performance in Slovakia: A Causal Forest Analysis of Collusion Signals},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {41607-41624},
Abstract = {Public procurement plays a crucial role in economic systems, accounting
   for approximately 15\% of global GDP. While electronic reverse auctions
   (eRAs) enhance transparency and efficiency, repeated supplier
   interactions can lead to reduced competition and potential collusion.
   This study investigates the relationship between supplier group
   stability in historical savings and its impact on procurement outcomes,
   leveraging an extensive dataset of 30,349 public contracts from
   Slovakia's national e-procurement platform, EKS. Using advanced causal
   machine learning methods, specifically causal forests, the study
   estimates heterogeneous treatment effects to uncover the nuances of
   supplier behavior. Results indicate that contracts involving supplier
   portfolios with stable tender performance experience, on average, 71\%
   lower savings compared to those with volatile outcomes. However, the
   magnitude of this negative impact varies significantly across supplier
   group dynamics, with some situations exhibiting noticeable collusion
   signals. By estimating individual treatment effects and aggregating them
   at the supplier portfolio level, the model identifies groups showing
   potential competition suppression. The study's findings highlight the
   presence of collusion signals even in highly transparent procurement
   systems, emphasizing the importance of targeted policy interventions.},
Type = {Article},
Affiliation = {Demeter, G (Corresponding Author), Tech Univ Kosice, Dept Banking \& Investment, Kosice 04001, Slovakia.
   Demeter, Gabriel; Delina, Radoslav, Tech Univ Kosice, Dept Banking \& Investment, Kosice 04001, Slovakia.
   Urminsky, Jaroslav; Zajarosova, Marketa, VSB Tech Univ Ostrava, Dept Mkt \& Business, Ostrava 70800, Czech Republic.},
DOI = {10.1109/ACCESS.2025.3547688},
Keywords = {Procurement; Contracts; Stability criteria; Portfolios; Economic
   indicators; Machine learning; Ethics; Standards organizations;
   Stakeholders; Law; Public procurement; collusion; supplier portfolio
   stability; behavioral pattern},
Keywords-Plus = {REVERSE AUCTIONS; REPEATED EXCHANGE; COMPETITION; CORRUPTION; BUYER;
   PARADOX},
