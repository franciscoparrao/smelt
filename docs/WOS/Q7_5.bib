   Ikeda, Takaaki, Tohoku Univ, Grad Sch Dent, Dept Int \& Community Oral Hlth, Sendai, Japan.},
DOI = {10.1371/journal.pdig.0001268},
Article-Number = {e0001268},
Keywords-Plus = {BEHAVIOR; PREVALENCE},
Author-Email = {miki.takahiro@prevent.co.jp},
