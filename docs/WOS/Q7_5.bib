@article{ WOS:001320984800001,
Author = {Ke, Da and Zhou, Xiaoxiao and Yang, Qinglong and Song, Xinyuan},
Title = {Doubly Robust Triple Cross-Fit Estimation for Causal Inference with
   Imaging Data},
Journal = {STATISTICS IN BIOSCIENCES},
Year = {2024},
Month = {2024 SEP 28},
Abstract = {This paper develops a novel doubly robust triple cross-fit estimator to
   estimate the average treatment effect (ATE) using observational and
   imaging data. The construction of the proposed estimator consists of two
   stages. The first stage extracts representative image features using the
   high-dimensional functional principal component analysis model. The
   second stage incorporates the image features into the propensity score
   and outcome models and then analyzes these models through machine
   learning algorithms. A doubly robust estimator for ATE is obtained based
   on the estimation results. In addition, we extend the double cross-fit
   to a triple cross-fit algorithm to accommodate the imaging data that
   typically exhibit more subtle variation and yield less stable estimation
   compared to conventional scalar variables. The simulation study
   demonstrates the satisfactory performance of the proposed estimator. An
   application to the Alzheimer's Disease Neuroimaging Initiative dataset
   confirms the utility of our method.},
Type = {Article; Early Access},
Affiliation = {Song, XY (Corresponding Author), Chinese Univ Hong Kong, Dept Stat, Shatin NT, Hong Kong 999077, Peoples R China.
   Ke, Da; Yang, Qinglong, Zhongnan Univ Econ \& Law, Sch Stat \& Math, Wuhan 430073, Peoples R China.
   Zhou, Xiaoxiao, Univ Alabama Birmingham, Dept Biostat, Birmingham, AL 35294 USA.
   Song, Xinyuan, Chinese Univ Hong Kong, Dept Stat, Shatin NT, Hong Kong 999077, Peoples R China.},
DOI = {10.1007/s12561-024-09458-1},
EarlyAccessDate = {SEP 2024},
Keywords = {Causal inference; Cross fitting; Doubly robust; Imaging data; Machine
   learning},
Keywords-Plus = {MODEL},
