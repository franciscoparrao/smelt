   Collet, Jean-Paul, Univ British Columbia UBC, Vancouver, BC, Canada.
   Vecino, Ramon Hernandez, Sanofi, Dept Res \& Dev, Gentilly, France.},
DOI = {10.1007/s43441-025-00849-0},
