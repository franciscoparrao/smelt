@article{ WOS:000540750000002,
Author = {Huang, Yu and Fu, Zuntao and Franzke, Christian L. E.},
Title = {Detecting causality from time series in a machine learning framework},
Journal = {CHAOS},
Year = {2020},
Volume = {30},
Number = {6},
Month = {JUN},
Abstract = {Detecting causality from observational data is a challenging problem.
   Here, we propose a machine learning based causality approach, Reservoir
   Computing Causality (RCC), in order to systematically identify causal
   relationships between variables. We demonstrate that RCC is able to
   identify the causal direction, coupling delay, and causal chain
   relations from time series. Compared to a well-known phase space
   reconstruction based causality method, Extended Convergent Cross
   Mapping, RCC does not require the estimation of the embedding dimension
   and delay time. Moreover, RCC has three additional advantages: (i)
   robustness to noisy time series; (ii) computational efficiency; and
   (iii) seamless causal inference from high-dimensional data. We also
   illustrate the power of RCC in identifying remote causal interactions of
   high-dimensional systems and demonstrate its usability on a real-world
   example using atmospheric circulation data. Our results suggest that RCC
   can accurately detect causal relationships in complex systems.},
Type = {Article},
Affiliation = {Fu, ZT (Corresponding Author), Peking Univ, Sch Phys, Dept Atmospher \& Ocean Sci, Lab Climate \& Ocean Atmosphere Studies, Beijing 100871, Peoples R China.
   Huang, Yu; Fu, Zuntao, Peking Univ, Sch Phys, Dept Atmospher \& Ocean Sci, Lab Climate \& Ocean Atmosphere Studies, Beijing 100871, Peoples R China.
