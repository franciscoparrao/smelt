   Univ Penn, Wharton Sch, Dept Stat \& Data Sci, 265 South 37th St, Philadelphia, PA 19104 USA.},
DOI = {10.1093/biomet/asad055},
EarlyAccessDate = {FEB 2024},
Keywords = {Average treatment effect; Doubly robust functional; Influence function;
   Machine learning; Model selection},
Keywords-Plus = {REGULARIZED CALIBRATED ESTIMATION; MISSING DATA; INFERENCE; REGRESSION;
   ESTIMATOR; NONRESPONSE; EFFICIENCY; MODELS},
Author-Email = {cuiyf@zju.edu.cn
   ett@wharton.upenn.edu},
