}

@incollection{ WOS:000534424302032,
Author = {Meding, Kristof and Janzing, Dominik and Schoelkopf, Bernhard and
   Wichmann, Felix A.},
Editor = {Wallach, H and Larochelle, H and Beygelzimer, A and d'Alche-Buc, F and Fox, E and Garnett, R},
Title = {Perceiving the arrow of time in autoregressive motion},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 32 (NIPS 2019)},
Series = {Advances in Neural Information Processing Systems},
Year = {2019},
Volume = {32},
Abstract = {Understanding the principles of causal inference in the visual system
   has a long history at least since the seminal studies by Albert
   Michotte. Many cognitive and machine learning scientists believe that
   intelligent behavior requires agents to possess causal models of the
   world. Recent ML algorithms exploit the dependence structure of additive
   noise terms for inferring causal structures from observational data,
   e.g. to detect the direction of time series; the arrow of time. This
   raises the question whether the subtle asymmetries between the time
   directions can also be perceived by humans. Here we show that human
   observers can indeed discriminate forward and backward autoregressive
   motion with non-Gaussian additive independent noise, i.e. they appear
   sensitive to subtle asymmetries between the time directions. We employ a
   so-called frozen noise paradigm enabling us to compare human performance
   with four different algorithms on a trial-by-trial basis: A causal
   inference algorithm exploiting the dependence structure of additive
   noise terms, a neurally inspired network, a Bayesian ideal observer
   model as well as a simple heuristic. Our results suggest that all human
   observers use similar cues or strategies to solve the arrow of time
   motion discrimination task, but the human algorithm is significantly
   different from the three machine algorithms we compared it to. In fact,
   our simple heuristic appears most similar to our human observers.},
Type = {Proceedings Paper},
Affiliation = {Meding, K (Corresponding Author), Univ Tubingen, Neural Informat Proc Grp, Tubingen, Germany.
   Meding, Kristof; Wichmann, Felix A., Univ Tubingen, Neural Informat Proc Grp, Tubingen, Germany.
   Janzing, Dominik, Amazon Res Tubingen, Tubingen, Germany.
   Schoelkopf, Bernhard, Max Planck Inst Intelligent Syst, Empir Inference Dept, Tubingen, Germany.},
Keywords-Plus = {CAUSATION; MODEL},
Author-Email = {kristof.meding@uni-tuebingen.de
   janzind@amazon.com
   bs@tuebingen.mpg.de
   felix.wichmann@uni-tuebingen.de},
Number-of-Cited-References = {62},
Times-Cited = {1},
Unique-ID = {WOS:000534424302032},
}

@incollection{ WOS:000427768602074,
Author = {Zhao, Jianing and Runfola, Daniel M. and Kemper, Peter},
Editor = {Chan, V and DAmbrogio, A and Zacharewicz, G and Mustafee, N},
Title = {SIMULATION STUDY IN QUANTIFYING HETEROGENEOUS CAUSAL EFFECTS},
Booktitle = {2017 WINTER SIMULATION CONFERENCE (WSC)},
Series = {Winter Simulation Conference Proceedings},
Year = {2017},
Pages = {2650-2661},
Abstract = {Quantifying the impact of an intervention or treatment in a real setting
   is a common and challenging problem. For example, we would like to
   calculate the environmental implications of aid projects in third world
   countries that target economic development. For causal inference
   problems of this kind, the Rubin causal model is one of several popular
   theoretical frameworks that comes with a set of algorithmic methods to
   quantify treatment effects. However, for a given data set, we neither
   know the ground truth nor can we easily increase the size of the data
   set. So, simulation is a natural choice to evaluate the applicability of
   a set of methods for a particular problem. In this paper, we report
   findings of a simulation study with four causal inference approaches,
   namely two single tree approaches ( transformed outcome tree, causal
   tree), and two random forest versions of the former.},
Type = {Proceedings Paper},
Affiliation = {Zhao, JN (Corresponding Author), Coll William \& Mary, Dept Comp Sci, 251 Jamestown Rd, Williamsburg, VA 23185 USA.
   Zhao, Jianing; Kemper, Peter, Coll William \& Mary, Dept Comp Sci, 251 Jamestown Rd, Williamsburg, VA 23185 USA.
