@incollection{ WOS:000833496100014,
Author = {Lin, Xiliang and Le, Tho Ngoc and Carrion, Carlos and Wang, Zenan},
Editor = {Atukorala, N and Chang, C and Damiani, E and Fu, M and Spanoudakis, G and Srivatsa, M and Wang, Z and Zhang, J},
Title = {Turning a Curse into a Blessing: A General Approach to Resolve
   Endogeneity Problem in Data-Rich Environment},
Booktitle = {2021 IEEE INTERNATIONAL CONFERENCE ON SMART DATA SERVICES (SMDS 2021)},
Year = {2021},
Pages = {105-114},
Abstract = {High-dimensional data is often a curse in causal analysis with
   observational data. The lack of exogenous variations in the treatment
   makes causal inference with observational study challenging, because
   confounding variables may mask the real causal effects or sometimes
   point to spurious correlations. High-dimensional data makes it harder to
   identify and control the confounders, thus exacerbates the endogeneity
   problem. Leveraging machine learning tools, we present a novel approach
   to resolve endogeneity and turn high-dimensional data into a blessing.
   Our method first builds regression models to predict the endogenous
   treatment. This prediction reduces input dimension and helps decouple
   exogenous variation from confounders. We then use the prediction as a
   control function, and the regression residual as an instrumental
   variable to estimate the causal effect. Through simulation, we show that
   both estimation methods significantly reduce endogeneity, with the
   control function performing slightly better. Our method is simple,
   semi-parametric, and flexible for various applications.},
Type = {Proceedings Paper},
Affiliation = {Lin, XL (Corresponding Author), JD Com, Beijing, Peoples R China.
   Lin, Xiliang; Le, Tho Ngoc; Carrion, Carlos; Wang, Zenan, JD Com, Beijing, Peoples R China.},
DOI = {10.1109/SMDS53860.2021.00024},
Keywords = {instrumental variables; observational data; machine learning; big data;
   causal inference},
Keywords-Plus = {PROPENSITY SCORE ESTIMATION; INSTRUMENTAL VARIABLES; CAUSAL INFERENCE;
   IDENTIFICATION},
Author-Email = {xiliang.lin@jd.com
   ngocle.tho@jd.com
   carlos.carrion@jd.com
   wangzenan5@jd.com},
Number-of-Cited-References = {20},
Times-Cited = {3},
Unique-ID = {WOS:000833496100014},
}

@article{ WOS:000476621500001,
Author = {Herlands, William and Neill, Daniel B. and Nickisch, Hannes and Wilson,
   Andrew Gordon},
Title = {Change Surfaces for Expressive Multidimensional Changepoints and
   Counterfactual Prediction},
Journal = {JOURNAL OF MACHINE LEARNING RESEARCH},
Year = {2019},
Volume = {20},
Abstract = {Identifying changes in model parameters is fundamental in machine
   learning and statistics. However, standard changepoint models are
   limited in expressiveness, often addressing unidimensional problems and
   assuming instantaneous changes. We introduce change surfaces as a
   multidimensional and highly expressive generalization of changepoints.
   We provide a model-agnostic formalization of change surfaces,
   illustrating how they can provide variable, heterogeneous, and
   non-monotonic rates of change across multiple dimensions. Additionally,
   we show how change surfaces can be used for counterfactual prediction.
   As a concrete instantiation of the change surface framework, we develop
   Gaussian Process Change Surfaces (GPCS). We demonstrate counterfactual
   prediction with Bayesian posterior mean and credible sets, as well as
   massive scalability by introducing novel methods for additive
   nonseparable kernels. Using two large spatio-temporal datasets we employ
   GPCS to discover and characterize complex changes that can provide
   scientific and policy relevant insights. Specifically, we analyze
   twentieth century measles incidence across the United States and
   discover previously unknown heterogeneous changes after the introduction
   of the measles vaccine. Additionally, we apply the model to requests for
   lead testing kits in New York City, discovering distinct spatial and
   demographic patterns.},
Type = {Article},
Affiliation = {Herlands, W (Corresponding Author), Carnegie Mellon Univ, HJ Heinz III Coll, Event \& Pattern Detect Lab, Pittsburgh, PA 15213 USA.
