@article{ WOS:000897576200003,
Author = {Ling, Yaobin and Upadhyaya, Pulakesh and Chen, Luyao and Jiang, Xiaoqian
   and Kim, Yejin},
Title = {Emulate randomized clinical trials using heterogeneous treatment effect
   estimation for personalized treatments: Methodology review and benchmark},
Journal = {JOURNAL OF BIOMEDICAL INFORMATICS},
Year = {2023},
Volume = {137},
Month = {JAN},
Abstract = {Big data and (deep) machine learning have been ambitious tools in
   digital medicine, but these tools focus mainly on association.
   Intervention in medicine is about the causal effects. The average
   treatment effect has long been studied as a measure of causal effect,
   assuming that all populations have the same effect size. However, no
   ``one -size-fits-all{''} treatment seems to work in some complex
   diseases. Treatment effects may vary by patient. Esti-mating
   heterogeneous treatment effects (HTE) may have a high impact on
   developing personalized treatment. Lots of advanced machine learning
   models for estimating HTE have emerged in recent years, but there has
   been limited translational research into the real-world healthcare
   domain. To fill the gap, we reviewed and compared eleven recent HTE
   estimation methodologies, including meta-learner, representation
   learning models, and tree -based models. We performed a comprehensive
   benchmark experiment based on nationwide healthcare claim data with
   application to Alzheimer's disease drug repurposing. We provided some
   challenges and opportunities in HTE estimation analysis in the
   healthcare domain to close the gap between innovative HTE models and
   deployment to real-world healthcare problems.},
Type = {Review},
Affiliation = {Kim, Y (Corresponding Author), Univ Texas Hlth Sci Ctr Houston, Ctr Secure Artificial Intelligence Healthcare, Sch Biomed Informat, Fannin 7000, Houston, TX 77030 USA.
   Ling, Yaobin; Upadhyaya, Pulakesh; Chen, Luyao; Jiang, Xiaoqian; Kim, Yejin, Univ Texas Hlth Sci Ctr Houston, Ctr Secure Artificial Intelligence Healthcare, Sch Biomed Informat, Fannin 7000, Houston, TX 77030 USA.},
DOI = {10.1016/j.jbi.2022.104256},
EarlyAccessDate = {DEC 2022},
Article-Number = {104256},
Keywords = {Causal inference; Target trial; Conditional average treatment effect;
   Drug development; Deep learning; Machine learning},
Keywords-Plus = {CAUSAL INFERENCE; RECORD},
Author-Email = {yaobin.ling@uth.tmc.edu
