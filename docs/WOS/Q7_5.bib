DOI = {10.1145/3580305.3599774},
Keywords = {Machine Learning for Healthcare; Causal Inference; Representation
   Learning; Semi-supervised Learning; Treatment Effect Estimation; COVID
   Analysis; Generative AI; Deep Latent Variable Models; Variational
   Autoencoder},
Keywords-Plus = {EXTRACORPOREAL MEMBRANE-OXYGENATION; MORTALITY RISK; PREDICTION; SCORE},
