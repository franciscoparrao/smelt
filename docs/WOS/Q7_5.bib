@article{ WOS:001238552000002,
Author = {Hu, Jinping and de Haan, Evert and Skiera, Bernd},
Title = {Uplift modeling with quasi-loss-functions},
Journal = {DATA MINING AND KNOWLEDGE DISCOVERY},
Year = {2024},
Volume = {38},
Number = {4},
Pages = {2495-2519},
Month = {JUL},
Abstract = {Uplift modeling, also referred to as heterogeneous treatment effect
   estimation, is a machine learning technique utilized in marketing for
   estimating the incremental impact of treatment on the response of each
   customer. Uplift models face a fundamental challenge in causal inference
   because the variable of interest (i.e., the uplift itself) remains
   unobservable. As a result, popular uplift models (such as meta-learners
   and uplift trees) do not incorporate loss functions for uplifts in their
   algorithms. This article addresses that gap by proposing uplift models
   with quasi-loss functions (UpliftQL models), which separately use four
   specially designed quasi-loss functions for uplift estimation in
   algorithms. Using simulated data, our analysis reveals that, on average,
   55\% (34\%) of the top five models from a set of 14 are UpliftQL models
   for binary (continuous) outcomes. Further empirical data analysis shows
   that over 60\% of the top-performing models are consistently UpliftQL
   models.},
Type = {Article},
Affiliation = {Hu, JP (Corresponding Author), Shenzhen Technol Univ, 3002 Lantian Rd, Shenzhen 518118, Peoples R China.
   Hu, Jinping, Shenzhen Technol Univ, 3002 Lantian Rd, Shenzhen 518118, Peoples R China.
   de Haan, Evert, Univ Groningen, Nettelbosje 2, NL-9747 AE Groningen, Netherlands.
   Skiera, Bernd, Goethe Univ Frankfurt, Theodor W Adorno Pl 4, D-60323 Frankfurt, Germany.
   Skiera, Bernd, Deakin Business Sch, Dept Mkt, Melbourne, Vic 3124, Australia.},
DOI = {10.1007/s10618-024-01042-x},
EarlyAccessDate = {JUN 2024},
Keywords = {Uplift modeling; Loss function; Heterogeneous treatment effects; Causal
