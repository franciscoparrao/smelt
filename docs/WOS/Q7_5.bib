   Rao, Shishir; Mamouei, Mohammad; Salimi-Khorshidi, Gholamreza; Li, Yikuan; Ramakrishnan, Rema; Hassaine, Abdelaali, Univ Oxford, Natl Perinatal Epidemiol Unit, Oxford OX3 7LF, England.
   Canoy, Dexter; Rahimi, Kazem, Oxford Univ Hosp Natl Hlth Serv NHS Fdn Trust, NIHR Oxford Biomed Res Ctr, Oxford OX3 9DU, England.},
DOI = {10.1109/TNNLS.2022.3183864},
EarlyAccessDate = {JUN 2022},
Keywords = {Estimation; Data models; Deep learning; Cancer; Predictive models; Task
   analysis; Benchmark testing; Causal inference; deep learning; electronic
   health records (EHRs); machine learning},
Keywords-Plus = {PROPENSITY SCORE; DATABASES},
Author-Email = {shishir.rao@wrh.ox.ac.uk},
