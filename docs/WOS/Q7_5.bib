@article{ WOS:001564162000001,
Author = {Wang, Di and Song, Mingyue and Chen, Shiwei and Du, Hongyuan},
Title = {The impact of the global 100 resilient cities strategy on urban
   resilience under climate change},
Journal = {CITIES},
Year = {2025},
Volume = {167},
Month = {DEC},
Abstract = {Urban areas are pivotal in addressing climate change. Despite
   considerable efforts by foundations and municipal governments to enhance
   the resilience of cities, the actual improvement in their resilience
   under the context of climate change (CCRC) requires empirical
   verification. This study focuses on the Global 100 Resilient Cities
   (100RC) strategy proposed by the Rockefeller Foundation, and constructs
   a comprehensive urban evaluation index system that encompasses the
   dimensions of economy, society, environment, and governance. Employing
   methods such as DID, SDID, DML, and case studies, the research assesses
   the effectiveness of the 100RC initiative in enhancing CCRC.
   Additionally, it explores the challenges and policy implementation
   pathways for building resilience in cities under climate change. The
   findings indicate that the 100RC strategy generally achieves its goals
   in enhancing CCRC, particularly in the United States and in cities with
   established emergency management agencies. However, there remains room
   for optimization in managing resilience, as the strategy has not
   effectively catalyzed positive network effects among pilot cities. The
   study further categorizes cities into four types: those stimulating
   social vitality, enhancing emergency efficacy, optimizing resource and
   environmental conditions, and those with comprehensive resilience
   limitations, revealing heterogeneous policy effects among individual
   cities. Based on these findings, the study develops a
   ``policy-tool-effectiveness{''} analytical framework, recommending that
   local governments select appropriate policy tools tailored to their
   unique challenges, employ diverse methods to enhance strategic
   capabilities, and periodically adjust policy design and implementation.},
Type = {Article},
Affiliation = {Wang, D (Corresponding Author), Peking Univ, Sch Govt, Beijing 100871, Peoples R China.
   Wang, Di; Du, Hongyuan, Peking Univ, Sch Govt, Beijing 100871, Peoples R China.
   Wang, Di, Peking Univ, Inst Publ Governance, Beijing, Peoples R China.
