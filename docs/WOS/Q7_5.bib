@article{ WOS:000991153200002,
Author = {Banerjee, Amitava and Chandra, Sarthak and Ott, Edward},
Title = {Network inference from short, noisy, low time-resolution, partial
   measurements: Application to C. elegans neuronal calcium dynamics},
Journal = {PROCEEDINGS OF THE NATIONAL ACADEMY OF SCIENCES OF THE UNITED STATES OF
   AMERICA},
Year = {2023},
Volume = {120},
Number = {12},
Month = {MAR 13},
Abstract = {Network link inference from measured time series data of the behavior of
   dynamically interacting network nodes is an important problem with
   wide-ranging applications, e.g., estimating synaptic connectivity among
   neurons from measurements of their calcium fluorescence. Network
   inference methods typically begin by using the measured time series to
   assign to any given ordered pair of nodes a numerical score reflecting
   the likelihood of a directed link between those two nodes. In typical
   cases, the measured time series data may be subject to limitations,
   including limited duration, low sampling rate, observational noise, and
   partial nodal state measurement. However, it is unknown how the
   performance of link inference techniques on such datasets depends on
   these experimental limitations of data acquisition. Here, we utilize
   both synthetic data generated from coupled chaotic systems as well as
   experimental data obtained from Caenorhabditis elegans neural activity
   to systematically assess the influence of data limitations on the
   character of scores reflecting the likelihood of a directed link between
   a given node pair. We do this for three network inference techniques:
   Granger causality, transfer entropy, and, a machine learning-based
   method. Furthermore, we assess the ability of appropriate surrogate data
   to determine statistical confidence levels associated with the results
   of link-inference techniques.},
Type = {Article},
Affiliation = {Banerjee, A (Corresponding Author), Univ Maryland, Dept Phys, College Pk, MD 20742 USA.
   Banerjee, A (Corresponding Author), Univ Maryland, Inst Res Elect \& Appl Phys, College Pk, MD 20742 USA.
   Banerjee, Amitava; Ott, Edward, Univ Maryland, Dept Phys, College Pk, MD 20742 USA.
   Banerjee, Amitava; Ott, Edward, Univ Maryland, Inst Res Elect \& Appl Phys, College Pk, MD 20742 USA.
   Chandra, Sarthak, MIT, Dept Brain \& Cognit Sci, 77 Massachusetts Ave, Cambridge, MA 02139 USA.
   Chandra, Sarthak, MIT, McGovern Inst, 77 Massachusetts Ave, Cambridge, MA 02139 USA.
   Ott, Edward, Univ Maryland, Dept Elect \& Comp Engn, College Pk, MD 20742 USA.},
DOI = {10.1073/pnas.2216030120},
Article-Number = {2216030120},
Keywords = {network inference; time series analysis; surrogate data techniques;
   causal inference; neural networks},
Keywords-Plus = {GENE REGULATORY NETWORKS; GRANGER CAUSALITY; CELLULAR RESOLUTION;
   TRANSFER ENTROPY; CONNECTIVITY; NONLINEARITY; SERIES},
