@article{ WOS:001616700000001,
Author = {Kabata, Daijiro and Henderson, Nicholas C. and Varadhan, Ravi},
Title = {Quantifying uncertainty of individualized treatment effects in
   right-censored survival data: a comparison of Bayesian additive
   regression trees and causal survival forest},
Journal = {HEALTH SERVICES AND OUTCOMES RESEARCH METHODOLOGY},
Year = {2026},
Volume = {26},
Number = {1, SI},
Pages = {87-107},
Month = {MAR},
Abstract = {Estimation of individualized treatment effects (ITE), also known as
   conditional average treatment effects (CATE), is an active area of
   methodology development. However, much less attention has been paid to
   the quantification of uncertainty of ITE/CATE estimates in
   right-censored survival data. Here we undertake an extensive simulation
   study to examine the coverage of interval estimates from two popular
   estimation algorithms, Bayesian additive regression trees (BART) and
   causal survival forest (CSF). We conducted simulation designs from 3
   different settings: first, in a setting where BART was developed for an
   accelerated failure time model; second, where CSF was developed; and
   finally, a ``neutral{''} simulation taken from a setting where neither
   BART nor CSF was developed. BART outperformed CSF in all three
   simulation settings. Both the BART and CSF algorithms involve multiple
   hyperparameters, and BART credible intervals had better coverage than
   the CSF confidence intervals under the default values, as well as under
   optimized values, of these hyperparameters.},
Type = {Article},
Affiliation = {Varadhan, R (Corresponding Author), Johns Hopkins Univ, Sch Med, Dept Oncol, Baltimore, MD 21218 USA.
   Varadhan, R (Corresponding Author), Johns Hopkins Univ, Dept Biostat, Baltimore, MD 21218 USA.
   Kabata, Daijiro, Kobe Univ, Ctr Math \& Data Sci, Kobe, Hyogo, Japan.
   Henderson, Nicholas C., Univ Michigan, Dept Biostat, Ann Arbor, MI USA.
   Varadhan, Ravi, Johns Hopkins Univ, Sch Med, Dept Oncol, Baltimore, MD 21218 USA.
   Varadhan, Ravi, Johns Hopkins Univ, Dept Biostat, Baltimore, MD 21218 USA.},
DOI = {10.1007/s10742-025-00362-9},
EarlyAccessDate = {NOV 2025},
Keywords = {Causal inference; Coverage evaluation; Interval estimation;
