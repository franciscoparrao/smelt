   Le Thi, Christine, OECD, Hlth Div, OECD Directorate Employment Labour \& Social Affair, 2 Rue Andre Pascal, F-75016 Paris, France.},
DOI = {10.1016/j.jeem.2025.103149},
EarlyAccessDate = {MAR 2025},
