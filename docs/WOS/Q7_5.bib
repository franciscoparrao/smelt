@article{ WOS:001219246700001,
Author = {Kosko, Matthew and Wang, Lin and Santacatterina, Michele},
Title = {A fast bootstrap algorithm for causal inference with large data},
Journal = {STATISTICS IN MEDICINE},
Year = {2024},
Volume = {43},
Number = {15},
Pages = {2894-2927},
Month = {JUL 10},
Abstract = {Estimating causal effects from large experimental and observational data
   has become increasingly prevalent in both industry and research. The
   bootstrap is an intuitive and powerful technique used to construct
   standard errors and confidence intervals of estimators. Its application
   however can be prohibitively demanding in settings involving large data.
   In addition, modern causal inference estimators based on machine
   learning and optimization techniques exacerbate the computational burden
   of the bootstrap. The bag of little bootstraps has been proposed in
   non-causal settings for large data but has not yet been applied to
   evaluate the properties of estimators of causal effects. In this
   article, we introduce a new bootstrap algorithm called causal bag of
   little bootstraps for causal inference with large data. The new
   algorithm significantly improves the computational efficiency of the
   traditional bootstrap while providing consistent estimates and desirable
   confidence interval coverage. We describe its properties, provide
   practical considerations, and evaluate the performance of the proposed
   algorithm in terms of bias, coverage of the true 95\% confidence
   intervals, and computational time in a simulation study. We apply it in
   the evaluation of the effect of hormone therapy on the average time to
   coronary heart disease using a large observational data set from the
   Women's Health Initiative.},
Type = {Article},
Affiliation = {Kosko, M (Corresponding Author), George Washington Univ, Dept Stat, Washington, DC 20052 USA.
   Kosko, Matthew, George Washington Univ, Dept Stat, Washington, DC 20052 USA.
   Wang, Lin, Purdue Univ, Dept Stat, W Lafayette, IN USA.
   Santacatterina, Michele, NYU, Dept Populat Hlth, New York, NY USA.},
DOI = {10.1002/sim.10075},
EarlyAccessDate = {MAY 2024},
Keywords = {causal bootstrap; covariate balance; machine learning; propensity score;
   real-world data},
Keywords-Plus = {PROPENSITY-SCORE; INVERSE PROBABILITY; HORMONE-THERAPY; STRATEGIES;
   ESTIMATORS; VARIANCE},
Author-Email = {matthewdkosko@gmail.com},
