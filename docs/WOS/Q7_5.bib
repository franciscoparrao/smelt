@article{ WOS:001686959500001,
Author = {Shah, Vishalie and Hatamyar, Julia and Hidayat, Taufik and Kreif, Noemi},
Title = {Exploring the heterogeneous impacts of Indonesia's conditional cash
   transfer scheme (PKH) on maternal health care utilisation using
   instrumental causal forests},
Journal = {EMPIRICAL ECONOMICS},
Year = {2026},
Volume = {70},
Number = {2},
Month = {FEB 12},
Abstract = {This paper uses instrumental causal forests, a novel machine learning
   method, to explore the treatment effect heterogeneity of Indonesia's
   conditional cash transfer scheme on maternal health care utilisation.
   Using randomised programme assignment as an instrument for enrollment in
   the scheme, we estimate conditional local average treatment effects for
   four key outcomes: good assisted delivery, delivery in a health care
   facility, pre-natal visits, and post-natal visits. We find significant
   treatment effect heterogeneity by supply-side characteristics, even
   though supply-side readiness was taken into account during programme
   development. Mothers in areas with more doctors, nurses, and delivery
   assistants were more likely to benefit from the programme, in terms of
   increased rates of good assisted delivery outcome. We also find large
   differences in benefits according to indicators of household poverty and
   survey wave, reflecting the possible impact of changes in programme
   design in its later years. The impact on post-natal visits in 2013
   displayed the largest heterogeneity among all outcomes, with some women
   less likely to attend post-natal check-ups after receiving the cash
   transfer in the long term.},
Type = {Article},
Affiliation = {Hatamyar, J (Corresponding Author), Univ York, Ctr Hlth Econ, York, England.
   Shah, Vishalie, IQVIA UK, London, England.
   Hatamyar, Julia, Univ York, Ctr Hlth Econ, York, England.
   Hidayat, Taufik, Univ Sussex, Brighton and Hove, England.
   Univ Indonesia, Fac Publ Hlth, Ctr Hlth Econ \& Policy Studies CHEPS, Depok, Indonesia.
   Kreif, Noemi, Univ Washington, Seattle, WA USA.},
DOI = {10.1007/s00181-025-02846-6},
Article-Number = {39},
Keywords-Plus = {MIDDLE-INCOME COUNTRIES; TRANSFER PROGRAMS; INTERVENTIONS; CONSEQUENCES;
   INCENTIVES; MORTALITY; ACCESS},
Author-Email = {julia.hatamyar@york.ac.uk},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001686959500001},
}

@article{ WOS:001685507700001,
Author = {Deng, Lu and Huang, Bai and Luo, Zehui and Sun, Kunpeng},
Title = {The Heterogeneous Effect of Alternative Data on the Capital Market:
   Evidence from Online Recruitment Big Data},
Journal = {EMERGING MARKETS FINANCE AND TRADE},
Year = {2026},
Month = {2026 FEB 11},
Abstract = {Modern information systems enable the collection and analysis of
   non-traditional information sources, commonly referred to as alternative
   data. This information is context-rich and has predictive efficacy,
   making it particularly valuable for investment decisions. However,
   previous studies have divergent findings on the question of whether
   alternative data can affect corporate performance. Using the Causal
   Forest Double Machine Learning model, we analyze approximately 7 million
   job postings from 1079 Chinese listed companies, including three
   dimensions: the source, receiver, and content characteristics. Our
   findings indicate that (i) recruitment data can affect corporate
   performance, with heterogeneity explaining the inconsistent impacts;
   (ii) the treatment effect is smaller for enterprises with higher state
   ownership; (iii) firms in the introduction and growth stages exhibit
   relatively higher treatment effects, whereas those in the shake-out and
   decline stages show relatively lower treatment effects. Also, the
   effects of recruitment positions and salary level are examined.},
Type = {Article; Early Access},
Affiliation = {Huang, B (Corresponding Author), Cent Univ Finance \& Econ, Sch Stat \& Math, Changping Dist Shahe Univ Pk, Beijing 102206, Peoples R China.
   Deng, Lu; Huang, Bai; Luo, Zehui, Cent Univ Finance \& Econ, Sch Stat \& Math, Changping Dist Shahe Univ Pk, Beijing 102206, Peoples R China.
