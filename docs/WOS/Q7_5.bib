@article{ WOS:001622632500001,
Author = {Rafiullah and Wang, Hong},
Title = {Heterogeneous treatment effects estimation with residualized LASSO and
   support vector machines},
Journal = {JOURNAL OF THE KOREAN STATISTICAL SOCIETY},
Year = {2025},
Month = {2025 NOV 25},
Abstract = {The Residualized LASSO (RLASSO) approach is widely employed for
   estimating heterogeneous treatment effects (HTE) due to its proficiency
   in high-dimensional settings and variable selection capabilities.
   However, its reliance on linear models for both outcome and treatment
   assignment imposes limitations. Specifically, the linearity assumption
   can restrict the flexibility required to capture complex, nonlinear
   relationships between covariates and treatment or outcomes. In
   observational studies, where such nonlinearities are prevalent, this may
   lead to biased treatment effect estimates. To overcome the linear
   constraints of traditional RLASSO, we propose the RLASSO-SVM model,
   which integrates Support Vector Machines (SVM) into the R-learner
   framework to enable flexible, nonlinear modeling of both treatments and
   outcomes. This hybrid approach leverages SVM for residual estimation
   while employing LASSO to ensure interpretable treatment effect
   estimation, thereby enhancing performance in high-dimensional, nonlinear
   contexts. Results from Monte Carlo simulations and real-world
   applications demonstrate that the proposed RLASSO-SVM approach achieves
   superior precision compared to other machine learning methods used for
   estimating HTE .},
Type = {Article; Early Access},
Affiliation = {Wang, H (Corresponding Author), Cent South Univ, Sch Math \& Stat, Changsha 410083, Hunan, Peoples R China.
   Rafiullah; Wang, Hong, Cent South Univ, Sch Math \& Stat, Changsha 410083, Hunan, Peoples R China.},
DOI = {10.1007/s42952-025-00355-x},
EarlyAccessDate = {NOV 2025},
Keywords = {Machine learning; Non-parametric; Support vector machine; LASSO;
   Heterogeneous treatment effects; Observational studies},
Keywords-Plus = {ADDITIVE REGRESSION TREES; BIG DATA},
Author-Email = {rafiuom111@gmail.com
   wh@csu.edu.cn},
Number-of-Cited-References = {50},
Times-Cited = {0},
Unique-ID = {WOS:001622632500001},
}

@article{ WOS:001626956000001,
Author = {Jiang, Hanfeng and Xie, Yuyan and Wu, Jiangyan and Zhao, Fangzhou and
   Tian, Yuxin and Chen, Haoming and Huo, Zongli},
Title = {Unveiling the unbiased causal mechanisms of phosphogypsum on plant
   performance: Optimal application and heterogeneous environmental effects
   identified by machine learning},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {6},
Month = {DEC},
Abstract = {Phosphogypsum (PG) is a byproduct of the phosphate fertilizer industry
   that presents both environmental challenges and potential opportunities
   for agricultural use. This study pioneers a novel framework that
   integrates machine learning (ML) with causal inference to unbiasedly
   evaluate PG's effects on soil-crop systems, especially crop yield and
   nutrient content. Bayesian optimization-based CatBoost model accurately
   predicted crop yield, N, P, and K content (Test R-2 = 0.94-0.97)
   compared to other models, and was empirically proven to be generalizable
   and robust (Validation R-2 > 0.85). PG dosage, soil pH, calcium and
   magnesium content were key drivers. SHAP analysis revealed PG dosage in
   the optimal range of 3.5-6.5 t/ha can efficiently promote crop quality
   and yield enhancement. While double ML framework quantifies PG's average
   treatment effect for crop yield, N, P, and K content were 0.0164,
   0.0786, 0.0020 and -0.1127, indicated that PG enhances N and P
   availability but may suppress K content, its direct effect on yield is
   more modest than previously thought. Compared to linear regression and
   partial dependence analysis, this causal approach prevents
   overestimation and provides reliable, unbiased evidence. Therefore, PG
   should be used for soil improvement and plant growth with differentiated
   application strategies based on soil and crop heterogeneity. This study
   offers valuable insights for sustainable PG recycling in agriculture,
   aligning with the goals of precision farming and industrial waste
   valorization.},
Type = {Article},
Affiliation = {Chen, HM (Corresponding Author), Nanjing Univ Sci \& Technol, Sch Environm \& Biol Engn, Nanjing, Peoples R China.
   Chen, HM; Huo, ZL (Corresponding Author), Jiangsu Prov Acad Prevent Med, Jiangsu Prov Ctr Dis Control \& Prevent, Nanjing, Peoples R China.
