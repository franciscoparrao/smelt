   Zhu, Yiying; Rao, Haicheng, 169 Shuanggang East St,Changbei Econ \& Technol Dev, Nanchang 330013, Jiangxi, Peoples R China.},
DOI = {10.1016/j.cities.2024.104815},
EarlyAccessDate = {FEB 2024},
