@article{ WOS:001540159100001,
Author = {Devina, Helma and Ardhi, Rizqi},
Title = {Causal machine learning and strategic pricing under short-term rental
   regulation},
Journal = {JOURNAL OF POLICY RESEARCH IN TOURISM LEISURE AND EVENTS},
Year = {2025},
Month = {2025 JUL 29},
Abstract = {This study examines how Airbnb hosts respond to short-term rental
   regulation by analysing the impact of Byron Shire's 60-day cap on
   non-hosted listings. Situated within Australia's broader housing and
   tourism policy debate, the research explores host pricing strategies
   under regulatory constraints. Using a causal inference that combines
   Difference-in-Differences, Difference-in-Difference-in-Differences, and
   Propensity Score Matching, the analysis isolates the regulation's
   effects at the listing level. Results show that affected hosts increased
   nightly rates to offset limited availability, while unaffected listings
   exhibited seasonal price adjustments. Host characteristics significantly
   moderated these responses, with professional operators demonstrating
   greater adaptability than individual hosts. To complement the
   econometric analysis, machine learning models identify nonlinear pricing
   behaviours and key determinants, such as host experience, guest
   sentiment, and spatial location. The findings reveal heterogeneous
   market adaptations, cautioning against uniform regulatory assumptions.
   The study advocates for an adaptive, tiered policy that balances housing
   affordability with economic resilience of platform-based markets.},
Type = {Article; Early Access},
Affiliation = {Devina, H (Corresponding Author), Cornell Univ, Cornell Tech, 2 Loop Rd, New York, NY 10044 USA.
   Devina, Helma, Cornell Univ, Cornell Tech, 2 Loop Rd, New York, NY 10044 USA.
   Ardhi, Rizqi, Univ Edinburgh, Business Sch, Edinburgh, Scotland.},
DOI = {10.1080/19407963.2025.2538547},
EarlyAccessDate = {JUL 2025},
Keywords = {Northern rivers; difference-in-difference (DiD); difference-in -
   difference-in-differences (DDD); propensity score matching (PSM);
   machine learning (random forest and XGBoost); causal inference},
Keywords-Plus = {AIRBNB},
Author-Email = {hd382@cornell.edu},
Number-of-Cited-References = {40},
