Keywords-Plus = {INVALID INSTRUMENTS; INFERENCE; IDENTIFICATION; PREDICTION; MODELS;
   STATISTICS; REGRESSION; VARIABLES; SYSTEMS},
Author-Email = {buhlmann@stat.math.ethz.ch},
Number-of-Cited-References = {70},
Times-Cited = {90},
Unique-ID = {WOS:000568739100012},
}

@incollection{ WOS:000473814700037,
Author = {Madras, David and Creager, Elliot and Pitassi, Toniann and Zemel,
   Richard},
Book-Group-Author = {Assoc Comp Machinery},
Title = {Fairness through Causal Awareness: Learning Causal Latent-Variable
   Models for Biased Data},
Booktitle = {FAT{*}'19: PROCEEDINGS OF THE 2019 CONFERENCE ON FAIRNESS,
   ACCOUNTABILITY, AND TRANSPARENCY},
Year = {2019},
Pages = {349-358},
Abstract = {How do we learn from biased data? Historical datasets often reflect
   historical prejudices; sensitive or protected attributes may affect the
   observed treatments and outcomes. Classification algorithms tasked with
   predicting outcomes accurately from these datasets tend to replicate
   these biases. We advocate a causal modeling approach to learning from
   biased data, exploring the relationship between fair classification and
   intervention. We propose a causal model in which the sensitive attribute
   confounds both the treatment and the outcome. Building on prior work in
   deep learning and generative modeling, we describe how to learn the
   parameters of this causal model from observational data alone, even in
   the presence of unobserved confounders. We show experimentally that
   fairness-aware causal modeling provides better estimates of the causal
   effects between the sensitive attribute, the treatment, and the outcome.
   We further present evidence that estimating these causal effects can
   help learn policies that are both more accurate and fair, when presented
   with a historically biased dataset.},
Type = {Proceedings Paper},
Affiliation = {Madras, D (Corresponding Author), Univ Toronto, Vector Inst, Toronto, ON, Canada.
   Madras, David; Creager, Elliot; Pitassi, Toniann; Zemel, Richard, Univ Toronto, Vector Inst, Toronto, ON, Canada.},
DOI = {10.1145/3287560.3287564},
Keywords = {causal inference; variational inference; fairness in machine learning},
Author-Email = {madras@cs.toronto.edu
   creager@cs.toronto.edu
   toni@cs.toronto.edu
   zemel@cs.toronto.edu},
Number-of-Cited-References = {51},
Times-Cited = {80},
Unique-ID = {WOS:000473814700037},
}

@article{ WOS:000638135000011,
Author = {Knaus, Michael C. and Lechner, Michael and Strittmatter, Anthony},
Title = {Machine learning estimation of heterogeneous causal effects: Empirical
   Monte Carlo evidence},
Journal = {ECONOMETRICS JOURNAL},
Year = {2021},
Volume = {24},
Number = {1, SI},
Pages = {134-161},
Month = {JAN},
Abstract = {We investigate the finite-sample performance of causal machine learning
   estimators for heterogeneous causal effects at different aggregation
   levels. We employ an empirical Monte Carlo study that relies on arguably
   realistic data generation processes (DGPs) based on actual data in an
   observational setting. We consider 24 DGPs, eleven causal machine
   learning estimators, and three aggregation levels of the estimated
   effects. Four of the considered estimators perform consistently well
   across all DGPs and aggregation levels. These estimators have multiple
   steps to account for the selection into the treatment and the outcome
   process.},
Type = {Article},
Affiliation = {Knaus, MC (Corresponding Author), Univ St Gallen, Varnbuelstr 14, CH-9000 St Gallen, Switzerland.
