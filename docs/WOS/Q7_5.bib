@article{ WOS:001702411800001,
Author = {Lai, Yongjie and Her, Qoua L. and Zhang, Yue and Xu, Hong and
   Kucharska-newton, Anna and Ji, Dongze and Wu, Guorong and Garden, Gwenn
   and Sturmer, Til and Wang, Tiansheng and Xu, Yang},
Title = {The heterogeneous treatment effects of statins on dementia: a target
   trial emulation with causal machine learning using integrated genetic
   and real-world data},
Journal = {ALZHEIMERS \& DEMENTIA},
Year = {2026},
Volume = {22},
Number = {2},
Month = {FEB 26},
Abstract = {INTRODUCTION Given the complexity of dementia, the inconsistent evidence
   on statins and dementia highlights the need for robust methods to assess
   heterogeneous treatment effects (HTEs).METHODS We emulated a target
   trial using UK Biobank comparing statin initiators and non-initiators
   aged >= 55 years. Marginal structural models were fitted to estimate
   5-year adjusted risk difference (aRD). We used iterative causal forest,
   a causal machine learning subgrouping algorithm, to identify subgroups
   with HTEs. RESULTS Among 18,366 participants, the overall aRD for
   all-cause dementia was -1.0 parts per thousand (95\% CI: -4.2 parts per
   thousand to 2.3 parts per thousand). We identified subgroups by
   polygenic risk score for Alzheimer's disease (AD) excluding
   apolipoprotein E (APOE) genotype ({''}non-APOE PRS{''}). Participants
   with high non-APOE PRS showed cognitive benefit (all-cause dementia: aRD
   -5.9 parts per thousand, 95\% CI: -8.1 parts per thousand to 1.2 parts
   per thousand; AD: aRD -5.0 parts per thousand, 95\% CI: -8.2 parts per
   thousand to -0.2 parts per thousand). DISCUSSION Participants with high
   non-APOE PRS may benefit from statins, suggesting genetic susceptibility
   beyond APOE could modify statins' cognitive effects.},
Type = {Article},
Affiliation = {Xu, Y (Corresponding Author), Peking Univ, Hlth Sci Ctr, Sch Pharmaceut Sci, Dept Pharm Adm \& Clin Pharm, 38 Xueyuan Rd, Beijing 100191, Peoples R China.
