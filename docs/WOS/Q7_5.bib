@article{ WOS:001462773600001,
Author = {Wang, Tiansheng and Pate, Virginia and Wyss, Richard and Buse, John B.
   and Kosorok, Michael R. and Sturmer, Til},
Title = {High-dimensional iterative causal forest (hdiCF) for subgroup
   identification using health care claims data},
Journal = {AMERICAN JOURNAL OF EPIDEMIOLOGY},
Year = {2025},
Volume = {194},
Number = {7},
Pages = {2085-2097},
Month = {JUL},
Abstract = {We recently developed a machine learning subgrouping algorithm,
   iterative causal forest (iCF), to identify subgroups with heterogeneous
   treatment effects (HTEs) using predefined covariates. However, such
   predefined covariates may miss or poorly define important features,
   leading to inaccurate subgrouping. To address such limitations, we
   developed a new semiautomatic subgrouping algorithm, hdiCF, which adapts
   methodology from the high-dimensional propensity score for feature
   recognition in claims data. The hdiCF algorithm has 3 steps: (1)
   high-dimensional feature identification by International Classification
   of Diseases, Current Procedural Terminology, and Anatomical Therapeutic
   Chemical codes (in/outpatient diagnoses, procedures, prescriptions) and
   creation of ordinal variables by frequency of occurrence; (2) propensity
   score trimming and high-dimensional feature preparation; and (3) iCF
   implementation to identify subgroups. We applied hdiCF in a 20\% random
   sample of fee-for-service Medicare beneficiaries who initiated
   sodium-glucose cotransporter 2 inhibitors (SGLT2i) or glucagon-like
   peptide 1 receptor agonists to identify subgroups with HTEs for
   incidence of hospitalized heart failure. HdiCF findings were consistent
   with studies suggesting SGLT2i to be more beneficial for patients with
   preexisting heart failure or chronic kidney disease. HdiCF is not
   dependent on prior hypotheses about HTEs and identifies subgroups with
   markers for potential HTEs in real-world evidence studies where
   active-comparator, new-user study designs limit the potential for
   unmeasured confounding.},
Type = {Article},
Affiliation = {Wang, TS (Corresponding Author), 2101-B McGavran Greenberg Hall CB, Chapel Hill, NC 27516 USA.
   Wang, Tiansheng; Pate, Virginia; Sturmer, Til, Univ North Carolina Chapel Hill, Gillings Sch Global Publ Hlth, Dept Epidemiol, Chapel Hill, NC 27599 USA.
   Wyss, Richard, Brigham \& Womens Hosp, Dept Med, Div Pharmacoepidemiol \& Pharmacoecon, Boston, MA 02120 USA.
   Buse, John B., Univ North Carolina Chapel Hill, Sch Med, Dept Med, Chapel Hill, NC 27599 USA.
   Kosorok, Michael R., Univ North Carolina Chapel Hill, Gillings Sch Global Publ Hlth, Dept Biostat, Chapel Hill, NC 27599 USA.},
DOI = {10.1093/aje/kwae322},
EarlyAccessDate = {APR 2024},
Keywords = {iterative causal forest; high-dimensional; causal machine learning;
   claims data; subgroup identification; heterogeneous treatment effect;
   pharmacoepidemiology; precision medicine},
Keywords-Plus = {CARDIOVASCULAR OUTCOMES; HEART-FAILURE; EMPAGLIFLOZIN},
Author-Email = {tianwang@unc.edu
