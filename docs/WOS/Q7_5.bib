Keywords = {Qinghai-Tibet Plateau; ecosystem services; causal inference; ecological
   restoration; interpretative machine learning; sand fixation; adaptive
   management},
Keywords-Plus = {CARBON; CHINA},
Author-Email = {11230853@stu.lzjtu.edu.cn
   daief@igsnrr.ac.cn
   xingshuo0650@igsnrr.ac.cn
