DOI = {10.1007/s10797-025-09925-5},
EarlyAccessDate = {NOV 2025},
Keywords = {Optimal tax administration; Enforcement elasticity of tax revenue;
   Machine learning; Operational audits; H21; H30; C54; C55},
Author-Email = {daniele.spinelli@unimib.it
