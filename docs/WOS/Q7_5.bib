@article{ WOS:000889680400001,
Author = {Langworthy, Benjamin and Wu, Yujie and Wang, Molin},
Title = {An overview of propensity score matching methods for clustered data},
Journal = {STATISTICAL METHODS IN MEDICAL RESEARCH},
Year = {2023},
Volume = {32},
Number = {4},
Pages = {641-655},
Month = {APR},
Abstract = {Propensity score matching is commonly used in observational studies to
   control for confounding and estimate the causal effects of a treatment
   or exposure. Frequently, in observational studies data are clustered,
   which adds to the complexity of using propensity score techniques. In
   this article, we give an overview of propensity score matching methods
   for clustered data, and highlight how propensity score matching can be
   used to account for not just measured confounders, but also unmeasured
   cluster level confounders. We also consider using machine learning
   methods such as generalized boosted models to estimate the propensity
   score and show that accounting for clustering when using these methods
   can greatly reduce the performance, particularly when there are a large
   number of clusters and a small number of subjects per cluster. In order
   to get around this we highlight scenarios where it may be possible to
   control for measured covariates using propensity score matching, while
   using fixed effects regression in the outcome model to control for
   cluster level covariates. Using simulation studies we compare the
   performance of different propensity score matching methods for clustered
   data across a number of different settings. Finally, as an illustrative
   example we apply propensity score matching methods for clustered data to
   study the causal effect of aspirin on hearing deterioration using data
   from the conservation of hearing study.},
Type = {Article},
Affiliation = {Langworthy, B (Corresponding Author), Harvard Univ, TH Chan Sch Publ Hlth, Dept Epidemiol, 655 Huntington Ave, SPH2, 4th fl, Boston, MA 02115 USA.
   Langworthy, Benjamin; Wu, Yujie; Wang, Molin, Harvard TH Chan Sch Publ Hlth, Dept Biostat, Boston, MA USA.
   Langworthy, Benjamin; Wang, Molin, Harvard TH Chan Sch Publ Hlth, Dept Epidemiol, Boston, MA USA.
   Langworthy, Benjamin, Harvard Univ, TH Chan Sch Publ Hlth, Dept Epidemiol, 655 Huntington Ave, SPH2, 4th fl, Boston, MA 02115 USA.},
DOI = {10.1177/09622802221133556},
EarlyAccessDate = {NOV 2022},
Keywords = {Average treatment among the treated; clustered data; confounding;
   propensity score matching; propensity score estimation},
Keywords-Plus = {CAUSAL INFERENCE; BALANCE; REGRESSION; DESIGNS; SCHOOLS},
Author-Email = {blangworthy@hsph.harvard.edu},
Number-of-Cited-References = {42},
Times-Cited = {37},
Unique-ID = {WOS:000889680400001},
}

@article{ WOS:000743140600025,
Author = {Zhong, Yongqi and Kennedy, Edward H. and Bodnar, Lisa M. and Naimi, I,
   Ashley},
Title = {AIPW: An R Package for Augmented Inverse Probability-Weighted
   Estimation of Average Causal Effects},
Journal = {AMERICAN JOURNAL OF EPIDEMIOLOGY},
Year = {2021},
Volume = {190},
Number = {12},
Pages = {2690-2699},
Month = {DEC},
Abstract = {An increasing number of recent studies have suggested that doubly robust
   estimators with cross-fitting should be used when estimating causal
   effects with machine learning methods. However, not all existing
   programs that implement doubly robust estimators support machine
   learning methods and cross-fitting, or provide estimates on
   multiplicative scales. To address these needs, we developed AIPW, a
   software package implementing augmented inverse probability weighting
   (AIPW) estimation of average causal effects in R (R Foundation for
   Statistical Computing, Vienna, Austria). Key features of the AIPW
   package include cross-fitting and flexible covariate adjustment for
   observational studies and randomized controlled trials (RCTs). In this
   paper, we use a simulated RCT to illustrate implementation of the AIPW
   estimator. We also perform a simulation study to evaluate the
   performance of the AIPW package compared with other doubly robust
   implementations, including CausalGAM, npcausal, tmle, and tmle3. Our
   simulation showed that the AIPW package yields performance comparable to
   that of other programs. Furthermore, we also found that cross-fitting
   substantively decreases the bias and improves the confidence interval
   coverage for doubly robust estimators fitted with machine learning
   algorithms. Our findings suggest that the AIPW package can be a useful
   tool for estimating average causal effects with machine learning methods
   in RCTs and observational studies.},
Type = {Article},
Affiliation = {Naimi, AI (Corresponding Author), Emory Univ, Rollins Sch Publ Hlth, Dept Epidemiol, 1518 Clifton Rd, Atlanta, GA 30322 USA.
   Zhong, Yongqi; Bodnar, Lisa M., Univ Pittsburgh, Grad Sch Publ Hlth, Dept Epidemiol, Pittsburgh, PA 15260 USA.
   Kennedy, Edward H., Carnegie Mellon Univ, Dietrich Coll Humanities \& Social Sci, Dept Data Sci \& Stat, Pittsburgh, PA 15213 USA.
   Naimi, Ashley, I, Emory Univ, Rollins Sch Publ Hlth, Dept Epidemiol, 1518 Clifton Rd, Atlanta, GA 30322 USA.},
DOI = {10.1093/aje/kwab207},
EarlyAccessDate = {JUL 2021},
Keywords = {average causal effects; causal inference; doubly robust estimation;
   epidemiologic methods; machine learning; nonparametric statistics},
Keywords-Plus = {LOW-DOSE ASPIRIN; DOUBLY ROBUST ESTIMATION; INFERENCE; PREGNANCY;
   PRECISION; GESTATION; MODELS; TRIALS},
Author-Email = {ashley.naimi@emory.edu},
Number-of-Cited-References = {62},
Times-Cited = {37},
Unique-ID = {WOS:000743140600025},
}

@article{ WOS:000806859000004,
Author = {Zhang, Yingheng and Li, Haojie and Ren, Gang},
Title = {Estimating heterogeneous treatment effects in road safety analysis using
   generalized random forests},
Journal = {ACCIDENT ANALYSIS AND PREVENTION},
Year = {2022},
Volume = {165},
Month = {FEB},
Abstract = {Numerous evaluation studies have been conducted on a variety of road
   safety measures. However, the issue of treatment heterogeneity, defined
   as the variation in treatment effects, has rarely been investigated
   before. This paper contributes to the literature by introducing
   generalized random forests (GRF) for estimation of heterogeneous
   treatment effects (HTEs) in road safety analysis. GRF has high
   functional flexibility and is able to search for complex treatment
   heterogeneity. We first perform a series of simulation experiments to
   compare GRF with three causal methods that have been used in road safety
   studies, i.e., outcome regression method, propensity score method, and
   doubly robust estimation method. The simulation results suggest that GRF
   is superior to these three methods in terms of model specification,
   especially with the existence of nonlinearity and nonadditivity. On the
   other hand, a large dataset is required for accurate GRF estimation.
   Then we conduct a case study on the UK's speed camera program. Our
   results indicate significant reductions in the number of road accidents
   at speed camera sites. And the heterogeneity in treatment effects is
   found to be statistically significant. We further consider the
   associations between the baseline accident records, traffic volume,
   local socio-economic characteristics, and the safety effects of speed
   cameras. In general, the effect of speed cameras is larger at the sites
   with more baseline accident records, higher traffic volume, and in more
   densely-populated and deprived areas. Several policy suggestions are
   provided based on these findings. The evaluation of HTEs likely offers
   more comprehensive information to local authorities and policy makers,
   and improves the performance of speed camera programs. Moreover, GRF can
   be a promising approach for revealing treatment effect heterogeneity in
   road safety analysis.},
Type = {Article},
Affiliation = {Li, HJ (Corresponding Author), Southeast Univ, Sch Transportat, Nanjing, Peoples R China.
   Zhang, Yingheng; Li, Haojie; Ren, Gang, Southeast Univ, Sch Transportat, Nanjing, Peoples R China.
   Zhang, Yingheng; Li, Haojie; Ren, Gang, Jiangsu Key Lab Urban ITS, Nanjing, Peoples R China.
   Zhang, Yingheng; Li, Haojie; Ren, Gang, Jiangsu Prov Collaborat Innovat Ctr Modern, Urban Traff Technol, Nanjing, Peoples R China.},
DOI = {10.1016/j.aap.2021.106507},
Article-Number = {106507},
Keywords = {Heterogeneous treatment effects; Road safety evaluation; Speed
   enforcement cameras; Generalized random forest; Causal machine learning},
Keywords-Plus = {PROPENSITY SCORE METHODS; BAYES BEFORE-AFTER; SPEED ENFORCEMENT;
   EMPIRICAL BAYES; POTENTIAL OUTCOMES; CAMERAS; CASUALTIES; SELECTION;
   PROGRAMS; IMPACT},
Author-Email = {h.li@seu.edu.cn},
Number-of-Cited-References = {59},
