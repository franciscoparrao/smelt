}

@article{ WOS:001711171600004,
Author = {Scheidegger, Cyrill and Guo, Zijian and Buhlmann, Peter},
Title = {Inference for heterogeneous treatment effects with efficient instruments
   and machine learning},
Journal = {ELECTRONIC JOURNAL OF STATISTICS},
Year = {2026},
Volume = {20},
Number = {1},
Pages = {718-770},
Abstract = {We introduce a new instrumental variable (IV) estimator for
   heterogeneous treatment effects in the presence of endogeneity. Our
   estimator is based on double/debiased machine learning (DML) and uses
   efficient machine learning instruments (MLIV) and kernel smoothing. We
   prove consistency and asymptotic normality of our estimator and also
   construct confidence sets that are more robust towards weak IV. Along
   the way, we also provide an accessible discussion of the corresponding
   estimator for the homogeneous treatment effect with efficient machine
   learning instruments. The methods are evaluated on synthetic and real
   datasets and an implementation is made available in the R package IVDML.},
Type = {Article},
Affiliation = {Scheidegger, C (Corresponding Author), Swiss Fed Inst Technol, Seminar Stat, Zurich, Switzerland.
   Scheidegger, Cyrill; Buhlmann, Peter, Swiss Fed Inst Technol, Seminar Stat, Zurich, Switzerland.
   Guo, Zijian, Zhejiang Univ, Ctr Data Sci, Hangzhou, Peoples R China.},
DOI = {10.1214/26-EJS2498},
Keywords = {Heterogeneous treatment effect; double/debiased machine learn-ing;
   instrumental variables; endogeneity; partially linear model; kernel
   smoothing},
Keywords-Plus = {CAUSAL INFERENCE; COEFFICIENT; RATES; MODELS},
Author-Email = {cyrill.scheidegger@stat.math.ethz.ch
   zijguo@zju.edu.cn},
Number-of-Cited-References = {58},
Times-Cited = {0},
Unique-ID = {WOS:001711171600004},
