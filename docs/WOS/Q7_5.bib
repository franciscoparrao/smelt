@article{ WOS:001593752600001,
Author = {Hayakawa, Takashi and Asai, Satoshi},
Title = {Debiased Maximum Likelihood Estimators of Hazard Ratios Under
   Kernel-Based Machine Learning Adjustment},
Journal = {MATHEMATICS},
Year = {2025},
Volume = {13},
Number = {19},
Month = {SEP 26},
Abstract = {Previous studies have shown that hazard ratios between treatment groups
   estimated with the Cox model are uninterpretable because the unspecified
   baseline hazard of the model fails to identify temporal change in the
   risk-set composition due to treatment assignment and unobserved factors
   among multiple contradictory scenarios. To alleviate this problem,
   especially in studies based on observational data with uncontrolled
   dynamic treatment and real-time measurement of many covariates, we
   propose abandoning the baseline hazard and using kernel-based machine
   learning to explicitly model the change in the risk set with or without
   latent variables. For this framework, we clarify the context in which
   hazard ratios can be causally interpreted, then develop a method based
   on Neyman orthogonality to compute debiased maximum likelihood
   estimators of hazard ratios, proving necessary convergence results.
   Numerical simulations confirm that the proposed method identifies the
   true hazard ratios with minimal bias. These results lay the foundation
   for the development of a useful alternative method for causal inference
   with uncontrolled, observational data in modern epidemiology.},
Type = {Article},
Affiliation = {Hayakawa, T (Corresponding Author), Nihon Univ, Sch Med, Dept Biomed Sci, Div Pharmacol, 30-1 Oyaguchi Kami Machi,Itabashi Ku, Tokyo 1738610, Japan.
   Hayakawa, T (Corresponding Author), Nihon Univ, Sch Med, Clin Trials Res Ctr, Div Genom Epidemiol \& Clin Trials, 30-1 Oyaguchi Kami Machi,Itabashi Ku, Tokyo 1738610, Japan.
   Hayakawa, Takashi; Asai, Satoshi, Nihon Univ, Sch Med, Dept Biomed Sci, Div Pharmacol, 30-1 Oyaguchi Kami Machi,Itabashi Ku, Tokyo 1738610, Japan.
   Hayakawa, Takashi; Asai, Satoshi, Nihon Univ, Sch Med, Clin Trials Res Ctr, Div Genom Epidemiol \& Clin Trials, 30-1 Oyaguchi Kami Machi,Itabashi Ku, Tokyo 1738610, Japan.},
DOI = {10.3390/math13193092},
Article-Number = {3092},
Keywords = {survival analysis; hazard ratio; machine learning; causal inference;
   kernel method},
Keywords-Plus = {MARGINAL STRUCTURAL MODELS; HIDDEN MARKOV-MODELS; INFORMATION;
   INFERENCE; SURVIVAL; CONSISTENCY; SPARSITY},
Author-Email = {hayakawa.takashi@nihon-u.ac.jp},
