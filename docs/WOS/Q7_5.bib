DOI = {10.1007/s10255-020-0960-1},
Keywords = {causal effect; matching; machine learning},
Keywords-Plus = {PROPENSITY SCORE ESTIMATION; MATCHING ESTIMATORS; REMOVE BIAS;
   REGRESSION; SUBCLASSIFICATION; ADJUSTMENT},
Author-Email = {xweitong@bnu.edu.cn},
