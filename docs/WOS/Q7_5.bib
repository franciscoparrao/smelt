   Naghi, Andrea A., Queen Mary Univ London, Mile End Rd, London E1 4NS, England.},
DOI = {10.1093/ectj/utae004},
EarlyAccessDate = {MAR 2024},
Keywords = {Average treatment effects; causal inference; heterogeneous treatment
   effects; machine learning},
Keywords-Plus = {ECONOMETRICS; HETEROGENEITY},
Author-Email = {baiardi@ese.eur.nl
   a.naghi@qmul.ac.uk},
