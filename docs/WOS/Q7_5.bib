   Tjardes, Thorsten, Witten Herdecke Univ, Cologne Merheim Med Ctr, Dept Trauma Surg Orthoped Surg \& Sports Med, Cologne, Germany.},
DOI = {10.1097/MCC.0000000000001104},
Keywords = {algorithm; causal inference; decision support; machine learning; trauma},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; ALGORITHM; PREDICT; TOOL},
Author-Email = {tgauss@chu-grenoble.fr},
