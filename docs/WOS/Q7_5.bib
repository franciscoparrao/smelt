Keywords = {Causal Bayesian network; Probabilistic causal reasoning; Interventions
   recommendation; Real medical study; Elderly fall prevention},
Keywords-Plus = {BAYESIAN NETWORK STRUCTURES; TECHNOLOGIES},
Author-Email = {salma.chaieb2@yahoo.com
   brahim.hnich@fsm.rnu.tn},
