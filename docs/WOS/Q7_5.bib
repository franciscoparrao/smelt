   Hahn, Richard, Arizona State Univ, Sch Math \& Stat Sci, Tempe, AZ 85281 USA.
   Inoue, Kosuke, Kyoto Univ, Grad Sch Med, Dept Social Epidemiol, Kyoto 6068501, Japan.},
DOI = {10.1016/j.ssmmh.2025.100552},
