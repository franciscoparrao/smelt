   Zhou, Cheng, Jiangxi Univ Finance \& Econ, Sch Finance, Nanchang, Peoples R China.
   Xie, Junyu, Zhongnan Univ Econ \& Law, Sch Finance, Wuhan, Peoples R China.},
DOI = {10.1111/beer.12798},
EarlyAccessDate = {MAR 2025},
Keywords = {corporate social responsibility disclosure; cross-border e-commerce
