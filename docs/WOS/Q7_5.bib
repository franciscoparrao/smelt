   Liu, Chengkun, Macau Univ Sci \& Technol, Inst Sustainable Dev, Macau 999078, Peoples R China.},
DOI = {10.3390/math13223718},
Article-Number = {3718},
Keywords = {machine learning; green innovation; institutional investors; knowledge
   spillover externalities; environmental externalities},
Keywords-Plus = {CORPORATE GOVERNANCE; TRANSPARENCY; ENVIRONMENT; OWNERSHIP; FAILURES},
Author-Email = {3220000277@student.must.edu.mo
