   Zhao, Hongwei, Univ Utah, Div Occupat \& Environm Hlth, Salt Lake City, UT USA.},
DOI = {10.1080/10485252.2025.2544936},
EarlyAccessDate = {AUG 2025},
Keywords = {Doubly robust; influence curve; observational study; propensity score;
   target maximum likelihood estimator},
Keywords-Plus = {EFFICIENT SEMIPARAMETRIC ESTIMATION; DOUBLY ROBUST ESTIMATION;
   PROPENSITY SCORE; MULTIVALUED TREATMENTS; REGRESSION; STRATEGIES;
   OUTCOMES; BIAS},
Author-Email = {shschen@ucdavis.edu},
