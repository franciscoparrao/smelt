   Wu, Qingmei, Wuzhou Gongren Hosp, Wuzhou, Peoples R China.},
DOI = {10.3389/fmed.2026.1732164},
Article-Number = {1732164},
Keywords = {clinical decision support; deep learning; machine learning; multimodal
   data; prediction models; sepsis; translational medicine},
Keywords-Plus = {MACHINE LEARNING-MODEL; ARTIFICIAL-INTELLIGENCE; MORTALITY},
Author-Email = {qinlian@sr.gxmu.edu.cn
   junyulu@gxmu.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001698675200001},
}

@article{ WOS:001697370100001,
Author = {Chen, Yunzhu and Li, Tianyou},
Title = {Early metoprolol use in ICU patients with congestive heart failure is
   associated with increased 30-day mortality: a causal machine learning
   study},
Journal = {FRONTIERS IN PHARMACOLOGY},
Year = {2026},
Volume = {17},
Month = {FEB 9},
Abstract = {Background The risk-benefit balance of early metoprolol administration
   in critically ill patients with congestive heart failure (CHF) admitted
   to the intensive care unit (ICU) remains controversial. However,
   high-quality causality clinical evidence is still lacking. This study
   utilized real-world data and causal forest algorithm to investigate the
   average treatment effect (ATE) of early metoprolol use on 30-day
   mortality in ICU patients with CHF. We also explored the heterogeneity
   of individual treatment effects (ITE) to identify clinical
   characteristics across different treatment-effect populations. Method
   Study population and their clinical characteristics were obtained from
   the MIMIC-IV database (version 3.1). Propensity score matching (PSM) was
   performed to balance baseline confounders. Causal forest models
   estimated the ATE and ITE. Variable importance, conditional average
   treatment effect (CATE), and ITE-based quartile analysis were performed
   to identify heterogeneity and clinical characteristics of patients.
   Results A total of 5,758 patients were included in the initial cohort,
   with 3,934 patients entering the final analysis after PSM. The causal
   forest model indicated that early metoprolol use increased the risk of
   30-day ICU mortality by 2\% compared with no use group (ATE = 0.02, 95\%
   CI: 0.0004-0.0396, P = 0.045). APSIII, age, and SOFA were the top three
   variables contributing to the ATE. The causal forest model estimated the
   conditional average treatment effects for every variable. Individual
   treatment effects exhibited a right-skewed distribution. The highest ITE
   percentile was associated with APSIII >64, age >78 years, SOFA >8, WBC
   >13.95 \& times; 109/L, and BUN >43.06 mg/dL. Conclusion Early
   metoprolol use within 24 h of ICU admission in CHF patients is
   associated with increased 30-day mortality. Therapeutic effects were
   heterogeneous, with the adverse effects being particularly pronounced in
   patients with high APSIII, advanced age, elevated SOFA, high white blood
   cell counts, and elevated blood urea nitrogen levels. These findings
   suggest careful consideration should be given to the early use of
   metoprolol in high-risk patients.},
Type = {Article},
Affiliation = {Li, TY (Corresponding Author), Fourth Peoples Hosp Jinan, Jinan, Shandong, Peoples R China.
   Chen, Yunzhu, Zunyi Fourth Peoples Hosp, Zunyi, Guizhou, Peoples R China.
   Li, Tianyou, Fourth Peoples Hosp Jinan, Jinan, Shandong, Peoples R China.},
DOI = {10.3389/fphar.2026.1771969},
Article-Number = {1771969},
Keywords = {causal forest; causal machine learning; congestive heart failure;
   metoprolol; treatment heterogeneity},
Keywords-Plus = {BETA-BLOCKERS; AMERICAN; SCORE},
Author-Email = {youth\_lty@126.com},
Number-of-Cited-References = {38},
Times-Cited = {0},
Unique-ID = {WOS:001697370100001},
}

@article{ WOS:001688663300001,
Author = {Crudu, Petru},
Title = {Heterogeneous scars in later life: The economic impact of early labour
   market opportunities},
Journal = {LABOUR ECONOMICS},
Year = {2026},
Volume = {99},
Month = {APR},
Abstract = {I analyse the heterogeneous effects of labour market opportunities at
   education completion on end-of-career outcomes. I use data on European
   individuals who completed education between 1963 and 1982, observing
   their outcomes beyond age 50. Using standard econometric models and
   machine learning, I find that poor initial opportunities have lasting
   effects. Economic downturns have a non-linear impact: missing good
   opportunities harms more than avoiding bad ones. Effects are stronger
   for less-educated and low socioeconomic individuals. Women face
   permanent reductions in labour market participation. I examine
   explanatory channels over the lifecycle, showing how initial
   opportunities shape human capital trajectories.},
Type = {Article},
Affiliation = {Crudu, P (Corresponding Author), Univ Innsbruck, Innsbruck, Austria.
   Crudu, Petru, Univ Innsbruck, Innsbruck, Austria.
