   Taniguchi, Leandro U., Univ Sao Paulo, Intens Care Unit, Emergency Med Discipline, Sao Paulo, Brazil.
   Taniguchi, Leandro U., Hosp Sirio Libanes, Res Inst, Sao Paulo, Brazil.},
DOI = {10.1016/j.bja.2019.02.026},
Keywords = {acute respiratory distress syndrome; Bayesian statistics; heterogeneity
