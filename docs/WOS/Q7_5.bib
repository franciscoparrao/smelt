   Wang, Bangyu, HDR, Bellevue, WA USA.},
DOI = {10.1177/03611981251414092},
EarlyAccessDate = {JAN 2026},
Keywords = {safety evaluation; small sample size; generative adversarial network;
   causal inference; pre-right-turn stops; crash modification factor},
Keywords-Plus = {CRASH MODIFICATION FACTORS; BEFORE-AFTER; EMPIRICAL BAYES; SAFETY},
Author-Email = {wangxs@tongji.edu.cn},
