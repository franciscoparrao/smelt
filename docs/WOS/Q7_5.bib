DOI = {10.1186/s12874-024-02284-5},
Article-Number = {167},
Keywords = {Machine learning; Propensity score; Deep learning; Causal inference; C18},
Keywords-Plus = {REGRESSION; MISSPECIFICATION; ROBUSTNESS; MORTALITY; BALANCE; CARE},
Author-Email = {ehsan.karim@ubc.ca},
