@article{ WOS:001619167600001,
Author = {Zarbipour, Pouya and Akbari, Hassan and Nikoo, Mohammad Reza},
Title = {Quantum machine learning for wave overtopping estimation: Integrating
   with causal inference and uncertainty quantification},
Journal = {OCEAN ENGINEERING},
Year = {2026},
Volume = {343},
Number = {4},
Month = {JAN 15},
Abstract = {This study presents a robust Quantum Support Vector Machine (QSVM) model
   for predicting mean wave overtopping discharge in coastal structures,
   leveraging the comprehensive CLASH dataset to achieve high predictive
   accuracy (R-2 = 0.972, RMSE = 1.09 x 10(-3) m(3)/s/m, CC = 0.986).
   Uncertainty quantification via bootstrapping provides 95 \% confidence
   intervals, ensuring reliable predictions for engineering applications.
   The model integrates quantum-enhanced feature mapping with advanced
   interpretability tools, including SHAP, Sobol sensitivity analysis, and
   partial dependence plots, to elucidate the dominant roles of spectral
   significant wave height (H-m0), crest freeboard (R-c), water depth over
   berm (h(b)), structure surface roughness factor (gamma(f)) and spectral
   wave period at toe (T-m-1,T-0,T- toe) in driving overtopping discharge.
   Causal inference frameworks, namely Linear Double Machine Learning and
   Causal Forest DML, reveal heterogeneous treatment effects modulated by
   R-c, highlighting non-linear interactions critical to coastal design.
   While H-m0 has the most influence on overtopping discharge, the results
   suggest using high freeboards (R-c/H-m0>1.5) to reduce design
   uncertainties. A meticulous comparison with prior literature, including
   empirical (EurOtop, 2018) and machine learning models (ANN, XGBoost,
   GRNN), underscores QSVM's superior performance in handling non-linear
   complexities due to scaling and data variabilities. These findings
   position QSVM as a transformative tool for coastal engineering, offering
   enhanced accuracy and generalizability while paving the way for future
   research into scalable quantum algorithms to address complex
   environmental challenges such as sea-level rise and storm surges.},
Type = {Article},
Affiliation = {Akbari, H (Corresponding Author), Tarbiat Modares Univ, Dept Civil \& Environm Engn, Tehran, Iran.
   Zarbipour, Pouya; Akbari, Hassan, Tarbiat Modares Univ, Dept Civil \& Environm Engn, Tehran, Iran.
   Nikoo, Mohammad Reza, Sultan Qaboos Univ, Dept Civil \& Architectural Engn, Muscat, Oman.},
DOI = {10.1016/j.oceaneng.2025.123482},
EarlyAccessDate = {NOV 2025},
Article-Number = {123482},
Keywords = {Quantum machine learning (QML); Coastal structures; CLASH database;
   Uncertainty quantification; Causal forest DML; Overtopping},
Keywords-Plus = {SUPPORT VECTOR MACHINE; PREDICTION; MODEL; EXTREME},
