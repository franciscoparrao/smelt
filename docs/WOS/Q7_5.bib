   Wang, Donggen, Hong Kong Baptist Univ, Dept Geog, Kowloon Tong, Kowloon, Hong Kong, Peoples R China.},
DOI = {10.1016/j.tbs.2024.100852},
EarlyAccessDate = {JUL 2024},
Article-Number = {100852},
Keywords = {Causal inference; Difference-in-differences; Machine learning; Travel
