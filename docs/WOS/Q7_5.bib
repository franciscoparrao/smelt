@article{ WOS:001602604800018,
Author = {Abecassis, Judith and Dumas, Elise and Alberge, Julie and Varoquaux,
   Gael},
Title = {From Prediction to Prescription: Machine Learning and Causal Inference
   for the Heterogeneous Treatment Effect},
Journal = {ANNUAL REVIEW OF BIOMEDICAL DATA SCIENCE},
Year = {2025},
Volume = {8},
Pages = {381-404},
Abstract = {The increasing accumulation of medical data brings the hope of
   data-driven medical decision-making, but data's increasing complexity-as
   text or images in electronic health records-calls for complex models,
   such as machine learning. Here, we review how machine learning can be
   used to inform decisions for individualized interventions, a causal
   question. Going from prediction to causal effects is challenging, as no
   individual is seen as both treated and not. We detail how some data can
   support some causal claims and how to build causal estimators with
   machine learning. Beyond variable selection to adjust for confounding
   bias, we cover the broader notions of study design that make or break
   causal inference. As the problems span across diverse scientific
   communities, we use didactic yet statistically precise formulations to
   bridge machine learning to epidemiology.},
Type = {Article},
Affiliation = {Abécassis, J (Corresponding Author), Inria Saclay, Soda, Palaiseau, France.
   Abecassis, Judith; Alberge, Julie; Varoquaux, Gael, Inria Saclay, Soda, Palaiseau, France.
   Dumas, Elise, Ecole Polytech Fed Lausanne, Inst Math, Lausanne, Switzerland.
   Varoquaux, Gael, Probabl Ai, Paris, France.},
DOI = {10.1146/annurev-biodatasci-103123-095750},
Keywords = {personalized medicine; data-driven decision-making; large-scale data;
   causal inference; machine learning},
Keywords-Plus = {REAL-WORLD EVIDENCE; SENSITIVITY-ANALYSIS; PROPENSITY SCORE; MEASUREMENT
   ERROR; TRIAL EMULATION; LUNG-CANCER; BIAS; VALIDITY; OVERLAP; SURGERY},
Author-Email = {judith.abecassis@inria.fr
   elise.dumas@epfl.ch
   judith.abecassis@inria.fr
   gael.varoquaux@inria.fr},
Number-of-Cited-References = {129},
