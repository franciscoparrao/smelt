Pages = {77-81},
Month = {FEB},
Abstract = {This is a contribution to the discussion of the paper by Dorie et al.
   (Statist. Sci. 34 (2019) 43-68), which reports the lessons learned from
   2016 Atlantic Causal Inference Conference Competition. My comments
   strongly support the authors' focus on empirical evaluation, using
