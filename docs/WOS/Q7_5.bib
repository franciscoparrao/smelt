Keywords-Plus = {BUILT ENVIRONMENT; SELF-SELECTION; POTENTIAL OUTCOMES; NEIGHBORHOOD
   TYPE; PROPENSITY SCORE; ESTIMATOR; ATTITUDES; MODELS},
