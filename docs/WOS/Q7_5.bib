   Degha, Houssem Eddine, Kasdi Merbah Ouargla Univ, Fac New Technol Informat \& Commun, Dept Comp Sci \& Informat Technol, Ouargla, Algeria.
   Teiba, Islam I., Tanta Univ, Fac Agr, Dept Bot, Tanta, Egypt.
   Mahmoud, Seedahmed S., Shantou Univ, Coll Engn, Dept Biomed Engn, Shantou, Peoples R China.},
DOI = {10.3389/fmicb.2025.1691503},
