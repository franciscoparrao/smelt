@article{ WOS:001681213500001,
Author = {Gutierrez, Juan David and Tapias-Rivera, Johanna and Hijuelos-Cardenas,
   Martha Liliana and Montano-Villalba, Ludivia Esther},
Title = {Effect of sea surface temperature in El Niño regions on dengue dynamics
   in Colombia: Evidence from causal machine learning},
Journal = {PLOS GLOBAL PUBLIC HEALTH},
Year = {2026},
Volume = {6},
Number = {1},
Month = {JAN 23},
Abstract = {Dengue fever is among the most rapidly expanding vector-borne diseases
   globally, with Colombia ranking among the most affected countries in the
   Americas. Although previous research has linked climate variability and
   El Ni \& ntilde;o-Southern Oscillation (ENSO) episodes to dengue
   dynamics, the direct causal effect of sea surface temperature (SST) in
   El Ni \& ntilde;o regions remains insufficiently explored. We conducted
   a retrospective ecological analysis using monthly laboratory-confirmed
   dengue cases from 1,044 Colombian municipalities (2013-2023), combined
   with atmospheric, oceanic, and socioeconomic data. We emulated an
   experimental design to estimate the effect of SST in El Ni \& ntilde;o
   regions 1-2, 3, 3-4, and 4 on excess dengue cases. Confounder adjustment
   was guided by a Directed Acyclic Graph (DAG), and causal effects were
   estimated using Double Machine Learning (DML) with XGBoost learners. We
   estimated the Average Treatment Effect (ATE) and the Conditional Average
   Treatment Effect (CATE) conditioned on altitude. Robustness was
   evaluated with refutation tests introducing random confounders, subset
   replacement, and placebo exposures. A total of 455,329 confirmed dengue
   cases were reported during the study period, peaking in 2023. The
   strongest association was observed for El Ni \& ntilde;o region 3, where
   a standard deviation increase in SST (1.24 degrees C) raised the
   probability of excess dengue cases by 6.9 percentage points (ATE =
   0.069, 95\% CI = 0.056 - 0.083). El Ni \& ntilde;o regions 3-4 and 4
   showed slightly weaker ATE yet significant effects (6.4\% and 6.2\%),
   while El Ni \& ntilde;o region 1-2 had the lowest effect (4.6\%). The
   CATE analysis revealed that the effects of El Ni \& ntilde;o regions 1-2
   and 3 were stronger at higher altitudes; meanwhile, for El Ni \&
   ntilde;o regions 3-4 and 4, the effects showed a slightly negative
   trend, suggesting a heterogeneous effect of El Ni \& ntilde;o regions on
   dengue incidence in Colombia based on altitude. Robustness checks
   indicated the presence of residual bias, particularly when applying the
   subset replacement test. These findings highlight the importance of
   integrating oceanic monitoring into early warning systems of the disease
   and tailoring vector-control strategies to local ecological contexts.},
Type = {Article},
Affiliation = {Gutiérrez, JD (Corresponding Author), Univ Santander, Fac Ciencias Med \& Salud, Inst Masira, Bucaramanga, Santander, Colombia.
   Gutierrez, Juan David; Tapias-Rivera, Johanna; Hijuelos-Cardenas, Martha Liliana; Montano-Villalba, Ludivia Esther, Univ Santander, Fac Ciencias Med \& Salud, Inst Masira, Bucaramanga, Santander, Colombia.},
DOI = {10.1371/journal.pgph.0005796},
Article-Number = {e0005796},
Keywords-Plus = {EPIDEMICS; CLIMATE; OSCILLATION; AMERICA; BURDEN; SYSTEM; FEVER},
Author-Email = {jdgutierrez@mail.udes.edu.co},
Number-of-Cited-References = {70},
Times-Cited = {0},
Unique-ID = {WOS:001681213500001},
}

@article{ WOS:001695888300001,
Author = {Knowlton, Rebecca and Parast, Layla},
Title = {Assessing surrogate heterogeneity in real world data using meta-learners},
Journal = {JOURNAL OF CAUSAL INFERENCE},
Year = {2026},
Volume = {14},
Number = {1},
Month = {JAN 23},
Abstract = {Surrogate markers are most commonly studied within the context of
   randomized clinical trials. However, the need for alternative outcomes
   also extends to real-world public health and social science research,
   where randomized trials are often impractical. While standard methods
   for evaluating surrogate markers largely rely on the assumption of
   randomized treatment, there is a significant gap in applying these
   techniques to observational data, where the central challenge shifts to
   managing confounding. The few methods that do allow for non-randomized
   treatment/exposure do not offer a way to examine surrogate heterogeneity
   with respect to patient characteristics. In this paper, we propose a
   framework to assess surrogate heterogeneity in non-randomized data and
   implement this framework using meta-learners. Our approach allows us to
   quantify heterogeneity in surrogate strength with respect to patient
   characteristics while accommodating confounders through the use of
   flexible, off-the-shelf machine learning methods. In addition, we use
   our framework to identify covariate profiles where the surrogate is a
   valid replacement of the primary outcome. We examine the performance of
   our methods via a simulation study and application to examine
   heterogeneity in the surrogacy of hemoglobin A1c as a surrogate for
   fasting plasma glucose.},
Type = {Article},
Affiliation = {Parast, L (Corresponding Author), Univ Texas Austin, Dept Stat \& Data Sci, Austin, TX 78712 USA.
   Knowlton, Rebecca; Parast, Layla, Univ Texas Austin, Dept Stat \& Data Sci, Austin, TX 78712 USA.},
DOI = {10.1515/jci-2025-0033},
Article-Number = {20250033},
Keywords = {surrogate markers; heterogeneity; observational data; meta-learners;
   treatment effect},
Keywords-Plus = {SMOOTHING PARAMETER-ESTIMATION; PROPORTION; GLUCOSE; RISK},
Author-Email = {parast@austin.utexas.edu},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001695888300001},
}

@article{ WOS:001700635000001,
Author = {Shen, Youxie and Zhang, Peidong and Luo, Jialiu and Chen, Shunyao and
   Gu, Shuaipeng and Lin, Zhiqiang and Tang, Zhaohui},
Title = {Artificial Intelligence Drives Advances in Multi-Omics Analysis and
   Precision Medicine for Sepsis},
Journal = {BIOMEDICINES},
Year = {2026},
Volume = {14},
Number = {2},
Month = {JAN 23},
Abstract = {Sepsis is a life-threatening syndrome characterized by marked clinical
   heterogeneity and complex host-pathogen interactions. Although
   traditional mechanistic studies have identified key molecular pathways,
   they remain insufficient to capture the highly dynamic, multifactorial,
   and systems-level nature of this condition. The advent of
   high-throughput omics technologies-particularly integrative multi-omics
   approaches encompassing genomics, transcriptomics, proteomics, and
   metabolomics-has profoundly reshaped sepsis research by enabling
   comprehensive profiling of molecular perturbations across biological
   layers. However, the unprecedented scale, dimensionality, and
   heterogeneity of multi-omics datasets exceed the analytical capacity of
   conventional statistical methods, necessitating more advanced
   computational strategies to derive biologically meaningful and
   clinically actionable insights. In this context, artificial intelligence
   (AI) has emerged as a powerful paradigm for decoding the complexity of
   sepsis. By leveraging machine learning and deep learning algorithms, AI
   can efficiently process ultra-high-dimensional and heterogeneous
   multi-omics data, uncover latent molecular patterns, and integrate
   multilayered biological information into unified predictive frameworks.
   These capabilities have driven substantial advances in early sepsis
   detection, molecular subtyping, prognosis prediction, and therapeutic
   target identification, thereby narrowing the gap between molecular
   mechanisms and clinical application. As a result, the convergence of AI
   and multi-omics is redefining sepsis research, shifting the field from
   descriptive analyses toward predictive, mechanistic, and
   precision-oriented medicine. Despite these advances, the clinical
   translation of AI-driven multi-omics approaches in sepsis remains
   constrained by several challenges, including limited data availability,
   cohort heterogeneity, restricted interpretability and causal inference,
   high computational demands, difficulties in integrating static molecular
   profiles with dynamic clinical data, ethical and governance concerns,
   and limited generalizability across populations and platforms.
   Addressing these barriers will require the establishment of
   standardized, multicenter datasets, the development of explainable and
   robust AI frameworks, and sustained interdisciplinary collaboration
   between computational scientists and clinicians. Through these efforts,
   AI-enabled multi-omics research may progress toward reproducible,
   interpretable, and equitable clinical implementation. Ultimately, the
   synergy between artificial intelligence and multi-omics heralds a new
   era of intelligent discovery and precision medicine in sepsis, with the
   potential to transform both research paradigms and bedside practice.},
Type = {Review},
Affiliation = {Lin, ZQ; Tang, ZH (Corresponding Author), Huazhong Univ Sci \& Technol, Tongji Med Coll, Tongji Trauma Ctr, Tongji Hosp,Dept Trauma Surg Emergency Surg \& Surg, Wuhan 430030, Peoples R China.
   Shen, Youxie; Zhang, Peidong; Luo, Jialiu; Chen, Shunyao; Gu, Shuaipeng; Lin, Zhiqiang; Tang, Zhaohui, Huazhong Univ Sci \& Technol, Tongji Med Coll, Tongji Trauma Ctr, Tongji Hosp,Dept Trauma Surg Emergency Surg \& Surg, Wuhan 430030, Peoples R China.},
DOI = {10.3390/biomedicines14020261},
Article-Number = {261},
Keywords = {sepsis; artificial intelligence; machine learning; multi-omics;
   precision medicine},
Keywords-Plus = {DEFINITIONS; PROTEOMICS; MORTALITY},
Author-Email = {shenyouxie@hust.edu.cn
   linzhiqiang@hust.edu.cn
   tangzh@tjh.tjmu.edu.cn},
Number-of-Cited-References = {101},
Times-Cited = {0},
Unique-ID = {WOS:001700635000001},
}

@article{ WOS:001665747000001,
Author = {Zhang, Jielu and Mu, Lan and Mai, Gengchen and Grundstein, Andrew and
   Zhou, Zhongliang and Zhang, Donglan},
Title = {SpatialCausal: a spatially-aware causal inference deep learning
   model for out-of-hospital cardiac arrest survival prediction},
Journal = {INTERNATIONAL JOURNAL OF GEOGRAPHICAL INFORMATION SCIENCE},
Year = {2026},
Month = {2026 JAN 19},
Abstract = {Recently, numerous machine learning methods have been effectively
   applied to uncover spatial relationships between health risk factors and
   health outcomes. However, traditional machine learning methods often
   fail to address confounding bias, which arises when a common factor
   simultaneously influences both the treatment and the outcome - a
   challenge frequently encountered in observational studies. Deep
   learning-based causal inference models seek to mitigate confounding bias
   by learning balanced representations of covariates between treated and
   control groups, thereby reducing the dependence of treatment assignment
   on covariates. This enables accurate estimation of causal effects on
   health outcomes. Moreover, distinct geospatial patterns of risk exposure
   and health outcomes are common in many chronic diseases. Therefore,
   developing a spatially-aware causal inference model is essential for
   guiding geospatial health interventions. Here, we propose SpatialCausal,
   a spatially-aware deep learning-based causal inference model that
   explicitly integrates spatial, non-spatial, and unmeasured confounders,
   enabling accurate estimation of spatially-aware causal effects. We
   demonstrate the effectiveness of our approach through an application to
   Out-of-Hospital Cardiac Arrest survival outcome prediction. Our method
   surpasses state-of-the-art approaches and exhibits robust adaptability
   to various geospatial disease scenarios, making it a valuable tool for
   spatially-aware causal effect estimation in health geography.},
Type = {Article; Early Access},
Affiliation = {Mu, L (Corresponding Author), Univ Georgia, Geog Dept, Athens, GA 30602 USA.
   Zhang, Jielu; Mu, Lan; Grundstein, Andrew, Univ Georgia, Geog Dept, Athens, GA 30602 USA.
   Zhang, Jielu, Harvard Univ, Ctr Geog Anal, Cambridge, MA USA.
   Mai, Gengchen, Univ Texas Austin, Dept Geog \& Environm, Austin, TX USA.
   Zhou, Zhongliang, Merck \& Co Inc, Biometr Res, Rahway, NJ USA.
   Zhang, Donglan, NYU, Grossman Long Isl Sch Med, Ctr Populat \& Hlth Serv Res, Dept Fdn Med, Mineola, NY USA.},
DOI = {10.1080/13658816.2025.2611981},
EarlyAccessDate = {JAN 2026},
Keywords = {Spatially-aware causal inference; causal effect; treatment effect; deep
   learning; out-of-hospital cardiac arrest survival outcome},
Author-Email = {mulan@uga.edu},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001665747000001},
}

@article{ WOS:001674163900001,
Author = {Huo, Xiaoqian and Xing, Hui},
Title = {New-type urbanization and corporate carbon performance: Evidence from
   double machine learning model},
Journal = {SUSTAINABLE FUTURES},
Year = {2026},
Volume = {11},
Month = {JUN},
Abstract = {Enterprises are the primary source of carbon emissions, and enhancing
   corporate carbon performance is crucial for achieving sustainable
   development. With the coordinated development of economy, society, and
   environment as the primary goal, new-type urbanization provides a
   significant impetus for improving corporate carbon performance. This
   study first delineates the policy background of new-type urbanization,
   and then theoretically analyzes its impact and mechanisms on corporate
   carbon performance based on the essential characteristics of new-type
   urbanization and the driving factors of corporate carbon performance.
   Finally, using data from Chinese A-share listed companies from 2011 to
   2022 and a double machine learning model to empirically investigate the
   impact, mechanism, and heterogeneous effect of new-type urbanization on
   corporate carbon performance. The results indicate that new-type
   urbanization significantly improves corporate carbon performance, which
   is attributed to strengthened environmental regulation, enhanced public
   environmental concern, and the promotion of corporate digital
   transformation and green technology innovation. Heterogeneity analysis
   reveals that the positive effect of new-type urbanization on corporate
   carbon performance is more pronounced in enterprises located in cities
   with higher economic development levels and non-resource-based cities,
   for enterprises facing fierce market competition, state-owned
   enterprises, heavily polluting enterprises, high-tech enterprises, and
   enterprises with low financing constraints. This study provides
   micro-level evidence of the carbon reduction effect of new-type
   urbanization and offers important policy implications for improving
   corporate carbon performance.},
Type = {Article},
Affiliation = {Huo, XQ (Corresponding Author), 8 Guangrong Rd, Tianjin 300130, Peoples R China.
   Huo, Xiaoqian; Xing, Hui, Hebei Univ Technol, Sch Econ \& Management, Tianjin, Peoples R China.},
