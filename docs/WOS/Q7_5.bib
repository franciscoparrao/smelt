@article{ WOS:000782915600003,
Author = {Kim, Yeji and Choi, Taehwa and Choi, Sangbum},
Title = {Exploring modern machine learning methods to improve causal-effect
   estimation},
Journal = {COMMUNICATIONS FOR STATISTICAL APPLICATIONS AND METHODS},
Year = {2022},
Volume = {29},
Number = {2},
Pages = {177-191},
Month = {MAR},
Abstract = {This paper addresses the use of machine learning methods for causal
   estimation of treatment effects from observational data. Even though
   conducting randomized experimental trials is a gold standard to reveal
   potential causal relationships, observational study is another rich
   source for investigation of exposure effects, for example, in the
   research of comparative effectiveness and safety of treatments, where
   the causal effect can be identified if covariates contain all
   confounding variables. In this context, statistical regression models
   for the expected outcome and the probability of treatment are often
   imposed, which can be combined in a clever way to yield more efficient
   and robust causal estimators. Recently, targeted maximum likelihood
   estimation and causal random forest is proposed and extensively studied
   for the use of data-adaptive regression in estimation of causal
   inference parameters. Machine learning methods are a natural choice in
   these settings to improve the quality of the final estimate of the
   treatment effect. We explore how we can adapt the design and training of
   several machine learning algorithms for causal inference and study their
   finite-sample performance through simulation experiments under various
   scenarios. Application to the percutaneous coronary intervention (PCI)
   data shows that these adaptations can improve simple linear
   regression-based methods.},
Type = {Article},
Affiliation = {Choi, S (Corresponding Author), Korea Univ, Dept Stat, 145 Anam Ro, Seoul 02841, South Korea.
   Kim, Yeji; Choi, Taehwa; Choi, Sangbum, Korea Univ, Dept Stat, 145 Anam Ro, Seoul 02841, South Korea.},
DOI = {10.29220/CSAM.2022.29.2.177},
Keywords = {average causal effect; doubly-robust estimation; inverse probability
   weighting; propensity score; random forest; targeted learning},
Keywords-Plus = {PROPENSITY SCORE; INFERENCE},
Author-Email = {choisang@korea.ac.kr},
Number-of-Cited-References = {24},
Times-Cited = {1},
Unique-ID = {WOS:000782915600003},
}

@incollection{ WOS:000870706300049,
Author = {Cao, Yiwen and Yu, Kui and Huang, Xiaoling and Wang, Yujie},
Editor = {Gama, J and Li, T and Yu, Y and Chen, E and Zheng, Y and Teng, F},
Title = {A New Skeleton-Neural DAG Learning Approach},
Booktitle = {ADVANCES IN KNOWLEDGE DISCOVERY AND DATA MINING, PAKDD 2022, PT I},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2022},
Volume = {13280},
Pages = {626-638},
Abstract = {Learning a Directed Acyclic Graph (DAG) structure from observational
   data plays an essential role in causal inference and machine learning. A
   recent advance in the area is that the DAG learning problem was
   formulated as a continuous optimization problem and this provides a new
   research line for leveraging powerful neural networks for DAG learning.
   Although several DAG learning algorithms using neural networks (called
   neural DAG learning) have been proposed, they still face some serious
   challenges, leading to unsatisfactory performance. To tackle this issue,
   in this paper, we combine ideas from local DAG learning and neural DAG
   learning techniques and propose a new Skeleton-Neural DAG (SN-DAG)
   structure learning algorithm. The SN-DAG algorithm first learns the
   structure skeleton of each variable using a local learning algorithm to
   initialize the weighted adjacency matrix, then employ multilayer
   perceptrons to optimize the weighted adjacency matrix for learning a DAG
   structure, and finally it corrects wrong edges in the learnt DAG using
   the learnt skeleton and v-structure identifying techniques. By
   conducting experiments on both synthetic and real datasets, experimental
   results validate the SN-DAG algorithm compared to traditional DAG
   learning algorithms and neural DAG learning methods.},
Type = {Proceedings Paper},
Affiliation = {Yu, K (Corresponding Author), Hefei Univ Technol, Hefei 230601, Peoples R China.
   Cao, Yiwen; Yu, Kui; Huang, Xiaoling; Wang, Yujie, Hefei Univ Technol, Hefei 230601, Peoples R China.
   Huang, Xiaoling, Chuzhou Univ, Chuzhou 239000, Anhui, Peoples R China.},
DOI = {10.1007/978-3-031-05933-9\_49},
Keywords = {Directed acyclic graph; Neural DAG structure learning; Local structure
   learning},
Author-Email = {cyw@mail.hfut.edu.cn
   yukui@hfut.edu.cn
   hxl@chzu.edu.cn
   yujiewang@mail.hfut.edu.cn},
Number-of-Cited-References = {32},
