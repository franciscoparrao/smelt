@article{ WOS:000887306700001,
Author = {Hu, Liangyuan and Ji, Jiayi and Liu, Hao and Ennis, Ronald},
Title = {A Flexible Approach for Assessing Heterogeneity of Causal Treatment
   Effects on Patient Survival Using Large Datasets with Clustered
   Observations},
Journal = {INTERNATIONAL JOURNAL OF ENVIRONMENTAL RESEARCH AND PUBLIC HEALTH},
Year = {2022},
Volume = {19},
Number = {22},
Month = {NOV},
Abstract = {Personalized medicine requires an understanding of treatment effect
   heterogeneity. Evolving toward causal evidence for scenarios not studied
   in randomized trials necessitates a methodology using real-world
   evidence. Herein, we demonstrate a methodology that generates causal
   effects, assesses the heterogeneity of the effects and adjusts for the
   clustered nature of the data. This study uses a state-of-the-art machine
   learning survival model, riAFT-BART, to draw causal inferences about
   individual survival treatment effects, while accounting for the
   variability in institutional effects; further, it proposes a data-driven
   approach to agnostically (as opposed to a priori hypotheses) ascertain
   which subgroups exhibit an enhanced treatment effect from which
   intervention, relative to global evidence-average treatment effects
   measured at the population level. Comprehensive simulations show the
   advantages of the proposed method in terms of bias, efficiency and
   precision in estimating heterogeneous causal effects. The empirically
   validated method was then used to analyze the National Cancer Database.},
Type = {Article},
Affiliation = {Hu, LY (Corresponding Author), Rutgers State Univ, Dept Biostat \& Epidemiol, New Brunswick, NJ 07102 USA.
   Hu, Liangyuan; Ji, Jiayi; Liu, Hao, Rutgers State Univ, Dept Biostat \& Epidemiol, New Brunswick, NJ 07102 USA.
   Liu, Hao; Ennis, Ronald, Rutgers State Univ, Canc Inst New Jersey, New Brunswick, NJ 07102 USA.
   Ennis, Ronald, Rutgers State Univ, Robert Wood Johnson Med Sch, New Brunswick, NJ 07102 USA.},
DOI = {10.3390/ijerph192214903},
Article-Number = {14903},
Keywords = {causal inference; survival data analysis; machine learning; treatment
   effect heterogeneity; clustering},
Author-Email = {lh707@sph.rutgers.edu},
Number-of-Cited-References = {20},
Times-Cited = {3},
Unique-ID = {WOS:000887306700001},
}

@article{ WOS:000835914500001,
Author = {Xu, Yizhe and Greene, Tom H. and Bress, Adam P. and Bellows, Brandon K.
   and Zhang, Yue and Zhang, Zugui and Kolm, Paul and Weintraub, William S.
   and Moran, Andrew S. and Shen, Jincheng},
Title = {An efficient approach for optimizing the cost-effective individualized
   treatment rule using conditional random forest},
Journal = {STATISTICAL METHODS IN MEDICAL RESEARCH},
Year = {2022},
Volume = {31},
Number = {11},
Pages = {2122-2136},
Month = {NOV},
Abstract = {Evidence from observational studies has become increasingly important
   for supporting healthcare policy making via cost-effectiveness analyses.
   Similar as in comparative effectiveness studies, health economic
   evaluations that consider subject-level heterogeneity produce
   individualized treatment rules that are often more cost-effective than
   one-size-fits-all treatment. Thus, it is of great interest to develop
   statistical tools for learning such a cost-effective individualized
   treatment rule under the causal inference framework that allows proper
   handling of potential confounding and can be applied to both trials and
   observational studies. In this paper, we use the concept of
   net-monetary-benefit to assess the trade-off between health benefits and
   related costs. We estimate cost-effective individualized treatment rule
   as a function of patients' characteristics that, when implemented,
   optimizes the allocation of limited healthcare resources by maximizing
   health gains while minimizing treatment-related costs. We employ the
   conditional random forest approach and identify the optimal
   cost-effective individualized treatment rule using
   net-monetary-benefit-based classification algorithms, where two
   partitioned estimators are proposed for the subject-specific weights to
   effectively incorporate information from censored individuals. We
   conduct simulation studies to evaluate the performance of our proposals.
   We apply our top-performing algorithm to the NIH-funded Systolic Blood
   Pressure Intervention Trial to illustrate the cost-effectiveness gains
   of assigning customized intensive blood pressure therapy.},
Type = {Article},
Affiliation = {Shen, JC (Corresponding Author), Univ Utah, Dept Populat Hlth Sci, Salt Lake City, UT 84108 USA.
   Xu, Yizhe; Greene, Tom H.; Bress, Adam P.; Zhang, Yue; Shen, Jincheng, Univ Utah, Dept Populat Hlth Sci, Salt Lake City, UT 84108 USA.
   Bellows, Brandon K.; Moran, Andrew S., Columbia Univ Med Ctr, New York, NY USA.
   Zhang, Zugui, Christiana Care Hlth Syst, Newark, DE USA.
   Kolm, Paul; Weintraub, William S., MedStar Hlth Res Inst, Dept Med, Washington, DC USA.},
DOI = {10.1177/09622802221115876},
EarlyAccessDate = {AUG 2022},
Keywords = {Cost-effectiveness; conditional random forest; individualized treatment
   rule; net-monetary-benefit; partitioned estimator; weighted
   classification algorithm},
Keywords-Plus = {ESTIMATING MEDICAL COSTS; TREATMENT REGIMES; TASK-FORCE; FOLLOW-UP;
   TRIAL},
Author-Email = {jincheng.shen@hsc.utah.edu},
Number-of-Cited-References = {46},
Times-Cited = {3},
Unique-ID = {WOS:000835914500001},
}

@article{ WOS:000821059500001,
Author = {Agniel, Denis and Hejblum, Boris P. and Thiebaut, Rodolphe and Parast,
   Layla},
Title = {Doubly robust evaluation of high-dimensional surrogate markers},
Journal = {BIOSTATISTICS},
Year = {2023},
Volume = {24},
Number = {4},
Pages = {985-999},
Month = {OCT 18},
Abstract = {When evaluating the effectiveness of a treatment, policy, or
   intervention, the desired measure of efficacy may be expensive to
   collect, not routinely available, or may take a long time to occur. In
   these cases, it is sometimes possible to identify a surrogate outcome
   that can more easily, quickly, or cheaply capture the effect of
   interest. Theory and methods for evaluating the strength of surrogate
   markers have been well studied in the context of a single surrogate
   marker measured in the course of a randomized clinical study. However,
   methods are lacking for quantifying the utility of surrogate markers
   when the dimension of the surrogate grows. We propose a robust and
   efficient method for evaluating a set of surrogate markers that may be
   high-dimensional. Our method does not require treatment to be randomized
   and may be used in observational studies. Our approach draws on a
   connection between quantifying the utility of a surrogate marker and the
   most fundamental tools of causal inference-namely, methods for robust
   estimation of the average treatment effect. This connection facilitates
   the use of modern methods for estimating treatment effects, using
   machine learning to estimate nuisance functions and relaxing the
   dependence on model specification. We demonstrate that our proposed
   approach performs well, demonstrate connections between our approach and
   certain mediation effects, and illustrate it by evaluating whether gene
   expression can be used as a surrogate for immune activation in an Ebola
   study.},
Type = {Article},
Affiliation = {Agniel, D (Corresponding Author), RAND Corp, 1776 Main St, Santa Monica, CA 90401 USA.
   Agniel, Denis, RAND Corp, 1776 Main St, Santa Monica, CA 90401 USA.
   Hejblum, Boris P.; Thiebaut, Rodolphe, Univ Bordeaux, INSERM, INRIA, BPH,U1219,SISTM, F-33000 Bordeaux, France.
   Hejblum, Boris P.; Thiebaut, Rodolphe, Vaccine Res Inst, F-94000 Creteil, France.
   Thiebaut, Rodolphe, CHU Bordeaux, Serv Informat Med, F-33000 Bordeaux, France.
   Parast, Layla, Univ Texas Austin, Dept Stat \& Data Sci, 3925 West Braker Lane, Austin, TX 78759 USA.},
DOI = {10.1093/biostatistics/kxac020},
EarlyAccessDate = {JUL 2022},
Keywords = {Average treatment effect estimation; High-dimensional data; Surrogate
   marker evaluation},
Keywords-Plus = {END-POINTS; PROPORTION; INFERENCE; CORRELATE; VACCINES; LINKS},
Author-Email = {dagniel@rand.org},
Number-of-Cited-References = {48},
Times-Cited = {3},
Unique-ID = {WOS:000821059500001},
}

@article{ WOS:000728692100001,
Author = {Bertsimas, Dimitris and Borenstein, Alison Rose Ann and Dauvin, Antonin
   and Orfanoudaki, Agni},
Title = {Ensemble machine learning for personalized antihypertensive treatment},
Journal = {NAVAL RESEARCH LOGISTICS},
Year = {2022},
Volume = {69},
Number = {5},
Pages = {669-688},
Month = {AUG},
Abstract = {Due to its prevalence and association with cardiovascular diseases and
   premature death, hypertension is a major public health challenge. Proper
   prevention and management measures are needed to effectively reduce the
   pervasiveness of the condition. Current clinical guidelines for
   hypertension provide physicians with general suggestions for first-line
   pharmacologic treatment, but do not consider patient-specific
   characteristics. In this study, longitudinal electronic health record
   data are utilized to develop personalized predictions and prescription
   recommendations for hypertensive patients. We demonstrate that both
   binary classification and regression algorithms can be used to
   accurately predict a patient's future hypertensive status. We then
   present a prescriptive framework to determine the optimal
   antihypertensive treatment for a patient using their individual
   characteristics and clinical condition. Given the observational nature
   of the data, we address potential confounding through generalized
   propensity score evaluation and optimal matching. For patients for whom
   the algorithm recommendation differs from the standard of care, we
   demonstrate an approximate 15.87\% decrease in next blood pressure score
   based on the predicted outcome under the recommended treatment. An
   interactive dashboard has been developed to be used by physicians as a
   clinical support tool.},
Type = {Article},
Affiliation = {Orfanoudaki, A (Corresponding Author), Univ Oxford, Said Business Sch, Pk End St, Oxford OX1 1HP, England.
   Bertsimas, Dimitris; Borenstein, Alison Rose Ann; Dauvin, Antonin; Orfanoudaki, Agni, MIT, Sloan Sch Management, 77 Massachusetts Ave, Cambridge, MA 02139 USA.
   Borenstein, Alison Rose Ann; Dauvin, Antonin; Orfanoudaki, Agni, MIT, Operat Res Ctr, 77 Massachusetts Ave, Cambridge, MA 02139 USA.
   Dauvin, Antonin, Ecole Polytech, Appl Math, Palaiseau, France.
   Orfanoudaki, Agni, Univ Oxford, Said Business Sch, Pk End St, Oxford OX1 1HP, England.},
DOI = {10.1002/nav.22040},
EarlyAccessDate = {DEC 2021},
Keywords = {electronic health records; hypertension; machine learning; prescriptive
   analytics},
Keywords-Plus = {PROPENSITY SCORE; CAUSAL INFERENCE; REMOVE BIAS; MEDICINE; HYPERTENSION;
   MANAGEMENT; BALANCE; IMPACT},
Author-Email = {agni.orfanoudaki@sbs.ox.ac.uk},
