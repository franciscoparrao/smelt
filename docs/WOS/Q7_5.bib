   Buse, John B., Univ North Carolina Chapel Hill, Sch Med, Dept Med, Chapel Hill, NC USA.
   Kosorok, Michael R., Univ North Carolina Chapel Hill, Gillings Sch Global Publ Hlth, Dept Biostat, Chapel Hill, NC USA.},
DOI = {10.1093/aje/kwaf127},
EarlyAccessDate = {AUG 2025},
Keywords = {iterative causal forest; high-dimensional; causal machine learning;
   claims data; subgroup identification; heterogeneous treatment effect;
   pharmacoepidemiology; precision medicine},
Keywords-Plus = {CARDIOVASCULAR OUTCOMES; SUBGROUP ANALYSES; HEART-FAILURE;
   IDENTIFICATION; EMPAGLIFLOZIN; ASSOCIATION; SEMAGLUTIDE; MANAGEMENT;
   MORTALITY},
