   Dou, Yifan, Fudan Univ, Sch Management, Shanghai 200433, Peoples R China.
   Tan, Yong, Univ Washington, Michael G Foster Sch Business, Seattle, WA 98195 USA.},
DOI = {10.1287/isre.2019.0865},
Keywords = {causal inference; graphical model; app analytics; WeChat; spillover
   effects; machine learning; econometrics},
Keywords-Plus = {CAUSAL INFERENCE; IDENTIFICATION; DISADVANTAGE; ANALYTICS; DIAGRAMS;
   DEMAND; IMPACT; LATENT; APPS},
Author-Email = {zhengjy@purdue.edu
