   Zoccali, Carmine, Grande Osped Metropolitano, Assoc Ipertens Nefrol Trapianto Renale IPNET, c-o Nefrol, I-89125 Reggio Di Calabria, Italy.
   Tripepi, Giovanni, Grande Osped Metropolitano, CNR IFC, Inst Clin Physiol, Res Unit Clin Epidemiol, I-89125 Reggio Di Calabria, Italy.},
DOI = {10.1007/s40620-024-02158-5},
EarlyAccessDate = {NOV 2024},
Keywords = {Trial emulation; Target trial emulation; Observational studies; Causal
   inference; Randomized controlled trials (RCTs)},
Keywords-Plus = {CAUSAL INFERENCE; TARGET TRIAL; PROPENSITY SCORES; MORTALITY; PROTOCOL;
