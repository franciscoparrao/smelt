   Restrepo, Juan G., Univ Colorado, Dept Appl Math, Boulder, CO 80309 USA.
   Ott, Edward, Univ Maryland, Dept Elect \& Comp Engn, College Pk, MD 20742 USA.},
DOI = {10.1063/1.5134845},
Article-Number = {121104},
Keywords-Plus = {GENERALIZED SYNCHRONIZATION},
Number-of-Cited-References = {42},
Times-Cited = {34},
