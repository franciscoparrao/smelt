   Hsu, Yu-Chin, Natl Cent Univ, Dept Finance, Taoyuan, Taiwan.
   Hsu, Yu-Chin, Natl Chengchi Univ, Dept Econ, Taipei, Taiwan.
   Lieli, Robert P., Cent European Univ, Dept Econ \& Business, Budapest, Hungary.
   Zhang, Yichong, Singapore Management Univ, Sch Econ, Singapore, Singapore.},
DOI = {10.1080/07350015.2020.1811102},
EarlyAccessDate = {SEP 2020},
Keywords = {Heterogeneous treatment effects; High-dimensional data; Uniform
