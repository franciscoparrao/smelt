Keywords = {Artificial Intelligence (AI); Bayesian networks; explainable AI (xAI);
   sepsis; intensive care unit (ICU); prediction; CDSS},
Keywords-Plus = {ALGORITHM; MORTALITY},
Author-Email = {geoffray.agard@ap-hm.fr
