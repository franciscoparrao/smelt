   Wang, Siqin, Univ Queensland, Sch Environm, Brisbane, Australia.
   Wei, Chunzhu, Sun Yat Sen Univ, Sch Geog \& Planning, Guangzhou, Guangdong, Peoples R China.},
DOI = {10.1016/j.scs.2025.107066},
EarlyAccessDate = {DEC 2025},
