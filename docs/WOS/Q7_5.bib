@article{ WOS:001669425900001,
Author = {Li, Yu and Han, Feng and Zheng, Yi},
Title = {Artificial Intelligence in Surface Water Quality Research and
   Management: Recent Progress and Future Directions},
Journal = {ECOSYSTEM HEALTH AND SUSTAINABILITY},
Year = {2026},
Volume = {12},
Month = {JAN 27},
Abstract = {Surface water quality is under growing pressure from climate change and
   human activities, posing potential risks to both human health and
   aquatic ecosystems. Addressing this pressing challenge requires
   intelligent, data-driven approaches for monitoring, prediction, and
   management. This review synthesizes peer-reviewed studies published
   between 2014 and 2024, illustrating how artificial intelligence (AI) has
   been applied in surface water quality research and governance.
   Bibliometric analysis reveals rapid growth in AI-related studies, with
   rivers as the most frequently studied systems and sediment, nutrients,
   and dissolved oxygen as key parameters. The review shows how AI extends
   monitoring beyond traditional constraints through image-based,
   crowdsourced, and sensor-integrated data acquisition, as well as robust
   gap-filling and anomaly detection. In predictive modeling, AI
   models-especially machine learning and deep learning-have shown superior
   accuracy over process-based models, while recent physics-informed
   approaches enhance robustness and interpretability. For knowledge
   discovery, AI enables the identification of key drivers through
   explainable methods and causal inference and helps reveal complex
   temporal, spatial, and textual patterns. In management, AI supports
   adaptive assessment frameworks and decision tools that improve early
   risk detection, pollution source attribution, and resource allocation.
   Despite these advances, challenges remain in data privacy, heterogeneous
   data integration, and model interpretability. Promising frontiers
   include privacy-preserving federated learning, edge AI for real-time
   fusion, symbolic discovery of physical laws, and
   large-language-model-powered agents for inclusive stakeholder engagement
   in water-quality decisions. Overall, this review positions AI as a
   transformative force for the future of surface water quality management.},
Type = {Review},
Affiliation = {Zheng, Y (Corresponding Author), Southern Univ Sci \& Technol, Sch Environm Sci \& Engn, Shenzhen 518000, Peoples R China.
   Zheng, Y (Corresponding Author), Southern Univ Sci \& Technol, Shenzhen Municipal Engn Lab Environm IoT Technol, Shenzhen 518000, Peoples R China.
