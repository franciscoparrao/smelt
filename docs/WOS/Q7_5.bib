   Lui, Vivian Wai Yan, Augusta Univ, Med Coll Georgia, Georgia Canc Ctr, Augusta, GA 30912 USA.
   Lui, Vivian Wai Yan, Augusta Univ, Med Coll Georgia, Dept Med, Augusta, GA 30912 USA.
   Cooper, Gregory F.; Lu, Xinghua, Univ Pittsburgh, UPMC Hillman Canc Ctr, Med Ctr, Pittsburgh, PA 15232 USA.},
DOI = {10.3390/cancers14194825},
Article-Number = {4825},
Keywords = {HNSCC; cancer drivers; causal inference; cellular signaling; subtyping;
