@article{ WOS:001608115900001,
Author = {Zong, Xu},
Title = {The long arm of childhood: The association between early-life indoor air
   pollution exposure and cognitive performance in later life},
Journal = {SOCIAL SCIENCE \& MEDICINE},
Year = {2025},
Volume = {387},
Month = {DEC},
Abstract = {A large number of poor people all over the world rely on solid fuels,
   such as coal and wood, for cooking, directly bringing exposure to indoor
   air pollution. This exposure has been linked to decreased cognitive
   performance in later life. However, relatively little is known about the
   long-term effects of early-life indoor air pollution exposure and how
   this association varies in different population groups and its
   mechanisms. This study used nationally representative data of 7,161
   adults aged 45 or older in China. Causal forest approach was applied to
   capture the complex nonlinear relationships and estimate the average
   treatment effect of early-life indoor air pollution exposure on
   later-life cognitive performance. Additionally, we estimated
   heterogeneous associations across subgroups. The results demonstrated
   that, after allowing for covariates, early-life indoor air pollution
   exposure was associated with poorer later-life cognitive performance
   (-1.11; 95 \% CI {[}-1.15, -1.07]). Biological and socioeconomic
   pathways, but not psychological pathway, mediated the negative
   association. For specific domains of cognitive performance, we found
   this exposure both significantly associated with worsen performance of
   episodic memory and mental intactness. The heterogenous analysis further
   revealed that men, individuals with a history of smoking, and those with
   a history of alcohol consumption were more vulnerable to the long-term
   detrimental effects of early-life indoor air pollution exposure on
   cognitive performance. Our findings suggest a need to improve access to
   clean energy, such as electricity and gas, which may prevent cognitive
   impairments from the upstream.},
Type = {Article},
Affiliation = {Zong, X (Corresponding Author), Univ Helsinki, Unioninkatu 33, Helsinki 00170, Finland.
   Zong, Xu, Univ Helsinki, Helsinki Inst Demog \& Populat Hlth, Fac Social Sci, Helsinki, Finland.
   Zong, Xu, Max Planck Univ Helsinki Ctr Social Inequal Popula, Helsinki, Finland.},
DOI = {10.1016/j.socscimed.2025.118662},
EarlyAccessDate = {OCT 2025},
Article-Number = {118662},
Keywords = {Indoor air pollution; Solid fuel; Cognitive performance; Childhood
   adversity; Causal forest; CHARLS; Machine learning},
Keywords-Plus = {SOLID-FUEL USE; HOUSEHOLD COOKING; DEPRESSION; HEALTH; IMPAIRMENT;
   IMPUTATION; CHINA},
Author-Email = {xu.zong@helsinki.fi},
Number-of-Cited-References = {82},
Times-Cited = {0},
Unique-ID = {WOS:001608115900001},
}

@article{ WOS:001596437300001,
Author = {Fu, Liping and Yang, Jie and Chen, Qin and Pei, Tong},
Title = {How E-commerce Affects Tourism Development: A New Method based on Double
   Machine Learning},
Journal = {TOURISM PLANNING \& DEVELOPMENT},
Year = {2025},
Month = {2025 OCT 18},
Abstract = {E-commerce drives tourism industry growth. However, little is known
   about the heterogeneous impacts of e-commerce on domestic and
   international tourism. Using panel data from 257 prefecture-level cities
   in China from 2011 to 2019 and applying a double machine learning
   method, this study utilises the National E-commerce Pilot City Policy
   (NEPCP) as a quasi-experiment to evaluate the effect of e-commerce on
   tourism. The results indicate that the NEPCP significantly promotes
   domestic and overall tourism, while its impact on foreign tourism is
   minimal. Tourism entrepreneurial activity, network attention, and
   green-built environment mediate these effects. Heterogeneity analysis
   reveals that the NEPCP substantially impacts cities with high
   development tier rankings, extensive internet infrastructure, and high
   levels of public service. Additionally, the NEPCP creates a significant
   siphon effect on tourism in neighbouring areas. This study provides
   empirical evidence on the impact of e-commerce on tourism and offers
   recommendations for promoting sustainable tourism.},
Type = {Article; Early Access},
Affiliation = {Yang, J (Corresponding Author), Tianjin Univ, Coll Management \& Econ, Ctr Social Sci Survey \& Data, Tianjin, Peoples R China.
   Chen, Q (Corresponding Author), Tsinghua Univ, Sch Publ Policy \& Management, Beijing, Peoples R China.
