   Sato, Koryu, Keio Univ, Fac Policy Management, Fujisawa, Kanagawa, Japan.
   Shiba, Koichiro, Boston Univ, Sch Publ Hlth, Dept Epidemiol, Boston, MA USA.},
DOI = {10.1001/jamanetworkopen.2025.30523},
