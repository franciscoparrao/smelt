   Lin, Jiajun, Fujian Business Univ, Sch Int Business \& Econ, Fuzhou 350002, Peoples R China.},
DOI = {10.3390/f16081232},
Article-Number = {1232},
Keywords = {green industrial policy; export competitiveness; forestry products;
   double machine learning; sustainable development; product complexity;
   China},
Keywords-Plus = {GOVERNMENT},
