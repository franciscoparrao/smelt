   Xu, Ronghui, Univ Calif San Diego, Halicioglu Data Sci Inst, San Diego, CA 92093 USA.},
DOI = {10.1002/sim.9644},
EarlyAccessDate = {JAN 2023},
Keywords = {machine learning; nonparametric methods; orthogonal score; regression
