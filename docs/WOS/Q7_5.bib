   Tanaka, Takashi S. T., Gifu Univ, Fac Appl Biol Sci, Artificial Intelligence Adv Res Ctr, Gifu, 5011193, Japan.
   Bullock, David S., Univ Illinois, Dept Agr \& Consumer Econ, Urbana, IL 61801 USA.},
DOI = {10.1016/j.compag.2022.107164},
EarlyAccessDate = {JUL 2022},
Article-Number = {107164},
Keywords = {Site-specific input management; Nitrogen rate; On-farm precision
   experimentation; Machine learning; Causal forest; Economically optimal
   input rates},
Keywords-Plus = {CORN YIELD; NITROGEN; SOIL; FRAMEWORK; RESPONSES},
Author-Email = {skakimoto3@huskers.unl.edu},
