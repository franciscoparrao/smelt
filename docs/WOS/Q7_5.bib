@article{ WOS:001647361900001,
Author = {Kuang, Yuanpei and Yang, Peiyu},
Title = {The Impact of Green Finance on Urban Energy Efficiency: A Double Machine
   Learning Analysis},
Journal = {SUSTAINABILITY},
Year = {2025},
Volume = {17},
Number = {24},
Month = {DEC 9},
Abstract = {Urban areas globally face the critical challenge of meeting growing
   energy demands while maintaining environmental sustainability. However,
   existing research provides limited and often inconsistent evidence on
   how green finance affects urban energy efficiency, largely due to
   heterogeneous measurement systems, methodological constraints, and
   insufficient identification of underlying mechanisms. To address these
   research gaps, this study investigates two core questions: Does green
   finance significantly improve urban energy efficiency? If so, what are
   the specific transmission mechanisms driving this impact?
   Methodologically, this exploration employs a Double Machine Learning
   (DML) approach to analyze panel data from 210 Chinese cities between
   2006 and 2022. The analysis demonstrates a significant and positive
   impact of green finance on urban energy efficiency, with an estimated
   coefficient of 0.1910. Further analysis identifies three constructive
   mechanisms, including environmental regulations, industrial structures,
   and green technological innovation, which enhance resource allocation
   and energy utilization efficiency. Moreover, green finance shows a
   stronger positive impact in non-resource-dependent cities, regions
   outside traditional industrial bases, and financially developed areas.
   These findings recommend establishing standardized green finance
   frameworks, increasing targeted financial support for key regions, and
   integrating green innovation with industrial restructuring. These
   measures help consolidate China's green finance system and improve
   regional energy efficiency through market expansion, energy transition,
   and technological advancement.},
Type = {Article},
Affiliation = {Yang, PY (Corresponding Author), Hunan Agr Univ, Sch Econ, Changsha 410128, Peoples R China.
   Kuang, Yuanpei; Yang, Peiyu, Hunan Agr Univ, Sch Econ, Changsha 410128, Peoples R China.},
DOI = {10.3390/su172411016},
Article-Number = {11016},
Keywords = {green finance; energy efficiency; urban; double machine learning model},
Author-Email = {kyp0008@163.com
   yyangpeiyu@outlook.com},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001647361900001},
}

@article{ WOS:001636546200002,
Author = {Ji, Yufan and Shafieezadeh, Abdollah},
Title = {Robust treatment assignment with uncertainty-aware causal forests: Joint
   optimization of accuracy and estimation uncertainty},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {303},
Month = {MAR 25},
Abstract = {Causal treatment decision-making methods commonly aim at point-estimate
   accuracy of causal effect estimation and overlook the estimation
   uncertainty, leading to overconfident policies that may fail to
   generalize reliably in real-world settings. This study introduces an
   Uncertainty-Aware Causal Forest framework that explicitly trains causal
   forests to minimize finite-sample estimation uncertainty. Our approach
   achieves this goal by embedding infinitesimal-jackknife-based confidence
   interval (CI) width directly into a joint uncertainty-accuracy learning
   formulation. Specifically, the framework couples Gaussian-process
   Bayesian optimization-for inferring a joint probabilistic model of
   predictive error and CI width and for adaptively exploring the
   hyperparameter space-with a fully nested, honest cross-validation
   architecture. This integration ensures hyperparameter selection is
   guided by out-of-sample uncertainty behavior rather than idiosyncrasies
   of the training data, yielding well-calibrated and robust conditional
   average treatment effect (CATE) estimates. Across one synthetic and two
   real-world benchmark datasets, the proposed framework reduces test CI
   width by more than an order of magnitude compared with Generalized
   Random Forests and Double Machine Learning, while maintaining or
   improving predictive accuracy, achieving near-nominal uncertainty
   coverage, and substantially shrinking train-test discrepancies. A
   dual-threshold targeting rule, supplemented by a lower-confidence-bound
   ranking strategy, translates these gains into actionable treatment
   decisions by prioritizing individuals with high estimated effects and
   low uncertainty. By coupling uncertainty minimization with practical
   decision rules, the proposed framework offers a transparent,
   statistically robust, and uncertainty-aware foundation for expert
   systems in healthcare, marketing, and policy applications.},
Type = {Article},
Affiliation = {Shafieezadeh, A (Corresponding Author), Ohio State Univ, Dept Civil Environm \& Geodet Engn, Risk Assessment \& Management Struct \& Infrastruct, Columbus, OH 43210 USA.
   Ji, Yufan; Shafieezadeh, Abdollah, Ohio State Univ, Dept Civil Environm \& Geodet Engn, Risk Assessment \& Management Struct \& Infrastruct, Columbus, OH 43210 USA.},
DOI = {10.1016/j.eswa.2025.130578},
EarlyAccessDate = {DEC 2025},
Article-Number = {130578},
Keywords = {Causal inference; Treatment effect estimation; Decision making
   enhancement; Uncertainty minimization},
Keywords-Plus = {TRANSITION},
Author-Email = {shafieezadeh.1@osu.edu},
Number-of-Cited-References = {54},
Times-Cited = {0},
Unique-ID = {WOS:001636546200002},
}

@article{ WOS:001646652000001,
Author = {Zhou, Junzuo and Zhu, Zhaoyang and Wang, Huimeng and Gong, Yuki and
   Zhang, Yuge and Li, Frank},
Title = {Data Asset Disclosure and Stock Price Crash Risk: A Double Machine
   Learning Study of Chinese A Share Firms},
Journal = {INTERNATIONAL JOURNAL OF FINANCIAL STUDIES},
Year = {2025},
Volume = {13},
Number = {4},
Month = {DEC 2},
Abstract = {In the digital economy, data assets have become key drivers of firm
   competitiveness and market stability. This study examines the
   association between data asset information disclosure and stock price
   crash risk. Using annual reports of Chinese A-share listed firms from
   2010 to 2023, we construct a Data Asset Information Disclosure Index
   through textual analysis. A double machine learning framework is
   employed to flexibly control for high-dimensional confounders, and the
   results indicate that greater disclosure is associated with lower crash
   risk across multiple specifications. Generalized random forest analysis
   further highlights heterogeneous relationships, with disclosures on both
   internally used and transactional data assets showing stronger negative
   associations with crash risk. Mechanism evidence suggests that
   disclosure may facilitate information dissemination, strengthen investor
   confidence, and improve analyst forecast accuracy. The association is
   more pronounced in firms with weaker corporate governance, higher
   reporting transparency, more competitive industries, and in regions with
   less developed digital economies. An industry spillover pattern is also
   observed, whereby one firm's disclosure is linked to reduced crash risk
   among peers. Overall, this study contributes to the literature on data
   asset disclosure and corporate risk management by providing empirical
   evidence from a major emerging market and by highlighting the potential
   relevance of enhanced transparency for digital governance and capital
   market resilience.},
