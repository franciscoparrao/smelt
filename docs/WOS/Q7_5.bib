   Yeranee, Kirttayoth, Shanghai Jiao Tong Univ, Sch Mech Engn, Shanghai 200240, Peoples R China.},
DOI = {10.1109/JBHI.2024.3432766},
Keywords = {Physiology; Artificial intelligence; Predictive models; Temperature;
   Silicon; Random variables; Mathematical models; Causal discovery; causal
   inference; explainable artificial intelligence; machine learning;
   physiological response; user-centered model},
Author-Email = {bukhoree.sa@wu.ac.th
