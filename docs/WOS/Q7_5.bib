@article{ WOS:001039995600001,
Author = {Rubinstein, Max and Branson, Zach and Kennedy, Edward H.},
Title = {Heterogeneous interventional effects with multiple mediators:
   Semiparametric and nonparametric approaches},
Journal = {JOURNAL OF CAUSAL INFERENCE},
Year = {2023},
Volume = {11},
Number = {1},
Month = {JUL 29},
Abstract = {We propose semiparametric and nonparametric methods to estimate
   conditional interventional indirect effects in the setting of two
   discrete mediators whose causal ordering is unknown. Average
   interventional indirect effects have been shown to decompose an average
   treatment effect into a direct effect and interventional indirect
   effects that quantify effects of hypothetical interventions on mediator
   distributions. Yet these effects may be heterogeneous across the
   covariate distribution. We consider the problem of estimating these
   effects at particular points. We propose an influence function-based
   estimator of the projection of the conditional effects onto a working
   model, and show under some conditions that we can achieve root-n
   consistent and asymptotically normal estimates. Second, we propose a
   fully nonparametric approach to estimation and show the conditions where
   this approach can achieve oracle rates of convergence. Finally, we
   propose a sensitivity analysis that identifies bounds on both the
   average and conditional effects in the presence of mediator-outcome
   confounding. We show that the same methods easily extend to allow
   estimation of these bounds. We conclude by examining heterogeneous
   effects with respect to the effect of COVID-19 vaccinations on
   depression during February 2021.},
Type = {Article},
Affiliation = {Rubinstein, M (Corresponding Author), RAND Corp, Pittsburgh, PA 15213 USA.
   Rubinstein, Max, RAND Corp, Pittsburgh, PA 15213 USA.
   Branson, Zach; Kennedy, Edward H., Carnegie Mellon Univ, Dept Stat \& Data Sci, Pittsburgh, PA 15213 USA.},
DOI = {10.1515/jci-2022-0070},
Article-Number = {20220070},
Keywords = {mediation; heterogeneous effects; machine learning; nonparametrics;
   causal inference},
Author-Email = {mrubinstein@rand.org
   zach@stat.cmu.edu
   edward@stat.cmu.edu},
Number-of-Cited-References = {25},
Times-Cited = {3},
Unique-ID = {WOS:001039995600001},
}

@article{ WOS:000943531000001,
Author = {Deng, Chuyu and Wolf, Jack M. and Vock, David M. and Carroll, Dana M.
   and Boatman, Jeffrey A. and Hatsukami, Dorothy K. and Leng, Ning and
   Koopmeiners, Joseph S.},
Title = {Practical guidance on modeling choices for the virtual twins method},
Journal = {JOURNAL OF BIOPHARMACEUTICAL STATISTICS},
Year = {2023},
Volume = {33},
Number = {5},
Pages = {653-676},
Month = {SEP 3},
Abstract = {Individuals can vary drastically in their response to the same
   treatment, and this heterogeneity has driven the push for more
   personalized medicine. Accurate and interpretable methods to identify
   subgroups that respond to the treatment differently from the population
   average are necessary to achieving this goal. The Virtual Twins (VT)
   method is a highly cited and implemented method for subgroup
   identification because of its intuitive framework. However, since its
   initial publication, many researchers still rely heavily on the authors'
   initial modeling suggestions without examining newer and more powerful
   alternatives. This leaves much of the potential of the method untapped.
   We comprehensively evaluate the performance of VT with different
   combinations of methods in each of its component steps, under a
   collection of linear and nonlinear problem settings. Our simulations
   show that the method choice for Step 1 of VT, in which dense models with
   high predictive performance are fit for the potential outcomes, is
   highly influential in the overall accuracy of the method, and
   Superlearner is a promising choice. We illustrate our findings by using
   VT to identify subgroups with heterogeneous treatment effects in a
   randomized, double-blind trial of very low nicotine content cigarettes.},
Type = {Article},
Affiliation = {Koopmeiners, JS (Corresponding Author), Univ Minnesota, Div Biostat, Minneapolis, MN 55455 USA.
   Deng, Chuyu; Wolf, Jack M.; Vock, David M.; Boatman, Jeffrey A.; Koopmeiners, Joseph S., Univ Minnesota, Sch Publ Hlth, Div Biostat, Minneapolis, MN USA.
   Carroll, Dana M., Univ Minnesota, Sch Publ Hlth, Div Environm Hlth Sci, Minneapolis, MN USA.
   Hatsukami, Dorothy K., Univ Minnesota, Masonic Canc Ctr, Minneapolis, MN USA.
   Hatsukami, Dorothy K., Univ Minnesota, Dept Psychiat \& Behav Sci, Minneapolis, MN USA.
   Leng, Ning, Genentech Inc, Prod Dev Data Sci, San Francisco, CA USA.
   Koopmeiners, Joseph S., Univ Minnesota, Div Biostat, Minneapolis, MN 55455 USA.},
DOI = {10.1080/10543406.2023.2170404},
EarlyAccessDate = {MAR 2023},
Keywords = {Virtual twins; causal inference; machine learning; personalized
   medicine; precision medicine},
Keywords-Plus = {NICOTINE CONTENT CIGARETTES; SUBGROUP IDENTIFICATION; TOXICANT EXPOSURE;
   SMOKING-BEHAVIOR; HETEROGENEITY; SELECTION},
Author-Email = {koopm007@umn.edu},
