@article{ WOS:001300957900001,
Author = {Lee, Yongseok and Leite, Walter L.},
Title = {A Comparison of Random Forest-Based Missing Imputation Methods for
   Covariates in Propensity Score Analysis},
Journal = {PSYCHOLOGICAL METHODS},
Year = {2024},
Month = {2024 JUN 13},
Abstract = {Propensity score analysis (PSA) is a prominent method to alleviate
   selection bias in observational studies, but missing data in covariates
   is prevalent and must be dealt with during propensity score estimation.
   Through Monte Carlo simulations, this study evaluates the use of
   imputation methods based on multiple random forests algorithms to handle
   missing data in covariates: multivariate imputation by chained
   equations-random forest (Caliber), proximity imputation (PI), and
   missForest. The results indicated that PI and missForest outperformed
   other methods with respect to bias of average treatment effect
   regardless of sample size and missing mechanisms. A demonstration of
   these five methods with PSA to evaluate the effect of participation in
   center-based care on children's reading ability is provided using data
   from the Early Childhood Longitudinal Study, Kindergarten Class of
   2010-2011.},
Type = {Article; Early Access},
Affiliation = {Lee, Y (Corresponding Author), Univ Florida, Bur Econ \& Business Res, 720 Southwest Second Ave Suite 150, Gainesville, FL 32611 USA.
   Lee, Yongseok, Univ Florida, Bur Econ \& Business Res, 720 Southwest Second Ave Suite 150, Gainesville, FL 32611 USA.
   Leite, Walter L., Univ Florida, Sch Human Dev \& Org Studies Educ, Gainesville, FL 32611 USA.},
DOI = {10.1037/met0000676},
EarlyAccessDate = {JUN 2024},
Keywords = {propensity score analysis; missing data; multivariate imputation by
   chained equations; machine learning; random forests},
Keywords-Plus = {MULTIPLE IMPUTATION; CHAINED EQUATIONS; CAUSAL INFERENCE;
   SENSITIVITY-ANALYSIS; MATCHING METHODS; MODELS; ASSUMPTION; ROBUSTNESS;
   STATISTICS; VARIABLES},
Author-Email = {yseok.lee@ufl.edu},
Number-of-Cited-References = {101},
