   Kiuchi, Sakura, Tohoku Univ, Grad Sch Dent, Dept Int \& Community Oral Hlth, Sendai, Miyagi, Japan.
   Spencer, Andrew J., Univ Adelaide, Australian Res Ctr Populat Oral Hlth, Adelaide, SA, Australia.},
DOI = {10.1093/ije/dyaf080},
Article-Number = {dyaf080},
Keywords = {health inequalities; population strategy; dentistry; causal inference;
   machine learning},
Keywords-Plus = {SOCIAL INEQUALITIES; SOCIOECONOMIC-STATUS; TOOTH-DECAY; CARIES;
   PREVENTION; INCREASE; DISEASES; CHILDREN; IMPACT},
