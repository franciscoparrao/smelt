   Knox, Dean, Univ Penn, Wharton Sch, Operat Informat \& Decis Dept, Philadelphia, PA 19104 USA.
   Knox, Dean, Univ Penn, Wharton Sch, Dept Stat \& Data Sci, Philadelphia, PA 19104 USA.
   Stewart, Brandon M., Princeton Univ, Dept Sociol, Princeton, NJ 08542 USA.
   Stewart, Brandon M., Princeton Univ, Off Populat Res, Princeton, NJ 08542 USA.},
Article-Number = {182},
Keywords = {causal inference; deconfounder; machine learning; unmeasured confounding},
