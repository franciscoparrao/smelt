Article-Number = {e2522390},
Keywords-Plus = {RANDOMIZED CONTROLLED-TRIALS; INDIVIDUAL PATIENT DATA; BLOOD-PRESSURE;
   DECISION-MAKING; CLINICAL-TRIALS; RISK; SUBGROUPS; MANAGEMENT; MEDICINE;
   VALIDATION},
