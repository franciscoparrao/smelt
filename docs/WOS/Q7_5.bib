DOI = {10.1016/j.watres.2025.125026},
EarlyAccessDate = {NOV 2025},
Article-Number = {125026},
Keywords = {Coastal marine water quality; Explainable machine learning; Causal
   inference; Longterm monitoring; Anthropogenic drivers},
Author-Email = {shanw@connect.hku.hk
   zhanghs@hku.hk},
Number-of-Cited-References = {59},
