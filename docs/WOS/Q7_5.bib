   Yin, Weiwen, Univ Macau, Ave Univ,Room 4041,Humanities \& Social Sci Bldg E2, Taipa, Macao, Peoples R China.},
DOI = {10.1177/20531680231153080},
Article-Number = {20531680231153080},
Keywords = {Causal forests; heterogeneous treatment effect; machine learning;
   multiplicative interaction model},
Keywords-Plus = {MODELS},
Author-Email = {wwyin@um.edu.mo},
Number-of-Cited-References = {20},
