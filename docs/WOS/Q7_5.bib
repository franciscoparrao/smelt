@incollection{ WOS:001222710500001,
Author = {Schacht, Oliver and Klaassen, Sven and Schwarz, Philipp and Spindler,
   Martin and Gruenbaum, Daniel and Imhof, Sebastian},
Editor = {Le, T and Li, J and Ness, R and Triantafillou, S and Shimizu, S and Cui, P and Kuang, K and Pei, J and Wang, F and Prosperi, M},
Title = {Causally Learning an Optimal Rework Policy},
Booktitle = {KDD'23 WORKSHOP ON CAUSAL DISCOVERY, PREDICTION AND DECISION, VOL 218},
Series = {Proceedings of Machine Learning Research},
Year = {2023},
Volume = {218},
Pages = {3-24},
Abstract = {In manufacturing, rework refers to an optional step of a production
   process which aims to eliminate errors or remedy products that do not
   meet the desired quality standards. Reworking a production lot involves
   repeating a previous production stage with adjustments to ensure that
   the final product meets the required specifications. While offering the
   chance to improve the yield and thus increase the revenue of a
   production lot, a rework step also incurs additional costs.
   Additionally, the rework of parts that already meet the target
   specifications may damage them and decrease the yield. In this paper, we
   apply double/debiased machine learning (DML) to estimate the conditional
   treatment effect of a rework step during the color conversion process in
   opto-electronic semiconductor manufacturing on the final product yield.
   We utilize the implementation DoubleML to develop policies for the
   rework of components and estimate their value empirically. From our
   causal machine learning analysis we derive implications for the coating
   of monochromatic LEDs with conversion layers.},
Type = {Proceedings Paper},
Affiliation = {Schacht, O (Corresponding Author), Univ Hamburg, Fac Business Adm, Moorweidenstr 18, D-20148 Hamburg, Germany.
   Schacht, Oliver; Klaassen, Sven; Schwarz, Philipp; Spindler, Martin, Univ Hamburg, Fac Business Adm, Moorweidenstr 18, D-20148 Hamburg, Germany.
   Gruenbaum, Daniel; Imhof, Sebastian, Ams OSRAM, Leibnizstr 4, D-93055 Regensburg, Germany.
   Klaassen, Sven; Schwarz, Philipp; Spindler, Martin, Economic AI, Nurnberger Str 262 A, D-93059 Regensburg, Germany.},
Keywords = {Causal Inference; Machine Learning; Heterogeneous Treatment Effects;
   Double Machine Learning; Policy Learning},
Author-Email = {OLIVER.SCHACHT@UNI-HAMBURG.DE},
Number-of-Cited-References = {15},
