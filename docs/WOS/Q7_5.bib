   Franzke, Christian L. E., Univ Hamburg, Ctr Earth Syst Res \& Sustainabil, D-20144 Hamburg, Germany.},
DOI = {10.1063/5.0007670},
Article-Number = {063116},
Keywords-Plus = {STATE-SPACE RECONSTRUCTION; SURFACE AIR-TEMPERATURE; ANNULAR MODE;
