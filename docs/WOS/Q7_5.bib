}

@article{ WOS:001358284200023,
Author = {Kolkman, Daan and Lee, Gwendolyn K. and van Witteloostuijn, Arjen},
Title = {Data science and automation in the process of theorizing: Machine
   learning's power of induction in the co-duction cycle},
Journal = {PLOS ONE},
Year = {2024},
Volume = {19},
Number = {11},
Month = {NOV 4},
Abstract = {Recent calls to take up data science either revolve around the superior
   predictive performance associated with machine learning or the potential
   of data science techniques for exploratory data analysis. Many believe
   that these strengths come at the cost of explanatory insights, which
   form the basis for theorization. In this paper, we show that this
   trade-off is false. When used as a part of a full research process,
   including inductive, deductive and abductive steps, machine learning can
   offer explanatory insights and provide a solid basis for theorization.
   We present a systematic five-step theory-building and theory-testing
   cycle that consists of: 1. Element identification (reduction); 2.
   Exploratory analysis (induction); 3. Hypothesis development
   (retroduction); 4. Hypothesis testing (deduction); and 5. Theorization
   (abduction). We demonstrate the usefulness of this approach, which we
   refer to as co-duction, in a vignette where we study firm growth with
   real-world observational data.},
Type = {Article},
Affiliation = {Lee, GK (Corresponding Author), Univ Florida, Gainesville, FL 32611 USA.
   Kolkman, Daan, Jheronimus Acad Data Sci, Shertogenbosch, Netherlands.
   Kolkman, Daan, Univ Utrecht, Utrecht, Netherlands.
   Lee, Gwendolyn K., Univ Florida, Gainesville, FL 32611 USA.
   van Witteloostuijn, Arjen, Vrije Univ Amsterdam, Amsterdam, Netherlands.
   van Witteloostuijn, Arjen, Antwerp Management Sch, Antwerp, Belgium.},
DOI = {10.1371/journal.pone.0309318},
Article-Number = {e0309318},
Keywords-Plus = {FIRM GROWTH; SCALING BEHAVIOR; CAUSAL INFERENCE; CEO PERSONALITY;
   PREDICTION; DYNAMICS; MODEL},
Author-Email = {gwendolyn.lee@warrington.ufl.edu},
Number-of-Cited-References = {96},
Times-Cited = {3},
Unique-ID = {WOS:001358284200023},
}

@article{ WOS:001345470300004,
Author = {Domguia, Edmond Noubissi and Nkengfack, Hilaire and Pondie, Thierry
   Messie and Ngounou, Borice Augustin},
Title = {Do environmental taxes encourage the decarbonization of economies?},
Journal = {ENVIRONMENT DEVELOPMENT AND SUSTAINABILITY},
Year = {2024},
Month = {2024 OCT 28},
Abstract = {The fight against weather change requires a great reduction in
   greenhouse gas emissions. Environmental taxes are a potential tool for
   encouraging businesses and households to adopt more sustainable
   behaviour. This study explores the impact of environmental tax on the
   decarbonization of economies. It focuses on OECD countries and analyses
   changes in CO2 output in the industry and transport sectors following
   the introduction of environmental tax. Econometric approach alongside
   machine learning are used to estimate the causal and heterogeneous
   influence of environmental tax on CO2 output. The outcomes of the
   research indicate that environmental tax have a positive and significant
   effect on reducing CO2 output. Moreover, it reveals that the effect is
   more pronounced in energy-intensive sectors such as manufacturing and
   transport. The achievements of the study support the idea that ecotax
   can serve as an efficacious mechanism for encouraging the
   decarbonization of economies. It also highlights the importance of
   designing well-calibrated environmental taxes and combining them with
   other incentive policies. This study provides empirical evidence that
   ecotax can play an important role in transitioning to a low-carbon
   economy. This article encourages governments to adopt ambitious
   environmental taxation policies to encourage the transition to a more
   carbon-free economy.},
Type = {Review; Early Access},
Affiliation = {Domguia, EN (Corresponding Author), Ctr Etud \& Rech Management \& Econ, Lab Rech Econ Fondamentale \& Appl, Dschang, Cameroon.
   Domguia, Edmond Noubissi; Nkengfack, Hilaire, Ctr Etud \& Rech Management \& Econ, Lab Rech Econ Fondamentale \& Appl, Dschang, Cameroon.
   Pondie, Thierry Messie; Ngounou, Borice Augustin, Lab Rech Econ Fondamentale \& Appliquee, Dschang, Cameroon.},
DOI = {10.1007/s10668-024-05571-9},
EarlyAccessDate = {OCT 2024},
Keywords = {Environmental tax; Decarbonization; Difference in difference; Propensity
   score matching; Lewbel 2SLS; Heterogeneous treatment effect; Quantile
   treatment effect},
Keywords-Plus = {FINANCIAL DEVELOPMENT; DEGRADATION EVIDENCE; ENERGY-CONSUMPTION; CO2
