   Xu, Yong; Zou, Bin; Li, Shen-Xin, Cent South Univ, Sch Geosci \& Info Phys, Changsha 410083, Peoples R China.
   Feng, Yu-Xi, Guangdong Hong Kong Joint Lab Carbon Neutral, Jiangmen Lab Carbon Sci \& Technol, Jiangmen 529199, Guangdong, Peoples R China.},
DOI = {10.1016/j.watres.2026.125746},
Article-Number = {125746},
Keywords = {Lake eutrophication; Driving pattern classification; Interpretable
   machine learning; Causal inference},
Keywords-Plus = {PHOSPHORUS; NUTRIENT; NITROGEN},
Author-Email = {yu-xifeng@foxmail.com
