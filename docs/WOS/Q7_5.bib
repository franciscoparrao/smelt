   Kang, Hyunseung, Univ Wisconsin Madison, Dept Stat, Madison, WI USA.},
DOI = {10.3102/1076998620951983},
EarlyAccessDate = {SEP 2020},
Article-Number = {1076998620951983},
Keywords = {causal inference; machine learning methods; observational studies;
   multilevel propensity score matching; finite mixture modeling},
Keywords-Plus = {PROPENSITY SCORE METHODS; CAUSAL INFERENCE; MAXIMUM-LIKELIHOOD},
Author-Email = {ysuk@wisc.edu
