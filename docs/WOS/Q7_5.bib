   Daoud, Adel; Johansson, Fredrik D., Chalmers Univ Technol, Dept Comp Sci \& Engn, Div Data Sci \& Artificial Intelligence, Gothenburg, Sweden.},
DOI = {10.1016/j.ssresearch.2023.102973},
EarlyAccessDate = {DEC 2023},
Article-Number = {102973},
Keywords = {Child welfare; Causal inference; Demography; Families; Population
   heterogeneity; Poverty; Austerity; Public policy; policy Social
   stratification},
Keywords-Plus = {INTERNATIONAL MONETARY FUND; CROSS-NATIONAL ANALYSIS; STRUCTURAL
   ADJUSTMENT; SENSITIVITY-ANALYSIS; IMF CONDITIONALITY; GREAT RECESSION;
   HEALTH; STATE; NEGOTIATIONS; INEQUALITY},
