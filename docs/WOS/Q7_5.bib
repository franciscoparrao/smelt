   Erickson, John A., Western Kentucky Univ, Analyt \& Informat Syst, Bowling Green, KY 42101 USA.
   Miratrix, Luke W., Harvard Univ, Grad Sch Educ, Cambridge, MA USA.
   Heffernan, Neil T., Worcester Polytech Inst, Dept Comp Sci, Worcester, MA USA.},
DOI = {10.1515/jci-2022-0011},
