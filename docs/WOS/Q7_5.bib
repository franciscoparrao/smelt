Affiliation = {Zampieri, FG (Corresponding Author), HCor Hosp Coracao, Res Inst, Sao Paulo, Brazil.
   Zampieri, FG (Corresponding Author), Hosp Alemao Oswaldo Cruz, Res Div, Sao Paulo, Brazil.
