@article{ WOS:001626154700001,
Author = {Fan, Chen and Lin, Cheng},
Title = {Can green credit policy promote corporate carbon information disclosure:
   the evidence from Chinese listed companies},
Journal = {APPLIED ECONOMICS},
Year = {2025},
Month = {2025 NOV 28},
Abstract = {This study uses panel data from Chinese A-share firms (2008-2023) to
   examine the relationship between corporate carbon disclosure and green
   credit policies. We use a difference-in-differences (DID) model,
   verified by double machine learning (DML) and propensity score
   matching-DID (PSM-DID), under the parallel trends assumption, to show a
   notable rise in disclosure levels. Heterogeneous impacts draw attention
   to differences associated with emission intensity, regional
   marketization, and executive political ties. Green innovation
   incentives, increased competitiveness, and the removal of financial
   constraints are examples of mechanistic routes; environmental rules and
   commercial credit serve as negative moderators. This research
   contributes to global climate governance frameworks by defining the
   contextual boundaries of green finance and offering micro-level evidence
   of its governance role. This helps design targeted policies for
   sustainable economic transformation.},
