}

@article{ WOS:001345470300003,
Author = {Lv, Lijuan and Zhang, Peiliang},
Title = {Green location-oriented policies and their effect on carbon abatement
   costs: evidence from China's Eco-Industrial Demonstration Parks},
Journal = {ENVIRONMENT DEVELOPMENT AND SUSTAINABILITY},
Year = {2024},
Month = {2024 OCT 28},
Abstract = {Green location-oriented policies are pivotal in reducing carbon
   emissions. Currently, it remains unclear whether green location-oriented
   policies can affect the marginal abatement cost (MAC) of carbon
   emissions. This study leverages the establishment of China's
   Eco-Industrial Demonstration Parks (EDP) as a quasi-natural experiment
   to investigate this effect. Utilizing data from 2006 to 2019 for
   prefecture-level and above cities, we estimate the shadow price of
   carbon dioxide using a dual model of slacks-based measure, which serves
   as a proxy for MAC. Through a staggered difference-in-differences (DID)
   model, our analysis reveals that EDP construction has increased MAC in
   demonstration cities by 9\%. This result remains robust under
   heterogeneous robust estimation, synthetic DID, continuous DID, and
   double machine learning models. The effectiveness of EDP in raising MAC
   is particularly significant in cities hosting multiple parks, regions
   without traditional industrial bases, and the eastern areas. Mechanism
   analysis suggests that EDP influences MAC through carbon intensity and
   green innovation effects. Additionally, EDP construction exhibits
   significant positive spillovers to the control group. These findings
   provide policy insights for maximizing the sustainable development
   benefits of EDP.},
Type = {Article; Early Access},
Affiliation = {Zhang, PL (Corresponding Author), Wuhan Univ Technol, Sch Comp Sci \& Artificial Intelligence, Wuhan 430070, Peoples R China.
   Lv, Lijuan, Shandong Univ, Ctr Econ Res, Jinan 250100, Peoples R China.
   Zhang, Peiliang, Wuhan Univ Technol, Sch Comp Sci \& Artificial Intelligence, Wuhan 430070, Peoples R China.},
DOI = {10.1007/s10668-024-05613-2},
EarlyAccessDate = {OCT 2024},
Keywords = {Green location-oriented policies; National Eco-Industrial Demonstration
   Parks; Marginal abatement cost; Shadow price; Staggered
   difference-in-differences},
Keywords-Plus = {CO2 EMISSIONS; PERFORMANCE; IMPACT; PANEL},
Author-Email = {lvlijuan@mail.sdu.edu.cn
   zhangpl109@whut.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {2},
Unique-ID = {WOS:001345470300003},
}

@article{ WOS:001339270000001,
Author = {Bernasconi, Alice and Zanga, Alessio and Lucas, Peter J. F. and Scutari,
   Marco and Trama, Annalisa and Stella, Fabio},
Title = {A causal network model to estimate the cardiotoxic effect of oncological
   treatments in young breast cancer survivors},
Journal = {PROGRESS IN ARTIFICIAL INTELLIGENCE},
Year = {2024},
Month = {2024 OCT 23},
Abstract = {Randomised clinical trials to study treatment effects may be infeasible
   for several reasons: we often resort to analysing observational
   healthcare data instead. Still, we must ensure the validity and
   interpretability of the causal relationships discovered using machine
   learning to support clinical decision-making. This is particularly
   important in oncology, where clinicians are interested in disentangling
   the long-term impact of treatments on cancer survivors to plan
   personalised follow-up strategies. For this purpose, here we develop a
   causal network model by uniquely combining clinical expert knowledge and
   simultaneous causal discovery on population and clinical cohorts. Our
   results highlight the individual causal effects on the cardiotoxicity of
   neoadjuvant chemotherapy, radiotherapy, and targeted molecular therapies
   in adolescent and young adult breast cancer survivors. In contrast, the
   causal roles of adjuvant therapies and hormone therapy remain unclear.
   We estimated treatment effects, validated them with clinical expertise,
   and compared them to the scientific literature. Moreover, we compared
   the estimated effects to unadjusted raw estimates to get insight into
   the impact of the bias in the data, highlighting the relevance of the
   proposed methodological approach used to handle it.},
