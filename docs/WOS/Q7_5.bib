@incollection{ WOS:000468160600054,
Author = {Zhu, Fujin and Lin, Adi and Zhang, Guangquan and Lu, Jie and Zhu,
   Donghua},
Editor = {Liu, J and Lu, J and Xu, Y and Martinez, L and Kerre, EE},
Title = {Pareto-smoothed inverse propensity weighing for causal inference},
Booktitle = {DATA SCIENCE AND KNOWLEDGE ENGINEERING FOR SENSING DECISION SUPPORT},
Series = {World Scientific Proceedings Series on Computer Engineering and
   Information Science},
Year = {2018},
Volume = {11},
Pages = {413-420},
Abstract = {Causal inference has received great attention across different fields
   ranging from economics, statistics, biology, medicine, to machine
   learning. Observational causal inference is challenging because
   confounding variables may influence both the treatment and outcome.
   Propensity score based methods are theoretically able to handle this
   confounding bias problem. However, in practice, propensity score
   estimation is subject to extreme values, leading to small effective
   sample size and making the estimators unstable or even misleading. Two
   strategies - truncation and normalization - are usually adopted to
   address this problem. In this paper, we propose a new Pareto-smoothing
   strategy to tackle this problem. Simulations and a real-world example
   validate the effectiveness.},
Type = {Proceedings Paper},
Affiliation = {Zhu, FJ (Corresponding Author), Beijing Inst Technol, Sch Management \& Econ, Beijing 100081, Peoples R China.
   Zhu, FJ (Corresponding Author), Univ Technol Sydney, FEIT, Ctr Artificial Intelligence CAI, Sch Software, Sydney, NSW 2007, Australia.
