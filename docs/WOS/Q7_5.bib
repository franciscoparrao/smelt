   Zhang, Cong, China Novartis Inst Biomed Res Co, Shanghai, Peoples R China.
   Vandemeulebroecke, Marc, UCB Farchim SA, Dev Analyt \& Stat Innovat, Bulle, Switzerland.
   Hemmings, Rob, Consilium Hemmings UK Ltd, Woking, England.
   Ruberg, Stephen, Analytix Thinking LLC, Indianapolis, IN USA.},
DOI = {10.1002/pst.2463},
Article-Number = {e2463},
Keywords = {heterogeneous treatment effects; machine learning; subgroup analysis;
