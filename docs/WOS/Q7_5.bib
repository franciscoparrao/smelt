@article{ WOS:001688208500001,
Author = {Iatrou, Miltiadis and Mourelatos, Spiros and Karydas, Christos},
Title = {Comparing XGBoost and Double Machine Learning for Predicting the
   Nitrogen Requirement of Rice},
Journal = {REMOTE SENSING},
Year = {2026},
Volume = {18},
Number = {3},
Month = {JAN 28},
Abstract = {Highlights What are the main findings? Double Machine Learning
   outperformed XGBoost in identifying heterogeneous nitrogen yield
   responses under real farm conditions. A hybrid decision support system
   combining DR-Learner and Causal Forest models was developed for
   site-specific nitrogen management. What are the implications of the main
   findings? Causal machine learning enables yield-oriented nitrogen
   recommendations by adjusting for confounding in observational field
   data. Integrating plant-status information with causal treatment effects
   improves the reliability of nitrogen response estimation.Highlights What
   are the main findings? Double Machine Learning outperformed XGBoost in
   identifying heterogeneous nitrogen yield responses under real farm
   conditions. A hybrid decision support system combining DR-Learner and
   Causal Forest models was developed for site-specific nitrogen
   management. What are the implications of the main findings? Causal
   machine learning enables yield-oriented nitrogen recommendations by
   adjusting for confounding in observational field data. Integrating
   plant-status information with causal treatment effects improves the
   reliability of nitrogen response estimation.Abstract Estimating how crop
   yield responds to site-specific nitrogen (N) fertilization is essential
   for maximizing yield potential under variable field conditions. However,
   classical Machine Learning (ML) approaches applied to observational farm
   data primarily focus on yield prediction and often fail to recover
   causal N response due to confounding arising from non-random fertilizer
   application. In this study, we develop and evaluate a Causal Machine
   Learning (CML) framework to estimate heterogeneous N treatment effects
   under real commercial rice-farming conditions in the Axios River Plain,
   Greece. The proposed approach combines Double Machine Learning (DML)
   with remote sensing, soil, climatic, and management data to adjust for
   confounding and identify causal relationships between N inputs, Leaf
   Nitrogen Concentration (LNC), and yield. A doubly robust (DR) learner is
   used to estimate yield sensitivity to N at key agronomic thresholds,
   while a Causal Forest model leverages LNC to assess crop physiological N
   status. Results demonstrate that the CML-based framework outperforms
   conventional XGBoost predictive models in identifying field plots that
   are responsive to additional N. By integrating causal effect estimation
   with plant-status information, the proposed decision support system
   identifies zones where yield gains can be achieved through targeted N
   increases while avoiding overfertilization in non-responsive areas.},
