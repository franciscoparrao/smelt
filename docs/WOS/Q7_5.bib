   Ma, Chong, Novartis Pharmaceut, Early Dev Analyt, Cambridge, MA USA.
   Vandemeulebroecke, Marc, Novartis Pharm AG, Clin Dev \& Analyt, Basel, Switzerland.},
DOI = {10.1002/bimj.202100337},
EarlyAccessDate = {NOV 2022},
Keywords = {benchmarking; machine learning; simulation; subgroup analysis; subgroup
   identification; treatment effect heterogeneity},
Keywords-Plus = {CONTINUOUS VARIABLE SIMULATION; SUBGROUP IDENTIFICATION; TUTORIAL;
