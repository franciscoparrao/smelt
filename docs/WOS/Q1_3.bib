   Wang, Yuxi, Nanjing Med Univ, Affiliated Taizhou Peoples Hosp, Dept Neurol, Taizhou, Jiangsu, Peoples R China.},
DOI = {10.1371/journal.pone.0330530},
Article-Number = {e0330530},
Keywords-Plus = {SCORE; HEMORRHAGE; SCALE},
Author-Email = {2110276269@szu.edu.cn
