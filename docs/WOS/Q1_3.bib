}

@incollection{ WOS:001222727705031,
Author = {Hegselmann, Stefan and Buendia, Alejandro and Lang, Hunter and Agrawal,
   Monica and Jiang, Xiaoyi and Sontag, David},
Editor = {Ruiz, F and Dy, J and VanDeMeent, JW},
Title = {TabLLM: Few-shot Classification of Tabular Data with Large Language
   Models},
Booktitle = {INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE AND STATISTICS, VOL
   206},
Series = {Proceedings of Machine Learning Research},
Year = {2023},
Volume = {206},
Abstract = {We study the application of large language models to zero-shot and
   few-shot classification of tabular data. We prompt the large language
   model with a serialization of the tabular data to a natural-language
   string, together with a short description of the classification problem.
   In the few-shot setting, we fine-tune the large language model using
   some labeled examples. We evaluate several serialization methods
   including templates, table-to-text models, and large language models.
   Despite its simplicity, we find that this technique outperforms prior
   deep-learning-based tabular classification methods on several benchmark
   datasets. In most cases, even zero-shot classification obtains
   non-trivial performance, illustrating the method's ability to exploit
   prior knowledge encoded in large language models. Unlike many deep
   learning methods for tabular datasets, this approach is also competitive
   with strong traditional baselines like gradient-boosted trees,
   especially in the very-few-shot setting.},
Type = {Proceedings Paper},
Affiliation = {Hegselmann, S (Corresponding Author), MIT, CSAIL, Cambridge, MA 02139 USA.
   Hegselmann, S (Corresponding Author), Univ Munster, Munster, Germany.
   Hegselmann, Stefan; Buendia, Alejandro; Lang, Hunter; Agrawal, Monica; Sontag, David, MIT, CSAIL, Cambridge, MA 02139 USA.
   Hegselmann, Stefan; Jiang, Xiaoyi, Univ Munster, Munster, Germany.},
Keywords-Plus = {PREDICTION},
Number-of-Cited-References = {66},
Times-Cited = {46},
Unique-ID = {WOS:001222727705031},
}

@article{ WOS:001323818200001,
Author = {Farhood, Helia and Joudah, Ibrahim and Beheshti, Amin and Muller, Samuel},
Title = {Evaluating and Enhancing Artificial Intelligence Models for Predicting
   Student Learning Outcomes},
Journal = {INFORMATICS-BASEL},
Year = {2024},
Volume = {11},
Number = {3},
Month = {SEP},
Abstract = {Predicting student outcomes is an essential task and a central challenge
   among artificial intelligence-based personalised learning applications.
   Despite several studies exploring student performance prediction, there
   is a notable lack of comprehensive and comparative research that
   methodically evaluates and compares multiple machine learning models
   alongside deep learning architectures. In response, our research
   provides a comprehensive comparison to evaluate and improve ten
   different machine learning and deep learning models, either
   well-established or cutting-edge techniques, namely, random forest,
   decision tree, support vector machine, K-nearest neighbours classifier,
   logistic regression, linear regression, and state-of-the-art extreme
   gradient boosting (XGBoost), as well as a fully connected feed-forward
   neural network, a convolutional neural network, and a gradient-boosted
   neural network. We implemented and fine-tuned these models using Python
   3.9.5. With a keen emphasis on prediction accuracy and model performance
   optimisation, we evaluate these methodologies across two benchmark
   public student datasets. We employ a dual evaluation approach, utilising
   both k-fold cross-validation and holdout methods, to comprehensively
   assess the models' performance. Our research focuses primarily on
   predicting student outcomes in final examinations by determining their
   success or failure. Moreover, we explore the importance of feature
   selection using the ubiquitous Lasso for dimensionality reduction to
   improve model efficiency, prevent overfitting, and examine its impact on
   prediction accuracy for each model, both with and without Lasso. This
   study provides valuable guidance for selecting and deploying predictive
   models for tabular data classification like student outcome prediction,
   which seeks to utilise data-driven insights for personalised education.},
Type = {Article},
Affiliation = {Farhood, H (Corresponding Author), Macquarie Univ, Sch Math \& Phys Sci, Sydney, NSW 2109, Australia.
   Farhood, Helia; Joudah, Ibrahim; Muller, Samuel, Macquarie Univ, Sch Math \& Phys Sci, Sydney, NSW 2109, Australia.
   Beheshti, Amin, Macquarie Univ, Sch Comp, Sydney, NSW 2109, Australia.},
DOI = {10.3390/informatics11030046},
Article-Number = {46},
Keywords = {student outcome prediction; technologies of information in education;
   machine learning; deep learning; information and communication
   technologies in education; AI neural networks},
Keywords-Plus = {CROSS-VALIDATION; SELECTION},
Author-Email = {helia.farhood@mq.edu.au
   ibrahim.joudah@mq.edu.au
   amin.beheshti@mq.edu.au
   samuel.muller@mq.edu.au},
Number-of-Cited-References = {65},
Times-Cited = {10},
Unique-ID = {WOS:001323818200001},
}

@incollection{ WOS:001566005900076,
Author = {Parque, Victor},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Towards a Fast and Generalizable Neural Inference Scheme for Tabular
   Data},
Booktitle = {2025 IEEE INTERNATIONAL PARALLEL AND DISTRIBUTED PROCESSING SYMPOSIUM
   WORKSHOPS, IPDPSW},
Series = {International Symposium on Parallel and Distributed Processing Workshops
   and Phd Forum},
Year = {2025},
Pages = {588-596},
Abstract = {Machine learning for tabular data has been key for regression and
   classification tasks across diverse fields such as finance,
   instrumentation, health, engineering, and climate science. Over the past
   two decades, decision trees have been popular due to enabling fast
   learning schemes; however, despite the widespread use, generalization
   remains a key bottleneck. Recently, deep learning using attention-based
   mechanisms have been proposed for tabular data, achieving fast training
   and high accuracy, and outperforming the leading tree-based learning
   approaches in several key benchmarks. However, a notable limitation has
   been the slow learning and inference. In this paper, we present an
   approach based on modules of randomized neural networks with learnable
   activation functions, achieving the improved performance with respect to
   other fast machine learning schemes.},
Type = {Proceedings Paper},
Affiliation = {Parque, V (Corresponding Author), Hiroshima Univ, Grad Sch Adv Sci \& Engn, 1-4-1 Kagamiyama, Higashihiroshima, Japan.
