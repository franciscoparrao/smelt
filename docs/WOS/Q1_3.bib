@article{ WOS:001704331400001,
Author = {Karizaky, Hamide Sarvary and Ebadzadeh, Mohammad Mehdi},
Title = {Dynamic cooperative genetic programming for synergistic feature
   construction in classification problems},
Journal = {APPLIED SOFT COMPUTING},
Year = {2026},
Volume = {193},
Month = {MAY},
Abstract = {This paper introduces Dynamic Cooperative Genetic Programming (DCGP), a
   novel method designed to enhance pattern classification accuracy by
   constructing and selecting high-quality features. DCGP employs a problem
   decomposition strategy that divides the feature construction task into
   smaller subcomponents, each represented by a subpopulation. These
   subpopulations are formed dynamically through clustering, which enables
   efficient search-space exploration and promotes feature diversity.
   Feature evaluation is based on two main criteria: the synergy criterion,
   which captures interactions among features, and mutual information,
   which measures each feature's relevance to the target class. A random
   crossover operator further enhances diversity and prevents premature
   convergence. DCGP is evaluated on 17 benchmark datasets, encompassing
   both binary and multi-class tasks. It achieves competitive or superior
   accuracy compared to 20 state-of-the-art methods, including classical
   classifiers, multi-tree GP variants, Random Forests, and deep learning
   models for tabular data. On average, DCGP reduces the number of selected
   features by over 13\% while improving accuracy by 11\%. Moreover, the
   evolved features are explicit and interpretable, offering deeper
   insights into the underlying data relationships.},
Type = {Article},
Affiliation = {Ebadzadeh, MM (Corresponding Author), Amirkabir Univ Technol, Tehran Polytech, Dept Comp Engn \& Informat Technol, Tehran, Iran.
   Karizaky, Hamide Sarvary; Ebadzadeh, Mohammad Mehdi, Amirkabir Univ Technol, Tehran Polytech, Dept Comp Engn \& Informat Technol, Tehran, Iran.},
DOI = {10.1016/j.asoc.2026.114854},
Article-Number = {114854},
Keywords = {Genetic programming; Cooperative co-evolution; Feature construction;
   Feature selection; Dynamic clustering; Multi-class classification},
Keywords-Plus = {MULTIPLE-FEATURE CONSTRUCTION; AUTOENCODER; CLASSIFIERS; ALGORITHMS},
Author-Email = {h.sarvari@aut.ac.ir
   ebadzadeh@aut.ac.ir},
Number-of-Cited-References = {111},
Times-Cited = {0},
Unique-ID = {WOS:001704331400001},
}

@article{ WOS:001670286600001,
Author = {Topcuoglu, Hincal and Evren, Atif and Tuna, Elif and Ustaoglu, Erhan},
Title = {LAFS: A Fast, Differentiable Approach to Feature Selection Using
   Learnable Attention},
Journal = {ENTROPY},
Year = {2025},
Volume = {28},
Number = {1},
Month = {DEC 24},
Abstract = {Feature selection is a critical preprocessing step for mitigating the
   curse of dimensionality in machine learning. Existing methods present a
   difficult trade-off: filter methods are fast but often suboptimal as
   they evaluate features in isolation, while wrapper methods are powerful
   but computationally prohibitive due to their iterative nature. In this
   paper, we propose LAFS (Learnable Attention for Feature Selection), a
   novel, end-to-end differentiable framework that achieves the performance
   of wrapper methods at the speed of simpler models. LAFS employs a neural
   attention mechanism to learn a context-aware importance score for all
   features simultaneously in a single forward pass. To encourage the
   selection of a sparse and non-redundant feature subset, we introduce a
   novel hybrid loss function that combines the standard classification
   objective with an information-theoretic entropic regularizer on the
   attention weights. We validate our approach on real-world
   high-dimensional benchmark datasets. Our experiments demonstrate that
   LAFS successfully identifies complex feature interactions and handles
   multicollinearity. In general comparison, LAFS achieves very close and
   accurate results to state-of-the-art RFE-LGBM and embedded FSA methods.
   Our work establishes a new point on the accuracy-efficiency frontier,
   demonstrating that attention-based architectures provide a compatible
   solution to the feature selection problem.},
Type = {Article},
Affiliation = {Topçuoglu, H (Corresponding Author), Yildiz Tech Univ, Fac Sci \& Literature, Dept Stat, TR-34210 Istanbul, Turkiye.
   Topcuoglu, Hincal; Evren, Atif; Tuna, Elif, Yildiz Tech Univ, Fac Sci \& Literature, Dept Stat, TR-34210 Istanbul, Turkiye.
   Ustaoglu, Erhan, Marmara Univ, Fac Management, Dept Informat, TR-34180 Istanbul, Turkiye.},
DOI = {10.3390/e28010020},
Article-Number = {20},
Keywords = {feature selection; attention mechanism; information theory; deep
   learning; tabular data},
Author-Email = {hincal.topcuoglu@std.yildiz.edu.tr
   aevren@yildiz.edu.tr
   eozturk@yildiz.edu.tr
   erhan.ustaoglu@marmara.edu.tr},
Number-of-Cited-References = {32},
Times-Cited = {0},
Unique-ID = {WOS:001670286600001},
}

@incollection{ WOS:000555729900115,
Author = {Grari, Vincent and Ruf, Boris and Lamprier, Sylvain and Detyniecki,
   Marcin},
Editor = {Wang, J and Shim, K and Wu, X},
Title = {Fair Adversarial Gradient Tree Boosting},
Booktitle = {2019 19TH IEEE INTERNATIONAL CONFERENCE ON DATA MINING (ICDM 2019)},
Series = {IEEE International Conference on Data Mining},
Year = {2019},
Pages = {1060-1065},
Abstract = {Fair classification has become an important topic in machine learning
   research. While most bias mitigation strategies focus on neural
   networks, we noticed a lack of work on fair classifiers based on
   decision trees even though they have proven very efficient. In an
   up-to-date comparison of state-of-the-art classification algorithms in
   tabular data, tree boosting outperforms deep learning {[}1]. For this
   reason, we have developed a novel approach of adversarial gradient tree
   boosting. The objective of the algorithm is to predict the output Y with
   gradient tree boosting while minimizing the ability of an adversarial
   neural network to predict the sensitive attribute S. The approach
   incorporates at each iteration the gradient of the neural network
   directly in the gradient tree boosting. We empirically assess our
   approach on 4 popular data sets and compare against state-of-the-art
   algorithms. The results show that our algorithm achieves a higher
   accuracy while obtaining the same level of fairness, as measured using a
   set of different common fairness definitions.},
Type = {Proceedings Paper},
Affiliation = {Grari, V (Corresponding Author), Sorbonne Univ, CNRS, LIP6, Paris, France.
   Grari, Vincent; Lamprier, Sylvain, Sorbonne Univ, CNRS, LIP6, Paris, France.
   Ruf, Boris; Detyniecki, Marcin, AXA, REV Res, Paris, France.},
DOI = {10.1109/ICDM.2019.00124},
Keywords = {Fair machine learning; Adversarial learning; Gradient Tree Boosting},
Author-Email = {vincent.grari@lip6.fr
   boris.ruf@axa.com
   sylvain.lamprier@lip6.fr
   marcin.detyniecki@axa.com},
