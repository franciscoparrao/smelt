   Liu, Shan-xi, Tangsteel Co, Hesteel Grp, Tangshan, Peoples R China.
   Zhang, Hua; An, Chao, Hesteel Grp, Digital Technol Co, Tangshan City, Peoples R China.},
DOI = {10.1177/03019233241283268},
EarlyAccessDate = {SEP 2024},
Keywords = {BOF steelmaking; oxygen blowing amount; machine learning; deep learning;
   SHapley Additive exPlanations; software development},
Keywords-Plus = {STRENGTH},
Author-Email = {txie1516@gmail.com},
Number-of-Cited-References = {42},
Times-Cited = {4},
