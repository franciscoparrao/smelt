@incollection{ WOS:001633263100200,
Author = {Holzmuller, David and Grinsztajn, Leo and Steinwart, Ingo},
Editor = {Globerson, A and Mackey, L and Belgrave, D and Fan, A and Paquet, U and Tomczak, J and Zhang, C},
Title = {Better by Default: Strong Pre-Tuned MLPs and Boosted Trees on Tabular
   Data},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 37 (NEURIPS 2024)},
Series = {Advances in Neural Information Processing Systems},
Year = {2024},
Abstract = {For classification and regression on tabular data, the dominance of
   gradient-boosted decision trees (GBDTs) has recently been challenged by
   often much slower deep learning methods with extensive hyperparameter
   tuning. We address this discrepancy by introducing (a) RealMLP, an
   improved multilayer perceptron (MLP), and (b) strong meta-tuned default
   parameters for GBDTs and RealMLP. We tune RealMLP and the default
   parameters on a meta-train benchmark with 118 datasets and compare them
   to hyperparameter-optimized versions on a disjoint meta-test benchmark
   with 90 datasets, as well as the GBDT-friendly benchmark by Grinsztajn
   et al. (2022). Our benchmark results on medium-to-large tabular datasets
   (1K-500K samples) show that RealMLP offers a favorable time-accuracy
   tradeoff compared to other neural baselines and is competitive with
   GBDTs in terms of benchmark scores. Moreover, a combination of RealMLP
   and GBDTs with improved default parameters can achieve excellent results
   without hyperparameter tuning. Finally, we demonstrate that some of
   RealMLP's improvements can also considerably improve the performance of
   TabR with default parameters.},
Type = {Proceedings Paper},
Affiliation = {Holzmuller, D (Corresponding Author), Inria Paris, SIERRA Team, Paris, France.
   Holzmuller, D (Corresponding Author), Ecole Normale Super, Paris, France.
   Holzmuller, D (Corresponding Author), PSL Univ, Paris, France.
   Holzmuller, David; Grinsztajn, Leo, Inria Paris, SIERRA Team, Paris, France.
   Holzmuller, David, Ecole Normale Super, Paris, France.
   Holzmuller, David, PSL Univ, Paris, France.
   Steinwart, Ingo, Univ Stuttgart, Fac Math \& Phys, Inst Stochast \& Applicat, Stuttgart, Germany.},
