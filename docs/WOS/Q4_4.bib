   Yin, Jie, CSIRO ICT Ctr, Informat Engn Lab, Marsfield, NSW, Australia.
   Hao, Zhifeng, Foshan Univ, Sch Math \& Big Data, Foshan, Peoples R China.},
DOI = {10.1016/j.knosys.2017.01.001},
Keywords = {Data stream; Multiple-instance learning},
