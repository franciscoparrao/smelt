   Hu, Xuegang, Anhui Prov Key Lab Ind Safety \& Emergency Technol, Hefei 230601, Anhui, Peoples R China.},
DOI = {10.1109/ACCESS.2019.2962059},
Keywords = {Data stream mining; multi-label data; multi-label classification},
Keywords-Plus = {EXTREME LEARNING-MACHINE; CONCEPT-DRIFTING DATA; CLASS IMBALANCE;
