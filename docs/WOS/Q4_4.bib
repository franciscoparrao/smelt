   Franco-Marin, Luis, Observ Volcanol Andes Sur, Temuco, Chile.},
DOI = {10.1016/j.jvolgeores.2021.107211},
EarlyAccessDate = {MAR 2021},
Article-Number = {107211},
Keywords = {Adaptive classification; Change detection; Classifier ensemble; Concept
   drift; Incremental learning; Seismic-volcanic signal},
Keywords-Plus = {AUTOMATIC CLASSIFICATION; PATTERN-RECOGNITION; FEATURE-SELECTION;
   NEURAL-NETWORKS; VILLARRICA; CHILE; EVENTS; EXPLOSIONS; LLAIMA; TREMOR},
