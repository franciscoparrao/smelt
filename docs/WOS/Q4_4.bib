Title = {M5P Model Tree in Predicting Student Performance : A Case Study},
Booktitle = {2016 IEEE INTERNATIONAL CONFERENCE ON RECENT TRENDS IN ELECTRONICS,
   INFORMATION \& COMMUNICATION TECHNOLOGY (RTEICT)},
Year = {2016},
Pages = {1103-1107},
Abstract = {In recent developments, Educational institutions seeking and persisting
   best performance from the students. So the Educational Institutions are
   striving to enhance the performance of students in academics. In this
   paper a decision tree induction approach called Multivariate Regression
   prediction model M5P has been used for predicting performance of
   students based on relevant terms such as online-learning skills,
   problem-solving efficiency, time management, intention of doing higher
   studies, adaptable nature, sports participation, day-scholar,
   self-learning, time spent on social networks, versatility nature,
   library usage, and practical knowledge. For evaluating the proposed
   model sample data is collected from 307 students of third year Computer
   Science and Engineering under graduates, in India. The outcome shown in
   this proposed model yields better accuracy with 97.17\% when compared
   with other four models. With this model performance of students can be
   predicted early in the semester and necessary remedial measures can be
   taken to improve the performance of students.},
