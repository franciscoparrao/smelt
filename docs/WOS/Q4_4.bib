   Ng, Wee-Keong, Nanyang Technol Univ, Sch Comp Engn, Singapore 639798, Singapore.},
DOI = {10.1007/s10115-014-0808-1},
Keywords = {Data stream mining; Clustering; Classification; Survey},
Keywords-Plus = {SELF-ORGANIZING MAP; ALGORITHMS; EVOLUTION; ENSEMBLE; TRACKING},
