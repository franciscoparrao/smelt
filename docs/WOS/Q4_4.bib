   Felix, Lucca M., Univ Fed Rio de Janeiro, DCC, Rio De Janeiro, RJ, Brazil.
   Lima, Priscila M. V., Univ Fed Rio de Janeiro, NCE, Rio De Janeiro, RJ, Brazil.},
DOI = {10.1016/j.neucom.2019.12.134},
Keywords = {Regression WiSARD; WiSARD; ClusWiSARD; n-Tuple classifier; n-Tuple
   Regression Network; Ensemble; Online learning},
Author-Email = {lusquino@cos.ufrj.br},
