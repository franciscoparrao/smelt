   Guan, Xiaohong, Tsinghua Univ, Ctr Intelligent \& Networked Syst, Beijing 100084, Peoples R China.},
DOI = {10.1016/j.apenergy.2013.03.038},
Keywords = {Wind energy; Probabilistic forecasting; Gaussian process regression;
