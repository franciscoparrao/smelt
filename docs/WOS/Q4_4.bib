DOI = {10.1007/s10489-022-03414-6},
EarlyAccessDate = {APR 2022},
Keywords = {Multi-label; Classification; Incremental learning; Streaming scene; Deep
   forest},
Keywords-Plus = {CLASSIFIERS; ENSEMBLES},
