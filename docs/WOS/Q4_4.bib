   Zhu, Tuanfei, Changsha Univ, Coll Comp Engn \& Appl Math, Changsha 410000, Hunan, Peoples R China.},
DOI = {10.1016/j.knosys.2020.105694},
Article-Number = {105694},
Keywords = {Data stream classification; Concept drift; Class imbalance; Ensemble},
Keywords-Plus = {SMOTE},
