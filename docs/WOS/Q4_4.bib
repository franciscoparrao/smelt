   Sousa, Pedro A. C., Univ Nova Lisboa, Fac Ciencias \& Tecnol, P-1200 Lisbon, Portugal.},
Keywords = {Collaborative Data Stream Mining; Context-awareness; Concept Drift;
   Ubiquitous Knowledge Discovery},
Keywords-Plus = {DRIFT},
Author-Email = {joao.bartolo.gomes@alumnos.upm.es
   mohamed.gaber@port.ac.uk
   pas@fct.unl.pt
   emenasalvas@fi.upm.es},
Number-of-Cited-References = {26},
