   Sabourin, Robert, Ecole Technol Super, Montreal, PQ, Canada.},
DOI = {10.1016/j.inffus.2020.09.004},
Keywords = {Dynamic ensemble selection; Imbalanced data; Data stream; Data
   preprocessing; Concept drift},
Keywords-Plus = {WEIGHTED MAJORITY; MINORITY CLASS; MACHINE; SMOTE; COMPETENCE; DIVERSITY},
Author-Email = {michal.wozniak@pwr.edu.pl},
Number-of-Cited-References = {69},
