   Shao, Junming, Univ Elect Sci \& Technol China, Shenzhen Inst Adv Study, Shenzhen 518067, Peoples R China.},
DOI = {10.1109/TCYB.2025.3612885},
EarlyAccessDate = {OCT 2025},
Keywords = {Concept drift; contrastive learning; contrastive learning; data stream;
   data stream; micro-cluster (MC); semi-supervised learning;
   semi-supervised learning},
Keywords-Plus = {ENSEMBLE},
