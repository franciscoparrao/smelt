DOI = {10.1371/journal.pone.0093600},
Article-Number = {e93600},
Keywords-Plus = {CONTRAST-ENHANCED MRI; DIFFUSION-WEIGHTED MRI; INTENSITY NONUNIFORMITY;
   TEXTURAL FEATURES; CANCER; ENSEMBLE; SEGMENTATION; INHOMOGENEITY;
   LOCALIZATION; DIAGNOSIS},
Author-Email = {fernandogarcia.jm@gmail.com},
Number-of-Cited-References = {80},
