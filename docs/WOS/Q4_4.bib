@article{ WOS:001507578600002,
Author = {de Carvalho, Halcyon Davys P. and de Oliveira, Joao Fausto L. and
   Fagundes, Roberta Andrade de A.},
Title = {Dynamic selection of ensemble-based regression models: Systematic
   literature review},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {290},
Month = {SEP 25},
Abstract = {Dynamic selection techniques have emerged as a promising approach to
   enhance ensemble-based regression methods, offering adaptive solutions
   for dynamic and heterogeneous data. This study presents a comprehensive
   Systematic Literature Review (SLR) on dynamic selection in regression
   models, aiming to investigate how these techniques can improve
   predictive effectiveness across various contexts. The review encompassed
   21 primary empirical studies published between 2015 and 2024, addressing
   six research questions (RQs) covering models used, evaluation metrics,
   implementation strategies, and performance criteria. The findings
   highlight the use of 59 distinct models and 26 evaluation metrics, such
   as RMSE, MAE, and R2, applied across 144 datasets from domains including
   healthcare, energy, finance, and time series forecasting. Four main
   categories of dynamic selection techniques were identified: Dynamic
   Selection (DS), Dynamic Weighting (DW), Dynamic Weighting with Selection
   (DWS), and Optimization-Based Methods. These approaches demonstrated
   significant improvements in accuracy, robustness, and scalability,
   particularly in scenarios involving noise, data imbalance, and concept
   drift. However, challenges such as high computational costs and the lack
   of unified evaluation frameworks remain. This study provides a
   consolidated foundation for researchers and practitioners seeking to
   explore and apply dynamic selection techniques, highlighting promising
   avenues for future research, including integration with deep learning
   and distributed systems.},
Type = {Review},
Affiliation = {de Carvalho, HDP (Corresponding Author), Univ Pernambuco, Rua Benf 455, BR-50720001 Recife, PE, Brazil.
   de Carvalho, Halcyon Davys P.; de Oliveira, Joao Fausto L.; Fagundes, Roberta Andrade de A., Univ Pernambuco, Rua Benf 455, BR-50720001 Recife, PE, Brazil.},
DOI = {10.1016/j.eswa.2025.128429},
EarlyAccessDate = {JUN 2025},
Article-Number = {128429},
Keywords = {Machine learning; Ensemble; Dynamic ensemble; Dynamic selection},
Keywords-Plus = {FRAMEWORK},
Author-Email = {hdpc@ecomp.poli.br
   fausto.lorenzato@upe.br
   roberta.fagundes@upe.br},
Number-of-Cited-References = {51},
Times-Cited = {7},
Unique-ID = {WOS:001507578600002},
}

@article{ WOS:001397806100033,
Author = {Ghosh, Ananya and Chaki, Jyotismita},
Title = {Fuzzy Enhanced Kidney Tumor Detection: Integrating Machine Learning
   Operations for a Fusion of Twin Transferable Network and Weighted
   Ensemble Machine Learning Classifier},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {7135-7159},
Abstract = {Kidney tumors, often asymptomatic, can lead to serious health problems
   if left undiagnosed. This study tackles the crucial issue of kidney
   tumor detection using CT scans. The proposed approach leverages the
   power of image enhancement using fuzzy systems, deep learning, and
   machine learning for automated kidney tumor detection in CT images. The
   study proposes a fuzzy inference system to enhance kidney CT image
   contrast. This system analyzes image data and uses fuzzy logic to adjust
   pixel intensities, aiming to improve the distinction between features in
   the image without creating over-enhancement. Two pre-trained deep
   convolutional neural networks (PT-DCNNs), DenseNet121 and ResNet101, are
   used to extract features from the enhanced CT images. These features
   capture essential characteristics that differentiate between normal and
   tumor-containing scans. Combining features from twin PT-DCNNs (ensemble
   approach) creates a richer representation of the image content. The
   informative features are fed into a combined classifier where Support
   Vector Machines and Random Forests are combined using a weighted average
   to achieve the final and potentially more robust classification of
   kidney tumors. To improve training, we amplified the original dataset by
   creating variations with added noise and artificial modifications to
   simulate real-world image imperfections. The integration of Machine
   Learning Operations practices ensures the scalability, reproducibility,
   and clinical deployment of the system. The model achieved an impressive
   accuracy of 99.2\% on high-quality images and 98.5\% on noisy images,
   surpassing traditional methods. This automated approach can assist
   urologists in confirming the presence of kidney tumors, minimizing human
   error during physical inspection and potentially leading to improved
   patient outcomes.},
Type = {Article},
Affiliation = {Chaki, J (Corresponding Author), Vellore Inst Technol, Sch Comp Sci \& Engn, Vellore 632014, India.
   Ghosh, Ananya; Chaki, Jyotismita, Vellore Inst Technol, Sch Comp Sci \& Engn, Vellore 632014, India.},
DOI = {10.1109/ACCESS.2025.3526272},
Keywords = {Kidney; Tumors; Computed tomography; Machine learning; Feature
   extraction; Accuracy; Training; Predictive models; Deep learning;
   Streaming media; Deep neural network; ensemble learning; kidney tumor;
   machine learning; transfer learning},
Keywords-Plus = {SYSTEM},
Author-Email = {jyotismita@vit.ac.in},
Number-of-Cited-References = {39},
Times-Cited = {7},
Unique-ID = {WOS:001397806100033},
}

@article{ WOS:001354743800017,
Author = {Yun, Fan and Yu, Zhiwen and Yang, Kaixiang and Chen, C. L. Philip},
Title = {AdaBoost-Stacking Based on Incremental Broad Learning System},
Journal = {IEEE TRANSACTIONS ON KNOWLEDGE AND DATA ENGINEERING},
Year = {2024},
Volume = {36},
Number = {12},
Pages = {7585-7599},
Month = {DEC},
Abstract = {Due to the advantages of fast training speed and competitive
   performance, Broad Learning System (BLS) has been widely used for
   classification tasks across various domains. However, the random weight
   generation mechanism in BLS makes the model unstable, and the
   performance of BLS may be limited when dealing with some complex
   datasets. On the other hand, the instability of BLS brings diversity to
   ensemble learning, and ensemble methods can also reduce the variance and
   bias of the single BLS. Therefore, we propose an ensemble learning
   algorithm based on BLS, which includes three modules. To improve the
   stability and generalization ability of BLS, we utilize BLS as the base
   classifier in an AdaBoost framework first. Taking advantage of the
   incremental learning mechanism of BLS, we then propose a selective
   ensemble method to raise the accuracy and diversity of the BLS ensemble
   method. In addition, based on the former selective Adaboost framework,
   we suggest a hierarchical ensemble algorithm, which combines sample and
   feature dimensions to further improve the fitting ability of the
   ensemble BLS. Extensive experiments have demonstrated that the proposed
   method performs better than the original BLS and other state-of-the-art
   models, proving the effectiveness and versatility of our proposed
   approaches.},
Type = {Article},
Affiliation = {Yu, ZW (Corresponding Author), South China Univ Technol, Sch Comp Sci \& Engn, Guangzhou 510006, Peoples R China.
   Yu, ZW (Corresponding Author), Pengcheng Lab, Shenzhen 518000, Peoples R China.
