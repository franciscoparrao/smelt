Keywords = {transfer learning; clinical prediction model; performance drift; concept
   drift; acute kidney injury},
Keywords-Plus = {ACUTE KIDNEY INJURY; AKI},
Author-Email = {henryhu200211@163.com},
Number-of-Cited-References = {42},
