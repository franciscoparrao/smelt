@article{ WOS:000761758600002,
Author = {Yin, Jiao and Tang, MingJian and Cao, Jinli and Wang, Hua and You,
   Mingshan},
Title = {A real-time dynamic concept adaptive learning algorithm for
   exploitability prediction},
Journal = {NEUROCOMPUTING},
Year = {2022},
Volume = {472},
Pages = {252-265},
Month = {FEB 1},
Abstract = {Exploitability prediction has become increasingly important in
   cybersecurity, as the number of disclosed software vulnerabilities and
   exploits are soaring. Recently, machine learning and deep learning
   algo-rithms, including Support Vector Machine (SVM), Decision Tree, deep
   Neural Networks and their ensem-ble models, have achieved great success
   in vulnerability evaluation and exploitability prediction. However, they
   make a strong assumption that the data distribution is static over time
   and therefore fail to consider the concept drift problems due to the
   evolving system behaviours. In this work, we propose a novel consecutive
   batch learning algorithm, called Real-time Dynamic Concept Adaptive
   Learning (RDCAL), to deal with the concept drift and dynamic class
   imbalance problems existing in exploitability prediction. Specifically,
   we develop a Class Rectification Strategy (CRS) to handle the `actual
   drift' in sam-ple labels and a Balanced Window Strategy (BWS) to boost
   the minority class during real-time learning. Experimental results
   conducted on the real-world vulnerabilities collected between 1988 to
   2020 show that the overall performance of classifiers, including Neural
   Networks, SVM, HoeffdingTree and Logistic Regression (LR), improves over
   3\% by adopting our proposed RDCAL algorithm. Furthermore, RDCAL
   achieves state-of-the-art performance on exploitability prediction
   compared with other concept drift algorithms. (c) 2021 Elsevier B.V. All
   rights reserved.},
Type = {Article},
Affiliation = {Cao, JL (Corresponding Author), La Trobe Univ, Dept Comp Sci \& Informat Technol, Melbourne, Vic 3083, Australia.
   Yin, Jiao; Cao, Jinli, La Trobe Univ, Dept Comp Sci \& Informat Technol, Melbourne, Vic 3083, Australia.
   Yin, Jiao, Chongqing Univ Arts \& Sci, Sch Artificial Intelligence, Chongqing 402160, Peoples R China.
   Tang, MingJian, Huawei Technol Co Ltd, Shenzhen 518129, Peoples R China.
   Wang, Hua, Victoria Univ, Inst Sustainable Ind \& Liveable Cities, Melbourne, Vic 3083, Australia.
   You, Mingshan, Hunan Univ, Coll Informat Sci \& Engn, Changsha 410082, Hunan, Peoples R China.},
DOI = {10.1016/j.neucom.2021.01.144},
Keywords = {Real-time learning; Concept drift; Class imbalance; Class rectification;
   Balanced window},
Keywords-Plus = {ENSEMBLE; CLASSIFICATION},
Author-Email = {j.cao@latrobe.edu.au},
Number-of-Cited-References = {37},
Times-Cited = {13},
