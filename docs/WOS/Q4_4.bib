DOI = {10.1007/s10758-021-09583-6},
EarlyAccessDate = {JAN 2022},
Keywords = {Online learning; Learning analytics; Final performance; Self-regulated
   learning; Technical skills; Motivation and attitude},
Keywords-Plus = {ONE-SIZE-FITS; HIGHER-EDUCATION; SELF-REGULATION; MOTIVATION; STUDENTS;
   READINESS; MODEL; ACHIEVEMENT; PREDICTORS; HYPERMEDIA},
