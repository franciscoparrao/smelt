   Qu, Youyang, Deakin Univ, Sch Informat Technol, Melbourne, Vic 3125, Australia.},
DOI = {10.1007/s10489-022-03556-7},
EarlyAccessDate = {JUN 2022},
Keywords = {Deep learning; Incremental learning; Ensemble learning; Distillation
   loss; Image classification},
Author-Email = {xiegang@tyut.edu.cn},
Number-of-Cited-References = {31},
