@article{ WOS:000445954400006,
Author = {Zhang, Yong and Yu, Jiaxin and Liu, Wenzhe and Ota, Kaoru},
Title = {Ensemble Classification for Skewed Data Streams Based on Neural Network},
Journal = {INTERNATIONAL JOURNAL OF UNCERTAINTY FUZZINESS AND KNOWLEDGE-BASED
   SYSTEMS},
Year = {2018},
Volume = {26},
Number = {5},
Pages = {839-853},
Month = {OCT},
Abstract = {Data stream learning in non-stationary environments and skewed class
   distributions has been receiving more attention in machine learning
   communities. This paper proposes a novel ensemble classification method
   (ECSDS) for classifying data streams with skewed class distributions. In
   the proposed ensemble method, back-propagation neural network is
   selected as the base classifier. In order to demonstrate the
   effectiveness of our proposed method, we choose three baseline methods
   based on ECSDS and evaluate their overall performance on ten datasets
   from UCI machine learning repository. Moreover, the performance of
   incremental learning is also evaluated by these datasets. The
   experimental results show our proposed method can effectively deal with
   classification problems on non-stationary data streams with class
   imbalance.},
