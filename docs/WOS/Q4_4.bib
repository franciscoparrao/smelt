   Wang, Guanjin, Murdoch Univ, Sch Informat Technol, Murdoch, WA 6150, Australia.},
DOI = {10.1109/TII.2025.3547056},
EarlyAccessDate = {MAR 2025},
Keywords = {Incremental learning; Accuracy; Sensors; Training; Medical services;
   Linguistics; Feature extraction; Testing; Random forests; Sensor
   phenomena and characterization; Human activity recognition;
   Takagi-Sugeno-Kang (TSK) fuzzy classifiers; ensemble learning;
   generalization; linguistic interpretability; incremental learning},
Keywords-Plus = {HUMAN ACTIVITY RECOGNITION; MACHINE; ELM},
Author-Email = {7201607003@stu.jiangnan.edu.cn
