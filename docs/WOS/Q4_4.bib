   Chen, Yin-Kai; Yang, Wei-Pang, Natl Dong Hwa Univ, Dept Informat Management, Hualien, Taiwan.
   Chu, Ko-Tsung, Minghsin Univ Sci \& Technol, Dept Finance, Hsinchu, Taiwan.
   Tang, Jih-Hsin, Natl Taipei Univ Business, Dept Informat Management, Taipei, Taiwan.},
DOI = {10.1002/sec.1584},
Keywords = {spam; data mining; decision tree},
Keywords-Plus = {CONCEPT DRIFT},
Author-Email = {ktc1009@must.edu.tw},
Number-of-Cited-References = {34},
Times-Cited = {8},
