@article{ WOS:000929422800001,
Author = {Wunnasri, Warunya and Musikawan, Pakarat and So-In, Chakchai},
Title = {A Two-Phase Ensemble-Based Method for Predicting Learners' Grade in
   MOOCs},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2023},
Volume = {13},
Number = {3},
Month = {FEB},
Abstract = {MOOCs are online learning environments which many students use, but the
   success rate of online learning is low. Machine learning can be used to
   predict learning success based on how people learn in MOOCs. Predicting
   the learning performance can promote learning through various methods,
   such as identifying low-performance students or by grouping students
   together. Recent machine learning has enabled the development of
   predictive models, and the ensemble method can assist in reducing the
   variance and bias errors associated with single-machine learning. This
   study uses a two-phase classification model with an ensemble technique
   to predict the learners' grades. In the first phase, binary
   classification is used, and the non-majority class is then sent to the
   second phase, which is multi-class classification. The new features are
   computed based on the distance from the class's center. The distance
   between the data and the center of an overlapping cluster is calculated
   using silhouette score-based feature selection. Lastly, Bayesian
   optimization boosts the performance by fine tuning the optimal parameter
   set. Using data from the HMPC- and the CNPC datasets, the experiment
   results demonstrate that the proposed design, the two-phase
   ensemble-based method, outperforms the state-of-the-art machine learning
   algorithms.},
Type = {Article},
Affiliation = {Wunnasri, W (Corresponding Author), Khon Kaen Univ, Coll Comp, Dept Comp Sci, Khon Kaen 40002, Thailand.
   Wunnasri, Warunya; Musikawan, Pakarat; So-In, Chakchai, Khon Kaen Univ, Coll Comp, Dept Comp Sci, Khon Kaen 40002, Thailand.},
DOI = {10.3390/app13031492},
Article-Number = {1492},
Keywords = {learning performance; grade prediction; MOOC; imbalance data; ensemble
   method},
Author-Email = {waruwu@kku.ac.th},
Number-of-Cited-References = {35},
Times-Cited = {6},
Unique-ID = {WOS:000929422800001},
}

@incollection{ WOS:001161549503073,
Author = {Abadifard, Soheil and Bakhshi, Sepehr and Gheibuni, Sanaz and Can, Fazli},
Book-Group-Author = {ACM},
Title = {DynED: Dynamic Ensemble Diversification in Data Stream Classification},
Booktitle = {PROCEEDINGS OF THE 32ND ACM INTERNATIONAL CONFERENCE ON INFORMATION AND
   KNOWLEDGE MANAGEMENT, CIKM 2023},
Year = {2023},
Pages = {3707-3711},
Abstract = {Ensemble methods are commonly used in classification due to their
   remarkable performance. Achieving high accuracy in a data stream
   environment is a challenging task considering disruptive changes in the
   data distribution, also known as concept drift. A greater diversity of
   ensemble components is known to enhance prediction accuracy in such
   settings. Despite the diversity of components within an ensemble, not
   all contribute as expected to its overall performance. This necessitates
   a method for selecting components that exhibit high performance and
   diversity. We present a novel ensemble construction and maintenance
   approach based on MMR (Maximal Marginal Relevance) that dynamically
   combines the diversity and prediction accuracy of components during the
   process of structuring an ensemble. The experimental results on both
   four real and 11 synthetic datasets demonstrate that the proposed
   approach (DynED) provides a higher average mean accuracy compared to the
   five state-of-the-art baselines.},
Type = {Proceedings Paper},
Affiliation = {Abadifard, S (Corresponding Author), Bilkent Univ, Ankara, Turkiye.
   Abadifard, Soheil; Bakhshi, Sepehr; Gheibuni, Sanaz; Can, Fazli, Bilkent Univ, Ankara, Turkiye.},
DOI = {10.1145/3583780.3615266},
Keywords = {Data stream classification; Concept drift; Diversity adjustment;
   Ensemble learning; Ensemble pruning; Maximal Marginal Relevance},
Author-Email = {soheil.abadifard@bilkent.edu.tr
   sepehr.bakhshi@bilkent.edu.tr
   sanaz.gheibuni@bilkent.edu.tr
   canf@cs.bilkent.edu.tr},
