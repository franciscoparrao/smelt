DOI = {10.1016/j.compchemeng.2016.08.017},
Keywords = {Soft sensors; Adaptive mechanisms; Streaming data; Ensemble methods},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; LEAST-SQUARES REGRESSION; ENSEMBLE;
