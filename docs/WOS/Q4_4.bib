   Yang, Weiyi, Mcgill, Dept Biomed Engn, Montreal, PQ H3A 2B4, Canada.},
DOI = {10.1016/j.ins.2022.07.074},
EarlyAccessDate = {AUG 2022},
Keywords = {Arrhythmia; Broad learning system (BLS); Class -specific weighted broad
   learning; system (CSWBLS); Imbalanced heartbeat classification;
   Incremental learning},
Keywords-Plus = {CONVOLUTIONAL NEURAL-NETWORK; ECG; FEATURES; RECOGNITION; ENSEMBLE;
   MIXTURE; HOG},
Author-Email = {siyj@jlu.edu.cn},
Number-of-Cited-References = {50},
