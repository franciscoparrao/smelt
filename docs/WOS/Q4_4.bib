@incollection{ WOS:000393510400024,
Author = {Fong, Simon and Zhuang, Yan and Wong, Raymond and Mohammed, Sabah},
Editor = {Deb, S and Serguieva, A and Fong, S},
Title = {A Scalable Data Stream Mining Methodology: Stream-based Holistic
   Analytics and Reasoning in Parallel},
Booktitle = {PROCEEDINGS OF 2014 2ND INTERNATIONAL SYMPOSIUM ON COMPUTATIONAL AND
   BUSINESS INTELLIGENCE (ISCBI)},
Year = {2014},
Pages = {110-115},
Abstract = {Big Data though it is a hype up-springing many technical challenges that
   confront both academic research communities and commercial IT
   deployment, the root sources of Big Data are founded on data streams. It
   is generally known that data which are sourced from data streams
   accumulate continuously making traditional batch-based model induction
   algorithms infeasible for real-time data mining or high-speed data
   analytics in a broad sense. In this paper, a novel data stream mining
   methodology, called Stream-based Holistic Analytics and Reasoning in
   Parallel (SHARP) is proposed. SHARP is based on principles of
   incremental learning which span across a typical data-mining model
   construction process, from lightweight feature selection, one-pass
   incremental decision tree induction, and incremental swarm optimization.
   Each one of these components in SHARP is designed to function together
   aiming at improving the classification/prediction performance to its
   best possible. SHARP is scalable, that depends on the available
   computing resources during runtime, the components can execute in
   parallel, collectively enhancing different aspects of the overall SHARP
   process for mining data streams. It is believed that if Big Data are
   being mined by incrementally learning a data mining model, one pass at a
   time on the fly, the large volume of such big data is no longer a
   technical issue, from the perspective of data analytics. Three computer
   simulation experimentations are shown in this paper, pertaining to three
   components of SHARP, for demonstrating its efficacy.},
Type = {Proceedings Paper},
Affiliation = {Fong, S (Corresponding Author), Univ Macau, Dept Comp \& Informat Sci, Macau, Peoples R China.
   Fong, Simon; Zhuang, Yan, Univ Macau, Dept Comp \& Informat Sci, Macau, Peoples R China.
   Wong, Raymond, Univ New South Wales, Sch Comp Sci \& Engn, Kensington, NSW 2052, Australia.
   Mohammed, Sabah, Lakehead Univ, Dept Comp Sci, Thunder Bay, ON P7B 5E1, Canada.},
DOI = {10.1109/ISCBI.2014.31},
Keywords = {Data stream mining methodology; Cache-based data stream classifier; CCV
   feature selection; Meta-heusristics},
Keywords-Plus = {FEATURE-SELECTION},
Author-Email = {ccfong@umac.mo
   syz@umac.mo
   wong@cse.unsw.edu.au
   mohammed@lakeheadu.ca},
Number-of-Cited-References = {16},
Times-Cited = {3},
Unique-ID = {WOS:000393510400024},
}

@incollection{ WOS:000345642100007,
Author = {Waiyamai, Kitsana and Kangkachit, Thanapat and Saengthongloun, Bordin
   and Rakthanmanon, Thanawin},
Editor = {Perner, P},
Title = {ACCD: Associative Classification over Concept-Drifting Data Streams},
Booktitle = {MACHINE LEARNING AND DATA MINING IN PATTERN RECOGNITION, MLDM 2014},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2014},
Volume = {8556},
Pages = {78-90},
Abstract = {Associative classification has shown good result over many
   classification techniques on static datasets. However, little work has
   been done on associative classification over data streams. Different
   from data in traditional static databases, data streams typically arrive
   continuously and unboundedly with occasionally changing data
   distribution known as concept drift. In this paper, we propose a new
   Associative Classification over Concept-Drifting data streams, ACCD.
   ACCD is able to accurately detect concept drift in data streams and
   reduce its effect by using an ensemble of classifiers. A mechanism for
   statistical accuracy bounds estimation is used for supporting
   concept-drift detection. With this mechanism, accuracy recovering time
   is decreased and a situation where ensemble of classifiers drops
   accuracy is avoided. Compared to AC-DS (first technique on associative
   classification algorithm over data streams), AUEH (Accuracy updated
   ensemble with Hoeffding tree) and VFDT(Very Fast Decision Trees) on 4
   real-world data stream datasets, ACCD exhibits the best performance in
   terms of accuracy.},
Type = {Proceedings Paper},
Affiliation = {Waiyamai, K (Corresponding Author), Kasetsart Univ, Dept Comp Engn, Bangkok, Thailand.
   Waiyamai, Kitsana; Kangkachit, Thanapat; Saengthongloun, Bordin; Rakthanmanon, Thanawin, Kasetsart Univ, Dept Comp Engn, Bangkok, Thailand.},
Keywords = {concept drift; changing environments; data streams classification;
   associative classification; multiple class-sssociation rules},
Author-Email = {fengknw@ku.ac.th
   g5185041@ku.ac.th
   g5314550113@ku.ac.th
   thanawin.r@ku.ac.th},
Number-of-Cited-References = {13},
Times-Cited = {3},
Unique-ID = {WOS:000345642100007},
}

@incollection{ WOS:000360999100297,
Author = {Wang, Yongheng and Weyrich, Michael},
Book-Group-Author = {IEEE},
Title = {An adaptive image processing system based on incremental learning for
   industrial applications},
Booktitle = {2014 IEEE EMERGING TECHNOLOGY AND FACTORY AUTOMATION (ETFA)},
Year = {2014},
Abstract = {Machine learning has been applied in image processing system for object
   recognition, inspection and measurement. It assumes that the provided
   training objects are representative enough to the real objects. However
   in real application, new (unlearned) objects always emerge over time,
   which may deviate from the trained (learned) objects. The conventional
   image processing system using machine learning is not able to learn and
   then recognize these new objects.
   In this paper, an incremental learning based image processing system is
   presented. The overall system consists of three layers: execution,
   learning and user. The conventional image processing system is
   constructed in execution layer. In learning layer, adviser and
   incremental learning are applied to generate a new classifier. The
   incremental learning is differentiated into different methodologies:
   data accumulation and ensemble learning. Through the adviser, a proper
   methodology can be recommended. User is able to interact with the system
   via user layer. Comparing to the conventional image processing system,
   the proposed system is robust in industrial applications, since it deals
   with the classification problems dynamically.},
Type = {Proceedings Paper},
Affiliation = {Wang, YH (Corresponding Author), Univ Stuttgart, Inst Ind Automat \& Software Engn, D-70174 Stuttgart, Germany.
   Wang, Yongheng; Weyrich, Michael, Univ Stuttgart, Inst Ind Automat \& Software Engn, D-70174 Stuttgart, Germany.},
Keywords = {adaptive image processing; industrial image processing; machine
   learning; incremental learning},
Keywords-Plus = {ALGORITHM},
Author-Email = {yongheng.wang@ias.uni-stuttgart.de},
Number-of-Cited-References = {14},
Times-Cited = {3},
Unique-ID = {WOS:000360999100297},
}

@article{ WOS:000329048600010,
Author = {Gomes, Joao Bartolo and Gaber, Mohamed Medhat and Sousa, Pedro A. C. and
   Menasalvas, Ernestina},
Title = {COLLABORATIVE DATA STREAM MINING IN UBIQUITOUS ENVIRONMENTS USING
   DYNAMIC CLASSIFIER SELECTION},
Journal = {INTERNATIONAL JOURNAL OF INFORMATION TECHNOLOGY \& DECISION MAKING},
Year = {2013},
Volume = {12},
Number = {6},
Pages = {1287-1308},
Month = {NOV},
Abstract = {In ubiquitous data stream mining, different devices often aim to learn
   concepts that are similar to some extent. In many applications, such as
   spam filtering or news recommendation, the data stream underlying
   concept (e. g., interesting mail/news) is likely to change over time.
   Therefore, the resultant model must be continuously adapted to such
   changes. This paper presents a novel Collaborative Data Stream Mining
   (Coll-Stream) approach that explores the similarities in the knowledge
   available from other devices to improve local classification accuracy.
   Coll-Stream integrates the community knowledge using an ensemble method
   where the classifiers are selected and weighted based on their local
   accuracy for different partitions of the feature space. We evaluate
   Coll-Stream classification accuracy in situations with concept drift,
   noise, partition granularity and concept similarity in relation to the
   local underlying concept. The experimental results show that Coll-Stream
   resultant model achieves stability and accuracy in a variety of
   situations using both synthetic and real-world datasets.},
Type = {Article},
Affiliation = {Gomes, JB (Corresponding Author), ASTAR, Inst Infocomm Res I2R, 1 Fusionopolis Way Connexis, Singapore 138632, Singapore.
   Gomes, Joao Bartolo, ASTAR, Inst Infocomm Res I2R, Singapore 138632, Singapore.
   Gaber, Mohamed Medhat, Robert Gordon Univ, Sch Comp Sci \& Digital Media, Aberdeen AB10 7GJ, Scotland.
   Sousa, Pedro A. C., Univ Nova Lisboa, Fac Ciencias \& Tecnol, P-2825114 Quinta Da Torre, Caparica, Portugal.
   Menasalvas, Ernestina, Univ Politecn Madrid, Fac Informat, E-28660 Madrid, Spain.},
DOI = {10.1142/S0219622013500375},
Keywords = {Collaborative data stream mining; ubiquitous knowledge discovery;
   concept drift; performance evaluation},
Keywords-Plus = {EVOLVING DATA},
Author-Email = {bartologjp@i2r.a-star.edu.sg
   m.gaber1@rgu.ac.uk
   pas@fct.unl.pt
   emenasalvas@fi.upm.es},
Number-of-Cited-References = {33},
