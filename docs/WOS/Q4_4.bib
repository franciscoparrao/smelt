@incollection{ WOS:001221742900043,
Author = {Aasi, Erfan and Cai, Mingyu and Vasile, Cristian-Ioan and Belta, Calin},
Editor = {Pappas, GJ and Matni, N and Morari, M},
Title = {Time-Incremental Learning of Temporal Logic Classifiers Using Decision
   Trees},
Booktitle = {LEARNING FOR DYNAMICS AND CONTROL CONFERENCE, VOL 211},
Series = {Proceedings of Machine Learning Research},
Year = {2023},
Volume = {211},
Abstract = {Real-time and human-interpretable decision-making in autonomous systems
   is a significant but challenging task, which usually requires
   predictions of possible future events from limited data. While machine
   learning techniques have achieved promising results in this field, they
   lack interpretability and the ability to make online predictions for
   sequential behaviors. In this paper, we introduce a time-incremental
   learning framework to predict the labels of time-series signals that are
   received incrementally over time, referred to as prefix signals. These
   signals are being observed as they are generated, and their time lengths
   are shorter than their corresponding time horizons. We present a novel
   decision tree-based approach to learn a finite number of Signal Temporal
   Logic (STL) specifications from a given dataset and construct a
   predictor based on them. Each STL specification serves as a binary
   classifier of the time-series data and captures a specific part of the
   dataset's temporal properties over time. The predictor is built by
   assigning time-variant weights to the STL formulas, which represent
   their classification impacts. The weights are learned using neural
   networks to minimize the misclassification rate of classifying prefix
   signals with different time lengths. The predictor is then used to
   predict the labels of prefix signals by computing the weighted sum of
   their robustnesses with respect to the STL formulas. The effectiveness
   and classification performance of our algorithm is evaluated on
   urban-driving and naval-surveillance case studies.},
Type = {Proceedings Paper},
Affiliation = {Aasi, E (Corresponding Author), Boston Univ, Boston, MA 02215 USA.
   Aasi, Erfan; Belta, Calin, Boston Univ, Boston, MA 02215 USA.
   Cai, Mingyu; Vasile, Cristian-Ioan, Lehigh Univ, Bethlehem, PA 18015 USA.},
Keywords = {Machine Learning; Formal Methods; Decision Trees},
Keywords-Plus = {ROBUSTNESS; DESIGN},
Author-Email = {EAASI@BU.EDU
   MIC221@LEHIGH.EDU
   CVASILE@LEHIGH.EDU
   CBELTA@BU.EDU},
Number-of-Cited-References = {32},
Times-Cited = {2},
Unique-ID = {WOS:001221742900043},
}

@article{ WOS:001318379200012,
Author = {Arik, Kaan},
Title = {Machine Learning Models on MOBA Gaming: League of Legends Winner
   Prediction},
Journal = {ACTA INFOLOGICA},
Year = {2023},
Volume = {7},
Number = {1},
Abstract = {The entertainment industry includes companies engaged in
   telecommunications services, television, music streaming, video games,
   and live events. Gaming has gained momentum in revenue growth in the
   entertainment industry over the past decade. This momentum has made the
   gaming industry one of the most popular areas of the entertainment
   industry. Official leagues have been teamed up with professional
   players, and the concept of e-sports has become widespread. MOBA
   (Multiplayer Online Battle Arena), which is a derivative of MMO
   (massively multiplayer online) games, is the name given to the games
   played on the Internet in which players destroy the opponent's base by
   dominating specific objectives on a map, usually with two teams of five
   players each. LoL (League of Legends) is one of the most popular MOBA
   games. Predicting winners in online games has become an essential
   application for machine learning models. This research aims to predict
   classification with machine learning methods of match winner with LoL
   player metrics. Key performance metrics and their impact on each game
   model were analyzed. The results show that winner prediction is possible
   in League of Legends, also, LightGBM (0.97), Logistic Regression (0.96),
   SVM and GBC (Gradient Boosting Classifier) (0.95) are outperformed with
   a high accuracy ratio. This paper will contribute to the classification
   research on topic of gaming with machine learning},
Type = {Article},
Affiliation = {Arik, K (Corresponding Author), Sakarya Appl Sci Univ, Dept Multidimens Modeling \& Animat, Sakarya, Turkiye.
   Arik, Kaan, Sakarya Appl Sci Univ, Dept Multidimens Modeling \& Animat, Sakarya, Turkiye.},
DOI = {10.26650/acin.1180583},
Keywords = {Gaming; classification; machine learning; league of legends; MOBA},
Author-Email = {kaanarik@subu.edu.tr},
Number-of-Cited-References = {30},
Times-Cited = {2},
Unique-ID = {WOS:001318379200012},
}

@article{ WOS:001165038500007,
Author = {Bodyanskiy, V. Ye and Lipianina-Honcharenko, V. Kh. and Sachenko, A. O.},
Title = {ENSEMBLE OF ADAPTIVE PREDICTORS FOR MULTIVARIATE NONSTATIONARY SEQUENCES
   AND ITS ONLINE LEARNING},
Journal = {RADIO ELECTRONICS COMPUTER SCIENCE CONTROL},
Year = {2023},
Number = {4},
Pages = {91-98},
Abstract = {Context. In this research, we explore an ensemble of metamodels that
   utilizes multivariate signals to generate forecasts. The ensemble
   includes various traditional forecasting models such as multivariate
   regression, exponential smoothing, ARIMAX, as well as nonlinear
   structures based on artificial neural networks, ranging from simple
   feedforward networks to deep architectures like LSTM and transformers.
   Objective. A goal of this research is to develop an effective method for
   combining forecasts from multiple models forming metamodels to create a
   unified forecast that surpasses the accuracy of individual models. We
   are aimed to investigate the effectiveness of the proposed ensemble in
   the context of forecasting tasks with nonstationary signals. Method. The
   proposed ensemble of metamodels employs the method of Lagrange
   multipliers to estimate the parameters of the metamodel. The Kuhn-Tucker
   system of equations is solved to obtain unbiased estimates using the
   least squares method. Additionally, we introduce a recurrent form of the
   least squares algorithm for adaptive processing of nonstationary
   signals. Results. The evaluation of the proposed ensemble method is
   conducted on a dataset of time series. Metamodels formed by combining
   various individual models demonstrate improved forecast accuracy
   compared to individual models. The approach shows effectiveness in
   capturing nonstationary patterns and enhancing overall forecasting
   accuracy. Conclusions. The ensemble of metamodels, which utilizes
   multivariate signals for forecast generation, offers a promising
   approach to achieve better forecasting accuracy. By combining diverse
   models, the ensemble exhibits robustness to nonstationarity and the of
   forecasts.},
Type = {Article},
Affiliation = {Bodyanskiy, VY (Corresponding Author), Kharkiv Natl Univ Radio Elect, Artificial Intelligence Dept, Kharkiv, Ukraine.
   Bodyanskiy, V. Ye, Kharkiv Natl Univ Radio Elect, Artificial Intelligence Dept, Kharkiv, Ukraine.
   Lipianina-Honcharenko, V. Kh., West Ukrainian Natl Univ, Dept Informat Comp Syst \& Control, Ternopol, Ukraine.
   Sachenko, A. O., West Ukrainian Natl Univ, Res Inst Intelligent Comp Syst, Ternopol, Ukraine.},
DOI = {10.15588/1607-3274-2023-4-9},
Keywords = {ensemble; metamodels; boosting; bagging; multivariate signals;
   nonstationarity; forecasting},
Number-of-Cited-References = {14},
Times-Cited = {2},
Unique-ID = {WOS:001165038500007},
}

@incollection{ WOS:001165180100101,
Author = {Cao, Zhi and Zhang, Shuyi and Lin, Chin-Teng},
Editor = {Chen, G and Khan, L and Gao, X and Qiu, M and Pedrycz, W and Wu, X},
Title = {Online Ensemble of Ensemble OVA Framework for Class Evolution with
   Dominant Emerging Classes},
Booktitle = {23RD IEEE INTERNATIONAL CONFERENCE ON DATA MINING, ICDM 2023},
Series = {IEEE International Conference on Data Mining},
Year = {2023},
Pages = {968-973},
Abstract = {In real-world data stream mining, the composition of classes undergoes
   unpredictable changes, giving rise to the challenge of class evolution,
   encompassing class emergence, disappearance, and reoccurrence. However,
   most existing approaches require the storage of past data to adapt their
   model. While some studies have focused on online learning approaches,
   they are built on an underlying assumption that the number of instances
   in any single class is consistently less than the sum of other classes.
   This assumption becomes invalid when a class emerges with a dominant
   amount, e.g., news about a pandemic outbreak, harming the performance of
   existing methods. In this paper, we thoroughly investigate this scenario
   and propose a novel online ensemble of ensemble one-versus-all framework
   (EWE) to handle class evolution adaptively. The novel ensemble of
   ensemble architecture boosts diversity in each one-versus-all
   classifier. A novel adaptive model adaptation method is also designed to
   balance the error feedback between the emerging class and the other
   classes. A confidence-triggered fallback mode is integrated to prevent
   performance drop due to a wrong decision regarding class disappearance.
   Experimental studies are conducted on both synthetic and real-world data
   streams to show that our method achieves higher accuracy in diverse
   class evolution scenarios compared with the state-of-the-art method,
   particularly when classes emerge with dominant amounts.},
Type = {Proceedings Paper},
Affiliation = {Cao, Z (Corresponding Author), Southern Univ Sci \& Technol, Dept Comp Sci \& Engn, Shenzhen, Peoples R China.
   Cao, Z (Corresponding Author), Univ Technol, Sch Comp Sci, CIBCI Lab, Sydney, Australia.
   Cao, Zhi; Zhang, Shuyi, Southern Univ Sci \& Technol, Dept Comp Sci \& Engn, Shenzhen, Peoples R China.
   Cao, Zhi; Lin, Chin-Teng, Univ Technol, Sch Comp Sci, CIBCI Lab, Sydney, Australia.
   Zhang, Shuyi, Univ Birmingham, Sch Comp Sci, CERCM, Birmingham, England.},
DOI = {10.1109/ICDM58522.2023.00109},
Keywords = {data stream mining; online learning; class evolution; ensemble model},
Keywords-Plus = {STREAM CLASSIFICATION},
Number-of-Cited-References = {23},
Times-Cited = {2},
Unique-ID = {WOS:001165180100101},
}

