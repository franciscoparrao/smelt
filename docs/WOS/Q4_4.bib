Unique-ID = {WOS:000334105000076},
}

@article{ WOS:001180288300001,
Author = {Chen, Junzhao and You, Jiachun and Wei, Junting and Dai, Zhongkui and
   Zhang, Gulan},
Title = {Interpreting XGBoost predictions for shear-wave velocity using SHAP:
   Insights into gas hydrate morphology and saturation},
Journal = {FUEL},
Year = {2024},
Volume = {364},
Month = {MAY 15},
Abstract = {As an elastic parameter of formations, shear-wave (S-wave) velocity has
   important significance for assessing the morphology and saturation of
   gas hydrates but is often incompletely measured in actual drilling. To
   acquire missing S-wave velocity data for gas hydrate research in the
   Gulf of Mexico Gas Hydrate Joint Industry Project Leg II (GOM JIP Leg
   II), this paper introduces Extreme Gradient Boosting (XGBoost).
   Meanwhile, three additional machine learning models were trained for
   comparative analysis. The results show that XGBoost has better
   predictive performance than Gradient Boosting Decision Tree (GBDT) and
   Ordinary Least Squares (OLS) regression, and is more suitable for the
   small-sample well-log data in this study than Long Short-Term Memory
   (LSTM) networks. Based on this, Shapley Additive Explanations (SHAP)
   were used to explain the importance and specific contributions of
   well-logging parameters in XGBoost, and incremental learning was
   employed to overcome the issue of insufficient data for initial model
   training. Finally, the application of the prediction results provides
   hydrate morphology identification and saturation estimation based on
   S-wave velocity. This research opens a new intelligent path for
   recovering missing S-wave velocity in GOM JIP Leg II and enhances
   in-depth assessment of gas hydrate potential in the region.},
Type = {Article},
Affiliation = {You, JC (Corresponding Author), Chengdu Univ Technol, Coll Geophys, Chengdu 610059, Peoples R China.
   Chen, Junzhao; You, Jiachun; Wei, Junting; Dai, Zhongkui, Chengdu Univ Technol, Coll Geophys, Chengdu 610059, Peoples R China.
   Zhang, Gulan, Southwest Petr Univ, Sch Geosci \& Technol, Chengdu 610500, Peoples R China.},
DOI = {10.1016/j.fuel.2024.131145},
EarlyAccessDate = {FEB 2024},
Article-Number = {131145},
Keywords = {Gas hydrate; Extreme gradient boosting (XGBoost); Shear-wave prediction;
   Shapley additive explanations (SHAP); Saturation},
Keywords-Plus = {MARINE-SEDIMENTS; REGRESSION; MODELS},
Author-Email = {youjiachun@cdut.edu.cn},
Number-of-Cited-References = {83},
Times-Cited = {34},
Unique-ID = {WOS:001180288300001},
}

@article{ WOS:000892924400017,
Author = {Wang, Peng and Xu, Keqi and Ding, Zhaohao and Du, Yuling and Liu, Wenyu
   and Sun, Beibei and Zhu, Zhizhong and Tang, Huidi},
Title = {An Online Electricity Market Price Forecasting Method Via Random Forest},
Journal = {IEEE TRANSACTIONS ON INDUSTRY APPLICATIONS},
Year = {2022},
Volume = {58},
Number = {6},
Pages = {7013-7021},
Month = {NOV},
Abstract = {Electricity price forecasting (EPF) is essential to the bidding strategy
   formulation and market operation. Since EPF is important in the
   electricity market, lots of forecasting approaches are proposed.
   However, the new scene caused by the volatility of renewable power
   generation and other volatility factors has made previous methods
   inaccurate and inapplicable. To address this problem, we propose an
   online self-adaptive forecasting method based on random forest, which is
   different from the traditional batch learning. Our approach takes
   possible fluctuations of the market into consideration, and adapts to
   them by maintaining training sets of different sizes. A case study using
   actual electricity market data has shown that our proposed approach
   obtains higher accuracy than ordinary approaches, as well as sheds light
   on possible concept drift in the market.},
