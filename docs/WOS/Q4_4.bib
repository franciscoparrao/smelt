@article{ WOS:000310143400022,
Author = {Razavi-Far, Roozbeh and Baraldi, Piero and Zio, Enrico},
Title = {Dynamic Weighting Ensembles for Incremental Learning and Diagnosing New
   Concept Class Faults in Nuclear Power Systems},
Journal = {IEEE TRANSACTIONS ON NUCLEAR SCIENCE},
Year = {2012},
Volume = {59},
Number = {5, 3},
Pages = {2520-2530},
Month = {OCT},
Abstract = {Key requirements for the practical implementation of empirical
   diagnostic systems are the capabilities of incremental learning of new
   information that becomes available, detecting novel concept classes and
   diagnosing unknown faults in dynamic applications. In this paper, a
   dynamic weighting ensembles algorithm, called Lear(++).NC, is adopted
   for fault diagnosis. The algorithm is specially designed for efficient
   incremental learning of multiple new concept classes and is based on the
   dynamically weighted consult and vote (DW-CAV) mechanism to combine the
   classifiers of the ensemble. The detection of unseen classes in
   subsequent data is based on thresholding the normalized weighted average
   of outputs (NWAO) of the base classifiers in the ensemble. The detected
   unknown classes are classified as unlabeled until their correct labels
   can be assigned. The proposed diagnostic system is applied to the
   identification of simulated faults in the feedwater system of a boiling
   water reactor (BWR).},
