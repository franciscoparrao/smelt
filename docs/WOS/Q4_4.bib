Title = {Learning from Imbalanced Data Streams Using Rotation-Based Ensemble
   Classifiers},
Booktitle = {COMPUTATIONAL COLLECTIVE INTELLIGENCE, ICCCI 2023},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2023},
Volume = {14162},
Pages = {794-805},
Abstract = {In this paper, the problem of learning from imbalanced data streams is
   considered. To solve this problem, an approach is presented based on the
   processing of data chunks, which are formed using over-sampling and
   under-sampling. The final classification output is determined using an
   ensemble approach, which is supported by the rotation technique to
   introduce more diversification into the pool of base classifiers and
   increase the final performance of the system. The proposed approach is
   called Weighted Ensemble with one-class Classification and Over-sampling
   and Instance selection (WECOI). It is validated experimentally using
   several selected benchmarks, and some results are presented and
   discussed. The paper concludes with a discussion of future research
   directions.},
Type = {Proceedings Paper},
Affiliation = {Czarnowski, I (Corresponding Author), Gdynia Maritime Univ, Dept Informat Syst, Morska 83, PL-81225 Gdynia, Poland.
   Czarnowski, Ireneusz, Gdynia Maritime Univ, Dept Informat Syst, Morska 83, PL-81225 Gdynia, Poland.},
DOI = {10.1007/978-3-031-41456-5\_60},
Keywords = {Streaming Machine Learning; Data Stream; Imbalanced Data; Ensemble
   Learning; Rotation-Based Ensembles},
Author-Email = {i.czarnowski@umg.edu.pl},
Number-of-Cited-References = {23},
Times-Cited = {2},
