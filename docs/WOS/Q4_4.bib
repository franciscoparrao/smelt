   Herrera, Francisco, King Abdulaziz Univ, Fac Comp \& Informat Technol, Jeddah 21413, Saudi Arabia.},
DOI = {10.1016/j.neucom.2017.01.078},
Keywords = {Data mining; Data stream; Concept drift; Data preprocessing; Data
   reduction; Feature selection; Instance selection; Data discretization;
   Online learning},
Keywords-Plus = {ONLINE FEATURE-SELECTION; NEIGHBORHOOD PRESERVING PROJECTION; CONCEPT
   DRIFT; FEATURE-EXTRACTION; COMPONENT ANALYSIS; CLASSIFICATION;
   CLASSIFIERS; SIMILARITY; FRAMEWORK; ENSEMBLES},
