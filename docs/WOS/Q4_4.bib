Title = {A Family of GEP-Induced Ensemble Classifiers},
Booktitle = {COMPUTATIONAL COLLECTIVE INTELLIGENCE: SEMANTIC WEB, SOCIAL NETWORKS AND
   MULTIAGENT SYSTEMS},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2009},
Volume = {5796},
Pages = {641+},
Abstract = {The paper proposes applying Gene Expression Programming (GEP) to induce
   ensemble classifiers. Four algorithms inducing such classifiers are
   proposed. The first one, denoted GEPA, based on the Adaboost method, is
   the two-class specific. The second, denoted MV is based on majority
   voting learning. Third one, denoted MVI, assumes incremental learning
   where for some classes more genes may be needed than for other ones.
   Finally, the last one denoted MVC involves partitioning of the training
   dataset into clusters prior to expression trees induction. The proposed
   algorithms were validated experimentally using several datasets.},
Type = {Proceedings Paper},
Affiliation = {Jedrzejowicz, J (Corresponding Author), Univ Gdansk, Inst Informat, Wita Stwosza 57, PL-80952 Gdansk, Poland.
