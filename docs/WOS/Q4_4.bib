   stay; Decision-making support; Streaming},
Keywords-Plus = {ACUITY SCALE; FAST-TRACK; TAIWAN TRIAGE; COMPLEXITY; OUTCOMES; IMPACT},
Author-Email = {cnwang@asia.edu.tw},
