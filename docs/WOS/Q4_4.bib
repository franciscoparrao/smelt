   Dahal, Keshav, Univ Bradford, Sch Comp Informat \& Media, Artificial Intelligence Res Grp, Bradford BD7 1DP, W Yorkshire, England.},
DOI = {10.1016/j.eswa.2013.05.001},
Keywords = {Adaptive ensembles; Concept drift; Clustering; Data streams; Decision
   trees; Novel classes},
Keywords-Plus = {NOVELTY DETECTION},
Author-Email = {li.zhang@northumbria.ac.uk},
Number-of-Cited-References = {41},
Times-Cited = {117},
Unique-ID = {WOS:000322051600013},
}

@article{ WOS:000316230900011,
Author = {Ormandi, Robert and Hegedus, Istvan and Jelasity, Mark},
Title = {Gossip learning with linear models on fully distributed data},
Journal = {CONCURRENCY AND COMPUTATION-PRACTICE \& EXPERIENCE},
Year = {2013},
Volume = {25},
Number = {4, SI},
Pages = {556-571},
Abstract = {Machine learning over fully distributed data poses an important problem
   in peer-to-peer applications. In this model, we have one data record at
   each network node but without the possibility to move raw data because
   of privacy considerations. For example, user profiles, ratings, history,
   or sensor readings can represent this case. This problem is difficult
   because there is no possibility to learn local models; the system model
   offers almost no guarantee for reliability, yet the communication cost
   needs to be kept low. Here, we propose gossip learning, a generic
   approach that is based on multiple models taking random walks over the
   network in parallel, while applying an online learning algorithm to
   improve themselves, and getting combined via ensemble learning methods.
   We present an instantiation of this approach for the case of
   classification with linear models. Our main contribution is an ensemble
   learning method, which-through the continuous combination of the models
   in the network-implements a virtual weighted voting mechanism over an
   exponential number of models at practically no extra cost as compared
   with independent random walks. We prove the convergence of the method
   theoretically, and perform extensive experiments on benchmark data sets.
   Our experimental analysis demonstrates the performance and robustness of
   the proposed approach. Copyright (C) 2012 John Wiley \& Sons, Ltd.},
Type = {Article},
Affiliation = {Jelasity, M (Corresponding Author), Univ Szeged, Res Grp Artificial Intelligence, POB 652, H-6701 Szeged, Hungary.
   Ormandi, Robert; Hegedus, Istvan; Jelasity, Mark, Univ Szeged, Res Grp Artificial Intelligence, H-6701 Szeged, Hungary.
   Jelasity, Mark, Hungarian Acad Sci, Budapest, Hungary.},
DOI = {10.1002/cpe.2858},
Keywords = {P2P; gossip; bagging; online learning; stochastic gradient descent;
   random walk},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {jelasity@inf.u-szeged.hu},
Number-of-Cited-References = {44},
Times-Cited = {117},
Unique-ID = {WOS:000316230900011},
}

@article{ WOS:000455864400001,
Author = {Iwashita, Adriana Sayuri and Papa, Joao Paulo},
Title = {An Overview on Concepts Drift Learning},
Journal = {IEEE ACCESS},
Year = {2019},
Volume = {7},
Pages = {1532-1547},
Abstract = {Concept drift techniques aim at learning patterns from data streams that
   may change over time. Although such behavior is not usually expected in
   controlled environments, real-world scenarios can face changes in the
   data, such as new classes, clusters, and features. Traditional
   classifiers can be easily fooled in such situations, resulting in poor
   performances. Common concept drift domains include recommendation
   systems, energy consumption, artificial intelligence systems with
   dynamic environment interaction, and biomedical signal analysis (e.g.,
   neurogenerative diseases). In this paper, we surveyed several works that
   deal with concept drift, as well as we presented a comprehensive study
   of public synthetic and real datasets that can be used to cope with such
   a problem. In addition, we considered a review of different types of
   drifts and approaches to handling such changes in the data. We
   considered different learners employed in classification tasks and the
   use of drift detection mechanisms, among other characteristics.},
Type = {Article},
Affiliation = {Papa, JP (Corresponding Author), Sao Paulo State Univ, Dept Comp, BR-17033360 Bauru, Brazil.
   Iwashita, Adriana Sayuri, Univ Fed Sao Carlos, Dept Comp, BR-13565905 Sao Carlos, SP, Brazil.
   Papa, Joao Paulo, Sao Paulo State Univ, Dept Comp, BR-17033360 Bauru, Brazil.},
DOI = {10.1109/ACCESS.2018.2886026},
Keywords = {Concept drift; machine learning; pattern recognition},
Keywords-Plus = {DATA STREAMS; ENSEMBLE; CLASSIFICATION},
Author-Email = {joao.papa@unesp.br},
Number-of-Cited-References = {71},
Times-Cited = {115},
Unique-ID = {WOS:000455864400001},
}

@article{ WOS:000432728900001,
Author = {Boongoen, Tossapon and Iam-On, Natthakan},
Title = {Cluster ensembles: A survey of approaches with recent extensions and
   applications},
Journal = {COMPUTER SCIENCE REVIEW},
Year = {2018},
Volume = {28},
Pages = {1-25},
Month = {MAY},
Abstract = {Cluster ensembles have been shown to be better than any standard
   clustering algorithm at improving accuracy and robustness across
   different data collections. This meta-learning formalism also helps
   users to overcome the dilemma of selecting an appropriate technique and
   the corresponding parameters, given a set of data to be investigated.
   Almost two decades after the first publication of a kind, the method has
   proven effective for many problem domains, especially microarray data
   analysis and its down-streaming applications. Recently, it has been
   greatly extended both in terms of theoretical modelling and deployment
   to problem solving. The survey attempts to match this emerging attention
   with the provision of fundamental basis and theoretical details of
   state-of-the-art methods found in the present literature. It yields the
   ranges of ensemble generation strategies, summarization and
   representation of ensemble members, as well as the topic of consensus
   clustering. This review also includes different applications and
   extensions of cluster ensemble, with several research issues and
   challenges being highlighted. (C) 2018 Elsevier Inc. All rights
   reserved.},
Type = {Review},
Affiliation = {Iam-On, N (Corresponding Author), Mae Fah Luang Univ, IQ D Res Unit, Sch Informat Technol, Muang Dist 57100, Chiang Rai, Thailand.
