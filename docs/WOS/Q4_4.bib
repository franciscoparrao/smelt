   Yun, Fan; Chen, C. L. Philip, Pazhou Lab, Guangzhou 510335, Peoples R China.
   Yu, Zhiwen, Pengcheng Lab, Shenzhen 518000, Peoples R China.},
DOI = {10.1109/TKDE.2024.3433587},
Keywords = {ensemble learning; incremental learning; Broad learning system;
   AdaBoost; AdaBoost; stacking; stacking; AdaBoost; stacking},
Keywords-Plus = {APPROXIMATION; ENSEMBLES; MACHINE},
Author-Email = {zhwyu@scut.edu.cn},
