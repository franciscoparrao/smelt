   Ding, Weiping, Nantong Univ, Sch Informat Sci \& Technol, Nantong 226019, Peoples R China.},
DOI = {10.1109/TFUZZ.2022.3165390},
Keywords = {Internet of Things; Bayes methods; Intrusion detection; Feature
   extraction; Security; Fuzzy systems; Fuzzy logic; Ensemble learning;
   fuzzy clustering; internet of things (IoT) security},
Keywords-Plus = {SECURITY},
