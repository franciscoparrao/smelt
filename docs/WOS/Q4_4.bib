   Farhan, Muhammad, COMSATS Univ Islamabad, Sahiwal Campus, Sahiwal 57000, Pakistan.
   Ahmad, Tariq, Guilin Univ Elect Technol, Sch Informat \& Commun Engn, Guilin 541004, Peoples R China.},
DOI = {10.1109/JIOT.2023.3312152},
Keywords = {Malware; Internet of Things; Machine learning; Digital forensics;
   Feature extraction; Machine learning algorithms; Computer crime; Cyber
   security; feature engineering; machine learning (ML); malware
