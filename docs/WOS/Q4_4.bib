Times-Cited = {37},
Unique-ID = {WOS:000522550000006},
}

@article{ WOS:000405536900040,
Author = {Zhang, Yuhong and Chu, Guang and Li, Peipei and Hu, Xuegang and Wu,
   Xindong},
Title = {Three-layer concept drifting detection in text data streams},
Journal = {NEUROCOMPUTING},
Year = {2017},
Volume = {260},
Pages = {393-403},
Month = {OCT 18},
Abstract = {Text data streams have widely appeared in real-world applications, in
   which, concept drifts owe a significant challenge for classification.
   Compared with relational data streams, concept drifts hidden in text
   streams usually reflect in the relationship between the feature vector
   and the instance labels. Meanwhile, existing concept drifting detection
   methods are mainly based on error rates of classification. When applying
   these methods in text streams, they perform poorly in the evaluations of
   false alarms and missing detections, etc. Motivated by this, we firstly
   give a systematic analysis of the concept drifts in text data streams.
   Then, we propose a three-layer concept drifting detection approach,
   where the three layers indicate the layer of label space, the layer of
   feature space and the layer of the mapping relationships between labels
   and features, respectively. In this approach, the latter two layers are
   based on the values of WoE (Weight of Evidence) and the IV (Information
   Value) index. Experimental results show that our approach can improve
   the performance of concept drifting detection and the accuracy of
   classification, especially when concept drifts in text data streams are
   frequent. (C) 2017 Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Li, PP (Corresponding Author), Hefei Univ Technol, Sch Comp Sci \& Informat Engn, Hefei 230009, Anhui, Peoples R China.
   Zhang, Yuhong; Chu, Guang; Li, Peipei; Hu, Xuegang, Hefei Univ Technol, Sch Comp Sci \& Informat Engn, Hefei 230009, Anhui, Peoples R China.
   Wu, Xindong, Univ Louisiana Lafayette, Sch Comp \& Informat, 222 James R Oliver Hall, Lafayette, LA 70504 USA.},
DOI = {10.1016/j.neucom.2017.04.047},
Keywords = {Concept drift; Classification; Text data streams; IV value},
Keywords-Plus = {ONLINE; ENSEMBLE},
Author-Email = {zhangyh@hfut.edu.cn
   chuguang@mail.hfut.edu.cn
   peipeili.hfut@gmail.com
   jsjxhuxg@hfut.edu.cn
   xwu@louisiana.edu},
