DOI = {10.1016/j.ins.2023.02.046},
EarlyAccessDate = {FEB 2023},
Keywords = {Data stream; Pattern classification; Active learning; Classifier
   ensemble; Concept drift},
Keywords-Plus = {ONLINE},
Author-Email = {michal.wozniak@pwr.edu.pl
   pawel.zyblewski@pwr.edu.pl
   pawel.zyblewski@pwr.edu.pl},
