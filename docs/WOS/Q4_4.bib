   Xie, Wei, Chinese Acad Sci, Quanzhou Inst Equipment Mfg, Haixi Inst, Quanzhou 362000, Peoples R China.},
DOI = {10.1007/s12145-024-01229-2},
EarlyAccessDate = {FEB 2024},
Keywords = {Incremental learning; Random forest; Landslide susceptibility; Landslide
