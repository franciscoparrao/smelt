@article{ WOS:000414619600015,
Author = {Siahroudi, Sajjad Kamali and Moodi, Poorya Zare and Beigy, Hamid},
Title = {Detection of evolving concepts in non-stationary data streams: A
   multiple kernel learning approach},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2018},
Volume = {91},
Pages = {187-197},
Month = {JAN},
Abstract = {Due to the unprecedented speed and volume of generated raw data in most
   of applications, data stream mining has attracted a lot of attention
   recently. Methods for solving these problems should address challenges
   in this area such as infinite length, concept-drift, recurring concepts,
   and concept-evolution. Moreover, due to the speedy intrinsic of data
   streams, the time and space complexity of the methods are extremely
   important. This paper proposes a novel method based on multiple-kernels
   for classifying non-stationary data streams, which addresses the
   mentioned challenges with special attention to the space complexity. By
   learning multiple kernels and specifying the boundaries of classes in
   the feature (mapped) space of combined kernels, the required amount of
   memory will be decreased, These kernels will be updated regularly
   throughout the stream when the true labels of instances are received.
   Newly arrived instances will be classified with respect to their
   distance to boundaries of the previously known classes in the feature
   spaces. Due to the efficient memory usage, the computation time does not
   increase significantly through the stream. We evaluate the performance
   of the proposed method using a set of experiments conducted on both real
   and synthetic benchmark data sets. The experimental results show the
   superiority of the proposed method over the state-of-the-art methods in
   this area. (C) 2017 Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Beigy, H (Corresponding Author), Sharif Univ Technol, Dept Comp Engn, Tehran, Iran.
   Siahroudi, Sajjad Kamali; Moodi, Poorya Zare; Beigy, Hamid, Sharif Univ Technol, Dept Comp Engn, Tehran, Iran.},
DOI = {10.1016/j.eswa.2017.08.033},
Keywords = {Novel class detection; Data stream; Concept drift; Data stream
   classification},
Keywords-Plus = {CLASSIFICATION; SELECTION; ENSEMBLE; DRIFTS; NUMBER},
Author-Email = {shak16@mails.tsinghua.edu.cn
   poorya.zaremoodi@monash.edu
   beigy@sharif.edu},
Number-of-Cited-References = {31},
Times-Cited = {24},
Unique-ID = {WOS:000414619600015},
}

@incollection{ WOS:000454622300026,
Author = {Cerqueira, Vitor and Torgo, Luis and Oliveira, Mariana and Pfahringer,
   Bernhard},
Book-Group-Author = {IEEE},
Title = {Dynamic and Heterogeneous Ensembles for Time Series Forecasting},
Booktitle = {2017 IEEE INTERNATIONAL CONFERENCE ON DATA SCIENCE AND ADVANCED
   ANALYTICS (DSAA)},
Series = {Proceedings of the International Conference on Data Science and Advanced
   Analytics},
Year = {2017},
Pages = {242-251},
Abstract = {This paper addresses the issue of learning time series forecasting
   models in changing environments by leveraging the predictive power of
   ensemble methods. Concept drift adaptation is performed in an active
   manner, by dynamically combining base learners according to their recent
   performance using a non-linear function. Diversity in the ensembles is
   encouraged with several strategies that include heterogeneity among
   learners, sampling techniques and computation of summary statistics as
   extra predictors. Heterogeneity is used with the goal of better coping
   with different dynamic regimes of the time series. The driving
   hypotheses of this work are that (i) heterogeneous ensembles should
   better fit different dynamic regimes and (ii) dynamic aggregation should
   allow for fast detection and adaptation to regime changes. We extend
   some strategies typically used in classification tasks to time series
   forecasting. The proposed methods are validated using Monte Carlo
   simulations on 16 real-world univariate time series with numerical
   outcome as well as an artificial series with clear regime shifts. The
   results provide strong empirical evidence for our hypotheses. To
   encourage reproducibility the proposed method is publicly available as a
   software package.},
Type = {Proceedings Paper},
Affiliation = {Cerqueira, V (Corresponding Author), LIAAD INESCTEC, Porto, Portugal.
   Cerqueira, V (Corresponding Author), Univ Porto, Porto, Portugal.
   Cerqueira, Vitor; Torgo, Luis; Oliveira, Mariana, LIAAD INESCTEC, Porto, Portugal.
   Cerqueira, Vitor; Torgo, Luis; Oliveira, Mariana, Univ Porto, Porto, Portugal.
   Pfahringer, Bernhard, Univ Auckland, Auckland, New Zealand.},
DOI = {10.1109/DSAA.2017.26},
Keywords = {dynamic ensembles; time series forecasting},
Keywords-Plus = {COMBINATION},
Author-Email = {vmac@inesctec.pt
   ltorgo@inesctec.pt
