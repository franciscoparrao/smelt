DOI = {10.1155/2020/6688912},
Article-Number = {6688912},
Keywords-Plus = {SENTIMENT ANALYSIS},
Author-Email = {hager.saleh.fci@gmail.com},
Number-of-Cited-References = {28},
Times-Cited = {24},
Unique-ID = {WOS:000607929900002},
