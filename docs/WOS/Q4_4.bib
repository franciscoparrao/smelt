@article{ WOS:001121608800001,
Author = {Jian, Ling and Shao, Kai and Liu, Ying and Li, Jundong and Liang, Xijun},
Title = {OEC: an online ensemble classifier for mining data streams with noisy
   labels},
Journal = {DATA MINING AND KNOWLEDGE DISCOVERY},
Year = {2024},
Volume = {38},
Number = {3},
Pages = {1101-1124},
Month = {MAY},
Abstract = {Distilling actionable patterns from large-scale streaming data in the
   presence of concept drift is a challenging problem, especially when data
   is polluted with noisy labels. To date, various data stream mining
   algorithms have been proposed and extensively used in many real-world
   applications. Considering the functional complementation of classical
   online learning algorithms and with the goal of combining their
   advantages, we propose an Online Ensemble Classification (OEC) algorithm
   to integrate the predictions obtained by different base online
   classification algorithms. The proposed OEC method works by learning
   weights of different base classifiers dynamically through the classical
   Normalized Exponentiated Gradient (NEG) algorithm framework. As a
   result, the proposed OEC inherits the adaptability and flexibility of
   concept drift-tracking online classifiers, while maintaining the
   robustness of noise-resistant online classifiers. Theoretically, we show
   OEC algorithm is a low regret algorithm which makes it a good candidate
   to learn from noisy streaming data. Extensive experiments on both
   synthetic and real-world datasets demonstrate the effectiveness of the
   proposed OEC method.},
Type = {Article},
Affiliation = {Liang, XJ (Corresponding Author), China Univ Petr, Coll Sci, Qingdao, Peoples R China.
   Jian, Ling; Shao, Kai, China Univ Petr, Sch Econ \& Management, Qingdao, Peoples R China.
   Liu, Ying; Liang, Xijun, China Univ Petr, Coll Sci, Qingdao, Peoples R China.
   Li, Jundong, Univ Virginia, Dept Elect \& Comp Engn, Charlottesville, VA 22908 USA.},
DOI = {10.1007/s10618-023-00990-0},
EarlyAccessDate = {DEC 2023},
Keywords = {Ensemble classification; Online learning; Noise-resistant; Concept
   drift; Data streams},
