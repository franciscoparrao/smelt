DOI = {10.1016/j.knosys.2018.01.015},
Keywords = {Empirical Mode Decomposition; Discrete wavelet transform; Random Vector
   Functional Link network; Incremental learning; Time series forecasting;
   Electric load forecasting; Neural networks; Random forests},
Keywords-Plus = {EMPIRICAL MODE DECOMPOSITION; NEURAL-NETWORKS; DEMAND; CLASSIFICATION;
