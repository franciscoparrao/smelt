@article{ WOS:000406730000015,
Author = {Zhang, Haigang and Zhang, Sen and Yin, Yixin},
Title = {Online sequential ELM algorithm with forgetting factor for real
   applications},
Journal = {NEUROCOMPUTING},
Year = {2017},
Volume = {261},
Number = {SI},
Pages = {144-152},
Month = {OCT 25},
Abstract = {Sequential learning algorithms are a good choice for learning data
   one-by-one or chunk-by-chunk. Liang et al. has proposed OS-ELM algorithm
   based on the ordinary ELM algorithm, which produces better
   generalization performance than other famous sequential learning
   algorithms. One of the deficiencies of OS-ELM is that all the
   observations are weighted equally regardless of the acquisition time.
   However, the training data often have timeliness in many real industrial
   applications. In this paper, we propose a modified online sequential
   learning algorithm with the forgetting factor (named WOS-ELM algorithm)
   that weights the new observations more. Then a convergence analysis is
   presented to make sure the estimation of output weights tend to converge
   at the exponential speed with the arriving of new observations. For the
   determination of the value of forgetting factor, it would change with
   the forecast error automatically and get rid of excessive human
   interference. We employ several applications in the simulation part
   including time-series predication, time-variant system identification
   and the weather forecast problem. The simulation results show that
   WOS-ELM is more accurate and robust than other sequential learning
   algorithms. (C) 2017 Elsevier B.V. All rights reserved.},
Type = {Article; Proceedings Paper},
Affiliation = {Zhang, S (Corresponding Author), Univ Sci \& Technol Beijing, Sch Automat \& Elect Engn, 30 Xueyuan Rd, Beijing 100083, Peoples R China.
   Zhang, Haigang; Zhang, Sen; Yin, Yixin, Univ Sci \& Technol Beijing, Sch Automat \& Elect Engn, 30 Xueyuan Rd, Beijing 100083, Peoples R China.},
DOI = {10.1016/j.neucom.2016.09.121},
Keywords = {Extreme learning machine; Online learning; Forgetting factor; Sequential
   learning},
Keywords-Plus = {EXTREME LEARNING-MACHINE; LEAST-SQUARES; CLASSIFICATION; ENSEMBLE;
   SYSTEMS; KERNELS},
