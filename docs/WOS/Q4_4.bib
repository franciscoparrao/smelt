   Pardo, Xose M., Univ Santiago Compostela, CiTIUS, Santiago De Compostela, Spain.},
DOI = {10.1016/j.patcog.2022.108885},
EarlyAccessDate = {JUL 2022},
Article-Number = {108885},
Keywords = {Open-set face recognition; Incremental Learning; Self-updating; Adaptive
   biometrics; Video-surveillance},
