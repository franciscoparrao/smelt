@incollection{ WOS:000772144100035,
Author = {Kannan, N. and Yeh, Charles Y. C. and Chou, Chih-Yueh and Chan, Tak-Wai},
Editor = {Rodrigo, MMT and Iyer, S and Mitrovic, A},
Title = {A Machine Learning Approach to Estimating Student Mastery by Predicting
   Feedback Request and Solving Time in Online Learning System},
Booktitle = {29TH INTERNATIONAL CONFERENCE ON COMPUTERS IN EDUCATION (ICCE 2021), VOL
   I},
Year = {2021},
Pages = {241-250},
Abstract = {One of the most significant challenges for computers in education is the
   capacity to provide intelligent and adaptable learning systems to meet
   the real needs of students. In order to create efficient adaptive or
   personalized mechanisms for educational content, student models are
   proposed to estimate the actual knowledge or mastery level of students.
   Some earlier student models were proposed to estimate student mastery
   based on the correctness (e.g., correct or incorrect) of responses,
   feedback request, and solving time using classical Markov process and
   logistic regression models. In particular, these models were applied to
   predicting student future correctness, feedback request, and solving
   time (i.e., on the next question). The advent of increasingly
   large-scale datasets has turned Machine Learning (ML) methods such as
   conventional machine-learning algorithms and deep learning models for
   prediction into competitive alternatives to classical Markov process and
   logistic regression models. In addition, prediction by ML methods has
   numerous advantages such as interpretability, good accuracy, ease of
   maintenance, less execution time, and appropriately handling of missing
   data. Moreover, recent studies exhibit the significant achievement of ML
   prediction methods for estimating students' performance and mastery
   using learning log data (i.e., correctness, feedback request level,
   solving time, etc.). Hence, it is reasonable to use ML methods to
   estimate student mastery by predicting the feedback request level and
   solving time. This study analyzed the data logged by an online learning
   system called Math-Island, which teaches elementary level mathematics by
   incorporating game mechanisms and scaffolding feedback. Machine-learning
   regression methods such as Multiple Linear Regression (MLR), Support
   Vector Regression (SVR), Random Forest Regression (RFR), Extra Trees
   (ET), and Gradient Boosting Regression (GBR) were applied. The results
   showed that RFR and GBR were found to outperform other models to predict
   future feedback request level and solving time. The results lead to
   several future works. First, incorporating ML predictive models into
   Math-Island tutoring system to identify the individual student's actual
   needs and; reduce learning loss substantially. Second, it drives to
   effectively build a more efficient adaptive mechanism within the current
   session to utilize students' active learning time.},
Type = {Proceedings Paper},
Affiliation = {Kannan, N (Corresponding Author), Natl Cent Univ, Grad Inst Network Learning Technol, Taoyuan, Taiwan.
   Kannan, N.; Yeh, Charles Y. C.; Chan, Tak-Wai, Natl Cent Univ, Grad Inst Network Learning Technol, Taoyuan, Taiwan.
   Chou, Chih-Yueh, Yuan Ze Univ, Dept Comp Sci \& Engn, Taoyuan, Taiwan.},
Keywords = {Machine learning; prediction; regression; online learning system},
Author-Email = {kannannataraj@g.ncu.edu.tw},
Number-of-Cited-References = {32},
Times-Cited = {2},
Unique-ID = {WOS:000772144100035},
}

@incollection{ WOS:000824464300227,
Author = {Martinez Perez, Jose Luis and Palomino Marino, Laura Maria and Maior de
   Barros, Roberto Souto},
Book-Group-Author = {IEEE},
Title = {Improving Diversity in Concept Drift Ensembles},
Booktitle = {2021 IEEE SYMPOSIUM SERIES ON COMPUTATIONAL INTELLIGENCE (IEEE SSCI
   2021)},
Year = {2021},
Abstract = {This research investigates how the performance of ensembles is
   influenced by the diversity and behavior of base learners on abrupt and
   gradual concept drifts. To accomplish that, we propose to enhance
   ensemble algorithms by adjusting the voting procedure and using
   heterogeneous base-learners on three benchmark data stream methods: Fast
   Adaptive Stacking of Ensembles (FASE), Online Adaptive Classifier
   Ensemble based on bagging (OACE(BA)), and Online Adaptive Classifier
   Ensemble based on boosting (OACE(BO)). These ensembles were selected
   because they use different voting schemes (stacking, simple majority,
   and weighted voting) to perform the classification. The modified
   methods, MFASE, MOACE(BA) and MOACE(BO), were compared to their original
   versions regarding accuracy. Naive Bayes (NB) and Hoeffding Tree (HT)
   were used as base learners to evaluate the methods on artificial and
   real-world datasets. The experimental investigation included 44
   experiments and their evaluation using the Friedman and Nemenyi
   statistical tests. They showed that the modified methods improve the
   ensemble performance in concept drift problems in many scenarios.},
Type = {Proceedings Paper},
Affiliation = {Pérez, JLM (Corresponding Author), Univ Fed Pernambuco, Ctr Informcit, BR-50740560 Recife, PE, Brazil.
   Martinez Perez, Jose Luis; Palomino Marino, Laura Maria; Maior de Barros, Roberto Souto, Univ Fed Pernambuco, Ctr Informcit, BR-50740560 Recife, PE, Brazil.},
DOI = {10.1109/SSCI50451.2021.9660047},
Keywords = {concept drift; data-stream; ensemble methods; non-stationary data},
Keywords-Plus = {ONLINE},
Author-Email = {jlmp@cin.ufpe.br
   lmpm@cin.ufpe.br
   roberto@cin.ufpe.br},
Number-of-Cited-References = {35},
Times-Cited = {2},
