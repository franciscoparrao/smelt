   Zhou, Bin, Natl Univ Def Technol, State Key Lab High Performance Comp, Changsha 410073, Hunan, Peoples R China.},
DOI = {10.1007/s11280-017-0449-x},
Keywords = {Streaming data; Class imbalance; Multi-window; Ensemble learning},
