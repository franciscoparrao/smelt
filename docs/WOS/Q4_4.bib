   Mirza, Ali H.; Khan, Farhan; Kozat, Suleyman S., Bilkent Univ, Dept Elect \& Elect Engn, TR-06800 Ankara, Turkey.},
DOI = {10.1016/j.dsp.2018.07.012},
Keywords = {Online boosting; Adaptive filtering; Boosted filter; Ensemble learning;
   Smooth boost; Mixture methods},
Keywords-Plus = {PREDICTION; COMBINATION; ALGORITHMS; PERFORMANCE; MIXTURE},
