   alessandro.finamore@telefonica.com
   gd@ac.upc.edu
   konstantina.papagiannaki@telefonica.com},
Number-of-Cited-References = {34},
Times-Cited = {4},
Unique-ID = {WOS:000403398200083},
}

@article{ WOS:000404360000054,
Author = {Thakong, Mongkhon and Phimoltares, Suphakant and Jaiyen, Saichon and
   Lursinsap, Chidchanok},
Title = {Fast Learning and Testing for Imbalanced Multi-Class Changes in
   Streaming Data by Dynamic Multi-Stratum Network},
Journal = {IEEE ACCESS},
Year = {2017},
Volume = {5},
Pages = {10633-10648},
Abstract = {Although several efficient learning methods have recently been proposed
   to handle class drift situations, issues remain in various streaming
   data applications that possibly deteriorate classification accuracy.
   Three important issues were considered, that is: 1) lifetime and class
   changes; 2) high imbalance ratios of streaming data among classes; and
   3) classification accuracy of untrained data and class-changed data. A
   new dynamical learning structure based on hyper-elliptical capsule and
   multi-stratum network was introduced to cope with these issues. The
   experimental results on a simulated University of California at Irvine
   non-concept-drift database and real concept-drift data confirm that the
   proposed multi-stratum learning provided better accuracy, faster
   learning speed, and lower structural complexity than other concept-drift
   algorithms.},
Type = {Article},
Affiliation = {Thakong, M (Corresponding Author), Chulalongkorn Univ, Fac Sci, Dept Math \& Comp Sci, Bangkok 10330, Thailand.
   Thakong, Mongkhon; Phimoltares, Suphakant; Lursinsap, Chidchanok, Chulalongkorn Univ, Fac Sci, Dept Math \& Comp Sci, Bangkok 10330, Thailand.
   Jaiyen, Saichon, King Mongkuts Inst Technol Ladkrabang, Fac Sci, Dept Comp Sci, Bangkok 10520, Thailand.},
DOI = {10.1109/ACCESS.2017.2714345},
Keywords = {Data stream classification; imbalanced data; concept drift;
   nonstationary environment.},
Keywords-Plus = {CONCEPT DRIFT; NONSTATIONARY ENVIRONMENTS; CLASSIFICATION; ENSEMBLE;
   RECOGNITION; ALGORITHM},
Author-Email = {mongkhon720@gmail.com},
