Keywords = {Social networking (online); Blogs; Measurement; Business; Sentiment
   analysis; Neural networks; Electronic learning; Customer loyalty
   prediction; e-learning platforms; satisfaction score (SATS) per user;
   sentiment analysis; user sentiment score (USS) per user},
Keywords-Plus = {SENTIMENT ANALYSIS; CUSTOMER LOYALTY; ONLINE; REVIEWS; PROFITABILITY;
