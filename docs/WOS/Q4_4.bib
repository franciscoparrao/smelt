@article{ WOS:000519727800028,
Author = {Duda, Piotr and Rutkowski, Leszek and Jaworski, Maciej and Rutkowska,
   Danuta},
Title = {On the Parzen Kernel-Based Probability Density Function Learning
   Procedures Over Time-Varying Streaming Data With Applications to Pattern
   Classification},
Journal = {IEEE TRANSACTIONS ON CYBERNETICS},
Year = {2020},
Volume = {50},
Number = {4},
Pages = {1683-1696},
Month = {APR},
Abstract = {In this paper, we propose a recursive variant of the Parzen kernel
   density estimator (KDE) to track changes of dynamic density over data
   streams in a nonstationary environment. In stationary environments,
   well-established traditional KDE techniques have nice asymptotic
   properties. Their existing extensions to deal with stream data are
   mostly based on various heuristic concepts (losing convergence
   properties). In this paper, we study recursive KDEs, called recursive
   concept drift tracking KDEs, and prove their weak (in probability) and
   strong (with probability one) convergence, resulting in perfect tracking
   properties as the sample size approaches infinity. In three theorems and
   subsequent examples, we show how to choose the bandwidth and learning
   rate of a recursive KDE in order to ensure weak and strong convergence.
   The simulation results illustrate the effectiveness of our algorithm
   both for density estimation and classification over time-varying stream
   data.},
Type = {Article},
Affiliation = {Duda, P (Corresponding Author), Czestochowa Tech Univ, Inst Computat Intelligence, PL-42200 Czestochowa, Poland.
   Duda, Piotr; Rutkowski, Leszek; Jaworski, Maciej, Czestochowa Tech Univ, Inst Computat Intelligence, PL-42200 Czestochowa, Poland.
   Rutkowska, Danuta, Univ Social Sci, Inst Informat Technol, PL-90113 Lodz, Poland.},
DOI = {10.1109/TCYB.2018.2877611},
Keywords = {Kernel; Convergence; Neural networks; Bandwidth; Probability density
   function; Estimation; Probabilistic logic; Concept drift; convergence in
   probability and with probability one; online density estimation; pattern
   classification in nonstationary environments; time-varying environment},
Keywords-Plus = {NEURAL-NETWORKS; DECISION TREES; ENVIRONMENTS; ENSEMBLE},
Author-Email = {piotr.duda@iisi.pcz.pl
   drutkowska@san.edu.pl},
Number-of-Cited-References = {61},
Times-Cited = {29},
Unique-ID = {WOS:000519727800028},
}

@article{ WOS:000443262400004,
Author = {Wang, Yi and Li, Tao},
Title = {Improving semi-supervised co-forest algorithm in evolving data streams},
Journal = {APPLIED INTELLIGENCE},
Year = {2018},
Volume = {48},
Number = {10},
Pages = {3248-3262},
Month = {OCT},
Abstract = {Semi-supervised learning, which uses a large amount of unlabeled data to
   improve the performance of a classifier when only a limited amount of
   labeled data is available, has become a hot topic in machine learning
   research recently. In this paper, we propose a semi-supervised ensemble
   of classifiers approach, for learning in time-varying data streams. This
   algorithm maintains all the desirable properties of the semi-supervised
   Co-trained random FOREST algorithm (Co-Forest) and extends it into
   evolving data streams. It assigns a weight to each example according to
   Poisson(1) to simulate the bootstrap sample method in data streams,
   which is used to keep the diversity of Random Forest. By utilizing
   incremental learning technology, it avoids unnecessary repetition
   training and improves the accuracy of base models. In addition, the
   ADaptive WINdowing (ADWIN2) is introduced to deal with concept drift,
   which makes it adapt to the varying environment. Empirical evaluation on
   both synthetic data and UCI data reveals that our proposed method
   outperforms state-of-the-art semi-supervised and supervised methods in
   time-varying data streams, and also achieves relatively high performance
   in stationary streams.},
Type = {Article},
Affiliation = {Wang, Y (Corresponding Author), Sichuan Univ, Coll Comp Sci, Chengdu 610065, Sichuan, Peoples R China.
   Wang, Yi; Li, Tao, Sichuan Univ, Coll Comp Sci, Chengdu 610065, Sichuan, Peoples R China.},
DOI = {10.1007/s10489-018-1149-7},
Keywords = {Machine learning; Semi-supervised learning; Co-Forest; Data stream
   classification; Ensemble learning},
Keywords-Plus = {SUPPORT VECTOR MACHINE; CLASSIFICATION; ENSEMBLE},
Author-Email = {yiwongh@gmail.com
   litao@scu.edu.cn},
Number-of-Cited-References = {67},
