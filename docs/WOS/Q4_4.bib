@article{ WOS:000772458800054,
Author = {Von Krannichfeldt, Leandro and Wang, Yi and Zufferey, Thierry and Hug,
   Gabriela},
Title = {Online Ensemble Approach for Probabilistic Wind Power Forecasting},
Journal = {IEEE TRANSACTIONS ON SUSTAINABLE ENERGY},
Year = {2022},
Volume = {13},
Number = {2},
Pages = {1221-1233},
Month = {APR},
Abstract = {Probabilistic wind power forecasting is an important input in the
   decision-making process in future electric power grids with large
   penetrations of renewable generation. Traditional probabilistic wind
   power forecasting models are trained offline and are then used to make
   predictions online. However, this strategy cannot make full use of the
   most recent information during the prediction process. In addition,
   ensemble learning is recognized as an effective approach for further
   improving forecasting performance by combining multiple forecasting
   models. This paper studies an online ensemble approach for probabilistic
   wind power forecasting by taking full advantage of the most recent
   information and leveraging the strengths of multiple forecasting models.
   The online ensemble approach is first formulated as an online convex
   optimization problem. On this basis, a quantile passive-aggressive
   regression model is proposed to solve the online convex optimization
   problem. Case studies and comparisons with other online learning methods
   are conducted on an open wind power data set from Belgium. Results show
   that the proposed method outperforms competing methods in terms of
   pinball loss and Winkler score with high reliability.},
Type = {Article},
Affiliation = {Wang, Y (Corresponding Author), Univ Hong Kong, Dept Elect \& Elect Engn, Hong Kong, Peoples R China.
   Von Krannichfeldt, Leandro; Zufferey, Thierry; Hug, Gabriela, Swiss Fed Inst Technol, Power Syst Lab, CH-8092 Zurich, Switzerland.
   Wang, Yi, Univ Hong Kong, Dept Elect \& Elect Engn, Hong Kong, Peoples R China.},
DOI = {10.1109/TSTE.2021.3124228},
Keywords = {Forecasting; Wind power generation; Predictive models; Adaptation
   models; Probabilistic logic; Hidden Markov models; Training; Wind power
   forecasting; probabilistic forecasting; online learning; ensemble
   learning; quantile regression; passive-aggressive regression},
Author-Email = {leandro.von.krannichfeldt@hotmail.com
   yiwang@eee.hku.hk
