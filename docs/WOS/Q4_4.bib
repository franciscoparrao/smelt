   Li, Xue, Univ Queensland, Sch Informat Technol \& Elect Engn, Brisbane, Qld 4072, Australia.},
DOI = {10.1016/j.datak.2011.05.002},
Keywords = {Text stream classification; Concept drift; Classifier ensemble;
   Knowledge acquisition},
Author-Email = {ybg0359@nwsuaf.edu.cn
   zhangyang@nwsuaf.edu.cn
   xueli@itee.uq.edu.au},
