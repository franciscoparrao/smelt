   Qin, Keke; Wen, Yimin, Guilin Univ Elect Technol, Sch Comp Sci \& Informat Safety, Guilin 541004, Peoples R China.},
DOI = {10.1007/978-981-13-2122-1\_8},
Keywords = {Semi-supervised learning; Local component replacement; Ensemble learning},
Keywords-Plus = {ENSEMBLE},
