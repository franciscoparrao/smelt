}

@article{ WOS:000788139700001,
Author = {Zhang, Chenglong and Ding, Shifei and Du, Wei},
Title = {Broad stochastic configuration network for regression},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2022},
Volume = {243},
Month = {MAY 11},
Abstract = {Stochastic configuration network (SCN) is an incremental learning
   approach with universal approximation property for analyzing
   high-dimensional and large-scale data. It can start with a small
   structure and gradually increase hidden layer nodes through the
   supervision mechanism. Broad learning system (BLS), as a novel
   structure, has been widely used in various fields because of its high
   efficiency, generalization performance and scalability. Unlike deep
   learning models, BLS is proposed based on random vector functional link
   network (RVFLN) which can map input features to a more appropriate
   feature space and the mapped features are enhanced as enhancement nodes.
   Therefore, to enhance the feature learning ability and improve the
   effectiveness of SCN, inspired by BLS architecture, a novel broad
   stochastic configuration network (BSCN) is proposed, then we give the
   structure and theory of BSCN. In this model, the original features are
   transformed into mapping features in the feature layer and the mapping
   features are enhanced in the enhancement layer, then the input weights
   and biases of enhancement nodes are determined according to the
   supervision mechanism and the output weight matrix can be calculated
   through the standard least squares. The experimental results on function
   approximation problems and real-world datasets indicate that BSCN
   improves the performance of SCN, and it has higher regression accuracy
   and stability.(c) 2022 Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Ding, SF (Corresponding Author), China Univ Min \& Technol, Sch Comp Sci \& Technol, Xuzhou 221116, Jiangsu, Peoples R China.
   Zhang, Chenglong; Ding, Shifei; Du, Wei, China Univ Min \& Technol, Sch Comp Sci \& Technol, Xuzhou 221116, Jiangsu, Peoples R China.
   Ding, Shifei, Minist Educ Peoples Republ China, Mine Digitizat Engn Res Ctr, Xuzhou 221116, Jiangsu, Peoples R China.},
DOI = {10.1016/j.knosys.2022.108403},
EarlyAccessDate = {MAR 2022},
Article-Number = {108403},
Keywords = {Broad learning system; Stochastic configuration network; Neural network;
   Feature learning; Regression},
Keywords-Plus = {LEARNING-SYSTEM; PREDICTION INTERVALS; ALGORITHM; CLASSIFICATION;
   ENSEMBLE},
Author-Email = {dingsf@cumt.edu.cn},
Number-of-Cited-References = {60},
