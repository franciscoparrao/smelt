DOI = {10.1109/TCYB.2021.3070420},
EarlyAccessDate = {MAY 2021},
Keywords = {Clustering algorithms; Heuristic algorithms; Feature extraction;
   Classification algorithms; Data models; Data mining; Noise reduction;
   Concept drift; denoising autoencoder (DAE); evolving data streams;
   semisupervised learning (SSL); synchronization},
