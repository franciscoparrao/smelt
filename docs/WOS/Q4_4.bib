@incollection{ WOS:000388720000048,
Author = {Wozniak, Michal and Ksieniewicz, Pawel and Cyganek, Boguslaw and
   Walkowiak, Krzysztof},
Editor = {Saeed, K and Homenda, W},
Title = {Ensembles of Heterogeneous Concept Drift Detectors - Experimental Study},
Booktitle = {COMPUTER INFORMATION SYSTEMS AND INDUSTRIAL MANAGEMENT, CISIM 2016},
Series = {Lecture Notes in Computer Science},
Year = {2016},
Volume = {9842},
Pages = {538-549},
Abstract = {For the contemporary enterprises, possibility of appropriate business
   decision making on the basis of the knowledge hidden in stored data is
   the critical success factor. Therefore, the decision support software
   should take into consideration that data usually comes continuously in
   the form of so-called data stream, but most of the traditional data
   analysis methods are not ready to efficiently analyze fast growing
   amount of the stored records. Additionally, one should also consider
   phenomenon appearing in data stream called concept drift, which means
   that the parameters of an using model are changing, what could
   dramatically decrease the analytical model quality. This work is
   focusing on the classification task, which is very popular in many
   practical cases as fraud detection, network security, or medical
   diagnosis. We propose how to detect the changes in the data stream using
   combined concept drift detection model. The experimental evaluations
   confirm its pretty good quality, what encourage us to use it in
   practical applications.},
Type = {Proceedings Paper},
Affiliation = {Wozniak, M (Corresponding Author), Wroclaw Univ Technol, Fac Elect, Dept Syst \& Comp Networks, Wybreze Wyspianskiego 27, PL-50370 Wroclaw, Poland.
