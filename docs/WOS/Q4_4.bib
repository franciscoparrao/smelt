   Xu, Lu, Shandong Donghua Cement Co Ltd, Zibo 255144, Peoples R China.},
DOI = {10.1109/TIM.2020.3011251},
Article-Number = {2500610},
Keywords = {Deep feature extracting and transferring; eXtreme Gradient Boosting
   (XGBoost); free calcium oxide (f-CaO) content prediction; incremental
   learning; semisupervised learning; virtual sensor},
