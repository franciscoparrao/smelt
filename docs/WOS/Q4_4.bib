   Cyganek, Boguslaw, AGH Univ Sci \& Technol, Al Mickiewicza 30, PL-30059 Krakow, Poland.},
DOI = {10.1007/978-3-319-45378-1\_48},
Keywords = {Data stream; Concept drift; Pattern classification; Drift detector},
Author-Email = {michal.wozniak@pwr.edu.pl
   pawel.ksieniewicz@pwr.edu.pl
   cyganek@agh.edu.pl
   krzysztof.walkowiak@pwr.edu.pl},
