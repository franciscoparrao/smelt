   Johnston, Stephen J., Brunel Univ, Dept Psychol, Uxbridge UB8 3PH, Middx, England.},
DOI = {10.1016/j.patcog.2011.04.023},
Keywords = {Functional magnetic resonance imaging (fMRI); Online classification;
