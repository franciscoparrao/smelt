DOI = {10.3390/su15118924},
Article-Number = {8924},
Keywords = {e-learning readiness; ADKAR factors; machine learning; distance
   education; online learning},
Keywords-Plus = {VARIABLE IMPORTANCE; CHANGE MANAGEMENT; HIGHER-EDUCATION; MODEL;
   CHALLENGES; REGRESSION; SYSTEMS},
Author-Email = {mzine759@gmail.com
   fouzi.harrou@kaust.edu.sa},
