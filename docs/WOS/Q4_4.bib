Unique-ID = {WOS:001207399200001},
}

@incollection{ WOS:000569720900072,
Author = {Loezer, Lucas and Enembreck, Fabricio and Barddal, Jean Paul and Britto
   Jr, Alceu de Souza},
Book-Group-Author = {ACM},
Title = {Cost-sensitive learning for imbalanced data streams},
Booktitle = {PROCEEDINGS OF THE 35TH ANNUAL ACM SYMPOSIUM ON APPLIED COMPUTING
   (SAC'20)},
Year = {2020},
Pages = {498-504},
Abstract = {The data imbalance problem hampers the classification task. In streaming
   environments, this becomes even more cumbersome as the proportion of
   classes can vary over time. Approaches based on misclassification costs
   can be used to mitigate this problem. In this paper, we present the
   Cost-sensitive Adaptive Random Forest (CSARF) and compare it to the
   Adaptive Random Forest (ARF) and ARF with Resampling (ARF(RE)) in six
   real-world and six synthetic data sets with different class ratios. The
   empirical study analyzes two misclassification costs strategies of the
   CSARF and shows that the CSARF obtained statistically superior w.r.t.
   the average recall and average F1 when compared to ARF.},
Type = {Proceedings Paper},
Affiliation = {Loezer, L (Corresponding Author), Pontificia Univ Catolica Parana, Grad Program Informat PPGIa, Curitiba, Parana, Brazil.
