DOI = {10.1109/EMBC48229.2022.9871859},
Keywords = {Dry electrodes; ear EEG; user-generic; classification; neural recording;
   drowsiness},
Author-Email = {rikky@berkeley.edu},
Number-of-Cited-References = {10},
