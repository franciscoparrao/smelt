DOI = {10.1109/ACCESS.2022.3169785},
Keywords = {Machine learning; Detectors; Data models; Adaptation models; Task
   analysis; Classification algorithms; Training; Concept drift; data
   stream; ensemble; regression; non-stationary environments; systematic
   literature review},
Keywords-Plus = {PSEUDO-OUTER-PRODUCT; SOFT SENSOR; NEURAL-NETWORK; PART I; ENSEMBLE;
   ONLINE; PREDICTION; MODELS},
Author-Email = {mncal@ecomp.poli.br
