DOI = {10.1016/j.geits.2025.100299},
EarlyAccessDate = {NOV 2025},
Article-Number = {100299},
Keywords = {Electrothermal coupling; Sensitivity analysis; Weight based particle
   swarm optimization; Dynamic residual forest model},
