DOI = {10.1109/TLT.2022.3221495},
Keywords = {Dilatory behavior; learning analytics (LA); machine learning (ML);
   predictive performance; procrastination; Delays; Predictive models;
   Behavioral sciences; Prediction algorithms; Task analysis; Data models;
