   Palade, Vasile},
Editor = {Li, C and DeOliveira, JV and Ding, P and Guo, W and Shi, J and Bai, Y},
Title = {A Hybrid Ensemble Scheme for Diagnosing New Class Defects under
   Non-stationary and Class Imbalance Conditions},
Booktitle = {2017 INTERNATIONAL CONFERENCE ON SENSING, DIAGNOSTICS, PROGNOSTICS, AND
   CONTROL (SDPC)},
Year = {2017},
Pages = {355-360},
Abstract = {Strategic necessities to design and implement practical diagnostic
   systems are the abilities of incremental learning and diagnosing new
   class defects under non-stationary and class imbalance conditions. In
   this work, a hybrid ensemble scheme, named Learn (++) NCS, is adopted
   for diagnosing bearing defects in induction motors. This diagnostic
   scheme includes a feature extraction module and a hybrid ensemble
   scheme. The former intends to extract discriminant features from the
   vibrational signals. The latter collects various class imbalance sets of
   samples chunk by chunk from a non-stationary environment, constructs a
   hybrid ensemble by means of a consultation and voting mechanism,
   incrementally learns novel features-defects relations and diagnoses new
   class defects. Experimental results present the effectiveness of the
   proposed hybrid scheme.},
