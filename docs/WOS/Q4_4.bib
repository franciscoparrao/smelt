@article{ WOS:000991772400001,
Author = {Rakesh, Deepak Kumar and Jana, Prasanta K.},
Title = {An improved differential evolution algorithm for quantifying fraudulent
   transactions},
Journal = {PATTERN RECOGNITION},
Year = {2023},
Volume = {141},
Month = {SEP},
Abstract = {Identification of fraudulent credit card transactions is a complex
   problem mainly due to the following factors: 1) The relative behavior of
   customers and fraudsters may alter over time. 2) The ratio of legitimate
   to fraudulent transactions is highly imbalanced, and 3) Investigators
   examine a small segment of transactions in a reasonable time frame.
   Researchers have proposed various algorithms to identify potential fraud
   in a new incoming transaction. However, these approaches require
   significant human investigator effort and are sometimes misleading. To
   address this issue, this paper proposes an improved multiobjective
   differential evolution (DE) algorithm to estimate the distribution of
   fraudulent transactions in a set of new incoming transactions, referred
   to as quantifying fraudulent transactions. Our paper has three major
   novelties. First, we present the problem formulation of cost-based
   feature selection with maximum quantification ability. Second, we
   improve the DE by applying effective trial vector generation algorithms
   to the random control parameter settings to exploit the advantage of
   individual DE variants. Third, we develop the
   maximum-relevancy-minimum-redundancy-based Pareto refining operator to
   enhance the self-learning ability of individuals in Pareto solutions. We
   compare our approach against four other modifications of DE and five
   state-of-the-art evolutionary algorithms on real-time credit datasets in
   streaming and non-streaming frameworks using hyper-volume, two-set
   coverage, and spread performance metrics. (c) 2023 Elsevier Ltd. All
   rights reserved.},
Type = {Article},
Affiliation = {Rakesh, DK (Corresponding Author), Indian Inst Technol Indian Sch Mines, Dhanbad, India.
   Rakesh, Deepak Kumar; Jana, Prasanta K., Indian Inst Technol Indian Sch Mines, Dhanbad, India.},
DOI = {10.1016/j.patcog.2023.109623},
EarlyAccessDate = {APR 2023},
Article-Number = {109623},
Keywords = {Quantifying fraudulent transactions (QFT); Cost -based feature
   selection; Multiobjective optimization; Differential evolution},
Keywords-Plus = {FEATURE-SELECTION; MUTUAL INFORMATION; GENETIC ALGORITHM;
   CLASSIFICATION; ENSEMBLE},
Author-Email = {deep.17dr000644@cse.ism.ac.in
   prasantajana@iitism.ac.in},
Number-of-Cited-References = {41},
Times-Cited = {3},
Unique-ID = {WOS:000991772400001},
}

@article{ WOS:000926248800001,
Author = {Yuan, Jing and Liang, Zeming and Wang, Rongxi and Li, Yufan and Wang,
   Zhen and Gao, Jianmin},
Title = {A novel self-learning framework for fault identification of wind turbine
   drive bearings},
Journal = {PROCEEDINGS OF THE INSTITUTION OF MECHANICAL ENGINEERS PART I-JOURNAL OF
   SYSTEMS AND CONTROL ENGINEERING},
Year = {2023},
Volume = {237},
Number = {7},
Pages = {1296-1312},
Month = {AUG},
Abstract = {The drive train is one of the core structures of a wind turbine, and its
   working condition seriously affects the performance quality. It is
   important to identify the fault pattern of the drive bearings in time to
   ensure the safety and reliability of the wind turbine. However, in
   traditional methods, offline modeling and online identification are
   often fragmented, and such a mechanism limits the adaptive updating of
   the model. To realize real-time updating and self-learning of the
   identification model, we proposed a novel self-learning framework for
   the intelligent fault identification of wind turbine drive bearings.
   First, a complete ensemble empirical mode decomposition with adaptive
   noise analysis-based quantification scheme for intrinsic mode function
   values is proposed. Then, based on the intrinsic mode function values,
   we offer an attention mechanism for fault feature identification and
   construct an initial fault pattern database using unsupervised
   clustering techniques. Second, abnormal data are identified by the
   proposed artificial immunity-based outlier detection algorithm to
   determine the type of immune response. Third, we design an automatic
   update strategy based on incremental learning to realize adaptive
   creation, deletion, and modification of fault patterns. The proposed
   intelligent framework is applied to the fault diagnosis of a real
   offshore wind turbine drive train, showing its advantages in intelligent
   fault identification and model updating.},
Type = {Article},
Affiliation = {Wang, RX (Corresponding Author), Xi An Jiao Tong Univ, State Key Lab Mfg Syst Engn, Xian 710061, Peoples R China.
   Yuan, Jing; Wang, Rongxi; Li, Yufan; Gao, Jianmin, Xi An Jiao Tong Univ, State Key Lab Mfg Syst Engn, Xian, Peoples R China.
   Liang, Zeming, Xian Aircraft Ind Grp Co Ltd, Xian, Peoples R China.
   Wang, Zhen, Xian Thermal Power Res Inst Co Ltd, Xian, Peoples R China.
   Wang, Rongxi, Xi An Jiao Tong Univ, State Key Lab Mfg Syst Engn, Xian 710061, Peoples R China.},
DOI = {10.1177/09596518231153231},
EarlyAccessDate = {FEB 2023},
Keywords = {Wind turbine drive bearing; incremental learning; fault pattern
   identification; self-learning},
Keywords-Plus = {INCREMENTAL NEURAL-NETWORK; ARTIFICIAL IMMUNE-SYSTEMS; PLANETARY
   GEARBOX; DIAGNOSIS; ALGORITHM; CLASSIFICATION; RECOGNITION; MACHINE},
Author-Email = {rongxiwang@163.com},
Number-of-Cited-References = {50},
Times-Cited = {3},
