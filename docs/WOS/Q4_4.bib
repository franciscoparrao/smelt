}

@article{ WOS:000403459100003,
Author = {Zambelli, Martina and Demiris, Yiannis},
Title = {Online Multimodal Ensemble Learning Using Self-Learned Sensorimotor
   Representations},
Journal = {IEEE TRANSACTIONS ON COGNITIVE AND DEVELOPMENTAL SYSTEMS},
Year = {2017},
Volume = {9},
Number = {2, SI},
Pages = {113-126},
Month = {JUN},
Abstract = {Internal models play a key role in cognitive agents by providing on the
   one hand predictions of sensory consequences of motor commands (forward
   models), and on the other hand inverse mappings (inverse models) to
   realize tasks involving control loops, such as imitation tasks. The
   ability to predict and generate new actions in continuously evolving
   environments intrinsically requiring the use of different sensory
   modalities is particularly relevant for autonomous robots, which must
   also be able to adapt their models online. We present a learning
   architecture based on self-learned multimodal sensorimotor
   representations. To attain accurate forward models, we propose an online
   heterogeneous ensemble learning method that allows us to improve the
   prediction accuracy by leveraging differences of multiple diverse
   predictors. We further propose a method to learn inverse models
   on-the-fly to equip a robot with multimodal learning skills to perform
   imitation tasks using multiple sensory modalities. We have evaluated the
   proposed methods on an iCub humanoid robot. Since no assumptions are
   made on the robot kinematic/dynamic structure, the method can be applied
   to different robotic platforms.},
Type = {Article},
Affiliation = {Zambelli, M (Corresponding Author), Imperial Coll London, Dept Elect \& Elect Engn, Personal Robot Lab, London SW7 2BT, England.
   Zambelli, Martina; Demiris, Yiannis, Imperial Coll London, Dept Elect \& Elect Engn, Personal Robot Lab, London SW7 2BT, England.},
DOI = {10.1109/TCDS.2016.2624705},
Keywords = {Ensemble learning; multimodal imitation learning; online learning;
   sensorimotor contingencies},
Keywords-Plus = {ONE-SHOT; IMITATION; MODELS; ROBOT; REGRESSION; FRAMEWORK; SYSTEMS;
   SKILLS; TASK},
Author-Email = {m.zambelli13@imperial.ac.uk
   y.demiris@imperial.ac.uk},
Number-of-Cited-References = {82},
Times-Cited = {29},
Unique-ID = {WOS:000403459100003},
}

@incollection{ WOS:000392007300016,
Author = {Li, Peipei and Wu, Xindong and Hu, Xuegang},
Editor = {Sugiyama, M and Yang, Q},
Title = {Mining Recurring Concept Drifts with Limited Labeled Streaming Data},
Booktitle = {PROCEEDINGS OF 2ND ASIAN CONFERENCE ON MACHINE LEARNING (ACML2010)},
Series = {JMLR Workshop and Conference Proceedings},
Year = {2010},
Volume = {13},
Pages = {241-252},
Abstract = {Tracking recurring concept drifts in data streams is a significant and
   challenging issue for machine learning and data mining that frequently
   appears in real world stream classification problems. However, it has
   received little attention from the research community. Motivated by
   this, we propose a Semi-supervised classification algorithm for data
   streams with REcurring concept Drifts and Limited LAbeled data, called
   REDLLA, in which, a decision tree is adopted as the classification
   model. When growing a tree, a clustering algorithm based on k-Means is
   installed to produce concept clusters and label unlabeled data at
   leaves. In view of deviations between history concept clusters and new
   ones, potential concept drifts are distinguished and recurring concepts
   are maintained. Extensive studies on both synthetic and real-world data
   confirm the advantages of our REDLLA algorithm over two state-of-the-art
   online classification algorithms and several known online
   semi-supervised algorithms, even in the case with more than 90\%
   unlabeled data.},
Type = {Proceedings Paper},
Affiliation = {Li, PP (Corresponding Author), Hefei Univ Technol, Sch Comp Sci \& Informat Engn, Hefei 230009, Peoples R China.
   Li, Peipei; Hu, Xuegang, Hefei Univ Technol, Sch Comp Sci \& Informat Engn, Hefei 230009, Peoples R China.
   Wu, Xindong, Univ Vermont, Dept Comp Sci, Burlington, VT 05405 USA.},
Keywords = {Data stream; concept drift; decision tree; clustering},
Author-Email = {PEIPEILI.HFUT@GMAIL.COM
   XWU@CS.UVM.EDU
   JSJXHUXG@HFUT.EDU.CN},
