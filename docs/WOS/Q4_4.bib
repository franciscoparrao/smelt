   Fuhrman, Jed A., Univ Southern Calif, Dept Biol Sci, Los Angeles, CA 90089 USA.
   Fuhrman, Jed A., Univ Southern Calif, Wrigley Inst Environm Studies, Los Angeles, CA 90089 USA.
   Sun, Fengzhu, Fudan Univ, Ctr Computat Syst Biol, Shanghai 200433, Peoples R China.},
DOI = {10.1093/bioinformatics/btw290},
Keywords-Plus = {PHYLOGENETIC CLASSIFICATION; GENOMES; ALGORITHM; TOOL},
Author-Email = {fsun@usc.edu},
Number-of-Cited-References = {45},
Times-Cited = {101},
Unique-ID = {WOS:000397986500001},
}

@article{ WOS:000331851700035,
Author = {Yu, Qi and Miche, Yoan and Severin, Eric and Lendasse, Amaury},
Title = {Bankruptcy prediction using Extreme Learning Machine and financial
   expertise},
Journal = {NEUROCOMPUTING},
Year = {2014},
Volume = {128},
Pages = {296-302},
Month = {MAR 27},
Abstract = {Bankruptcy prediction has been widely studied as a binary classification
   problem using financial ratios methodologies. In this paper,
   Leave-One-Out-Incremental Extreme Learning Machine (LOO-IELM) is
   explored for this task. LOO-IELM operates in an incremental way to avoid
   inefficient and unnecessary calculations and stops automatically with
   the neurons of which the number is unknown. Moreover, Combo method and
   further Ensemble model are investigated based on different LOO-IELM
   models and the specific financial indicators. These indicators are
   chosen using different strategies according to the financial expertise.
   The entire process has shown its good performance with a very fast
   speed, and also helps to interpret the model and the special ratios. (C)
   2013 Published by Elsevier B.V.},
