DOI = {10.3390/electronics10131534},
Article-Number = {1534},
Keywords = {intrusion detection; outlier detection; streaming data; network
   security; online learning; unsupervised learning; machine learning},
Keywords-Plus = {ANOMALY DETECTION; CLASSIFIERS; SELECTION; ENSEMBLE; ATTACKS},
Author-Email = {heigl@kiv.zcu.cz
