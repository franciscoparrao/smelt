}

@incollection{ WOS:000672800000039,
Author = {Mahdi, Osama A. and Pardede, Eric and Ali, Nawfal},
Editor = {Shakshuki, E and Yasar, A},
Title = {KAPPA as Drift Detector in Data Stream Mining},
Booktitle = {12TH INTERNATIONAL CONFERENCE ON AMBIENT SYSTEMS, NETWORKS AND
   TECHNOLOGIES (ANT) / THE 4TH INTERNATIONAL CONFERENCE ON EMERGING DATA
   AND INDUSTRY 4.0 (EDI40) / AFFILIATED WORKSHOPS},
Series = {Procedia Computer Science},
Year = {2021},
Volume = {184},
Pages = {314-321},
Abstract = {Concept Drift is considered a challenging problem that appears in data
   streaming. The classifier's error rate and the ensemble are used in most
   of the previous works to manage classification accuracy as a criterion
   for judging whether concept drift is happening or not. KAPPA is an
   effective way to measure the level of agreement, and it may be suitable
   to detect concept drift in a reliable, fast, and computationally
   efficient way. In this paper, we propose a new concept drift detector,
   called KAPPA, which aims at reacting to detect concept drift in a
   reliable, fast, and computationally efficient way. Contrary the
   disagreement measure that we have already considered in our preliminary
   work (DMDDM), KAPPA would measure the level of agreement when different
   classifiers access data items is suitable to detect concept drifts. The
   performance of KAPPA has been experimentally compared with DMDDM on
   synthetic dataset streams, considering different performance measures,
   e.g., delay detection, true positives and the mean accuracy. (C) 2021
   The Authors. Published by Elsevier B.V.},
Type = {Proceedings Paper},
Affiliation = {Mahdi, OA (Corresponding Author), La Trobe Univ, Melbourne, Vic 3086, Australia.
   Mahdi, Osama A.; Pardede, Eric, La Trobe Univ, Melbourne, Vic 3086, Australia.
   Ali, Nawfal, Monash Univ, Clayton, Vic 3800, Australia.},
DOI = {10.1016/j.procs.2021.03.040},
Keywords = {Concept Drift; Data Stream Mining; Non-stationary Environments; KAPPA},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {o.mahdi@latrobe.edu.au},
Number-of-Cited-References = {31},
Times-Cited = {5},
Unique-ID = {WOS:000672800000039},
}

@incollection{ WOS:000800559501071,
Author = {Xu, Yiming and Klabjan, Diego},
Editor = {Chen, Y and Ludwig, H and Tu, Y and Fayyad, U and Zhu, X and Hu, X and Byna, S and Liu, X and Zhang, J and Pan, S and Papalexakis, V and Wang, J and Cuzzocrea, A and Ordonez, C},
Title = {Concept Drift and Covariate Shift Detection Ensemble with Lagged Labels},
Booktitle = {2021 IEEE INTERNATIONAL CONFERENCE ON BIG DATA (BIG DATA)},
Series = {IEEE International Conference on Big Data},
Year = {2021},
Pages = {1504-1513},
Abstract = {In model serving, having one fixed model during the entire often
   life-long inference process is usually detrimental to model performance,
   as data distribution evolves over time, resulting in lack of reliability
   of the model trained on historical data. It is important to detect
   changes and retrain the model in time. The existing methods generally
   have three weaknesses: 1) using only classification error rate as
   signal, 2) assuming ground truth labels are immediately available after
   features from samples are received and 3) unable to decide what data to
   use to retrain the model when change occurs. We address the first
   problem by utilizing six different signals to capture a wide range of
   characteristics of data, and we address the second problem by allowing
   lag of labels, where labels of corresponding features are received after
   a lag in time. For the third problem, our proposed method automatically
   decides what data to use to retrain based on the signals. Extensive
   experiments on structured and unstructured data for different type of
   data changes establish that our method consistently outperforms the
   state-of-the-art methods by a large margin.},
Type = {Proceedings Paper},
Affiliation = {Xu, YM (Corresponding Author), Northwestern Univ, Evanston, IL 60208 USA.
   Xu, Yiming; Klabjan, Diego, Northwestern Univ, Evanston, IL 60208 USA.},
DOI = {10.1109/BigData52589.2021.9671279},
Keywords = {Drift Detection; Model Serving; Lagged Labels},
Author-Email = {x.yiming@outlook.com
   d-klabjan@northwestern.edu},
Number-of-Cited-References = {20},
Times-Cited = {5},
Unique-ID = {WOS:000800559501071},
}

@incollection{ WOS:000704288403091,
Author = {Yang, Chen and Yang, Shuyuan},
Book-Group-Author = {IEEE},
Title = {DEEP ENSEMBLE SIAMESE NETWORK FOR INCREMENTAL SIGNAL CLASSIFICATION},
Booktitle = {2021 IEEE INTERNATIONAL CONFERENCE ON ACOUSTICS, SPEECH AND SIGNAL
   PROCESSING (ICASSP 2021)},
Year = {2021},
Pages = {3200-3204},
Abstract = {Incremental Signal Classification (ISC) aims to continuously identify
   and classify unknown signal categories, which is essentially an open-set
   classification task. In this paper, a new Deep Ensemble Siamese Network
   (DESN) is constructed for unknown category detection and incremental
   accumulation of signals from the detected category. Then the accumulated
   samples are used to update a One-dimensional Convolution Network (OCN)
   for incremental learning of new signal categories. Experimental results
   show that the proposed method can achieve accurate detection and
   accumulation of unknown signals, and is feasible for practical ISC.},
Type = {Proceedings Paper},
Affiliation = {Yang, C (Corresponding Author), Xidian Univ, Sch Artificial Intelligence, Xian, Shaanxi, Peoples R China.
