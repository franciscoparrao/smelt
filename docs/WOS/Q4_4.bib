@incollection{ WOS:000530893803069,
Author = {Xu, Rui and Yan, WeiZhong},
Book-Group-Author = {IEEE},
Title = {Continuous Modeling of Power Plant Performance with Regularized Extreme
   Learning Machine},
Booktitle = {2019 INTERNATIONAL JOINT CONFERENCE ON NEURAL NETWORKS (IJCNN)},
Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2019},
Abstract = {Power plant modeling is critically important for power plant operation
   optimization and cost reduction. The inherently nonstationary
   characteristics of power plants raise a big challenge to the learning
   mechanisms and require the learning algorithms to adapt effectively and
   promptly to the continuously drifting environments. In our previous
   study, we proposed an online ensemble regression approach, with extreme
   learning machine (ELM) as the base model, to model power plant
   performance in a dynamic environment, which can autonomously update
   models to respond to environmental changes, either gradual or abrupt.
   However, one drawback we observed for the proposed approach is that the
   algorithm performance is not stable due to the randomness nature of
   ELMs. In this paper, we address this issue by applying regularized ELM
   as the base model within the online ensemble framework. The empirical
   results on three real power plant data sets demonstrate that the
   proposed modification can lead to more stable generalization performance
   of the algorithm. At the same time, the algorithm consistently achieves
   performance with mean average percentage error less than the required
   1\% threshold in real field operations.},
Type = {Proceedings Paper},
Affiliation = {Xu, R (Corresponding Author), GE Global Res, Artificial Intelligence \& Machine Learning Lab, Niskayuna, NY 12309 USA.
   Xu, Rui; Yan, WeiZhong, GE Global Res, Artificial Intelligence \& Machine Learning Lab, Niskayuna, NY 12309 USA.},
Keywords = {power plant performance modeling; ensemble learning; online learning;
   extreme learning machines; regularization; learning in nonstationary
   environments; concept drift},
Keywords-Plus = {CONCEPT DRIFT; CLASSIFIERS; ALGORITHM},
Author-Email = {xur@ge.com
   yan@ge.com},
Number-of-Cited-References = {36},
Times-Cited = {8},
Unique-ID = {WOS:000530893803069},
}

