   Carvalho, Andre C. P. L. F., Univ Sao Paulo, ICMC, USP Ave Trabalhador Saocarlense,400 Ctr Sao Carlo, Sao Carlos, SP, Brazil.},
DOI = {10.1016/j.knosys.2016.04.019},
Keywords = {Adaptive learning; Concept drift; Data stream mining; Decision trees;
   Incremental learning; Online learning},
