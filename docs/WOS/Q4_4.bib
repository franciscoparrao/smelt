DOI = {10.1016/j.jretconser.2024.103922},
EarlyAccessDate = {MAY 2024},
Article-Number = {103922},
Keywords = {Consumers' basic characteristics; Attitudes; S-O-R; Correspondence
   analysis; Logistic regression; Decision tree},
