   Lumini, Alessandra, Univ Bologna, Dept Comp Sci \& Engn, Bologna, Italy.
   Brahnam, Sheryl, Missouri State Univ, Dept Informat Technol \& Cybersecur, Springfield, MO 65897 USA.},
DOI = {10.1108/ACI-11-2021-0301},
Keywords = {Machine learning; Multilabel classifier; Bidirectional long short-term
