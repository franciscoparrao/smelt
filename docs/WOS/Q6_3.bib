   Cheng, Haoran, Emory Univ, Rollins Sch Publ Hlth, Atlanta, GA USA.
   Teo, Zhen Ling; Ting, Daniel Shu Wei, Singapore Natl Eye Ctr, Singapore, Singapore.},
DOI = {10.47102/annals-acadmedsg.2023113},
Keywords = {AI; artificial intelligence; automated machine learning; autoML; machine
