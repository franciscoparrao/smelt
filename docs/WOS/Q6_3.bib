@article{ WOS:001685756000001,
Author = {Mokhtari, Abolfazl and Nikzad, Mohammad Hossein},
Title = {From classical machine learning to modern neural networks for
   multi-output prediction of metallic composites mechanical properties
   using a small molecular dynamics-driven dataset: Application to Al-Cu
   alloys with pre-existing voids},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2026},
Volume = {51},
Month = {FEB},
Abstract = {High-fidelity molecular dynamics (MD) simulations provide a physically
   grounded route to estimate mechanical properties of metallic alloys and
   composites; however, each simulation can be computationally expensive,
   and systematic sampling across composition, defect features, and
   thermomechanical conditions often yields practically small MD-driven
   datasets. This challenge is further amplified in multi-output
   regression, where multiple target properties must be predicted
   simultaneously from limited data. To address this, we conducted a
   comprehensive benchmark study of 21 machine learning (ML) algorithms for
   the simultaneous prediction of Young's modulus (E) and ultimate tensile
   strength (UTS) of Al-Cu alloys with pre-existing voids derived from MD
   simulation. Nineteen of these were classical ML methods, one was a
   classical feed-forward neural network (FFNN), and one was a modern
   tabular neural network (TabNet). Our results show that Gaussian Process
   Regression (GPR) achieved the highest accuracy across all models, with a
   coefficient of determination R2 = 98.89 \% and mean absolute error (MAE)
   = 0.024 on the test set. Among the neural network approaches, the modern
   TabNet architecture outperformed the classical FFNN, demonstrating
   superior ability to learn from a limited, structured dataset. To further
   interpret the models, Shapley Additive Explanations (SHAP) analysis was
   employed, identifying temperature and strain rate as the most
   influential parameters for E and UTS, respectively. Overall, this study
   provides a systematic evaluation of predictive strategies for mechanical
   property estimation in metallic alloys and composites under small-data
   conditions. While experimental measurements remain essential for
   validation and for improving predictive fidelity in alloy design, the
   proposed MD-ML-SHAP framework enables accurate and interpretable
   multi-target predictions when exhaustive simulations or experiments are
   infeasible.},
