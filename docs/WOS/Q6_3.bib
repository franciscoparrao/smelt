}

@incollection{ WOS:000793730500024,
Author = {Braendle, Sebastian and Hanussek, Marc and Blohm, Matthias and Kintz,
   Maximilien},
Editor = {Arai, K},
Title = {Evaluation of Representation Models for Text Classification with AutoML
   Tools},
Booktitle = {PROCEEDINGS OF THE FUTURE TECHNOLOGIES CONFERENCE (FTC) 2021, VOL 2},
Series = {Lecture Notes in Networks and Systems},
Year = {2022},
Volume = {359},
Pages = {310-322},
Abstract = {Automated Machine Learning (AutoML) has gained increasing success on
   tabular data in recent years. However, processing unstructured data like
   text is a challenge and not widely supported by open-source AutoML
   tools. This work compares three manually created text representations
   and text embeddings automatically created by AutoML tools. Our benchmark
   includes four popular open-source AutoML tools and eight datasets for
   text classification purposes. The results show that straightforward text
   representations perform better than AutoML tools with automatically
   created text embeddings.},
Type = {Proceedings Paper},
Affiliation = {Blohm, M (Corresponding Author), Univ Stuttgart IAT, Inst Human Factors \& Technol Management, Stuttgart, Germany.
