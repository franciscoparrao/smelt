@article{ WOS:001658618200004,
Author = {De Aquino Silva, Rogerio and Pinto, Alex Sandro Roschildt and Medeiros
   De Araujo, Gustavo and Emilia Maria Ricci, Laura},
Title = {A Novel Cryptocurrency Trend Prediction Framework Powered by Innovative
   Feature Engineering},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {3722-3743},
Abstract = {Bitcoin trend prediction in high-frequency environments remains a
   significant challenge. This study introduces a robust feature
   engineering methodology that achieves state-of-the-art accuracy in
   Bitcoin trend classification across multiple temporal granularities. Our
   approach, which systematically combines temporal variables with
   recalibrated technical indicators, was refined through rigorous
   hyperparameter optimization and forecasting horizon standardization.
   These methodological improvements unlocked remarkable predictive power,
   particularly at fine-grained intervals, demonstrating a relative
   accuracy improvement of up to 73\% over established benchmarks. Through
   a comprehensive evaluation against two seminal studies using over 20
   machine learning models, we demonstrate that our approach is effective
   at 5-minute, 15-minute, and 1-hour granularities, achieving a peak
   accuracy of 91.9\% with a RandomForest model at the 5-minute level. This
   result challenges the conventional view that high-frequency data is too
   noisy for reliable trend prediction. A key finding is that intelligent
   feature engineering, when paired with appropriate model selection,
   surpasses the performance of more complex deep learning architectures,
   which consistently underperformed in our tests. The superior performance
   of tree-based ensemble methods highlights the synergy between our
   tabular feature set and these algorithms. This methodology provides
   immediate practical value for algorithmic trading and risk management,
   offering a validated, high-performance framework. Our study provides a
   complete and reproducible guide, from theoretical justification to
   empirical validation, establishing a new, robust baseline for
   cryptocurrency market analysis.},
Type = {Article},
Affiliation = {Pinto, ASR (Corresponding Author), Univ Fed Santa Catarina, Dept IT \& Stat INE, BR-88040900 Florianopolis, SC, Brazil.
   De Aquino Silva, Rogerio; Pinto, Alex Sandro Roschildt, Univ Fed Santa Catarina, Dept IT \& Stat INE, BR-88040900 Florianopolis, SC, Brazil.
   Medeiros De Araujo, Gustavo, Univ Fed Santa Catarina, Dept Informat Sci, PGCIN, BR-88040900 Florianopolis, SC, Brazil.
   Emilia Maria Ricci, Laura, Univ Pisa, Dept Comp Sci, I-56126 Pisa, Italy.},
DOI = {10.1109/ACCESS.2025.3640400},
Keywords = {Market research; Bitcoin; Accuracy; Benchmark testing; Forecasting; Time
   series analysis; Predictive models; Trees (botanical); Machine learning
   algorithms; Biological system modeling; Cryptocurrencies; machine
   learning; minute granularity; time series analysis; trend forecasting},
Keywords-Plus = {OCCAMS RAZOR; BITCOIN},
Author-Email = {a.r.pinto@ufsc.br},
Number-of-Cited-References = {98},
Times-Cited = {0},
Unique-ID = {WOS:001658618200004},
