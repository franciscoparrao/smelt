@article{ WOS:001582056600003,
Author = {Lange, Christoph and Altmann, Madeline and Stors, Daniel and Seidel,
   Simon and Moynahan, Kyle and Cai, Linda and Born, Stefan and Neubauer,
   Peter and Bournazou, M. Nicolas Cruz},
Title = {Deep learning for Raman spectroscopy: Benchmarking models for upstream
   bioprocess monitoring},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {258},
Number = {A},
Month = {JAN 30},
Abstract = {Raman spectroscopy serves as a useful Process Analytical Technology in
   biotechnology, allowing us to monitor upstream bioprocesses in real-time
   by estimating substrate and product concentrations from spectral data.
   While there is potential in machine learning models for enhancing
   concentration predictions, we note a lack of systematic comparisons
   among modern deep learning architectures and gradient boosted tree
   methods for this regression task. In this study, we present a new
   reference dataset of 6960 annotated spectra for evaluating machine
   learning models on Raman spectra. We compare eleven different model
   types, including Convolutional Neural Networks, attention-based
   transformers, ensemble methods, and traditional chemometric approaches
   such as Partial Least Squares. The dataset consists of spectra for eight
   key fermentation substrates, generated using an automated pipetting
   system to ensure a broad and unbiased representation of concentration
   variations. Our results show that some deep learning approaches
   significantly outperform Partial Least Squares in terms of coefficient
   of determination and Mean Absolute Error. In particular, we observe that
   the in-context learning approach Tabular Prior-data Fitted Network
   achieves promising results for most substances but remains inconsistent
   across all analytes. By publishing our dataset, we aim to facilitate the
   development of more accurate and generalizable models for Raman
   spectroscopy applications. Our findings underscore the potential of deep
   learning for spectroscopic methods bioprocess monitoring while
   highlighting the need for further research on attention-based and
   in-context learning approaches for spectral data analysis.},
Type = {Article},
Affiliation = {Lange, C (Corresponding Author), Tech Univ Berlin, Inst Biotechnol, Fac Process Sci 3, Chair Bioprocess Engn, Str 17 Juni 135, D-10623 Berlin, Germany.
   Lange, Christoph; Altmann, Madeline; Stors, Daniel; Seidel, Simon; Moynahan, Kyle; Cai, Linda; Neubauer, Peter; Bournazou, M. Nicolas Cruz, Tech Univ Berlin, Inst Biotechnol, Fac Process Sci 3, Chair Bioprocess Engn, Str 17 Juni 135, D-10623 Berlin, Germany.
   Born, Stefan, Tech Univ Berlin, Orientierungsstudium MINTgrun, Str 17 Juni 135, D-10623 Berlin, Germany.},
DOI = {10.1016/j.measurement.2025.118884},
EarlyAccessDate = {SEP 2025},
Article-Number = {118884},
Keywords = {Raman spectroscopy; Deep learning; Upstream bioprocessing; Gradient
   boosted trees; Partial least squares},
Keywords-Plus = {CONVOLUTIONAL NEURAL-NETWORKS},
Author-Email = {christoph.lange@tu-berlin.de},
Number-of-Cited-References = {96},
Times-Cited = {1},
Unique-ID = {WOS:001582056600003},
}

@article{ WOS:001568890900001,
Author = {Chan, Jun Qiang and Azam, S. M. Kayser and Raymond, Wong Jee Keen and
   Illias, Hazlee Azil and Othman, Mohamadariff},
Title = {Compensation strategies for improved real-world deployment of deep
   learning-based partial discharge localization from digital twin data},
Journal = {AIN SHAMS ENGINEERING JOURNAL},
Year = {2025},
Volume = {16},
Number = {12},
Month = {DEC},
Abstract = {Measurement errors caused by real-time electromagnetic (EM) noise or the
   sensitivity of measuring equipment significantly affect Partial
   Discharge (PD) localization accuracy in open-space substations. This
   study proposes a Deep Neural Network (DNN) approach combined with an
   augmented Time Difference of Arrival (TDOA) dataset to improve PD
   coordinate estimation. A digital twin of a 10 m x 10 m x 2 m space was
   used to generate over one million synthetic data points, substantially
   reducing data collection time. The trained DNN demonstrated excellent
   localization performance in the digital environment, with more than 90\%
   of errors below 5\%, as validated by 3D scatter plots. Despite relying
   on augmented TDOA data from the digital twin, the DNN model exhibited
   high confidence when applied to real-world measurements, achieving an
   average localization error of 0.3610 m across 21 test points,
   outperforming Random Forest Regression (RFR), Gaussian Process
   Regression (GPR) and 1-dimensional Convolutional Neural Networks
   (1DCNN). Additionally, an in-depth analysis of the augmented TDOA
   dataset synthesis was conducted to optimize the DNN model. Key factors
   investigated included the impact of dataset size on localization
   accuracy, training time and performance across different training
   durations. Finally, a benchmarking comparison with existing methods was
   summarized in tabular form, highlighting the advantages of the proposed
   work over conventional iterative algorithms and other machine learning
   (ML) models.},
Type = {Article},
Affiliation = {Raymond, WJK (Corresponding Author), Univ Malaya, Fac Engn, Dept Elect Engn, Kuala Lumpur 50603, Malaysia.
   Chan, Jun Qiang; Azam, S. M. Kayser; Raymond, Wong Jee Keen; Illias, Hazlee Azil; Othman, Mohamadariff, Univ Malaya, Fac Engn, Dept Elect Engn, Kuala Lumpur 50603, Malaysia.},
DOI = {10.1016/j.asej.2025.103734},
EarlyAccessDate = {SEP 2025},
Article-Number = {103734},
Keywords = {Digital twin; Deep neural network; Partial discharge; Substation; TDOA
   localization; UHF},
