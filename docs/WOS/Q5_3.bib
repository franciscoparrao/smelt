@article{ WOS:001708783200001,
Author = {Xia, Xuemin and Zhao, Yule and Jiang, Simin and Hu, Yao and Li, Xianwen},
Title = {A hybrid deep learning-data assimilation approach for joint inversion of
   groundwater contaminant sources and hydraulic conductivity with
   uncertain boundary conditions},
Journal = {ADVANCES IN WATER RESOURCES},
Year = {2026},
Volume = {211},
Month = {MAY},
Abstract = {Accurate identification of groundwater contamination sources is
   essential for effective risk assessment and remediation design.
   Conventional inversion methods, however, often treat the boundary
   conditions as known, an assumption that is frequently invalid under
   real-world hydrogeological conditions and leads to structural bias as
   well as reduced reliability of estimated parameters. To address this,
   this study proposes an integrated deep learning-enhanced inversion
   framework for simultaneous estimation of contaminant source
   characteristics, heterogeneous hydraulic conductivity fields, and
   uncertain boundary conditions. The framework integrates three key
   components: (1) a Wasserstein GAN with gradient penalty (WGAN-GP) for
   low-dimensional latent representation of high-dimensional conductivity
   fields while preserving geostatistical features; (2) a novel
   CNN-Transformer surrogate model that captures both local spatial
   heterogeneity and long-range spatiotemporal dependencies under dynamic
   boundary scenarios, enhanced by a boundary-aware feature selection
   mechanism and a localized loss function; and (3) an Iterative Local
   Updating Ensemble Smoother (ILUES) for robust multi-parameter
   assimilation. Evaluated on synthetic cases with constant-head,
   constant-flux, and time-varying flux boundaries, the proposed method
   accurately identifies boundary types, characterize contaminant source
   parameters and precisely reconstructs heterogeneous hydraulic
   conductivity fields, thereby substantially reducing overall parameter
   uncertainty. Moreover, it achieves considerable computational
   acceleration compared to highfidelity physical simulations while
   maintaining comparable inversion accuracy. This study presents a viable
   solution for reliable source characterization in complex aquifers with
   unknown boundary conditions, while revealing the potential to enhance
   joint parameter estimation through further integration of data
   assimilation and deep learning methodologies.},
Type = {Article},
Affiliation = {Xia, XM (Corresponding Author), Univ Shanghai Sci \& Technol, Sch Environm \& Architecture, Shanghai 200083, Peoples R China.
   Xia, XM (Corresponding Author), China Univ Geosci Beijing, Key Lab Groundwater Circulat \& Environm Evolut, MOE, Beijing 100083, Peoples R China.
   Xia, Xuemin; Zhao, Yule; Hu, Yao, Univ Shanghai Sci \& Technol, Sch Environm \& Architecture, Shanghai 200083, Peoples R China.
   Xia, Xuemin, China Univ Geosci Beijing, Key Lab Groundwater Circulat \& Environm Evolut, MOE, Beijing 100083, Peoples R China.
