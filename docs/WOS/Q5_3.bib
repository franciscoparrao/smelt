@article{ WOS:001270631300001,
Author = {Zhou, Bin and Zou, Qiang and Jiang, Hu and Yang, Tao and Zhou, Wentao
   and Chen, Siyu and Yao, Hongkun},
Title = {A novel framework for predicting glacial lake outburst debris flows in
   the Himalayas amidst climate change},
Journal = {SCIENCE OF THE TOTAL ENVIRONMENT},
Year = {2024},
Volume = {946},
Month = {OCT 10},
Abstract = {The retreat of Himalayan glaciers and the expansion of glacial lakes due
   to global warming have increased the occurrence of glacial lake outburst
   debris flow (GLODF), posing a serious threat to downstream communities.
   However, there are gaps in understanding the changes in GLODF occurrence
   driven by climate change, which challenges disaster management and
   cross-border cooperation in the Himalayas. To consider this issue, our
   study presents a novel framework integrating environmental evolution, a
   process-driven indicator system, and a hybrid machine learning model to
   predict Himalayan GLODF occurrence in the 21st century. Our findings
   indicate ongoing temperature (0.27-0.60 degrees C/10a) and precipitation
   (1.30-5.00 \%/10a) increases under both SSP245 and SSP585 scenarios.
   Meanwhile, Himalayan glaciers are projected to lose between 70 \% and 86
   \% of their mass by 2100 compared to 2020. Additionally, 2722 +/- 207
   new glacial lakes are expected to emerge by 2100. GLODF occurrence
   probability index is anticipated to rise to 1.27-1.30 times the current
   levels, with the Western Himalayas and Indus basin as high-incidence
   areas. Currently and in the future, the China-Nepal border remains a
   hotspot for cross-border GLODF. Our framework offers valuable long-term
   insights into Himalayan GLODF occurrence trends in response to climate
   change.},
Type = {Article},
Affiliation = {Zou, Q (Corresponding Author), Chinese Acad Sci, Inst Mt Hazards \& Environm IMHE, Chengdu, Peoples R China.
   Zhou, Bin; Zou, Qiang; Jiang, Hu; Yang, Tao; Zhou, Wentao; Chen, Siyu; Yao, Hongkun, Chinese Acad Sci, Inst Mt Hazards \& Environm, State Key Lab Mt Hazards \& Engn Resilience, Chengdu 610299, Peoples R China.
   Zhou, Bin; Jiang, Hu; Zhou, Wentao; Yao, Hongkun, Univ Chinese Acad Sci, Beijing 100049, Peoples R China.
   Chen, Siyu, Southwest Univ Sci \& Technol, Sch Environm \& Resource, Mianyang 621010, Peoples R China.},
DOI = {10.1016/j.scitotenv.2024.174435},
EarlyAccessDate = {JUL 2024},
Article-Number = {174435},
Keywords = {Glacial lake outburst debris flow; Occurrence probability; Prediction;
   Climate change; Himalayas},
Keywords-Plus = {HIGH-MOUNTAIN ASIA; SPATIAL INTERPOLATION; TIBETAN PLATEAU; LANDSLIDES;
   IMPACTS; HAZARD; FLOOD; MODEL; GIS; PRECIPITATION},
