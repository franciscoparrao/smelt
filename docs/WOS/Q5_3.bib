}

@article{ WOS:001693038800001,
Author = {Sun, Yaoyu and Bose, Neil and Hwang, Jimin and Zou, Ting},
Title = {Chronic oil pollution in small ports: A review of the role and potential
   of AUVs},
Journal = {MARINE POLLUTION BULLETIN},
Year = {2026},
Volume = {226},
Month = {MAY},
Abstract = {Chronic oil pollution in small ports are typically low-level, repeated,
   and long-lasting, making them difficult to monitor with conventional
   approaches. Autonomous Underwater Vehicles (AUVs) provide a mobile means
   of high-resolution in-situ observation. This review evaluates recent
   progress in sensor integration, data fusion, spatial interpolation, and
   machine learning methods that improve AUV-based detection. Fluorescence
   sensors, mass spectrometers, and hybrid payloads expand chemical
   monitoring capacity, while fusion techniques mitigate the weaknesses of
   individual sensors. Interpolation approaches such as Gaussian Process
   Regression (GPR) address spatial gaps in survey data, and
   physics-informed models add physical constraints. Together, these
   advances highlight the potential for AUVs to serve as practical tools
   for monitoring chronic oil pollution in confined, dynamic port
   environments.},
Type = {Review},
Affiliation = {Sun, YY (Corresponding Author), Mem Univ Newfoundland, Dept Ocean \& Naval Architectural Engn, 240 Prince Philip Dr, St John, NF A1B 3X5, Canada.
   Sun, Yaoyu; Bose, Neil; Hwang, Jimin, Mem Univ Newfoundland, Dept Ocean \& Naval Architectural Engn, 240 Prince Philip Dr, St John, NF A1B 3X5, Canada.
   Zou, Ting, Mem Univ Newfoundland, Dept Mech \& Mechatron Engn, 240 Prince Philip Dr, St John, NF A1B 3X5, Canada.},
DOI = {10.1016/j.marpolbul.2026.119421},
EarlyAccessDate = {MAY 2026},
Article-Number = {119421},
Keywords = {AUVs; Chronic oil pollution; Small ports; Oil detection; Multi-sensor
   fusion; Spatial interpolation},
Keywords-Plus = {POLYCYCLIC AROMATIC-HYDROCARBONS; UNDERWATER VEHICLES; SPILLS; PAHS;
   INTERPOLATION; SEDIMENTS; SEABIRDS; SENSORS; SURFACE; DESIGN},
