@article{ WOS:001434688900001,
Author = {Guo, Hongyang and Luo, Changqi and Zhu, Shun-Peng and You, Xinya and
   Yan, Mengli and Liu, Xiaohua},
Title = {Machine learning-based enhanced Monte Carlo simulation for low failure
   probability structural reliability analysis},
Journal = {STRUCTURES},
Year = {2025},
Volume = {74},
Month = {APR},
Abstract = {Low failure probability problems with high computational costs are
   difficult to solve. Regarding this, a structural reliability analysis
   method (called AK-EMCS-SVR) combining active Kriging model, support
   vector regression and enhanced Monte Carlo simulation is proposed. To
   achieve global modeling, the uniform sampling strategy and expected
   feasibility function are also adopted. Besides, this paper proposes an
   adaptive training interval combining with the support vector regression
   algorithm to achieve more accurate and robust prediction. Five numerical
   cases and a finite element engineering case are used to illustrate the
   effectiveness of the proposed method. The results comparison showed that
   the AK-EMCS-SVR has an advantage in the number of calls to the limit
   state function and to the surrogate model. The method shows higher
   accuracy and robustness solving low failure probability problems with
   high computational cost.},
Type = {Article},
Affiliation = {Zhu, SP (Corresponding Author), Univ Elect Sci \& Technol China, Sch Mech \& Elect Engn, Chengdu 611731, Peoples R China.
   Guo, Hongyang; Luo, Changqi; Zhu, Shun-Peng; You, Xinya; Yan, Mengli; Liu, Xiaohua, Univ Elect Sci \& Technol China, Sch Mech \& Elect Engn, Chengdu 611731, Peoples R China.
   Zhu, Shun-Peng, UESTC Guangdong, Inst Elect \& Informat Engn, Dongguan 523808, Peoples R China.},
DOI = {10.1016/j.istruc.2025.108530},
EarlyAccessDate = {FEB 2025},
Article-Number = {108530},
Keywords = {Structural reliability analysis; Enhanced Monte Carlo simulation;
   Support vector regression; Kriging model},
Keywords-Plus = {IMPORTANCE SAMPLING METHOD},
