   Dengiz, O., Ondokuz Mayis Univ, Agr Fac, Plant Nutr \& Soil Sci Dept, Samsun, Turkiye.},
DOI = {10.1007/s13762-024-05574-z},
EarlyAccessDate = {APR 2024},
Keywords = {Soil properties; Erodibility factors; Machine-learning algorithm; Remote
   sensing; Kriging},
Keywords-Plus = {SPATIAL PREDICTION; TEXTURE; BIOMASS; EROSION},
