   He, Dupeng, China Steel Research\& Technol Grp Co, Digital R\&D Ctr, Beijing, Peoples R China.},
DOI = {10.1016/j.mtcomm.2023.105556},
EarlyAccessDate = {FEB 2023},
Article-Number = {105556},
Keywords = {Laser welding; Aluminum alloys; Welding metal composition; Thermodynamic
   method; Solidification cracking; Machine learning},
Keywords-Plus = {DENDRITE-ARM; SUSCEPTIBILITY; PERFORMANCE; DIFFUSION; LIQUATION; ISSUES},
Author-Email = {xnrpt@swjtu.edu.cn
