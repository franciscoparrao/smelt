@article{ WOS:001464701100001,
Author = {Laimighofer, J. and Laaha, G.},
Title = {Statistical Learning and Topkriging Improve Spatio-Temporal Low-Flow
   Estimation},
Journal = {WATER RESOURCES RESEARCH},
Year = {2025},
Volume = {61},
Number = {4},
Month = {APR 11},
Abstract = {This study evaluates the potential of a novel hierarchical space-time
   model for predicting monthly low-flow in ungauged basins. The model
   decomposes the monthly low-flows into a mean field and a residual field,
   where the mean field represents the seasonal low-flow regime plus a
   long-term trend component. We compare four statistical learning
   approaches for the mean field, and three geostatistical methods for the
   residual field. All model combinations are evaluated using a
   hydrologically diverse dataset of 260 stations in Austria and the
   predictive performance is validated using nested 10-fold
   cross-validation. The best model for monthly low-flow prediction is a
   combination of a model-based boosting approach for the mean field and
   topkriging for the residual field. This model reaches a median R2
   \$\{R\}<\^{}>\{2\}\$ of 0.73 across all stations, outperforming an
   XGBoost model on the same data set. Model performance is generally
   higher for stations with a winter regime (median R2 \$\{R\}<\^{}>\{2\}\$
   = 0.84) than for summer regimes (R2 \$\{R\}<\^{}>\{2\}\$ = 0.70), and
   lowest for the mixed regime type (R2 \$\{R\}<\^{}>\{2\}\$ = 0.68). The
   proposed model appears to be most useful in headwater catchments and
   provides robust estimates not only for moderate events, but also for
   extreme low-flow events. The favorable performance is due to the
   hierarchical model structure, which effectively combines different types
   of information: the low-flow regime estimated from average climate and
   catchment characteristics, and the actual flow conditions estimated from
   flow records of neighboring catchments. This information is readily
   available for most regions of the world, making the model easily
   transferable to other studies.},
Type = {Article},
Affiliation = {Laimighofer, J (Corresponding Author), Univ Nat Resources \& Life Sci BOKU, Inst Stat STAT, Vienna, Austria.
   Laimighofer, J.; Laaha, G., Univ Nat Resources \& Life Sci BOKU, Inst Stat STAT, Vienna, Austria.},
DOI = {10.1029/2024WR038329},
Article-Number = {e2024WR038329},
Keywords = {prediction in ungauged basins; low flow; geostatistics; drought; machine
   learning},
Keywords-Plus = {EMPIRICAL ORTHOGONAL FUNCTIONS; EUROPEAN 2015 DROUGHT; UNGAUGED BASINS;
   AIR-POLLUTION; FREQUENCY-ANALYSIS; MONTHLY RUNOFF; TIME-SERIES; R
   PACKAGE; INTERPOLATION; MODEL},
Author-Email = {johannes.laimighofer@boku.ac.at},
Number-of-Cited-References = {72},
Times-Cited = {1},
Unique-ID = {WOS:001464701100001},
}

@article{ WOS:001463537100003,
Author = {Rastkhadiv, Himan and Motamedvaziri, Baharak and Javadi, Seyed Akbar and
   Ahmadi, Hassan},
Title = {Landslide hazard zonation using advanced machine learning algorithms
   based on statistical models (Case study: Sarvabad, Iran)},
Journal = {EARTH SCIENCE INFORMATICS},
Year = {2025},
Volume = {18},
Number = {2},
Month = {APR 10},
Abstract = {Effectively reducing damages and making decisions on land development
   policies can be achieved identifying areas that are at high risk. Thus,
   the aim of the current research is to explore the risk of landslides
   zonation in Sarvabad by use of advanced machine learning algorithms
   based on statistical models. At the present research, landslide hazard
   zonation was conducted by use of hybrid algorithms, including Frequency
   Ratio-Random Forest (FR-RF), Frequency Ratio-Support Vector Machine
   (FR-SVM), Weight of Evidence-Random Forest (WoE-RF), and Weight of
   Evidence-Support Vector Machine (Woe-SVM). First, the point shape files
   of 166 landslides in Sarvabad, prepared by the Natural Resource
   Departmens of Kurdistan State, considered as the inventory of landslides
   map. The data from the landslide points was split into training sets
   comprising 70\% and validation sets comprising 30\%. To achieve to
   conduct the landslides hazard zone, a sum of 16 items were used that are
   as follows: slope, aspect, elevation, distance to the stream, distance
   to the road, river density, distance to the fault, fault density,
   roadway density, precipitation, land utilization, Normalized Difference
   Vegetation Index (NDVI), lithology, earthquake, Stream Power Index
   (SPI), and topographic wetness index (TWI). Finally, the performance of
   the models was evaluated using the ROC curve. Among the FR-RF, WoE-RF,
   FR-SVM, and WoE-SVM models, the FR-RF model accounted for the most high
   performance. In the end, it can be concluded that obtaining an accurate
   and reasonable spatial prediction map can help managers and urban
   planners identify zones susceptible to landslide occurrence so that they
   can manage the potential crises of landslide-prone zones.},
Type = {Article},
Affiliation = {Motamedvaziri, B (Corresponding Author), Islamic Azad Univ, Dept Nat Engn, Sci \& Res Branch, Tehran, Iran.
   Rastkhadiv, Himan; Motamedvaziri, Baharak; Javadi, Seyed Akbar, Islamic Azad Univ, Dept Nat Engn, Sci \& Res Branch, Tehran, Iran.
   Ahmadi, Hassan, Univ Tehran, Dept Reclamat Arid \& Mt Reg, Karaj, Iran.},
DOI = {10.1007/s12145-025-01862-5},
Article-Number = {370},
Keywords = {Landslide; Random forest algorithm; Support vector machine algorithm;
   Sarvabad},
Keywords-Plus = {SUPPORT VECTOR MACHINE; LOGISTIC-REGRESSION; SUSCEPTIBILITY ASSESSMENT;
   RANDOM FOREST; 3 GORGES; GIS; ENTROPY; INDEX; BASIN; DISTRICT},
Author-Email = {bmvaziri@gmail.com},
Number-of-Cited-References = {69},
