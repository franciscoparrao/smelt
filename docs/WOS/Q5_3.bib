   Li, Xianwen, Northwest A\&F Univ, Key Lab Agr Soil \& Water Engn Arid \& Semiarid Area, Minist Educ, Yangling 712100, Shaanxi, Peoples R China.},
DOI = {10.1016/j.advwatres.2026.105260},
Article-Number = {105260},
Keywords = {Uncertain boundary conditions; WGAN-GP; CNN-Transformer surrogate model;
   Data assimilation; Joint inversion},
