DOI = {10.1515/cls-2024-0004},
Article-Number = {20240004},
Keywords = {composite material reliability; reliability sensitivity; artificial
   neural network; support vector regression; Kriging; Monte Carlo
   simulation; active learning},
Keywords-Plus = {RESPONSE-SURFACE APPROACH; STRUCTURAL RELIABILITY; FREE-VIBRATION;
