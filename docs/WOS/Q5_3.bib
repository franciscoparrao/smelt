@article{ WOS:001581113300001,
Author = {Cui, Jiahang and Li, Jianghong and Cai, Feichao and Zhao, Zhenmin and
   Liu, Yuxi},
Title = {A GRU-KAN Surrogate Model with Genetic Algorithm Uniform Sampling for
   Active Magnetic Bearings-Rotor Critical Speed Prediction},
Journal = {SENSORS},
Year = {2025},
Volume = {25},
Number = {18},
Month = {SEP 11},
Abstract = {With the development of active magnetic bearings (AMBs) toward higher
   speeds, understanding high-speed rotor dynamics has become a crucial
   focus in AMB research. Traditional finite element modeling (FEM)
   methods, however, are unable to rapidly and comprehensively uncover the
   complex interplay between controller parameters and dynamic behavior. To
   address this limitation, a surrogate modeling approach based on a hybrid
   gated recurrent unit-Kolmogorov-Arnold network (GRU-KAN) is introduced
   to mathematically capture the effects of coupled control gains on rotor
   dynamics. To enhance model generalization, a genetic algorithm-driven
   uniform design sampling strategy is also implemented. Comparative
   studies against support vector regression and Kriging surrogates
   indicate a higher coefficient of determination (R2=0.9887) and lower
   residuals for the proposed approach. Experimental validation across
   multiple controller parameter combinations shows that the resulting
   machine learning surrogate predicts the critical speed with a mean
   absolute error of only 38.51 rpm and a mean absolute percentage error of
   1.56x10-1\%, while requiring merely 1.14x10-4 s per evaluation-compared
   to 201 s for traditional FEM. These findings demonstrate the surrogate's
   efficiency, accuracy, and comprehensive predictive capabilities,
   offering an effective method for rapid critical speed estimation in
   AMB-rotor systems.},
Type = {Article},
Affiliation = {Li, JH (Corresponding Author), Northwestern Polytech Univ, Sch Power \& Energy, Xian 710129, Peoples R China.
   Li, JH (Corresponding Author), Sci \& Technol Altitude Simulat Lab, Mianyang 621000, Peoples R China.
