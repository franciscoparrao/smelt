   spatiotemporal patterns},
Keywords-Plus = {CARBON-DIOXIDE CONCENTRATION; ATMOSPHERIC BOUNDARY-LAYER;
   VERTICAL-DISTRIBUTION; TRANSPORT MODEL; URBAN FORM; EMISSIONS; SURFACE;
   IMPACT; DYNAMICS; VARIABILITY},
