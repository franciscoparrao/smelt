   Frazier, Abby G., Clark Univ, Grad Sch Geog, Worcester, MA 01610 USA.
   McLean, Jared; Cleveland, Sean B., Informat \& Technol Serv, Honolulu, HI USA.
   Huang, Yu-Fen, Univ Hawaii Manoa, Dept Nat Resources \& Environm Management, Honolulu, HI 96822 USA.
   Lee, Jonghyun, Univ Hawaii Manoa, Dept Civil Environm Engn, Honolulu, HI 96822 USA.},
DOI = {10.1175/JHM-D-21-0171.1},
Keywords = {Rainfall; Machine learning; Interpolation schemes},
