@article{ WOS:001717223700001,
Author = {Wang, Wei and Hu, Xianglei},
Title = {A Kriging-Markov hybrid method for real-time spatiotemporal indoor
   daylight prediction under data-sparse and sensor-limited conditions
   toward adaptive daylight control applications},
Journal = {BUILDING AND ENVIRONMENT},
Year = {2026},
Volume = {295},
Month = {MAY 1},
Abstract = {Accurate prediction of indoor daylight illuminance is essential for
   adaptive daylight control (ADC) systems that balance visual comfort and
   energy efficiency. However, practical limitations such as sparse sensor
   deployment, limited data availability, and computational constraints
   hinder the real-time applicability of existing spatiotemporal models.
   This study proposes a hybrid Kriging-Markov (KM) framework that
   integrates spatial interpolation and temporal state-transition modeling
   to achieve high-resolution illuminance prediction under
   resources-limited conditions. The model predicts illuminance at
   unmeasured locations and future time steps using current readings from a
   limited number of sensors, enabling reliable short-term forecasting for
   dynamic lighting control. Validation in a multifunctional office space
   demonstrated that Kriging interpolation achieved the highest spatial
   accuracy, outperforming deterministic methods including Inverse Distance
   Weighting (IDW), machine learning approaches such as K-Nearest Neighbors
   (KNN), Extreme Gradient Boosting (XGBoost), and deep learning models
   based on Graph Attention Networks (GAT). Temporally, the fifth-order
   Markov chain effectively captured illuminance state transitions,
   surpassing Autoregressive Integrated Moving Average (ARIMA), Random
   Forest (RF), and Long Short-Term Memory (LSTM) models in balancing
   accuracy, computational efficiency, and data requirements. The inclusion
   of a parameter-adaptive mechanism allowed consistent performance across
   desk work, meeting, and presentation scenarios. As a feedforward module
   in ADC systems, the KM model can provides scenario-aware illuminance
   forecasts, facilitating proactive control of blinds and lighting
   systems. The results highlight the model's potential as a low-cost,
   interpretable, and real-time solution for intelligent daylighting
   control in office buildings, advancing the integration of spatiotemporal
   prediction and adaptive environmental regulation in smart building
   applications.},
Type = {Article},
Affiliation = {Hu, XL (Corresponding Author), Tongji Univ, Coll Architecture \& Urban Planning, Shanghai, Peoples R China.
   Wang, Wei; Hu, Xianglei, Tongji Univ, Coll Architecture \& Urban Planning, Shanghai, Peoples R China.},
DOI = {10.1016/j.buildenv.2026.114465},
