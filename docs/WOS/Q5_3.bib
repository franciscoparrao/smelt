   Renzullo, Luigi J., Bur Meteorol, Parkes, ACT 2600, Australia.
   Searle, Ross D., CSIRO Agr \& Food, St Lucia, Qld 4067, Australia.
   Bishop, Thomas F. A., Univ Sydney, Sydney Inst Agr, Sch Life \& Environm Sci, Sydney, NSW 2015, Australia.
   Walker, Jeffrey P., Monash Univ, Dept Civil Engn, Clayton, Vic 3800, Australia.},
DOI = {10.1109/TGRS.2025.3565818},
