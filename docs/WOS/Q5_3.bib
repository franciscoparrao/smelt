}

@article{ WOS:001310571200001,
Author = {Barikloo, Ali and Alamdari, Parisa and Rezapour, Salar and
   Taghizadeh-Mehrjardi, Ruhollah},
Title = {Digital mapping of soil quality index to evaluate orchard fields using
   random forest models},
Journal = {MODELING EARTH SYSTEMS AND ENVIRONMENT},
Year = {2024},
Volume = {10},
Number = {6},
Pages = {6787-6803},
Month = {DEC},
Abstract = {Soil characteristics can be used to calculate the soil quality index
   (SQI). However, measuring these qualities is expensive and
   time-consuming, one option is to employ a digital soil mapping
   technique. The present study aims to digitally map SQI in the Urmia
   Plain (Northwest of Iran) using covariate data, random forest (RF), and
   RF-ordinary Kriging (RF-OK) models. A total of 120 soil samples were
   collected from the solum (0-60 cm) and subsequently subjected to various
   physicochemical analyses. Digital elevation models and multiple
   remote-sensing characteristics were derived from satellite images. Among
   the study soil parameters, soil pH and salinity (EC) had the lowest
   (2.5\%) and highest (154.6\%) coefficients of variation, respectively.
   Six soil variables, including sodium absorption ratio (SAR), nickel
   (Ni), cation exchange capacity (CEC), sand, active calcium carbonate
   (ACC), and available P, had the highest weights, leading to their
   maximum contribution to SQI. The RF model demonstrated high accuracy in
   predicting SQI, and its R-2, root mean square error (RMSE), and
   normalized root mean square error (NRMSE) were 0.82, 0.032, and 0.052,
   respectively. Furthermore, implementing the hybrid RF-OK model enhanced
   the prediction outcomes, increasing the RF model's R-2 to 0.89 and
   reducing its RMSE and NRMSE values to 0.007 and 0.011, respectively.
   Future research is recommended to apply pedometric methods and covariate
   data to digital soil quality mapping in other locations, considering our
   results.},
Type = {Article},
Affiliation = {Rezapour, S (Corresponding Author), Urmia Univ, Dept Soil Sci, POB 165, Orumiyeh 57134, Iran.
   Barikloo, Ali; Alamdari, Parisa, Univ Zanjan, Dept Soil Sci, POB 165, Zanjan, Iran.
   Rezapour, Salar, Urmia Univ, Dept Soil Sci, POB 165, Orumiyeh 57134, Iran.
   Taghizadeh-Mehrjardi, Ruhollah, Ardakan Univ, Fac Agr \& Nat Resources, Ardakan, Iran.},
DOI = {10.1007/s40808-024-02145-6},
EarlyAccessDate = {SEP 2024},
Keywords = {Soil quality; Random forest; Environmental variables; Landsat 8},
Author-Email = {ali\_barikloo@alumni.znu.ac.ir
   p\_alamdari@znu.ac.ir
   S.Rezapour@urmia.ac.ir
   taghizadeh.130@gmail.com},
