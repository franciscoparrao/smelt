@article{ WOS:001661790600001,
Author = {Kunakote, Tawatchai and Promthaisong, Pitak and Kumar, Sumit and
   Bubphachot, Bopit and Chompookham, Teerapat and Siriwan, Narin and
   Sabangban, Numchoak and Wansasueb, Kittinan},
Title = {Comparative analysis of machine learning-assisted metaheuristic
   optimization algorithms for corrugated tube heat exchanger design},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {This study presents an integrated machine learning (ML)-assisted
   metaheuristic (MH) optimization framework for the design of corrugated
   tube (CT) heat exchangers. Previous research has typically focused on
   optimizing single geometric parameters or specific flow regimes,
   limiting the ability to achieve global thermo-hydraulic optimization and
   requiring extensive computational effort. To overcome these limitations,
   this work addresses the scientific question: Can an integrated ML-MH
   optimization framework effectively enhance both the heat transfer and
   hydraulic performance of CTs across a wide range of Reynolds numbers
   while reducing computational cost? Computational fluid dynamics (CFD)
   simulations were employed to analyze heat transfer and flow behavior,
   considering variations in corrugation number, depth ratio, and pitch
   ratio within a Reynolds number range of 100-2000. Machine learning
   surrogate models, including Kriging (KRG), radial basis function (RBF),
   and k-nearest neighbor (KNN), were trained to accelerate multi-objective
   optimization targeting the maximization of Nusselt number and the
   minimization of the Poiseuille number. Among these, the RBF model
   achieved the highest prediction accuracy and was effectively integrated
   with the multi-objective metaheuristic with iterative parameter
   distribution estimation (MMIP-DE) algorithm. Our results demonstrate
   that the optimized designs achieved thermal enhancement factors greater
   than one across all conditions, with the configuration NC = 4, DR = 0.1,
   and PR = 0.85 performing best for Re > 1000. The proposed ML-MH
   framework significantly advances thermal system design by achieving high
   accuracy and efficiency with reduced computational demand.},
Type = {Article},
Affiliation = {Wansasueb, K (Corresponding Author), Mahasarakham Univ, Fac Engn, Dept Mech Engn, Heat Pipe \& Thermal Equipment Design Res Unit, Maha Sarakham 44150, Thailand.
   Kunakote, Tawatchai; Promthaisong, Pitak; Bubphachot, Bopit; Chompookham, Teerapat; Siriwan, Narin; Wansasueb, Kittinan, Mahasarakham Univ, Fac Engn, Dept Mech Engn, Heat Pipe \& Thermal Equipment Design Res Unit, Maha Sarakham 44150, Thailand.
