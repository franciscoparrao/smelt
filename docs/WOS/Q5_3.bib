   Scholten, Thomas; Taghizadeh-Mehrjardi, Ruhollah, Univ Tubingen, DFG Cluster Excellence Machine Learning, Tubingen, Germany.},
DOI = {10.1080/10106049.2022.2138565},
EarlyAccessDate = {OCT 2022},
Keywords = {Sentinel; hyperspectral; machine learning; environmental covariates;
