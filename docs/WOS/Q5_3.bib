   Li, Chunxiang, Shanghai Univ, Sch Mech \& Engn Sci, Dept Civil Engn, Shanghai 200444, Peoples R China.},
DOI = {10.1063/5.0301816},
Article-Number = {115139},
Keywords-Plus = {PRESSURES; HIGHRISE},
