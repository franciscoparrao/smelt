}

@article{ WOS:001689982100001,
Author = {Pourmorad, Saeid and Abbasi, Samira and Dimuccio, Luca Antonio},
Title = {Mapping Soil Trace Metals Using VIS-NIR-SWIR Spectroscopy and Machine
   Learning in Aligudarz District, Western Iran},
Journal = {REMOTE SENSING},
Year = {2026},
Volume = {18},
Number = {3},
Month = {FEB 1},
Abstract = {Detecting trace metals in soil across geologically diverse terrains
   remains challenging due to complex mineral-metal interactions and the
   limited spatial coverage of traditional geochemical tests. This study
   develops a scalable VIS-NIR-SWIR spectroscopy and machine learning (ML)
   framework to predict and map soil concentrations of Cr, As, Cu, and Cd
   in the Aligudarz District, located within the geotectonically complex
   Sanandaj-Sirjan Zone of western Iran. Laboratory reflectance spectra
   (similar to 350-2500 nm) obtained from 110 soil samples were
   pre-processed using derivative filtering, scatter-correction techniques,
   and genetic algorithm (GA)-based wavelength optimisation to enhance
   diagnostic absorption features linked to Fe-oxides, clay minerals, and
   carbonates. Multiple ML-based approaches, including artificial neural
   networks (ANNs), support vector regression (SVR), and partial least
   squares regression (PLSR), as well as stepwise multiple linear
   regression (SMLR), were compared using nested, spatial, and external
   validation. Nonlinear models, particularly ANNs, exhibited the highest
   predictive accuracy, with strong generalisation confirmed via an
   independent test set. GA-selected wavelengths and derivative-enhanced
   spectra revealed mineralogical controls on metal retention, confirming
   that spectral predictions reflect underlying geological processes.
   Ordinary kriging of spectral-ML residuals generated spatially consistent
   metal-distribution maps that aligned well with local and regional
   geological features. The integrated framework demonstrates high
   predictive accuracy and operational scalability, providing a
   reproducible, field-ready method for rapid geochemical assessment. The
   findings highlight the potential of VIS-NIR-SWIR spectroscopy, combined
   with advanced modelling and geostatistics, to support environmental
   monitoring, mineral exploration, and risk assessment in geologically
   complex terrains.},
Type = {Article},
Affiliation = {Dimuccio, LA (Corresponding Author), Univ Coimbra, Fac Arts \& Humanities, Ctr Studies Geog \& Spatial Planning CEGOT, Dept Geog \& Tourism, P-3004530 Coimbra, Portugal.
   Pourmorad, Saeid; Dimuccio, Luca Antonio, Univ Coimbra, Fac Arts \& Humanities, Ctr Studies Geog \& Spatial Planning CEGOT, Dept Geog \& Tourism, P-3004530 Coimbra, Portugal.
   Abbasi, Samira, Univ Coimbra, Fac Sci \& Technol, Dept Earth Sci, P-3030790 Coimbra, Portugal.},
DOI = {10.3390/rs18030465},
Article-Number = {465},
Keywords = {soil-borne trace metals; hyperspectral spectroscopy; artificial neural
   networks; support vector regression; partial least squares regression;
   stepwise multiple linear regression},
Keywords-Plus = {SANANDAJ-SIRJAN ZONE; REFLECTANCE SPECTROSCOPY; TECTONIC EVOLUTION;
   CONVERGENCE; PERFORMANCE; REGRESSION; TOOL; SVM},
Author-Email = {uc2023140908@student.uc.pt
   uc2025161649@student.uc.pt
   luca@ci.uc.pt},
