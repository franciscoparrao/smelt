   El Ouali, Anas, Mohammed V Univ, Sci Inst, Dept Geomorphol \& Geomat, Ave Ibn Batouta,BP 703, Rabat 10000, Rabat, Morocco.},
DOI = {10.1016/j.gsd.2024.101281},
