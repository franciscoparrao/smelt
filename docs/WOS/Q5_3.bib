}

@article{ WOS:001701285500001,
Author = {Yang, Leqi and Yue, Tianxiang and Ma, Maohua},
Title = {Soil Heavy Metals for Sustainable Risk Management: A Systematic Review
   and a Context-Aware Method Selection Framework},
Journal = {SUSTAINABILITY},
Year = {2026},
Volume = {18},
Number = {4},
Month = {FEB 12},
Abstract = {Sustainable land use requires precise monitoring of soil pollution, yet
   accurately predicting the spatial distribution of heavy metals often
   relies on post hoc accuracy comparisons with limited a priori diagnosis.
   To address the challenge of cost effective environmental monitoring, we
   conducted a PRISMA guided systematic review (2000-2024) and synthesized
   135 studies to develop a mechanism-informed, context aware method
   selection framework. Evidence revealed three regularities: (i)
   element-driver coupling is structured (Pb/Cd/Zn predominantly
   anthropogenic; Cr/Ni geogenic; As/Hg mixed), with dominant influence
   scales from local to regional; (ii) model performance hinges on
   alignment between algorithmic assumptions, and context hybrid machine
   learning models integrating multi-source covariates tend to excel under
   strong, non-stationary anthropogenic heterogeneity, whereas kriging
   variants are more robust when geogenic continuity holds; and (iii)
   applicability is jointly constrained by environmental context, data
   foundations, and management objectives. Building on these insights, we
   propose a three-step decision workflow-goal definition, contextual
   diagnosis, and method matching. This framework serves as a decision
   support tool that shifts selection from trial and error to a priori
   alignment, optimizing resource allocation and enhancing the reliability
   of pollution assessments for sustainable soil remediation and
   policymaking.},
Type = {Review},
Affiliation = {Yue, TX (Corresponding Author), Chinese Acad Sci, State Key Lab Resources \& Environm Informat Syst, Inst Geog Sci \& Nat Resources Res, Beijing 100101, Peoples R China.
   Yang, Leqi; Ma, Maohua, Chinese Acad Sci, Chongqing Inst Green \& Intelligent Technol, Chongqing 400714, Peoples R China.
   Yang, Leqi; Ma, Maohua, Univ Chinese Acad Sci, Chongqing Sch, Chongqing 400714, Peoples R China.
   Yang, Leqi; Yue, Tianxiang, Chinese Acad Sci, State Key Lab Resources \& Environm Informat Syst, Inst Geog Sci \& Nat Resources Res, Beijing 100101, Peoples R China.},
DOI = {10.3390/su18041893},
Article-Number = {1893},
Keywords = {soil heavy metals; spatial interpolation; sustainable land management;
   precision environmental monitoring; method selection; context diagnosis;
   decision support tool; uncertainty; geostatistics; machine learning},
Keywords-Plus = {SPATIAL-DISTRIBUTION; SURFACE SOIL; URBAN; INTERPOLATION; POLLUTION;
   GIS; IDENTIFICATION; GEOSTATISTICS; CONTAMINATION; IMPROVEMENT},
Author-Email = {yangleqi23@mails.ucas.ac.cn
