   Muhammad, Faiz, Univ Balochistan UOB, Dept Chem, Quetta, Pakistan.
   Khan, Maqbool, Pak Austria Fachhochschule Inst Appl Sci \& Technol, Sch Comp Sci, Haripur, Kpk, Pakistan.
   Khan, Changaiz, Beijing Normal Univ, Sch Environm, State Key Joint Lab Environm Simulat \& Pollut Cont, Beijing 100875, Peoples R China.},
DOI = {10.1007/s10653-024-02335-2},
Article-Number = {32},
