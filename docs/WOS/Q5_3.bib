}

@article{ WOS:001662243700001,
Author = {Chen, Guochen and Li, Chunlei},
Title = {Thoughts on Developing an Early Warning Model for Hospital Violence Risk
   Events Using Geographic Information Systems},
Journal = {JOURNAL OF MULTIDISCIPLINARY HEALTHCARE},
Year = {2026},
Volume = {19},
Pages = {1-10},
Abstract = {The risk of violence faced by healthcare workers is a widespread
   challenge in the global healthcare industry. This article examines the
   feasibility and practical value of developing a spatial prediction and
   early warning model for hospital violent injury incidents using
   Geographic Information System(GIS) technology. By integrating
   multi-source spatiotemporal data and employing spatiotemporal analysis,
   machine learning, and spatial interpolation methods, the model can
   identify hotspots and predict the risk of violent events at a micro
   scale, shifting from passive response to proactive prevention and
   control. This study not only offers a novel approach for the refined and
   scientific management of hospital safety but also provides valuable
   insights for the development of smart hospitals, the application of
   artificial intelligence, and interdisciplinary integration. Although
   challenges remain in data integration, privacy protection, and model
   generalization, advancements in technology and management optimization
   are expected to establish this technology as a core tool for security
   prevention and control in smart hospitals. This study is a preliminary
   exploration in this field.},
Type = {Article},
Affiliation = {Li, CL (Corresponding Author), Peoples Publ Secur Univ China, Sch Criminol, 1 Muxidi Nanli, Beijing 100038, Peoples R China.
   Chen, Guochen; Li, Chunlei, Peoples Publ Secur Univ China, Sch Criminol, 1 Muxidi Nanli, Beijing 100038, Peoples R China.},
DOI = {10.2147/JMDH.S569538},
Keywords = {violence against healthcare workers; geographic information system;
   hospital safety protection; risk warning model},
Keywords-Plus = {WORKPLACE VIOLENCE},
Author-Email = {20050892@ppsuc.edu.cn},
Number-of-Cited-References = {32},
