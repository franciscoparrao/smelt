   Zhu, A-Xing, Univ Wisconsin, Dept Geog, Madison, WI USA.},
DOI = {10.1016/j.jag.2022.102986},
EarlyAccessDate = {AUG 2022},
Article-Number = {102986},
Keywords = {Digital soil mapping; Soil-environment relationship; Large area;
