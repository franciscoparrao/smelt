}

@article{ WOS:001587550300001,
Author = {Li, Zeyue and Liu, Yang and Bi, Jianzhao and Hu, Xuefei},
Title = {Forecasting high-resolution PM2.5 concentrations in southeastern China
   by combining high-resolution satellite data and numerical simulation
   with machine learning},
Journal = {JOURNAL OF CLEANER PRODUCTION},
Year = {2025},
Volume = {528},
Month = {OCT 15},
Abstract = {PM2.5 is a significant air contaminant that presents a serious risk to
   human health. Accurate PM2.5 forecasts with high spatial resolution are
   essential for decision-makers to implement effective mitigation
   strategies and prevent harmful public exposure to PM2.5. Current methods
   often rely on spatial data of limited precision, like outputs from
   spatial interpolation and chemical transport models (CTMs), resulting in
   PM2.5 forecasts that either have inaccurate spatial patterns or
   completely omit spatial details. For this research, we developed a novel
   approach to demonstrate the feasibility of employing 1 km satellite AOD
   data to generate 1 km resolution PM2.5 forecasts in southeastern China
   up to five days in advance by integrating machine learning models, CTM
   simulations, and 1 km resolution satellite AOD measurements. Our
   forecast framework integrated with satellite AOD data demonstrated
   superior performance, surpassing the precision of the original CTM
   forecast data, as evidenced by both spatial cross-validation and overall
   validation results. In addition, incorporating satellite AOD into the
   forecasting model could enhance the spatial resolution of PM2.5
   forecasts. The model enables the production of PM2.5 forecasts featuring
   both accurate spatial representation and high spatial resolution.},
Type = {Article},
Affiliation = {Hu, XF (Corresponding Author), Sun Yat Sen Univ, Sch Geospatial Engn \& Sci, Zhuhai 519082, Peoples R China.
   Li, Zeyue; Hu, Xuefei, Sun Yat Sen Univ, Sch Geospatial Engn \& Sci, Zhuhai 519082, Peoples R China.
   Liu, Yang, Emory Univ, Rollins Sch Publ Hlth, Gangarosa Dept Environm Hlth, Atlanta, GA 30322 USA.
   Bi, Jianzhao, Univ Washington, Dept Environm \& Occupat Hlth Sci, Seattle, WA 98105 USA.},
DOI = {10.1016/j.jclepro.2025.146759},
EarlyAccessDate = {SEP 2025},
Article-Number = {146759},
Keywords = {PM2.5; Air pollution forecast; Chemical transport model; MAIAC AOD; And
   random forest},
Keywords-Plus = {GROUND-LEVEL PM2.5; RANDOM-FOREST; AIR-POLLUTION; VARIABILITY; MODEL},
