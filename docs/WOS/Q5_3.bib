   Song, Yongze, Curtin Univ, Sch Design \& Built Environm, Perth, WA 6845, Australia.
   Soon, Susannah, Curtin Univ, Sch Elect Engn Comp \& Math Sci, Perth, WA 6845, Australia.},
DOI = {10.3390/rs17142392},
