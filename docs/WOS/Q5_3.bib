@article{ WOS:001657094000003,
Author = {Wu, Hansong and Zhang, Jinxi and Liu, Yuzhen and Nie, Lei and Zhou,
   Shengnan},
Title = {Prediction model for pavement quality index (PQI) based on multi-source
   data fusion},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2026},
Volume = {335},
Month = {FEB 28},
Abstract = {By systematically monitoring and analyzing pavement deterioration
   patterns, transportation agencies can optimize resource allocation,
   minimize energy consumption, and establish cost-effective maintenance
   plans. This article proposes a multi-source data fusion strategy for
   enhanced pavement performance prediction that addresses critical
   challenges in highway maintenance decision-making. Based on the
   comprehensive pavement condition dataset (2008-2022) from the Beijing
   sections of G4, G6, G7, S15, and G106, the proposed framework comprises
   three principal components: 1) data-level fusion through matrix analysis
   of historical pavement quality index (PQI) data combined with Kriging
   interpolation for spatial-temporal prediction; 2) feature-level fusion
   using convolutional neural networks to establish nonlinear relationships
   between multi-dimensional pavement indicators and the PQI; and 3)
   decision-level fusion through support vector machine algorithms to
   consolidate primary and secondary fusion results. Comparative validation
   demonstrated that the proposed multisource model achieved classification
   consistency of 98.4\% and 93.3\% for the Excellent and Good PQI levels
   for the PQI, representing an improvement over the conventional linear
   regression approach. The key innovations of this research include the
   following: 1) a hierarchical fusion architecture that addresses both
   spatial heterogeneity and temporal dependencies in pavement performance
   evolution; 2) quantitative integration of historical performance impacts
   through machine learning-enhanced feature engineering; and 3) robust
   uncertainty quantification considering the variability in detection
   indicators and measurement errors. The experimental results confirm the
   reliability of the model in practical engineering applications,
   particularly in capturing the complex interactions between the pavement
   deterioration mechanisms and affecting factors.},
