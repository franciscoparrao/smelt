Affiliation = {Wu, AP (Corresponding Author), Tsinghua Univ, Dept Mech Engn, Beijing 100084, Peoples R China.
   Wan, Zhandong; Li, Quan; Li, Jian, Beijing Univ Technol, Coll Mat Sci \& Engn, Beijing 100124, Peoples R China.
