Keywords-Plus = {MULTIOBJECTIVE OPTIMIZATION; ENERGY-ABSORPTION; CRASH BOX;
   NEURAL-NETWORKS; DESIGN; THICKNESS},
Author-Email = {lucd21@mails.jlu.edu.cn
   caewdf@jlu.edu.cn},
Number-of-Cited-References = {80},
