   Gokceoglu, Candan, Hacettepe Univ, Dept Geol Engn, TR-06800 Ankara, Turkiye.},
DOI = {10.1007/s13753-023-00477-y},
EarlyAccessDate = {MAR 2023},
Keywords = {Earthquakes; Floods; Fuzzy inference systems; Landslides; Multi-hazard
