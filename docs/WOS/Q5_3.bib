   Pisoni, Enrico, European Commiss Joint Res Ctr Ispra Sect, Via Enr Fermi,2749, I-21027 Ispra, Italy.},
DOI = {10.1016/j.envsoft.2026.106918},
Article-Number = {106918},
Keywords = {Air pollution interpolation; Machine learning; Simulated-data},
