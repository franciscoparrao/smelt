DOI = {10.1016/j.geodrs.2024.e00874},
EarlyAccessDate = {OCT 2024},
Article-Number = {e00874},
Keywords = {Sampling; cLHS; FSCS; Random Forest; Digital soil mapping; Smart farming},
Keywords-Plus = {SPATIAL PREDICTION; CARBON; UNCERTAINTY; TEMPERATE; MOISTURE; SETS},
Author-Email = {zizala.daniel@vumop.cz
   vojtech.lukas@mendelu.cz},
