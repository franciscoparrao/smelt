   Zhan, Wenfeng, Jiangsu Ctr Collaborat Innovat Geog Informat Resou, Nanjing 210023, Peoples R China.},
DOI = {10.3390/land12020309},
Article-Number = {309},
Keywords = {land surface temperature; thermal remote sensing; annual temperature
   cycle; global-local interpolation; random forest},
Keywords-Plus = {TIME-SERIES; THERMAL OBSERVATIONS; AIR-TEMPERATURE; ANNUAL DYNAMICS;
