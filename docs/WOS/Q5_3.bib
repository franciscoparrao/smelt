@article{ WOS:001650628300001,
Author = {Li, Decang and Wang, Wu and Wang, Shaojie},
Title = {Multi-objective optimization of high-speed train suspension system
   parameters based on an ensemble surrogate model},
Journal = {ENGINEERING RESEARCH EXPRESS},
Year = {2025},
Volume = {7},
Number = {4},
Month = {DEC 31},
Abstract = {The suspension parameters of high-speed trains critically influence
   their dynamic performance, and multi-objective optimization serves as an
   effective means to enhance operational performance. To address existing
   challenges in suspension parameter optimization-such as insufficient
   accuracy of surrogate models, inadequate methods for model evaluation,
   and the difficulty for multi-objective algorithms to balance convergence
   and distribution-this paper proposes a multi-objective optimization
   method for high-speed train suspension parameters based on an ensemble
   surrogate model. Firstly, an integrated approach combining Pearson
   correlation analysis, the Analytic Hierarchy Process, and fuzzy
   comprehensive evaluation is employed to systematically identify the four
   key suspension parameters with the most significant influence on dynamic
   performance. Using these as design variables, Kriging, Support Vector
   Machine, and Gaussian Process Regression surrogate models are
   constructed respectively. Model accuracy is evaluated using the
   coefficient of determination and root mean square error, leading to the
   selection of the superior Gaussian Process Regression model as the base
   model for integration. Furthermore, an ensemble surrogate model is built
   using Least Squares Boosting and Gaussian Process Regression Ensemble
   techniques, and parameter optimization is performed by introducing the
   Multi-objective Rime Optimization Algorithm. The results demonstrate
   that the optimized suspension parameters significantly improve the
   train's dynamic performance: the derailment coefficient, wheel load
   reduction rate, vertical ride comfort, and lateral ride comfort are
   improved by 15.84\%, 14.15\%, 12.59\%, and 11.32\%, respectively.
   Compared to algorithms such as NSGA-II, MOMSA, and MOCOA, the proposed
   method yields a Pareto solution set with superior diversity and
   convergence. The integrated modeling and optimization framework
   presented herein provides an effective tool for the design of high-speed
   train suspension systems. Future work will further incorporate parameter
   uncertainties and a wider range of track conditions, extending the
   approach to robust optimization and the design of more complex
   mechatronic systems.},
Type = {Article},
Affiliation = {Li, DC (Corresponding Author), Lanzhou Jiaotong Univ, Sch Mech Engn, Lanzhou, Peoples R China.
   Li, DC (Corresponding Author), Lanzhou Jiaotong Univ, Mech T\&R Inst, Lanzhou, Peoples R China.
   Li, Decang; Wang, Wu; Wang, Shaojie, Lanzhou Jiaotong Univ, Sch Mech Engn, Lanzhou, Peoples R China.
   Li, Decang, Lanzhou Jiaotong Univ, Mech T\&R Inst, Lanzhou, Peoples R China.},
DOI = {10.1088/2631-8695/ae2ce6},
Article-Number = {0455e9},
Keywords = {high-speed train; surrogate model; parameter optimization; stability;
   MORIME algorithm},
Author-Email = {Lidecang1978@163.com},
Number-of-Cited-References = {39},
Times-Cited = {0},
Unique-ID = {WOS:001650628300001},
}

@article{ WOS:001622399400001,
Author = {Chen, Chia-Hsing and Wu, Ko-Chiu},
Title = {Assessing urban heat island hotspots through virtual and physical
   boundary analysis with space syntax},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2025},
Volume = {40},
Number = {1},
Month = {DEC 31},
Abstract = {This study presents a three-dimensional framework for assessing the
   microclimate in urban canyons. The temperature data were collected using
   UAV-mounted sensors and calibrated against meteorological records.
   Kriging interpolation was employed to create high-resolution 3D thermal
   fields, while K-means clustering was used to identify hotspot groupings.
   Space syntax analysis was used to quantify the spatial integration and
   connectivity of these hotspots through Delaunay triangulation and
   network modeling. Findings reveal that even compact urban forms can
   generate pronounced hotspots, which are typically concentrated in dense,
   low-rise neighborhoods with narrow streets and scant vegetation, often
   occurring near the ground rather than at the canopy level. The proposed
   method integrates virtual boundaries with actual urban structures within
   an interactive visualization platform, allowing for the dynamic
   exploration of hotspot relationships. This framework offers a scalable,
   data-driven tool for assessing UHI at a fine-grained level and supports
   urban planning strategies aimed at achieving carbon neutrality.},
Type = {Article},
Affiliation = {Chen, CH (Corresponding Author), Natl Taipei Univ Technol, Dept Interact Design, Taipei, Taiwan.
   Chen, Chia-Hsing; Wu, Ko-Chiu, Natl Taipei Univ Technol, Dept Interact Design, Taipei, Taiwan.},
DOI = {10.1080/10106049.2025.2582135},
Article-Number = {2582135},
Keywords = {Information visualization; machine learning; microclimates; space
   syntax; UHI},
Keywords-Plus = {IMPACT},
Author-Email = {biabobo@icloud.com},
Number-of-Cited-References = {46},
Times-Cited = {0},
Unique-ID = {WOS:001622399400001},
}

@article{ WOS:001589251300001,
Author = {Zhou, Jian and Tang, Minggao and Zhang, Guodong and Zhou, Yonggang and
   Li, Chaorui and Zhang, Qiaofeng and Jiang, Yishun},
Title = {Coupled model for susceptibility mapping of hydro-fluctuation belt rock
   degradation in the Jinsha River reservoirs},
Journal = {GEOMATICS NATURAL HAZARDS \& RISK},
Year = {2025},
Volume = {16},
Number = {1},
Month = {DEC 31},
Abstract = {Hydro-fluctuation belt (HFB) rock mass degradation poses significant
   risks to bank slope stability. While existing studies primarily focus on
   laboratory experiments and localized investigations, systematic
   regional-scale susceptibility mapping of HFB rock masses remains
   unexplored. This study focuses on the four cascade reservoirs along the
   Jinsha River in China. Systematically assesses 17 factors across four
   categories: topography, geology, environment, and reservoir operations.
   By combining the information value (IV) model with machine learning
   algorithms, an evaluation framework integrating geostatistical and
   machine learning methods is constructed, achieving the first
   regional-scale susceptibility mapping of HFB rock mass degradation. The
   results indicate that compared with the single IV model, the coupled
   models exhibit better applicability, among which the IV + RF (random
   forest) model performs the best (area under curve = 0.928, kappa =
   0.897). The key driving factors of degradation include slope, bank slope
   shape, lithology, proximity to faults and rainfall intensity. Spatial
   analysis reveals that high-sensitivity zones within the reservoir areas
   predominantly occur in Triassic, Jurassic, Ordovician-Silurian,
   Cambrian, and Proterozoic strata, characterized by interbedded
   fragile-competent sequences. The findings of this study can deepen the
   understanding of susceptibility evaluation methods for HFB rock mass
   degradation and provide new insights for reservoir disaster prevention,
   mitigation, and long-term safety monitoring.},
Type = {Article},
Affiliation = {Tang, MG (Corresponding Author), Chengdu Univ Technol, State Key Lab Geohazard Prevent \& Geoenvironm Prot, Chengdu, Peoples R China.
   Tang, MG (Corresponding Author), Chengdu Univ Technol, Coll Environm \& Civil Engn, Chengdu, Peoples R China.
