   Ali, Mazhar, Chulalongkorn Univ, Telecommun Syst Res Lab TSLR, Bangkok 10330, Thailand.},
DOI = {10.1016/j.jnlssr.2025.100236},
Article-Number = {100236},
Keywords = {Machine learning optimization; Adaptive classifier selection; Sensor
   fusion; Fire hazard mitigation; Real-time analytics},
Keywords-Plus = {SPATIAL PREDICTION; SYSTEM},
