@article{ WOS:001522744800001,
Author = {Zvarivadza, T. and Yi, C. and Dineva, S. and Onifade, M. and Khandelwal,
   M. and Genc, B.},
Title = {Evaluating destress blasting for rock fracture and rockburst prediction
