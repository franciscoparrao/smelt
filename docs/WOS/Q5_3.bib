}

@article{ WOS:001609691900004,
Author = {Ahamadabad, Fatemeh Mikaeeli and Dastjerdi, Pouria Asgari and Nasseri,
   Mohsen},
Title = {Spatiotemporal GRACE TWS downscaling using statistical and machine
   learning methods: Random Forest, area-to-area kriging, and hybrid
   methods},
Journal = {JOURNAL OF HYDROLOGY-REGIONAL STUDIES},
Year = {2025},
Volume = {62},
Month = {DEC},
Abstract = {Study region: The Karkheh and Karoon watersheds in southwestern Iran,
   covering 116,000 km2, present complex topography, diverse climates
   (Mediterranean to arid), and significant anthropogenic pressures from
   irrigation and dam construction projects. This high spatial
   heterogeneity in hydrological processes makes the region an ideal,
   challenging case study for advanced downscaling techniques. Study focus:
   The coarse 0.5 degrees resolution of Gravity Recovery and Climate
   Experiment (GRACE) Terrestrial Water Storage (TWS) data limits its
   regional utility. This research downscales GRACE TWS to 0.1 degrees
   using a novel hybrid method coupling Random Forest (RF) and Area-to-Area
   Kriging (ATAK). The novelty is using ATAK-interpolated TWS as a
   spatially coherent predictor within the RF model, alongside key
   hydro-climatic variables and optimized GRACE temporal lags, a feature
   previously overlooked. This approach leverages RF's predictive power
   while using ATAK to enforce spatial consistency. New hydrological
   insights for the region: The hybrid method significantly outperformed
   standalone models, producing more accurate, spatially coherent TWS maps.
   Strong performance (with KGE values often above 0.8 and NSE values above
   0.9) confirmed the superiority of the integrated approach. The inclusion
   of GRACE TWS temporal lags was crucial for model performance,
   highlighting the importance of capturing water storage autocorrelation
   for this region. The resulting high-resolution TWS data is an improved
   tool for identifying local water stress and managing water resources
   more effectively in these vital Iranian basins.},
Type = {Article},
Affiliation = {Nasseri, M (Corresponding Author), Univ Tehran, Coll Engn, Sch Civil Engn, Tehran, Iran.
   Ahamadabad, Fatemeh Mikaeeli; Dastjerdi, Pouria Asgari; Nasseri, Mohsen, Univ Tehran, Coll Engn, Sch Civil Engn, Tehran, Iran.},
DOI = {10.1016/j.ejrh.2025.102885},
EarlyAccessDate = {OCT 2025},
Article-Number = {102885},
Keywords = {Spatiotemporal downscaling; GRACE; Area to area kriging; Random Forest;
   Machine Learning; Karkheh and Karoon watersheds},
Keywords-Plus = {LAND-SURFACE MODEL; RIVER-BASIN; GROUNDWATER STORAGE; SOIL-MOISTURE;
   WATER; ASSIMILATION; EVAPOTRANSPIRATION; PRECIPITATION; PREDICTION;
   SELECTION},
Author-Email = {fateme.mikaeeli@ut.ac.ir
   pouria.asgari@ut.ac.ir
   mnasseri@ut.ac.ir},
Number-of-Cited-References = {85},
Times-Cited = {0},
Unique-ID = {WOS:001609691900004},
}

@article{ WOS:001609526400007,
Author = {Paladaechanan, Passakorn and Zhong, Yao and Ye, Maokun and Wan, Decheng
   and Abdel-Maksoud, Moustafa},
Title = {Ensemble adaptive gated multi-fidelity neural network for Bayesian
   optimization: Application to hydrofoil design},
Journal = {OCEAN ENGINEERING},
Year = {2026},
Volume = {343},
Number = {2},
Month = {JAN 15},
Abstract = {High-fidelity computational fluid dynamics (CFD) simulations provide
   critical predictive accuracy in marine and ocean engineering design;
   however, their substantial computational expense often renders direct
   optimization infeasible. To alleviate this limitation, surrogate models
   approximate expensive objective functions from a finite set of
   observations, thereby enabling more tractable design exploration and
   optimization. Our objective is to build a novel, general-purpose
   multi-fidelity surrogate modeling approach that integrates seamlessly
   into a Bayesian optimization framework and remains robust under sparse
   high-fidelity data. We propose an adaptive gated multi-fidelity neural
   network (AGMF-Net), which incorporates three specialized expert
   subnetworks-linear, nonlinear, and residual-combined through a deep
   Mixture-of-Experts gating network that dynamically adjusts their
   contributions based on the input. To improve predictive uncertainty
   estimation, we ensemble multiple independently initialized AGMF-Net
   instances and use the resulting variance to guide sampling decisions. We
   embed this surrogate into a Bayesian optimization workflow driven by the
   logarithmic expected improvement acquisition function, which balances
   exploration and exploitation while maintaining numerical stability. We
   evaluated the proposed method against co-Kriging and the multi-fidelity
   neural network baseline on benchmark functions. AGMF-Net achieved higher
   initial predictive accuracy, rapidly converged to global optima, and
   maintained lower mean absolute relative error during optimization
   iterations. Finally, we applied the framework to a hydrofoil design
   optimization. The model successfully identified a subtle camber
   modification that improved the lift-to-drag ratio by 41.6 \% compared to
   the baseline geometry, demonstrating that AGMF-Net can accelerate
   CFD-driven hydrodynamic design scenarios that combine sparse
   high-fidelity data with cheaper simulations. These results highlight the
   potential of adaptive gating and ensemble uncertainty quantification to
   accelerate design exploration and improve solution quality when only
   limited high-fidelity evaluations are feasible.},
Type = {Article},
Affiliation = {Wan, DC (Corresponding Author), Shanghai Jiao Tong Univ, Sch Ocean \& Civil Engn, Computat Marine Hydrodynam Lab CMHL, Shanghai, Peoples R China.
   Paladaechanan, Passakorn; Ye, Maokun; Wan, Decheng, Shanghai Jiao Tong Univ, Sch Ocean \& Civil Engn, Computat Marine Hydrodynam Lab CMHL, Shanghai, Peoples R China.
   Zhong, Yao, Powerchina Zhongnan Engn Corp Ltd, Changsha, Peoples R China.
   Abdel-Maksoud, Moustafa, Hamburg Univ Technol TUHH, Inst Fluid Dynam \& Ship Theory M8, Hamburg, Germany.},
DOI = {10.1016/j.oceaneng.2025.123314},
EarlyAccessDate = {OCT 2025},
Article-Number = {123314},
Keywords = {Multi-fidelity surrogate modeling; Bayesian optimization; Deep learning;
   Mixture of experts; Uncertainty quantification; Hydrofoil optimization;
   Computational fluid dynamics},
Author-Email = {dcwan@sjtu.edu.cn},
Number-of-Cited-References = {49},
Times-Cited = {1},
Unique-ID = {WOS:001609526400007},
}

@article{ WOS:001608430500002,
Author = {Tang, Henan and Yu, Xuefeng and Liu, Qingxian and Li, Yunlong and Dong,
   Jingyao and Wang, Shuaida and Yang, Bin},
Title = {A machine learning prediction framework for damping performance of
   silicone rubber based on molecular dynamics and VAE-OK data augmentation},
Journal = {POLYMER},
Year = {2025},
Volume = {340},
Month = {DEC 5},
Abstract = {The remarkable damping characteristics of the silicone rubber (SR) have
   piqued the curiosity of scientists. Molecular dynamics (MD) simulations
   are helpful for studying the impact of crucial structural factors on
   damping performance at the molecular level. There is a great deal of
   potential to enhance the efficiency and accuracy of MD simulations by
   combining machine learning method. In this study, a novel data
   augmentationmachine learning technique trained by small-sample MD
   results were proposed to predict the damping performance of SR. The
   methodology encompassed: (1) employing a variational autoencoder for
   rapid scaling of MD computational data; (2) utilizing Ordinary Kriging
   for labeling virtual samples; (3) employing the Gradient Boosting
   Algorithm Model for damping performance prediction. Crucial structural
   factors such as the hydrogen bond number, free volume, and volume
   modulus of SR were focused. The findings demonstrated the effectiveness
   on the data augmentation and GBR prediction model based on augmented MD
   samples. The updated regression models showed significant improvements
   in the accuracy and reliability. With this approach, the issue of
   inadequate data for machine learning applications in materials science
   could be effectively tackled. Subsequently, the model's robustness and
   predictive capability were validated, demonstrating strong internal and
   external prediction performance.},
Type = {Article},
Affiliation = {Li, YL (Corresponding Author), Shenyang Univ Technol, Sch Mech Engn, Shenyang 110870, Peoples R China.
   Liu, QX (Corresponding Author), Shantou Univ, Dept Mech Engn, Shantou 515063, Guangdong, Peoples R China.
   Tang, Henan; Yu, Xuefeng; Li, Yunlong; Dong, Jingyao; Wang, Shuaida; Yang, Bin, Shenyang Univ Technol, Sch Mech Engn, Shenyang 110870, Peoples R China.
   Liu, Qingxian, Shantou Univ, Dept Mech Engn, Shantou 515063, Guangdong, Peoples R China.},
DOI = {10.1016/j.polymer.2025.129269},
EarlyAccessDate = {OCT 2025},
Article-Number = {129269},
Keywords = {Silicone rubber; Loss factor; GBR gradient regression; Molecular
   dynamics simulation; Data enhancement; Ordinary Kriging},
Keywords-Plus = {MECHANICAL-PROPERTIES},
Author-Email = {qxliu@stu.edu.cn
   yunlongli@sut.edu.cn},
Number-of-Cited-References = {48},
