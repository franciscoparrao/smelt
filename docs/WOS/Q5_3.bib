}

@article{ WOS:001294955200001,
Author = {Auzzas, Alessandro and Capra, Gian Franco and Jani, Arun Dilipkumar and
   Ganga, Antonio},
Title = {An improved digital soil mapping approach to predict total N by
   combining machine learning algorithms and open environmental data},
Journal = {MODELING EARTH SYSTEMS AND ENVIRONMENT},
Year = {2024},
Volume = {10},
Number = {5},
Pages = {6519-6538},
Month = {OCT},
Abstract = {Digital Soil Mapping (DSM) is fundamental for soil monitoring, as it is
   limited and strategic for human activities. The availability of high
   temporal and spatial resolution data and robust algorithms is essential
   to map and predict soil properties and characteristics with adequate
   accuracy, especially at a time when the scientific community,
   legislators and land managers are increasingly interested in the
   protection and rational management of soil. Proximity and remote
   sensing, efficient data sampling and open public environmental data
   allow the use of innovative tools to create spatial databases and
   digital soil maps with high spatial and temporal accuracy. Applying
   machine learning (ML) to soil data prediction can improve the accuracy
   of maps, especially at scales where geostatistics may be inefficient.
   The aim of this research was to map the nitrogen (N) levels in the soils
   of the Nurra sub-region (north-western Sardinia, Italy), testing the
   performance of the Ranger, Random Forest Regression (RFR) and Support
   Vector Regression (SVR) models, using only open source and open access
   data. According to the literature, the models include soil
   chemical-physical characteristics, environmental and topographic
   parameters as independent variables. Our results showed that predictive
   models are reliable tools for mapping N in soils, with an accuracy in
   line with the literature. The average accuracy of the models is high
   (R-2 = 0.76) and the highest accuracy in predicting N content in surface
   horizons was obtained with RFR (R-2 = 0.79; RMSE = 0.32; MAE = 0.18).
   Among the predictors, SOM has the highest importance. Our results show
   that predictive models are reliable tools in mapping N in soils, with an
   accuracy in line with the literature. The results obtained could
   encourage the integration of this type of approach in the policy and
   decision-making process carried out at regional scale for land
   management.},
Type = {Article},
Affiliation = {Ganga, A (Corresponding Author), Univ Sassari, Dipartimento Architettura Design E Urbanist, Via Piandanna 4, I-07100 Sassari, Italy.
   Auzzas, Alessandro; Capra, Gian Franco; Ganga, Antonio, Univ Sassari, Dipartimento Architettura Design E Urbanist, Via Piandanna 4, I-07100 Sassari, Italy.
   Jani, Arun Dilipkumar, Calif State Univ Monterey Bay, Dept Biol \& Chem, Seaside, CA 93955 USA.},
DOI = {10.1007/s40808-024-02127-8},
EarlyAccessDate = {AUG 2024},
Keywords = {Machine learning; Random Forest Regression; Support Vector Regression;
   Digital soil mapping; Open data},
Keywords-Plus = {REMOTE-SENSING DATA; EROSION; REGRESSION; EUROPE},
Author-Email = {aganga@uniss.it},
Number-of-Cited-References = {95},
Times-Cited = {9},
