   Wang, Bo; Wu, Yizhong, Huazhong Univ Sci \& Technol, Natl CAD Supported Software Engn Ctr, Wuhan 430074, Peoples R China.},
DOI = {10.1016/j.oceaneng.2026.124592},
EarlyAccessDate = {FEB 2026},
