@incollection{ WOS:001697361400019,
Author = {Noriega, Roberto and Boisvert, Jeff},
Editor = {Azevedo, L and Narciso, J and Soares, A and Pereira, MJ and Vargas-Guzman, JA},
Title = {Underground Stope Design Under Geological Uncertainty Using Deep
   Reinforcement Learning},
Booktitle = {INTERNATIONAL GEOSTATISTICS CONGRESS 2024},
Series = {Quantitative Geology and Geostatistics},
Year = {2025},
Volume = {20},
Pages = {229-237},
Abstract = {The design of a stope layout is the initial step in an underground stope
   project and helps with long term planning while also defining the
   mineable ore reserves and the economic value to be extracted during the
   life-of-mine. Decision-making at this stage is subject to uncertainties
   in the geological and mineral grade estimated models due to the scarce
   data typically available, which has a major impact on the performance of
   mining assets. Although geostatistical techniques have been established
   to characterize uncertainty with multiple conditional simulated models,
   incorporating these orebody simulations into the mining design process
   remains a major challenge. Simulated models are typically used for
   evaluation of deterministic mine designs rather than optimization. In
   this paper, a Proximal Policy Optimization (PPO) algorithm, a Deep
   Reinforcement Learning technique, is proposed to integrate multiple
   conditional orebody simulations to generate an underground stope layout
   that maximizes the expected profit of the mine over an ensemble of
   geostatistical realizations. A risk-discounted approach is then
   presented that penalizes the downside risk of stopes to generate a
   design that has a lower risk. The user controls their attitude towards
   risk, allowing for a risk-averse (lower profit variance over the
   ensemble) or opportunity-seeking (higher average profit over the
   ensemble) set of stopes. A case study is presented based on a gold
   deposit where 100 conditional simulations are generated and multiple
   stope designs are compared. The proposed framework achieves a higher
   expected value than the widely used deterministic underground stope
   design tool, as it uses information across all the simulated scenarios
   to guide the mine design process. Moreover, the proposed approach allows
   the practitioner to tune the risk profile of the generated stopes to
   align with their attitude towards profit uncertainty.},
Type = {Proceedings Paper},
Affiliation = {Noriega, R (Corresponding Author), Univ Alberta, Ctr Computat Geostat, Edmonton, AB, Canada.
   Noriega, Roberto; Boisvert, Jeff, Univ Alberta, Ctr Computat Geostat, Edmonton, AB, Canada.},
DOI = {10.1007/978-3-031-92870-3\_19},
Keywords = {Geological uncertainty; Underground mine design; Reinforcement learning},
Author-Email = {noriega@ualberta.ca},
Number-of-Cited-References = {9},
Times-Cited = {0},
Unique-ID = {WOS:001697361400019},
}

@incollection{ WOS:001697361400022,
Author = {Hadavand, Mostafa and Deutsch, Clayton V.},
Editor = {Azevedo, L and Narciso, J and Soares, A and Pereira, MJ and Vargas-Guzman, JA},
Title = {Application of Generative Adversarial Networks (GAN) to Geostatistical
   Modeling of Categorical Variables},
Booktitle = {INTERNATIONAL GEOSTATISTICS CONGRESS 2024},
Series = {Quantitative Geology and Geostatistics},
Year = {2025},
Volume = {20},
Pages = {261-278},
Abstract = {The rapid advancement of machine learning techniques has motivated
   exploring their application to geostatistical modeling. GAN (generative
   adversarial networks) is a machine learning framework based on training
   two neural networks known as a generator and a discriminator
   simultaneously and by an adversarial process to generate models that
   honor the underlying distribution of the training data. This paper
   explores the application of GAN with deep convolutional neural networks
   to generate geological models of categorical variables. An ensemble of
   training images is used to train the generator to generate fake models
   that are not distinguishable from real ones while the discriminator is
   trained simultaneously to distinguish between the real and fake models.
   The trained network is capable of processing random inputs and
   generating realizations that honor the spatial continuity of the
   training images. Conditioning to drill hole data is also integrated into
   the training process to generate an ensemble of conditional realizations
   that can capture the geological uncertainty. In this paper, a
   comprehensive overview of the theoretical foundation of GAN is provided.
   A case study is developed to demonstrate application of GAN to produce
   multiple realizations of a conceptual geological model informed by drill
   hole data and training models. A comparison with multiple point
   statistics (MPS) is conducted to assess the performance of GAN.},
Type = {Proceedings Paper},
Affiliation = {Hadavand, M (Corresponding Author), Resource Modeling Solut, Calgary, AB, Canada.
   Hadavand, Mostafa; Deutsch, Clayton V., Resource Modeling Solut, Calgary, AB, Canada.},
DOI = {10.1007/978-3-031-92870-3\_22},
Keywords = {GAN; Categorical variables; Conditional simulation},
Author-Email = {mhadavand@geologicai.com},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001697361400022},
}

@incollection{ WOS:001697361400036,
Author = {de Oliveira, Leandro Jose and de Alcantara, Rodrigo Moura and Coimbra
   Leite Costa, Joao Felipe and Pessoa, Maria Veronica and Capponi, Luciano
   Nunes and Faria de Carvalho, Luiz Henrique},
Editor = {Azevedo, L and Narciso, J and Soares, A and Pereira, MJ and Vargas-Guzman, JA},
Title = {A Proposal for a Hierarchical and Hybrid Methodology for Resource
   Classification: Integration of Traditional Methods with Risk Maps},
Booktitle = {INTERNATIONAL GEOSTATISTICS CONGRESS 2024},
Series = {Quantitative Geology and Geostatistics},
Year = {2025},
Volume = {20},
Pages = {461-475},
Abstract = {Mineral Resources classification by confidence levels of tonnages and
   grades is fundamental for Mineral Resources disclosure and to assess the
   maturity and risk associated with a mineral deposit. While geometric
   methods are transparent and easy to understand, they do not directly
   capture local variations of uncertainty. Geostatistical methods
   primarily address the quality of grade estimation. The Scorecard method
   aims to consider various parameters involved in Mineral Resources
   Classification. However, some aspects of this methodology, such as the
   scoring system for defining uncertainty classes and the weights as
   signed in the final scoring, can be considered subjective. The goal of
   this work is to present a methodology for Mineral Resources
   Classification that considers various parameters. The methodology is a
   hybrid approach that combines traditional geometric classification
   methods with risk map. The risk map is composed of sources: (i)
   geological uncertainty, (ii) data base quality, and (iii) grade
   estimation quality. To avoid subjectivity in combining uncertainties,
   the risk map is built by K-means clustering methodology. The risk map,
   divided into high, medium, and low risks. The final classification is
   hierarchical combination of geometric classification with the risk map.
   The application of subsequent machine learning methodology is used to
   eliminate the ``salt and pepper{''} and/or ``spotted dog{''} effects.
   The developed methodology was applied in a case study on a stratigraphic
   deposit and showed good results. It was able to consider traditional
   geometric classification with others important factors. The methodology
   showed to be very efficient, eliminating subjectivity in determining
   boundaries for classifying uncertainties and making the classification
   methodology reproducible.},
Type = {Proceedings Paper},
Affiliation = {de Oliveira, LJ (Corresponding Author), SRK Consulting Brasil, Belo Horizonte, MG, Brazil.
   de Oliveira, Leandro Jose; Pessoa, Maria Veronica; Faria de Carvalho, Luiz Henrique, SRK Consulting Brasil, Belo Horizonte, MG, Brazil.
   de Alcantara, Rodrigo Moura; Capponi, Luciano Nunes, Companhia Brasileira Metal \& Mineracao CBMM, Araxa, MG, Brazil.
   Coimbra Leite Costa, Joao Felipe, Rio Grande Do Sul Fed Univ UFRGS, Porto Alegre, RS, Brazil.},
DOI = {10.1007/978-3-031-92870-3\_36},
Keywords = {Resource classification; Geometrical classification; Machine learning;
   Risk map},
Author-Email = {loliveira@srk.com.br
   rodrigo.alcantara@cbmm.com
   jfelipe@ufrgs.br
   mvpessoa@srk.com.br
   luciano.capponi@cbmm.com
   lhcarvalho@srk.com.br},
Number-of-Cited-References = {15},
Times-Cited = {0},
Unique-ID = {WOS:001697361400036},
}

@article{ WOS:001643335900001,
Author = {Syu, Chien-Hui and Yen, Chun-Chien and Maisyarah, Selly and Yang,
   Bo-Jiun and Tzou, Yu-Min and Jien, Shih-Hao},
Title = {Soil organic carbon projections and climate adaptation strategies across
   Pacific Rim agro-ecosystems},
Journal = {SOIL},
Year = {2025},
Volume = {11},
Number = {2},
Pages = {1109-1130},
Abstract = {In Pacific Rim regions highly exposed to climate variability, accurate
   projections of soil organic carbon (SOC) are critical for future
   effective land management and climate adaptation strategies. This study
   integrated digital soil mapping with CMIP6-based climate correlative
   spatial modelling to estimate the spatiotemporal distribution of SOC
   stocks in subtropical (Zhuoshui River) and tropical (Laonong River)
   watersheds in Taiwan. We collected 901 soil samples and data on 18
   environmental covariates and modeled SOC stocks at a 20 m resolution
   through the Cubist and random forest algorithms, which were also
   combined with regression kriging. The Cubist-based kriging model was
   discovered to achieve the highest performance in SOC stock prediction.
   Mountainous areas were found to contain >80 \% of SOC stocks, and
   tropical zones were discovered to store substantially less carbon than
   subtropical zones. The space-for-time estimates derived from future
   climate analogues indicated considerable spatial heterogeneity in
   potential steady-state SOC conditions. Under SSP1-2.6, climatic
   analogues associated with cooler and drier conditions corresponded to
   lower SOC stocks - up to 20.9 \% lower than baseline - particularly in
   uplands, whereas SSP2-4.5 analogues were associated with SOC states that
   were 7.9 \% higher, especially in mountainous regions. These contrasts
   reflect spatial associations observed in the contemporary landscape
   rather than mechanistic predictions of erosion, productivity, or
   carbon-cycle responses. Partial least squares path modeling revealed a
   strong climate-topography interaction and explicitly quantified their
   contributions to SOC stocks, dominated by topography and followed by
   prolonged dry spells (CDD). This interaction is more pronounced in
   uplands than in mountainous areas, where topography mitigates
   temperature extremes and their effects on SOC retention. Extended CDD
   may decrease organic inputs by reducing vegetation growth and soil
   moisture, thereby enhancing carbon losses. Examining the interactions
   between climatic extremes, landscape types, and SOC stocks is essential
   for enhancing soil resilience and ensuring stable SOC stocks in the
   future.},
Type = {Article},
Affiliation = {Jien, SH (Corresponding Author), Natl Chung Hsing Univ, Dept Soil \& Environm Sci, Taichung 40227, Taiwan.
   Syu, Chien-Hui; Yen, Chun-Chien; Yang, Bo-Jiun, Agr Res Inst Taiwan, Agr Chem Div, Taichung 40227, Taiwan.
   Yen, Chun-Chien; Maisyarah, Selly; Tzou, Yu-Min; Jien, Shih-Hao, Natl Chung Hsing Univ, Dept Soil \& Environm Sci, Taichung 40227, Taiwan.},
DOI = {10.5194/soil-11-1109-2025},
Keywords-Plus = {STOCKS; FOREST; MAPS; TOOL},
Author-Email = {shjien@nchu.edu.tw},
Number-of-Cited-References = {68},
Times-Cited = {0},
Unique-ID = {WOS:001643335900001},
}

@incollection{ WOS:001604632600016,
Author = {Parra, Maritza Ospina and Riascos, Carlos Orlando Lozada and Porras,
   Julio Cesar Chavarro},
Editor = {Agredo-Delgado, V and Ruiz, PH and Escobar, CAM},
Title = {Selection of a Machine Learning Model for Automated Massive Valuation in
   the Context of the Colombian Cadastre},
Booktitle = {COLLABORATION IN KNOWLEDGE DISCOVERY AND DECISION MAKING, DECISIONING
   2024},
Series = {Communications in Computer and Information Science},
Year = {2025},
Volume = {2369},
Pages = {200-211},
Abstract = {Knowledge of land values is crucial for the development of economic and
   fiscal policies that enable the estimation of comprehensive property
   values in alignment with the dynamic nature of the real estate market.
   In Colombia, the cadastre has undergone a significant transformation,
   evolving from a purely fiscal model to a multipurpose cadastre aimed at
   addressing contemporary challenges such as outdated records, incomplete
   coverage, and the lack of systematic training. Consequently, continuous
   cadastral updating and professional training are essential to accurately
   reflect economic development, urban expansion, and administrative
   changes. However, despite advancements in technology, the available
   tools have not been sufficient to efficiently capture, process, and
   analyze the vast volume of information required for an accurate
   valuation system. This paper presents a theoretical approach to
   evaluating and selecting an artificial intelligence-based methodology to
   improve urban land valuation. The machine learning models analyzed
   include Random Forest (RF), Support Vector Machine (SVM), Artificial
   Neural Network (ANN), and Gradient Boosting Model (GB). Ultimately, the
   study highlights the effectiveness of Random Forest (RF), which, when
   integrated with the Kriging geostatistical model (KG) to incorporate
   spatial dependencies, achieves a superior predictive accuracy.},
