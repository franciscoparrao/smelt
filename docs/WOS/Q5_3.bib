   Pradhan, Biswajeet, Univ Kebangsaan Malaysia, Inst Climate Change, Earth Observat Ctr, Bangi 43600, Selangor, Malaysia.},
DOI = {10.1038/s41598-025-15381-2},
Article-Number = {30968},
Keywords = {Multi-hazard; Remote sensing; Spatial prediction; Machine learning; Risk
   assessment},
Keywords-Plus = {WEIGHTS-OF-EVIDENCE; RISK; ALGORITHMS; CHALLENGES; MODELS},
