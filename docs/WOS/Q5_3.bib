   Wu, Kening, Minist Nat Resources, Key Lab Land Consolidat \& Rehabil, Beijing 100035, Peoples R China.},
DOI = {10.3390/agronomy15040963},
Article-Number = {963},
Keywords = {genetic algorithm; precision agriculture; sampling layout optimization;
   soil type mapping},
Keywords-Plus = {SPATIAL PREDICTION; GENETIC ALGORITHM; ORGANIC-MATTER; RANDOM FOREST;
   REGRESSION; CLASSIFICATION; DESIGN; MODELS; TREE; GIS},
