   Triantafilis, John, Manaaki Whenua Landcare Res, POB 69040, Lincoln 7640, New Zealand.},
DOI = {10.1007/s10705-022-10233-1},
EarlyAccessDate = {SEP 2022},
Keywords = {Digital soil mapping (DSM); Electromagnetic (EM) induction data;
   Gamma-ray (gamma-ray) data; Vis-NIR library; Machine learning modelling},
Keywords-Plus = {GAMMA-RAY; RANDOM FOREST; MATTER; CLASSIFICATION; INVERSION; MACHINE;
   MODEL; SCALE; NIR},
Author-Email = {triantafilisj@landcareresearch.co.nz},
