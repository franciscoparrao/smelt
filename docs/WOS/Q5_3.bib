DOI = {10.1080/19475705.2025.2562281},
Article-Number = {2562281},
Keywords = {Jinsha River reservoir; hydro-fluctuation belt; degradation
   susceptibility; machine learning models; coupling models},
Keywords-Plus = {LANDSLIDE SUSCEPTIBILITY; FAULT ZONE; STRENGTH},
Author-Email = {tmg@cdut.edu.cn},
