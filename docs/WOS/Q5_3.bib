   Yan, Yiming; Wu, Sensen, Zhejiang Prov Key Lab Geog Informat Sci, 148 Tianmushan Rd, Hangzhou 310028, Peoples R China.},
DOI = {10.3390/rs16142542},
Article-Number = {2542},
Keywords = {nighttime land surface temperature; spatial downscaling; geographically
   neural network weighted regression; area-to-point kriging},
Keywords-Plus = {URBAN HEAT-ISLAND; ENERGY FLUXES; IN-SITU; MODEL; WATER; DISAGGREGATION;
