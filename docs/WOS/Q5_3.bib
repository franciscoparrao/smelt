@article{ WOS:001168754300001,
Author = {Narayanan, Sai Ranjeet and Ji, Yi and Sapra, Harsh Darshan and Kweon,
   Chol-Bum Mike and Kim, Kenneth S. and Sun, Zongxuan and Kokjohn, Sage
   and Mak, Simon and Yang, Suo},
Title = {A misfire-integrated Gaussian process (MInt-GP) emulator for
   energy-assisted compression ignition (EACI) engines with varying cetane
   number jet fuels},
Journal = {INTERNATIONAL JOURNAL OF ENGINE RESEARCH},
Year = {2024},
Volume = {25},
Number = {7},
Pages = {1349-1380},
Month = {JUL},
Abstract = {For energy-assisted compression ignition (EACI) engine propulsion at
   high-altitude operating conditions using sustainable jet fuels with
   varying cetane numbers, it is essential to develop an efficient engine
   control system for robust and optimal operation. Control systems are
   typically trained using experimental data, which can be costly and time
   consuming to generate due to setup time of experiments, unforeseen
   delays/issues with manufacturing, mishaps/engine failures and the
   consequent repairs (which can take weeks), and errors in measurements.
   Computational fluid dynamics (CFD) simulations can overcome such burdens
   by complementing experiments with simulated data for control system
   training. Such simulations, however, can be computationally expensive.
   Existing data-driven machine learning (ML) models have shown promise for
   emulating the expensive CFD simulator, but encounter key limitations
   here due to the expensive nature of the training data and the range of
   differing combustion behaviors (e.g. misfires and partial/delayed
   ignition) observed at such broad operating conditions. We thus develop a
   novel physics-integrated emulator, called the Misfire-Integrated GP
   (MInt-GP), which integrates important auxiliary information on engine
   misfires within a Gaussian process surrogate model. With limited CFD
   training data, we show the MInt-GP model can yield reliable predictions
   of in-cylinder pressure evolution profiles and subsequent heat release
   profiles and engine CA50 predictions at a broad range of input
   conditions. We further demonstrate much better prediction capabilities
   of the MInt-GP at different combustion behaviors compared to existing
   data-driven ML models such as kriging and neural networks, while also
   observing up to 80 times computational speed-up over CFD, thus
   establishing its effectiveness as a tool to assist CFD for fast data
   generation in control system training.},
Type = {Article},
Affiliation = {Yang, S (Corresponding Author), Univ Minnesota Twin Cities, 111 Church St SE, Minneapolis, MN 55455 USA.
   Narayanan, Sai Ranjeet; Sun, Zongxuan; Yang, Suo, Univ Minnesota Twin Cities, 111 Church St SE, Minneapolis, MN 55455 USA.
   Ji, Yi; Mak, Simon, Duke Univ, Durham, NC USA.
   Sapra, Harsh Darshan; Kokjohn, Sage, Univ Wisconsin, Madison, WI USA.
   Kweon, Chol-Bum Mike; Kim, Kenneth S., DEVCOM Army Res Lab, Aberdeen Proving Ground, MD USA.},
DOI = {10.1177/14680874241229514},
EarlyAccessDate = {FEB 2024},
Keywords = {Compression ignition (CI); glow plug; sustainable aviation fuel (SAF);
   computational fluid dynamics (CFD); machine learning (ML); Gaussian
   process (GP); neural network (NN); support vector machine (SVM)},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; MODEL-PREDICTIVE CONTROL; PROCESS REGRESSION;
   DIESEL; COMBUSTION; OPTIMIZATION; PERFORMANCE; DESIGN},
Author-Email = {suo-yang@umn.edu},
Number-of-Cited-References = {99},
Times-Cited = {4},
Unique-ID = {WOS:001168754300001},
}

@article{ WOS:001188391800001,
Author = {Kang, Jing and Zhang, Bailing and Dang, Anrong},
Title = {A novel geospatial machine learning approach to quantify non-linear
   effects of land use/land cover change (LULCC) on carbon dynamics},
Journal = {INTERNATIONAL JOURNAL OF APPLIED EARTH OBSERVATION AND GEOINFORMATION},
Year = {2024},
Volume = {128},
Month = {APR},
Abstract = {Land Use and Land Cover Change (LULCC) introduces considerable
   uncertainties in its relationship with carbon emissions, posing
   challenges to nature-based climate mitigation. The effective
   establishment and protection of carbon sinks through land use management
   lack clarity. To address this challenge, this study utilized top -down
   interannual grided CO2 data from satellite observations, revealing a 7
   \% decline in carbon sinks in mainland China from 2016 to 2019. Faced
   with this anomaly, we proposed a novel approach that combined machine
   learning with traditional regression analysis, to investigate the
   nonlinear relationship between annual spatiotemporal variations in net
   carbon exchange and LULCC. Sentinel-2 imagery was employed for
   high-resolution (10 m) LULC classification based on uniform rules.
   Particularly, time-series LULC class probabilities were considered and
   estimated using a deep learning framework via the Google Earth Engine
   (GEE) cloud platform, which allows us to access the effects of dynamic
   LULCC. GIS methods were applied to enhance machine learning
   interpretability, integrating multi -source remote sensing datasets,
   particularly for capturing nonlinear features in spatiotemporal aspects
   of LULCC and carbon emissions. Threshold effects revealed how LULCC
   transformed areas were associated with carbon sinks or sources. The
   results mapped carbon sink shrinkage locations, highlighting
   correlations with significant reductions in snow cover (-6.25 \%),
   changing water patterns (-1.3 \%), urban expansion (1 \%), and mixed
   forest changes (regrowth of 4 \% and deforestation of -1\%). This
   research aims to advance understanding of carbon emissions through
   remote sensing, bridging different Earth observation data within a
   geostatistical context, and expects to provide a new validation method
   for the bottom -up approach.},
Type = {Article},
Affiliation = {Dang, AR (Corresponding Author), Tsinghua Univ, Sch Architecture, Beijing 100084, Peoples R China.
   Kang, Jing; Zhang, Bailing, Hiroshima Univ, Grad Sch Adv Sci \& Engn, Higashihiroshima 7398529, Japan.
   Kang, Jing; Dang, Anrong, Tsinghua Univ, Sch Architecture, Beijing 100084, Peoples R China.
   Kang, Jing, Waseda Univ, Waseda Inst Adv Study, Tokyo 1698050, Japan.},
DOI = {10.1016/j.jag.2024.103712},
EarlyAccessDate = {FEB 2024},
Article-Number = {103712},
Keywords = {GEE; Sentinel-2; Top-downCO2 observations; Net carbon exchange; Land
   use/land cover; Machine learning; Non-linear; Carbon neutrality},
Keywords-Plus = {EMISSIONS; FORESTS},
Author-Email = {jkw@aoni.waseda.jp
   d223033@hiroshima-u.ac.jp
   danrong@mail.tsinghua.edu.cn},
Number-of-Cited-References = {37},
Times-Cited = {28},
Unique-ID = {WOS:001188391800001},
}

