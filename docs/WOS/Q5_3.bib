   Nwaogu, Chukwudi, Fed Univ Technol Owerri, Sch Environm Sci, Dept Environm Management, Owerri, Nigeria.},
DOI = {10.1007/s40808-023-01890-4},
EarlyAccessDate = {NOV 2023},
Keywords = {Regression kriging; Soil nutrient; Terrain attributes; Uncertainty
   assessment},
