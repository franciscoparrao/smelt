@article{ WOS:001714517700001,
Author = {Carranza, Juan Pablo and Bologna, Eduardo Leon and Lucca, Carlos Maria},
Title = {The missing link: Comparing mass appraisal techniques and their
   implications for urban land valuation policies in Latin America},
Journal = {LAND USE POLICY},
Year = {2026},
Volume = {166},
Month = {JUL},
Abstract = {From a public policy perspective, this paper examines technical
   alternatives for urban land mass appraisal, employing quantile
   regression forest (machine learning), ordinary kriging (geostatistics),
   and a linear model. These techniques significantly impact automated mass
   appraisal policies. The study was conducted in Cordoba, Argentina.
   Although machine learning models offer advantages in out-of-sample
   prediction, their black-box nature complicates public policy. Linear
   models enable the reconstruction of the value assignment process, but
   they have high prediction variance. Ordinary kriging uses only sample
   geographic coordinates to predict land values, thus eliminating the cost
   of generating independent variables. The results show that machine
   learning provides lower out-of-sample errors and a consistent value map
   that reflects the structure of urban land values. Geostatistics yield
   acceptable results, but they struggle to accurately capture urban
   barriers. The linear model performs poorly outside the sample, with high
   dispersion in similar environments. This study emphasizes the importance
   of considering the strengths and limitations of technical alternatives
   for mass appraisal policies, particularly in Latin America, where
   multilateral credit agencies often fund and control such policies.
   Implementing successful methodologies requires analyzing the capacity of
   local administrations to absorb innovation. Future research should focus
   on hybrid models that combine techniques},
Type = {Article},
Affiliation = {Carranza, JP (Corresponding Author), Univ Nacl Cordoba, Ave Haya Torre, RA-5000 Cordoba X, Argentina.
   Carranza, Juan Pablo; Lucca, Carlos Maria, Univ Nacl Cordoba, Fac Ciencias Sociales, Inst Invest \& Formac Adm Publ, Cordoba, Argentina.
   Bologna, Eduardo Leon, Univ Nacl Cordoba, Fac Ciencias Sociales, Ctr Estudios Avanzados, Cordoba, Argentina.},
DOI = {10.1016/j.landusepol.2026.107998},
EarlyAccessDate = {JUL 2026},
Article-Number = {107998},
Keywords = {Land value; Mass appraisal; Urban public finances; Machine learning;
   Geostatistics; Automated valuation},
Keywords-Plus = {REGRESSION; INDEX; SELECTION},
Author-Email = {juan.carranza@unc.edu.ar
   eduardo.leon.bologna@unc.edu.ar
   carlos.lucca@unc.edu.ar},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001714517700001},
}

@article{ WOS:001720066700001,
Author = {Tavakoli, Mortaza and Parizi, Esmaeel and Kanani-Sadat, Yousef and
   Nikraftar, Zahir and Delooei, Amirhossein Heydari},
Title = {An integrated framework for flood susceptibility assessment in rural
   areas using PSO-optimized machine learning and SHAP-based intelligent
   clustering},
Journal = {ENVIRONMENTAL IMPACT ASSESSMENT REVIEW},
Year = {2026},
Volume = {120},
Month = {JUL},
Abstract = {Flood susceptibility modeling with machine learning (ML) has advanced
   rapidly, yet translating model explanations into actionable,
   place-specific insights remains challenging. To address this gap, we
   extend SHAP-based interpretation beyond global summaries by computing
   settlement-level SHAP values and clustering them to derive interpretable
   rural settlement types. Six ML algorithms (Random Forest, Extreme
   Gradient Boosting, Categorical Boosting, Na \& iuml;ve Bayes Trees,
   Alternating Decision Trees, and Bayesian Logistic Regression) were
   optimized using Particle Swarm Optimization (PSO) and evaluated using
   nine performance metrics. All optimized models achieved strong
   discrimination (AUC > 0.90), with CatBoost performing best (Accuracy =
   0.930; AUC = 0.978). SHAP results identified horizontal and vertical
   overland flow distances, elevation, topographic wetness index,
   lithology, heavy rainfall, terrain ruggedness, slope, and river density
   as the dominant controls of flood susceptibility. Using the CatBoost
   susceptibility map, approximately 76-82\% of rural settlements fall
   within the high to very high susceptibility classes, depending on the
   GIS classification method. We computed settlement-level SHAP values for
   976 rural settlements in Iran's Atrak Basin and applied a two-step
   clustering procedure to summarize these high-dimensional explanations
   into interpretable settlement typologies. The clustering analysis
   further distinguished six rural settlement types, each shaped by unique
   combinations and hierarchies of flood-driving factors, highlighting the
   pronounced spatial variability of flood risk. Overall, the proposed
   framework helps planners prioritize high-risk rural settlements, tailor
   mitigation to dominant local drivers, and inform land-use zoning and
   infrastructure planning in data-scarce regions.},
Type = {Article},
Affiliation = {Tavakoli, M (Corresponding Author), Tarbiat Modares Univ, Dept Geog \& Planning, POB 14115-111, Tehran, Iran.
   Parizi, E (Corresponding Author), Iranian Natl Inst Oceanog \& Atmospher Sci, Tehran 1411813389, Iran.
   Tavakoli, Mortaza, Tarbiat Modares Univ, Dept Geog \& Planning, POB 14115-111, Tehran, Iran.
   Parizi, Esmaeel, Iranian Natl Inst Oceanog \& Atmospher Sci, Tehran 1411813389, Iran.
   Kanani-Sadat, Yousef, Univ Tehran, Coll Engn, Sch Surveying \& Geospatial Engn, Tehran, Iran.
   Nikraftar, Zahir, Queen Mary Univ London, Sch Elect Engn \& Comp Sci, Machine Intelligence \& Decis Syst MInDS Res Grp, London E1 4NS, England.
   Delooei, Amirhossein Heydari, Univ Tehran, Coll Engn, Sch Engn Sci, Tehran, Iran.},
DOI = {10.1016/j.eiar.2026.108414},
Article-Number = {108414},
Keywords = {Machine learning; Flood susceptibility; Particle swarm optimization;
   SHAP; Rural},
Keywords-Plus = {SUPPORT VECTOR MACHINES; SPATIAL PREDICTION; ARTIFICIAL-INTELLIGENCE;
   DECISION TREES; LANDSLIDES; RAINFALL; EVOLUTION; FREQUENCY; CHINA},
