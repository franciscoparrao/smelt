@article{ WOS:001606326000009,
Author = {Azis, I. and Djuraidah, A. and Aidi, M. N. and Indahwati and
   Sopaheluwakan, A.},
Title = {Spatial prediction of the number of wildfire hotspots using negative
   binomial conditional autoregressive random forest},
Journal = {GLOBAL JOURNAL OF ENVIRONMENTAL SCIENCE AND MANAGEMENT-GJESM},
Year = {2025},
Volume = {11},
Number = {4},
Pages = {1509-1526},
Month = {FAL},
Abstract = {BACKGROUND AND OBJECTIVES: Predicting the spatial distribution of
   wildfire hotspots is crucial for forest fire mitigation, particularly in
   high-risk regions such as Kalimantan Island, Indonesia. Hotspots are
   defined as locations where thermal anomalies are present, surpassing the
   usual background temperature. An integrated framework is proposed: a
   negative binomial conditional autoregressive random forest. The approach
   is designed to capture nonlinearity in meteorological drivers,
   over-dispersion in the number of hotspots, and spatial dependence among
   neighboring grid cells. This study aims to estimate the number of
   hotspots and to pinpoint the meteorological factors that significantly
   affect the emergence of hotspots. METHODS: The number of hotspots in
   Kalimantan for September 2024 were analyzed on a grid. Predictors
   included air temperature, precipitation, relative humidity, wind speed,
   and dry days. These variables were aggregated into spatial grids with a
   resolution of 0.25 degree by 0.25 degree. The study conducted a
   simulation where the levels of spatial autocorrelation, alternative
   spatial weight matrices, the ratios of predictorvariance to spatial
   residual variance, and sample sizes were modified. Model performance was
   evaluated using root mean square error and mean absolute error.
   FINDINGS: The proposed model consistently outperformed the conventional
   conditional autoregressive model in both simulated and empirical
   datasets. Gains were largest when predictor variance exceeded spatial
   residual variance. Across most scenarios, reductions in root mean square
   error by 24 percent and in mean absolute error by 33.3 percent were
   observed. It was observed that the results remained stable when
   alternative spatial weight matrices were applied. In the empirical
   application, the model accurately predicted the spatial distribution of
   hotspots. Overestimation occurred in approximately 21.43 percent of the
   grid cells of the observed. Air temperature and relative humidity
   emerged as the leading predictors, but their relative significance
   changed across distinct spatial clusters. Meteorological effects were
   weaker in wet, humid clusters and stronger in hot, dry clusters.
   CONCLUSION: Practical accuracy improvements for spatial prediction of
   the number of hotspots are generated by the integrated framework. It is
   advisable to integrate into operational early-warning systems and
   decision support mechanisms for the prevention of forest and land fires
   in tropical areas susceptible to fires.},
Type = {Article},
Affiliation = {Djuraidah, A (Corresponding Author), IPB Univ, Sch Data Sci Math \& Informat, Bogor, Indonesia.
   Azis, I.; Djuraidah, A.; Aidi, M. N.; Indahwati, IPB Univ, Sch Data Sci Math \& Informat, Bogor, Indonesia.
   Sopaheluwakan, A., Meteorol Climatol \& Geophys Agcy BMKG, Jakarta, Indonesia.},
DOI = {10.22034/gjesm.2025.04.09},
Keywords = {Conditional autoregressive; Hotspots; Negative binomial distribution;
   Random forest; Spatial model},
Author-Email = {irfaniazis@apps.ipb.ac.id
   anikdjuraidah@apps.ipb.ac.id
   muhammadai@apps.ipb.ac.id
   indahwati@apps.ipb.ac.id
   ardhasena@bmkg.go.id},
