@article{ WOS:001695156100003,
Author = {Wang, Bo and Wang, Yangwei and Mou, Jianhui and Wu, Yizhong},
Title = {A novel hybrid meta-model-based multi-objective optimization framework
   for simulation-based expensive black-box problems and its application to
   semi-submersible drilling platforms},
Journal = {OCEAN ENGINEERING},
Year = {2026},
Volume = {352},
Number = {2},
Month = {APR 15},
Abstract = {Structural optimization of semi-submersible drilling platforms is
   hindered by the prohibitive computational cost of high-fidelity finite
   element simulations, making efficient multi-objective optimization a
   significant challenge. This study presents a novel framework (HAM-T-MO)
   that integrates a dynamic hybrid meta-model with a trustregion algorithm
   to directly address this cost barrier. The framework employs three
   distinct meta-models (RBF, Kriging, SVR) and, through an iterative
   trust-region mechanism, strategically guides the search and refines
   approximations specifically within regions of promising Pareto-optimal
   solutions. This focused approach systematically minimizes the number of
   required expensive simulations. Validated on six benchmark problems, the
   method demonstrates high precision and a substantial reduction in
   function evaluations compared to established alternatives like TRIS-mu
   MOGA. In a practical application, the framework was successfully
   deployed for the structural optimization of a generator foundation on a
   semi-submersible platform. It achieved an optimal design meeting all
   engineering constraints with only 68 expensive evaluations, contrasting
   sharply with the hundreds typically required in conventional
   simulation-driven approaches. The results confirm that the proposed
   framework offers a computationally viable and efficient pathway for
   high-fidelity, simulation-based multi-objective design in marine
   structures.},
Type = {Article},
Affiliation = {Wu, YZ (Corresponding Author), Huazhong Univ Sci \& Technol, Sch Mech Sci \& Engn, Wuhan 430074, Peoples R China.
   Wu, YZ (Corresponding Author), Huazhong Univ Sci \& Technol, Natl CAD Supported Software Engn Ctr, Wuhan 430074, Peoples R China.
