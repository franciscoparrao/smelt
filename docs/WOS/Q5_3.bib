@article{ WOS:001568936200001,
Author = {de Sousa, Lizandra de Barros and Montenegro, Abelardo Antonio de
   Assuncao and Isidoro, Jorge Manuel G. P. and da Silva, Thieres George
   Freire and Almeida, Thayna Alice Brito and de Limad, Joao Luis Mendes
   Pedroso and Giongoe, Pedro Rogerio and Jardim, Alexandre Manicoba da
