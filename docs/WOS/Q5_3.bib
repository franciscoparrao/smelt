   Xi, Lei, Chinese Acad Forestry, Inst Ecol Protect \& Restorat, Beijing 100091, Peoples R China.},
DOI = {10.1109/JSTARS.2023.3340429},
Keywords = {Co-Kriging (CK); forest canopy cover (FCC); Ice, Cloud, and Land
   Elevation Satellite/Geoscience Laser Altimeter System (ICESat-2 ATLAS);
   random forest regression (RFR); semivariogram; validity validation},
