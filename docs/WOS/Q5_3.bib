EarlyAccessDate = {JUL 2025},
Keywords = {K-Nearest neighbor (KNN); Land subsidence susceptibility mapping (LSSM);
   Machine learning optimization; Metaheuristic algorithms; Shapley
   additive explanations (SHAP); Spatial prediction models},
