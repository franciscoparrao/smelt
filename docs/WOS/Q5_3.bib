   Magalhaes, Paulo Sergio Graziano, Univ Estadual Campinas, NIPE, Av Cora Coralina 330, Campinas, SP, Brazil.},
DOI = {10.1016/j.geoderma.2022.116252},
EarlyAccessDate = {NOV 2022},
