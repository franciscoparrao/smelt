Keywords = {land surface temperature; downscaling; urban areas; random forests;
   kriging; ground-based data; validation},
Keywords-Plus = {DIFFERENCE WATER INDEX; RESOLUTION; NDWI},
Author-Email = {r.andriamb@postgrad.curtin.edu.au
