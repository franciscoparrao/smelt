}

@article{ WOS:001516883900001,
Author = {Zhai, Mingyang and Li, Zhikai},
Title = {Sensitivity analysis and multiobjective optimization of automotive
   B-pillar crashworthiness considering mechanical uncertainty of
   resistance spot welds},
Journal = {PROCEEDINGS OF THE INSTITUTION OF MECHANICAL ENGINEERS PART C-JOURNAL OF
   MECHANICAL ENGINEERING SCIENCE},
Year = {2025},
Month = {2025 JUN 25},
Abstract = {Unavoidable mechanical uncertainties in engineering structures
   significantly affect their crash performance. The mechanical uncertainty
   of Resistance Spot Welds (RSWs) and its effect on structure
   crashworthiness require a better understanding in vehicle safety and
   lightweight design. Therefore, this work proposed a feasible
   multi-objective optimization approach based on Hybrid Response Surface
   Method (HRSM) to explore the effect of RSWs mechanical uncertainty on
   B-pillar crashworthiness design. The mechanical uncertainty of RSWs was
   investigated experimentally and the variation range of RSWs strength
   under different loading conditions were quantified. Subsequently, a
   reasonable RSW modeling method and Body-In-White (BIW) subsystem
   collision simulation approach were demonstrated and validated with
   experimental results. A HRSM was proposed as surrogate model and the
   NSGA-III genetic algorithm was employed for multi-objective
   optimization. A multi-factor analysis based on HRSM was conducted to
   reveal effects of RSW strength uncertainty on structure crashworthiness
   design. The performance of HRSM was examined and results show that it
   can approximate the actual response between inputs and outputs of
   collision system. Compared with Kriging and Deep Neural Network (DNN),
   the HRSM can improve computational accuracy while ensuing efficiency.
   The machine-learning-based HRSM is an alternative for multiobjective
   optimization and subsequent robustness optimization design for vehicle
   crashworthiness safety. The numerical modeling method and control
   mechanisms of RSWs' mechanical uncertainty on B-pillar crashworthiness
   can provide reference for BIW safety design.},
Type = {Article; Early Access},
Affiliation = {Zhai, MY (Corresponding Author), BYD Autoind Co Ltd, Automot Engn Res Inst, 1001 BYD Rd, Shenzhen, Guangdong, Peoples R China.
   Zhai, Mingyang; Li, Zhikai, BYD Autoind Co Ltd, Automot Engn Res Inst, 1001 BYD Rd, Shenzhen, Guangdong, Peoples R China.},
DOI = {10.1177/09544062251340899},
EarlyAccessDate = {JUN 2025},
Keywords = {Multi-objective optimization; vehicle crash safety; resistance spot
   weld; structure crashworthiness; mechanical uncertainty},
Keywords-Plus = {COACH-PEEL; DESIGN; BODY},
Author-Email = {807349283@qq.com},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001516883900001},
}

@article{ WOS:001521305200002,
Author = {Ding, Yongxia and Fu, Darong and Jiao, Peixiang and Zhang, Jielin and
   Peng, Shouzhang},
Title = {Predicting planting suitability of globally important grain crops using
   a hybrid model},
Journal = {EUROPEAN JOURNAL OF AGRONOMY},
Year = {2025},
Volume = {170},
Month = {SEP},
Abstract = {With global warming and population growth, optimizing crop distribution
   and yields has become an urgent need worldwide. To address this need, we
   simulated potential yields of three globally important grain crops
   (i.e., wheat, maize, and rice) and assessed their planting suitability
   under future climate change using a hybrid model that integrated 9
   outputs of a process-based crop model (i.e., LPJ-GUESS) and the 40
   environmental variables with random forest method. The following results
   were obtained: (1) The hybrid model considering the outputs of LPJ-GUESS
   model and the environmental variables presented a high performance in
   the simulation of crop yields with the coefficient of determination
   ranging from 0.89 to 0.92, suggesting a considerable potential of hybrid
   modeling approach in the spatial interpolation of geography; (2) the
   future climate change and the irrigation will enhance the potential
   yield and the optimal planting suitability of the three crops, excepting
   for future climate change under the high-emission scenario that will
   reduce the optimal planting area of rice; and (3) the actual utilization
   rates of the optimal suitability area for the three crops are very low
   (4.4 \%-32.8 \%), whatever in historical and future periods or under
   rain-fed and irrigation cases, indicating that further spatial
   optimization for the three crops is needed. This study provides regional
   policymakers and managers with a theoretical basis for improving food
   production and rationalizing land planning.},
Type = {Article},
Affiliation = {Ding, YX (Corresponding Author), Baoji Univ Arts \& Sci, Coll Geog \& Environm, Shaanxi Key Lab Disasters Monitoring Mech Simulat, Baoji 721013, Peoples R China.
