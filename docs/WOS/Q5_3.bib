   Nguyen Thi Thuy Ha; Vu Van Luong; Hoang Anh The; Vo Thi Thu Ha, Vinh Univ, Sch Agr \& Nat Resources, Vinh, Vietnam.
   Nguyen Thi Thuy Ha, Patrice Lumumba Peoples Friendship Univ Russia, Moscow, Russia.},
DOI = {10.1088/1755-1315/1345/1/012008},
Article-Number = {012008},
Keywords = {Landslide; machine learning; remote sensing; susceptibility; Nghe An},
Keywords-Plus = {LOGISTIC-REGRESSION; SPATIAL PREDICTION; DECISION; MANAGEMENT;
   ALGORITHMS},
Author-Email = {antt@tdmu.edu.vn},
Number-of-Cited-References = {34},
