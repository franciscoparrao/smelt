Affiliation = {Chen, JP (Corresponding Author), China Univ Geosci, Sch Earth Sci \& Resources, Beijing 100083, Peoples R China.
   Zhang, Zitong; Jiang, Fujie, China Univ Petr, State Key Lab Petr Resources \& Engn, Beijing 102249, Peoples R China.
   Zhang, Zitong; Jiang, Fujie, China Univ Petr, Coll Geosci, Beijing 102249, Peoples R China.
   Chen, Jianping, China Univ Geosci, Sch Earth Sci \& Resources, Beijing 100083, Peoples R China.},
DOI = {10.1016/j.gsf.2026.102248},
Article-Number = {102248},
Keywords = {Mineral prospectivity mapping; Artificial intelligence; Causal feature;
   Machine learning; Granger causality; Geostatistics},
Keywords-Plus = {TIME-SERIES; EXPLORATION; INFERENCE; GRANGER; MODELS},
Author-Email = {cugb\_zzt@163.com
   3s@cugb.edu.cn
   jfjhtb@163.com},
