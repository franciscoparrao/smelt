   Sun, Zheng, Nanjing Hydraul Res Inst, Ctr Ecoenvironm Res, Nanjing 210029, Peoples R China.
   Ma, Lixia, Chinese Acad Sci, Inst Soil Sci, State Key Lab Soil \& Sustainable Agr, Nanjing 210008, Peoples R China.},
DOI = {10.1016/j.still.2026.107135},
Article-Number = {107135},
Keywords = {Soil erodibility; Spatial association dimension; Multi-scale
   environmental covariates; K -value empirical models; Digital mapping},
Keywords-Plus = {UNIFYING QUANTITATIVE-ANALYSIS; LOESS PLATEAU; FIELD PLOTS; EROSION;
   RUNOFF; CHINA; SEDIMENT},
