@article{ WOS:001145177200003,
Author = {Chen, Zelu and Quan, Hechun and Jin, Ri and Jin, Aifen and Lin, Zhehao
   and Jin, Guangri and Jin, Guangzhu},
Title = {Assessment of Landslide Susceptibility Using the PCA and ANFIS with
   Various Metaheuristic Algorithms},
Journal = {KSCE JOURNAL OF CIVIL ENGINEERING},
Year = {2024},
Volume = {28},
Number = {4},
Pages = {1461-1474},
Month = {APR},
Abstract = {It is very important for the susceptibility assessment and disaster
   prediction of the region to effectively evaluate the landslide
   susceptibility. In this study, Particle Swarm Optimization (PSO),
   Artificial Bee Colony algorithm (ABC), Shuffled Frog Leaping Algorithm
   (SFLA) and Bat algorithm (BAT) are used to optimize Adaptive Neuro-Fuzzy
   Inference System (ANFIS) to evaluate the landslide susceptibility. 811
   sample points were collected through remote sensing analysis and field
   investigation for susceptibility analysis. Fifteen landslide evaluation
   factors were quantified and normalized, and the Principal Component
   Analysis (PCA) method was used to compress them into 6 main factors. The
   accuracy analysis results of the area under the curve (AUC), Root Mean
   Square Error (RMSE) and Mean Absolute Error (MAE) evaluation models show
   that the AUC values of PSO, ABC, SFLA and BAT are 93.6\%, 96.2\%, 90.8\%
   and 86.1\%, respectively. Among them, the accuracy of ABC is the
   highest. This study effectively evaluates the landslide susceptibility
   through a new neural network hybrid method, which provides a theoretical
   basis for landslide disaster susceptibility management.},
Type = {Article},
Affiliation = {Quan, HC (Corresponding Author), Yanbian Univ, Coll Geog \& Ocean Sci, Yanji 133002, Peoples R China.
   Chen, Zelu, Yanbian Univ, Coll Integrat Sci, Yanji 133002, Peoples R China.
   Quan, Hechun; Jin, Ri; Jin, Aifen; Lin, Zhehao, Yanbian Univ, Coll Geog \& Ocean Sci, Yanji 133002, Peoples R China.
   Jin, Guangri, YanBian Univ, Coll Engn, Yanji 133002, Peoples R China.
   Jin, Guangzhu, Yanbian Univ, Agr Coll, Yanji 133002, Peoples R China.},
DOI = {10.1007/s12205-024-1598-y},
EarlyAccessDate = {JAN 2024},
Keywords = {Landslide susceptibility; ANFIS; PCA; Natural hazards; Machine learning},
Keywords-Plus = {FUZZY INFERENCE SYSTEM; SPATIAL PREDICTION; RIVER-BASIN; OPTIMIZATION;
   REGRESSION; CHINA},
Author-Email = {hcquan@ybu.edu.cn},
Number-of-Cited-References = {74},
Times-Cited = {7},
