@article{ WOS:001591687300001,
Author = {Felix, Barbara S. and Perron, Christian and Ahuja, Jai and Mavris,
   Dimitri N.},
Title = {Parametric Reduced-Order Model Drag Polars for Supersonic Transport
   Conceptual Design},
Journal = {JOURNAL OF AIRCRAFT},
Year = {2026},
Volume = {63},
Number = {1},
Pages = {234-248},
Month = {JAN-FEB},
Abstract = {Traditional low-fidelity, semi-empirical aerodynamic models are
   typically used to provide drag polars needed for conceptual-level
   mission analysis but are insufficient for unconventional vehicles. In
   such scenarios, higher-fidelity, computationally expensive models
   commonly used in preliminary design are required. Due to the associated
   high computational cost and longer model evaluation time, it is
   impractical to estimate aerodynamic performance for all the design
   perturbations explored in the conceptual sizing stage. This paper
   presents a novel approach for efficiently approximating parametric
   mission drag polars by integrating sensitivity analysis, multifidelity
   surrogate models, and parametric reduced-order modeling techniques. The
   standardized regression coefficients method is used to select the
   geometry design parameters that have the largest impact on key vehicle
   performance metrics. These parameters, combined with hierarchical
   kriging surrogate models, are employed to generate mission drag polars
   for fixed vehicle geometries. Then, the proper orthogonal decomposition
   reduced-order model with kriging interpolation is used to approximate
   the coherent structure of mission drag polars. The proposed method is
   demonstrated on a supersonic commercial aircraft. Results show that both
   the multifidelity surrogate model and the reduced-order model
   effectively emulate vehicle drag polars well for fixed and varying
   vehicle geometries, respectively.},
Type = {Article},
Affiliation = {Felix, BS (Corresponding Author), Georgia Inst Technol, Sch Aerosp Engn, Aerosp Syst Design Lab, Atlanta, GA 30332 USA.
   Felix, Barbara S.; Perron, Christian; Ahuja, Jai, Georgia Inst Technol, Sch Aerosp Engn, Aerosp Syst Design Lab, Atlanta, GA 30332 USA.
   Mavris, Dimitri N., Georgia Inst Technol, ASDL, Atlanta, GA 30332 USA.},
DOI = {10.2514/1.C038369},
EarlyAccessDate = {OCT 2025},
Keywords = {Proper Orthogonal Decomposition; Aerodynamic Performance; Reynolds
   Averaged Navier Stokes; Reduced Order Model; High Fidelity Aircraft;
   Computer Simulation; Machine Learning; Supersonic Aircraft; Supersonic
   Aerodynamics},
Keywords-Plus = {OPTIMIZATION; INTERPOLATION},
Author-Email = {bfelix6@gatech.edu
