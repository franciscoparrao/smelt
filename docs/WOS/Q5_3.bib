   Liu, Peijia, Henan Acad Geol, Zhengzhou 450001, Peoples R China.
   Liu, Peijia, Zhengzhou Univ, Contemporary Capitalism Res Ctr, Zhengzhou 450001, Peoples R China.},
DOI = {10.3390/plants12071464},
Article-Number = {1464},
Keywords = {topsoil; total nitrogen; random forest; modified regression kriging;
