   Wang, Yaqiang, Xiongan Inst Meteorol Artificial Intelligence, Xiongan, Peoples R China.},
DOI = {10.1029/2024GL109870},
Article-Number = {e2024GL109870},
Keywords = {air quality; negative air ions; environmental monitoring; public health;
   machine learning; spatiotemporal augmentation},
