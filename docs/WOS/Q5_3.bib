   Craig, Nicholas J., Univ Melbourne, Sch Biosci, Parkville, Vic 3010, Australia.},
DOI = {10.1016/j.marpolbul.2026.119353},
EarlyAccessDate = {FEB 2026},
Article-Number = {119353},
Keywords = {XGBoost; Random forest; Spatial interpolation; Source apportionment;
   Urban-rural interface},
Keywords-Plus = {WASTE-WATER TREATMENT; TREATMENT PLANTS; RISK-ASSESSMENT; ESTUARY;
   CONTAMINATION; SEDIMENTS; SHANGHAI; RUNOFF; CHINA},
