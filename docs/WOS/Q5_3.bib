@article{ WOS:001470071100009,
Author = {Cotrina-Teatino, Marco Antonio and Marquina-Araujo, Jairo Jhonatan and
   Mamani-Quispe, Jose Nestor and Arango-Retamozo, Solio Marino and
   Ccatamayo-Barrios, Johnny Henrry and Gonzalez-Vasquez, Joe Alexis and
   Donaires-Flores, Teofilo and Calla-Huayapa, Maxgabriel Alexis},
Title = {Categorization of Mineral Resources using Random Forest Model in a
   Copper Deposit in Peru},
Journal = {JOURNAL OF MINING AND ENVIRONMENT},
Year = {2025},
Volume = {16},
Number = {3},
Pages = {947-962},
Abstract = {This work aimed to categorize mineral resources in a copper deposit in
   Peru, using a machine learning model, integrating the K-prototypes
   clustering algorithm for initial classification and Random Forest (RF)
   as a spatial smoother. A total of 318,443 blocks were classified using
   geostatistical and geometric variables derived from Ordinary Kriging
   (OK) such as kriging variance, sample distance, number of drillholes,
   and geological confidence. The model was trained and validated using
   precision, recall, and F1-score metrics. The results indicated an
   overall accuracy of 97\%, with the measured category achieving 98\%
   precision and an F1-score of 0.98. The total estimated tonnage was
   5,859.36 Mt, distributed as follows: 1,446.13 Mt (measured), 2,249.22 Mt
   (Indicated), and 2,164.01 Mt (Inferred), with average copper grades of
   0.43\%, 0.33\%, and 0.31\% Cu, respectively. Compared to the traditional
   geostatistical methods, this hybrid approach improves classification
   objectivity, spatial continuity, and reproducibility, minimizing abrupt
   transitions between categories. The RF model proved to be a robust tool,
   reducing classification inconsistencies and better capturing geological
   uncertainty. Future studies should explore hybrid models (K-means with
   RF, ANN with K-Prototypes, gradient boosting, and deep learning) and
   incorporate economic variables to optimize decision-making in resource
   estimation.},
Type = {Article},
Affiliation = {Cotrina-Teatino, MA (Corresponding Author), Natl Univ Trujillo, Fac Engn, Dept Min Engn, Trujillo, Peru.
   Cotrina-Teatino, Marco Antonio; Marquina-Araujo, Jairo Jhonatan; Arango-Retamozo, Solio Marino, Natl Univ Trujillo, Fac Engn, Dept Min Engn, Trujillo, Peru.
   Marquina-Araujo, Jairo Jhonatan; Donaires-Flores, Teofilo, Natl Univ Altiplano Puno, Fac Chem Engn, Puno, Peru.
   Ccatamayo-Barrios, Johnny Henrry, Univ Nacl San Cristobal Huamanga, Dept Min Engn, Ayacucho, Peru.
   Gonzalez-Vasquez, Joe Alexis, Natl Univ Trujillo, Fac Engn, Dept Ind Engn, Trujillo, Peru.
   Calla-Huayapa, Maxgabriel Alexis, Natl Univ Juliaca, Fac Ind Proc Engn, Juliaca, Peru.},
DOI = {10.22044/jme.2025.15568.2984},
Keywords = {Random forest; Geostatistics; Kriging variance; Mineral resource
   categorization},
Keywords-Plus = {MACHINE LEARNING TECHNIQUES; CLASSIFICATION},
Author-Email = {mcotrinat@unitru.edu.pe},
