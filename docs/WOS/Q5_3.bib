Keywords-Plus = {HIGH-ACCURACY METHOD; CARBON STOCKS; FILLING VOIDS; MODEL; UNCERTAINTY;
   COMPUTATION; INTEGRATION; ALGORITHMS; ADVANTAGE; SATELLITE},
Author-Email = {yue@lreis.ac.cn
