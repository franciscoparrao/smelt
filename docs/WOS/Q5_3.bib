@article{ WOS:001686388600002,
Author = {Hesty, Nurry Widya and Renata, Dionysius Aldion and Pranoto, Bono and
   Wijaya, Prima Trie and Wijayanto, Rudi Purwo and Rostyono, Didik and
   Fithri, Silvy Rahmah and Nurliyanti, Vetri and Nurrohim, Agus and
   Siregar, Erwin and Kuncoro, Arief Heru},
Title = {A comparative study of machine learning and Kriging: Improving wind
   resource assessment in data-scarce, monsoon-affected regions},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {The global transition toward renewable energy necessitates accurate wind
   resource assessments, particularly in data-scarce regions with complex
   terrain and strong seasonal variability. This study presents a
   comparative analysis of machine learning (ML) and geostatistical Kriging
   methods for horizontal wind speed interpolation over Sumba Island,
   Indonesia, using daily NASA POWER gridded data for 2023 under
   monsoon-influenced conditions. Twelve ML algorithms (including ensemble,
   regression, and deep learning approaches) were evaluated under two
   feature scenarios (with and without simple spatial descriptors: distance
   and azimuth) using a cross-site training framework with four training
   locations and Hambapraing as an unseen target site. In parallel, five
   Kriging variogram models were tested, with the exponential variogram
   yielding the best performance among the evaluated configurations. Within
   this specific dataset and experimental design, the Gradient Boosting
   Regressor (GBR) without spatial features achieved the highest predictive
   accuracy among the tested ML models and outperformed
   exponential-variogram Kriging. Seasonal analysis further indicates that
   both ML and Kriging performed better during the dry monsoon, when wind
   fields were more stable. Still, ML maintained slightly more consistent
   accuracy across both wet and dry seasons compared to Kriging. These
   findings highlight practical trade-offs for early-stage wind resource
   mapping in monsoon-affected, data-limited settings: ML can provide
   strong pointwise predictive accuracy, while Kriging offers
   interpretability and uncertainty-related information that supports
   risk-aware planning. Integrating these approaches can enhance the
   reliability and bankability of wind energy projects in
   monsoon-influenced, data-limited environments, ultimately supporting
   more effective site selection and sustainable energy development.},
Type = {Article},
Affiliation = {Hesty, NW (Corresponding Author), Natl Res \& Innovat Agcy BRIN, Res Ctr Energy Convers Technol, South Tangerang 15314, Indonesia.
   Hesty, Nurry Widya; Wijaya, Prima Trie; Wijayanto, Rudi Purwo; Rostyono, Didik; Fithri, Silvy Rahmah; Nurliyanti, Vetri; Nurrohim, Agus; Siregar, Erwin; Kuncoro, Arief Heru, Natl Res \& Innovat Agcy BRIN, Res Ctr Energy Convers Technol, South Tangerang 15314, Indonesia.
