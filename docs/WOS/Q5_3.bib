@article{ WOS:000874428500001,
Author = {Hosseini, Sajjad Talesh and Asghari, Omid and Benndorf, Jorg and Emery,
   Xavier},
Title = {Real-time Uncertain Geological Boundaries Updating for Improved Block
   Model Quality Control Based on Blast Hole Data: A Case Study for
   Golgohar Iron Ore Mine in Southeastern Iran},
Journal = {MATHEMATICAL GEOSCIENCES},
Year = {2023},
Volume = {55},
Number = {4},
Pages = {541-562},
Month = {MAY},
Abstract = {One main problem in the modeling of mineral deposits is to design a
   block model that divides the deposit into homogeneous subdomains. The
   spatial uncertainty in the geological boundaries becomes a critical
   factor prior to the modeling of the ore properties. For this reason,
   reducing the uncertainty of geological models leads to an improved
   mineral resource evaluation. This research work addresses the problem of
   updating the geological models by using actual online-sensor measurement
   data. A novel algorithm is provided, which integrates the discrete
   wavelet transform to the Ensemble Kalman Filter for assimilating
   online-sensor production data into geological models. The geological
   realizations in each time step are transformed to frequency coefficients
   and, after each assimilation step, the updated realizations are
   back-transformed to the original categorical distribution. Furthermore,
   a reconciliation process is performed to compare the online-sensor data
   derived from the production blocks and the updated realizations in each
   time step. The algorithm is illustrated through an application to the
   Golgohar iron deposit located in SW of Sirjan, Iran, and proves to
   reproduce the statistical parameters and connectivity values of the
   primary geological realizations.},
Type = {Article},
Affiliation = {Asghari, O (Corresponding Author), Univ Tehran, Univ Coll Engn, Sch Min Engn, Simulat \& Data Proc Lab, North Amir Abad St, Tehran, Iran.
   Hosseini, Sajjad Talesh; Asghari, Omid, Univ Tehran, Univ Coll Engn, Sch Min Engn, Simulat \& Data Proc Lab, North Amir Abad St, Tehran, Iran.
