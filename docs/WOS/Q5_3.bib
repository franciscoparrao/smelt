DOI = {10.1016/j.geodrs.2025.e00922},
EarlyAccessDate = {JAN 2025},
Article-Number = {e00922},
Keywords = {Soil legacy data; Google earth engine; Pedometrics; Remote sensing;
   Bare-soil image},
Keywords-Plus = {VARIABILITY; REFLECTANCE; MOISTURE; REGION},
Author-Email = {michele.menezes@ufla.br},
