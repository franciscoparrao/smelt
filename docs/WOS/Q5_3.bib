}

@article{ WOS:001634459700001,
Author = {He, Yifan and Cai, Ximei and Dong, Suhang and Wang, Shengli and Li,
   Chongbin and He, Fan},
Title = {Estimation of spatial distribution of heavy metals in soils of mining
   areas based on ensemble learning and multi-source environmental
   variables: Application of LGGWR model},
Journal = {JOURNAL OF HAZARDOUS MATERIALS},
Year = {2026},
Volume = {501},
Month = {JAN 1},
Abstract = {Accurate prediction of soil heavy metal concentrations is crucial for
   environmental management in mining watersheds. Traditional machine
   learning models cannot fully capture the spatial heterogeneity of soil
   contamination. This study proposes a novel Lightweight Gradient Boosting
   Machine-Geographically Weighted Regression (LGGWR) model that combines
   the lightweight gradient boosting machine (LightGBM) with geographically
   weighted regression (GWR). The model uses seven environmental covariates
   and incorporates the Risk Factor for Soil Index (RFSI) technique to
   predict heavy metal concentrations. LGGWR improves prediction accuracy
   by accounting for spatial heterogeneity and nonlinear relationships.
   Results show that after crossvalidation, the coefficients of
   determination (R2) for five heavy metals (Lead (Pb), Zinc (Zn), Copper
   (Cu), Nickel (Ni), and Cadmium (Cd)) are 0.84, 0.71, 0.76, 0.86, and
   0.84, respectively. Compared to random forest (RF), extreme gradient
   boosting (XGBoost), ordinary kriging (OK), GWR, and LightGBM models,
   LGGWR improves R2 by 30.95-42.09 \%. The study is conducted in the
   Baiyin mining area, Gansu, China, using 227 samples from mining and
   agricultural lands, along with 14 control samples. This study provides a
   fundamental data source for environmental management and targeted soil
   remediation strategies.},
Type = {Article},
Affiliation = {Wang, SL (Corresponding Author), Lanzhou Univ, Coll Earth \& Environm Sci, Technol Res Ctr Pollut Control \& Remediat Northwes, Lanzhou 730000, Peoples R China.
   He, Yifan; Cai, Ximei; Dong, Suhang; Wang, Shengli; Li, Chongbin; He, Fan, Lanzhou Univ, Coll Earth \& Environm Sci, Technol Res Ctr Pollut Control \& Remediat Northwes, Lanzhou 730000, Peoples R China.},
DOI = {10.1016/j.jhazmat.2025.140684},
EarlyAccessDate = {DEC 2025},
Article-Number = {140684},
Keywords = {Soil heavy metals; Environmental covariates; Spatial autocorrelation;
   RFSI; Machine learning},
Keywords-Plus = {ACID-MINE DRAINAGE; IMPACTS},
Author-Email = {wangshengl@lzu.edu.cn},
Number-of-Cited-References = {99},
Times-Cited = {1},
Unique-ID = {WOS:001634459700001},
}

@article{ WOS:001723197400001,
Author = {Dastres, Emran and Esmaeili, Hassan and Sonboli, Ali and Mirjalili,
   Mohammad Hossein},
Title = {Optimizing cultivation areas for Salvia leriifolia using
   advanced spatial prediction and hybrid machine learning algorithms for
   maximum bioactive compound yield},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {This study investigated the transformative potential of integrating
   machine learning algorithms into spatial modeling to identify optimum
   cultivation areas of the Salvia leriifolia medicinal plant, focusing on
   maximizing secondary metabolite (abietatriene) production. By employing
   a novel combination of individual and hybrid machine learning
   models-including Random Forest (RF), Boosted Regression Trees (BRT),
   Support Vector Machines (SVM), and their hybrids (RF-BRT, SVM-BRT,
   SVM-RF, and RF-BRT-SVM)-the research offered an advanced approach to
   spatially predicting suitable cultivation sites in Razavi Khorasan
   province, Iran. A Geographic Information System (GIS) was employed to
   analyze 23 environmental factors after rigorous feature selection using
   Variance Inflation Factor (VIF) and Recursive Feature Elimination with
   Cross-Validation (RFECV), ensuring model robustness. Variable
   contributions were evaluated using Bagged CART, and key influencing
   factors, such as clay content (FR = 6.70), land use/cover (FR = 6.25),
   and electrical conductivity (EC) (FR = 5.41), were identified. Among the
   tested models, the RF-BRT hybrid achieved the highest predictive
   accuracy (RMSE = 0.011 and MAE = 0.007), with statistical significance
   confirmed through Friedman test followed by Nemenyi Critical Difference
   (CD) test. Furthermore, spatial uncertainty was assessed using
   prediction standard deviations and 95\% prediction intervals, revealing
   that the RF-BRT model not only produced the most accurate but also the
   most stable predictions. These insights are crucial for enhancing the
   sustainable cultivation and conservation of S. leriifolia, particularly
   in the northern and northwestern regions of Razavi Khorasan, and provide
   a framework for informed agricultural practices. The broader
   implications extend to medicinal plant conservation, sustainable
   agriculture, and drug development, with recommendations for future
   research to explore physiological mechanisms and extend predictive
   models to other regions and species.},
Type = {Article},
Affiliation = {Esmaeili, H (Corresponding Author), Shahid Beheshti Univ, Med Plants \& Drugs Res Inst, Dept Agr, Tehran 1983969411, Iran.
   Dastres, Emran; Esmaeili, Hassan; Mirjalili, Mohammad Hossein, Shahid Beheshti Univ, Med Plants \& Drugs Res Inst, Dept Agr, Tehran 1983969411, Iran.
   Sonboli, Ali, Shahid Beheshti Univ, Med Plants \& Drugs Res Inst, Dept Biol, Tehran 1983969411, Iran.},
DOI = {10.1016/j.atech.2025.101482},
Article-Number = {101482},
Keywords = {Abietatriene; Spatial prediction models; Secondary metabolites;
   Environmental factors; Machine Learning Algorithms; Artificial
   Intelligence (AI)},
Keywords-Plus = {STRESS},
Author-Email = {h\_esmaeili@sbu.ac.ir},
Number-of-Cited-References = {89},
Times-Cited = {1},
Unique-ID = {WOS:001723197400001},
}

@article{ WOS:001636442000001,
Author = {Zhang, Lei and Mi, Jian and Zhao, Yongchuan and Tan, Zhihua and Wu,
   Yonghong and Dong, Jiaxing},
Title = {Study on the spatial distribution and advanced prediction of dolomite
   sandification grades using multiple detection methods},
Journal = {AIP ADVANCES},
Year = {2025},
Volume = {15},
Number = {12},
Month = {DEC 1},
Abstract = {The problem of dolomite sandification has gradually become one of the
   key factors affecting tunnel construction safety. In practical
   engineering, accurately predicting the dolomite sandification grades and
   their spatial distribution, especially during the advanced forecasting
   stage of tunnel construction, has become a crucial technical issue for
   improving construction safety, optimizing design parameters, and
   enhancing support efficiency. This study first establishes a systematic
   multi-parameter index system for dolomite sandification grade
   classification. By integrating preliminary excavation indicators,
   structural characteristics of the rock mass, and quantitative
   physical-mechanical property indices, a comprehensive method for
   sandification grade classification from qualitative to quantitative is
   proposed. The fuzzy analytic hierarchy process and membership degree
   calculation methods are employed to eliminate the interference of
   subjective human factors, thereby improving the scientific and objective
   nature of sandification grade classification. Next, this study designs a
   multi-source data fusion framework for predicting sandification grades,
   incorporating multiple detection methods, such as seismic waves,
   transient electromagnetic methods, geological radar methods, and
   advanced drilling methods. By combining deep learning techniques, a
   high-precision spatial prediction model for sandification grades is
   constructed. The prediction results of different detection methods are
   fused using weighted averaging and ensemble learning techniques, which
   enhance the model's stability and accuracy. This is particularly
   effective in complex dolomite strata, where the spatial distribution
   patterns of sandification zones can be effectively identified. Finally,
   to ensure the scientific and practical nature of the predictions, this
   paper proposes and implements a ``prediction-validation-feedback{''}
   closed-loop system. In the prediction phase, the multi-source data
   fusion framework is used to predict the spatial distribution of
   sandification grades. In the validation phase, the accuracy of the
   prediction is verified by comparing the lithological exposure after
   excavation in actual engineering projects. In the feedback phase, based
   on actual excavation results, model parameters are optimized, and the
   weights of different detection methods are adjusted, thus enabling
   dynamic improvements in prediction accuracy and dynamic optimization of
   support design. Through the application of this closed-loop system,
   dynamic optimization of sandification grade prediction was successfully
   achieved in the Yuxi section of the Yunnan Central Water Diversion
   Project, significantly improving the prediction accuracy.},
Type = {Article},
Affiliation = {Mi, J (Corresponding Author), Yunnan Inst Water \& Hydropower Engn Invest Design, Kunming 650021, Peoples R China.
   Zhang, Lei, Yunnan Inst Water \& Hydropower Engn Invest Design, Kunming 650021, Peoples R China.
   Mi, Jian; Zhao, Yongchuan; Tan, Zhihua, Yunnan Inst Water \& Hydropower Engn Invest Design, Kunming 650021, Peoples R China.
   Wu, Yonghong; Dong, Jiaxing, Kunming Univ Sci \& Technol, Kunming 650031, Peoples R China.},
