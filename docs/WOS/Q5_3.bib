   Lin, Guang, Purdue Univ, Dept Math, W Lafayette, IN 47907 USA.
   Lin, Guang, Purdue Univ, Sch Mech Engn, W Lafayette, IN 47907 USA.},
DOI = {10.1007/s11004-022-09998-6},
