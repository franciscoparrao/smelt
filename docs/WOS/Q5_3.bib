   Wang, Li, Natl Inst Nat Hazards, Beijing, Peoples R China.},
DOI = {10.1016/j.ejrh.2024.101828},
Article-Number = {101828},
Keywords = {Himalayan glaciated basin; Precipitation; Stacking machine learning;
   Hydrological modeling; De-trend analysis},
Keywords-Plus = {KOSHI RIVER-BASIN; SPATIAL INTERPOLATION; TIANSHAN MOUNTAINS; MODEL
   CALIBRATION; NEPAL HIMALAYA; GLACIER MELT; LAND-USE; FUTURE; ASIA;
   SIMULATION},
