}

@article{ WOS:001713079200020,
Author = {Mishra, Abhishek Kumar and Kumar, Suraj and Kumari, Astha and Maurya,
   Madan Chandra and Maurya, Nityanand Singh},
Title = {Comparative Analysis of Random Forest and Decision Tree for Arsenic
   Prediction in Groundwater in Begusarai, Bihar},
Journal = {ORIENTAL JOURNAL OF CHEMISTRY},
Year = {2026},
Volume = {42},
Number = {1},
Pages = {194-201},
Month = {FEB},
Abstract = {A comprehensive statistical analysis was conducted on groundwater
   samples from Matihani and Cheria Bariarpur blocks of Begusarai District,
   Bihar to assess physicochemical properties and heavy metal
   concentrations. While pH levels in both blocks remained within
   acceptable limits (6.5-8.5), arsenic (As) concentrations significantly
   exceeded the permissible limit (0.01 mg/L), with mean values of 0.129
   mg/L in Matihani and 0.1656 mg/L in Cheria Bariarpur. Machine learning
   models-Decision Tree Regressor (DTR) and Random Forest Regressor
   (RFR)-were applied to predict arsenic concentrations. RFR outperformed
   DTR, achieving a lower MSE (0.001867), RMSE (0.043208), and higher NSE
   and R2 values (0.895), demonstrating superior predictive accuracy.The
   results indicate that arsenic contamination poses a serious public
   health risk, and Random Forest offers a robust tool for spatial
   prediction and water quality management. This study highlights the
   importance of integrating AI-driven modeling with field data to enhance
   groundwater risk assessment and support informed mitigation strategies.},
Type = {Article},
Affiliation = {Maurya, NS (Corresponding Author), Natl Inst Technol Patna, Dept Civil Engn, Patna 800005, Bihar, India.
   Mishra, Abhishek Kumar; Kumar, Suraj; Maurya, Nityanand Singh, Natl Inst Technol Patna, Dept Civil Engn, Patna 800005, Bihar, India.
   Kumari, Astha, Bakhtiyarpur Coll Engn, Dept Civil Engn, Bhaktiyarpur 803212, Bihar, India.
   Maurya, Madan Chandra, Madan Mohan Malaviya Univ Technol, Civil Engn Dept, Gorakhpur 273010, Uttar Pradesh, India.},
DOI = {10.13005/ojc/420121},
Keywords = {Arsenic; Decision tree; Machine learning; Modelling; Prediction.},
Keywords-Plus = {WATER-QUALITY; DRINKING; TOXICITY},
Author-Email = {nsmaurya@nitp.ac.in},
