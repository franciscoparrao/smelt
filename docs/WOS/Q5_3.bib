@article{ WOS:001531186800001,
Author = {Yoon, Sunhee and Kim, Se-Hyun and Lee, Wang-Hee},
Title = {Spatial prediction of Melanoplus differentialis using an ensemble
   of multiple species distribution models},
Journal = {INSECT CONSERVATION AND DIVERSITY},
Year = {2026},
Volume = {19},
Number = {1},
Pages = {26-39},
Month = {JAN},
Abstract = {Melanoplus differentialis, a notorious invasive alien species with a
   high spread potential, causes negative socioecological impacts. Climate
   change-induced alterations in its occurrence areas are a global concern,
   necessitating a precautionary evaluation of its distribution under
   varying climatic conditions to prevent damage caused by this pest. In
   this study, multiple species distribution modelling (SDM) algorithms
   (CLIMEX, MaxEnt and Random Forest) were employed and integrated to
   evaluate the potential distribution of M. differentialis under climate
   change scenarios. Model performance was evaluated using both the
   validation dataset used during model development and a spatiotemporally
   separated test dataset. Although the SDM algorithms showed differences
   in performance, all models consistently demonstrated a recall exceeding
   0.9 on the test occurrence datasets. The potential occurrence areas for
   M. differentialis are expected to expand primarily around its native
   North America as climate changes. Additionally, Europe and Far East
   Asia, where the species has not yet been observed, have been identified
   as risk areas for its post-invasion spread, highlighting the need for
   intensive monitoring. This study provides essential information for
   establishing proactive strategies to control M. differentialis, which
   occurs on a large scale and moves rapidly. It also proposes a
   methodological approach using a multi-algorithm-based ensemble SDM to
   develop an effective species distribution prediction model.},
Type = {Article},
Affiliation = {Lee, WH (Corresponding Author), Chungnam Natl Univ, Dept Smart Agr Syst, Daejeon 34134, South Korea.
   Yoon, Sunhee; Lee, Wang-Hee, Chungnam Natl Univ, Dept Smart Agr Syst, Daejeon 34134, South Korea.
   Kim, Se-Hyun, ALLFORLAND, Seoul, South Korea.
   Lee, Wang-Hee, Chungnam Natl Univ, Dept Smart Agr Syst Machinery Engn, Daejeon, South Korea.},
DOI = {10.1111/icad.70002},
EarlyAccessDate = {JUL 2025},
Keywords = {climate change; differential grasshopper; ensemble modelling; multiple
   algorithms; spatial evaluation},
Keywords-Plus = {CLIMATE-CHANGE; RANDOM FORESTS; GRASSHOPPERS; ORTHOPTERA; PERFORMANCE;
   MAXENT; LANDSCAPE; ACRIDIDAE; FUTURE; BIAS},
Author-Email = {wanghee@cnu.ac.kr},
Number-of-Cited-References = {107},
Times-Cited = {1},
Unique-ID = {WOS:001531186800001},
}

@article{ WOS:001555135000001,
Author = {Hu, Bifeng and Geng, Yibo and Ni, Hanjie and Shi, Zhou and Wang, Zheng
   and Wang, Nan and Luo, Jipeng and Xie, Modian and Zou, Qian and Optiz,
   Thomas and Li, Hongyi},
Title = {Mapping and understanding the regional farmland SOC distribution in
   southern China using a Bayesian spatial model},
Journal = {GEODERMA},
Year = {2025},
Volume = {460},
Month = {AUG},
Abstract = {Information on the spatial distribution of soil organic carbon (SOC) in
   regional farmland is crucial for improving management and production.
   Mapping SOC in farmlands is challenging due to the strong variation of
   SOC caused by the influence of natural and anthropogenic activities.
   Additionally, currently widely used predictive models usually suffer
   from a lack of model interpretability. To fill these gaps, here we use a
   Bayesian spatial model termed Integrated Nested Laplace Approximation
   with the Stochastic Partial Differential Equation (INLA-SPDE) to produce
   the fine scale SOC map in the farmland of Jiangxi Province, south China
   based on an extensive soil survey dataset (n = 16,050). The competitive
   adaptive reweighted sampling algorithm - partial least square (CARS-PLS)
   algorithm is adopted to select the most related covariates from the
   original covariates pool. Then, the performance of Random Forest (RF),
   Geographically Weighted Regression (GWR), and Ordinary Kriging (OK) was
   compared with INLA-SPDE. Finally, an interpretable machine learning
   model, the SHapley Additive exPlanation (SHAP), is used to quantify the
   environmental covariates' contribution to mapping SOC, as well as
   mapping spatial varying primary covariates for predicting SOC in the
   study area. We find that INLA-SPDE was able to handle a large data and
   performed much better than OK and GWR with an improvement of 38.89 \%
   and 117.39 \% in R2, respectively. It also outperforms RF. Overall,
   amount of straw return, mean annual precipitation, mean annual solar
   radiation are the most important covariates for mapping SOC. Locally,
   soil management are the most important covariates for mapping SOC in
   50.52 \% regions of the study area, followed by climate factors (22.06
   \%), soil properties (17.09 \%), terrain (6.38 \%), lithology (2.21 \%)
   and biota factors (1.72 \%). Our study demonstrates the advantages of
   INLA-SPDE on mapping SOC compared with geostatistical and RF for SOC
   mapping and provides valuable implications for interpreting the results
   of digital soil mapping.},
Type = {Article},
Affiliation = {Li, HY (Corresponding Author), Jiangxi Univ Finance \& Econ, Sch Publ Adm, Dept Land Resource Management, Nanchang 330013, Peoples R China.
   Li, HY (Corresponding Author), Jiangxi Univ Finance \& Econ, Key Lab Data Sci Finance \& Econ Jiangxi Prov, Nanchang 330013, Peoples R China.
