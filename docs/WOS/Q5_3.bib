   Abebrese, David Kwesi, Czech Univ Life Sci, Fac Agrobiol Food \& Nat Resources, Dept Water Resources, Suchdol 16500, Prague, Czech Republic.},
DOI = {10.1016/j.catena.2025.108902},
EarlyAccessDate = {MAR 2025},
