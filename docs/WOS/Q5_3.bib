@article{ WOS:001706908700001,
Author = {Shen, Liang and Song, Guozhen and Zhang, Hao},
Title = {Predicting the spatial distribution of invasive species richness using
   the combination of machine learning and geostatistical algorithms},
Journal = {ECOLOGICAL INFORMATICS},
Year = {2026},
Volume = {94},
Month = {MAR},
Abstract = {Spatial predictions of invasive plant species richness across large
   geographic areas are essential for assessing the effects of management
   practices across environmental gradients. Traditional spatial
   statistical algorithms often struggle with large-scale, high-dimensional
   datasets in the era of big data, limiting their analytical capabilities
   and predictive accuracy. Simultaneously, measuring and exploring the
   drivers of invasive species richness is crucial for both ecological
   research and land management aimed at controlling invasions. To address
   these challenges, two novel hybrid machine learning-geostatistical
   algorithms, elastic net regression residual combined with ordinary
   kriging (ElaNetOK) and elastic net regression residual combined with
   inverse distance weighting (ElaNetIDW), were constructed and applied
   across six ecoregions of mixed forests in the United States. Datasets of
   29,228 mixed forest plots together with 51 ecological variables from the
   WorldClim 2.1 and the Forest Inventory and Analysis (FIA) were used to
   evaluate the performance of traditional geostatistical models and the
   two hybrid machine learning-geostatistical algorithms. Results
   demonstrate that ElaNetOK and ElaNetIDW effectively handle
   high-dimensional spatial datasets, reduce prediction uncertainty, and
   consistently outperform traditional geostatistical methods in both
   accuracy and stability. Quantitatively, ElaNetIDW achieved accuracy
   improvements over conventional IDW ranging from 0.88\% to 6.90\% across
   six ecoregions, with an average improvement of 3.25\%. Similarly,
   ElaNetOK outperformed OK, with regional improvements between 1.10\% and
   7.11\%, averaging 3.33\%. Furthermore, spatial prediction maps reveal
   that the hybrid models preserve large-scale environmental gradients
   while capturing enhanced local spatial heterogeneity, producing more
   ecologically realistic spatial patterns. These findings demonstrate the
   potential of hybrid machine learning-geostatistical frameworks for
   large-scale ecological prediction and invasive species management.},
Type = {Article},
Affiliation = {Zhang, H (Corresponding Author), Michigan State Univ, Dept Stat \& Probabil, E Lansing, MI 48824 USA.
   Shen, Liang; Song, Guozhen, Qingdao Univ Technol, Dept Stat, Qingdao, Peoples R China.
   Zhang, Hao, Michigan State Univ, Dept Stat \& Probabil, E Lansing, MI 48824 USA.},
DOI = {10.1016/j.ecoinf.2026.103676},
Article-Number = {103676},
Keywords = {Invasive species richness; Hybrid algorithms; Elastic net regression;
   Machine learning; Geostatistical methods; Spatial prediction},
Author-Email = {zhan2329@msu.edu},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001706908700001},
}

@article{ WOS:001699332300001,
Author = {Rosmin, Arby Pratama Putra and Hidayat, Mas Irfan Purbawanto and
   Pramata, Azzah Dyah},
Title = {Recent progress on machine learning techniques for flow field
   optimization toward performance and commercial scale proton exchange
   membrane fuel cell: A systematic review},
Journal = {RESULTS IN ENGINEERING},
Year = {2026},
Volume = {29},
Month = {MAR},
Abstract = {Proton exchange membrane fuel cells (PEMFC) are promising technologies
   for sustainable energy conversion. One of the important factors
   governing its performance is the design of the flow field within bipolar
   plate, which plays a key role in ensuring efficient reactant
   distribution and water management in the membrane electrode assembly.
   This paper provides a systematic review of recent advancements in
   surrogate modelling and machine learning (ML)-based optimization
   techniques as applied to the design of flow fields in PEMFC. The review
   encompasses various flow field configurations, including both 2D and 3D
   designs that incorporate baffles, traps, and bio-inspired structures.
   The modelling and optimization strategies, either single- or
   multi-objective, are identified and examined, enabling clearer
   evaluation of each contribution and limitation. The predictive
   accuracies are reported. The principal factors affecting the performance
   of surrogate models are nonlinearity degree in the input-output
   relationships, dataset size, number and quality of input parameters,
   model architecture, training strategies, and hyperparameter tuning.
   While neural networks (NN), response surface methodology (RSM), support
   vector machines (SVM), Kriging models, and deep neural networks (DNN)
   are commonly utilized surrogate models, the NNs outperform other ML
   models. The other models, however, show more flexibility with limited
   datasets. In addition, genetic algorithm (GA) and non-dominated sorting
   genetic algorithm II (NSGA-II) are respectively the single- and
   multi-objective algorithms most frequently integrated with the surrogate
   models. The use of ML techniques leads to efficient approach greatly
   enhancing PEMFC flow field optimization and hold a promising solution
   toward performance and commercial scale PEMFC.},
Type = {Review},
Affiliation = {Rosmin, APP; Hidayat, MIP (Corresponding Author), Inst Teknol Sepuluh Nopember, Fac Ind Technol \& Syst Engn, Dept Mat \& Met Engn, Lab Mat Innovat, Kampus ITS Keputih Sukolilo, Surabaya 60111, Indonesia.
