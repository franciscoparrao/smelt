   Guo, Hui-Ying, Bengbu Univ, Sch Sci, Bengbu 233030, Peoples R China.
   Cui, Hong-Zhi; Ji, Jian, Shaoxing Univ, State Lab Intelligent Min \& Equipment Deep Met Min, Shaoxing 312000, Peoples R China.
   Cui, Hong-Zhi; Ji, Jian, Shaoxing Univ, Key Lab Rock Mech \& Geohazards Zhejiang Prov, Shaoxing 312000, Peoples R China.},
DOI = {10.3390/w17121778},
