   Solomatine, Dimitri, Delft Univ Technol, Delft, Netherlands.
   Jomaa, Seifeddine, UFZ Helmholtz Ctr Environm Res, Dept Aquat Ecosyst Anal \& Management, Magdeburg, Germany.
   Karatzas, George P., Tech Univ Crete, Sch Chem \& Environm Engn, Khania, Greece.},
DOI = {10.1007/s00477-023-02436-x},
EarlyAccessDate = {APR 2023},
Keywords = {Transgaussian Kriging; Geostatistics; Self-organizing maps; Machine
   learning; Groundwater; Box-Cox},
Keywords-Plus = {WATER-RESOURCES; CLIMATE-CHANGE; PRECIPITATION; PREDICTION; PATTERNS;
