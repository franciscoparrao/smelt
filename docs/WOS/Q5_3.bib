}

@article{ WOS:001671640600001,
Author = {Holobaca, Iulian-Horia and Alexe, Mircea and Temerdek-Ivan, Kinga and
   Ursu, Cosmina-Daniela},
Title = {Enhanced Urban Heat Island Modeling with Machine Learning and Regression
   Kriging in a Topographically Diverse Medium-Sized City},
Journal = {LAND},
Year = {2025},
Volume = {15},
Number = {1},
Month = {DEC 26},
Abstract = {Urban heat islands (UHIs) represent a major environmental challenge,
   particularly in cities with complex topography and local air dynamics
   where spatial variability of the surface temperature is difficult to
   model. This study presents an enhanced UHI modeling framework that
   integrates Random Forest regression with Regression Kriging (RF-RK) in
   Cluj-Napoca, Romania. Using a network of 36 air temperature sensors and
   spatial predictors such as urban environment and location parameters, we
   evaluated the performance of RF-RK against traditional Multiple Linear
   Regression (MLR). Results show that RF-RK achieved substantially higher
   accuracy (R2 = 0.844, RMSE = 0.241 degrees C) compared to MLR (R2 =
   0.653, RMSE = 0.359 degrees C). Spatial patterns revealed that a notable
   thermal gradient can be seen between the western and eastern parts of
   the city and the extension of the heat island core eastward. The
   combined approach effectively captured both the non-linear relationships
   of predictors and the spatial autocorrelation of residuals,
   outperforming single-method models. These findings highlight the
   potential of hybrid machine learning-geostatistical frameworks for urban
   climate research and provide insights for urban planning and heat
   mitigation strategies in topographically diverse cities.},
Type = {Article},
Affiliation = {Alexe, M (Corresponding Author), Babes Bolyai Univ, Fac Geog, Lab Teledetectie \& Observare Mediului GEOTOMLAB, Cent Cercetare Pentru Dezvoltare Durabila CCDD, Cluj Napoca 400006, Romania.
   Holobaca, Iulian-Horia; Alexe, Mircea; Temerdek-Ivan, Kinga; Ursu, Cosmina-Daniela, Babes Bolyai Univ, Fac Geog, Lab Teledetectie \& Observare Mediului GEOTOMLAB, Cent Cercetare Pentru Dezvoltare Durabila CCDD, Cluj Napoca 400006, Romania.},
DOI = {10.3390/land15010049},
Article-Number = {49},
Keywords = {urban heat island UHI; regression; machine learning; topography; spatial
   modeling; environmental monitoring},
Keywords-Plus = {LOCAL CLIMATE ZONES; RANDOM FOREST; MITIGATION; COMFORT; CITIES},
Author-Email = {mircea.alexe@ubbcluj.ro},
Number-of-Cited-References = {42},
Times-Cited = {0},
Unique-ID = {WOS:001671640600001},
}

@article{ WOS:001655502800001,
Author = {Ntibahanana, Munezero and Song, Jianguo and Tondozi, Keto and Luemba,
   Moise and Matindi, Balembo},
Title = {Deep learning-enhanced hybrid geostatistical and physics-guided seismic
   inversion for reservoir fluid discrimination},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {166},
Number = {B},
Month = {FEB 15},
Abstract = {Seismic inversion is essential for subsurface characterization,
   including reservoir fluid discrimination, with applications in
   hydrocarbon exploration, geological carbon dioxide (CO2) sequestration,
   and environmental monitoring. Traditional methods, while physically
   grounded, are computationally demanding and sensitive to subsurface
   heterogeneity. Conversely, purely data-driven deep learning models often
   lack interpretability and perform poorly in data-limited settings. To
   address these limitations, this study presents a hybrid inversion
   framework that integrates deep learning with geostatistics and
   physics-based constraints. Terrain-following meshes, constructed from
   interpreted seismic horizons, guide three-dimensional (3D) synthetic
   porosity modeling via sequential Gaussian simulation, constrained by
   well-log data. Four fully connected neural networks are trained to learn
   nonlinear mappings between seismic attributes and elastic
   parameters-acoustic impedance, the ratio of compressional and shear wave
   velocities, and Poisson's ratio-as proxies for lithofluid content. The
   networks incorporate Gassmann's fluid substitution theory and
   Aki-Richards approximations. An optimized ensemble, developed via random
   weight search and enhanced through higher-order statistical uncertainty
   quantification, demonstrates high predictive performance on field
   seismic data (e.g., Coefficient of Determination ``R2{''} = 0.947; Mean
   Squared Error ``MSE{''} = 0.00112), with narrow uncertainty bounds.
   Evaluation metrics-including cross-plots, Taylor diagrams, and residual
   histograms-show strong agreement with well-log data (Pearson Correlation
   Coefficient ``R{''} = 0.8907, probability value ``p-value{''}
   approximate to 3.46 x 10- 110), while minimal skewness (-0.136) and
   kurtosis (0.142) indicate unbiased and stable predictions. Despite
   limitations in highly heterogeneous formations due to simplified
   petroelastic assumptions, the proposed method offers a scalable,
   interpretable, and computationally efficient solution-achieving full
   inversion in 3 min on a Graphics Processing Unit (GPU). This contributes
   to enhanced reservoir hydrocarbon resource characterization and robust
   CO2 storage monitoring, which is paramount within the context of energy
   transition.},
Type = {Article},
Affiliation = {Song, JG (Corresponding Author), China Univ Petr East China, Sch Geosci, Qingdao 266580, Peoples R China.
   Ntibahanana, M (Corresponding Author), Univ Kinshasa, Fac Petr Gaz \& Energies Renouvelables, BP 127, Kinshasa, DEM REP CONGO.
   Song, Jianguo; Luemba, Moise, China Univ Petr East China, Sch Geosci, Qingdao 266580, Peoples R China.
   Ntibahanana, Munezero, Univ Kinshasa, Fac Petr Gaz \& Energies Renouvelables, BP 127, Kinshasa, DEM REP CONGO.
   Ntibahanana, Munezero; Tondozi, Keto; Matindi, Balembo, Ctr Rech Geophys CRG, BP 127, Kinshasa, DEM REP CONGO.
   Tondozi, Keto; Matindi, Balembo, Univ Kinshasa, Fac Sci \& Technol, BP 127, Kinshasa, DEM REP CONGO.},
DOI = {10.1016/j.engappai.2025.113666},
EarlyAccessDate = {DEC 2025},
Article-Number = {113666},
Keywords = {Physics-guided deep learning; Hybrid seismic inversion; Geostatistics;
   Reservoir fluid prediction; Geological carbon sequestration},
Keywords-Plus = {VELOCITIES; POROSITY; MODULUS},
Author-Email = {joseph.ntibahanana@unikin.ac.cd
   sjg@upc.edu.cn},
