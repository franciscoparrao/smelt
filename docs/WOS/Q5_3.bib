Affiliation = {Tsangaratos, P (Corresponding Author), Natl Tech Univ Athens, Sch Min \& Met Engn, Athens, Greece.
   Ilia, Loanna; Tsangaratos, Paraskevas, Natl Tech Univ Athens, Sch Min \& Met Engn, Athens, Greece.
