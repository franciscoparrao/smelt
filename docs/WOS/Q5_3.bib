DOI = {10.5194/gmd-17-2569-2024},
Keywords-Plus = {WEIGHTED MEAN TEMPERATURE; GROUND-BASED GPS; SOLAR-RADIATION;
   VALIDATION; RADIOSONDE; SURFACE},
Author-Email = {junyu\_li@whu.edu.cn},
