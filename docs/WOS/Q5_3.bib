}

@article{ WOS:001184945600002,
Author = {Gao, Binghai and He, Yi and Chen, Xueye and Chen, Hesheng and Yang, Wang
   and Zhang, Lifeng},
Title = {A Deep Neural Network Framework for Landslide Susceptibility Mapping by
   Considering Time-Series Rainfall},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2024},
Volume = {17},
Pages = {5946-5969},
Abstract = {Landslide susceptibility mapping (LSM) is of great significance in
   geohazard early warning and prevention. The existing LSM methods mostly
   used traditional static landslide conditioning factors (LCFs), which
   only considered the spatial features of single-pixel neighborhoods and
   could not extract the time-series dynamic features of developing
   landslides, resulting in low accuracy and insufficient reliability of
   LSM. To solve this problem, this study proposes to introduce time-series
   rainfall factors based on the traditional static factors and construct
   an integrated time-series dynamic neural network (TSDNN) model for LSM.
   A convolutional neural network (CNN) adding time-distributed convolution
   and a bidirectional long and short-term memory neural network is
   utilized to extract time-series rainfall features, and a multiscale
   convolutional neural network (MSCNN) is utilized to extract static
   features of the static LCFs. In this study, multicollinearity analysis
   and geodetector are utilized to analyze the LCFs. Multiple evaluation
   metrics are utilized to analyze the proposed model performance. The
   results indicate that the overall accuracy has improved by introducing
   time-series rainfall factors, and the susceptibility area of actual
   predicted is more refined. The study indicates that significant
   advantages of the proposed TSDNN model are over models {[}CNN, MSCNN,
   random forest (RF)] when processing combined static and rainfall data.
   This is notably evident that the accuracy is enhanced by 12.9\%, 10.7\%,
   and 11.4\% compared to CNN, MSCNN, and RF models in the receiver
   operating characteristic curve analysis, respectively. Moreover, two
   typical areas containing three recent landslide events validate the
   reliability of the proposed TSDNN model. The proposed network model
   framework for LSM considering time-series rainfall factors can provide
   new ideas and key technical support for landslide disaster prevention.},
Type = {Article},
Affiliation = {He, Y (Corresponding Author), Minist Nat Resources, Key Lab Urban Land Resources Monitoring \& Simulat, Shenzhen 518034, Peoples R China.
   He, Y (Corresponding Author), Lanzhou Jiaotong Univ, Fac Geomatics, Lanzhou 730070, Peoples R China.
   Gao, Binghai; He, Yi; Chen, Xueye, Minist Nat Resources, Key Lab Urban Land Resources Monitoring \& Simulat, Shenzhen 518034, Peoples R China.
   Gao, Binghai; He, Yi; Chen, Hesheng; Yang, Wang; Zhang, Lifeng, Lanzhou Jiaotong Univ, Fac Geomatics, Lanzhou 730070, Peoples R China.},
DOI = {10.1109/JSTARS.2024.3370218},
Keywords = {Deep learning (DL); dynamic factors; interferometry synthetic aperture
   radar (InSAR); landslide susceptibility},
Keywords-Plus = {SPATIAL PREDICTION; 3 GORGES; CHINA; COUNTY},
Author-Email = {1921412281@qq.com
