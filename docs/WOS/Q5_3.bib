DOI = {10.1016/j.jhazmat.2025.140008},
EarlyAccessDate = {OCT 2025},
Article-Number = {140008},
Keywords = {Machine learning; Spatial distribution prediction; Environmental
   predictors; Sediments; Potentially toxic elements},
Keywords-Plus = {HEAVY-METALS; RISK-ASSESSMENT; MACHINE; POLLUTION; WATER},
Author-Email = {guogh@igsnrr.ac.cn},
