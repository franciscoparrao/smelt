   Allafi, Randa, Northern Border Univ, Coll Sci, Dept Comp Sci, Ar Ar, Saudi Arabia.
   Mahgoub, Hany, King Khalid Univ, Coll Sci \& Art Mahayil, Dept Comp Sci, Abha, Saudi Arabia.},
DOI = {10.1016/j.jsames.2025.105440},
EarlyAccessDate = {FEB 2025},
Article-Number = {105440},
Keywords = {Soil salinity; Remote sensing; Machine learning; Random Forest; Salinity
   indices; Spatial prediction; Sustainable land management},
Author-Email = {thenmozhithangarasu74@gmail.com},
