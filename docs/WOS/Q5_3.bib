   Zhao, Zhenmin, Northwestern Polytech Univ, Natl Elite Inst Engn, Xian 710129, Peoples R China.},
DOI = {10.3390/s25185680},
Article-Number = {5680},
Keywords = {AMB-rotor; dynamic model; surrogate model; GRU-KAN; critical speed},
