DOI = {10.1016/j.geodrs.2022.e00578},
EarlyAccessDate = {OCT 2022},
Keywords = {Environmental covariates; Climate change mitigation; Legacy soil data;
   Regression kriging; Shrink-swell soils; SOC stocks},
