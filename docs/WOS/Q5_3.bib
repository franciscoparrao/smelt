DOI = {10.3390/ma18153588},
Article-Number = {3588},
Keywords = {laminated spherical-conical shell; uncertainty optimization; adaptive
   hybrid correlation kriging; improved multi-objective salp swarm
   algorithm},
Keywords-Plus = {FREE-VIBRATION ANALYSIS; EVOLUTIONARY ALGORITHMS; LAMINATED COMPOSITE;
