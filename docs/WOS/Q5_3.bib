@article{ WOS:001389082800001,
Author = {Alves, G. P. and Miguel, L. F. F. and Lopez, R. H. and Carvalho, H.},
Title = {A hybrid metaheuristic and machine learning approach for optimum design
   of transmission line tower families},
Journal = {ENGINEERING OPTIMIZATION},
Year = {2025},
Volume = {57},
Number = {10},
Pages = {2891-2921},
Month = {OCT 3},
Abstract = {In long transmission lines, transmission line tower (TLT) configurations
   are often repeated, unlike most unique structures. To reduce their
   global mass, several optimization methods have been developed.
   Traditionally, metaheuristic algorithms are used to find the optimum,
   but recently, machine learning (ML) techniques have been integrated with
   metaheuristics to accelerate the process. However, the application of ML
   has been limited to small-scale TLTs or academic research. This article
   introduces a novel approach combining a metaheuristic called the
   backtracking search algorithm (BSA) with Kriging-based efficient global
   optimization (EGO). This method optimizes the size and shape of a
   full-scale self-supported TLT family, addressing some of the main
   industrial aspects. Results show that EGO can decrease the TLT family's
   mass by up to 8.37\% with just a few additional objective function
   evaluations (OFEs), while BSA alone would need over 100,000 OFEs for
   comparable outcomes. This efficiency highlights the proposed approach's
   effectiveness in complex engineering design optimization.},
Type = {Article},
Affiliation = {Alves, GP (Corresponding Author), Univ Fed Santa Catarina, Dept Civil Engn, Florianopolis, Brazil.
   Alves, G. P.; Miguel, L. F. F.; Lopez, R. H., Univ Fed Santa Catarina, Dept Civil Engn, Florianopolis, Brazil.
   Carvalho, H., Univ Fed Minas Gerais, Dept Struct Engn, Belo Horizonte, Brazil.
   Carvalho, H., Univ Sao Paulo, Dept Struct \& Geotech Engn, Sao Paulo, Brazil.},
DOI = {10.1080/0305215X.2024.2420744},
EarlyAccessDate = {DEC 2024},
Keywords = {Transmission line towers; optimization; tower family; EGO; Kriging},
Keywords-Plus = {STRUCTURAL OPTIMIZATION; TOPOLOGY OPTIMIZATION; GLOBAL OPTIMIZATION;
   STEEL; SHAPE},
Author-Email = {gpadilhaalves@gmail.com},
Number-of-Cited-References = {40},
