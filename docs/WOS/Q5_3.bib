   Singh, Vijay P., Texas A\&M Univ, Dept Biol \& Agr Engn, College Stn, TX 77469 USA.
   Sun, Shuai, China Meteorol Adm, Natl Meteorol Informat Ctr, Beijing 100875, Peoples R China.},
DOI = {10.3390/rs14184662},
