@article{ WOS:001696884000001,
Author = {Chen, Ling and Guo, Bumin and Shen, Jinwei and Zhao, Jian and Xu, Yantao
   and Li, Shuan and Zhang, Yichang and Qu, Ximo},
Title = {Study on Deep Coal Seam Fracturing Technology and
   Productivity-Influencing Factors},
Journal = {INDIAN GEOTECHNICAL JOURNAL},
Year = {2026},
Month = {2026 FEB 20},
Abstract = {To address issues such as insufficient productivity release and poor
   process parameter adaptability in the fracturing development of deep
   coal seams, this study takes vertical wells and horizontal wells in deep
   coal seams of the Linxing and Shenfu blocks as research objects. It
   conducts data analysis on fractured wells from three dimensions:
   geology, engineering, and production, identifies the key determinants of
   productivity by combining machine learning models, and optimizes the
   commingled fracturing process for sand-coal superimposed reservoirs. The
   results show that the main controlling factors of post-fracturing
   productivity for horizontal wells, in order of importance, are preflush
   ratio > fracture pressure gradient > displacement > gas content per ton
   of coal > sanding intensity; while for vertical wells, the order is
   reservoir thickness > gas content per ton of coal > closure pressure
   gradient > displacement > reservoir depth. The intelligent control
   program constructed based on the Gaussian Kriging surrogate model can
   output optimal construction parameters, achieving a balance between
   maximizing the stimulated reservoir volume (SRV) of fracture networks
   and minimizing construction costs. The research results offer technical
   support for effective development of deep coal seams.},
Type = {Article; Early Access},
Affiliation = {Chen, L (Corresponding Author), China Oilfield Serv Ltd, Tianjin 300450, Peoples R China.
   Chen, Ling; Guo, Bumin; Shen, Jinwei; Zhao, Jian; Xu, Yantao; Li, Shuan; Zhang, Yichang; Qu, Ximo, China Oilfield Serv Ltd, Tianjin 300450, Peoples R China.},
DOI = {10.1007/s40098-026-01500-x},
EarlyAccessDate = {FEB 2026},
Keywords = {Deep coal seam; Fracturing technology; Main controlling factors of
   productivity; Machine learning; Parameter optimization},
Author-Email = {chenhong8008@yeah.net},
Number-of-Cited-References = {20},
Times-Cited = {0},
Unique-ID = {WOS:001696884000001},
}

@article{ WOS:001696063600001,
Author = {Zhang, Shihao},
Title = {Spatial Analysis of Soil Erosion and Sediment Yield in Hunan Province,
   China, Using Digital Soil Mapping Techniques},
Journal = {JOURNAL OF SOIL SCIENCE AND PLANT NUTRITION},
Year = {2026},
Month = {2026 FEB 19},
Abstract = {Soil erosion and sediment yield pose significant threats to agricultural
   sustainability, water security, and ecosystem stability in subtropical
   landscapes. This study aimed to quantify and spatially predict soil
   erosion and sediment yield across Hunan Province, China, by integrating
   field measurements, the Universal Soil Loss Equation (USLE), and
   advanced digital soil mapping techniques. The central research question
   was which modeling approach provides the most accurate and reliable
   spatial predictions to guide soil and water conservation planning. A
   total of 467 composite surface soil samples (0-30 cm) were collected
   during the dry season using a random sampling design. Laboratory
   analyses included soil texture, bulk density, soil organic matter
   content, aggregate stability, and infiltration rate. USLE factors were
   derived from regional rainfall data, soil properties, slope metrics from
   digital elevation models, NDVI, and land management practices. Three
   machine learning algorithms-Random Forest (RF), Artificial Neural
   Network (ANN), and Support Vector Machine (SVM)-were trained using 80\%
   of the dataset and validated with the remaining 20\%. Model performance
   was evaluated using R \& sup2;, RMSE, and MAE, and uncertainty was
   assessed using the prediction interval coverage probability (PICP). The
   RF model consistently outperformed ANN and SVM in predicting both soil
   erosion (training R \& sup2; = 0.92; test R \& sup2; = 0.86) and
   sediment yield (training R \& sup2; = 0.89; test R \& sup2; = 0.80).
   Spatial predictions revealed severe soil erosion (up to 19.8 t ha(-)\&
   sup1; yr(-)\& sup1;) and sediment yield (up to 1,623 t ha(-)\& sup1;
   yr(-)\& sup1;) in the southern and southeastern mountainous areas, while
   flatter central regions exhibited lower values. Elevation and slope were
   identified as the dominant controlling factors, and uncertainty was
   minimal in stable lowlands and highest in dynamic, high-relief
   landscapes. These findings demonstrate the robustness and effectiveness
   of the RF model for spatial environmental modeling and provide
   high-resolution maps of soil erosion and sediment yield that can support
   targeted soil and water conservation policies in subtropical China.
   Future studies should incorporate climate change scenarios and land-use
   dynamics to evaluate long-term impacts on erosion processes and
   management effectiveness.},
Type = {Article; Early Access},
Affiliation = {Zhang, SH (Corresponding Author), Chinese Univ Hong Kong, Inst Space \& Earth Informat Sci, Ma Liu Shui 999077, Peoples R China.
   Zhang, Shihao, Chinese Univ Hong Kong, Inst Space \& Earth Informat Sci, Ma Liu Shui 999077, Peoples R China.},
DOI = {10.1007/s42729-026-03111-0},
EarlyAccessDate = {FEB 2026},
Keywords = {Random forest; Spatial prediction; Systematic-random design; USLE model},
Keywords-Plus = {LAND-COVER; DEGRADATION; RUNOFF},
Author-Email = {1155198726@link.cuhk.edu.hk},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001696063600001},
}

@article{ WOS:001693705700001,
Author = {Razavi-Termeh, Seyed Vahid and Sadeghi-Niaraki, Abolghasem and Pirasteh,
   Saied and Liu, Lingbo and Bao, Shuming and Choi, Soo-Mi},
Title = {Optimizing spatial prediction of land subsidence through synergized
   non-parametric machine learning and swarm-based metaheuristic algorithms},
Journal = {ENVIRONMENTAL AND ECOLOGICAL STATISTICS},
Year = {2026},
Volume = {33},
Number = {1},
Pages = {273-305},
Month = {MAR},
Abstract = {Land subsidence in arid and semi-arid regions has intensified due to
   severe water shortages and prolonged droughts, threatening
   infrastructure, agriculture, and communities. Accurate prediction and
   mapping of land subsidence-prone areas are essential for effective
   management and targeted mitigation efforts to reduce potential damage.
   Traditional parametric models often fail to accurately capture the
   complex, nonlinear relationships among the factors contributing to land
   subsidence. This study introduces an innovative approach to address
   these limitations by integrating a non-parametric machine learning
   algorithm {[}Decision Tree (DT)] with advanced swarm-based metaheuristic
   algorithms (Artificial Bee Colony (ABC), Jaya Algorithm (JA), and
   Bacterial Foraging Optimization (BFO)). Specifically, we developed
   DT-ABC, DT-JA, and DT-BFO models to generate Land Subsidence
   Susceptibility Maps (LSSM) for Kurdistan Province, Iran. Interferometric
   Synthetic Aperture Radar (InSAR) images were utilized to monitor
   subsidence, and 15 spatial factors influencing land subsidence were
   incorporated into the models. The DT-ABC model demonstrated the highest
   accuracy with an Area Under the ROC Curve (AUC) of 0.91, a Coefficient
   of Determination (R2) of 0.682, a Mean Absolute Error (MAE) of 0.124,
   and a Root Mean Square Error (RMSE) of 0.281, outperforming the DT-BFO
   model, which had an AUC of 0.90, a R2 of 0.635, a MAE of 0.126, and a
   RMSE of 0.301, and the DT-JA model, which had an AUC of 0.895, a R2 of
   0.629, a MAE of 0.131, and a RMSE of 0.304. These results highlight the
   effectiveness of combining non-parametric machine learning with
   metaheuristic optimization for enhancing the spatial prediction of land
   subsidence, providing a valuable tool for risk management in
   subsidence-prone regions.},
