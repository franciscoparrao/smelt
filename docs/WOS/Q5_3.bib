Keywords = {Skyscraper; Deep learning; Wind-induced response; Wind load; Data-driven
   machine learning; Structural health monitoring},
Keywords-Plus = {SUPER-TALL BUILDINGS; MODAL IDENTIFICATION; PERFORMANCE; MODEL},
Author-Email = {zhangqilin@tongji.edu.cn},
