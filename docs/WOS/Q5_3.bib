   Dias, Kaio O. G., Univ Fed Vicosa, Dept Gen Biol, Vicosa, MG, Brazil.
   Dias, Kaio O. G., Univ Fed Vicosa, Inst Artificial \& Computat Intelligence IDATA, Vicosa, MG, Brazil.},
DOI = {10.1038/s41598-025-21882-x},
