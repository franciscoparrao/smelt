   Aravind, P. V., Delft Univ Technol, Fac Mech Maritime \& Mat Engn, Dept Proc \& Energy, Leeghwaterstr 39, NL-2628 CB Delft, Netherlands.},
DOI = {10.1016/j.ecolind.2024.112654},
