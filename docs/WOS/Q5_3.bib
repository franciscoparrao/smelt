   Zhang, Xiaoyuan, Beijing Technol \& Business Univ, Business Sch, Beijing 100048, Peoples R China.},
DOI = {10.1109/JSTARS.2025.3597914},
Keywords = {Soil; Predictive models; Biological system modeling; Accuracy;
