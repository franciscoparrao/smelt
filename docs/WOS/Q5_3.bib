Unique-ID = {WOS:000834820800001},
}

@article{ WOS:000829173300024,
Author = {Manfredi, Paolo and Trinchero, Riccardo},
Title = {A Probabilistic Machine Learning Approach for the Uncertainty
   Quantification of Electronic Circuits Based on Gaussian Process
   Regression},
Journal = {IEEE TRANSACTIONS ON COMPUTER-AIDED DESIGN OF INTEGRATED CIRCUITS AND
   SYSTEMS},
Year = {2022},
Volume = {41},
Number = {8},
Pages = {2638-2651},
Month = {AUG},
Abstract = {This article introduces a probabilistic machine learning framework for
   the uncertainty quantification (UQ) of electronic circuits based on the
   Gaussian process regression (GPR). As opposed to classical surrogate
   modeling techniques, GPR inherently provides information on the model
   uncertainty. The main contribution of this work is twofold. First, it
   describes how, in a UQ scenario, the model uncertainty can be combined
   with the uncertainty of the input design parameters to provide
   confidence bounds for the statistical estimates of the system outputs,
   such as moments and probability distributions. These confidence bounds
   allow assessing the accuracy of the predicted statistics. Second, in
   order to deal with dynamic multioutput systems, principal component
   analysis (PCA) is effectively employed to compress the time-dependent
   output variables into a smaller set of components, for which the
   training of individual GPR models becomes feasible. The uncertainty on
   the principal components is then propagated back to the original output
   variables. Several application examples, ranging from a trivial RLC
   circuit to real-life designs, are used to illustrate and validate the
   advocated approach.},
Type = {Article},
Affiliation = {Manfredi, P (Corresponding Author), Politecn Torino, Dept Elect \& Telecommun, I-10129 Turin, Italy.
   Manfredi, Paolo; Trinchero, Riccardo, Politecn Torino, Dept Elect \& Telecommun, I-10129 Turin, Italy.},
DOI = {10.1109/TCAD.2021.3112138},
Keywords = {Uncertainty; Computational modeling; Integrated circuit modeling; Data
   models; Training; Principal component analysis; Market research;
   Gaussian process regression (GPR); machine learning; principal component
   analysis (PCA); probability; statistical analysis; stochastic processes;
   surrogate modeling; uncertainty quantification (UQ)},
Keywords-Plus = {POLYNOMIAL-CHAOS; KRIGING SURROGATES; YIELD ANALYSIS; MONTE-CARLO;
   EFFICIENT; OPTIMIZATION; VARIABILITY; PREDICTION; POWER; PERFORMANCE},
Author-Email = {paolo.manfredi@polito.it
   riccardo.trinchero@polito.it},
Number-of-Cited-References = {75},
Times-Cited = {32},
Unique-ID = {WOS:000829173300024},
}

