   Scholten, Thomas, Univ Tubingen, Fac Sci, Dept Geosci, Chair Soil Sci \& Geomorphol,Soil Sci \& Geoecol La, Tubingen, Germany.},
DOI = {10.1002/jpln.202200239},
EarlyAccessDate = {NOV 2022},
Keywords = {coevolution; dynamics; solid phase; virtual soil},
