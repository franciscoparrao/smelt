}

@article{ WOS:001721499500001,
Author = {Duah, Kinspride and Sun, Yan and Moussa, Maha},
Title = {A random quantile approach for prior covariance estimation in Bayesian
   Maximum Entropy},
Journal = {SPATIAL STATISTICS},
Year = {2026},
Volume = {73},
Month = {JUN},
Abstract = {Spatial prediction in environmental and geophysical applications is
   frequently hindered by heterogeneous and imprecise data, particularly
   when observations are available only as ranges rather than exact values.
   The Bayesian Maximum Entropy (BME) framework provides a rigorous basis
   for integrating hard and soft data, yet conventional implementations
   typically rely on midpoint representations of soft intervals and
   covariance structures derived solely from hard data, which can
   mischaracterize distributional asymmetry and uncertainty. To address
   this limitation, we propose a quantile-based covariance method within
   the BME framework, referred to as Quantile-based BME (QBME). The
   proposed method models the underlying unknown value of each soft
   observation as a latent quantile within its interval, discretizes the
   interval into multiple quantile levels, and constructs an ensemble of
   variograms from hybrid datasets. The performance of QBME is evaluated
   using comprehensive simulations under various distribution and variogram
   designs and through a case study on snow water equivalent (SWE)
   prediction across Montana. Results show that QBME consistently
   outperforms conventional BME (CBME) in terms of root mean squared error
   (RMSE), mean average error (MAE), and explanatory power, particularly in
   settings characterized by skewness, heavy tails, and higher degrees of
   uncertainty. The proposed framework extends BME by providing a
   principled treatment of soft-data uncertainty and offers a foundation
   for future developments in nonstationary and spatiotemporal modeling.},
Type = {Article},
Affiliation = {Duah, K (Corresponding Author), Utah State Univ, Math \& Stat, Logan, UT 84322 USA.
   Duah, Kinspride; Sun, Yan; Moussa, Maha, Utah State Univ, Math \& Stat, Logan, UT 84322 USA.},
DOI = {10.1016/j.spasta.2026.100974},
Article-Number = {100974},
Keywords = {Soft-interval data; Hard data; Uncertainty; Quantile; Variogram},
Keywords-Plus = {PATTERNS; MODEL},
Author-Email = {kinspride.duah@usu.edu},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001721499500001},
}

@article{ WOS:001713201300001,
Author = {Wen, Ying and Li, Jiahui and Zhang, Gaosen and Wang, Xufeng and Chen,
   Tuo and Zhang, Wei and Liu, Guangxiu},
Title = {Environmental controls and spatiotemporal patterns of bacterial
   diversity across China's desert ecosystems},
Journal = {CATENA},
Year = {2026},
Volume = {267},
Month = {JUN 1},
Abstract = {Arid ecosystems are subject to extreme and persistent environmental
   stress, yet the mechanisms underlying their structural stability and
   functional persistence under global change remain poorly understood.
   Although rigorous study on the geographical distribution patterns of
   microbial communities and their climate-driven mechanisms under climate
   change is still lacking, deserts play a critical role in global
   biogeochemical cycles. This study integrates field-collected samples
   with publicly available sequencing data, using machine learning based
   spatial prediction techniques to investigate the environmental
   regulation mechanisms of microbial community structure and functional
   characteristics across multiple deserts. By integrating these maps with
   future climate scenarios, we assess the potential impacts of
   environmental change and human activities on microbial distribution
   dynamics. Results indicate that desert microbial ecosystems are
   primarily shaped by deterministic environmental constraints rather than
   spatial succession. Aridity index, precipitation, temperature, and
   vegetation cover exert the strongest influence on desert bacterial
   species richness and functional diversity. Under the SSP245 scenario,
   microbial diversity and richness are projected to decline by 2.7\%,
   while phylogenetic diversity is expected to increase by approximately
   1.6\% by 2030, 2050, and 2100. In contrast, the SSP585 scenario shows
   diversity and abundance increasing until 2050, followed by a decline by
   2100, with Shannon diversity decreasing by 4.3\% and phylogenetic
   diversity fluctuating within +/- 3.6\% of current values. This study
   establishes a comprehensive baseline for the spatial distribution and
   ecological functions of desert microbial communities, thereby improving
   predictions of arid ecosystem responses to future climate change and
   degradation, and highlighting the role of desert microbes in climate
   feedbacks as well as ecosystem resilience under ongoing global warming
   and desertification.},
Type = {Article},
Affiliation = {Zhang, W (Corresponding Author), Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, State Key Lab Ecol Safety \& Sustainable Dev Arid L, Donggang West Rd 320, Lanzhou 730000, Peoples R China.
   Wen, Ying; Zhang, Gaosen; Zhang, Wei; Liu, Guangxiu, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, State Key Lab Ecol Safety \& Sustainable Dev Arid L, Donggang West Rd 320, Lanzhou 730000, Peoples R China.
   Wen, Ying, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, Natl Cryosphere Desert Data Ctr, Lanzhou 730000, Peoples R China.
   Wen, Ying; Li, Jiahui; Zhang, Gaosen; Chen, Tuo; Zhang, Wei; Liu, Guangxiu, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, Key Lab Extreme Environm Microbial Resources \& Eng, Lanzhou 730000, Peoples R China.
   Wang, Xufeng, Chinese Acad Sci, Cold \& Arid Reg Environm \& Engn Res Inst, Key Lab Remote Sensing Gansu Prov, Heihe Remote Sensing Expt Res Stn, Lanzhou 730000, Peoples R China.
   Chen, Tuo, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, State Key Lab Cryospher Sci \& Frozen Soil Engn, Lanzhou 730000, Peoples R China.},
DOI = {10.1016/j.catena.2026.109974},
Article-Number = {109974},
Keywords = {Desert ecosystems; Bacteria biogeography; Climate change; Community
   function; Extreme aridity; SSP scenarios},
