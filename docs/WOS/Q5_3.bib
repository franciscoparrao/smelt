}

@incollection{ WOS:001190737300074,
Author = {Karaman, C. H. and Akyurek, Z.},
Editor = {Altan, O and Sunar, F and Klein, D},
Title = {IMPROVING THE ACCURACY OF SATELLITE-BASED NEAR SURFACE AIR TEMPERATURE
   AND PRECIPITATION PRODUCTS},
Booktitle = {39TH INTERNATIONAL SYMPOSIUM ON REMOTE SENSING OF ENVIRONMENT ISRSE-39
   FROM HUMAN NEEDS TO SDGS, VOL. 48-M-1},
Series = {International Archives of the Photogrammetry, Remote Sensing and Spatial
   Information Sciences},
Year = {2023},
Pages = {537-545},
Abstract = {In this study, we evaluate the performance of several reanalyses and
   satellite-based products of near-surface air temperature and
   precipitation to determine the best product in estimating daily and
   monthly variables across the complex terrain of Turkey. Each product's
   performance was evaluated using 1120 ground-based gauge stations from
   2015 to 2019, covering a range of complex topography with different
   climate classes according to the Koppen-Geiger classification scheme and
   land surface types according to the Moderate Resolution Imaging
   Spectroradiometer (MODIS). Furthermore, various traditional and more
   advanced machine learning downscaling algorithms were applied to improve
   the spatial resolution of the products. We used distance-based
   interpolation, classical Random Forest, and more innovative Random
   Forest Spatial Interpolation (RFSI) algorithms. We also investigated
   several satellite-based covariates as a proxy to downscale the
   precipitation and near-surface air temperature, including MODIS Land
   Surface Temperature, Vegetation Index (NDVI and EVI), Cloud Properties
   (Cloud Optical Properties, Cloud Effective Radius, Cloud Water Path),
   and topography-related features. The agreement between the ground
   observations and the different products, as well as the downscaled
   temperature products, was examined using a range of commonly employed
   measures. The results showed that AgERA5 was the best-performing product
   for air temperature estimation, while MSWEP V2.2 was superior for
   precipitation estimation. Spatial downscaling using bicubic
   interpolation improved air temperature product performance, and the
   Random Forest (RF) machine learning algorithm outperformed all other
   methods in certain seasons. The study suggests that combining
   ground-based measurements, precipitation products, and features related
   to topography can substantially improve the representation of
   spatiotemporal precipitation distribution in data-scarce regions.},
Type = {Proceedings Paper},
Affiliation = {Karaman, ÇH (Corresponding Author), METU, Geodet \& Geog Informat Technol, Nat \& Appl Sci, TR-06800 Ankara, Turkiye.
   Karaman, C. H.; Akyurek, Z., METU, Geodet \& Geog Informat Technol, Nat \& Appl Sci, TR-06800 Ankara, Turkiye.
   Akyurek, Z., METU, Civil Eng Dept, TR-06800 Ankara, Turkiye.},
DOI = {10.5194/isprs-archives-XLVIII-M-1-2023-537-2023},
Keywords = {Near-Surface Air Temperature; Precipitation; Satellite; Downscaling;
   Machine Learning},
Keywords-Plus = {REGRESSION},
Author-Email = {cagri.karaman@metu.edu.tr
   zakyurek@metu.edu.tr},
Number-of-Cited-References = {26},
Times-Cited = {1},
Unique-ID = {WOS:001190737300074},
}

@incollection{ WOS:001190705600010,
Author = {Zhu, Jiahui and Yan, Sijie and Yang, Zeyuan and Cai, Wenqi and Ding, Han},
Book-Group-Author = {IEEE},
Title = {Robotic Positional Error Calibration Based on a Hybrid Data-driven
   Prediction Framework},
Booktitle = {2023 29TH INTERNATIONAL CONFERENCE ON MECHATRONICS AND MACHINE VISION IN
   PRACTICE, M2VIP 2023},
Series = {International Conference on Mechatronics and Machine Vision in Practice},
Year = {2023},
Abstract = {This paper introduces a hybrid compensation method for mitigating robot
   end position error. Initially, the XGBoost machine learning model,
   supervised based on physical insights, and a spatial interpolation model
   that leverages error similarity are employed to predict errors along
   each axis, forming the physics-data driven layer. Subsequently, the loss
   function for the Neural Network with the Constrained Neural Network
   Stacking (CNNS) approach is constructed using the predictions of
   physics-data driven layer. This neural network then carries out the
   ultimate prediction, forming the ultimate prediction layer. Validation
   is conducted using the UR10 robot, the absolute mean/maximum positioning
   errors are decreased from 4.740/9.421 mm to 0.748/1.470 mm after
   compensation.},
Type = {Proceedings Paper},
Affiliation = {Zhu, JH (Corresponding Author), Huazhong Univ Sci \& Technol, Dept Mech Sci \& Engn, State Key Lab Intelligent Intelligent Mfg Equipme, Wuhan, Peoples R China.
   Zhu, Jiahui; Yan, Sijie; Yang, Zeyuan; Cai, Wenqi; Ding, Han, Huazhong Univ Sci \& Technol, Dept Mech Sci \& Engn, State Key Lab Intelligent Intelligent Mfg Equipme, Wuhan, Peoples R China.},
DOI = {10.1109/M2VIP58386.2023.10413374},
Keywords = {robot calibration; error compensation; hybrid prediction},
Author-Email = {3484502546@qq.com
   sjyan@hust.edu.cn
   yangzeyuan@hust.edu.cn
   kyle9478@hust.edu.cn
   dinghan@hust.edu.cn},
