Times-Cited = {2},
Unique-ID = {WOS:001464291400001},
}

@article{ WOS:001459793100001,
Author = {Zhang, Yuxi and Wimalathunge, Niranjan and Haan, Sebastian and Wang, Jie
   and Zou, Xinglong and Bishop, Thomas},
Title = {High spatio-temporal resolution soil moisture nowcasting at multiple
   depths with data-driven approaches},
Journal = {AGRICULTURAL WATER MANAGEMENT},
Year = {2025},
Volume = {312},
Month = {MAY 1},
Abstract = {Soil moisture nowcasting provides valuable information for site-specific
   management in dryland cropping systems. The increasing publicly
   available data streams have made it possible to capture soil moisture
   across the profile at fine spatiotemporal resolution. While many studies
   have applied data-driven approaches, they are generally limited to
   moderate to coarse spatial resolution and focus on the soil surface.
   This study investigated the importance of water-related features and
   showcased a data-driven practice that integrate multi-source
   water-related data streams for high-resolution soil moisture nowcasting
   (< 100 m, daily) throughout the soil profile. The models were evaluated
   with a series of cross-validation experiments, including spatial
   interpolation, temporal prediction, spatio-temporal prediction,
   gap-filling and spatial extrapolation. The best performance was observed
   in the Adelong Creek catchment using RF, with ubRMSE= 0.051 m(3)/m(3),
   R= 0.85, and LCCC= 0.82 for spatial interpolation; ubRMSE= 0.041
   m(3)/m(3), R= 0.89, and LCCC= 0.89 for temporal prediction; ubRMSE=
   0.051 m(3)/m(3), R= 0.85, and LCCC= 0.72 for spatio-temporal prediction;
   and ubRMSE= 0.062 m(3)/m(3), R= 0.76, and LCCC= 0.73 for spatial
   extrapolation. Additionally, XGBoost achieved the best performance for
   gap-filling, with ubRMSE= 0.025 m(3)/m(3), R= 0.96, and LCCC= 0.96. Our
   work has the potential to provide an information platform for growers to
   monitor and understand soil moisture at fine resolution in the future.},
Type = {Article},
Affiliation = {Zhang, YX (Corresponding Author), Univ Sydney, Sydney Inst Agr, Sch Life \& Environm Sci, Eveleigh, NSW 2015, Australia.
   Zhang, Yuxi; Wimalathunge, Niranjan; Wang, Jie; Zou, Xinglong; Bishop, Thomas, Univ Sydney, Sydney Inst Agr, Sch Life \& Environm Sci, Eveleigh, NSW 2015, Australia.
   Haan, Sebastian; Bishop, Thomas, Univ Sydney, Sydney Informat Hub, Camperdown, NSW 2050, Australia.},
DOI = {10.1016/j.agwat.2025.109457},
EarlyAccessDate = {MAR 2025},
Article-Number = {109457},
Keywords = {Soil moisture nowcasting; Data-driven models; Machine learning; Fine
   resolution; Spatiotemporal mapping},
Keywords-Plus = {DATA ASSIMILATION; PRODUCT},
Author-Email = {yuxi.zhang@sydney.edu.au},
Number-of-Cited-References = {61},
Times-Cited = {0},
Unique-ID = {WOS:001459793100001},
}

@article{ WOS:001459267100001,
Author = {Peshkov, Georgy and Khemraev, Kerim and Safonov, Sergey and Bukhanov,
   Nikita and Alali, Ammar and Abughaban, Mahmoud},
Title = {Predicting mud weight in carbonate formations using seismic data: A
   data-driven approach},
Journal = {GEOENERGY SCIENCE AND ENGINEERING},
Year = {2025},
Volume = {250},
Month = {JUL},
Abstract = {Accurate mud weight prediction is crucial for safe and efficient
   drilling operations in overpressured formations. Especially. Traditional
   approaches heavily rely on manual seismic interpretation, which is
   limited by data noise and high dimensionality, and the need for well log
   data. This study aims to address these challenges by integrating
   advanced machine learning techniques with seismic and mud weight data,
   focusing on developing an automated, data-driven workflow that can
   reliably predict appropriate mud weight trends across large-scale
   geological fields. The methodology employs a neural network (NN)
   autoencoder for seismic dimensionality reduction, retaining critical
   geological features in latent layers. Optimized input features are
   selected using statistical and interpretability-driven techniques. A
   k-nearest neighbors model, tuned through grid search, serves as the
   predictive core, with kriging applied to refine spatial predictions and
   reduce errors. The approach demonstrates improved geological
   interpretability and accuracy compared to conventional methods. Applied
   to a large carbonate field, the workflow effectively predicts spatial
   mud weight variations, highlighting its scalability and reliability. By
   combining autoencoding, feature selection, and geostatistical
   refinement, this methodology offers a robust and interpretable framework
   for tackling complex geological challenges in drilling operations.},
Type = {Article},
Affiliation = {Peshkov, G (Corresponding Author), Aramco Innovat, Moscow 117105, Russia.
   Peshkov, Georgy; Khemraev, Kerim; Safonov, Sergey, Aramco Innovat, Moscow 117105, Russia.
   Bukhanov, Nikita; Alali, Ammar; Abughaban, Mahmoud, Saudi Aramco, POB 13765, Dhahran 31311, Saudi Arabia.},
DOI = {10.1016/j.geoen.2025.213850},
EarlyAccessDate = {MAR 2025},
Article-Number = {213850},
Keywords = {Overpressure; Drilling mud weight; Seismic; Autoencoder; Latent space;
   Machine learning},
Keywords-Plus = {PORE PRESSURE; SEA; GENERATION; MECHANISMS; VELOCITY; STRESS; CHALK},
Author-Email = {peshkovg@ya.ru},
Number-of-Cited-References = {46},
Times-Cited = {3},
Unique-ID = {WOS:001459267100001},
}

@article{ WOS:001454168800001,
Author = {Guo, Zhenxi and Li, Kewen and Zhang, Han and Gu, Chao and He, Jifu},
Title = {Predicting Geothermal Heat Flow in the Bohai Bay Basin Based on Machine
   Learning Methods},
Journal = {MATHEMATICAL GEOSCIENCES},
Year = {2025},
Month = {2025 MAR 26},
Abstract = {Geothermal heat flow (GHF) is a critical parameter for understanding the
   geothermal gradient, rock thermal conductivity, radiogenic heat
   generation, and heat transfer from both the crust and mantle. It plays a
   key role in identifying and assessing potential geothermal resources. In
   the Bohai Bay Basin, the available GHF measurements are sparse and
   unevenly distributed. Consequently, the GHF maps generated through
   conventional interpolation techniques often lack accuracy, particularly
   in regions with limited data. In this paper, we developed and trained a
   specific gradient boosting regression tree (GBRT) model with advanced
   machine learning technology to predict the GHF of the Bohai Bay Basin in
   China. Unlike previous models that relied on limited features and
   datasets, this study integrates a wider range of geological and
   geophysical features (GGF), utilizing a substantially larger dataset to
   develop a more robust predictive GBRT model. We compared three GBRT
   models and found the best one. Specifically, we selected 16 key GGFs and
   utilized a global GHF dataset to develop GBRT models. To investigate the
   impact of different GGFs on the model's predictive performance, we
   conducted feature removal experiments by evaluating the contribution of
   each feature to the overall accuracy of the GBRT model in predicting
   GHF. The GBRT model's performance was evaluated under three
   considerations: Model I, based on the global dataset excluding the Bohai
   Bay Basin (R-2 = 79.7\%, MAE = 7.43, and RMSE = 11.69); Model II, using
   the global dataset with 50\% inclusion of the Bohai Bay Basin (R-2 =
   81.3\%, MAE = 7.20, and RMSE = 10.92); and Model III, utilizing the full
   global dataset including the Bohai Bay Basin (R-2 = 80.5\%, MAE = 7.22,
   and RMSE = 11.11). This study demonstrates the advantages of machine
   learning techniques over traditional kriging interpolation methods for
   predicting GHF distribution: the R-2 improved by 212\%, the MAE
   decreased by approximately 18.9\%, and the RMSE reduced by about 23.9\%.
   We updated the GHF map of the Bohai Bay Basin with the predicted data.
   Importantly, we discovered new geothermal sweet spots with high GHF,
   providing useful guidelines and clear targets for geothermal resource
   exploration in the Bohai Bay Basin.},
Type = {Article; Early Access},
Affiliation = {Li, KW (Corresponding Author), China Univ Geosci Beijing, Sch Energy Resources, Beijing 100083, Peoples R China.
   Li, KW (Corresponding Author), Beijing Key Lab Unconvent Nat Gas Geol Evaluat \& D, Beijing 100083, Peoples R China.
   Guo, Zhenxi; Li, Kewen; He, Jifu, China Univ Geosci Beijing, Sch Energy Resources, Beijing 100083, Peoples R China.
   Guo, Zhenxi; Li, Kewen; He, Jifu, Beijing Key Lab Unconvent Nat Gas Geol Evaluat \& D, Beijing 100083, Peoples R China.
   Zhang, Han; Gu, Chao, Henan Acad Geol, Zhengzhou 450016, Henan, Peoples R China.},
DOI = {10.1007/s11004-025-10182-9},
EarlyAccessDate = {MAR 2025},
Keywords = {Machine learning; Gradient boosted regression trees; Geothermal heat
   flow; Bohai Bay Basin},
Keywords-Plus = {CHINA; MODEL},
Author-Email = {likewen1268@163.com},
Number-of-Cited-References = {32},
Times-Cited = {2},
Unique-ID = {WOS:001454168800001},
}

@article{ WOS:001474990000001,
Author = {Zhang, Lei and Yang, Liu and Sun, Jinhua and Zhu, Qimeng and Wang, Ting
   and Zhao, Hui},
Title = {Estimation of Tree Species Diversity in Warm Temperate Forests via GEDI
   and GF-1 Imagery},
Journal = {FORESTS},
Year = {2025},
Volume = {16},
Number = {4},
Month = {MAR 25},
Abstract = {Estimates of tree species diversity via traditional optical remote
   sensing are based only on the spectral variation hypothesis (SVH);
   however, this approach does not account for the vertical structure of a
   forest. The relative height (RH) indices derived from GEDI spaceborne
   LiDAR provide vertical vegetation structure information through waveform
   decomposition. Although RH indices have been widely studied, the optimal
   RH index for tree species diversity estimation remains unclear. This
   study integrated GF-1 optical imagery and GEDI LiDAR data to estimate
   tree species diversity in a warm temperate forest. First, random forest
   plus residual kriging (RFRK) was employed to achieve wall-to-wall
   mapping of the GEDI-derived indices. Second, recursive feature
   elimination (RFE) was applied to select relevant spectral and LiDAR
   features. The random forest (RF), support vector machine (SVM), and
   k-nearest neighbor (kNN) methods were subsequently applied to estimate
   tree species diversity through remote sensing data. The results
   indicated that multisource data achieved greater accuracy in tree
   species diversity estimation (average R2 = 0.675, average RMSE = 0.750)
   than single-source data (average R2 = 0.636, average RMSE = 0.754).
   Among the three machine learning methods, the RF model (R2 = 0.760, RMSE
   = 2.090, MAE = 1.624) was significantly more accurate than the SVM (R2 =
   0.571, RMSE = 2.556, MAE = 1.995) and kNN (R2 = 0.715, RMSE = 2.084, MAE
   = 1.555) models. Moreover, mean\_mNDVI, mean\_RDVI, and mean\_Blue were
   identified as the most important spectral features, whereas RH30 and
   RH98 were crucial features derived from LiDAR for establishing models of
   tree species diversity. Spatially, tree species diversity was high in
   the west and low in the east in the study area. This study highlights
   the potential of integrating optical imagery and spaceborne LiDAR for
   tree species diversity modeling and emphasizes that low RH indices are
   most indicative of middle- to lower-canopy tree species diversity.},
Type = {Article},
Affiliation = {Yang, L (Corresponding Author), Henan Agr Univ, Coll Forestry, Zhengzhou 450046, Peoples R China.
   Zhang, Lei; Yang, Liu; Sun, Jinhua; Zhu, Qimeng; Wang, Ting, Henan Agr Univ, Coll Forestry, Zhengzhou 450046, Peoples R China.
   Zhao, Hui, Henan Acad Agr Sci, Zhengzhou 450008, Peoples R China.
   Zhao, Hui, Henan Yuzhou Forest Ecosyst Natl Positioning Obser, Yuzhou 461670, Peoples R China.},
DOI = {10.3390/f16040570},
Article-Number = {570},
Keywords = {forest; diversity index; spectral image; LiDAR; machine learning},
Keywords-Plus = {SUPPORT VECTOR MACHINE; LEAF PIGMENT CONTENT; VEGETATION INDEXES; GLOBAL
   VEGETATION; REMOTE; CLASSIFICATION; BIODIVERSITY; HEIGHT; REFLECTANCE;
