@article{ WOS:001625806100001,
Author = {Pirunjinda, Sanan and Jongpradist, Pornkasem and Ryu, Dong-Woo and
   Inoue, Junya and Yazdani, Mahmoud and Kim, Hyung-Mok},
Title = {Ground subsidence hazard evaluation in large reclaimed area using
   unsupervised machine learning with parameter estimation and spatial
   interpolation},
Journal = {ENGINEERING GEOLOGY},
Year = {2026},
Volume = {360},
Month = {JAN},
Abstract = {Land reclamation areas are inherently prone to long-term settlement due
   to the consolidation of underlying compressible soils. Reliable
   assessment of ground subsidence hazard is therefore essential for
   ensuring stability and mitigating potential hazards. Traditionally,
   borehole sampling and field tests conducted at discrete locations serve
   as the primary means of evaluating consolidation settlement. However,
   these datasets are often limited due to project constraints. As field
   measurements become more abundant in later stages of reclamation, they
   can be utilized to obtain soil parameter estimation beyond boreholes and
   test locations. This study presents a unified framework for developing a
   ground subsidence hazard map based on field settlement measurements. The
   proposed methodology integrates parameter estimation, spatial
   interpolation, and hazard evaluation, providing a systematic approach to
   subsidence hazard assessment. Machine learning techniques are
   incorporated to improve accuracy and efficiency. The resulting hazard
   map provides a clear and comprehensive visualization of subsidence
   hazards by integrating multiple influencing factors. This approach
   offers a systematic and data-driven method for assessing ground
   subsidence hazard, supporting better decision-making in land reclamation
   projects.},
Type = {Article},
Affiliation = {Kim, HM (Corresponding Author), Sejong Univ, Coll Engn, Dept Energy Resources \& Geosyst Engn, Seoul 05006, South Korea.
   Pirunjinda, Sanan; Kim, Hyung-Mok, Sejong Univ, Coll Engn, Dept Energy Resources \& Geosyst Engn, Seoul 05006, South Korea.
