   Samadzamini, Karim, Univ Coll Nabi Akram, Dept Comp Engn, Tabriz 5183918993, Iran.},
DOI = {10.1007/s12518-023-00488-w},
EarlyAccessDate = {JAN 2023},
Keywords = {Landslide susceptibility; Random forest; Support vector machine;
   Multiple layer neural network},
Keywords-Plus = {ANALYTICAL HIERARCHY PROCESS; SUPPORT VECTOR MACHINES; EVIDENTIAL BELIEF
