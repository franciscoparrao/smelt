   Liu, Liming, Hubei Prov Land \& Resources Informat Ctr, Geol Bur Hubei Prov, 27 Gongzheng Rd, Wuhan 430071, Peoples R China.},
DOI = {10.31545/intagr/206078},
Keywords = {carbon sequestration; dryland soils; geospatial analysis; predictive
   modeling; sustainable agriculture},
