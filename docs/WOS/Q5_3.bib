   Chen, Zhen-Song, Wuhan Univ, Sch Civil Engn, Wuhan 430072, Peoples R China.
   Qin, Yawei, Wuhan Huazhong Univ Sci \& Technol Testing Technol, Wuhan 430074, Hubei, Peoples R China.},
DOI = {10.1016/j.conbuildmat.2022.129232},
