   Rinnert, Alexander; Hanneken, Jessica, BFS Hlth Finance, Healthcare \& Polit, Dortmund, Germany.
   Johansson, Tim, SAGES, Salzburg Reg Hlth Fund, Salzburg, Austria.},
DOI = {10.1186/s12903-024-03897-4},
Article-Number = {205},
