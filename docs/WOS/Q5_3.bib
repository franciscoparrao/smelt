DOI = {10.1016/j.asoc.2023.110846},
EarlyAccessDate = {SEP 2023},
Article-Number = {110846},
Keywords = {Flood susceptibility mapping; AutoML; Convolutional neural network; HPO;
   Bayesian optimization; Kerala},
Keywords-Plus = {SPATIAL PREDICTION; REGION; RISK; INUNDATION; IMAGERY; MODELS; AREAS;
   BASIN; CITY},
Author-Email = {amalamaryvincent@gmail.com},
