DOI = {10.1016/j.rineng.2026.109519},
Article-Number = {109519},
Keywords = {PEMFC; Machine learning; Systematic literature review; Surrogate models;
   Single/multi-objective flow field optimization},
Keywords-Plus = {CHANNEL DESIGN; GEOMETRY OPTIMIZATION; NUMERICAL-ANALYSIS; BIPOLAR
   PLATE; MASS-TRANSFER; PEMFC; MODEL; SIMULATION; PREDICTION; SERPENTINE},
Author-Email = {arbypratamax6@gmail.com
   irfan@mat-eng.its.ac.id},
