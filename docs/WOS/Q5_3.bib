@article{ WOS:001680310500001,
Author = {Elboghdady, Rahma and El-Zehairy, Amr and Omara, Hewida and Nassar,
   Karim},
Title = {Spatiotemporal analysis and prediction of shoreline dynamics: A
   comparative study of machine learning and traditional forecasting
   approach},
Journal = {MARINE GEORESOURCES \& GEOTECHNOLOGY},
Year = {2026},
Month = {2026 FEB 1},
Abstract = {Understanding shoreline dynamics is critical for effective coastal
   management. This study analyzes the 1990-2024 evolution of Egypt's
   Damietta coastline using satellite imagery and the Digital Shoreline
   Analysis System (DSAS). Results show a dominant accretion trend, with a
   mean accretion rate of 3.0 m/year and mean erosion of -0.95 m/year,
   resulting in a net shoreline advance of 28.9 km. To evaluate predictive
   capability, a standard Kalman filter model was tested but showed limited
   accuracy for long-term forecasting, yielding a high error (RMSE =
   102.7). A significant improvement was achieved using a Long Short-Term
   Memory (LSTM) deep learning model, which combined historical shoreline
   data with hydrodynamic forcings (wave height, tidal range). The LSTM
   model demonstrated superior performance, reducing the RMSE by 92.78\%
   and achieving high accuracy (RMSE = 9.89, MAPE = 0.012) for the
   2020-2024 validation period. Its projection to 2044 identified 15
   distinct coastal sectors with divergent future erosion and accretion
   patterns. This research concludes that while geostatistical methods are
   useful for historical analysis, reliable long-term shoreline forecasting
   requires integrating physical processes into models. The LSTM's enhanced
   accuracy advocates a shift in coastal management from reactive planning
   to proactive, data-driven strategies based on dynamic, process-aware
   modeling for sustainable resilience.},
Type = {Article; Early Access},
Affiliation = {Nassar, K (Corresponding Author), Mansoura Univ, Fac Engn, Irrigat \& Hydraul Dept, Mansoura, Egypt.
   Elboghdady, Rahma, Damietta Univ, Fac Engn, Civil Engn Dept, Dumyate Elgedida, Egypt.
   El-Zehairy, Amr; Nassar, Karim, Mansoura Univ, Fac Engn, Irrigat \& Hydraul Dept, Mansoura, Egypt.
   Omara, Hewida, Tanta Univ, Fac Engn, Irrigat \& Hydraul Engn Dept, Tanta, Egypt.},
DOI = {10.1080/1064119X.2026.2626019},
EarlyAccessDate = {FEB 2026},
Keywords = {Shoreline change; coastal erosion; remote sensing; DSAS; LSTM networks;
   Kalman filter},
Keywords-Plus = {COAST},
Author-Email = {karim.nassar@ejust.edu.eg},
Number-of-Cited-References = {25},
Times-Cited = {0},
Unique-ID = {WOS:001680310500001},
}

@article{ WOS:001656975300001,
Author = {Pham, Hoa Thi and Awange, Joseph and Claessens, Sten and Kuhn, Michael},
Title = {Location-Specific Ensemble Kriging: New Approach for Local Hybrid
   Geoid-Quasigeoid Estimation},
Journal = {JOURNAL OF SURVEYING ENGINEERING},
Year = {2026},
Volume = {152},
Number = {1},
Month = {FEB 1},
Abstract = {Geostatistical methods have been employed to develop local hybrid geoid
   models. However, prior studies often overlooked the issue of
   covariance/variogram nonstationarity, potentially leading to
   underfitting or overfitting in different regions. Additionally, ensemble
   methods that combine multiple models have not yet been explored. Against
   this backdrop, this study introduces the location-specific ensemble
   kriging (LSEK) method, wherein a location-specific approach is
   consistently applied throughout both interpolation and ensemble
   modeling. Specifically, LSEK integrates both local and global
   optimization for kriging, focusing on improving the accuracy of the
   method, accounting for input data quality, and ensuring consistency
   between the real variance and the kriging variance. Furthermore, LSEK
   simultaneously optimizes both the variogram modeling and the kriging
   interpolation. Meanwhile, the ensemble strategy leverages the
   complementary strengths of data sources and variogram functions, further
   enhancing the overall accuracy and robustness of the model. The
   effectiveness of LSEK is demonstrated through case studies in Vietnam
   using gravimetric quasi-geoids and GNSS/leveling data with varied
   spatial complexities. Employing a traditional global method with a
   single variogram function as a benchmark, the results show that the
   location-specific approach significantly enhances estimation accuracy
   and offers a more realistic representation of the uncertainty. As
   spatial complexity increases, the advantages of the location-specific
   method become more pronounced, with some cases achieving up to a 45\%
   improvement. Meanwhile, the ensemble method consistently demonstrates
   enhanced accuracy and stability. The top 10 ensemble combinations yield
   small and consistent errors in both the training and testing phases,
   underscoring the robustness and adaptability of the LSEK approach.},
Type = {Article},
Affiliation = {Pham, HT (Corresponding Author), Curtin Univ, Sch Earth \& Planetary Sci, Spatial Sci Discipline, Perth, WA 6102, Australia.
   Pham, HT (Corresponding Author), Hanoi Univ Nat Resources \& Environm, Fac Surveying Mapping \& Geog Informat, Hanoi 100000, Vietnam.
   Pham, Hoa Thi; Claessens, Sten; Kuhn, Michael, Curtin Univ, Sch Earth \& Planetary Sci, Spatial Sci Discipline, Perth, WA 6102, Australia.
   Pham, Hoa Thi, Hanoi Univ Nat Resources \& Environm, Fac Surveying Mapping \& Geog Informat, Hanoi 100000, Vietnam.
   Awange, Joseph, Hong Kong Polytech Univ, Dept Land Surveying \& Geoinformat, Hong Kong, Peoples R China.},
DOI = {10.1061/JSUED2.SUENG-1598},
Article-Number = {04025020},
Keywords = {Geoid; Quasi-geoid; Variogram; Kriging; Nonstationary; Ensemble},
Keywords-Plus = {MODEL; PERFORMANCE; INTERPOLATION; GEOSTATISTICS; PREDICTION;
   VARIOGRAMS; GPS},
Author-Email = {thihoa.pham@curtin.edu.au
   joseph.awange@polyu.edu.hk
   S.Claessens@curtin.edu.au
   M.Kuhn@curtin.edu.au},
