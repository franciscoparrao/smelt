@article{ WOS:001499297600002,
Author = {Zhu, Zixu and Shi, Chenghua and Sun, Yingjie and Zheng, Keyue and Zhang,
   Jianan and Zhu, Tao and Shuai, Jianbing},
Title = {Augmented data-driven ensemble prediction and explainability analysis of
   shear adhesion strength at mixed clay-metal interfaces},
Journal = {MATERIALS LETTERS},
Year = {2025},
Volume = {396},
Month = {OCT 1},
Abstract = {Shear adhesion strength (SAS) serves as a critical indicator for
   evaluating clay-metal interface adhesion behaviours. This study develops
   an augmented data-driven ensemble prediction framework integrating SHAP
   explainability analysis to enable rapid SAS estimation while reducing
   experimental costs. Through 152 systematic SAS measurements under
   controlled types of clay mineralogy (TCM), consistency index (CI), clay
   content (CC), normal stress (NS), and rotation rate (RR), augmented
   ordinary Kriging method, which successfully characterized SAS peak
   features normal pressure/shear conditions. The Bayesian-optimized
   XGBoost model (5-fold cross-validation) demonstrated exceptional
   accuracy (R-2 > 0.985, RMSE < 2 kPa) validated by independent testing,
   with SHAP analysis revealing parameter importance as TCM (9.828) > CI
   (7.525) > NS (6.547) > CC (1.777) > RR (1.497), consistent with
   engineering principles. This study provides a cost-effective rapid
   analysis tool for predicting SAS of mixed clays with varying
   compositions under different pressure/shear conditions, offering
   technical guidance for engineering adhesion control.},
Type = {Article},
Affiliation = {Zheng, KY (Corresponding Author), Cent South Univ, Sch Civil Engn, Changsha 410075, Peoples R China.
   Zhu, Zixu; Shi, Chenghua; Zheng, Keyue; Zhu, Tao, Cent South Univ, Sch Civil Engn, Changsha 410075, Peoples R China.
   Sun, Yingjie, PowerChina ZhongNan Engn Corp Ltd, Changsha 410014, Peoples R China.
   Zhang, Jianan; Shuai, Jianbing, China Railway 12th Bur Grp Co Ltd, Taiyuan 030024, Peoples R China.},
DOI = {10.1016/j.matlet.2025.138796},
EarlyAccessDate = {MAY 2025},
Article-Number = {138796},
Keywords = {Mixed clay; Interface adhesion behaviours; Data augmentation technique;
   Machine learning; SHAP analysis},
Author-Email = {zkycsu@163.com},
Number-of-Cited-References = {11},
Times-Cited = {0},
Unique-ID = {WOS:001499297600002},
}

@article{ WOS:001498999100001,
Author = {Chen, Ruijun and Ren, Chao and Cai, Meng and Chen, Guangzhao and Liao,
   Cuiping and Huang, Ying and Liu, Zhen},
Title = {Integrating local climate zones and spatial modeling for carbon emission
   forecasting in the Guangdong-Hong Kong-Macao Greater Bay Area toward
   2060},
Journal = {URBAN CLIMATE},
Year = {2025},
Volume = {61},
Month = {JUN},
Abstract = {High-resolution and sector-specific spatial prediction of carbon
   emissions is essential for developing effective urban planning
   strategies to mitigate climate change. This study introduces an
   innovative approach by integrating the Local Climate Zone (LCZ) scheme
   and calculating landscape metrics indices as impact factors to enhance
   the spatial precision of carbon emission predictions. Using the
   Long-range Energy Alternatives Planning System (LEAP) model, enriched
   with machine learning and sector-specific analysis, this research
   predicts spatial carbon emissions in the Guangdong-Hong Kong-Macao
   Greater Bay Area (GBA) from 2020 to 2060 at a fine resolution of 500 m x
   500 m under the Business-As-Usual scenario. Results indicate a peak in
   emissions around 2030, followed by a targeted 22.7 \% reduction by 2060
   compared to 2020 levels. While a shift from coal to cleaner energy
   sources is evident, the increasing dependence on natural gas raises
   concerns. The study highlights that urban morphology, population
