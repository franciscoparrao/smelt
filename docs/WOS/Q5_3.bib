}

@article{ WOS:001117096800006,
Author = {Suleymanov, Azamat and Abakumov, Evgeny and Nizamutdinov, Timur and
   Polyakov, Vyacheslav and Shevchenko, Evgeny and Makarova, Maria},
Title = {Soil organic carbon stock retrieval from Sentinel-2A using a hybrid
   approach},
Journal = {ENVIRONMENTAL MONITORING AND ASSESSMENT},
Year = {2024},
Volume = {196},
Number = {1},
Month = {JAN},
Abstract = {Digital soil maps find application in numerous fields, making their
   accuracy a crucial factor. Mapping soil properties in homogeneous
   landscapes where the soil surface is concealed, as in forests, presents
   a complex challenge. In this study, we evaluated the spatial
   distribution of soil organic carbon stocks (SOCstock) under forest
   vegetation using three methods: regression kriging (RK), random forest
   (RF), and RF combined with ordinary kriging of residuals (RFOK) in
   combination with Sentinel-2A satellite data. We also compared their
   accuracies and identified key influencing factors. We determined that
   SOCstock ranged from 0.6 to 10.9 kg/m2 with an average value of 4.9
   kg/m2. Among the modelling approaches, we found that the RFOK exhibited
   the highest accuracy (RMSE = 1.58 kg/m2, NSE = 0.33), while the RK
   demonstrated a lack of spatial correlation of residuals, rendering this
   method inapplicable. An analysis of variable importance revealed that
   the SWIR B12 band of the Sentinel-2A satellite contributed the most to
   RFOK predictions. We concluded that the RFOK hybrid approach
   outperformed the others, potentially serving as a foundation for digital
   soil mapping under similar environmental conditions. Therefore, it is
   essential to consider spatial correlations when mapping soil properties
   in ecosystems that are inaccessible for capturing the spectral response
   of the soil surface.},
Type = {Article},
Affiliation = {Suleymanov, A (Corresponding Author), St Petersburg State Univ, Fac Biol, Dept Appl Ecol, St Petersburg 199034, Russia.
   Suleymanov, A (Corresponding Author), Ufa Univ Sci \& Technol, Dept Geodesy Cartog \& Geog Informat Syst, Ufa 450076, Russia.
   Suleymanov, Azamat; Abakumov, Evgeny; Nizamutdinov, Timur; Polyakov, Vyacheslav, St Petersburg State Univ, Fac Biol, Dept Appl Ecol, St Petersburg 199034, Russia.
   Suleymanov, Azamat, Ufa Univ Sci \& Technol, Dept Geodesy Cartog \& Geog Informat Syst, Ufa 450076, Russia.
   Shevchenko, Evgeny, St Petersburg State Univ, Ctr Diagnost Funct Mat Med Pharmacol \& Nanoelect, St Petersburg 199034, Russia.
   Makarova, Maria, St Petersburg State Univ, Fac Phys, Dept Atmospher Phys, St Petersburg 199034, Russia.},
DOI = {10.1007/s10661-023-12172-y},
Article-Number = {23},
Keywords = {Digital soil mapping; Remote sensing; Kriging; Random forest; Spatial
   assessment},
Keywords-Plus = {FOREST; MATTER; IMAGES; VARIABILITY; PREDICTION; VEGETATION; NITROGEN},
Author-Email = {a.suleymanov@spbu.ru},
Number-of-Cited-References = {55},
