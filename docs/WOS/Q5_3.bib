DOI = {10.1007/s10596-025-10390-6},
Article-Number = {49},
Keywords = {Evolutionary representativeness; Representative models; Uncertainties
   representation; Production strategy optimization; Decision-making
   speed-up},
Keywords-Plus = {DISCRETE LATIN HYPERCUBE; ADAPTATION; REDUCTION; DESIGN; MODELS},
