Keywords = {digital soil mapping; one-dimensional convolutional neural networks;
   multi-layer perceptron; model comparison; SCORPAN},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; ORGANIC-CARBON; REGRESSION},
