Keywords-Plus = {CELLULAR-AUTOMATON; CREDAL-C4.5; VEGETATION; IMPACTS; VIETNAM; DROUGHT;
   EVENTS; SPREAD},
Author-Email = {nhuvietha@humg.edu.vn},
Number-of-Cited-References = {73},
