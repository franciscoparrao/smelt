}

@article{ WOS:001679384400009,
Author = {Peng, Ying and Gu, Yicheng and Yang, Pengtao and Zhan, Linfu},
Title = {Data Management Method in the Petroleum Exploration Work Area},
Journal = {JOURNAL OF INTERNET TECHNOLOGY},
Year = {2026},
Volume = {27},
Number = {1},
Pages = {87-94},
Month = {JAN},
Abstract = {Petroleum exploration is an industry that generates a large amount of
   data, but the datasets used are highly correlated and complex to
   process. To achieve intelligent management of petroleum data, we propose
   a multi-model framework based on deep learning networks. This framework
   combines the advantages of Multilayer Perceptron Short-Term Memory
   (LSTM) to identify hot data that are more likely to be accessed by
   voting. In addition, we compare the performance of three commonly used
   time series prediction models for spatial prediction of petroleum
   exploration work areas. Experiments show that the compared to the
   best-performing LSTM model in a single 90\% of real scenarios.},
