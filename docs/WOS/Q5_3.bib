   Bui, Dieu Tien, Univ South Eastern Norway, Dept Business \& IT, GIS Grp, Gullbringvegen 36, N-3800 Bo I Telemark, Norway.},
DOI = {10.15625/2615-9783/22189},
Keywords = {Flash flood susceptibility; Random Forest; Balancing Composite Motion
   Optimization; GIS; Tropical areas},
Keywords-Plus = {IMPACT},
Author-Email = {Dieu.T.Bui@usn.no},
Number-of-Cited-References = {37},
