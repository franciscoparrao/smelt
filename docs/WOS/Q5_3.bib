@article{ WOS:001513373000001,
Author = {Feng, Yuechun},
Title = {Participant privacy protection and air quality prediction based on FCM,
   PFI ,LSTM, and DBN},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {26},
Month = {JUN},
Abstract = {This paper presents a new air quality monitoring scheme with location
   privacy protection. It combines the fuzzy C-means (FCM) algorithm and
   Laplacian noise injection to design a privacy-preserving method for
   pollution source location, ensuring both location accuracy and position
   privacy. An innovative privacy-preserving fuzzy interpolation (PFI)
   method that integrates spatial interpolation and fuzzy theory is
   proposed to predict air quality at unknown locations and protect
   geographical privacy. During model building, the long short-term memory
   (LSTM) network predicts single-pollutant concentrations, with
   homomorphic encryption for user data privacy in the federated learning
   framework. A joint multipollutant concentration prediction model based
   on a deep belief network (DBN) and multimodal fusion is developed.
   Privacy protection is incorporated into training to secure
   cross-pollutant data interactions. The experimental results show that
   the single-pollutant LSTM model has a mean square error (MSE) of 0.012
   and a mean absolute error (MAE) of 0.009 on the validation set under
   optimal settings. The model's accuracy reaches 0.94, and its robustness
   is above 0.9, surpassing that of the baseline model. In summary, this
   paper innovatively applies privacy-related techniques in air quality
   monitoring, constructing a multipollutant model to protect data privacy
   and enhance prediction accuracy and model robustness.},
Type = {Article},
Affiliation = {Feng, YC (Corresponding Author), Ningxia Inst Sci \& Technol, Coll Comp Sci \& Engn, Shizuishan 753000, Peoples R China.
   Feng, Yuechun, Ningxia Inst Sci \& Technol, Coll Comp Sci \& Engn, Shizuishan 753000, Peoples R China.},
DOI = {10.1016/j.rineng.2025.105496},
EarlyAccessDate = {JUN 2025},
Article-Number = {105496},
Keywords = {Machine learning; Mobile swarm sensing; Participatory privacy
   preservation; Air quality prediction; Federated learning; Homomorphic
   encryption},
Keywords-Plus = {FORECAST; INDEX},
Author-Email = {yuechun\_feng@hotmail.com},
Number-of-Cited-References = {35},
Times-Cited = {3},
Unique-ID = {WOS:001513373000001},
}

@article{ WOS:001508814500001,
Author = {Heusler, Janne and Funk, Jonas and Wagner, Andreas},
Title = {Spatial Interpolation in Applied Insect Ecology: A Review, Including
   Guidelines and Datasets for Practical Use},
Journal = {JOURNAL OF APPLIED ENTOMOLOGY},
Year = {2025},
Volume = {149},
Number = {9},
Pages = {1319-1334},
Month = {NOV},
Abstract = {Spatial interpolation represents a fundamental approach in applied
   insect ecology, offering insight into species distributions and
   supporting biodiversity analysis, pest management and disease vector
   mapping. Insects-including important pollinators-face escalating threats
   due to habitat loss, climate change and anthropogenic pressures. As
   data-driven decisions become more critical in addressing these
   ecological challenges, spatial interpolation techniques such as kriging
   and regression-based models have become essential for estimating insect
   abundance in unsampled areas. This paper offers an in-depth review of
   both geostatistical and non-geostatistical methods employed in insect
   ecology, including ordinary kriging, universal kriging and machine
   learning-based methods such as random forests and maximum entropy. We
   present a structured overview of their applications in pest management,
   disease vector mapping and biodiversity monitoring, and we provide
   practical guidelines for selecting appropriate spatial interpolation
   methods. In addition, we present several datasets that can support case
   studies in spatial modelling for insect ecology. Our findings underscore
   the advantages of integrating geostatistical approaches with
   environmental variables to enhance the accuracy of species distribution
   models. This review serves as a resource for entomologists and
   researchers seeking to advance ecological monitoring and management
   through spatial interpolation techniques.},
Type = {Review},
Affiliation = {Funk, J (Corresponding Author), Karlsruhe Univ Appl Sci, Karlsruhe, Germany.
   Heusler, Janne; Funk, Jonas; Wagner, Andreas, Karlsruhe Univ Appl Sci, Karlsruhe, Germany.
   Wagner, Andreas, Fraunhofer Inst Ind Math ITWM, Kaiserslautern, Germany.},
DOI = {10.1111/jen.13455},
EarlyAccessDate = {JUN 2025},
Keywords = {entomology; geostatistics; kriging; literature review; spatial
   interpolation; species distribution modelling},
Keywords-Plus = {GYPSY-MOTH LEPIDOPTERA; GEOGRAPHIC INFORMATION-SYSTEMS; INTEGRATED
   PEST-MANAGEMENT; POTATO BEETLE COLEOPTERA; GEOSTATISTICAL
   CHARACTERIZATION; SPATIOTEMPORAL DISTRIBUTION; LYMANTRIIDAE DEFOLIATION;
   SPECIES RICHNESS; AEDES-ALBOPICTUS; SOIL PROPERTIES},
Author-Email = {janneheusler@web.de
   jonas.funk@h-ka.de
   andreas.wagner@h-ka.de},
Number-of-Cited-References = {120},
Times-Cited = {1},
Unique-ID = {WOS:001508814500001},
}

@article{ WOS:001506930900001,
Author = {Liang, Xiao Xia and Gloaguen, Erwan and Claprood, Maxime and Paradis,
   Daniel and Lauzon, Dany},
Title = {Graph Neural Network Framework for Spatiotemporal Groundwater Level
   Forecasting},
Journal = {MATHEMATICAL GEOSCIENCES},
Year = {2025},
Volume = {57},
Number = {6, SI},
Pages = {1071-1093},
Month = {AUG},
Abstract = {Spatiotemporal groundwater (GW) forecasting plays an important role in
   water resources management and planning. Given the increasing
   anthropogenic and climatic pressures on GW, there is an urgent need for
   more efficient and accessible forecasting tools to ensure the
   sustainable management and distribution of this vital resource.
   Traditional methods, including simple empirical relationships and
   complex numerical simulations, have shown varying success. However,
   these approaches often struggle to incorporate new information and are
   computationally demanding, which can compromise the accuracy and
   reliability of forecasts over time. To address these limitations, we
   propose a graph neural network (GNN)-based framework that integrates
   explicit geostatistical methods with implicit machine learning
   techniques, serving as a surrogate for numerical models to provide fast
   and accurate GW level forecasts. This GNN framework can be used as a
   coupling tool with the numerical model to aid in forecasting; it is not
   limited to surrogacy. GNNs excel in handling complex data structures,
   making them well suited for geosciences applications. Our framework is
   trained on simulated transient GW levels and pumping rates generated
