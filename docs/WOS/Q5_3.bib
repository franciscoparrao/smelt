   Hussain, Saddam, Univ Florida, Inst Food \& Agr Sci IFAS, Trop Res \& Educ Ctr TREC, Dept Agr \& Biol Engn, Homestead, FL 33031 USA.},
DOI = {10.1007/s41748-026-01030-9},
EarlyAccessDate = {FEB 2026},
Keywords = {Geographic information system (GIS); Erosion susceptibility; Random
   forest; CatBoost; Safsaf watershed},
