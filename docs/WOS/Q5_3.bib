@article{ WOS:001073865600001,
Author = {Ismail, Amir and Radwan, Ahmed A. and Leila, Mahmoud and Abdelmaksoud,
   Ahmed and Ali, Moamen},
Title = {Unsupervised machine learning and multi-seismic attributes for fault and
   fracture network interpretation in the Kerry Field, Taranaki Basin, New
   Zealand},
Journal = {GEOMECHANICS AND GEOPHYSICS FOR GEO-ENERGY AND GEO-RESOURCES},
Year = {2023},
Volume = {9},
Number = {1},
Month = {DEC},
Abstract = {Unsupervised machine learning using an unsupervised vector quantization
   neural network (UVQ-NN) integrated with meta-geometrical attributes as a
   novel computation process as opposed to traditional methodologies is
   currently used effectively in the 3D seismic structural interpretation
   for highresolution detection of fault patterns, fracture network zones,
   and small-scale faults (SSFs). This technology has a crucial role in
   locating prospective well sites and building a 3D structural model while
   saving time and cost. The innovation of the current workflow involves
   combining geostatistical and structural filtering, optimal geometrical
   seismic attributes, UVQ-NN for automatic major faults, fracture network
   zones, and SSFs volumes extraction due to the unavailability of well
   logs and cores. To sharpen the fault edges and discontinuities, a
   steered volume was first extracted. Structural filters were then applied
   to the 3D volume, first with a dip-steered median filter (DSMF),
   followed by a dip-steered diffusion filter (DSDF), and finally, both
   DSMF and DSDF were combined to generate the fault enhancement filter
   (FEF). After that, optimal geometrical attributes were computed and
   extracted, such as similarity, FEF on similarity, maximum curvature,
   polar dip, fracture density, and thinned fault likelihood (TFL)
   attributes. Finally, selected attributes were inserted as the input
   layer to the UVQ-NN to generate segmentation and matching volumes. On
   the other hand, the TFL was used with the voxel connectivity filter
   (VCF) for 3D automatic fault patches extraction. The results from the
   UVQ-NN and VCF identified the locations, orientations, and extensions of
   the main faults, SSFs, and fracture networks. The implemented approach
   is innovative and can be employed in the future for the identification,
   extraction, and classification of geological faults and fracture
   networks in any region of the world.},
Type = {Article},
Affiliation = {Ismail, A (Corresponding Author), Helwan Univ, Fac Sci, Dept Geol, Cairo, Egypt.
   Ismail, Amir, Helwan Univ, Fac Sci, Dept Geol, Cairo, Egypt.
   Radwan, Ahmed A., Al Azhar Univ, Fac Sci, Geol Dept, Assiut Branch, Assiut 71524, Egypt.
   Leila, Mahmoud, Mansoura Univ, Fac Sci, Geol Dept, Mansoura, Egypt.
   Abdelmaksoud, Ahmed; Ali, Moamen, Khalifa Univ, Dept Earth Sci, Abu Dhabi 127788, U Arab Emirates.
   Abdelmaksoud, Ahmed; Ali, Moamen, Assiut Univ, Fac Sci, Dept Geol, Assiut 71516, Egypt.},
DOI = {10.1007/s40948-023-00646-9},
Article-Number = {122},
