   Zhao, Chunju; Zhou, Yihong; Liang, Zhipeng, Hubei Univ Technol, Sch Civil Engn Architecture \& Environm, Wuhan 430068, Peoples R China.
   Zheng, Anran, China Three Gorges Univ, Sch Foreign Languages, Yichang 443002, Peoples R China.},
DOI = {10.3390/app13095407},
Article-Number = {5407},
Keywords = {concrete dam; temperature field; thermal parameters inversion;
   integrated surrogate model; Jaya optimization algorithm},
Keywords-Plus = {SIMULATION; PREDICTION; ENSEMBLE; CRACKING},
Author-Email = {zhaochunju@hbut.edu.cn},
Number-of-Cited-References = {45},
Times-Cited = {9},
