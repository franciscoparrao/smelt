@article{ WOS:001534551100040,
Author = {Marques, Andre Luis Ferreira and Sbragio, Ricardo and Correa, Pedro Luiz
   Pizzigatti and Martins, Marcelo Ramos},
Title = {Artificial Intelligence in Data Science: Evaluating Forecasting Models
   for Solar Energy in the Amazon Basin},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {125066-125079},
Abstract = {Forecasting models employing machine learning (ML) and deep learning
   (DL) have become fundamental for assessing the technical feasibility of
   renewable energy systems. Among these, solar energy stands out as a
   renewable energy option, particularly relevant for supporting the
   preservation of the Amazon rainforest. This study introduces a novel
   approach using ML and DL methods-integrated with Universal Kriging and
   Holt-Winters (time series) models - to forecast solar irradiance
   (kWh/m(2)) in cities across the state of Amazonas. The analysis is
   grounded in the Data Science cycle, with input data sourced from both
   ground stations and satellite products. Forecasting performance was
   evaluated for short-term horizons (one to three days ahead) across three
   representative cities. The hybrid SARIMAX-CNN-LSTM,
   SARIMAX-CNN-Transformer, and SARIMAX-TCN models achieved MAPE values
   ranging from 18.1\% to 26.6\% for the different forecast horizons and
   cities. These results are consistent with existing literature and
   reinforce the suitability of advanced ML/DL approaches for solar energy
   forecasting in highly variable and challenging environments such as the
   Amazon Basin.},
Type = {Article},
Affiliation = {Marques, ALF (Corresponding Author), Univ Sao Paulo, Comp Engn Dept, BigData Lab C216, Polytech Sch, BR-05508010 Sao Paulo, Brazil.
   Marques, Andre Luis Ferreira; Correa, Pedro Luiz Pizzigatti, Univ Sao Paulo, Comp Engn Dept, BigData Lab C216, Polytech Sch, BR-05508010 Sao Paulo, Brazil.
   Sbragio, Ricardo; Martins, Marcelo Ramos, Univ Sao Paulo, Naval Architecture \& Ocean Engn Dept, Lab Anal Evaluat \& Risk Management LabRisco, Polytech Sch, BR-05508010 Sao Paulo, Brazil.},
DOI = {10.1109/ACCESS.2025.3589275},
Keywords = {Forecasting; Neural networks; Discrete wavelet transforms; Data models;
   Solar irradiance; Predictive models; Data science; Renewable energy
   sources; Long short term memory; Wavelet packets; Deep learning; long
   short-term memory; multi-layer perceptron; data science; Amazon Basin;
   solar energy; kriging metamodel},
Keywords-Plus = {IRRADIANCE; DECOMPOSITION; VARIABILITY; DESIGN; IMPACT},
Author-Email = {alfmarques@alumni.usp.br},
Number-of-Cited-References = {76},
Times-Cited = {0},
