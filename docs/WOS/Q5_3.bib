}

@article{ WOS:001704338800002,
Author = {Ding, Xinkai and Wang, Lintao and Zhang, Zhexin and Yang, Yili and Liu,
   Xin and Li, Ruichuan and Xue, Bing},
Title = {Study on the cross-level differentiated optimization design of valve
   packing sealing system based on preload adaptive control},
Journal = {TRIBOLOGY INTERNATIONAL},
Year = {2026},
Volume = {213},
Month = {JAN},
Abstract = {This study addresses the uneven sealing performance in traditional
   multi-layer packing sealing systems for marine valves, proposing an
   innovative layered optimization method. Finite element analysis reveals
   that, under preload, the sealing performance of traditional packing
   decreases from top to bottom, and excessive preload can cause stress to
   exceed limits in the upper layers. The study proposes a new design
   method allowing independent variation of structural parameters for each
   packing layer. A parametric model considering preload transmission was
   created, and the sensitivity of structural parameters and preload to
   sealing performance was analyzed. To improve prediction precision of
   equivalent stress, a high-precision hybrid surrogate model combining
   GWO-BPNN and Kriging was introduced. Single-objective optimization
   minimized contact pressure variance, resulting in improved balance of
   contact pressure. However, to reduce equivalent stress while maintaining
   sealing performance, multi-objective optimization was applied, leading
   to a final optimized solution. Experimental verification showed that
   after 1000 cycles of opening and closing, the optimized packing remained
   leak-free. This layered differentiation design method, by adjusting each
   packing layer to suit preload distribution, not only improves sealing
   balance but also enhances performance, offering a novel approach for
   valve sealing system design.},
Type = {Article},
Affiliation = {Wang, LT (Corresponding Author), Dalian Univ Technol, Sch Mech Engn, Dalian 116081, Peoples R China.
   Ding, Xinkai; Wang, Lintao; Zhang, Zhexin; Yang, Yili; Liu, Xin, Dalian Univ Technol, Sch Mech Engn, Dalian 116081, Peoples R China.
   Li, Ruichuan, Shandong Key Lab Intelligent Electro Hydraul Cont, Rizhao 276817, Peoples R China.
   Li, Ruichuan, Chongqing Univ, State Key Lab High End Equipment Mech Transmiss, Chongqing 400044, Peoples R China.
   Xue, Bing, Dalian Univ Technol, Natl Expt Teaching Demonstrat Ctr Engn Training, Dalian 116081, Peoples R China.},
DOI = {10.1016/j.triboint.2025.111092},
Article-Number = {111092},
Keywords = {Contact mechanics; Structural optimization; Hybrid surrogate model;
   Machine learning},
Keywords-Plus = {PRESSURE},
Author-Email = {wlt@dlut.edu.cn},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001704338800002},
}

@article{ WOS:001676316000034,
Author = {Huang, Anran and Li, Hongyi and Miao, Hongsong and Hao, Yi and Sui,
   Yangyi},
Title = {Physics-Constrained Gaussian Process Regression With Mag-Potential
   Kernel for Aeromagnetic Gradient Tensor Interpolation},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Aeromagnetic gradient tensor (AMGT) interpolation is a critical but
   challenging step in geophysical data processing, essential for
   transforming sparse, nonplanar survey data into regular grids for
   interpretation. Existing methods often fail to enforce the complete
   physical constraints of the magnetic field-namely, its curl-free and
   divergence-free nature-leading to physically inconsistent and inaccurate
   results. To address these limitations, this article introduces a
   physics-constrained Gaussian process regression (GPR) framework. The
   core of our contribution is the novel mag-potential (MP) kernel function
   derived directly from first principles that the magnetic scalar
   potential is a harmonic function. This construction ensures that any
   tensor field realization from the GP priori inherently satisfies both
   the curl-free (symmetry) and divergence-free (zero-trace) constraints,
   enabling a physically sound, joint interpolation of all tensor
   components. The efficacy of the method is validated through
   comprehensive experiments on both synthetic datasets and real-world
   field data acquired by a UAV-borne tensor gradiometer. Results
   demonstrate that the proposed mag-potential GPR (MP-GPR) method
   substantially outperforms state-of-the-art benchmarks, including
   conventional Kriging with continuation and a curl-free GPR model. It not
   only achieves significantly lower interpolation errors and higher
   structural similarity but also produces demonstrably more physically
   consistent fields. Crucially, our method shows exceptional robustness,
   yielding stable results across different flight dynamics and survey
   parameters. The proposed MP kernel provides a principled and effective
   way to integrate fundamental physical laws into a machine learning
   framework, delivering a more reliable and accurate tool for the
   processing of AMGT data.},
Type = {Article},
Affiliation = {Sui, YY (Corresponding Author), Jilin Univ, Coll Instrumentat \& Elect Engn, State Key Lab Deep Earth Explorat \& Imaging, Changchun 130026, Peoples R China.
   Huang, Anran; Li, Hongyi; Miao, Hongsong; Hao, Yi; Sui, Yangyi, Jilin Univ, Coll Instrumentat \& Elect Engn, State Key Lab Deep Earth Explorat \& Imaging, Changchun 130026, Peoples R China.},
DOI = {10.1109/TGRS.2026.3656579},
Article-Number = {5902017},
Keywords = {Tensors; Kernel; Interpolation; Noise; Magnetic domains; Surveys;
   Magnetic field measurement; Vectors; Noise measurement; Gaussian
   processes; Aeromagnetic gradient tensor (AMGT); Gaussian process
   regression (GPR); geophysical interpolation; physics-informed machine
   learning (PIML); potential fields},
Keywords-Plus = {FIELD; CONTINUATION},
Author-Email = {huangar22@mails.jlu.edu.cn
   hongyi23@mails.jlu.edu.cn
   miaohs@jlu.edu.cn
   yihao23@mails.jlu.edu.cn
   suiyangyi@jlu.edu.cn},
Number-of-Cited-References = {52},
