   Chen, Pau-Chung; Guo, Yue-Leon, Natl Taiwan Univ Hosp, Dept Environm \& Occupat Med, Taipei, Taiwan.
   Chen, Pau-Chung, Natl Taiwan Univ, Dept Publ Hlth, Coll Publ Hlth, Taipei, Taiwan.
   Lung, Shih-Chun Candice, Acad Sinica, Res Ctr Environm Changes, Taipei, Taiwan.
   Lung, Shih-Chun Candice, Natl Taiwan Univ, Dept Atmospher Sci, Taipei, Taiwan.
   Lung, Shih-Chun Candice, Natl Taiwan Univ, Inst Environm Hlth, Sch Publ Hlth, Taipei, Taiwan.},
DOI = {10.1016/j.jhazmat.2023.130749},
