   Huang, Senwang, Univ Chinese Acad Sci, Beijing, Peoples R China.
   Chen, Liping, Tongling Univ, Sch Civil \& Architectural Engn, Tongling, Anhui, Peoples R China.},
DOI = {10.1080/19475705.2024.2396908},
