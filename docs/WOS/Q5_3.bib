DOI = {10.3390/w16233354},
Article-Number = {3354},
Keywords = {land use land cover; machine learning; flood vulnerabilities; flood
   damages; flood hazards},
Keywords-Plus = {FLOOD SUSCEPTIBILITY ASSESSMENT; SPATIAL PREDICTION; RIVER-BASIN;
   HAZARD; REGRESSION; BIVARIATE; IMPACTS; DAMAGE; TREES},
Author-Email = {farinaz\_gholami@qdu.edu.cn
   qdenv@126.com
