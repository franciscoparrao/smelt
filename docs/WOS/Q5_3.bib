}

@article{ WOS:001502802100001,
Author = {Shirali, Masoud and Hatamiafkoueieh, Javad and Razoumny, Yury and
   Olegovich, Dryga Danila},
Title = {Accuracy enhancement in land subsidence prediction using lightgbm and
   metaheuristic optimization},
Journal = {EARTH SCIENCE INFORMATICS},
Year = {2025},
Volume = {18},
Number = {3},
Month = {SEP},
Abstract = {Land subsidence has caused numerous problems and dilemmas in
   agricultural lands, roads, and power and energy transmission lines for
   various reasons, including excessive groundwater extraction and climate
   change. Accurate prediction of land subsidence is crucial for effective
   risk management and mitigation strategies. However, existing models
   often struggle with limited predictive accuracy due to suboptimal
   algorithmic performance and the lack of effective hyperparameter
   optimization. This study addresses this gap by proposing a novel
   approach for land subsidence modeling in Arzuiyeh County of Iran,
   combining the LightGBM (Light Gradient Boosting Machine) algorithm with
   two advanced metaheuristic optimization techniques: the Imperialist
   Competitive Algorithm (ICA) and the War Strategy Optimization (WSO). The
   innovation of this research lies in the hybridization of LightGBM with
   ICA and WSO to optimize the hyperparameters and enhance the model's
   predictive accuracy. To evaluate the effectiveness of the proposed
   models, comparisons were made with benchmark models, including Random
   Forest (RF) and Extreme Gradient Boosting (XGBoost). The results show
   that the LightGBM-ICA model outperforms the standalone LightGBM and
   LightGBM-WSO models, achieving an Area Under the Receiver Operating
   Characteristic Curve (AUC-ROC) value of 0.981. The LightGBM-WSO, RF,
   XGBoost, and baseline LightGBM models achieved AUC values of 0.971,
   0.970, 0.937, and 0.922, respectively. The findings demonstrate that
   combining LightGBM with metaheuristic optimization provides a robust
   solution to improve land subsidence prediction, offering higher accuracy
   than existing models. This research contributes to the field of natural
   hazard modeling by providing an innovative and accurate framework for
   land subsidence prediction, which can be applied in regions facing
   subsidence risks.},
Type = {Article},
Affiliation = {Hatamiafkoueieh, J (Corresponding Author), RUDN Univ, Peoples Friendship Univ Russia, Acad Engn, Dept Mech \& Control Proc, Moscow 117198, Russia.
   Shirali, Masoud; Hatamiafkoueieh, Javad; Razoumny, Yury; Olegovich, Dryga Danila, RUDN Univ, Peoples Friendship Univ Russia, Acad Engn, Dept Mech \& Control Proc, Moscow 117198, Russia.},
DOI = {10.1007/s12145-025-01929-3},
Article-Number = {435},
Keywords = {Land subsidence; Spatial prediction; Machine learning; Optimization;
   Groundwater-related subsidence},
Keywords-Plus = {IMPERIALIST COMPETITIVE ALGORITHM; SUSCEPTIBILITY},
Author-Email = {1042245257@rudn.ru
   khatamiafkuiekh\_d@rudn.ru
   yury.razoumny@gmail.com
   dryga\_do@rudn.ru},
Number-of-Cited-References = {89},
Times-Cited = {2},
Unique-ID = {WOS:001502802100001},
}

@article{ WOS:001564275400003,
Author = {Zhang, Shuxiang and Zhang, Qilin and Li, Zhigang},
Title = {Real-time wind response prediction and load inversion for skyscraper
   using deep learning},
Journal = {ENGINEERING STRUCTURES},
Year = {2025},
Volume = {343},
Number = {D},
Month = {NOV 15},
Abstract = {This paper presents a real-time method for predicting wind-induced
   responses and inverting wind loads using deep learning techniques. The
   proposed method is applied to two skyscrapers in China, both over 500 m
   tall. The study uses full-scale nonlinear finite element analysis
   results along with real health monitoring data. The main research
   focuses are as follows: (1) A neural network for predicting wind-induced
   responses, based on an improved Inception module, is proposed. Combined
   with Kriging interpolation, this method can predict realtime,
   full-degree-of-freedom wind-induced responses in super-tall structures.
   (2) The non-unique relationship between wind-induced response sequences
   and wind load sequences is discussed, and verified through inverse
   neural networks and finite element analysis, with theoretical
   validation. (3) A physics-informed variational autoencoder model is
   proposed, capable of reconstructing wind load sequences in real-time
   from limited sensor inputs.},
Type = {Article},
Affiliation = {Zhang, QL (Corresponding Author), Tongji Univ, Coll Civil Engn, 1239 Siping Rd, Shanghai, Peoples R China.
   Zhang, Shuxiang; Zhang, Qilin, Tongji Univ, Coll Civil Engn, 1239 Siping Rd, Shanghai, Peoples R China.
