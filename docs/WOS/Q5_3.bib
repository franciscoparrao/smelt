@article{ WOS:001723135200002,
Author = {Gsoels, Patrick Dominik and Lopera, Jose Romero and Hackl, Herbert and
   Riener, Christian Manfred and Vollmaier, Franz and Stoiber, Martin and
   Henninger, Jan and Kratzer, Markus and Heinisch, Martin and Auinger,
   Bernhard and Hansen, Jan Carsten and Deutschmann, Bernd},
Title = {Achieving EMC Compliance in Traction Inverters via Multiobjective
   Optimization},
Journal = {IEEE OPEN JOURNAL OF THE INDUSTRIAL ELECTRONICS SOCIETY},
Year = {2026},
Volume = {7},
Pages = {525-550},
Abstract = {Achieving first-time-right electromagnetic compatibility (EMC) is
   crucial in automotive industry for competitiveness. However, compliance
   with EM emission limits is usually evaluated through measurements on
   hardware prototypes, especially for complex system like electric vehicle
   powertrains, which include multiple components such as traction
   inverters that collectively contribute to the overall emissions.
   Furthermore, several design goals, such as the amount of magnetic
   material or total installed filter capacitances, must be considered.
   Therefore, this article introduces a simulation framework based on
   common-and differential-mode emission surrogate models with 16 design
   parameters. The models are derived from a circuit simulation model valid
   up to 30 MHz and enable the prediction and optimization of conducted
   emissions (CEs) of traction inverters in the concept phase, prior to
   hardware prototyping. A Two-Level Traction Inverter system and CISPR 25
   standard limits serve as an example. According to the feature selective
   validation metric, the surrogate models achieve a worst-case accuracy
   rated as ``very good{''} for CE prediction when trained on a dataset of
   8064 samples. This corresponds to a spectral uncertainty of
   approximately +/- 2 dB. With evaluation times of about 15 ms, the
   presented surrogate models allow to perform 100 million TI optimizations
   in just 48 h, resulting in three selected optimal designs verified by
   circuit simulations. Therefore, the framework acts as a potential tool
   to develop first-time-right EMC and performance optimized prototypes.},
Type = {Article},
Affiliation = {Gsoels, PD (Corresponding Author), Silicon Austria Labs GmbH, Div Power Elect, A-8010 Graz, Austria.
