   Shinjo, Hitoshi, Kyoto Univ, Grad Sch Global Environm Studies, Yoshida Honmachi, Kyoto, Japan.
   Chotpantarat, Srilert, Chulalongkorn Univ, Fac Sci, Dept Geol, Bangkok, Thailand.
   Chotpantarat, Srilert, Chulalongkorn Univ, Environm Res Inst, Ctr Excellence Environm Innovat \& Management Met E, Bangkok, Thailand.},
DOI = {10.1080/03650340.2024.2448623},
