   Jin, Shaofei; Wang, Ku, MNR, Technol Innovat Ctr Monitoring \& Restorat Engn Eco, Fuzhou 350108, Peoples R China.},
DOI = {10.1016/j.ecolind.2024.112294},
EarlyAccessDate = {JUN 2024},
