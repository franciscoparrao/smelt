@article{ WOS:001606734900014,
Author = {He, Yongjian and Gu, Zhuting and Chen, Li and Wu, Tong and Sun, Yifan
   and Qian, Shihao},
Title = {Distributed Modeling for Daily Mean Air Temperature of Fujian Province
   Under Rugged Terrain With Different Land Surface Types},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2025},
Volume = {18},
Pages = {26908-26923},
Abstract = {High-resolution distributed modeling of daily mean air temperature is
   essential for regional climate research and urban heat island
   assessment. However, conventional interpolation methods and reanalysis
   products fail to capture fine-scale thermal heterogeneity in complex
   terrain. In this study, ERA5 solar radiation was corrected and
   downscaled using solar elevation angle, azimuth angle, and a 100 m
   digital elevation model (DEM). Combined with mean sea level pressure,
   relative humidity, wind speed, DEM, and land cover data, six machine
   learning models were applied to simulate daily mean air temperature at
   100 m resolution for Fujian Province. Cross-validation results
   demonstrated that CatBoost exhibited the best performance, achieving an
   RMSE of 0.60 degrees C and an MAE of 0.45 degrees C. Validation using
   data from automatic meteorological stations confirmed that CatBoost
   (RMSE = 1.21 degrees C) outperformed both ERA5 (RMSE = 1.53 degrees C)
   and Kriging (RMSE = 1.79 degrees C). The results reveal a clear
   north-south temperature gradient and strong local contrasts. In winter,
   the differences in solar radiation between sunny and shady slopes result
   in more distinct temperature patterns. For surface types, urban land was
   on average 2.65 degrees C warmer than natural surfaces, consistent with
   expected environmental processes.},
Type = {Article},
Affiliation = {Gu, ZT (Corresponding Author), Nanjing Univ Informat Sci \& Technol, Sch Geog Sci, Nanjing 210044, Peoples R China.
   He, Yongjian; Gu, Zhuting; Wu, Tong; Sun, Yifan; Qian, Shihao, Nanjing Univ Informat Sci \& Technol, Sch Geog Sci, Nanjing 210044, Peoples R China.
   Chen, Li, Fujian Prov Climate Ctr, Fuzhou 350008, Peoples R China.},
DOI = {10.1109/JSTARS.2025.3622347},
Keywords = {Ocean temperature; Atmospheric modeling; Temperature distribution; Land
