DOI = {10.3390/atmos16101168},
Article-Number = {1168},
Keywords = {marine atmosphere; ERA5/EAC4 reanalysis; Convolutional Neural Network;
   transfer learning},
Keywords-Plus = {SO2; NO2; CO},
