@article{ WOS:001684614500001,
Author = {Wang, Li and Peng, Cheng and Zhang, Lei and Guo, Xiao Jie and Ke, Zhi Wu
   and Lu, Fu Xin},
Title = {Numerical simulation of TIG welding under applied magnetic field and
   optimization of welding process parameter},
Journal = {JOURNAL OF MECHANICAL SCIENCE AND TECHNOLOGY},
Year = {2026},
Volume = {40},
Number = {2},
Pages = {1381-1391},
Month = {FEB},
Abstract = {To address the challenges associated with high experimental costs and
   low efficiency in optimizing TIG welding process parameters under
   external magnetic fields, this study proposes a multi-objective
   optimization framework that integrates numerical simulation with machine
   learning. A three-dimensional multi-physics model was developed using
   COMSOL Multiphysics, generating a dataset of 201 samples to train an
   XGBoost model for predicting the characteristics of the molten pool
   temperature field. Comparative evaluations against a BPNN model
   confirmed the superior predictive accuracy of the XGBoost model.
   Further, by incorporating a welding quality weighting formula and
   implementing the non-dominated sorting genetic algorithm II (NSGA-II),
   multi-objective optimization of the process parameters was conducted,
   leading to a set of optimal solutions. The findings demonstrate that the
   proposed methodology substantially improves the accuracy and efficiency
   of welding process design.},
Type = {Article},
Affiliation = {Zhang, L (Corresponding Author), Shenyang Univ Chem Technol, Sch Mech \& Power Engn, Shenyang 110142, Liaoning, Peoples R China.
   Guo, XJ (Corresponding Author), State Key Lab Marine Thermal Energy \& Power, Xiamen, Huhei, Peoples R China.
   Wang, Li; Peng, Cheng; Zhang, Lei; Lu, Fu Xin, Shenyang Univ Chem Technol, Sch Mech \& Power Engn, Shenyang 110142, Liaoning, Peoples R China.
   Guo, Xiao Jie; Ke, Zhi Wu, State Key Lab Marine Thermal Energy \& Power, Xiamen, Huhei, Peoples R China.},
DOI = {10.1007/s12206-025-1249-3},
EarlyAccessDate = {FEB 2026},
Keywords = {Applied magnetic field TIG welding; Numerical simulation; XGBoost;
   Multi-objective parameter optimization; NSGA-II d},
Keywords-Plus = {NEURAL-NETWORK; KRIGING MODEL},
Author-Email = {zhang\_lei@syuct.edu.com
   1126852094@qq.com},
Number-of-Cited-References = {43},
