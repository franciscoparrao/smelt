Keywords = {Multi-source remote sensing; Deep learning; Montane forest; Canopy
   height},
Keywords-Plus = {TREE HEIGHT; BASE-LINE; LIDAR; DECOMPOSITION; REGRESSION; BIOMASS;
   RADAR; MODEL},
