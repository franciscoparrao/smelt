   Verikoukis, Christos, ATHENA Res Ctr, Ind Syst Inst, Patras, Greece.
   Verikoukis, Christos, Univ Patras, Dept Comp Engn \& Informat, Patras, Greece.},
DOI = {10.1016/j.comnet.2026.112211},
Article-Number = {112211},
Keywords = {6G Networks; Cell-free communication; Distributed radio resource
   allocation; Deep clustering; Machine learning; Classification models;
   Scalable wireless networks},
Author-Email = {iioann06@cs.ucy.ac.cy
