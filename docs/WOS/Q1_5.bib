@article{ WOS:001622751300001,
Author = {Silva, Luan Pedro de Souza and Gomede, Everton},
Title = {Hybrid deep learning and texture-augmented spectral features for
   sugarcane mapping},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Timely identification of sugarcane cultivation is essential for
   precision agriculture, policy formulation, and sustainable land
   management. Our study presents a multimodal framework that integrates
   spectral, morphological, and textural features from Sentinel-2 imagery
   with hybrid deep learning techniques for sugarcane mapping. A
   comprehensive feature space combining NDVI, geometrical descriptors, and
   GLCM-based texture metrics was used to train Random Forest (RF) and
   Support Vector Machine (SVM) classifiers. A hybrid convolutional neural
   network (CNN+MLP) architecture further merged visual embeddings from
   image patches with tabular descriptors. The RF model achieved a macro
   F1-score of 0.91, a Kappa coefficient of 0.86, and a macro-AUC of 0.94
   across agricultural regions in Brazil. DBSCAN clustering was applied to
   filter noisy labels and improve the quality of the training dataset. A
   domain-specific confusion cost matrix illustrated the economic impact of
   misclassification, showing that the RF and CNN+MLP models improved
   accuracy and financial efficiency by reducing crop identification
   errors. Although the analysis was limited to S \& atilde;o Paulo and
   Mato Grosso do Sul, the framework showed consistent and robust
   performance within these regions. Overall, it highlights the benefits of
   combining morphospectral, textural, and deep features for crop
   classification, providing a scalable foundation for time-series modeling
   and real-time land-use analytics.},
Type = {Article},
Affiliation = {Silva, LPD (Corresponding Author), Univ Tecnol Fed Parana, Ave Alberto Carazzai,Ctr 1640, BR-86300000 Cornelio Procopio, PR, Brazil.
   Silva, Luan Pedro de Souza; Gomede, Everton, Univ Tecnol Fed Parana, Ave Alberto Carazzai,Ctr 1640, BR-86300000 Cornelio Procopio, PR, Brazil.},
DOI = {10.1016/j.atech.2025.101634},
EarlyAccessDate = {NOV 2025},
Article-Number = {101634},
Keywords = {Sugarcane identification; Remote sensing; Machine learning; Deep
   learning; Textural and morphospectral features},
Keywords-Plus = {IMAGES; FOREST},
Author-Email = {luanpedro@alunos.utfpr.edu.br
   gomede@utfpr.edu.br},
Number-of-Cited-References = {36},
