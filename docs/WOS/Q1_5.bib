   Lou, Vivian Weiqun, Univ Hong Kong, Sau Po Ctr Ageing, Hong Kong 999077, Peoples R China.},
DOI = {10.1109/JIOT.2025.3639112},
Keywords = {Five-time sit-to-stand (5TSTS); machine learning (ML); motion analysis;
   sarcopenia; wavelet transform (WT); wearable sensors; Five-time
   sit-to-stand (5TSTS); machine learning (ML); motion analysis;
