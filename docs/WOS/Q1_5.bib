   Wang, Yuling; Ou, Xingqi, Henan Inst Sci \& Technol, Sch Agron, Xinxiang 453003, Peoples R China.},
DOI = {10.1016/j.lwt.2025.117973},
EarlyAccessDate = {JUN 2025},
