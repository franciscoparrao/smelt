Keywords = {Associative classification mining; Fingerprint; Pipeline Pilot;
   Bayesian; SVM},
Keywords-Plus = {THROUGHPUT SCREENING DATA; GENE-EXPRESSION DATA; MODELS; PERFORMANCE;
   ALGORITHMS; PATTERNS},
Author-Email = {djwild@indiana.edu},
Number-of-Cited-References = {50},
