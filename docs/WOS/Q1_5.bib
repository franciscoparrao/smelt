   Akgul, Akif, ADBA Informat Technol \& Publishing Ltd, Corum Technopk, TR-19040 Corum, Turkiye.},
DOI = {10.1016/j.cam.2025.117095},
EarlyAccessDate = {OCT 2025},
Article-Number = {117095},
Keywords = {Pixel Map Medical Imaging; Medical Artificial Intelligence; Optimized
   Transfer Learning; Machine Learning Algorithms; Cardiovascular Disease
   Diagnosis; Improved Salp Swarm Algorithm; Classification Algorithms;
   Physiological Signal Analysis; Multi-Modal Medical Image Analysis},
Keywords-Plus = {SALP SWARM ALGORITHM},
Author-Email = {berkayemin@hitit.edu.tr
   yusufalaca@hitit.edu.tr
   ofarukakmese@hitit.edu.tr
   yeliz.karaca@ieee.org
   akifakgul@hitit.edu.tr},
