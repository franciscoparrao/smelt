@article{ WOS:001605228500001,
Author = {Kumar, Shailendra},
Title = {Controlled feasibility study for moisture-based grouping of dried wood:
   use of near infrared spectroscopy and support vector machine
   classification},
Journal = {JOURNAL OF THE INDIAN ACADEMY OF WOOD SCIENCE},
Year = {2025},
Month = {2025 OCT 31},
Abstract = {Grouping kiln-dried lumber according to moisture content can help with
   quality control by preventing the mixing of stock that is under-dried or
   over-dried with stock that has the right range of moisture content. It
   has been established that near-infrared spectroscopy (NIRS) is a useful,
   non-destructive method of determining the moisture content of wood.
   Support Vector Machines (SVM) is a supervised learning technique for
   regression and classification problems. This study explores the use of
   NIR spectroscopy and SVM classification to group Populus deltoides
   (Indian hardwood) specimens based on moisture content after drying, with
   the aim of contributing to more informed decision-making in wooden
   product processing. Absorbance spectra (9000 cm-1 to 4500 cm-1) of the
   training set specimens were pre-processed using standard normal variate
   (SNV) transformation. The data set (517 numbers) was divided into two
   parts: the training set and the test set, in a ratio of 3:1. The
   training data set was used to create four classes of moisture content:
   acceptable for production, full-scale drying needed, extended level of
   drying needed, and moderate level of drying needed. These classes had
   moisture content ranges of 8.0\% to 13.31\%, 19.5\% to 30.0\%, 13.32\%
   to 19.31\%, and 30.1\% and higher, respectively. The SVM classification
   model was developed using classification type NuSVC, kernel type radial
   basis function, gamma value 0.1, and Nu value 0.255. The
   cross-validation accuracy of the SVM classification training model was
   82.77\%, while its training accuracy was 91.64\%. The test specimens
   with unknown moisture content were classified with an average success
   rate of 92.5\% using the SVM classification model. The study, based on a
   limited controlled dataset, warrants future validation on larger, more
   diverse industrial samples to assess its robustness and scalability.},
Type = {Article; Early Access},
Affiliation = {Kumar, S (Corresponding Author), Forest Res Inst, Forest Prod Div, Wood Seasoning Discipline, Dehra Dun, India.
   Kumar, Shailendra, Forest Res Inst, Forest Prod Div, Wood Seasoning Discipline, Dehra Dun, India.},
DOI = {10.1007/s13196-025-00390-5},
EarlyAccessDate = {OCT 2025},
Keywords = {Grouping; Near Infrared Spectroscopy (NIRS); Moisture content
   classification; Support vector machine classification; <italic>Populus
   deltoides</italic>; Wood drying},
Keywords-Plus = {VARIABILITY; DENSITY},
Author-Email = {shailendra354@gmail.com},
Number-of-Cited-References = {20},
Times-Cited = {1},
Unique-ID = {WOS:001605228500001},
}

@article{ WOS:001609526500005,
Author = {Boujoudar, Mohamed and Taj, Amine Moulay and Bouarfa, Ibtissam and El
   Ydrissi, Massaab and Dadda, Abdelmounaim and Abraim, Mounir and
   Bennouna, El Ghali and Ghennioui, Hicham},
Title = {AI fault detection in CSP with simulation based fault injection on a 1
   MWe Fresnel-ORC plant},
Journal = {SOLAR ENERGY},
Year = {2026},
Volume = {303},
Month = {JAN},
Abstract = {Concentrated Solar Power (CSP) systems utilizing Fresnel collectors and
   Organic Rankine Cycles (ORC) provide dispatchable renewable energy
   generation, yet operational reliability is constrained by elevated
   maintenance costs and fault susceptibility. Current fault detection
   methodologies face significant challenges including insufficient labeled
   fault datasets, limited failure mode classification, and absence of
   generalizable diagnostic frameworks. This research addresses these
   limitations through development of a physics-informed simulation for a 1
   MWe Fresnel-ORC configuration, integrating meteorological data from
   Green Energy Park and implementing systematic fault injection via
   parameter perturbation. Four representative fault categories-mirror
   soiling, tracking misalignment, receiver degradation, and flow-rate
   blockage-were modeled to generate comprehensive labeled datasets. Three
   machine learning architectures (SVM, K-NN, and ResNet) were subsequently
   trained for automated fault detection and classification using
   operational time-series data. Simulation results reveal that mirror
   soiling, and receiver degradation constitute the most critical failure
   modes, inducing electrical output reductions of 48.7 \% and 27.8 \%,
   respectively. Comparative analysis demonstrates ResNet architecture
   superiority, achieving 95 \% accuracy in multi-class fault
   identification, surpassing SVM (94 \%) and KNN (82 \%) performance.
   Overall, the study shows that simulation-based fault synthesis with ML
   can deliver reliable predictive-maintenance diagnostics, forming a
   foundation for scalable and geographically adaptable deployment across
   CSP plants.},
Type = {Article},
Affiliation = {Boujoudar, M (Corresponding Author), Sidi Mohamed Ben Abdullah Univ, Lab Signals Syst \& Components, Fes, Morocco.
