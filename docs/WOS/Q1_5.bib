   Phuphaphud, Arthit; Saengprachatanarug, Khwantri, Khon Kaen Univ, Northeast Thailand Cane \& Sugar Res Ctr NECS, Khon Kaen 40002, Thailand.},
DOI = {10.1016/j.atech.2026.101938},
Article-Number = {101938},
Keywords = {Cassava mosaic disease (CMD); UAV multispectral imagery; Object-based
   image analysis (OBIA); Mean-shift segmentation; Machine learning
   classification; Precision agriculture},
Keywords-Plus = {CLASSIFICATION; DISEASE},
