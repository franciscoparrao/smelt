   Kim, Tai-hoon, Chonnam Natl Univ, Sch Elect \& Comp Engn, Yeosu Campus,50 Daehak ro, Yeosu Si 59626, Jeollanam Do, South Korea.},
DOI = {10.3390/technologies11050121},
