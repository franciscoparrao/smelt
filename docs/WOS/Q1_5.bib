@article{ WOS:001519086700001,
Author = {Wang, Chunli and Zhang, Xiao and Zhang, Nannan and Guo, Huaying and Wu,
   Hongxin and Wang, Xuanzhang},
Title = {Optimizing the estimation of cotton leaf SPAD and LAI values via UAV
   multispectral imagery and LASSO regression},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Cotton (Gossypium spp.) is a vital economic crop both globally and
   particularly in Xinjiang, China, where its growth status is closely
   linked to chlorophyll content and leaf area index (LAI). Chlorophyll
   content is commonly measured using the soil plant analysis development
   (SPAD) value. This study employed multispectral remote sensing data
   collected by a DJI Mavic 3 M unmanned aerial vehicle (UAV) to
   investigate the spectral responses of canopy SPAD and LAI in cotton
   fields affected by Verticillium wilt in southern Xinjiang. SPAD was
   strongly negatively correlated with the red band (r = -0.784) and
   positively correlated with the red-edge (REG) band (r = 0.498), while
   LAI showed the strongest correlation with the near-infrared (NIR) band
   (r = 0.673) and a moderate correlation with the REG band (r = 0.435).
   Among various vegetation indices (VIs), the photochemical reflectance
   ratio (PPR) exhibited the highest correlation with SPAD (r = 0.84), and
   the excess green (EXG) index showed the strongest correlation with LAI
   (r = 0.92). Inversion accuracy was highest during the boll stage. The
   least squares method (LSM) achieved coefficient of determination (R2)
   values of 0.58 for SPAD and 0.57 for LAI, while combining VIs and
   texture features through least absolute shrinkage and selection operator
   (LASSO) regression improved accuracy to 0.711 and 0.751, respectively.
   Comparative modeling using LSM, grey wolf optimizer-support vector
   machine (GWO-SVM), and ant colony optimization-random forest (ACO-RF)
   revealed that ACO-RF consistently outperformed the other models,
   particularly in capturing nonlinear relationships and multi-feature
   interactions. The ACO-RF model achieved R2 values of 0.898 (root mean
   square error, RMSE = 1.523) for SPAD and 0.893 (RMSE = 3.308) for LAI.
   These findings demonstrate that integrating spectral and textural
   features with optimized machine learning models can significantly
   enhance the accuracy, scalability, and cost-effectiveness of
   Verticillium wilt monitoring in cotton, thereby supporting early disease
   detection and precision agricultural management.},
Type = {Article},
Affiliation = {Zhang, NN (Corresponding Author), Tarim Univ, Coll Informat Engn, Alar 843300, Peoples R China.
   Wang, Chunli; Zhang, Xiao; Zhang, Nannan; Guo, Huaying; Wu, Hongxin; Wang, Xuanzhang, Tarim Univ, Coll Informat Engn, Alar 843300, Peoples R China.
   Wang, Chunli; Zhang, Xiao; Zhang, Nannan; Guo, Huaying; Wu, Hongxin; Wang, Xuanzhang, Tarim Univ, Key Lab Tarim Oasis Agr, Minist Educ, Alar 843300, Peoples R China.},
DOI = {10.1016/j.atech.2025.101098},
EarlyAccessDate = {JUN 2025},
Article-Number = {101098},
Keywords = {Cotton Verticillium wilt; UAV remote sensing; SPAD value; LASSO
   regression; ACO-RF},
Author-Email = {zhangnannan@taru.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {6},
Unique-ID = {WOS:001519086700001},
}

@article{ WOS:001517115800001,
Author = {Ahn, Jung Min and Jeong, Wuseong and Lee, Hyuk and Kim, Kyunghyun},
Title = {Hyperspectral imaging-based land use classification using a hybrid
   Convolutional Neural network-vision transformer model},
Journal = {ENVIRONMENTAL TECHNOLOGY \& INNOVATION},
Year = {2025},
Volume = {39},
Month = {AUG},
Abstract = {Effective land use and land cover (LULC) classification is critical for
   sustainable environmental management, particularly in the context of
   rapid urbanization. This study was motivated by the need to move beyond
   conventional, labor-intensive field survey methods by adopting advanced
   remote sensing technologies and artificial intelligence (AI)-based
   approaches. Traditional machine learning methods, such as Support Vector
   Machines (SVM), have shown limitations in capturing the complex spectral
   and spatial characteristics of hyperspectral data. To address these
   challenges, a hybrid deep learning framework is proposed, combining
   Convolutional Neural Networks (CNNs) with Vision Transformers (ViTs),
   leveraging the local feature extraction strengths of CNNs and the global
   contextual modeling capabilities of Transformers. The proposed
   methodology involves the collection of hyperspectral aerial imagery and
   groundbased spectral reflectance data from the Geum River Basin in South
   Korea. A hyperspectral reflectance library was constructed using over
   5700 field measurements obtained via a FieldSpec4 spectroradiometer.
   These data were used to train and validate a CNN-ViT model, which
   integrates a series of 1D convolutional layers for spatial-spectral
   feature extraction with a Transformer encoder for capturing long-range
   dependencies. To ensure robust training and generalization,
   preprocessing steps such as spectral band alignment and reflectance
   normalization were applied, and hyperparameter tuning was employed using
   Optuna. The classification performance of the CNN-ViT model was
   evaluated against the traditional SVM model and CNN model, showing
   significantly improved accuracy, particularly in areas where spectral
   mixing occurs due to the 2-meter spatial resolution of airborne
   hyperspectral imagery. In particular, traditional methods struggled to
   distinguish between mixed surfaces such as soil and vegetation, whereas
   the CNN-ViT model successfully resolved these ambiguities.The CNN-ViT
   model achieved an overall classification accuracy of 0.98, outperforming
   the SVM model's 0.72 and CNN model's 0.86. Furthermore, our approach was
   implemented in a scalable geospatial processing framework that enables
   efficient batch classification and raster map generation. These results
   highlight the effectiveness of the CNN-ViT hybrid approach in advancing
   LULC classification using hyperspectral data, with implications for
   enhancing land monitoring systems, environmental planning, and resource
   management.},
Type = {Article},
Affiliation = {Kim, K (Corresponding Author), Natl Inst Environm Res, Water Environm Res Dept, Incheon 22689, South Korea.
   Ahn, Jung Min; Jeong, Wuseong; Lee, Hyuk, Natl Inst Environm Res, Han River Environm Res Ctr, Water Environm Res Dept, Incheon 22689, South Korea.
   Kim, Kyunghyun, Natl Inst Environm Res, Water Environm Res Dept, Incheon 22689, South Korea.},
DOI = {10.1016/j.eti.2025.104317},
EarlyAccessDate = {JUN 2025},
Article-Number = {104317},
Keywords = {Remote sensing; Hyperspectral imaging; Deep learning; CNN-ViT; Land use
   classification},
Keywords-Plus = {SPATIAL CLASSIFICATION},
Author-Email = {jahn@korea.kr
   simzee95@korea.kr
   hyuk72@korea.kr
   matthias@korea.kr},
Number-of-Cited-References = {36},
Times-Cited = {6},
Unique-ID = {WOS:001517115800001},
}

@article{ WOS:001498114800001,
Author = {Katam, Rakesh and Pasupuleti, Venkata Dilip Kumar and Kalapatapu,
   Prafulla},
Title = {Machine learning-driven structural health monitoring: STFT-based feature
   extraction for damage detection},
Journal = {STRUCTURES},
Year = {2025},
Volume = {78},
Month = {AUG},
Abstract = {Structural health monitoring (SHM) is essential for ensuring the safety
   and durability of engineering structures by enabling early
   identification of damage. This research presents a novel approach that
   integrates experimental testing, signal processing, and machine learning
   to enhance damage detection in cantilever beams, mainly when working
   with limited datasets. Vibration-based time-series data (VBTSD) are
   gathered from damaged and undamaged beams, utilizing fast fourier
   transform (FFT) and short-time fourier transform (STFT) for
   frequencydomain analysis. While FFT delivers a comprehensive spectral
   overview, STFT provides a focused timefrequency analysis, effectively
   capturing transient structural changes that are critical for early
   damage detection. To manage the high-dimensional STFT feature space, an
   autoencoder is utilized to extract compressed yet informative
   representations while preserving essential frequency-magnitude
   variations. The resulting encoded features are then used to train a
   support vector machine (SVM) classifier, achieving an impressive 98 \%
   accuracy in predicting the presence of structural damage. The proposed
   framework is designed to function effectively even with limited data
   availability, ensuring robustness in real-world SHM applications where
   data collection is often restricted. The high-resolution frequency
   selectivity offered by STFT surpasses traditional methods such as
   wavelet transforms and standalone FFT, making it exceptionally suitable
   for real-time damage detection. This research highlights the combination
   of vibration-based feature extraction and machine learning, resulting in
   a scalable, data-efficient, and computationally feasible approach for
   SHM. The results aid in the progression of automated damage
   classification, presenting a practical and dependable resource to
   improve structural resilience and safety within civil engineering
   applications.},
Type = {Article},
Affiliation = {Katam, R; Pasupuleti, VDK (Corresponding Author), Mahindra Univ, Ctr Sustainable Infrastruct \& Syst, Hyderabad 500043, Telangana, India.
   Katam, Rakesh; Pasupuleti, Venkata Dilip Kumar; Kalapatapu, Prafulla, Mahindra Univ, Ctr Sustainable Infrastruct \& Syst, Hyderabad 500043, Telangana, India.},
DOI = {10.1016/j.istruc.2025.109244},
EarlyAccessDate = {MAY 2025},
Article-Number = {109244},
Keywords = {Structural health monitoring; Fast fourier transform; Short-time fourier
   transform; Support vector Machine; Vibration-based time series data;
   Autoencoders; And High-dimensional features},
Keywords-Plus = {IDENTIFICATION},
Author-Email = {rakesh20pcie002@mahindrauniversity.edu.in
   venkata.pasupuleti@mahindrauniversity.edu.in},
Number-of-Cited-References = {72},
Times-Cited = {6},
Unique-ID = {WOS:001498114800001},
}

@article{ WOS:001464182200001,
Author = {Zhou, Chengjiang and Xing, Lin and Zou, Wei and Wang, Ziyan and Yang,
   Yuting and Zhao, Shan and Bai, Haicheng and Yang, Yang},
Title = {EMGGDFuRDE: Enhancive multiscale generalized Gaussian distribution fuzzy
   Renyi dispersion entropy and its application in wind turbines fault
   diagnosis},
Journal = {MECHANICAL SYSTEMS AND SIGNAL PROCESSING},
Year = {2025},
Volume = {231},
Month = {MAY 15},
Abstract = {Accurate fault diagnosis in wind turbines requires methods capable of
   effectively processing time-series data with high stability, noise
   resilience, and precision, all of which are essential for enhancing
   maintenance efficiency. We propose two novel contributions: Enhancive
   Multiscale Generalized Gaussian Distribution Fuzzy Renyi Dispersion
   Entropy (EMGGDFuRDE) for advanced feature extraction, and Optimal Binary
   Tree Least Squares Twin SVM (OBT-LSTSVM) for robust classification.
   EMGGDFuRDE improves feature representation by integrating several key
   innovations: an enhancive multiscale coarse-graining technique to
   mitigate the loss of coarse-grained points, a Generalized Gaussian
   Distribution (GGD) mapping method to enhance noise suppression, and the
   removal of the round function to reduce boundary blurring. Furthermore,
   trapezoidal and triangular membership functions are incorporated to
   improve estimation accuracy, while Renyi entropy is introduced to
   provide scalability across different fault scenarios. For OBTLSTSVM, we
   propose a new intra-class and inter-class separability measure to
   address error accumulation in binary tree-based models, thereby
   enhancing classification stability by optimizing the discriminative
   power between classes. Experimental results demonstrate diagnostic
   accuracies of 98.2\% and 99.6\% across two distinct wind turbine fault
   scenarios, confirming that the scale features of EMGGDFuRDE more
   effectively capture fault information, and that OBTLSTSVM, enhanced by
   the separability measure, delivers superior classification performance.
   These innovations mark substantial progress in feature extraction and
   model optimization, surpasses existing methods in accuracy and noise
   resistance, providing a superior framework for wind turbine fault
   diagnosis.},
Type = {Article},
Affiliation = {Zou, W; Yang, Y (Corresponding Author), Yunnan Normal Univ, Sch Informat Sci \& Technol, Kunming 650500, Peoples R China.
   Zhou, Chengjiang; Xing, Lin; Zou, Wei; Wang, Ziyan; Yang, Yuting; Zhao, Shan; Bai, Haicheng; Yang, Yang, Yunnan Normal Univ, Sch Informat Sci \& Technol, Kunming 650500, Peoples R China.
   Zhou, Chengjiang; Xing, Lin; Zhao, Shan; Bai, Haicheng; Yang, Yang, Yunnan Normal Univ, Pattern Recognit \& Artificial Intelligence Lab, Kunming 650500, Peoples R China.},
DOI = {10.1016/j.ymssp.2025.112636},
EarlyAccessDate = {APR 2025},
Article-Number = {112636},
Keywords = {EMGGDFuRDE; Optimal binary tree LSTSVM; Wind turbines; Feature
   extraction; Fault diagnosis},
Author-Email = {lin.xing@ynnu.edu.cn
   zouwei@ynnu.edu.cn
   yangyang@ynnu.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {6},
Unique-ID = {WOS:001464182200001},
}

@article{ WOS:001465688700001,
Author = {Rampone, Glauco and Ivaniv, Taras and Rampone, Salvatore},
Title = {A Hybrid Federated Learning Framework for Privacy-Preserving
   Near-Real-Time Intrusion Detection in IoT Environments},
Journal = {ELECTRONICS},
Year = {2025},
Volume = {14},
Number = {7},
Month = {APR 2},
Abstract = {The proliferation of Internet of Things (IoT) devices has introduced
   significant challenges in cybersecurity, particularly in the realm of
   intrusion detection. While effective, traditional centralized machine
   learning approaches often compromise data privacy and scalability due to
   the need for data aggregation. In this study, we propose a federated
   learning framework for near-real-time intrusion detection in IoT
   environments. Federated learning enables decentralized model training
   across multiple devices without exchanging raw data, thereby preserving
   privacy and reducing communication overhead. Our approach builds upon a
   previously proposed hybrid model, which combines a machine learning
   model deployed on IoT devices with a second-level cloud-based analysis.
   This previous work required all data to be passed to the cloud in
   aggregate form, limiting security. We extend this model to incorporate
   federated learning, allowing for distributed training while maintaining
   high accuracy and privacy. We evaluate the performance of our
   federated-learning-based model against a traditional centralized model,
   focusing on accuracy retention, training efficiency, and privacy
   preservation. Our experiments utilize actual attack data partitioned
   across multiple nodes. The results demonstrate that this hybrid
   federated learning not only offers significant advantages in terms of
   data privacy and scalability but also retains the previous competitive
   accuracy. This paper also explores the integration of federated learning
   with cloud-based infrastructure, leveraging platforms such as Databricks
   and Google Cloud Storage. We discuss the challenges and benefits of
   implementing federated learning in a distributed environment, including
   the use of Apache Spark and MLlib for scalable model training. The
   results show that all the algorithms used maintain an excellent
   identification accuracy (98\% for logistic R=regression, 97\% for SVM,
   and 100\% for Random Forest). We also report a very short training time
   (less than 11 s on a single machine). The previous very low application
   time is also confirmed (0.16 s for over 1,697,851 packets). Our findings
   highlight the potential of federated learning as a viable solution for
   enhancing cybersecurity in IoT ecosystems, paving the way for further
   research in privacy-preserving machine learning techniques.},
Type = {Article},
Affiliation = {Rampone, S (Corresponding Author), Univ Sannio, Dept Law Econ Management \& Quantitat Methods DEMM, I-82100 Benevento, Italy.
