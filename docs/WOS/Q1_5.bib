   Duron, Dulis; Setiyono, Tri; Shiratsuchi, Luciano Shozo, Louisiana State Univ, Sch Plant Environm \& Soil Sci, AgCtr, Baton Rouge, LA 70803 USA.
   Moreira, Bruno Rafael de Almeida, Univ Georgia, Dept Crop \& Soil Sci, Athens, GA 30602 USA.},
DOI = {10.1016/j.indcrop.2024.118627},
EarlyAccessDate = {MAY 2024},
Article-Number = {118627},
Keywords = {Sugar content; Lignocellulosic content; Multispectral imagery; Machine
   learning; Active sensor; 1G and 2G bioethanol},
Keywords-Plus = {STRAW; DECOMPOSITION; STRESS; MODELS},
Author-Email = {marcelo.junior@unesp.br},
