@article{ WOS:000335457100011,
Author = {Djuric, Nemanja and Lan, Liang and Vucetic, Slobodan and Wang, Zhuang},
Title = {BudgetedSVM: A Toolbox for Scalable SVM Approximations},
Journal = {JOURNAL OF MACHINE LEARNING RESEARCH},
Year = {2013},
Volume = {14},
Pages = {3813-3817},
Month = {DEC},
Abstract = {We present BudgetedSVM, an open-source C++ toolbox comprising
   highly-optimized implementations of recently proposed algorithms for
   scalable training of Support Vector Machine (SVM) approximators:
   Adaptive Multi-hyperplane Machines, Low-rank Linearization SVM, and
   Budgeted Stochastic Gradient Descent. BudgetedSVM trains models with
   accuracy comparable to LibSVM in time comparable to LibLinear, solving
   non-linear problems with millions of high-dimensional examples within
   minutes on a regular computer. We provide command-line and Matlab
   interfaces to BudgetedSVM, an efficient API for handling large-scale,
   high-dimensional data sets, as well as detailed documentation to help
   developers use and further extend the toolbox.},
Type = {Article},
Affiliation = {Djuric, N (Corresponding Author), Temple Univ, 304 Wachman Hall,1805 North Broad St, Philadelphia, PA 19122 USA.
