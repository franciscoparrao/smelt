   Jeng, Yeau-Ren, Natl Cheng Kung Univ, Dept Biomed Engn, 1 Univ Rd, Tainan, Taiwan.},
DOI = {10.1016/j.rineng.2025.107644},
EarlyAccessDate = {OCT 2025},
