@article{ WOS:001505100700002,
Author = {He, Hong-Ju and Zhang, Chen and Xing, Longzhu and Qiao, Hong and Bi,
   Jicai and Niu, Shengyang and Li, Jin and Wang, Yuling and Ou, Xingqi},
Title = {Machine learning-driven pocket-sized NIR analysis for non-invasive
   quantification of cellulose, hemicellulose, lignin and pectin in sweet
   potato roots},
Journal = {LWT-FOOD SCIENCE AND TECHNOLOGY},
Year = {2025},
Volume = {226},
Month = {JUN 15},
Abstract = {This study developed an intelligent analytical framework integrating a
   novel StarFish Optimization Algorithm (SFOA) with support vector machine
   regression (SVR) to quantify cellulose, hemicellulose, lignin, and
   pectin concentrations (CC, HC, LC, PC) in fresh sweet potato roots (SPR)
   using near-infrared (NIR) spectra (900-1700 nm). By implementing
   successive projections algorithm and improved whale optimization
   algorithm, both individually and in combination, 20, 20, 20, and 11
   wavelengths were identified as the most informative wavelengths (MIWs)
   for CC, HC, LC, and PC quantification, respectively. The SFOA-optimized
   SVR models, trained on these MIWs, achieved robust predictive
   performance with determination coefficient and root-mean-square errors
   of prediction (R2P \& RMSEP) of 0.8892 \& 0.3811 mg/g for CC, 0.8638 \&
   0.3496 mg/g for HC, 0.9225 \& 0.2460 mg/g for LC, and 0.7942 \& 0.3868
   mg/g for PC, respectively. Model reliability was rigorously validated
   using independent test sets and statistical hypothesis testing (F-test
   and t-test), confirming the method robustness. By combining miniaturized
   handheld NIR spectrometer with the SFOA-driven SVR algorithm, this work
   established a rapid, nondestructive protocol for simultaneous
   quantification of cellulose, hemicellulose, lignin, and pectin in SPR.
   The framework provides a novel, scalable strategy for on-site assessment
   of dietary fiber quality in SPR breeding and processing industries.},
Type = {Article},
Affiliation = {Wang, YL; Ou, XQ (Corresponding Author), Henan Inst Sci \& Technol, Sch Agron, Xinxiang 453003, Peoples R China.
   He, Hong-Ju; Xing, Longzhu; Bi, Jicai; Niu, Shengyang, Henan Inst Sci \& Technol, Sch Food Sci, Xinxiang 453003, Peoples R China.
