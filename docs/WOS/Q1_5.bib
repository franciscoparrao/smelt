@article{ WOS:000422952400017,
Author = {Yu, Yinan and Diamantaras, Konstantinos I. and McKelvey, Tomas and Kung,
   Sun-Yuan},
Title = {CLAss-Specific Subspace Kernel Representations and Adaptive Margin Slack
   Minimization for Large Scale Classification},
Journal = {IEEE TRANSACTIONS ON NEURAL NETWORKS AND LEARNING SYSTEMS},
Year = {2018},
Volume = {29},
Number = {2},
Pages = {440-456},
Month = {FEB},
Abstract = {In kernel-based classification models, given limited computational power
   and storage capacity, operations over the full kernel matrix becomes
   prohibitive. In this paper, we propose a new supervised learning
   framework using kernel models for sequential data processing. The
   framework is based on two components that both aim at enhancing the
   classification capability with a subset selection scheme. The first part
   is a subspace projection technique in the reproducing kernel Hilbert
   space using a CLAss-specific Subspace Kernel representation for kernel
   approximation. In the second part, we propose a novel structural risk
   minimization algorithm called the adaptive margin slack minimization to
   iteratively improve the classification accuracy by an adaptive data
   selection. We motivate each part separately, and then integrate them
   into learning frameworks for large scale data. We propose two such
   frameworks: the memory efficient sequential processing for sequential
   data processing and the parallelized sequential processing for
   distributed computing with sequential data acquisition. We test our
   methods on several benchmark data sets and compared with the
   state-of-the-art techniques to verify the validity of the proposed
   techniques.},
Type = {Article},
Affiliation = {Yu, YA (Corresponding Author), Chalmers Univ Technol, Dept Signals \& Syst, S-41296 Gothenburg, Sweden.
   Yu, Yinan; McKelvey, Tomas, Chalmers Univ Technol, Dept Signals \& Syst, S-41296 Gothenburg, Sweden.
   Diamantaras, Konstantinos I., Technol Educ Inst Thessaloniki, Dept Informat Technol, Thessaloniki 57400, Greece.
   Kung, Sun-Yuan, Princeton Univ, Dept Elect Engn, Princeton, NJ 08544 USA.},
DOI = {10.1109/TNNLS.2016.2619399},
Keywords = {Adaptive data sampling; adaptive margin; between-class distance;
   classification; class-specific subspace; kernel approximation; large
   scale; sequential and parallel framework; support vector machine},
Keywords-Plus = {SUPPORT VECTOR MACHINE; NYSTROM METHOD; RECOGNITION; CLASSIFIERS;
   ONLINE; MATRIX},
Author-Email = {yinan@chalmers.se
   kdiamant@it.teithe.gr
   tomas.mckelvey@chalmers.se
   kung@princeton.edu},
Number-of-Cited-References = {46},
