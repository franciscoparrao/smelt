@article{ WOS:001673222200001,
Author = {An, Hangdong and Ma, Jin},
Title = {Fast diffusion-driven data augmentation for imbalanced power-system
   stability classification},
Journal = {INTERNATIONAL JOURNAL OF ELECTRICAL POWER \& ENERGY SYSTEMS},
Year = {2026},
Volume = {175},
Month = {FEB},
Abstract = {The increasing integration of intermittent renewable energies amplifies
   uncertainty in power system operation, complicating stability assessment
   and limiting the effectiveness of traditional model-based approaches. To
   address this challenge, data-driven methods have emerged as flexible
   alternatives, but they often suffer from severe class imbalance, with
   unstable cases being relatively rare. Generative models like Generative
   Adversarial Models (GANs) and Variational Autoencoders (VAEs) have been
   explored for sample augmentation, yet frequently encounter issues such
   as mode collapse and insufficient diversity. More recently, Denoising
   diffusion probabilistic models (DDPMs) have shown promise, but their
   high computational cost-often requiring hundreds of denoising
   steps-hinders practical deployment. To overcome these limitations, this
   paper proposes an FDDA that directly learns the residuals between noise
   samples at adjacent time steps, thereby eliminating the need for larger
   attention mechanism modules. This design significantly reduces the
   number of diffusion steps by more than 60\% compared to standard
   DDPMs-without compromising sample quality. Combined with support vector
   machine(SVM) and random forest(RF) classifiers, our approach is
   evaluated on multiple benchmark power system cases. Results demonstrate
   improved generalization, robustness to class imbalance, and lower
   computational cost compared to conventional augmentation techniques,
   thus providing a scalable and efficient data-driven strategy for
   enhancing power system stability assessment under high uncertainty.},
Type = {Article},
Affiliation = {Ma, J (Corresponding Author), Univ Sydney, Sch Elect \& Comp Engn, Sydney 2008, Australia.
   An, Hangdong; Ma, Jin, Univ Sydney, Sydney, NSW 2008, Australia.},
DOI = {10.1016/j.ijepes.2026.111559},
EarlyAccessDate = {JAN 2026},
Article-Number = {111559},
Keywords = {Renewable energy integration; Machine learning; Power system stability;
   Data augmentation; Class imbalance; Denoising probabilistic model},
Keywords-Plus = {TRANSIENT STABILITY},
Author-Email = {j.ma@sydney.edu.au},
Number-of-Cited-References = {42},
Times-Cited = {0},
Unique-ID = {WOS:001673222200001},
}

@article{ WOS:001669354500001,
Author = {Forootani, Ali and Iervolino, Raffaele},
Title = {Asynchronous Federated Learning: A Scalable Approach for Decentralized
   Machine Learning},
Journal = {IEEE TRANSACTIONS ON SYSTEMS MAN CYBERNETICS-SYSTEMS},
Year = {2026},
Volume = {56},
Number = {3},
Pages = {2062-2075},
Month = {MAR},
Abstract = {Federated learning (FL) has emerged as a powerful paradigm for
   decentralized machine learning, enabling collaborative model training
   across diverse clients without sharing raw data. However, traditional FL
   approaches often face limitations in scalability and efficiency due to
   their reliance on synchronous client updates, which can result in
   significant delays and increased communication overhead, particularly in
   heterogeneous and dynamic environments. To address these challenges in
   this article, we propose an asynchronous FL (AFL) algorithm, which
   allows clients to update the global model independently and
   asynchronously. Our key contributions include a comprehensive
   convergence analysis of AFL in the presence of client delays and model
   staleness. By leveraging martingale difference sequence theory and
   variance bounds, we ensure robust convergence despite asynchronous
   updates. Assuming strongly convex local objective functions, we
   establish bounds on gradient variance under random client sampling and
   derive a recursion formula quantifying the impact of client delays on
   convergence. Furthermore, we demonstrate the practical applicability of
   the AFL algorithm by training decentralized linear regression and
   support vector machine (SVM)-based classifiers and compare its results
   with synchronous FL algorithm to effectively handle non-IID data
   distributed among clients. The proposed AFL algorithm addresses key
   limitations of traditional FL methods, such as inefficiency due to
   global synchronization and susceptibility to client drift. It enhances
   scalability, robustness, and efficiency in real-world settings with
   heterogeneous client populations and dynamic network conditions. Our
   results underscore the potential of AFL to drive advancements in
   distributed learning systems, particularly for large-scale,
   privacy-preserving applications in resource-constrained environments.},
Type = {Article},
Affiliation = {Forootani, A (Corresponding Author), Max Planck Inst Geoanthropol, D-07745 Jena, Germany.
   Forootani, Ali, Max Planck Inst Geoanthropol, D-07745 Jena, Germany.
   Forootani, Ali, UFZ Helmholtz Ctr Environm Res, D-04318 Leipzig, Germany.
   Iervolino, Raffaele, Univ Naples Federico II, Dept Elect Engn \& Informat Technol, I-80125 Naples, Italy.},
DOI = {10.1109/TSMC.2025.3648504},
EarlyAccessDate = {JAN 2026},
Keywords = {Convergence; Training; Delays; Federated learning; Data models;
   Classification algorithms; Synchronization; Data privacy; Stochastic
   processes; Real-time systems; Asynchronous federated learning (AFL);
   client drifts; deep neural networks; federated learning (FL); stochastic
   gradient descent (SGD)},
Author-Email = {aliforootani@ieee.org
   rafierv@unina.it},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001669354500001},
}

@article{ WOS:001674325500001,
Author = {Zhao, Yaju and Yuan, Hang and Zhang, Yinsheng and Tang, Minmin and Wang,
   Haiyan},
Title = {Window function-assisted MALDI-TOF MS data preprocessing combined with
   variables intersection and machine learning for classification analysis},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {266},
Month = {MAR 24},
Abstract = {This study enhances chemical analysis by integrating matrix-assisted
   laser desorption/ionization time-of-flight mass spectrometry (MALDI-TOF
   MS) with machine learning (ML) algorithms. While MALDI-TOF MS excels in
   sensitivity for food and medicine analysis, its complex mass spectra
   require advanced analysis techniques. We introduce a novel data-driven
   preprocessing pipeline that combines window function with variable
   intersection to classify Radix Bupleuri samples. This approach reduces
   data dimensionality, enhances feature sparsity, and improves intra-class
   sample correlation, addressing key challenges in high-dimensional MS
   data analysis. Common features selected through information gain,
   Chi-square, and least absolute shrinkage and selection operator were
   intersected to create datasets for support vector machine (SVM)
   classification. The SVM classifier achieved 96.7\% accuracy for wild and
   cultivated samples and 100\% for samples from three regions. This work
   advances MALDI-TOF MS data preprocessing by introducing a dual-metric
   optimization framework and demonstrates the power of variable
   intersection for robust feature selection. The proposed pipeline offers
   a scalable, high-accuracy solution for quality control and
   anti-counterfeiting in food and pharmaceutical industries, with broader
   applicability to chemical profiling of complex matrices.},
Type = {Article},
Affiliation = {Zhao, YJ (Corresponding Author), Zhejiang Gongshang Univ, Hangzhou 310018, Peoples R China.
   Zhao, Yaju; Yuan, Hang; Zhang, Yinsheng; Wang, Haiyan, Zhejiang Gongshang Univ, Hangzhou 310018, Peoples R China.
