   Ahmad, Muneer, Univ Malaya, Fac Comp Sci \& Informat Technol, Dept Informat Syst, Kaula Lumpur 50603, Malaysia.},
DOI = {10.3390/electronics9111756},
Article-Number = {1756},
Keywords = {air monitoring; internet of things; distributed fog computing; air
   quality; outlier detection},
Keywords-Plus = {EDGE; SIMULATION; SCENARIOS; CLOUD},
