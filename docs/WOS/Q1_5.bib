   Ghadi, Yazeed Yasin, Al Ain Univ, Dept Comp Sci \& Software Engn, Al Ain 12555, Abu Dhabi, U Arab Emirates.
   Alahmadi, Tahani Jaser, Princess Nourah bint Abdulrahman Univ, Coll Comp \& Informat Sci, Dept Informat Syst, Riyadh 84428, Saudi Arabia.},
DOI = {10.32604/cmc.2024.054780},
Keywords = {Cross-site scripting; machine learning; XSS detection; stacking ensemble
   learning; hybrid learning},
Author-Email = {tjalahmadi@pnu.edu.sa},
Number-of-Cited-References = {34},
Times-Cited = {6},
