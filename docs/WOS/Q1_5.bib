@article{ WOS:001702265400001,
Author = {Sun, Hai and Chen, Yuhan and Chu, Yanan and Liang, Bingchen},
Title = {A multi-scale deep learning framework for real-time post-earthquake
   damage estimation leveraging wavelet-driven GoogLeNet-FC},
Journal = {SOIL DYNAMICS AND EARTHQUAKE ENGINEERING},
Year = {2026},
Volume = {204},
Month = {MAY},
Abstract = {Earthquakes frequently cause extensive structural damage and economic
   losses, necessitating timely and accurate post-disaster assessment.
   However, existing methods either lack adaptability or are
   computationally intensive, limiting their real-time applicability.
   Conventional reliance on peak ground motion metrics further constrains
   predictive accuracy by neglecting the non-stationary,
   frequency-dependent characteristics of seismic signals. This study
   presents a rapid damage assessment framework that integrates wavelet
   transform with a GoogLeNet-FC deep convolutional neural network. A
   scenario database is constructed to include regional building
   inventories, seismic ground motion records, and annotated damage states.
   Seismic signals are converted into high-resolution spectrograms and
   combined with structural attributes to form multimodal inputs. The
   GoogLeNet-FC model leverages Inception modules for hierarchical
   multi-scale feature extraction, enabling accurate and scalable
   estimation of building damage across diverse seismic scenarios. A case
   study involving 718 buildings in Huizhou, China, shows the model
   achieves 96.2 \% overall accuracy. Notably, it improves classification
   for transitional damage levels, achieving F1 scores of 0.91 and 0.96 for
   the ``Slight{''} and ``Moderate{''} classes, respectively. Compared with
   conventional machine learning models, the proposed framework
   demonstrates superior performance, substantially improving the F1 score
   for challenging intermediate damage classes by over 140 \% relative to
   baseline models like SVM. Furthermore, the model exhibits high
   computational efficiency (0.1 s per building) and maintains low spatial
   residual autocorrelation (Moran's I = 0.21). The SHAP analysis validates
   the model's adherence to engineering principles, and the resulting
   fragility matrix closely matches empirical benchmarks, with an average
   deviation of 1.26 percentage points. These findings underscore the
   proposed framework's ability to deliver accurate, interpretable, and
   spatially consistent damage predictions, supporting real-time response
   and seismic resilience planning.},
Type = {Article},
Affiliation = {Liang, BC (Corresponding Author), Ocean Univ China, Coll Engn, Qingdao 266404, Peoples R China.
   Sun, Hai; Chen, Yuhan; Chu, Yanan; Liang, Bingchen, Ocean Univ China, Coll Engn, Qingdao 266404, Peoples R China.
   Sun, Hai, Ocean Univ China, Minist Educ, Key Lab Marine Environm \& Ecol, Qingdao 266100, Peoples R China.
   Sun, Hai, Western Sydney Univ, Sch Engn Design \& Built Environm, Sydney, NSW 2745, Australia.},
DOI = {10.1016/j.soildyn.2025.110084},
Article-Number = {110084},
Keywords = {Rapid seismic risk evaluation; Time-frequency representation;
   Multi-scale feature extraction; Deep convolutional neural network;
   Non-stationary signal characterization},
Keywords-Plus = {PREDICTION},
Author-Email = {h.sun3@westernsydney.edu.au
   yuhanchen@stu.ouc.edu.cn
   chuyanan@stu.ouc.edu.cn
   bingchen@ouc.edu.cn},
Number-of-Cited-References = {54},
