   Tortora, Genoveffa; Vitiello, Autilia, Univ Salerno, Dept Comp Sci, I-84084 Fisciano, Italy.},
DOI = {10.1016/j.knosys.2018.02.022},
Keywords = {Training set selection; Multi-objective optimization; Support vector
