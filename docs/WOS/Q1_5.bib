Unique-ID = {WOS:001621972500001},
}

@article{ WOS:001616260500046,
Author = {Maity, Tapan and Mondal, Ashok and Samanta, Jagannath and Saha, Prabir
   and Majumdar, Shubhankar and Srivastava, Gautam},
Title = {Real-Time Soil Hydration Assessment and Monitoring Model for Smart
   Agriculture With IoT Integration},
Journal = {IEEE SENSORS JOURNAL},
Year = {2025},
Volume = {25},
Number = {22},
Pages = {42243-42250},
Month = {NOV 15},
Abstract = {In modern agriculture, effective water management is a major concern,
   particularly in areas with unpredictable climates and water scarcity.
   Conventional irrigation methods often depend on manual observation,
   which can result in excessive or insufficient irrigation, which has a
   detrimental effect on crop productivity, soil health, and resource
   utilization. Real-time, accurate, and scalable methods for tracking soil
   hydration (SH) levels in a variety of agricultural fields are lacking.
   This article introduces an IoT-based SH estimation model (ISHEM) for
   smart agriculture, utilizing multiple linear regression (MLR) to
   estimate SH content in agricultural fields. The performance of proposed
   model is compared with commonly used machine learning (ML) algorithms
   such as adaptive boost (AdaBoost), random forest (RF), extreme gradient
   boost (XGBoost), and support vector machine (SVM) using various
   performance measure metrics such as the coefficient of determination
   (R-2), mean absolute error (MAE), mean square error (mse),
   root-mean-square error (RMSE), ratio between prediction to deviation
   (RPD), and ratio of performance to the interquartile distance (RPIQ).
   The ISHEM model demonstrates superior performance over existing ML
   algorithms by achieving lower values in key error metrics (MAE, MSE, and
   RMSE), as well as higher values in RPD and RPIQ. This developed model
   enables accurate estimation of SH content, which can play a crucial role
   in enhancing the efficiency and effectiveness of smart agriculture
   practices.},
