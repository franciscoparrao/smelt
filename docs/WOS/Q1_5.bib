DOI = {10.1016/j.asej.2025.103436},
EarlyAccessDate = {APR 2025},
Article-Number = {103436},
Keywords = {Deep Autoencoders; EEG signal processing; Chronic Neuropathic Pain;
   Machine learning; Neurophysiological Markers; Deep Neural Networks (DNN)},
Keywords-Plus = {IMPACT; PREVALENCE; MACHINE; NETWORK; ICA},
Author-Email = {umit.senturk@ibu.edu.tr},
