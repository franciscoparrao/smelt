}

@incollection{ WOS:000389384800025,
Author = {Hinami, Ryota and Satoh, Shin'ichi},
Editor = {Leibe, B and Matas, J and Sebe, N and Welling, M},
Title = {Large-Scale R-CNN with Classifier Adaptive Quantization},
Booktitle = {COMPUTER VISION - ECCV 2016, PT III},
Series = {Lecture Notes in Computer Science},
Year = {2016},
Volume = {9907},
Pages = {403-419},
Abstract = {This paper extends R-CNN, a state-of-the-art object detection method, to
   larger scales. To apply R-CNN to a large database storing thousands to
   millions of images, the SVM classification of millions to billions of
   DCNN features extracted from object proposals is indispensable, which
   imposes unrealistic computational and memory costs. Our method
   dramatically narrows down the number of object proposals by using an
   inverted index and efficiently searches by using residual vector
   quantization (RVQ). Instead of k-means that has been used in inverted
   indices, we present a novel quantization method designed for linear
   classification wherein the quantization error is re-defined for linear
   classification. It approximates the error as the empirical error with
   pre-defined multiple exemplar classifiers and captures the variance and
   common attributes of object category classifiers effectively.
   Experimental results show that our method achieves comparable
   performance to that of applying R-CNN to all images while achieving a
   250 times speed-up and 180 times memory reduction. Moreover, our
   approach significantly outperforms the state-of-the-art large-scale
   category detection method, with about a 40 similar to 58\% increase in
   top-K precision. Scalability is also validated, and we demonstrate that
   our method can process 100K images in 0.13 s while retaining precision.},
Type = {Proceedings Paper},
Affiliation = {Hinami, R (Corresponding Author), Univ Tokyo, Natl Inst Informat, Tokyo, Japan.
   Hinami, Ryota; Satoh, Shin'ichi, Univ Tokyo, Natl Inst Informat, Tokyo, Japan.},
DOI = {10.1007/978-3-319-46487-9\_25},
Keywords = {Image retrieval; Object detection; Image indexing},
Keywords-Plus = {APPROXIMATE NEAREST-NEIGHBOR},
Author-Email = {hinami@nii.ac.jp
   satoh@nii.ac.jp},
Number-of-Cited-References = {33},
Times-Cited = {3},
Unique-ID = {WOS:000389384800025},
}

@incollection{ WOS:000387067900024,
Author = {Lizarraga, Gabriel and Rojas, Niovi and Cabrerizo, Mercedes and
   Adjouadi, Malek and Duara, Ranjan and Loewenstein, David},
Book-Group-Author = {IEEE},
Title = {A Web Platform for Data Acquisition and Analysis for Alzheimer's Disease},
Booktitle = {SOUTHEASTCON 2016},
Series = {IEEE SoutheastCon-Proceedings},
Year = {2016},
Abstract = {This study introduces a new implementation of a Web Interface and Web
   Services for the automatic acquisition and processing of data for
   neurological studies, with a focus on Alzheimer's Disease (AD). Our Web
   Platform consists of (a) a Data Upload module that provides forms and
   web services to store volumetric and surface area measures, derived from
   MRI, to a MySQL database; (b) a Web Interface and Web Services for
   classification of AD, utilizing Support Vector Machines (SVM). The MRI
   is processed with FreeSurfer (FS); the FS output is also made available
   to the Web Interface user. Our classifier was trained and tested with
   data from the Alzheimer's Disease Neuroimaging Initiative (ADNI)
