   Adam, Tarek N., Weill Cornell Med Ctr, NYP, New York, NY 10065 USA.
   Adam, Nabil R., Rutgers State Univ, Off Chancellor, 123 Washington St, Newark, NJ 07102 USA.},
DOI = {10.1109/TBDATA.2016.2623323},
Keywords = {Diseases; Medical diagnostic imaging; Diabetes; Big data; Indexes;
   Sociology; Comorbidity conditions; cardiovascular disease; two-way
   clustering; weighted k-means clustering; model-based clustering;
   weighted observations},
Author-Email = {dg708@scarletmail.rutgers.edu
   xavier.cabrera@gmail.com
   tna9001@nyp.org
   PetrosLevounis@rutgers.edu
   adam@adam.rutgers.edu},
