   Henriksen, Amelia, Univ Texas Austin, Oden Inst, Austin, TX 78712 USA.
   Tropp, Joel A., CALTECH, Comp \& Math Sci, Pasadena, CA 91125 USA.
   Ward, Rachel, Univ Texas Austin, Dept Math, Austin, TX 78712 USA.},
DOI = {10.1137/21M144983X},
