@article{ WOS:001458681100001,
Author = {Akrom, Muhamad and Rustad, Supriadi and Sutojo, Totok and Setiadi, De
   Rosal Ignatius Moses and Andono, Pulung Nurtantio and Shidik, Guruh
   Fajar and Dipojono, Hermawan Kresno and Maezono, Ryo},
Title = {A novel quantum-enhanced model cascading approach based on support
   vector machine in blood-brain barrier permeability prediction},
Journal = {MATERIALS TODAY COMMUNICATIONS},
Year = {2025},
Volume = {45},
Month = {APR},
Abstract = {The proposed Quantum-Enhanced Model Cascading-Support Vector Machine
   (QEMC-SVM) integrates quantum transfer learning with classical SVM to
   enhance Blood-Brain Barrier Permeability (BBBP) binary classification
   performance by leveraging the strengths of both paradigms. Traditional
   SVM methods often suffer from performance degradation when handling
   high-dimensional and imbalanced datasets, while quantum-enhanced
   approaches like QSVM face hardware limitations. QEMC-SVM mitigates these
   issues by utilizing classical SVM predictions as an informative feature
   for QSVM, improving classification accuracy and computational
   efficiency. Our model effectively reduces dimensionality and improves
   margin optimization, outperforming standalone SVM and QSVM. Furthermore,
   integrating SMOTE+Tomek techniques significantly enhances accuracy and
   stability, particularly in handling imbalanced data distributions.
   Experimental results demonstrate that QEMC-SVM consistently achieves
   superior classification accuracy across benchmark and BBBP datasets.
   Future research will explore hybrid quantum-classical deep learning
   architectures to optimize performance and scalability further.},
Type = {Article},
Affiliation = {Akrom, M; Rustad, S (Corresponding Author), Univ Dian Nuswantoro, Fac Comp Sci, Res Ctr Quantum Comp \& Mat Informat, Semarang 50131, Indonesia.
   Akrom, Muhamad; Rustad, Supriadi; Sutojo, Totok; Setiadi, De Rosal Ignatius Moses, Univ Dian Nuswantoro, Fac Comp Sci, Res Ctr Quantum Comp \& Mat Informat, Semarang 50131, Indonesia.
