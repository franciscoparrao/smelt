@article{ WOS:001625417100004,
Author = {Martins, Alexandre and Rodrigues, Joao and Mateus, Balduino and Fonseca,
   Inacio and Farinha, Jose Torres},
Title = {A new adaptable data-driven model approach for applying predictive
   maintenance in industrial systems through confidence sphere and the
   HMM-SVM method},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {This paper presents a novel strategy in predictive maintenance for an
   industrial system by integrating statistical models, stochastic methods,
   and machine learning techniques in condition monitoring and predicting
   equipment health. Most of these models rely exclusively on either
   supervised or unsupervised learning and remain static once trained,
   which limits their adaptability to new operating conditions. Moreover,
   many industrial datasets lack ground-truth labels, making the direct
   application of supervised methods challenging. This paper addresses
   these gaps by presenting a novel strategy that combines statistical
   feature extraction to enhance the information, Principal Component
   Analysis (PCA) for dimensionality reduction, unsupervised learning
   through K-means clustering and Hidden Markov Models (HMM) to identify
   abnormal patterns in sensor data, and Support Vector Machines (SVM) for
   real-time supervised classification of health states. The integration of
   K-means enables the segmentation of the data into groups that represent
   observable operating conditions of the equipment. The confidence sphere
   technique acts as a dynamic alert mechanism, enabling the model to
   evolve with new operational behaviors. Applied to an industrial case
   study of a drying press in the paper industry, the framework achieved an
   accuracy of approximately 95\% in a supervised model used to classify
   the three equipment health states (Good Functioning, Alert, and
   Failure). By enabling continuous monitoring and automatic retraining
   through the Confidence Sphere, the methodology reduces downtime and
   maintenance costs while providing predictive insights. These results
   demonstrate the effectiveness, scalability, and adaptability of the
   proposed approach for predictive maintenance in Industry 4.0.},
Type = {Article},
Affiliation = {Martins, A (Corresponding Author), Lusofona Univ, Res Ctr Asset Management \& Syst Engn RCM2, P-1749024 Lisbon, Portugal.
   Martins, A (Corresponding Author), Univ Beira Interior, CISE Electromechatron Syst Res Ctr Portugal, Covilha, Portugal.
