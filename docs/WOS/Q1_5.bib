@article{ WOS:000335103500005,
Author = {Saha, S. and Aldeen, M.},
Title = {Generic scalable fault diagnosis system for multimachine power grids},
Journal = {INTERNATIONAL JOURNAL OF ELECTRICAL POWER \& ENERGY SYSTEMS},
Year = {2014},
Volume = {59},
Pages = {36-57},
Month = {JUL},
Abstract = {A new approach for fault diagnosis in power grids is presented in this
   paper. The approach is capable of detecting, classifying and locating,
   with high speed and accuracy, any type of faults anywhere in the grid
   using bus voltage or line current measurements only. Fault detection and
   classification is accomplished by applying logic on measured data while
   fault location is determined by fault location identification functions
   generated off-line by using a least-square support vector machine. The
   high speed and accuracy aspects' of the proposed approach are verified
   through case studies in three test power systems. (C) 2014 Elsevier Ltd.
   All rights reserved.},
