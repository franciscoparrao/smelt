   Durban Univ Technol, Soc Res Grp, POB 1334, ZA-4000 Durban, South Africa.},
DOI = {10.1016/j.eij.2017.10.002},
Keywords = {E-commerce; Eigenvector; Ensemble; Neural network; Recommendation;
   Support vector},
Keywords-Plus = {SUPPORT VECTOR MACHINES; NEURAL-NETWORKS; RETRIEVAL; SVM},
Author-Email = {21242711@DUT4life.ac.za
