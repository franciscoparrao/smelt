   Taylor, Matthew A., Univ Calgary, 2500 Univ Drive NW, Calgary, AB T2N 1N4, Canada.
   Miller, Bryan W., NSF NOIRLab, Int Gemini Observ, Casilla 603, La Serena, Chile.},
DOI = {10.1051/0004-6361/202556455},
