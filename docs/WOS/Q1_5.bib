Keywords = {Flavor prediction; Machine learning models; Deep learning models;
   Receptor-ligand modeling; Molecular representations; Explainable AI},
Keywords-Plus = {IN-SILICO PREDICTION; BIOPEP DATABASE; SWEETNESS; PEPTIDES; PUNGENCY;
   SEQUENCE; UMAMI; TASTE; IDENTIFICATION; BITTERNESS},
