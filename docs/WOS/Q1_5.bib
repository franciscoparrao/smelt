   Singh, Maninder, Punjabi Univ, Dept Comp Sci, Patiala, Punjab, India.},
DOI = {10.1142/S219688882150007X},
Keywords = {GWO; SVM; breast cancer; shared fitness; UCI dataset},
Keywords-Plus = {FEATURE-EXTRACTION; HYBRID},
Author-Email = {sunilkapoorldh@gmail.com
   singhmaninder25@yahoo.com},
Number-of-Cited-References = {48},
