@article{ WOS:000723020900016,
Author = {Zhou, Zhengzheng and Ren, Jie and He, Xiaogang and Liu, Shuguang},
Title = {A comparative study of extensive machine learning models for predicting
   long-term monthly rainfall with an ensemble of climatic and
   meteorological predictors},
Journal = {HYDROLOGICAL PROCESSES},
Year = {2021},
Volume = {35},
Number = {11},
Month = {NOV},
Abstract = {Rainfall prediction is of vital importance in water resources
   management. Accurate long-term rainfall prediction remains an open and
   challenging problem. Machine learning techniques, as an increasingly
   popular approach, provide an attractive alternative to traditional
   methods. The main objective of this study was to improve the prediction
   accuracy of machine learning-based methods for monthly rainfall, and to
   improve the understanding of the role of large-scale climatic variables
   and local meteorological variables in rainfall prediction. One
   regression model autoregressive integrated moving average model (ARIMA)
   and five state-of-the-art machine learning algorithms, including
   artificial neural networks, support vector machine, random forest (RF),
   gradient boosting regression, and dual-stage attention-based recurrent
   neural network, were implemented for monthly rainfall prediction over 25
   stations in the East China region. The results showed that the ML models
   outperformed ARIMA model, and RF relatively outperformed other models.
   Local meteorological variables, humidity, and sunshine duration, were
   the most important predictors in improving prediction accuracy. 4-month
   lagged Western North Pacific Monsoon had higher importance than other
   large-scale climatic variables. The overall output of rainfall
   prediction was scalable and could be readily generalized to other
   regions.},
Type = {Article},
Affiliation = {Zhou, ZZ (Corresponding Author), Tongji Univ, Dept Hydraul Engn, Shanghai, Peoples R China.
   Zhou, Zhengzheng; Liu, Shuguang, Tongji Univ, Dept Hydraul Engn, Shanghai, Peoples R China.
   Ren, Jie, Huawei Technol Co Ltd, Algorithm \& Technol Dev Dept, Shanghai, Peoples R China.
   He, Xiaogang, Natl Univ Singapore, Dept Civil \& Environm Engn, Singapore, Singapore.
   He, Xiaogang, Stanford Univ, Woods Inst Environm, Water West, Stanford, CA 94305 USA.},
DOI = {10.1002/hyp.14424},
Article-Number = {e14424},
Keywords = {climatic and meteorological predictors; machine learning; monthly
   rainfall prediction},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; ASIAN SUMMER MONSOON; TIME-SERIES;
   INTELLIGENCE METHODS; AUSTRALIAN RAINFALL; SEASONAL RAINFALL;
   REGRESSION-MODEL; PRECIPITATION; PERFORMANCE; CALIFORNIA},
Author-Email = {19058@tongji.edu.cn},
