DOI = {10.1049/trit.2019.0054},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; WEATHER PREDICTION},
Author-Email = {jus.kocijan@ijs.si},
Number-of-Cited-References = {19},
