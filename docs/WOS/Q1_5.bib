   Almasi, Omid Naghash, Cammisa \& Wipf Consulting Engineers, 642 Harrison St,4th Floor, San Francisco, CA 94107 USA.},
DOI = {10.1016/j.mlwa.2021.100025},
Article-Number = {100025},
Keywords = {Support vector machine; Delaunay triangulation; Geometric method; Large
   datasets},
Keywords-Plus = {MODEL SELECTION; VECTOR MACHINES; SET SELECTION; CLASSIFICATION; CONVEX;
   DECOMPOSITION},
