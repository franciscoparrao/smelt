@article{ WOS:001446088900001,
Author = {Daoudi, Nawal and Zaki, Smail and Aboussaleh, Mohamed},
Title = {Predictive maintenance system for screw compressors using machine
   learning: a comparative study},
Journal = {INTERNATIONAL JOURNAL OF ADVANCED MANUFACTURING TECHNOLOGY},
Year = {2025},
Volume = {137},
Number = {7-8},
Pages = {3695-3708},
Month = {APR},
Abstract = {Maintaining the operational efficiency and reliability of any industrial
   system is mandatory to minimize downtime and prevent failures. For this
   purpose, forecasting the evolution of key operational parameters such as
   temperature is essential. Hence, for this work, we have considered the
   temperature at the compressor's screw element outlet. Given its
   criticality, this parameter is continuously monitored, as besides its
   operational role, it is considered a safety indicator for avoiding
   thermal events; moreover, it does not require any significant
   investment. In this paper, we will present a comparison between four
   machine-learning models for predicting this parameter. We have
   considered using regression models, i.e., Linear Regression, K-Nearest
   Neighbors, Support Vector Machine, and Gradient Boosting Machine (GBM).
   After the first steps which include data cleaning and preprocessing,
   feature selection using the correlation analysis and feature importance
   techniques, the models were trained and evaluated using key metrics:
   mean squared error (MSE), root mean squared error (RMSE), mean absolute
   error (MAE), R-squared (R2), and mean absolute percentage error (MAPE).
   Among the tested models, the GBM has proven a superior performance,
   explaining, and forecasting 92\% of the variance in the temperature at
   the screw element outlet and achieving the lowest error. Furthermore, A
   residual analysis confirmed the robustness of the GBM, highlighting its
   ability to make accurate predictions with minimal bias. This level of
   accuracy is considered sufficient through academic as well as industrial
   lenses. Whereas many studies are based on benchmark datasets, this work
   is based on real sensor data collected from industrial screw compressors
   to make maintenance planning relevant to the real world. The proposed
   framework is designed to be computationally efficient and scalable for
   real-time application on industrial edge devices. Accurately predicting
   the outlet temperature is crucial for developing an effective predictive
   maintenance system, which can proactively prevent failures and optimize
   compressor performance. Future work focuses on hyperparameter tuning and
   advanced feature engineering to improve model accuracy and robustness
   for real-time industrial applications. Additionally, by extending the
   scope of this approach to integrate other equipment, as the compressor
   is not an isolated machine in the industry but lives in an Ecosystem
   under the utility room, we can ensure the scalability, the integration,
   and the real-time processing capabilities.},
