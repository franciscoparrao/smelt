   Bamane, Kalyan Devappa, DY Patil Coll Engn, Dept Comp Engn, Pune, India.
   Bendre, Mininath, Pravara Rural Engn Coll, Dept Comp Engn, Loni, MH, India.},
DOI = {10.1007/s44196-025-00827-2},
Article-Number = {104},
Keywords = {Feature selection; ICS; Genetic Algorithm; Filter-based methods;
   Embedded methods; Classification},
Keywords-Plus = {CLASSIFICATION; CHALLENGES},
