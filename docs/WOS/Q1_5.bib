   Chang, Chein-, I, Providence Univ, Dept Comp Sci \& Informat Management, Taichung 02912, Taiwan.},
DOI = {10.1109/TGRS.2021.3085801},
EarlyAccessDate = {JUN 2021},
Keywords = {Support vector machines; Kernel; Detectors; Training; Hyperspectral
   imaging; Minimization; Iterative methods; 3-D receiver operating
   characteristic (3-D ROC); constrained energy minimization (CEM);
   hyperspectral image classification (HSIC); hyperspectral mixed pixel
   classification (HMPC); kernel CEM (KCEM); kernel LCMV (KLCMV); linearly
   constrained minimum variance (LCMV)},
Keywords-Plus = {SPECTRAL-SPATIAL CLASSIFICATION; IMAGE CLASSIFICATION; NYSTROM METHOD;
   FEATURE-EXTRACTION; ALGORITHM; NETWORK},
Author-Email = {kennethma1619@gmail.com},
