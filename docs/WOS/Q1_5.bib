   Shetty, Amba, Natl Inst Technol Karnataka, Dept Water Resource \& Ocean Engn, Surathkal, India.},
DOI = {10.1016/j.cageo.2024.105733},
EarlyAccessDate = {OCT 2024},
Article-Number = {105733},
Keywords = {Fractal dimension; Dimensionality reduction; Intrinsic dimension;
   Hyperspectral imagery; Support vector machine},
Keywords-Plus = {INDEPENDENT COMPONENT ANALYSIS; BAND SELECTION; SIMILARITY},
