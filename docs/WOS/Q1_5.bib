@incollection{ WOS:000263294500033,
Author = {Li, Yan and Hung, Edward and Chung, Korris and Huang, Joshua},
Editor = {Wobcke, W and Zhang, M},
Title = {Building a Decision Cluster Classification Model for High Dimensional
   Data by a Variable Weighting k-Means Method},
Booktitle = {AI 2008: ADVANCES IN ARTIFICIAL INTELLIGENCE, PROCEEDINGS},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2008},
Volume = {5360},
Pages = {337+},
Abstract = {In this paper, a now classification method (ADCC) for high dimensional
   data is proposed. In this method, a decision cluster classification
   model (DCC) consists of a set of disjoint decision clusters, each
   labeled with a dominant class that determines the class of new objects
   falling in the cluster. A cluster tree is first generated from a
   training data set by recursively calling a variable weighting k-means
   algorithm. Then, the DCC model is selected from the tree.
   Anderson-Darling test is used to determine the stopping condition of the
   tree growing. A series of experiments on both synthetic and real data
   sets have shown that the new classification method (ADCC) performed
   better in accuracy and scalability than the existing methods of k-NN,
   decision tree and SVM. It is particularly suitable for large, high
   dimensional data with many classes.},
Type = {Proceedings Paper},
Affiliation = {Li, Y (Corresponding Author), Hong Kong Polytech Univ, Dept Comp, Hong Kong, Hong Kong, Peoples R China.
   Li, Yan; Hung, Edward; Chung, Korris, Hong Kong Polytech Univ, Dept Comp, Hong Kong, Hong Kong, Peoples R China.
