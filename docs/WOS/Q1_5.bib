@article{ WOS:001722000400001,
Author = {Jin, Chen},
Title = {Optimizing crop yield prediction in precision agriculture using random
   forest and particle swarm optimization: A data-driven approach to
   sustainable farming},
Journal = {SUSTAINABLE COMPUTING-INFORMATICS \& SYSTEMS},
Year = {2026},
Volume = {50},
Month = {JUN},
Abstract = {Crop yield prediction stands as a pertinent factor when accounting for
   food securities and sustainable agriculture amidst climate variability
   and population pressure. Several regression models such as SVM, MLP, and
   CNN-RNN suffer from the drawback of being poorly generalized and
   inadequately hyperparameter-tuned, hence putting a limit on the
   performance and scalability of these models. With the goal of bypassing
   these challenges, this research puts forth the idea of a hybrid model
   wherein a Random Forest is combined with Particle Swarm Optimization to
   achieve higher prediction accuracies and model efficiencies. The
   uniqueness of this method rests on taking advantage of PSO to optimize
   hyperparameters dynamically and efficiently, thus while circumventing
   grid search, which is time-consuming, it also has the benefit of
   enhanced convergence speed. With RMSE = 0.20, MAE = 0.18, R2 = 0.98, and
   MAPE = 3.20\%, the RF-PSO model has produced good results based on the
   Crop Yield Prediction Dataset, significantly outperforming the baseline
   techniques such as SVM (RMSE = 0.37), RFXG (0.22), and CNN-RNN (21.69
   +/- 3.10). Error distribution graphs, feature importance displays, and
   performance comparison charts all confirm the model's sturdiness with
   rainfall, temperature, and soil type identified as the chief predictive
   characteristics. Unlike other contemporary models, the RF-PSO guarantees
   high generalizability, low prediction errors, and practical utility in
   various agricultural settings. It is demonstrated by this study that
   RF-PSO is a scalable, interpretable, high-performance solution for
   precision agriculture and presents actionable insights to agronomists
   and decision-makers, while paving the way for prospective enhancements
   via multi-objective PSO, hybrid optimization, and explainable AI.},
Type = {Article},
Affiliation = {Jin, C (Corresponding Author), Huangshan Univ, Sch Econ \& Management, Huangshan 245021, Peoples R China.
   Jin, Chen, Huangshan Univ, Sch Econ \& Management, Huangshan 245021, Peoples R China.},
DOI = {10.1016/j.suscom.2026.101336},
Article-Number = {101336},
Keywords = {Crop Yield Prediction; Random Forest; Particle Swarm Optimization;
   Precision Agriculture; Regression Optimization},
Author-Email = {jinchen1107@hotmail.com},
Number-of-Cited-References = {23},
Times-Cited = {0},
Unique-ID = {WOS:001722000400001},
}

@article{ WOS:001709420600001,
Author = {Henna, Shagufta and Rathnayake, Upaka},
Title = {Fast-gradient-guided generative adversarial learning for explainable
   cyber threat intelligence},
Journal = {APPLIED SOFT COMPUTING},
Year = {2026},
Volume = {194},
Month = {MAY},
Abstract = {The rapid evolution of Domain Generation Algorithm (DGA)-driven attacks
   and obfuscated DNS traffic ex poses fundamental weaknesses in
   conventional machine learning-based threat detection systems,
   particularly under adversarial manipulation. This study introduces
   FGM-GAN, a hybrid adversarial learning framework that synergistically
   combines gradient-based Fast Gradient Method (FGM) perturbations with
   adaptive Generative Adversarial Network (GAN)-based perturbations to
   improve both robustness and interpretability of deep neural networks for
   DNS threat classification. Unlike existing adversarial defenses that
   rely on model-specific perturbations, FGM-GAN explicitly learns
   class-conditional adversarial distributions for benign, phishing, and
   malware domains. This design enables the generation of realistic,
   feature-aligned perturbations that exhibit strong cross-model
   transferability. Experiments were conducted on the 32-feature
   CIC-BELL-DNS-2021 dataset (approximately 7000 labeled samples) using
   5fold cross-validation, hybrid perturbations with alpha = 0.5 and
   epsilon <= 0.1, and evaluated against baseline DNN, SVM, Random Forest,
   KNN, and Decision Tree classifiers using accuracy and robustness
   metrics. Comprehensive evaluation demonstrates that FGM-GAN consistently
   improves robustness across diverse ad versarial attacks (FGM, PGD, MIM,
   C\&W) while maintaining stable performance across folds. Ablation
   studies and reduced-capacity variants confirm that gains arise from the
   hybrid adversarial mechanism rather than over-parameterization or
   hyperparameter tuning, and statistical significance tests verify the
   reproducibility of results. To enhance transparency and operational
   trust, the framework integrates multi-level explainable AI analyses span
   ning feature, neuron, and layer representations. These analyses
   consistently identify a compact set of high-impact DNS features and
   reveal structured adversarial propagation patterns, showing that
   robustness emerges from se mantically meaningful representation
   learning. Collectively, these findings position FGM-GAN as a scalable
   and interpretable adversarial learning solution that jointly addresses
   robustness, transferability, and explainability in real-world DNS-based
   cybersecurity environments.},
Type = {Article},
Affiliation = {Henna, S (Corresponding Author), Atlantic Technol Univ, Dept Comp, Donegal, Ireland.
   Henna, Shagufta, Atlantic Technol Univ, Dept Comp, Donegal, Ireland.
   Rathnayake, Upaka, Atlantic Technol Univ, Dept Civil Engn \& Construct, Sligo, Ireland.},
DOI = {10.1016/j.asoc.2026.114911},
Article-Number = {114911},
Keywords = {Explainable AI; Adversarial machine learning; Domain generation
   algorithms; Generative adversarial networks; Fast gradient method; Cyber
   threat intelligence; Model transparency},
Keywords-Plus = {NETWORKS; ATTACKS; DEFENSE},
Author-Email = {shagufta.henna@atu.ie},
Number-of-Cited-References = {42},
Times-Cited = {0},
Unique-ID = {WOS:001709420600001},
}

@article{ WOS:001721518100001,
Author = {Ioannou, Iacovos and Mufti, Gusan and Christophorou, Christophoros and
   Klitis, Charalambos and Vassiliou, Vasos and Verikoukis, Christos},
Title = {A novel two-stage distributed radio resource allocation framework using
   deep machine learning in 6G cell-free dynamic communication networks},
Journal = {COMPUTER NETWORKS},
Year = {2026},
Volume = {281},
Month = {MAY},
Abstract = {Dense wireless networks, especially in 5G mMTC and eMBB scenarios, face
   significant challenges including limited FBs, high interference, and
   increased power consumption, particularly under UE mobility. These
   issues intensify in emerging 6G Cell-Free dynamic architectures where
   traditional cell boundaries are eliminated. To address these problems,
   we propose a novel two-stage framework that integrates deep clustering
   with deep MLP-based classification for intelligent, interference-aware
   FB allocation in networks scaling up to 1000 UEs. In the first stage,
   the clustering component evaluates multiple methods-KMeans, DEC, iDEC,
   and DeepClusterfor grouping UEs and selecting UE-Relays that act as
   distributed access points. DeepCluster demonstrates superior
   performance, achieving the highest sum-rate (2323.37 Mbps) at the lowest
   power consumption (228.68 W) with best clustering quality metrics
   (Silhouette 0.3350, DBI 0.9723, CH 1016.91). The optimal number of
   clusters is dynamically selected using the silhouette score, DBI, and CH
   index, ensuring adaptive clustering that responds to varying network
   density. A fully connected autoencoder compresses high-dimensional UE
   data into a compact latent space enhanced with a Student's
   t-distribution clustering layer, learning representations that naturally
   separate interference-prone UE groups. In the second stage, an
   ``in-out{''} cyclic FB assignment strategy allocates spectrum resources
   efficiently while generating training labels for supervised classifiers.
   Features including UE spatial coordinates, SINR, estimated data rate,
   and cluster labels are extracted to train FB prediction models. Among
   the evaluated classifiers-Random Forest, SVM, baseline MLP, and deep
   MLP-the deep MLP achieved the highest accuracy (99.90\%), followed by
   Random Forest (99.12\%), SVM with RBF kernel (98.23\%), and Baseline MLP
   (97.79\%). Critically, inference latencies are sub-millisecond per UE
   decision and remain below 0.1 s for batched inference over 1000 UEs,
   enabling real-time resource allocation decisions. To handle UE mobility
   without service interruption, we adapt DeepCluster for online/streaming
   operation using EMA centroid tracking and Hebbian encoder updates every
   100 ms. This enables real-time adaptation to dynamic network conditions
   without requiring costly full retraining. Our comprehensive evaluation
   under 3GPP-compliant channel models demonstrates that the framework
   delivers energy efficiency of 10.16 Mbps/W, outperforming KMeans (8.71),
   DEC (8.65), and iDEC (8.38). The key mechanism underlying these gains is
   the learned latent geometry, which compacts intra-cluster distances and
   widens inter-cluster gaps. This geometric property reduces path loss
   within clusters and co-channel interference between clusters, thereby
   improving SINR and overall network efficiency. Our framework provides a
   scalable, energy-efficient, and interference-aware radio resource
   management solution well-suited for dense 6G Cell-Free dynamic networks.},
Type = {Article},
Affiliation = {Ioannou, I (Corresponding Author), Philips Univ, Dept Comp Sci, Nicosia, Cyprus.
