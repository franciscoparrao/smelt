Keywords = {Human motion recognition; Fuzzy comprehensive evaluation; Physical
   performance; Intelligent assessment; Multi-sensor fusion},
Keywords-Plus = {PHYSICAL-EDUCATION; FRAMEWORK},
Author-Email = {pnytao@gmail.com},
