@article{ WOS:001578821100001,
Author = {Mahanta, Bashista Kumar and Rawat, Pankaj and Kumar, Sanjeev and Singh,
   Vivek Kumar and Singh, Shailesh Kumar},
Title = {Experimental and machine learning approaches to phase prediction in high
   entropy alloy and medium entropy alloy},
Journal = {MATERIALS CHEMISTRY AND PHYSICS},
Year = {2026},
Volume = {347},
Month = {JAN 1},
Abstract = {In recent years, High-Entropy Alloys (HEAs) have garnered significant
   attention due to their multi-principal element design and vast
   compositional flexibility, enabling the formation of diverse phases such
   as solid solutions (SS), intermetallic compounds (IM), Laves phases, and
   their combinations. Phase formation critically governs the physical and
   mechanical properties of HEAs, making accurate phase prediction
   essential for alloy design. Traditionally, Density Functional Theory
   (DFT) and thermodynamic models have been employed to evaluate phase
   stability; however, these approaches can be computationally intensive
   for complex systems. In this study, machine learning (ML) techniques are
   applied for phase prediction in HEAs, offering a faster and scalable
   alternative. Various ML algorithms-including Support Vector Machines
   (SVM), Random Forests (RF), Deep Neural Networks (DNN), Extreme Gradient
   Boosting (XGBoost), and Logistic Regression-are trained on curated
   datasets comprising experimentally validated HEA compositions and their
   corresponding phases. Among the tested models, DNN and XGBoost
   demonstrated superior predictive performance, achieving classification
   accuracies exceeding 95 \%. These models were further validated against
   experimentally synthesized HEAs, with predicted phases closely matching
   the observed results. The findings highlight the potential of advanced
   ML algorithms in accelerating phase prediction and guiding the discovery
   of novel HEAs with tailored properties.},
Type = {Article},
Affiliation = {Singh, SK (Corresponding Author), CSIR Indian Inst Petr, Climate Change \& Data Sci, Dehra Dun 248005, India.
   Mahanta, Bashista Kumar; Rawat, Pankaj; Kumar, Sanjeev; Singh, Shailesh Kumar, CSIR Indian Inst Petr, Climate Change \& Data Sci, Dehra Dun 248005, India.
   Kumar, Sanjeev; Singh, Shailesh Kumar, Acad Sci \& Innovat Res AcSIR, Ghaziabad 201002, India.
   Singh, Vivek Kumar, Indian Inst Technol, Dept Mech Engn, Mumbai 400076, India.},
DOI = {10.1016/j.matchemphys.2025.131403},
EarlyAccessDate = {AUG 2025},
Article-Number = {131403},
Keywords = {High-entropy alloys; Phase prediction; Machine learning; Microstructure;
   XRD validation; Medium-entropy alloys},
Keywords-Plus = {CLASSIFICATION; SELECTION; DESIGN},
