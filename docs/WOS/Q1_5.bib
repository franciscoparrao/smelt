Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2022},
Abstract = {In this paper, we formulate a new generalized reference kernel hoping to
   improve the original base kernel using a set of reference vectors.
   Depending on the selected reference vectors, our formulation shows
   similarities to approximate kernels, random mappings, and Non-linear
   Projection Trick. Focusing on small-scale one-class classification, our
