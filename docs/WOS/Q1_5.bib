   Li, Wangcheng, Beijing Normal Univ, Sch Stat, Beijing 100086, Peoples R China.
   Chen, Canyi, Univ Michigan, Dept Biostat, Ann Arbor, MI 48109 USA.},
DOI = {10.1093/biomtc/ujag003},
Article-Number = {ujag003},
Keywords = {classification error; convolution-smoothing; distributed learning;
