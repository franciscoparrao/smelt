   Lu, Feng, Jiangsu Ctr Collaborat Innovat Geog Informat Reso, Nanjing, Jiangsu, Peoples R China.},
DOI = {10.1007/978-3-319-45835-9\_23},
Keywords = {City traffic; Geospatial data; Ensemble learning; Stacked
