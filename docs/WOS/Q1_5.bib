@article{ WOS:001576792400038,
Author = {Zhu, Ping and Chen, Yating and Wang, Miaomiao and Liu, Shuge and Tan,
   Yushuo and Yuan, Yuxuan and Du, Liping and Wu, Chunsheng},
Title = {An in vivo bioelectronic nose utilizing support vector
   machine techniques for quantitative assessment of the odor detection
   performance},
Journal = {CHEMICAL ENGINEERING JOURNAL},
Year = {2025},
Volume = {523},
Month = {NOV 1},
Abstract = {The biological olfactory system-based in vivo bioelectronic nose (BEN)
   exhibits significant advantages in terms of sensitivity, selectivity,
   and response time. This study presents a methodology that integrates
   principal component analysis (PCA) with support vector machine (SVM)
   techniques to facilitate the classification and prediction of odorants
   within in vivo BEN systems. A bioengineered in vivo BEN system was
   created through the overexpression of the olfactory receptor OR3, aimed
   at enhancing the specificity of odor detection in targeted environments.
   The performance of two distinct in vivo BEN systems was quantitatively
   assessed and compared utilizing SVM. The developed system demonstrated
   robust multi-class discrimination capabilities, achieving accurate
   classification of single odorants across varying concentrations (10-3 to
   10-13 M) with strong linear correlation (R2 = 0.97) between predicted
   and actual concentrations. The BEN system incorporating novel sensitive
   elements exhibited 7 \% higher classification accuracy for 6 odors,
   along with stable odor discrimination for 40 days post-implantation. The
   PCA-SVM framework outperformed conventional classifiers in
   cross-validation tests and achieved 70 \% classification accuracy under
   background interference. These advancements establish a scalable
   platform for real-world odorant analysis. Future validation in complex
   environmental/clinical settings is warranted to confirm its efficacy in
   applied scenarios such as environmental monitoring and precision
   diagnostics.},
Type = {Article},
Affiliation = {Du, LP; Wu, CS (Corresponding Author), Xi An Jiao Tong Univ, Sch Basic Med Sci, Inst Med Engn, Dept Biophys,Hlth Sci Ctr, Xian, Peoples R China.
   Zhu, Ping; Chen, Yating; Wang, Miaomiao; Liu, Shuge; Tan, Yushuo; Yuan, Yuxuan; Du, Liping; Wu, Chunsheng, Xi An Jiao Tong Univ, Sch Basic Med Sci, Inst Med Engn, Dept Biophys,Hlth Sci Ctr, Xian, Peoples R China.
   Zhu, Ping, Chinese Acad Sci, Inst Automat, Lab Brain Atlas \& Brain Inspired Intelligence, Beijing, Peoples R China.},
DOI = {10.1016/j.cej.2025.168346},
EarlyAccessDate = {SEP 2025},
Article-Number = {168346},
Keywords = {Bioelectronic nose; Support vector machine; Pattern recognition; Odor
   classification; Olfactory bulb},
Keywords-Plus = {MICE},
Author-Email = {duliping@xjtu.edu.cn
   wuchunsheng@xjtu.edu.cn},
