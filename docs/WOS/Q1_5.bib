DOI = {10.1109/ACCESS.2024.3417176},
Keywords = {Skin; Generative adversarial networks; Lesions; Data models; Melanoma;
   Electronic healthcare; Data augmentation; Machine learning; Scalability;
   Deep learning; health data poverty; machine learning; scalability;
   digital health; GAN},
Keywords-Plus = {GENERATIVE ADVERSARIAL NETWORKS; GAN; SEGMENTATION; AUGMENTATION;
