   Ezhilarasi, K., Dr Dharmambal Govt Polytech Coll Women, Dept Comp Engn, Chennai 600113, Tamil Nadu, India.},
DOI = {10.1016/j.knosys.2025.114611},
EarlyAccessDate = {OCT 2025},
Article-Number = {114611},
Keywords = {Quantum machine learning; Min-max normalization; Inception
   attentional-based VGG; Parameterized quantum circuits},
Author-Email = {sudha16121990@gmail.com},
Number-of-Cited-References = {44},
