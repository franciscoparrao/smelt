   Yan, Han; Xu, Chang, Fujian Jinhua Integrated Circuit Co Ltd, Quanzhou 362200, Fujian, Peoples R China.},
DOI = {10.1016/j.eswa.2026.131994},
Article-Number = {131994},
Keywords = {Industrial production environment; Multiple representation; Item-wise
   layering; Open-world learning; Known-class image classification;
   Novel-class image detection},
Keywords-Plus = {DEFECT PATTERNS; BIN MAP; RECOGNITION; IDENTIFICATION; SYSTEM; YIELD;
   MODEL; TRIM},
Author-Email = {xrliu@xmu.edu.cn
   xander.xu@jhicc.com},
