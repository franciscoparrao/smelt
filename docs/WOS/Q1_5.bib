   Alshammari, Ali Hussein; Ali, Almashhadani Hasnain, Minist Higher Educ \& Sci Res, Baghdad 10001, Iraq.},
DOI = {10.3390/a19010037},
Article-Number = {37},
Keywords = {classification algorithms; supervised learning; k-nearest neighbors;
   support vector machine; decision tree; random forests; logistic
   regression; Na \& iuml;ve Bayes; methodological review},
Keywords-Plus = {SUPPORT VECTOR MACHINE; FINITE-SAMPLE ANALYSIS; DECISION TREES; NAIVE
