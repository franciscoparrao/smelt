   Ismanto, Rido Dwi, Natl Res \& Innovat Agcy BRIN, Res Ctr Comp, Jl Raya Bogor KM 46, Cibinong 16911, Indonesia.},
DOI = {10.1016/j.jag.2025.104965},
EarlyAccessDate = {NOV 2025},
