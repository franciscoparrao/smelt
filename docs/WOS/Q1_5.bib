@incollection{ WOS:000457750200032,
Author = {Sedghi, Mahlagha and Huang, Yinjie and Georgiopoulos, Michael and
   Anagnostopoulos, Georgios},
Book-Group-Author = {IEEE},
Title = {Multi-label Learning via Codewords},
Booktitle = {2018 IEEE 30TH INTERNATIONAL CONFERENCE ON TOOLS WITH ARTIFICIAL
   INTELLIGENCE (ICTAI)},
Series = {Proceedings-International Conference on Tools With Artificial
   Intelligence},
Year = {2018},
Pages = {221-228},
Abstract = {In this paper, we introduce a novel hash learning framework for
   multi-label learning which employs structured prediction. A hash
   function is learned to embed samples in Hamming spaces, and for each
   label, a pair of codewords are simultaneously inferred from the
   available data. These codewords are then used to determine label
   predictions based on Hamming proximity. The key advantage of this
   framework is it's computational efficiency in tackling multi-label
   problems without making restrictive, simplifying assumptions about the
   structure of the output space, or developing problem-dependent
   heuristics. Our method not only enjoys considerably better scalability
   while capturing label inter-dependence, but also yields an exact
   training algorithm. Experimental results on a collection of benchmark
   multi-label datasets demonstrate that our model attains higher
   performance over alternative state-of-the-art multi-label approaches. It
   is also worth noting that our method can be extended to semi-supervised
   and missing labels scenarios.},
Type = {Proceedings Paper},
Affiliation = {Sedghi, M (Corresponding Author), Univ Cent Florida, Dept Elect \& Comp Engn, Orlando, FL 32816 USA.
   Sedghi, Mahlagha; Huang, Yinjie; Georgiopoulos, Michael, Univ Cent Florida, Dept Elect \& Comp Engn, Orlando, FL 32816 USA.
   Anagnostopoulos, Georgios, Florida Inst Technol, Dept Elect \& Comp Engn, Melbourne, FL 32901 USA.},
DOI = {10.1109/ICTAI.2018.00042},
Keywords = {Multi-label Learning; Hash Function Learning; Structured Output
   Prediction; Structured Support Vector Machine},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {mahlagha.s@knights.ucf.edu
