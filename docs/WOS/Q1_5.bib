   Wang, Shaojun; Niu, Xinyu; Luk, Wayne, Imperial Coll London, London SW7 2NZ, England.
   Leong, Philip, Univ Sydney, Sydney, NSW 2006, Australia.},
DOI = {10.1007/978-3-319-30481-6\_9},
Keywords-Plus = {SUPPORT VECTOR MACHINES; FPGA},
