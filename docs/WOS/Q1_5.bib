@article{ WOS:001056479400024,
Author = {Lagerberg, Tyra and Virtanen, Suvi and Kuja-Halkola, Ralf and Hellner,
   Clara and Lichtenstein, Paul and Fazel, Seena and Chang, Zheng},
Title = {Predicting risk of suicidal behaviour after initiation of selective
   serotonin reuptake inhibitors in children, adolescents and young adults:
   protocol for development and validation of clinical prediction models},
Journal = {BMJ OPEN},
Year = {2023},
Volume = {13},
Number = {8},
Month = {AUG},
Abstract = {Introduction There is concern regarding suicidal behaviour risk during
   selective serotonin reuptake inhibitor (SSRI) treatment among the young.
   A clinically useful model for predicting suicidal behaviour risk should
   have high predictive performance in terms of discrimination and
   calibration; transparency and ease of implementation are
   desirable.Methods and analysis Using Swedish national registers, we will
   identify individuals initiating an SSRI aged 8-24 years 2007-2020. We
   will develop: (A) a model based on a broad set of predictors, and (B) a
   model based on a restricted set of predictors. For the broad predictor
   model, we will consider an ensemble of four base models: XGBoost (XG),
   neural net (NN), elastic net logistic regression (EN) and support vector
   machine (SVM). The predictors with the greatest contribution to
   predictive performance in the base models will be determined. For the
   restricted predictor model, clinical input will be used to select
   predictors based on the top predictors in the broad model, and inputted
   in each of the XG, NN, EN and SVM models. If any show superiority in
   predictive performance as defined by the area under the
   receiver-operator curve, this model will be selected as the final model;
   otherwise, the EN model will be selected. The training and testing
   samples will consist of data from 2007 to 2017 and from 2018 to 2020,
   respectively. We will additionally assess the final model performance in
   individuals receiving a depression diagnosis within 90 days before SSRI
   initiation. The aims are to (A) develop a model predicting suicidal
   behaviour risk after SSRI initiation among children and youths, using
   machine learning methods, and (B) develop a model with a restricted set
   of predictors, favouring transparency and scalability.Methods and
   analysis Using Swedish national registers, we will identify individuals
   initiating an SSRI aged 8-24 years 2007-2020. We will develop: (A) a
   model based on a broad set of predictors, and (B) a model based on a
   restricted set of predictors. For the broad predictor model, we will
   consider an ensemble of four base models: XGBoost (XG), neural net (NN),
   elastic net logistic regression (EN) and support vector machine (SVM).
   The predictors with the greatest contribution to predictive performance
   in the base models will be determined. For the restricted predictor
   model, clinical input will be used to select predictors based on the top
   predictors in the broad model, and inputted in each of the XG, NN, EN
   and SVM models. If any show superiority in predictive performance as
   defined by the area under the receiver-operator curve, this model will
   be selected as the final model; otherwise, the EN model will be
   selected. The training and testing samples will consist of data from
   2007 to 2017 and from 2018 to 2020, respectively. We will additionally
   assess the final model performance in individuals receiving a depression
   diagnosis within 90 days before SSRI initiation. The aims are to (A)
   develop a model predicting suicidal behaviour risk after SSRI initiation
   among children and youths, using machine learning methods, and (B)
   develop a model with a restricted set of predictors, favouring
   transparency and scalability.Ethics and dissemination The research is
   approved by the Swedish Ethical Review Authority (2020-06540). We will
   disseminate findings by publishing in peer-reviewed open-access
   journals, and presenting at international conferences.},
Type = {Article},
Affiliation = {Lagerberg, T (Corresponding Author), Karolinska Inst, Dept Med Epidemiol \& Biostat, Stockholm, Sweden.
   Lagerberg, T (Corresponding Author), Univ Oxford, Warneford Hosp, Dept Psychiat, Oxford, England.
   Lagerberg, Tyra; Virtanen, Suvi; Kuja-Halkola, Ralf; Lichtenstein, Paul; Chang, Zheng, Karolinska Inst, Dept Med Epidemiol \& Biostat, Stockholm, Sweden.
   Lagerberg, Tyra; Fazel, Seena, Univ Oxford, Warneford Hosp, Dept Psychiat, Oxford, England.
   Hellner, Clara, Karolinska Inst, Ctr Psychiat Res, Dept Clin Neurosci, Stockholm, Sweden.
   Fazel, Seena, Oxford Hlth NHS Fdn Trust, Oxford, England.},
DOI = {10.1136/bmjopen-2023-072834},
