DOI = {10.1109/TAP.2013.2263276},
Keywords = {Adaptivity; antenna array processing; kernel method; Mercer's kernels;
   non-stationary; support vector machines},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; SMART ANTENNAS},
