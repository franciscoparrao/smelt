DOI = {10.1109/JSTARS.2025.3595434},
Keywords = {Transformers; Feature extraction; Hyperspectral imaging; Computational
   modeling; Computer architecture; Convolutional neural networks; Image
   classification; Computer vision; Accuracy; Training; Classification;
   hyperspectral image classification (HSIC); squeeze and excitation (SE);
