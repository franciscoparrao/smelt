   Chung, Fu-Lai; Wang, Shitong, Hong Kong Polytech Univ, Dept Comp, Hong Kong, Hong Kong, Peoples R China.},
DOI = {10.1016/j.ins.2014.09.050},
Keywords = {Large datasets; Classification; Support vector machine; Privacy
