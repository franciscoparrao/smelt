   Sinayskiy, Ilya; Petruccione, Francesco, Univ KwaZulu Natal, Sch Chem \& Phys, Westville Campus, ZA-4001 Durban, South Africa.
   Petruccione, Francesco, Stellenbosch Univ, Sch Data Sci \& Computat Thinking, Dept Phys, ZA-7600 Cape Town, South Africa.},
DOI = {10.1007/s42484-024-00177-w},
Article-Number = {45},
Keywords = {Quantum computing; Machine learning; SVM; QSVM; Genetic algorithm;
   NSGA-II; Kernel-target alignment},
