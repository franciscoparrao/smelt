EarlyAccessDate = {SEP 2025},
Article-Number = {100348},
Keywords = {IOT-based framework; Diabetes management; Machine learning; Diabetes
   mellitus; Diabetes decision support system},
Author-Email = {saayouni@pnu.edu.sa},
Number-of-Cited-References = {25},
Times-Cited = {1},
Unique-ID = {WOS:001583050000001},
}

@article{ WOS:001576774100007,
Author = {Wang, Yuncong and Li, Ming and Sun, Jianjun and Zhang, Jinyao and Chang,
   Wei},
Title = {Nonlinear surrogate modeling for optimization of industrial
   hydrogen-chlorine synthetic combustor with porous nozzle},
Journal = {INTERNATIONAL JOURNAL OF HYDROGEN ENERGY},
Year = {2025},
Volume = {177},
Month = {OCT 13},
Abstract = {The growing demand for clean hydrogen utilization in chemical processes
   has highlighted the need for more efficient and sustainable combustion
   systems, particularly in hydrogen chlorine synthesis. Industrial
   synthetic combustors with porous nozzles play a crucial role in
   enhancing combustion control, optimizing energy recovery and promoting
   clean hydrogen utilization. However, the complex and nonlinear
   relationships between porous structural parameters and performance
   objectives make traditional modeling approaches computationally
   expensive and impractical for efficient optimization. To address this
   challenge, this study proposes a hybrid surrogate modeling framework
   that integrates Gaussian mixture models (GMM) with adaptive ensemble
   learning. Gaussian Mixture Model is used to cluster the data, and each
   cluster is assigned to a specific base learner, enhancing local learning
   efficiency and prediction accuracy. The ensemble learning model combines
   Ridge Regression, Random Forest, XGBoost, and Support Vector Machine
   (SVM) as base learners, with an Artificial Neural Network (ANN) serving
   as the meta-learner to capture nonlinear interactions in highdimensional
   design spaces. The proposed model improves predictive accuracy for heat
   transfer, product purity, and flame height by 14.5 \%, 12.4 \%, and 10.0
   \%, respectively, compared to single learners. Shapley Additive
   Explanations (SHAP) analysis reveals that porous characteristic
   parameters have a more significant influence on combustor performance
   than spray structural parameters. Compared to conventional CFD and
   experimental methods, the framework significantly reduces computational
   time and resource consumption. This study provides a scalable and
   interpretable tool for industrial synthetic combustor designs,
   contributing to the broader adoption of hydrogen-based energy in
   sustainable chemical production.},
Type = {Article},
Affiliation = {Chang, W (Corresponding Author), Jilin Univ, Natl Key Lab Automot Chassis Integrat \& Bion, Changchun 130025, Peoples R China.
   Wang, Yuncong; Li, Ming; Chang, Wei, Jilin Univ, Natl Key Lab Automot Chassis Integrat \& Bion, Changchun 130025, Peoples R China.
   Wang, Yuncong; Li, Ming; Chang, Wei, Jilin Univ, Coll Automot Engn, Changchun 130025, Peoples R China.
   Sun, Jianjun; Zhang, Jinyao, Nantong Xingqiu Graphite Equipment Co LTD, Lianyungang, Peoples R China.},
DOI = {10.1016/j.ijhydene.2025.151405},
EarlyAccessDate = {SEP 2025},
Article-Number = {151405},
Keywords = {Hydrogen chlorine synthesis; Energy recovery; Porous nozzle; Gaussian
   mixture models; Ensemble learning; Porous characteristic parameters},
Author-Email = {wchang47@jlu.edu.cn},
Number-of-Cited-References = {53},
Times-Cited = {1},
Unique-ID = {WOS:001576774100007},
}

@article{ WOS:001573753300001,
Author = {Ferreira, Ana T. and Shipley, Lisa A. and Stahl, Amanda T. and Camp,
   Meghan C. and Meddens, Arjan J. H.},
Title = {Handheld photogrammetry advances capabilities to systematically
   characterize broken-rock habitat},
Journal = {WILDLIFE SOCIETY BULLETIN},
Year = {2025},
Volume = {49},
Number = {4},
Month = {DEC},
Abstract = {Structurally complex habitats play a critical role in the survival of
   wildlife species by providing food, thermal refuges, and protection from
   predation. However, the same complex properties that make these habitats
   suitable for wildlife also make them challenging to characterize and
   assess their ecological value. Traditional methods for characterizing
   complex habitats are labor intensive and lack the fine-scale resolution
   needed for accurate habitat assessment. We developed a workflow using
   handheld photogrammetry to systematically map and measure fine-scale
   habitat characteristics in broken-rock patches, and identify key habitat
   features relevant to rock-dwelling wildlife. To test our workflow, we
   established 10 m x 10 m plots at 15 talus patches within the North
   Cascades National Park Service Complex in Washington, USA, and used a
   structured approach to capture overlapping images with an iPad Pro. We
   processed images in Agisoft Metashape, using structure-from-motion
   (SfM), to create georeferenced digital elevation models (DEMs) and
   orthomosaics. We used the Python package segment every grain to
   semi-automatically segment the orthomosaic rasters into individual rocks
   and enable us to quantify size and shape. For classifying areal cover,
   we created training samples and used a support vector machine algorithm
   to classify rasters into 3 categories (rock, moss, and vegetation).
   Using the DEMs, we characterized surface roughness at a 15-cm
   resolution. Photogrammetry successfully generated high-resolution
   orthomosaics and DEMs for all surveyed plots (GSD <= 1.05 mm). Image
   segmentation and supervised classification provided detailed
   quantitative data, revealing variations in rock size, shape, cover
   types, and surface roughness characteristics. Mean rock volume varied
   similar to 60-fold, and vegetation cover ranged from 0\% to 19\% across
   plots. Our workflow provides a scalable and adaptable tool for
   fine-scale habitat characterization of structurally complex systems,
   providing information for species and habitat monitoring.},
Type = {Article},
Affiliation = {Ferreira, AT (Corresponding Author), Washington State Univ, 1228 Webster Hall, Pullman, WA 99164 USA.
   Ferreira, Ana T.; Shipley, Lisa A.; Stahl, Amanda T.; Camp, Meghan C.; Meddens, Arjan J. H., Washington State Univ, Sch Environm, Pullman, WA 99164 USA.},
DOI = {10.1002/wsb.1613},
EarlyAccessDate = {SEP 2025},
Article-Number = {e1613},
Keywords = {ground-based; rock-dwellers; rock shape; rock size; structurally complex
   habitat; talus patch},
Keywords-Plus = {PATTERNS; TALUS; TERRESTRIAL; OCCUPANCY; ABUNDANCE; ACCURACY; BEHAVIOR},
Author-Email = {ana.torresferreira@wsu.edu},
Number-of-Cited-References = {52},
Times-Cited = {1},
Unique-ID = {WOS:001573753300001},
}

@article{ WOS:001585847300001,
Author = {Wu, Yizhen and Qiao, Yuling and Wu, Licheng and Gao, Minglin and Wong,
   Tsz Yiu and Li, Jingyun and Wang, Zhimeng and Zhao, Xu and Zhao, Hui and
   Fan, Xiwang},
Title = {A virtual reality-based multimodal framework for adolescent depression
   screening using machine learning},
Journal = {FRONTIERS IN PSYCHIATRY},
Year = {2025},
Volume = {16},
Month = {SEP 17},
Abstract = {Background: Major depressive disorder (MDD) in adolescents poses an
   increasing global health concern, yet current screening practices rely
   heavily on subjective reports. Virtual reality (VR), integrated with
   multimodal physiological sensing (EEG+ET+HRV), offers a promising
   pathway for more objective diagnostics. Methods: In this case-control
   study, 51 adolescents diagnosed with first-episode MDD and 64 healthy
   controls participated in a 10-minute VR-based emotional task.
   Electroencephalography (EEG), eye-tracking (ET), and heart rate
   variability (HRV) data were collected in real-time. Key physiological
   differences were identified via statistical analysis, and a support
   vector machine (SVM) model was trained to classify MDD status based on
   selected features. Results: Adolescents with MDD showed significantly
   higher EEG theta/beta ratios, reduced saccade counts, longer fixation
   durations, and elevated HRV LF/HF ratios (all p <.05). The theta/beta
   and LF/HF ratios were both significantly associated with depression
   severity. The SVM model achieved 81.7\% classification accuracy with an
   AUC of 0.921. Conclusions: The proposed VR-based multimodal system
   identified robust physiological biomarkers associated with adolescent
   MDD and demonstrated strong diagnostic performance. These findings
   support the utility of immersive, sensor-integrated platforms in early
   mental health screening and intervention. Future work may explore
   integrating the proposed multimodal system into wearable or mobile
   platforms for scalable, real-world mental health screening.},
