   Ivanov, Sergey, Criteo Res, Paris, France.},
Author-Email = {sergei.ivanov@skolkovotech.ru},
Number-of-Cited-References = {28},
Times-Cited = {43},
Unique-ID = {WOS:000683379202030},
}

@article{ WOS:000265376000015,
Author = {Camps-Valls, Gustavo and Munoz-Mari, Jordi and Gomez-Chova, Luis and
   Richter, Katja and Calpe-Maravilla, Javier},
Title = {Biophysical Parameter Estimation With a Semisupervised Support Vector
   Machine},
Journal = {IEEE GEOSCIENCE AND REMOTE SENSING LETTERS},
Year = {2009},
Volume = {6},
Number = {2},
Pages = {248-252},
Month = {APR},
Abstract = {This letter presents two kernel-based methods for semisupervised
   regression. The methods rely on building a graph or hypergraph Laplacian
   with both the available labeled and unlabeled data, which is further
   used to deform the training kernel matrix. The deformed kernel is then
   used for support vector regression (SVR). Given the high computational
   burden involved, we present two alternative formulations based on the
   Nystrom method and the incomplete Cholesky factorization to achieve
   operational processing times. The semisupervised SVR algorithms are
   successfully tested in multiplatform leaf area index estimation and
   oceanic chlorophyll concentration prediction. Experiments are carried
   out with both multispectral and hyperspectral data, demonstrating good
   generalization capabilities when a low number of labeled samples are
   available, which is usually the case in biophysical parameter retrieval.},
Type = {Article},
Affiliation = {Camps-Valls, G (Corresponding Author), Univ Valencia, Escola Tecn Super Engn, Dept Elect Engn, E-46100 Valencia, Spain.
   Camps-Valls, Gustavo; Munoz-Mari, Jordi; Gomez-Chova, Luis; Calpe-Maravilla, Javier, Univ Valencia, Escola Tecn Super Engn, Dept Elect Engn, E-46100 Valencia, Spain.
   Richter, Katja, Univ Naples Federico II, Fac Agr, Dipartimento Ingn Agr \& Agron Territorio, I-80055 Portici, Na, Italy.},
DOI = {10.1109/LGRS.2008.2009077},
Keywords = {Biophysical parameter; estimation; graph; kernel method; regression;
   retrieval; semisupervised learning (SSL); support vector machine},
Author-Email = {gustavo.camps@uv.es
