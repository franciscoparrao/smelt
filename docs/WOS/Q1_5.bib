   Giuliani, Gregory; Lacroix, Pierre, Univ Geneva, Inst Environm Sci, EnviroSPACE Lab, Bd Carl Vogt 66, CH-1211 Geneva, Switzerland.},
DOI = {10.3390/rs13040736},
