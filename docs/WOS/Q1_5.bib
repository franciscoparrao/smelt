   Ali, Mohamed Sultan Mohamed, Qatar Univ, Coll Engn, Dept Elect Engn, Doha, Qatar.
   Amirullah, Indrabayu, Hasanuddin Univ, Fac Engn, Dept Informat, Makassar, Indonesia.},
DOI = {10.1007/s11270-026-09194-w},
Article-Number = {522},
Keywords = {Water quality index (WQI); Artificial neural network (ANN) prediction;
   Freshwater pollution modelling; Environmental monitoring},
Keywords-Plus = {ADAPTIVE REGRESSION SPLINES; SUPPORT VECTOR MACHINE},
Author-Email = {herlina@utm.my},
Number-of-Cited-References = {30},
