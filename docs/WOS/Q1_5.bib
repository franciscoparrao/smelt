   Saravanan, S., Saveetha Inst Med \& Tech Sci, Saveetha Sch Engn, Dept Comp Sci \& Engn, Chennai, Tamilnadu, India.},
DOI = {10.1016/j.eswa.2023.121679},
EarlyAccessDate = {SEP 2023},
Article-Number = {121679},
Keywords = {Defect prediction; Support vector machine; Extreme learning machine;
   Grasshopper optimization with Levy Flight; Vessel condition monitoring
   system},
