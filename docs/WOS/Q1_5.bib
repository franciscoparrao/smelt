}

@article{ WOS:000436420400010,
Author = {Tao, Qing and Wu, Gaowei and Chu, Dejun},
Title = {Improving Sparsity and Scalability in Regularized Nonconvex
   Truncated-Loss Learning Problems},
Journal = {IEEE TRANSACTIONS ON NEURAL NETWORKS AND LEARNING SYSTEMS},
Year = {2018},
Volume = {29},
Number = {7},
Pages = {2782-2793},
Month = {JUL},
Abstract = {The truncated regular L-1-loss support vector machine can eliminate the
   excessive number of support vectors (SVs); thus, it has significant
   advantages in robustness and scalability. However, in this paper, we
   discover that the associated state-of-the-art solvers, such as
   difference convex algorithm and concave-convex procedure, not only have
   limited sparsity promoting property for general truncated losses
   especially the L-2-loss but also have poor scalability for large-scale
   problems. To circumvent these drawbacks, we present a general multistage
   scheme with explicit interpretation regarding SVs as well as outliers.
   In particular, we solve the general nonconvex truncated loss
   minimization through a sequence of associated convex subproblems, in
   which the outliers are removed in advance. The proposed algorithm can be
   regarded as a structural optimization attempt carefully considering
   sparsity imposed by the nonconvex truncated losses. We show that this
   general multistage algorithm offers sufficient sparsity especially for
   the truncated L-2-loss. To further improve the scalability, we propose a
   linear multistep algorithm by employing a single iteration of coordinate
   descent to monotonically decrease the objective function at each stage
   and a kernel algorithm by using the Karush-Kuhn-Tucker conditions to
   cheaply find most part of the outliers for the next stage. Comparison
   experiments demonstrate that our methods have superiority in sparsity as
   well as efficiency in scalability.},
Type = {Article},
Affiliation = {Tao, Q (Corresponding Author), PLA, Army Officer Acad, Hefei 230031, Anhui, Peoples R China.
   Tao, Qing; Chu, Dejun, PLA, Army Officer Acad, Hefei 230031, Anhui, Peoples R China.
   Tao, Qing; Wu, Gaowei, Chinese Acad Sci, Inst Automat, Beijing 100190, Peoples R China.
   Wu, Gaowei, Univ Chinese Acad Sci, Beijing 101408, Peoples R China.},
DOI = {10.1109/TNNLS.2017.2705429},
Keywords = {Concave-convex procedure (CCCP); coordinate descent (CD); multistage;
   optimization; scalability; sparsity; statistical machine learning;
   support vector machine (SVM); truncated losses},
Keywords-Plus = {BUNDLE METHODS; DESCENT METHOD; OPTIMIZATION; CONVEX; REGRESSION;
   SHRINKAGE},
Author-Email = {qing.tao@gmail.com
   gaowei.wu@ia.ac.cn
   chu@gmail.com},
Number-of-Cited-References = {40},
Times-Cited = {5},
Unique-ID = {WOS:000436420400010},
}

@article{ WOS:000429726500001,
Author = {Fan, Weibei and Han, Zhijie and Wang, Ruchuan},
Title = {An Evaluation Model and Benchmark for Parallel Computing Frameworks},
Journal = {MOBILE INFORMATION SYSTEMS},
Year = {2018},
Volume = {2018},
Abstract = {MARS and Spark are two popular parallel computing frameworks and widely
   used for large-scale data analysis. In this paper, we first propose a
   performance evaluation model based on support vector machine (SVM),
   which is used to analyze the performance of parallel computing
   frameworks. Furthermore, we give representative results of a set of
   analysis with the proposed analytical performance model and then perform
   a comparative evaluation of MARS and Spark by using representative
   workloads and considering factors, such as performance and scalability.
   The experiments show that our evaluation model has higher accuracy than
   multifactor line regression (MLR) in predicting execution time, and it
   also provides a resource consumption requirement. Finally, we study
   benchmark experiments between MARS and Spark. MARS has better
   performance than Spark in both throughput and speedup in the executions
   of logistic regression and Bayesian classification because MARS has a
   large number of GPU threads that can handle higher parallelism. It also
   shows that Spark has lower latency than MARS in the execution of the
