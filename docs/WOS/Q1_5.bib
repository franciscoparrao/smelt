   Yu, Wen, CINVESTAV, Dept Automat Control, Mexico City 07360, DF, Mexico.},
DOI = {10.1109/ICSMC.2009.5346130},
Keywords = {Splice sites detection; DNA; Large data sets; Bayesian classification;
   SVM},
Keywords-Plus = {SUPPORT VECTOR MACHINE},
Author-Email = {jcanales@cs.cinvestav.mx
   yuw@ctrl.cinvestav.mx},
Number-of-Cited-References = {13},
