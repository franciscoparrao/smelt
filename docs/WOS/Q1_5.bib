@article{ WOS:001695367100001,
Author = {Wayal, Sagar M. and Parab, Shardul and Raj, Anusha and Khandagale, Kiran
   and Bhegde, Sanket and Dawale, Mukund and Bhangare, Indira and Khaire,
   Mahesh and Kadam, Yogesh and Shaikh, Zafar and Karuppaiah, V. and Gedam,
   Pranjali and Bibwe, Bhushan and More, Sanket J. and Sharma, Lakesh K.
   and Mahajan, Vijay and Gawande, Suresh J.},
Title = {UAV multispectral sensing and data-driven modeling for precision onion
   yield prediction},
Journal = {FRONTIERS IN PLANT SCIENCE},
Year = {2026},
Volume = {16},
Month = {FEB 6},
Abstract = {The integration of unmanned aerial vehicle (UAV)-assisted remote sensing
   with the Internet of Things (IoT) and Internet of Everything (IoE)
   offers a robust platform for optimizing precision agriculture by
   capturing spatiotemporal variability in crop growth. In this context,
   the present study aimed to predict the bulb yield of rainy-season onion
   crops across four staggered planting dates using UAV-based multispectral
   imagery. Canopy reflectance mosaics acquired at key growth stages, along
   with vegetation indices (VIs), viz. NDVI, NDRE, SAVI, LAI, NORM2, and
   GNDVI, were extracted for yield modeling. Yield prediction models at
   three onion growth stages were developed and assessed using five machine
   learning algorithms: linear regression (lm), random forest (rf), support
   vector machine with radial kernel (svmRadial), gradient boosting (gbm),
   and elastic net regression (glmnet), with model training and evaluation
   performed using 10-fold cross-validation. Among these, random forest
   consistently outperformed the other models at all growth stages, showing
   promising results at the bulb development stage, with a training R2 =
   0.944, RMSE = 1.919 t ha-1, MAE = 1.523 t ha-1, and a validation R \&
   sup2; = 0.755, RMSE = 3.824 t ha-1, and MAE = 3.11 t ha-1. The support
   vector machine also demonstrated strong generalization (training R \&
   sup2; = 0.787; validation R2 = 0.716), highlighting its predictive
   capability. Year-wise evaluation revealed notable interannual
   variability in model performance, with models trained on data from 2024
   outperforming those from 2023. Overall, these results demonstrate the
   efficacy of UAV-derived multispectral sensing, combined with machine
   learning, as an effective, scalable, and timely approach for reliable
   onion yield prediction and decision support in rainy-season onion crops
   under varying agronomic conditions.},
Type = {Article},
Affiliation = {Gawande, SJ (Corresponding Author), ICAR Directorate Onion \& Garlic Res, Pune, India.
   Wayal, Sagar M.; Raj, Anusha; Khandagale, Kiran; Dawale, Mukund; Bhangare, Indira; Khaire, Mahesh; Kadam, Yogesh; Karuppaiah, V.; Gedam, Pranjali; Bibwe, Bhushan; More, Sanket J.; Mahajan, Vijay; Gawande, Suresh J., ICAR Directorate Onion \& Garlic Res, Pune, India.
