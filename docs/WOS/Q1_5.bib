@article{ WOS:001568696600001,
Author = {Acharyya, Rituparna and Majumder, Arijit and Pramanick, Niloy and
   Mukhopadhyay, Anirban and Pramanik, Malay and Dhungana, Ganesh and Hati,
   Jyoti Prakash and Das, Biswanath},
Title = {A Geo-Intelligent Approach in Analysing Land Use Transformation and
   Socio-Economic Change (1991-2031) in a Tropical Metropolitan},
Journal = {EARTH SYSTEMS AND ENVIRONMENT},
Year = {2025},
Month = {2025 SEP 11},
Abstract = {Rapid urbanization and industrial development in metropolitan areas are
   reshaping landscapes and impacting socio-economic structures, often at
   the expense of environmental sustainability. Rajarhat-New Town, located
   in the northeastern part of Kolkata, India, is a key example of this
   phenomenon. The area adjacent to the Calcutta Wetlands-a Ramsar site-has
   undergone significant land use and land cover (LULC) changes due to
   rapid urbanization, affecting both environmental conditions and the
   socio-economic mobility of local communities. This study fills that gap
   by examining LULC transformations and associated socio-economic Shifts
   in Rajarhat-New Town from 1991 to 2021, with the goal of informing
   sustainable urban development policies. Using Earth Observation data and
   the Google Earth Engine (GEE) platform, we employ an Object-Oriented
   (OO) classification approach combined with machine learning techniques,
   specifically Random Forest (RF) and Support Vector Machine (SVM), to
   classify and analyze the region's LULC. Our findings reveal that LULC
   changes have been predominantly negative since 1991, with agricultural
   land being converted into urban areas at an accelerated rate. A
   multi-temporal analysis of LULC patterns conducted at 10-year intervals
   indicates significant Shifts, particularly in the transition from
   agriculture to built-up areas, which aligns with population growth and
   socio-economic Shifts. Aquaculture expanded to cover 17.54\% of the area
   by 2011 but declined by 2.32\% by 2021 due to rapid urbanization. The
   study further predicts LULC changes for 2031, indicating continued urban
   growth, especially toward the southern part of the study area, with a
   further decline in open land, scrubland, and aquaculture areas. A
   projection of LULC for 2031 further highlights the continued urban
   expansion in the region. These findings highlight the urgent need for
   integrated land-use planning that balances urban growth with
   environmental conservation. We recommend targeted policy measures
   promoting sustainable land management, urban resilience, and
   socio-economic inclusivity to ensure the long-term sustainability of
   Rajarhat-New Town.Graphical AbstractThe graphical abstract illustrates a
   comprehensive geo-intelligent framework integrating remote sensing,
   image processing, and socio-economic data to analyze LULC changes over
   time. Preprocessed satellite imagery from Landsat 5 TM (1991, 2001,
   2011) and Landsat 8 OLI (2021) ensures radiometric and geometric
   consistency for accurate temporal analysis. Key environmental indicators
   such as NDVI, NDWI, Bare Soil Index, elevation, and proximity to
   transportation networks were derived to capture landscape dynamics.
   Advanced analytical techniques, including Gray Level Co-occurrence
   Matrix (GLCM), Principal Component Analysis (PCA), and SVM
   classification, were applied to generate high-accuracy LULC maps. These
   maps reveal spatial-temporal Shifts in vegetation, urban expansion,
   agriculture, and water bodies. Socio-economic trends, such as urban
   population growth from 1971 to 2021, were integrated to assess the
   developmental impacts of LULC transformation. Overall, the workflow
   demonstrates a scalable approach for monitoring and forecasting
   urbanization and its socio-environmental consequences using
   satellite-based intelligence. By linking environmental dynamics with
   socio-economic indicators, the framework enables evidence-based
   planning, sustainable land management, and proactive policy formulation
   to balance development needs with ecological preservation in tropical
   cities.},
Type = {Article; Early Access},
Affiliation = {Pramanik, M (Corresponding Author), Asian Inst Technol, Urban Innovat \& Sustainabil, Pathum Thani 12120, Thailand.
