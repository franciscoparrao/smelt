@incollection{ WOS:001567374700027,
Author = {Ehtesham, Abul and Singh, Aditi and Kumar, Saket and Khoei, Tala Talaei},
Editor = {Paul, R},
Title = {Early Detection of Pediatric Pneumonia Using Google's HeAR Model: A
   Respiratory Sound Embedding Approach},
Booktitle = {2025 IEEE WORLD AI IOT CONGRESS, AIIOT},
Year = {2025},
Pages = {185-191},
Abstract = {Pneumonia is a leading cause of illness and death among children under
   five, particularly in low-resource settings with limited access to
   radiological and laboratory diagnostics. This work presents a scalable
   AI-based framework for early detection of pediatric pneumonia using
   respiratory sound analysis. The approach leverages Google's Health
   Acoustic Representations (HeAR), a foundation model trained on over 300
   million health-related audio samples, to extract 512-dimensional
   embeddings from 2-second respiratory sound clips.
   The SPRSound dataset is a clinically curated, open-access collection of
   pediatric respiratory sounds and is used to identify pneumonia-related
   anomalies, such as Fine Crackles and Coarse Crackles. These serve as
   positive indicators, while normal breath sounds act as negative
   controls. After generating embeddings with HeAR, several classical
   machine learning models, including SVM, Random Forest, Gradient
   Boosting, and MLP, are trained to classify abnormal lung sounds.
   The system achieves strong performance across evaluation metrics, with
   accuracy exceeding 93 percent and favorable precision-recall tradeoffs
   for pneumonia-positive cases. Interpretability is enhanced using PCA
   projections, confusion matrices, and barcode-style embedding
   visualizations. The results highlight the potential of short respiratory
   clips, processed through foundation audio models, to enable early and
   explainable screening for pediatric pneumonia. This approach supports
   the development of AI-assisted diagnostics in child healthcare.},
Type = {Proceedings Paper},
Affiliation = {Ehtesham, A (Corresponding Author), Kent State Univ, Kent, OH 44240 USA.
   Ehtesham, Abul, Kent State Univ, Kent, OH 44240 USA.
   Singh, Aditi, Cleveland State Univ, Dept Comp Sci, Cleveland, OH USA.
   Kumar, Saket, Northeastern Univ, Boston, MA USA.
   Khoei, Tala Talaei, Northeastern Univ, Khoury Coll Comp Sci, Roux Inst, Portland, ME USA.},
DOI = {10.1109/AIIoT65859.2025.11105317},
Keywords = {Pediatric Pneumonia; Respiratory Sound Classification; HeAR Model;
   Health Acoustic Representations; Foundation Models; Google Research;
   Bioacoustics; Medical AI; Digital Health; Early Disease Screening; Audio
   Embeddings; Pediatric Diagnostics},
Author-Email = {aehtesha@kent.edu
   a.singh22@csuohio.edu
   kumar.sak@northeastern.edu
   t.talaeikhoei@northeastern.edu},
