   Huang, Heng, Univ Pittsburgh, Dept Elect \& Comp Engn, Pittsburgh, PA 15260 USA.},
DOI = {10.1109/TNNLS.2020.3015937},
Keywords = {Doubly stochastic gradients (DSGs); kernel learning; ordinal regression
   (OR); random features},
Keywords-Plus = {PREDICTION; RANKING; MODEL},
