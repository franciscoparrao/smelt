   Charu, Jaypee Inst Informat Technol, Dept CSE \& IT, Noida, India.},
DOI = {10.1111/exsy.12832},
EarlyAccessDate = {SEP 2021},
Article-Number = {e12832},
Keywords = {classifier algorithm; machine learning; prediction model; smart city;
   smart grid},
Author-Email = {anurag.jain@ddn.upes.ac.in},
Number-of-Cited-References = {31},
Times-Cited = {42},
Unique-ID = {WOS:000700104700001},
}

@incollection{ WOS:000380559500066,
Author = {Golmohammadi, Koosha and Zaiane, Osmar R. and Diaz, David},
Book-Group-Author = {IEEE},
Title = {Detecting Stock Market Manipulation using Supervised Learning Algorithms},
Booktitle = {2014 INTERNATIONAL CONFERENCE ON DATA SCIENCE AND ADVANCED ANALYTICS
   (DSAA)},
Year = {2014},
Pages = {435-441},
Abstract = {Market manipulation remains the biggest concern of investors in today's
   securities market, despite fast and strict responses from regulators and
   exchanges to market participants that pursue such practices. The
   existing methods in the industry for detecting fraudulent activities in
   securities market rely heavily on a set of rules based on expert
   knowledge. The securities market has deviated from its traditional form
   due to new technologies and changing investment strategies in the past
   few years. The current securities market demands scalable machine
   learning algorithms supporting identification of market manipulation
   activities. In this paper we use supervised learning algorithms to
   identify suspicious transactions in relation to market manipulation in
   stock market. We use a case study of manipulated stocks during 2003. We
   adopt CART, conditional inference trees, C5.0, Random Forest, Naive
   Bayes, Neural Networks, SVM and kNN for classification of manipulated
   samples. Empirical results show that Naive Bayes outperform other
   learning methods achieving F2 measure of 53\% (sensitivity and
   specificity are 89\% and 83\% respectively).},
Type = {Proceedings Paper},
Affiliation = {Golmohammadi, K (Corresponding Author), Univ Alberta, Dept Comp Sci, Edmonton, AB, Canada.
   Golmohammadi, Koosha; Zaiane, Osmar R., Univ Alberta, Dept Comp Sci, Edmonton, AB, Canada.
   Diaz, David, Univ Chile, Dept Adm, Fac Econ \& Negocios, Santiago, Chile.},
Keywords = {supervised learning; classification; data mining; fraud detection;
   market manipulation; stock market manipulation},
Keywords-Plus = {PRICE MANIPULATION; MARGIN},
Author-Email = {golmoham@ualberta.ca
   zaiane@ualberta.ca
   ddiaz@unegocios.cl},
Number-of-Cited-References = {32},
