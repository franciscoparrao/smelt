   Feng Yan-chun; Yin Li-hui; Hu Chang-qin, Natl Inst Food \& Drug Control, Beijing 100050, Peoples R China.},
DOI = {10.3964/j.issn.1000-0593(2019)11-3606-08},
Keywords = {Deep convolution neural network; Near infrared spectroscopy;
   Pharmaceutical discrimination; Multi-classification},
Keywords-Plus = {NEAR-INFRARED SPECTROSCOPY; NEURAL-NETWORKS; CLASSIFICATION; DRUGS},
