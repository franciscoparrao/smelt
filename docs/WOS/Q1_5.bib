   Bekhouche, Abdelaali, Abbes Laghrour Univ, Dept Comp Sci, Khenchela 40004, Algeria.},
DOI = {10.18280/ts.420302},
Keywords = {wildfire prediction; machine learning; Explainable AI (XAI); Aclimate
   adaptation; mediterranean ecosystems},
