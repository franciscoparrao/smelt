   Bertarini, Pedro Luiz Lima, Univ Fed Uberlandia, Fac Elect Engn, Uberlandia, Brazil.
   Fernandes, Henrique, Cranfield Univ, Fac Engn \& Appl Sci, IVHM Ctr, Cranfield, England.},
DOI = {10.1111/1750-3841.70532},
Article-Number = {e70532},
Keywords-Plus = {COMPUTER VISION; PREDICTION; CAPACITY},
Author-Email = {henrique.fernandes@ufu.br},
Number-of-Cited-References = {31},
