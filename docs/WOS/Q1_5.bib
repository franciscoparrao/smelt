   Colak, Ilhami, Istinye Univ, Fac Engn \& Nat Sci, Dept Elect \& Elect Engn, Istanbul, Turkiye.},
DOI = {10.1016/j.jii.2024.100760},
EarlyAccessDate = {JAN 2025},
Article-Number = {100760},
Keywords = {photovoltaic system (PV); Fault detection and localization (FDL);
