   computing; Digital water quality; Internet of things},
Keywords-Plus = {STORMWATER DRAINAGE SYSTEMS; DISINFECTION BY-PRODUCTS; NEURAL-NETWORK;
   DISEASE OUTBREAKS; PREDICTION; INDEX; MODELS; ANN; OPTIMIZATION;
