Keywords = {remote sensing; brix; sucrose; ripening; Saccharum spp; smart harvest},
Keywords-Plus = {LEAF; REFLECTANCE; ALGORITHMS; VEGETATION},
Author-Email = {marcelo.junior@unesp.br},
Number-of-Cited-References = {53},
