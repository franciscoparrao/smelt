Keywords = {Machine learning; Quality assurance; Artificial intelligence; Artificial
   neural networks; Predictive analytics; Process optimization; Decision
   trees; Object detection; KNN; SVM; Clustering algorithms},
Keywords-Plus = {NEAREST NEIGHBOR RULE; NEURAL-NETWORKS; INDUSTRY 4.0;
   ARTIFICIAL-INTELLIGENCE; DEFECT DETECTION; FAULT-DETECTION; DIGITAL
