   Musungu, Kevin; Smit, Julian, Cape Peninsula Univ Technol, Dept Civil Engn \& Geomat, ZA-8000 Cape Town, South Africa.},
DOI = {10.3390/geomatics5020017},
Article-Number = {17},
Keywords = {fynbos; wetland; unmanned aerial vehicles; leaf pigments; spectral
   distance; biodiversity},
Keywords-Plus = {CAPE FLORISTIC REGION; SUPPORT VECTOR MACHINE; MULTISPECTRAL CAMERAS;
