@article{ WOS:000784337600001,
Author = {Ma, Pengfei and Dong, Chaoyi and Lin, Ruijing and Ma, Shuang and Jia,
   Tingting and Chen, Xiaoyan and Xiao, Zhiyun and Qi, Yongsheng},
Title = {A classification algorithm of an SSVEP brain-Computer interface based on
   CCA fusion wavelet coefficients},
Journal = {JOURNAL OF NEUROSCIENCE METHODS},
Year = {2022},
Volume = {371},
Month = {APR 1},
Abstract = {Background: In the study of brain-computer interfaces (BCIs) based on
   steady-state visual evoked potentials (SSVEPs), how to improve the
   classification accuracies of BCIs has always been the focus of
   researchers. Canonical correlation analysis (CCA) is widely used in BCI
   systems of SSVEPs because of its rapidity and scalability. However, the
   classical CCA algorithm always encounters the difficulty of low accuracy
   in a short time. New method: For targetless stimuli, this paper proposes
   a fusion algorithm (CCA-CWT-SVM) that is combined with CCA, a continuous
   wavelet transform, and a support vector machine (SVM) to improve the low
   classification accuracies when a single feature extraction method is
   used.Results: This fusion algorithm achieves high accuracies and
   information transfer rates (ITRs) in the SSVEP paradigm with few
   targets.Comparison with existing methods and conclusions: Through the
   study of 400 groups of experimental data from 10 subjects, the results
   show that CCA-CWT-SVM has a classification accuracy of 91.76\% within 2
   s and an ITR of 48.92 bits/min, which are 10.88\% and 13.18 bits/min
   higher than those of the standard CCA. Compared with a mainstream EEG
   decoding algorithm, filter bank canonical correlation analysis (FBCCA),
   the classification accuracy and ITR of the CCA-CWT-SVM algorithm also
   improved (4.45\% and 5.69 bit/min, respectively). Using a dataset from
   Tsinghua University (THU), we also showed that the fusion algorithm is
   better than the classical algorithms. The CCA-CWT-SVM algorithm obtained
   an 89.1\% accuracy and a 39.91 bit/min ITR in a time window of 2 s. The
   results were significantly improved compared with those of CCA and the
   FBCCA (CCA: 79.44\% and 28.23 bits/min, FBCCA: 84.03\% and 33.4
   bits/min). Hence, this work provides an experimental basis for designing
   an SSVEP-based BCI system with a high task classification accuracy in
   some crucial biomedical applications.},
Type = {Article},
Affiliation = {Dong, CY (Corresponding Author), Inner Mongolia Univ Technol, Coll Elect Power, Hohhot 010080, Peoples R China.
   Ma, Pengfei; Dong, Chaoyi; Lin, Ruijing; Ma, Shuang; Jia, Tingting; Chen, Xiaoyan; Xiao, Zhiyun; Qi, Yongsheng, Inner Mongolia Univ Technol, Coll Elect Power, Hohhot 010080, Peoples R China.
   Ma, Pengfei; Dong, Chaoyi; Lin, Ruijing; Ma, Shuang; Jia, Tingting; Chen, Xiaoyan; Xiao, Zhiyun; Qi, Yongsheng, Intelligent Energy Technol \& Equipment Engn Res C, Hohhot 010051, Inner Mongolia, Peoples R China.},
DOI = {10.1016/j.jneumeth.2022.109502},
EarlyAccessDate = {FEB 2022},
Article-Number = {109502},
Keywords = {Steady-state visual evoked potential; Canonical correlation analysis;
   Support vector machine; Wavelet coefficients; Feature extraction},
Keywords-Plus = {MULTIVARIATE SYNCHRONIZATION INDEX; FREQUENCY RECOGNITION; BCI},
