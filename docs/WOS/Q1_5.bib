   Sahoo, Kshira Sagar, SRM Univ, Dept Comp Sci \& Engn, Amaravati, Andra Pradesh, India.
   Luhach, Ashish Kr, PNG Univ Technol, Dept Elect \& Commun Engn, Lae, Papua N Guinea.},
DOI = {10.1089/big.2020.0201},
EarlyAccessDate = {JUL 2021},
Keywords = {big data analytic; intrusion detection; ensemble methods; Decision Tree;
   SVM; K-NN},
Keywords-Plus = {HEALTH},
