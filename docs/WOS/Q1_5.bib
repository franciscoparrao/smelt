}

@article{ WOS:001086859300001,
Author = {Nandhini, S. and Parthasarathy, S. and Saravanan, S.},
Title = {An efficient optimal hybrid SVELM based monitoring and forecasting the
   engine operations for safety standards},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2024},
Volume = {238},
Number = {A},
Month = {MAR 15},
Abstract = {During the past years, the environmental and safety-based regulations
   have turned out to be more stringent, requiring more regulations on the
   ship's operation and condition for achieving most safety standards.
   Thus, timely, efficient, and accurate maintenance becomes more
   significant. The appropriate utilization of data can assist the shipping
   industry in obtaining improved efficiency and operational cost savings,
   greater safety, better crew rates, improved asset protection, and
   environmental protection. The most important objective of this study is
   to build up a novel technique that can synchronize collected data from
   different sensors on the ship and implement a scalable framework for
   identifying the early sign patterns of defective behavior in vessel
   operating conditions. Particularly, the novel technique investigated in
   the current study is based on a Hybrid SVELM-GOLF to evaluate time
   series directly from the dataset. The data smoothening, filtering,
   elimination of outliners and segmentation process are carried out in the
   preprocessing stage. Followed by preprocessing, the features are
   extracted for classification purposes. Here, a novel Hybrid Support
   Vector Extreme Learning Model based Grasshopper Optimization with Levy
   Flight (Hybrid SVELM-GOLF) technique is proposed to estimate the
   probability of cylinder condition (i.e. defective or healthy) in the
   ship. The simulation results display that the proposed hybrid SVELM-GOLF
   approach achieves a higher rate of prediction accuracy of about 96.2\%
   as well as precision, recall, specificity and F1-score by 95.2\%, 95\%,
   95.8\% and 94.9\% than other compared approaches. Thus, the hybrid
   SVELM-GOLF approach gains the higher capability to recognize suspicious
   patterns and localize defective regions.},
Type = {Article},
Affiliation = {Parthasarathy, S (Corresponding Author), SRM Inst Sci \& Technol, Dept Math, Ramapuram Campus, Chennai, India.
   Nandhini, S., SRM Inst Sci \& Technol, Dept Comp Sci \& Engn, Chennai, Tamilnadu, India.
