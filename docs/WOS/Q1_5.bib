   Effati, Sohrab, Ferdowsi Univ Mashhad, Ctr Excellence Soft Comp \& Intellegent Informat Pr, Mashhad, Iran.},
DOI = {10.1016/j.amc.2025},
Article-Number = {129705},
Keywords = {Twin support vector machine; Optimal angle; Gravitational LSTSVM; Class
   imbalance learning; Large scale data},
Keywords-Plus = {CONJUGATE-GRADIENT},
