@article{ WOS:001476750200001,
Author = {Ngoc, Le Tuan and Nguyen, Hoang and Bui, Xuan-Nam and Tran, Trung-Tin},
Title = {Dynamic weighting and genetic algorithm-based hybrid SVR-Ridge model for
   improving PM2.5 forecasting in open-pit copper mines},
Journal = {INTERNATIONAL JOURNAL OF MINING RECLAMATION AND ENVIRONMENT},
Year = {2026},
Volume = {40},
Number = {4},
Pages = {349-379},
Month = {APR 21},
Abstract = {It is challenging to know which is the best technique for predicting
   PM2.5 concentration in open-pit copper mines. Because fine particulate
   matter is of great environmental and occupational safety significance in
   open-pit copper mines. Therefore, a modelling approach was performed by
   establishing a dynamic weighting and genetic algorithm-based hybrid
   SVR-Ridge model (DW-GA-SVRR) to evaluate the effectiveness of PM2.5
   prediction in open-pit copper mines, and the Sin Quyen copper mine
   (Vietnam) was selected as a case study with a short-term pilot dataset
   collected from 09 April to 5 June 2024 with various timestamps. While
   this duration does not capture full seasonal variability, it allows for
   initial assessment of intra-daily and weekly dynamics relevant to mine
   operations. Feature engineering techniques, including lag-based
   variables and meteorological interaction features, were employed to
   capture temporal and nonlinear dependencies. Regularisation terms were
   introduced in the optimisation process to prevent overfitting and
   improve model robustness. Experimental results demonstrate that the
   DW-GA-SVRR model outperforms individual machine learning and statistical
   models in both training and testing phases, achieving high accuracy in
   capturing short-term PM2.5 fluctuations. The findings highlight the
   importance of hybrid modelling and optimisation strategies in
   environmental prediction tasks. This work contributes a scalable and
   practical framework for real-time air quality forecasting in open-pit
   mining, supporting sustainable operations and occupational health
   management.},
Type = {Article},
Affiliation = {Nguyen, H (Corresponding Author), Hanoi Univ Min \& Geol, Min Fac, Dept Surface Min, 18 Vien St,Duc Thang Ward, Hanoi 100000, Vietnam.
   Ngoc, Le Tuan, Vinacomin Minerals Holding Corp, Hanoi, Vietnam.
