DOI = {10.1016/j.measurement.2026.120487},
EarlyAccessDate = {JAN 2026},
Article-Number = {120487},
Keywords = {MALDI-TOF MS; Data preprocessing; Variables intersection; Machine
   learning; Classification},
Keywords-Plus = {FLIGHT MASS-SPECTROMETRY; RADIX-BUPLEURI; MILK; CHEMOMETRICS},
