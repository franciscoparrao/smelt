DOI = {10.1016/j.eswa.2011.08.040},
Keywords = {Text categorization; KNN text categorization; One-pass clustering; Spam
   filtering},
Keywords-Plus = {CLASSIFICATION; MODEL},
Author-Email = {jiangshengyi@163.com},
Number-of-Cited-References = {31},
