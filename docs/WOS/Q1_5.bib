   Dadda, Abdelmounaim, Mohammed V Univ Rabat, Equipe Rech Therm \& Energie, ENSAM Rabat, Rabat, Morocco.},
DOI = {10.1016/j.solener.2025.114089},
EarlyAccessDate = {OCT 2025},
