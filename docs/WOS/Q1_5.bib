   Kirupanithi, D. Nancy, Sathyabama Inst Sci \& Technol, Dept Comp Sci \& Engn, Chennai, Tamil Nadu, India.},
DOI = {10.1007/s12559-023-10176-x},
EarlyAccessDate = {AUG 2023},
Keywords = {Big data; Data preprocessing; City councils evolution (CCE); Ensemble
   support vector machine extreme learning machine (ESVM-ELM); Apache Spark
   platform},
Author-Email = {jagdeesan@gmail.com},
Number-of-Cited-References = {30},
