@article{ WOS:001691649500001,
Author = {Khadim, Adeeba and Tarabarov, Alexey and Gulzar, Zubia and Hussain,
   Sajid and Raza, Ali and Musharraf, Syed Ghulam and Qin, Chuanguang},
Title = {Simultaneous quantification and identification of pesticide and
   mycotoxin residues via a custom high-resolution tandem mass spectral
   library and machine learning},
Journal = {MICROCHEMICAL JOURNAL},
Year = {2026},
Volume = {223},
Month = {APR},
Abstract = {The persistent accumulation of pesticides and mycotoxins in agricultural
   products underscores a widespread health issue closely linked to modern
   diseases. Rapid, multiplexed screening of mycotoxins and pesticides in
   food is crucial. An open-access HR-MS2 library containing 318 pesticides
   and 58 mycotoxins was developed using QTOF-LC-MS/MS with stepped
   collision energies (10-60 eV) for {[}M + H]+, {[}M + Na]+, {[}M + NH4]+,
   and {[}M-H]- precursors. Curated spectra and retention-time fingerprints
   identified 42 pesticides and 6 mycotoxins in food samples. Quantitative
   analysis revealed concentrations from 0.00125 to 0.0495 mg/kg, with
   average recoveries of 82\% to 118\% at 0.01 and 0.1 mg/kg. Differences
   in contaminant profiles, analyzed using stoichiometric models, uncovered
   spectral variations among food samples, with some groups showing partial
   overlap. Four classification models, including random forest (RF),
   AdaBoost (AB), gradient boosting (GB), and support vector machine (SVM),
   were applied, and their performance was monitored. A random forest
   classifier achieved 100\% training accuracy and 100\% validation
   accuracy on external data. An open-access HR-MS2 library with
   machine-learning analytics provides scalable, untargeted food-hazard
   screening for regulators and producers.},
Type = {Article},
Affiliation = {Qin, CG (Corresponding Author), Northwestern Polytech Univ, Sch Chem \& Chem Engn, Dept Chem, Xian 710129, Shaanxi, Peoples R China.
