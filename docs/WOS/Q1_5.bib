   Hosny, Khalid M., Zagazig Univ, Fac Comp \& Informat, Dept Informat Technol, Zagazig 44519, Egypt.},
DOI = {10.1186/s40537-025-01125-6},
Article-Number = {93},
Keywords = {Feature selection; Meta-heuristic Algorithms; Kepler Optimization
   Algorithm; DE/rand and DE/best Mutation Approach; Machine learning
