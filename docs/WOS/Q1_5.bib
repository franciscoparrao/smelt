Title = {A PySpark Based Scalable Model for Churn Prediction using Embedding
   Models},
Booktitle = {2024 INTERNATIONAL CONFERENCE ON ADVANCES IN COMPUTING, COMMUNICATION
   AND APPLIED INFORMATICS, ACCAI 2024},
Year = {2024},
Abstract = {This study addresses the significant challenge of customer churn, the
   challenge of customers stopping their as- sociation with a service or
   product through the integration of advanced Natural Language Processing,
   PySpark, and machine learning techniques. Our dataset comprises a
   combination of structured and unstructured data, necessitating
   preprocessing of the data to enhance the predictive accuracy of churn.
   We employ TF-IDF for feature extraction and implement two distinct word
   embeddings methods, Word2Vec and SBERT. Leveraging PySpark's distributed
   computing capabilities, we efficiently han- dle large datasets ensuring
   scalability. Utilizing five machine learning models which include
   Logistic Regression, Decision Tree, Random Forest, SVM, and Gradient
   Boosted Trees, we observe that Decision Tree and Gradient Boosted Tree
   consistently deliver promising results. Notably, the combination of
   Gradient Boosted Tree and SBERT emerges as the top-performing model
   across all methods, with accuracy and F1-score at 0.94. This compre-
   hensive approach, integrating preprocessing, advanced NLP, and PySpark's
   scalability, offers businesses a powerful tool to analyze customer
   interactions, predict potential churn, and ultimately improve customer
   retention and overall performance.},
Type = {Proceedings Paper},
Affiliation = {Venugopalan, M (Corresponding Author), Amrita Vishwa Vidyapeetham, Amrita Sch Comp, Dept Comp Sci \& Engn, Bengaluru, India.
