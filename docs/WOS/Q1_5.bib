}

@incollection{ WOS:000946638600009,
Author = {Mansoori, Mohammad Amir and Casu, Mario R.},
Book-Group-Author = {IEEE},
Title = {HLS-based dataflow hardware architecture for Support Vector Machine in
   FPGA},
Booktitle = {2022 IEEE INTERNATIONAL SYMPOSIUM ON CIRCUITS AND SYSTEMS (ISCAS 22)},
Series = {IEEE International Symposium on Circuits and Systems},
Year = {2022},
Pages = {41-45},
Abstract = {Implementing fast and accurate Support Vector Machine (SVM) classifiers
   in embedded systems with limited compute and memory capacity and in
   applications with real-time constraints, such as continuous medical
   monitoring for anomaly detection, can be challenging and calls for low
   cost, low power and resource efficient hardware accelerators. In this
   paper, we propose a flexible FPGA-based SVM accelerator highly optimized
   through a dataflow architecture. Thanks to High Level Synthesis (HLS)
   and the dataflow method, our design is scalable and can be used for
   large data dimensions when there is limited on-chip memory. The hardware
   parallelism is adjustable and can be specified according to the
   available FPGA resources. The performance of different SVM kernels are
   evaluated in hardware. In addition, an efficient fixed-point
   implementation is proposed to improve the speed. We compared our design
   with recent SVM accelerators and achieved a minimum of 10x speed-up
   compared to other HLS-based and 4.4x compared to HDL-based designs.},
Type = {Proceedings Paper},
Affiliation = {Mansoori, MA (Corresponding Author), Politecn Torino, Dept Elect \& Telecommun, Turin, Italy.
   Mansoori, Mohammad Amir; Casu, Mario R., Politecn Torino, Dept Elect \& Telecommun, Turin, Italy.},
DOI = {10.1109/ISCAS48785.2022.9937927},
Keywords = {SVM; FPGA; HLS; Hardware acceleration},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {mohammadamir.mansoori@polito.it
   mario.casu@polito.it},
Number-of-Cited-References = {16},
Times-Cited = {1},
Unique-ID = {WOS:000946638600009},
}

