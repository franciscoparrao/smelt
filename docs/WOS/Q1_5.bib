   Samuel, Philip, Cochin Univ Sci \& Technol, Dept Comp Sci, Kochi 682022, Kerala, India.
   Chacko, Mariamma, Cochin Univ Sci \& Technol, Dept Ship Technol, Kochi 682022, Kerala, India.},
DOI = {10.1186/s40537-020-00292-y},
Article-Number = {13},
Keywords = {Distributed Memory-based; Resilient Distribution Dataset; Redundancy},
Keywords-Plus = {REVIEWS},
