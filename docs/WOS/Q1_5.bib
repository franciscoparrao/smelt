}

@article{ WOS:000426010500016,
Author = {Pavy, Anne and Rigling, Brian},
Title = {SV-Means: A Fast SVM-Based Level Set Estimator for Phase-Modulated Radar
   Waveform Classification},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN SIGNAL PROCESSING},
Year = {2018},
Volume = {12},
Number = {1},
Pages = {191-201},
Month = {FEB},
Abstract = {In this paper, a novel algorithm, SV-Means, is formulated for open set
   radar waveform classification. The approach extends the quantile
   one-class support vector machine (q-OCSVM) density estimation algorithm
   into a classification formulation with inspiration from k-means and
   stochastic gradient descent principles. Phase-modulated radar waveform
   data is used to compare the primal and dual q-OCSVM (configured for
   classification) to SV-Means to verify the algorithm's classification and
   rejection performance. SV-Means is also shown to be an effective open
   set classification algorithm and is compared to these other open set
   classifiers: 1-vs-set machine, W-SVM, PI-SVM, and probabilistic open
   space (POS)-SVM. The SV-Means algorithm proves to achieve similar, and
   some cases better, performance against comparable algorithms in a
   fraction of the training time (as the data records increase and, in the
   case of the q-OCSVM, level sets increase). The SV-Means open set
   algorithm is an attractive adaptive classification framework using any
   feature extraction approach including deep-learning architectures.},
Type = {Article},
Affiliation = {Pavy, A (Corresponding Author), Air Force Res Lab Sensors Directorate Dayton, Dayton, OH 45433 USA.
   Pavy, Anne, Air Force Res Lab Sensors Directorate Dayton, Dayton, OH 45433 USA.
   Rigling, Brian, Wright State Univ, Dept Elect Engn, Dayton, OH 45431 USA.},
DOI = {10.1109/JSTSP.2018.2797798},
Keywords = {Open set classification; one-class support vector machines; random
   features; waveform classification},
