   Vizcaino-Imacana, Paulina, Univ Int Ecuador, Quito, Ecuador.},
DOI = {10.1007/978-3-031-98287-3\_7},
Keywords = {Electromyography (EMG); Hand Gesture Recognition; Motor Rehabilitation;
   Support Vector Machines (SVM); K-Nearest; Neighbors (KNN); Multilayer
