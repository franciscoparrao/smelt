   Sahoo, Kshira Sagar, Umea Univ, Dept Comp Sci, SE-90187 Umea, Sweden.
   Nayyar, Anand, Duy Tan Univ, Grad Sch, Fac Informat Technol, Da Nang, Vietnam.},
DOI = {10.1007/s11042-022-13440-8},
