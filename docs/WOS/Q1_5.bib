@article{ WOS:001681401900001,
Author = {de-Alba, Hector G. and Tellez, Andres and Gomez-Rocha, Jose Emmanuel and
   Santos, Cipriano and Orozco, Juan Antonio and Baeza-Yates, Ricardo},
Title = {Towards a trade-off of interpretability, accuracy and scalability:
   Enhanced formulations in linear classification models},
Journal = {COMPUTERS \& OPERATIONS RESEARCH},
Year = {2026},
Volume = {189},
Month = {MAY},
Abstract = {Transparency and interpretability are important topics within the
   machine learning community, particularly concerning the impact on
   decision makers of these technologies. These aspects are crucial for
   enabling users to leverage their expertise and decide whether to trust
   these technologies. In ML methods and particularly in the binary
   classification task, sparse linear methods have been developed and used
   as scoring systems. However, beyond their accuracy, we want these models
   to be sparse, with integer coefficients, and manipulable to allow the
   incorporation of operational constraints. These are known as
   Interpretable Machine Learning (IML) models for linear classification,
   where mathematical integer programming emerges as a tool to generate
   these IML models. Nonetheless, using integer programming generates
   models that are difficult to solve for large data sets. Consequently,
   motivated by the aforementioned issues, in this paper we propose new IML
   models for linear classification, based on two models: the Supersparse
   Linear Integer Model (SLIM) and Discrete Level Support Vector Machine
   (DILSVM). This new approach explores modeling the L0 function through
   the use of SOS1 constraints. Additionally, a ``neural network style{''}
   approach is used to approximate the L2 function, where auxiliary
   variables and constraints are used to emulate an artificial neural
   network. Computational experiments conducted on a set of selected ML
   datasets demonstrate that our formulation has comparable accuracy and
   interpretability, but offers higher scalability.},
Type = {Article},
Affiliation = {Gómez-Rocha, JE (Corresponding Author), Tecnol Monterrey, Escuela Ingn \& Ciencias, Saltillo, Mexico.
   de-Alba, Hector G.; Tellez, Andres; Gomez-Rocha, Jose Emmanuel; Santos, Cipriano, Tecnol Monterrey, Escuela Ingn \& Ciencias, Saltillo, Mexico.
   Orozco, Juan Antonio, Gurobi Optimizat, Guadalajara, Mexico.
   Baeza-Yates, Ricardo, Northeastern Univ, Inst Experiential AI, Boston, MA USA.},
DOI = {10.1016/j.cor.2026.107411},
EarlyAccessDate = {JAN 2026},
Article-Number = {107411},
Keywords = {Binary linear classification; Integer programming; Interpretability;
   Sparsity; Linear regularization},
Keywords-Plus = {AKAIKE INFORMATION CRITERION; MACHINE LEARNING-MODELS;
   FEATURE-SELECTION; SUPPORT; OPTIMIZATION; DECISIONS},
Author-Email = {hrgarcia@tec.mx
