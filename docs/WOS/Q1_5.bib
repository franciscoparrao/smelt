Keywords = {ensemble SVM; liver disease prediction; novel improved colliding boding
   optimization; sample weighted random forest},
Keywords-Plus = {UNCERTAINTY QUANTIFICATION; TUMOR SEGMENTATION; DIAGNOSIS; SCHEME;
   MODEL; PERFORMANCE; ALGORITHMS},
