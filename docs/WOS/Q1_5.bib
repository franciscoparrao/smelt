}

@article{ WOS:001631854500001,
Author = {Chien, Ju-Ching and Lin, Chien-Min and Wu, Ruey-Beei},
Title = {Temperature-Dependent Eye-Height Prediction for HBM3E Links Using GPR
   Kernel Method},
Journal = {IEEE JOURNAL ON MULTISCALE AND MULTIPHYSICS COMPUTATIONAL TECHNIQUES},
Year = {2026},
Volume = {11},
Pages = {1-8},
Abstract = {For high-bandwidth memory (HBM) links in high-performance devices, an
   efficient eye-height assessment of signal-integrity (SI) is achieved
   using the worst-bit pattern response method to determine a design
   preference. The effect of temperature on those conductive traces through
   HBM links is quantifiably characterized using an equivalent circuit
   model. For the multiple design parameters in the terabyte-scale
   bandwidth applications at 9.6 Gbps of HBM3E links, a Gaussian Process
   Regression (GPR) algorithm that incorporates a prior knowledge (kernel)
   model is proposed to enable eye-height prediction. In terms of the
   rising time, normalized resistance and time delay per unit interval in
   the specific link structure, the GPR Kernel model infers a prediction
   profile of the eye-height contour that is 99.56\% accurate using less
   training data. The covariance function is used by the kernel model to
   smooth GPR by encapsulating prior knowledge to construct the feature
   space and enable fast and accurate evaluation across a broad range of
   designs. For a generic HBM3E link, the temperature-dependent SI
   degradation of the eye-height contour is comparable with results for
   simulating the conventional pseudo-random binary sequence (PRBS). To
   reduce running time, this model offers a scalable and data-efficient
   solution for co-optimizing electrical and thermal performance in the
   advanced HBM3E link designs.},
