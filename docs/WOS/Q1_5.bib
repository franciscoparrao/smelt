@incollection{ WOS:000252958200050,
Author = {Ahmed, Wamiq M. and Bayraktar, Bulent and Bhunia, Arun K. and Hirleman,
   E. Dan and Robinson, J. Paul and Rajwa, Bartek},
Editor = {Yang, MQ and Zhu, MM and Zhang, Y and Arabnia, HR and Deng, Y and Bourbakis, N},
Book-Author = {Yang, JY},
Title = {Rapid Detection and Classification of Bacterial Contamination Using Grid
   Computing},
Booktitle = {PROCEEDINGS OF THE 7TH IEEE INTERNATIONAL SYMPOSIUM ON BIOINFORMATICS
   AND BIOENGINEERING, VOLS I AND II},
Year = {2007},
Pages = {286+},
Abstract = {Bacterial contamination of food products is a serious public health
   problem that creates high costs for the food-processing industry. Rapid
   detection of bacterial pathogens is the key to avoiding disease
   outbreaks and costly product recalls associated with food-borne
   pathogens. Automated identification of pathogens using scatter patterns
   of bacterial colonies is a promising technique that uses image
   processing and machine learning approaches to extract features from
   forward-scatter patterns produced by irradiating bacterial colonies with
   red laser light. The feature vector used for this approach can consist
   of hundreds of features, and a sufficiently large number of training
   images is required for accurate classification. As most feature
   extraction algorithms have high computational cost, the feature
   extraction step becomes the bottleneck in the whole processing pipeline.
   Computational grid technologies provide a promising and economical
   solution to this problem. In this work we report the implementation of
   the laser-scatter-analysis technique on a computational grid. A set of
   more than 2000 images was used for training of classifiers. The
   invariant form of Zernike moments up to order 20, radial Chebyshev
   moments, and Haralick features were extracted. Linear discriminant
   analysis and support vector machine classifiers were used for
   classification. We report speed-ups achieved and the scalabitity of this
   approach for large sets of images and for higher-order moments.
   Laser-scatter-analysis technique combined with computational grid
   technology offers a feasible and economic solution for rapid and
   accurate detection and classification of bacterial contamination.},
Type = {Proceedings Paper},
Affiliation = {Ahmed, WM (Corresponding Author), Purdue Univ, Sch Elect \& Comp Engn, W Lafayette, IN 47907 USA.
   Ahmed, Wamiq M.; Bayraktar, Bulent, Purdue Univ, Sch Elect \& Comp Engn, W Lafayette, IN 47907 USA.
   Bhunia, Arun K., Purdue Univ, Mol Food Microbiol Lab, W Lafayette, IN 47907 USA.
   Hirleman, E. Dan, Purdue Univ, Sch Mech Engn, W Lafayette, IN 47907 USA.
   Robinson, J. Paul, Purdue Univ, Weldon Sch Biomed Engn, W Lafayette, IN 47907 USA.
   Robinson, J. Paul; Rajwa, Bartek, Purdue Univ, Bindley Biosci Ctr, W Lafayette, IN 47907 USA.},
Keywords = {bacterial contamination; grid computing; feature extraction;
   classification},
Number-of-Cited-References = {22},
Times-Cited = {2},
Unique-ID = {WOS:000252958200050},
}

@incollection{ WOS:000266628300012,
Author = {Chaovalitwongse, W. Art and Fan, Ya-Ju and Sachdeo, Raiesh C.},
Editor = {Berkhin, P and Caruana, R and Wu, X and Gaffney, S},
Title = {Support Feature Machine for Classification of Abnormal Brain Activity},
Booktitle = {KDD-2007 PROCEEDINGS OF THE THIRTEENTH ACM SIGKDD INTERNATIONAL
   CONFERENCE ON KNOWLEDGE DISCOVERY AND DATA MINING},
Year = {2007},
Pages = {113+},
Abstract = {In this study, a novel multidimensional time series classification
   technique, namely support feature machine (SFM), is proposed. SFM is
   inspired by the optimization model of support vector machine and the
   nearest neighbor rule to incorporate both spatial and temporal of the
   multi-dimensional time series data. This paper also describes an
   application of SFM for detecting abnormal brain activity. Epilepsy is a
   case in point in this study. In epilepsy studies, electroencephalograms
   (EEGs), acquired in multidimensional time series format, have been
   traditionally used as a gold-standard tool for capturing the electrical
   changes in the brain. From multi-dimensional EEG time series data, SFM
   was used to identify seizure pre-cursors and detect seizure
   susceptibility (pre-seizure) periods. The empirical results showed that
   SFM achieved over 80\% correct classification of per-seizure EEG on
   average in 10 patients using 5-fold cross validation. The proposed
   optimization model of SFM is very compact and scalable, and can be
   implemented as an online algorithm. The outcome of this study suggests
   that it is possible to construct a computerized algorithm used to detect
   seizure pre-cursors and warn of impending seizures through EEG
   classification.},
Type = {Proceedings Paper},
Affiliation = {Chaovalitwongse, WA (Corresponding Author), Rutgers State Univ, Dept Ind \& Syst Engn, Piscataway, NJ 08854 USA.
   Chaovalitwongse, W. Art; Fan, Ya-Ju, Rutgers State Univ, Dept Ind \& Syst Engn, Piscataway, NJ 08854 USA.
   Sachdeo, Raiesh C., Jersey Shore Univ, Med Ctr, Dept Pediat, Neptune, NJ USA.},
Keywords = {classification; time series; epilepsy; optimization},
Keywords-Plus = {SEIZURE PREDICTION; PREDICTABILITY; SELECTION; ENERGY; CYCLE},
Author-Email = {wchaoval@rci.rutgers.edu
   yjfan@eden.rutgers.edu
   drsachdeo@gmail.com},
Number-of-Cited-References = {36},
Times-Cited = {2},
Unique-ID = {WOS:000266628300012},
}

