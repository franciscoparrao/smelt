   Li, Maozhen, Tongji Univ, Minist Educ, Key Lab Embedded Syst \& Serv Comp, Shanghai, Peoples R China.
   Liu, Yang, Sichuan Univ, Sch Elect Engn \& Informat Syst, Chengdu 610065, Peoples R China.
   Qi, Man, Canterbury Christ Church Univ, Dept Comp, Canterbury CT1 1QU, Kent, England.},
DOI = {10.1016/j.camwa.2013.07.015},
Keywords = {Support vector machines; MapReduce framework; Ensemble classifier;
