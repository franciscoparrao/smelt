   Sarno, Riyanarto; Zulaika, Enny, Jalan Raya ITS, Surabaya 60111, East Java, Indonesia.},
DOI = {10.1016/j.snb.2020.128931},
Article-Number = {128931},
Keywords = {beef quality monitoring; classification; electronic nose; discrete
   wavelet transform; long short-term memory; regression},
Keywords-Plus = {SPOILAGE CLASSIFICATION; NEURAL-NETWORKS; GAS SENSORS; MEAT; SYSTEM;
   OPTIMIZATION; FRAMEWORK; MODEL},
Author-Email = {dedyrw@tass.telkomuniversity.ac.id
