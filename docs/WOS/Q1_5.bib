@article{ WOS:001662971800015,
Author = {Ahmad, Ali and Di Gioia, Francesco and Sendra, Sandra and Lloret, Jaime},
Title = {Novel MQ-Based Sensor System for Noninvasive Detection of Salt Stress in
   Arugula},
Journal = {IEEE SENSORS JOURNAL},
Year = {2026},
Volume = {26},
Number = {2},
Pages = {2946-2954},
Month = {JAN 15},
Abstract = {Timely detection of abiotic stress is critical for precision
   agriculture, enabling early intervention and sustainable crop
   management. This study introduces a novel, nondestructive sensor system
   for real-time detection of salinity stress in hydroponically grown
   arugula {[}Eruca sativa (Mill.) Thell.] using low-cost
   metal-oxide-semiconductor (MOS) gas sensors. Arugula plants were
   cultivated under controlled greenhouse conditions and exposed to three
   salinity levels {[}0-, 40-, and 80-mM sodium chloride (NaCl)]. Volatile
   organic compounds (VOCs) emissions from plants were captured using a
   dome-based enclosure equipped with MQ2, MQ135, and MQ137 sensors and
   continuously recorded over eight days. Sensor outputs revealed distinct
   VOC patterns associated with increasing salinity stress, validated
   through physiomorphological measurements. A machine learning (ML)
   pipeline-comprising K-nearest neighbors (KNNs), support vector machine
   (SVM), and random forest (RF) classifiers-was trained on the VOC data,
   achieving up to 99.15\% accuracy in identifying stress levels.
   Configurations using the full sensor array consistently outperformed
   single- and dual-sensor models, both in terms of classification
   performance and confidence. The system employed wireless sensor network
   (WSN) architecture to enable scalable and distributed environmental
   monitoring. Each node integrated an Arduino Mega 2560 for analog signal
   acquisition and was connected to a Raspberry Pi 4, serving as a gateway
   for the WSN. Data were then structured and stored in a MariaDB database.
   This work is the first to demonstrate the use of low-cost gas sensors
   for VOC-based salt stress detection in arugula, offering a promising
   tool for early stress diagnosis in controlled-environment agriculture.
   The approach provides a scalable, real-time solution to enhance crop
   monitoring, with potential applications across a wide range of crops and
   stress conditions.},
Type = {Article},
Affiliation = {Lloret, J (Corresponding Author), Univ Politecn Valencia, Gandia 46730, Spain.
   Ahmad, Ali; Sendra, Sandra; Lloret, Jaime, Univ Politecn Valencia, Gandia 46730, Spain.
   Ahmad, Ali; Di Gioia, Francesco, Penn State Univ, Dept Plant Sci, University Pk, PA 16802 USA.},
DOI = {10.1109/JSEN.2025.3637393},
Keywords = {Sensors; Stress; Salinity (geophysical); Monitoring; Crops; Accuracy;
   Gas detectors; Wireless sensor networks; Sensor arrays; Intelligent
   sensors; Digital fingerprints; machine learning (ML); precision farming;
   volatile organic compounds (VOCs); wireless sensor network (WSN)},
