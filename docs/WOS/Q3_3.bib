@article{ WOS:A1995RX14400010,
Author = {WRIGHT, WF},
Title = {SUPERIOR LOAN COLLECTIBILITY JUDGMENTS GIVEN GRAPHICAL DISPLAYS},
Journal = {AUDITING-A JOURNAL OF PRACTICE \& THEORY},
Year = {1995},
Volume = {14},
Number = {2},
Pages = {144-154},
Month = {FAL},
Abstract = {This study tests the hypothesis that, given considerable task
   complexity, incremental availability of graphs of financial
   relationships will result in better financial judgments. Financial
   institution auditors received either tabular only or tabular plus
   graphical summarizations and comparisons of financial ratios. Each
   auditor provided judgments at three levels of task complexity, i.e.,
   three levels of information acquisition and mental integration: (1) a
   comprehensive and demanding loan collectibility judgment, (2) less
   comprehensive and demanding trend assessments, and (3) limited and much
   simpler judgments of the status of borrower financial characteristics
   (e.g., short-term liquidity).
   When the number of pertinent information relationships was high and the
   requisite information integration was demanding, availability of graphs
   resulted in elimination of a bias to overestimate loan collectibility
   and reductions in judgment error of 23-44 percent, i.e., judgments
   closer to a criterion provided by a separate panel of highly experienced
   loan audit specialists. In contrast, when relatively few information
   relationships were pertinent and much simpler information integration
   was required, very little or no incremental benefit of the graphs was
   indicated. This significant interaction between the complexity of the
   task and the incremental benefit of graphs suggests when graphs may
   facilitate financial judgments and decisions.},
Type = {Note},
Affiliation = {WRIGHT, WF (Corresponding Author), UNIV CALIF IRVINE,IRVINE,CA 92717, USA.},
Keywords = {GRAPHS; LOAN COLLECTIBILITY; TASK COMPLEXITY; DECISION AIDS},
Keywords-Plus = {TASK COMPLEXITY; MULTIDIMENSIONAL GRAPHICS; INFORMATION PRESENTATION;
   DECISION-MAKING; REPORT FORMAT; COLOR},
Number-of-Cited-References = {30},
Times-Cited = {13},
Unique-ID = {WOS:A1995RX14400010},
}

@article{ WOS:001439676000001,
Author = {Goh, Ethan and Bunning, Bryan and Khoong, Elaine C. and Gallo, Robert J.
   and Milstein, Arnold and Centola, Damon and Chen, Jonathan H.},
Title = {Physician clinical decision modification and bias assessment in a
   randomized controlled trial of AI assistance},
Journal = {COMMUNICATIONS MEDICINE},
Year = {2025},
Volume = {5},
Number = {1},
Month = {MAR 4},
Abstract = {BackgroundArtificial intelligence assistance in clinical decision making
   shows promise, but concerns exist about potential exacerbation of
   demographic biases in healthcare. This study aims to evaluate how
   physician clinical decisions and biases are influenced by AI assistance
   in a chest pain triage scenario.MethodsA randomized, pre
   post-intervention study was conducted with 50 US-licensed physicians who
   reviewed standardized chest pain video vignettes featuring either a
   white male or Black female patient. Participants answered clinical
   questions about triage, risk assessment, and treatment before and after
   receiving GPT-4 generated recommendations. Clinical decision accuracy
   was evaluated against evidence-based guidelines.ResultsHere we show that
   physicians are willing to modify their clinical decisions based on GPT-4
   assistance, leading to improved accuracy scores from 47\% to 65\% in the
   white male patient group and 63\% to 80\% in the Black female patient
   group. The accuracy improvement occurs without introducing or
   exacerbating demographic biases, with both groups showing similar
   magnitudes of improvement (18\%). A post-study survey indicates that
   90\% of physicians expect AI tools to play a significant role in future
   clinical decision making.ConclusionsPhysician clinical decision making
   can be augmented by AI assistance while maintaining equitable care
   across patient demographics. These findings suggest a path forward for
   AI clinical decision support that improves medical care without
   amplifying healthcare disparities.},
Type = {Article},
Affiliation = {Goh, E (Corresponding Author), Stanford Univ, Stanford Biomed Informat Res, Stanford, CA 94305 USA.
   Goh, E (Corresponding Author), Stanford Univ, Stanford Clin Excellence Res Ctr, Stanford, CA 94305 USA.
