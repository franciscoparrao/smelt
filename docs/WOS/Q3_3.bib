DOI = {10.1002/acr.22831},
Keywords-Plus = {SOCIETY CLASSIFICATION CRITERIA; ANKYLOSING-SPONDYLITIS; AXIAL
   SPONDYLOARTHRITIS; RHEUMATOID-ARTHRITIS; POPULATION; DISEASES;
   EPIDEMIOLOGY; HLA-B27; METAANALYSIS; DISORDERS},
Author-Email = {c.stolwijk@maastrichtuniversity.nl},
