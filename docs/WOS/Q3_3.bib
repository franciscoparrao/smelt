@incollection{ WOS:001243747800119,
Author = {Zhao, Yuying and Wang, Yu and Derr, Tyler},
Editor = {Williams, B and Chen, Y and Neville, J},
Title = {Fairness and Explainability: Bridging the Gap towards Fair Model
   Explanations},
Booktitle = {THIRTY-SEVENTH AAAI CONFERENCE ON ARTIFICIAL INTELLIGENCE, VOL 37 NO 9},
Series = {AAAI Conference on Artificial Intelligence},
Year = {2023},
Pages = {11363-11371},
Abstract = {While machine learning models have achieved unprecedented success in
   real-world applications, they might make biased/unfair decisions for
   specific demographic groups and hence result in discriminative outcomes.
   Although research efforts have been devoted to measuring and mitigating
   bias, they mainly study bias from the result-oriented perspective while
   neglecting the bias encoded in the decision-making procedure. This
   results in their inability to capture procedure-oriented bias, which
   therefore limits the ability to have a fully debiasing method.
   Fortunately, with the rapid development of explainable machine learning,
   explanations for predictions are now available to gain insights into the
   procedure. In this work, we bridge the gap between fairness and
   explainability by presenting a novel perspective of procedure-oriented
   fairness based on explanations. We identify the procedure-based bias by
   measuring the gap of explanation quality between different groups with
   Ratio-based and Value-based Explanation Fairness. The new metrics
   further motivate us to design an optimization objective to mitigate the
   procedure-based bias where we observe that it will also mitigate bias
   from the prediction. Based on our designed optimization objective, we
   propose a Comprehensive Fairness Algorithm (CFA), which simultaneously
   fulfills multiple objectives - improving traditional fairness,
   satisfying explanation fairness, and maintaining the utility
   performance. Extensive experiments on real-world datasets demonstrate
   the effectiveness of our proposed CFA and highlight the importance of
   considering fairness from the explainability perspective. Our code:
   https://github.com/YuyingZhao/FairExplanations-CFA.},
Type = {Proceedings Paper},
Affiliation = {Zhao, YY (Corresponding Author), Vanderbilt Univ, Nashville, TN 37235 USA.
   Zhao, Yuying; Wang, Yu; Derr, Tyler, Vanderbilt Univ, Nashville, TN 37235 USA.},
Keywords-Plus = {BIAS},
Author-Email = {yuying.zhao@vanderbilt.edu
   yu.wang.1@vanderbilt.edu
   tyler.derr@vanderbilt.edu},
Number-of-Cited-References = {44},
Times-Cited = {14},
Unique-ID = {WOS:001243747800119},
}

@article{ WOS:001034092900001,
Author = {Hopkins, Danielle and Rickwood, Debra J. and Hallford, David J. and
   Watsford, Clare},
Title = {Structured data vs. unstructured data in machine learning prediction
   models for suicidal behaviors: A systematic review and meta-analysis},
Journal = {FRONTIERS IN DIGITAL HEALTH},
Year = {2022},
Volume = {4},
Month = {AUG 2},
Abstract = {Suicide remains a leading cause of preventable death worldwide, despite
   advances in research and decreases in mental health stigma through
   government health campaigns. Machine learning (ML), a type of artificial
   intelligence (AI), is the use of algorithms to simulate and imitate
   human cognition. Given the lack of improvement in clinician-based
   suicide prediction over time, advancements in technology have allowed
   for novel approaches to predicting suicide risk. This systematic review
   and meta-analysis aimed to synthesize current research regarding data
   sources in ML prediction of suicide risk, incorporating and comparing
   outcomes between structured data (human interpretable such as
   psychometric instruments) and unstructured data (only machine
   interpretable such as electronic health records). Online databases and
   gray literature were searched for studies relating to ML and suicide
   risk prediction. There were 31 eligible studies. The outcome for all
   studies combined was AUC = 0.860, structured data showed AUC = 0.873,
   and unstructured data was calculated at AUC = 0.866. There was
   substantial heterogeneity between the studies, the sources of which were
   unable to be defined. The studies showed good accuracy levels in the
   prediction of suicide risk behavior overall. Structured data and
   unstructured data also showed similar outcome accuracy according to
   meta-analysis, despite different volumes and types of input data.},
Type = {Review},
Affiliation = {Hopkins, D (Corresponding Author), Univ Canberra, Fac Hlth, Canberra, ACT, Australia.
   Hopkins, Danielle; Rickwood, Debra J.; Watsford, Clare, Univ Canberra, Fac Hlth, Canberra, ACT, Australia.
   Hallford, David J., Deakin Univ, Fac Hlth, Melbourne, Vic, Australia.},
DOI = {10.3389/fdgth.2022.945006},
Article-Number = {945006},
Keywords = {suicide prediction; suicide prevention; systematic review; structured
   data; unstructured data; meta-analysis},
Keywords-Plus = {RISK; ACCURACY; THOUGHTS; BIAS; APPLICABILITY; PERFORMANCE; PROBAST;
   SAMPLE; CURVE; YOUTH},
Author-Email = {danielle.hopkins@canberra.edu.au},
Number-of-Cited-References = {65},
Times-Cited = {14},
Unique-ID = {WOS:001034092900001},
}

@article{ WOS:000765335700001,
Author = {Rafanelli, Lucia M.},
Title = {Justice, injustice, and artificial intelligence: Lessons from political
   theory and philosophy},
Journal = {BIG DATA \& SOCIETY},
Year = {2022},
Volume = {9},
Number = {1},
Month = {JAN},
Abstract = {Some recent uses of artificial intelligence for (for example) facial
   recognition, evaluating resumes, and sorting photographs by subject
   matter have revealed troubling disparities in performance or impact
   based on the demographic traits (like race and gender) of subject
   populations. These disparities raise pressing questions about how using
   artificial intelligence can work to promote justice or entrench
   injustice. Political theorists and philosophers have developed nuanced
   vocabularies and theoretical frameworks for understanding and
   adjudicating disputes about what justice requires and what constitutes
   injustice. The interdisciplinary community committed to understanding
   and conscientiously using big data could benefit from this work. Thus,
   in the spirit of encouraging cross-disciplinary dialogue and
   collaboration, this piece examines contemporary scholarship in political
   theory and philosophy to illustrate some of the vocabularies and
   frameworks political theorists and philosophers have developed for
   thinking about justice and injustice. It then draws on these frameworks
   to illuminate how the use of artificial intelligence can implicate
   questions of justice, with a focus on institutional discrimination,
   structural injustice, and epistemic injustice. Ultimately, the piece
   argues that the use of artificial intelligence-far from representing a
   decision to take power out of human hands-represents a novel way of
   harnessing human power, making questions of justice central to its
   conscientious undertaking.},
Type = {Editorial Material},
Affiliation = {Rafanelli, LM (Corresponding Author), George Washington Univ, Dept Polit Sci, 2115 G St NW,Monroe Hall,Suite 440, Washington, DC 20052 USA.
   Rafanelli, Lucia M., George Washington Univ, Washington, DC USA.},
DOI = {10.1177/20539517221080676},
Keywords = {Political theory; political philosophy; fairness; ethics; artificial
   intelligence; machine learning},
Author-Email = {lmrafanelli@gwu.edu},
Number-of-Cited-References = {27},
Times-Cited = {14},
Unique-ID = {WOS:000765335700001},
}

@article{ WOS:000733221200001,
Author = {Andersen, Judith P. and Di Nota, Paula M. and Boychuk, Evelyn C. and
   Schimmack, Ulrich and Collins, I, Peter},
Title = {Racial Bias and Lethal Force Errors Among Canadian Police Officers},
Journal = {CANADIAN JOURNAL OF BEHAVIOURAL SCIENCE-REVUE CANADIENNE DES SCIENCES DU
   COMPORTEMENT},
Year = {2023},
Volume = {55},
Number = {2},
Pages = {130-141},
Month = {APR},
Abstract = {Public Significance Statement Academic research in psychology presents
   conflicting evidence for anti-White, anti-Black, and no racial bias.
   Further, lay popularity of the Implicit Association Test (IAT) has
   informed public policy recommendations to use the IAT as a screening
   tool for unconscious racial bias among police in Canada. The present
   study reveals anti-Black biases in police shooting errors that align
   with North American population studies showing anti-Black bias, but
   which are not statistically significant compared to scenarios featuring
   White suspects. Our findings do not support using the IAT as a screening
   tool for predicting racially biased shooting behavior among police.
   Scientific examination of racial disparities in police shootings shows
   conflicting evidence of anti-Black, anti-White, or no racial bias.
   Experimental studies that attempt to control for extraneous factors
   often lack ecological validity and have inconsistent approaches for
   measuring racial bias. Given the mounting outcry for police reform,
   including recommendations for racial bias screening and training,
   clarifying the relationship between observable lethal force behaviors
   and implicit racial bias is an urgent matter. Building on limited extant
   literature, the present study examined racial disparities in
   shoot/no-shoot decision-making among Canadian police officers (n = 187)
   during their service's annual recertification assessment that
   manipulated suspect race (Black or White) in otherwise identical
   scenarios. Lethal force errors were compared to implicit racial bias
   scores on the Implicit Association Test (IAT) and other demographic
   variables including officer sex, age, years of experience, and race. We
   found no statistically significant difference in error rates for
   simulations featuring a Black or White suspect for shoot (2.5\%, 3.1\%,
   respectively) or no-shoot scenarios (4.6\%, 3.0\%, respectively). Lethal
   force errors were not predicted by suspect race, extent of autonomic
   arousal, or IAT scores. However, the absolute frequencies of lethal
   force errors were greater in scenarios featuring Black suspects. The
   current findings suggest that widespread reform to police training is
   urgently needed to reduce racial disparities in use of force (UOF) and
   lethal force errors overall.},
Type = {Article},
Affiliation = {Andersen, JP (Corresponding Author), Univ Toronto Mississauga, Dept Psychol, 3359 Mississauga Rd,Deerfield Hall 4032, Mississauga, ON L5L 1C6, Canada.
   Andersen, Judith P.; Di Nota, Paula M.; Boychuk, Evelyn C.; Schimmack, Ulrich, Univ Toronto Mississauga, Dept Psychol, 3359 Mississauga Rd,Deerfield Hall 4032, Mississauga, ON L5L 1C6, Canada.
   Collins, Peter, I, Univ Toronto, Dept Psychiat, Toronto, ON, Canada.},
DOI = {10.1037/cbs0000296},
EarlyAccessDate = {AUG 2021},
Keywords = {implicit bias; racial bias; police use of force; lethal force;
   decision-making},
Keywords-Plus = {DECISION-MAKING; RESPONSES; SHOOT; BLACK; RACE; METAANALYSIS;
   PERFORMANCE; COGNITION; PRESSURE; WHITE},
Author-Email = {judith.andersen@utoronto.ca},
Number-of-Cited-References = {63},
Times-Cited = {14},
Unique-ID = {WOS:000733221200001},
}

@article{ WOS:000633107300001,
Author = {Qi, Jingyi and Barclay, Nicole},
Title = {Social Barriers and the Hiatus from Successful Green Stormwater
   Infrastructure Implementation across the US},
Journal = {HYDROLOGY},
Year = {2021},
Volume = {8},
Number = {1},
Month = {MAR},
Abstract = {Green stormwater infrastructure (GSI), a nature-inspired, engineered
   stormwater management approach, has been increasingly implemented and
   studied especially over the last two decades. Though recent studies have
   elucidated the social benefits of GSI implementation in addition to its
   environmental and economic benefits, the social factors that influence
   its implementation remain under-explored thus, there remains a need to
   understand social barriers on decisions for GSI. This review draws
   interdisciplinary research attention to the connections between such
   social barriers and the potentially underlying cognitive biases that can
   influence rational decision making. Subsequently, this study reviewed
   the agent-based modeling (ABM) approach in decision support for
   promoting innovative strategies in water management for long-term
   resilience at an individual level. It is suggested that a collaborative
   and simultaneous effort in governance transitioning, public engagement,
   and adequate considerations of demographic constraints are crucial to
   successful GSI acceptance and implementation in the US.},
Type = {Review},
Affiliation = {Qi, JY (Corresponding Author), Univ North Carolina Charlotte, Infrastruct \& Environm Syst Program, Charlotte, NC 28262 USA.
   Qi, Jingyi, Univ North Carolina Charlotte, Infrastruct \& Environm Syst Program, Charlotte, NC 28262 USA.
   Barclay, Nicole, Univ North Carolina Charlotte, Dept Engn Technol \& Construct Management, Charlotte, NC 28262 USA.},
DOI = {10.3390/hydrology8010010},
Article-Number = {10},
Keywords = {stormwater management; social factors; green stormwater infrastructure},
Keywords-Plus = {URBAN STORMWATER; COGNITIVE BIASES; CLIMATE-CHANGE; MANAGEMENT; WATER;
