   Vyavaharkar, Medha, Univ S Carolina, Arnold Sch Publ Hlth, Dept Hlth Serv Policy \& Management, Columbia, SC 29203 USA.
   Samantapudi, Ashok Varma; Chakraborty, Hrishikesh, Univ S Carolina, Arnold Sch Publ Hlth, Dept Epidemiol \& Biostat, Columbia, SC 29203 USA.
   Shull, Kirk A.; Stephens, Teresa G., S Carolina Dept Hlth \& Environm Control, Div Surveillance \& Tech Support, Columbia, SC 29201 USA.},
DOI = {10.1111/jrh.12057},
Keywords = {epidemiology; HIV; rural; rural definition},
Keywords-Plus = {INCREASED MORTALITY; UNITED-STATES; CARE; INFECTION; PROVIDER;
   RESIDENCE; VETERANS; AREAS; AIDS},
Author-Email = {sharon.weissman@uscmed.sc.edu},
