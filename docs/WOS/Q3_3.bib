   Zaridis, Dimitrios I., Natl Tech Univ Athens, Sch Elect \& Comp Engn, Biomed Engn Lab, 9 Iroon Polytech St, Athens 15780, Greece.},
DOI = {10.1016/j.csbj.2024.07.005},
EarlyAccessDate = {JUL 2024},
Keywords = {Synthetic data generation; Data privacy; Healthcare; Artificial
   intelligence; Tabular data; Imaging data; Radiomics data; Time-series
