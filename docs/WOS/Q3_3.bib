   Venugopalan, Shankar Rengasamy, Tufts Univ, Dept Orthodont, Sch Dent Med, Boston, MA USA.
   Yadav, Sumit, Univ Nebraska Med Ctr, Dept Orthodont, Lincoln, NE USA.
   Allareddy, Veerasathpurush, Univ Illinois, Dept Orthodont, Coll Dent, Chicago, IL 60612 USA.},
DOI = {10.1111/ocr.12721},
EarlyAccessDate = {OCT 2023},
Keywords = {algorithms; artificial intelligence; ethnoracial disparities; health
   disparities; machine learning; racial bias},
Author-Email = {sath@uic.edu},
Number-of-Cited-References = {40},
Times-Cited = {15},
