   Bartlett, Marian S., Emotient Inc, San Diego, CA USA.
   Huang, Jeannie S., Rady Childrens Hosp, San Diego, CA USA.},
DOI = {10.1542/peds.2015-0029},
Keywords-Plus = {FACIAL-EXPRESSION; SELF-REPORT; APPENDECTOMY; IMPACT; PARENT; NURSE},
