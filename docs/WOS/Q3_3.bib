   Case Western Reserve Univ, Dept Psychiat, Cleveland, OH 44106 USA.
   Yale Univ, Sch Med, Dept Pediat, New Haven, CT 06510 USA.},
DOI = {10.1016/j.chiabu.2003.07.004},
Keywords = {illicit drug screening; decision-making; provider attitudes; substance
   use during pregnancy},
Keywords-Plus = {INTENSIVE-CARE UNITS; DECISION-MAKING; COCAINE USE; DRUG; PERCEPTIONS;
   PREVALENCE; MANAGEMENT; INFANTS},
