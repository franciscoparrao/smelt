   Sueur, Cedric, Inst Univ France, F-75006 Paris, France.
   Pele, Marie, Lille Catholic Univ, Anthropo Lab, ETHICS EA7446, F-59000 Lille, France.},
DOI = {10.3390/ani10122323},
