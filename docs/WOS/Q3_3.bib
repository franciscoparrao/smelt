   Slany, Emanuel; Scheele, Stephan; Schmid, Ute, Fraunhofer Inst Integrated Circuits IIS, Sensory Percept \& Analyt, Comprehensible AI, Wolfsmantel 33, D-91058 Erlangen, Germany.},
DOI = {10.3390/make5040076},
Keywords = {fair machine learning; explanatory and interactive machine learning},
Author-Email = {louisa-marie.heidrich@stud.uni-bamberg.de
   emanuel.slany@iis.fraunhofer.de
