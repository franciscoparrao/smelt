   Liu, Ziqi; Zhang, Zhiqiang; Zhou, Jun, Ant Grp, AI Dept, Hangzhou 310013, Zhejiang, Peoples R China.},
DOI = {10.1109/TKDE.2023.3249186},
Keywords = {Feature interactions; graph neural networks; graph structure learning;
   message passing; tabular data},
Author-Email = {qhzheng@xjtu.edu.cn
