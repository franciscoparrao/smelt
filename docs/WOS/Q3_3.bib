   Griffiths, K., Charles Darwin Univ, Menzies Sch Hlth Res, Darwin, NT, Australia.},
DOI = {10.2147/CLEP.S241588},
Keywords = {rheumatic heart disease; international classification of diseases;
   prediction; case ascertainment; acute rheumatic fever; non-rheumatic
   valvular heart disease; administrative data; validation; discrimination;
   receiver operating curve; Australia},
Keywords-Plus = {BURDEN},
