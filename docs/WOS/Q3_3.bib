@article{ WOS:000474259900008,
Author = {Bijak, Jakub and Disney, George and Findlay, Allan M. and Forster,
   Jonathan J. and Smith, Peter W. F. and Wisniowski, Arkadiusz},
Title = {Assessing time series models for forecasting international migration:
   Lessons from the United Kingdom},
Journal = {JOURNAL OF FORECASTING},
Year = {2019},
Volume = {38},
Number = {5},
Pages = {470-487},
Month = {AUG},
Abstract = {Migration is one of the most unpredictable demographic processes. The
   aim of this article is to provide a blueprint for assessing various
   possible forecasting approaches in order to help safeguard producers and
   users of official migration statistics against misguided forecasts. To
   achieve that, we first evaluate the various existing approaches to
   modelling and forecasting of international migration flows.
   Subsequently, we present an empirical comparison of ex post performance
   of various forecasting methods, applied to international migration to
   and from the United Kingdom. The overarching goal is to assess the
   uncertainty of forecasts produced by using different forecasting
   methods, both in terms of their errors (biases) and calibration of
   uncertainty. The empirical assessment, comparing the results of various
   forecasting models against past migration estimates, confirms the
   intuition about weak predictability of migration, but also highlights
   varying levels of forecast errors for different migration streams. There
   is no single forecasting approach that would be well suited for
   different flows. We therefore recommend adopting a tailored approach to
   forecasts, and applying a risk management framework to their results,
   taking into account the levels of uncertainty of the individual flows,
   as well as the differences in their potential societal impact.},
Type = {Article},
Affiliation = {Bijak, J (Corresponding Author), Univ Southampton, Dept Social Stat \& Demog, Southampton SO17 1BJ, Hants, England.
   Bijak, Jakub; Forster, Jonathan J.; Smith, Peter W. F., ESRC Ctr Populat Change, Modelling Strand, Southampton, Hants, England.
   Disney, George; Wisniowski, Arkadiusz, ESRC Ctr Populat Change, Southampton, Hants, England.
   Findlay, Allan M., ESRC Ctr Populat Change, Migrat Strand, Southampton, Hants, England.
   Bijak, Jakub, Univ Southampton, Dept Social Stat \& Demog, Stat Demog, Southampton, Hants, England.
   Forster, Jonathan J., Univ Southampton, Math Sci, Southampton, Hants, England.
   Forster, Jonathan J., Univ Southampton, Stat, Southampton, Hants, England.
   Smith, Peter W. F., Univ Southampton, Dept Social Stat \& Demog, Social Stat, Southampton, Hants, England.
   Disney, George, Univ Melbourne, Melbourne, Vic, Australia.
   Findlay, Allan M., Univ St Andrews, Sch Geog \& Sustainable Dev, Human Geog, St Andrews, Fife, Scotland.
   Wisniowski, Arkadiusz, Univ Manchester, Social Stat Dept, Social Stat \& Quantitat Social Sci, Manchester, Lancs, England.},
DOI = {10.1002/for.2576},
Keywords = {ARIMA models; Bayesian methods; decision making; forecasting;
   international migration; uncertainty},
Keywords-Plus = {POPULATION FORECASTS; IMMIGRATION; METHODOLOGY; PROJECTION; ACCURACY},
Author-Email = {j.bijak@soton.ac.uk},
