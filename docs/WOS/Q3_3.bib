   Netemeyer, Richard, Univ Virginia, Ctr Data Analyt, Charlottesville, VA 22903 USA.
   Yang, Yi, HKUST, Dept Informat Syst \& Operat Management, Hong Kong, Peoples R China.},
Keywords-Plus = {HEALTH LITERACY; INSTRUMENT; NUMERACY; TRUST},
