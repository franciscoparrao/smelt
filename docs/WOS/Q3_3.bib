}

@incollection{ WOS:000855966303076,
Author = {Abbasi, Ahmed and Dobolyi, David and Lalor, John P. and Netemeyer,
   Richard and Smith, Kendall and Yang, Yi},
Book-Group-Author = {Assoc Computat Linguist},
Title = {Constructing a Psychometric Testbed for Fair Natural Language Processing},
Booktitle = {2021 CONFERENCE ON EMPIRICAL METHODS IN NATURAL LANGUAGE PROCESSING
   (EMNLP 2021)},
Year = {2021},
Pages = {3748-3758},
Abstract = {Psychometric measures of ability, attitudes, perceptions, and beliefs
   are crucial for understanding user behavior in various contexts
   including health, security, e-commerce, and finance. Traditionally,
   psychometric dimensions have been measured and collected using
   survey-based methods. Inferring such constructs from user-generated text
   could allow timely, unobtrusive collection and analysis. In this work we
   construct a corpus for psychometric natural language processing (NLP)
   related to important dimensions such as trust, anxiety, numeracy, and
   literacy, in the health domain. We discuss our multi-step process to
   align user text with their survey-based response items and provide an
   overview of the resulting testbed, which encompasses survey-based
   psychometric measures and accompanying user-generated text from 8,502
   respondents. Our testbed also encompasses self-reported demographic
   information, including race, sex, age, income, and education, allowing
   for measuring bias and benchmarking fairness of text classification
   methods. We report preliminary results on use of the text to
   predict/categorize users' survey response labels and on the fairness of
   these models. We also discuss the important implications of our work and
   resulting testbed for future NLP research on psychometrics and fairness.},
Type = {Proceedings Paper},
Affiliation = {Abbasi, A (Corresponding Author), Univ Notre Dame, Human Ctr Analyt Lab, Notre Dame, IN 46556 USA.
   Abbasi, A (Corresponding Author), Univ Notre Dame, Dept IT Analyt \& Operat, Notre Dame, IN 46556 USA.
   Abbasi, Ahmed; Dobolyi, David; Lalor, John P.; Smith, Kendall, Univ Notre Dame, Human Ctr Analyt Lab, Notre Dame, IN 46556 USA.
