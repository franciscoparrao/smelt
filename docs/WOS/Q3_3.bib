   Tepedelen, Mehmed S.; Uysal, Burcu, Ibn Haldun Univ, Dept Psychol, Istanbul, Turkiye.
   Erdodi, Laszlo A., Univ Windsor, Dept Psychol, Windsor, ON, Canada.},
DOI = {10.1007/s12207-023-09483-3},
