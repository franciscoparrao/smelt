   Briggs, Andrew M., MOVE Muscle Bone \& Joint Hlth, Elsternwick, Vic, Australia.
   Sullivan, Kaye, Monash Univ, Monash Univ Lib, Melbourne, Vic, Australia.},
DOI = {10.1016/j.semarthrit.2018.07.014},
Keywords = {Inflammatory arthritis; patient perspective; needs; health information;
   systematic review},
Keywords-Plus = {RHEUMATOID-ARTHRITIS; DECISION-MAKING; SELF-MANAGEMENT;
