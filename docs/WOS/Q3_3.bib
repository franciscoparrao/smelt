   Amador, Rosalis; Garcia, Maria-Matilde, Univ Cent Las Villas, Santa Clara 54830, Cuba.},
DOI = {10.1016/j.patcog.2024.111221},
EarlyAccessDate = {DEC 2024},
Article-Number = {111221},
Keywords = {Explainable artificial intelligence; Trustworthiness; Feature
   attribution; Quantitative evaluation; Likelihood ratio},
Keywords-Plus = {VALIDATION},
Author-Email = {mbgarcia@ugr.es},
