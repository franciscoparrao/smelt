   Masino, Aaron J., Clemson Univ, Sch Comp, Clemson, SC USA.
   Masino, Aaron J., Clemson Univ, Ctr Human Genet, Greenwood, SC USA.},
DOI = {10.1371/journal.pdig.0000642},
Article-Number = {e0000642},
Keywords-Plus = {SOCIOECONOMIC-STATUS; CHILDHOOD OBESITY; HEALTH-CARE; BIG DATA; MACHINE;
   RISK; PREVALENCE; MODELS; YOUTHS; ASTHMA},
