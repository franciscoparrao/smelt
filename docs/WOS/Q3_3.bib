   van Osch, L. A. D. M., Maastricht Univ, CAPHRI, Dept Hlth Promot, POB 616, NL-6200 MD Maastricht, Netherlands.},
DOI = {10.1093/humrep/dew352},
Keywords = {Preimplantation genetic diagnosis (PGD); prenatal diagnosis (PND);
   hereditary breast and ovarian cancer (HBOC); BRCA mutation; awareness;
   knowledge; acceptability},
Keywords-Plus = {PREIMPLANTATION GENETIC DIAGNOSIS; OVARIAN-CANCER; HEREDITARY BREAST;
