   Zhao, Yan-Yong, Nanjing Audit Univ, Dept Stat, Nanjing 211815, Peoples R China.},
DOI = {10.3390/math10071171},
Article-Number = {1171},
Keywords = {GR-GNN; graph neural network; bias random walks; GRU},
Author-Email = {gekao@nj.iscas.ac.cn
