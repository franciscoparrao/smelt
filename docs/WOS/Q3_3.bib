DOI = {10.1016/j.clinbiochem.2015.07.030},
Keywords = {Glomerular Filtration Rate; Creatinine; MDRD; CKD-EPI; Creatinine
   clearance; Chronic Kidney Disease; Estimation GFR},
Keywords-Plus = {GLOMERULAR-FILTRATION-RATE; CHRONIC KIDNEY-DISEASE; SERUM CREATININE;
   RENAL-DISEASE; CYSTATIN-C; MANAGEMENT; EQUATION},
