   Chevrier, Jonathan, McGill Univ, Fac Med, Dept Epidemiol Biostat \& Occupat Hlth, Montreal, PQ, Canada.
   Papenburg, Jesse, McGill Univ, Dept Pediat, Div Pediat Infect Dis, Hlth Ctr, Montreal, PQ, Canada.},
DOI = {10.1371/journal.pone.0252617},
