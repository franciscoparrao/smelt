Keywords = {synthetic categorical data generation; generative adversarial networks;
   imbalance learning; CTGAN; interpretable machine learning;
   cardiovascular disease},
Keywords-Plus = {FEATURE-SELECTION; SMOTE; EVENT},
Author-Email = {cristina.soguero@urjc.es},
