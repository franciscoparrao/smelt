   Herrera-Benavides, Jorge; Galleguillos, Mauricio, Univ Adolfo Ibanez, Fac Ingn \& Ciencias, Diagonal Torres 2640, Penalolen 7941169, Chile.
   Herrera-Benavides, Jorge; Galleguillos, Mauricio, Ctr Climate Resilience Res CR2, Blanco Encalada 2002, Santiago 8370449, Chile.
   Pfeiffer, Marco, Univ Chile, Fac Ciencias Agron, Santa Rosa 11315, Santiago 8820808, Chile.},
DOI = {10.1016/j.landurbplan.2024.105106},
