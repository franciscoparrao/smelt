Unique-ID = {WOS:001329034500002},
}

@article{ WOS:001127528100001,
Author = {Gearns, Richard and Kelly, Angela M. and Bugallo, Monica F.},
Title = {School counseling practices related to postsecondary STEM participation},
Journal = {CAREER DEVELOPMENT QUARTERLY},
Year = {2024},
Volume = {72},
Number = {1},
Pages = {2-17},
Month = {MAR},
Abstract = {This qualitative exploratory cross-case analysis analyzed the beliefs
   and practices of high school counselors related to science, technology,
   engineering, and mathematics (STEM) academic advisement, postsecondary
   planning, and career participation. Interviews were conducted with high
   school counselors (N = 13) who were purposively sampled to represent a
   diversity of schools in terms of demographic variables. Findings
   indicated that high school counselors perceived that (a) sociocultural
   factors influenced student preparation for STEM, career planning, and
   decision making; (b) students' STEM-related career goals and academic
   behaviors were sometimes misaligned, and academic advisement often
   mediated this tension; and (c) their professional STEM knowledge,
   beliefs, and practices were influenced by professional preparation,
   workplace characteristics, and their academic experiences. Implications
   include the need for early, sustained high school STEM counseling and
   academic advisement; accessible professional development in STEM
   preparation and careers to promote multiple pathways and reduce school
   counselor bias; and encouraging family involvement in STEM career
   decision making.},
Type = {Article},
Affiliation = {Kelly, AM (Corresponding Author), SUNY Stony Brook, Dept Phys \& Astron, 092 Life Sci, Stony Brook, NY 11794 USA.
   Kelly, AM (Corresponding Author), SUNY Stony Brook, Inst STEM Educ, 092 Life Sci, Stony Brook, NY 11794 USA.
