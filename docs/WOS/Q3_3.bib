   Couper, Mick P.; Singer, Eleanor, Univ Michigan, Survey Res Ctr, Inst Social Res, Ann Arbor, MI 48109 USA.
   Levin, Carrie A., Fdn Informed Med Decis Making, Boston, MA USA.},
DOI = {10.1177/0272989X10378700},
Keywords = {informed decision making; patient education; knowledge},
