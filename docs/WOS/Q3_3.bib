   Couper, Mick P.; Van Hoewyk, John; Zikmund-Fisher, Brian J., Univ Michigan, Ann Arbor, MI 48109 USA.
   Barry, Michael J., Massachusetts Gen Hosp, Div Gen Med, Boston, MA 02114 USA.
   Elmore, Joann G., Univ Washington, Dept Med, Seattle, WA USA.
   Levin, Carrie A., Fdn Informed Med Decis Making, Boston, MA USA.
   Zikmund-Fisher, Brian J., Ann Arbor VA Hlth Care Syst, Ann Arbor, MI USA.},
DOI = {10.1177/0272989X10378701},
Keywords = {prostatic neoplasms; breast neoplasms; colorectal neoplasms; early
   detection of cancer; decision making},
