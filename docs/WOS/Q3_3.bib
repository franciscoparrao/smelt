   Wulf, Torsten, HHL Leipzig Grad Sch Management, Jahnallee 59, D-04109 Leipzig, Germany.},
DOI = {10.1016/j.lrp.2017.11.002},
Keywords = {Group overconfidence; Demographic diversity; Tenure},
Keywords-Plus = {GROUP DECISION-MAKING; TOP-MANAGEMENT; UNSHARED INFORMATION; GROUP
