}

@incollection{ WOS:001213927503027,
Author = {Sattigeri, Prasanna and Ghosh, Soumya and Padhi, Inkit and Dognin,
   Pierre and Varshney, Kush R.},
Editor = {Koyejo, S and Mohamed, S and Agarwal, A and Belgrave, D and Cho, K and Oh, A},
Title = {Fair Infinitesimal Jackknife: Mitigating the Influence of Biased
   Training Data PointsWithout Refitting},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 35 (NEURIPS 2022)},
Series = {Advances in Neural Information Processing Systems},
Year = {2022},
Abstract = {In consequential decision-making applications, mitigating unwanted
   biases in machine learning models that yield systematic disadvantage to
   members of groups delineated by sensitive attributes such as race and
   gender is one key intervention to strive for equity. Focusing on
   demographic parity and equality of opportunity, in this paper we propose
   an algorithm that improves the fairness of a pre-trained classifier by
   simply dropping carefully selected training data points. We select
   instances based on their influence on the fairness metric of interest,
   computed using an infinitesimal jackknife-based approach. The dropping
   of training points is done in principle, but in practice does not
   require the model to be refit. Crucially, we find that such an
   intervention does not substantially reduce the predictive performance of
   the model but drastically improves the fairness metric. Through careful
   experiments, we evaluate the effectiveness of the proposed approach on
   diverse tasks and find that it consistently improves upon existing
   alternatives.},
Type = {Proceedings Paper},
Affiliation = {Sattigeri, P (Corresponding Author), IBM Res, Yorktown Hts, NY 10598 USA.
   Sattigeri, Prasanna; Padhi, Inkit; Dognin, Pierre; Varshney, Kush R., IBM Res, Yorktown Hts, NY 10598 USA.
   Ghosh, Soumya, IBM Res, MIT IBM Watson AI Lab, Cambridge, MA USA.},
Author-Email = {psattig@us.ibm.com
   ghoshso@us.ibm.com
   inkit.padhi@ibm.com
   pdognin@us.ibm.com
   krvarshn@us.ibm.com},
