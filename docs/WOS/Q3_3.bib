   Randi, Ettore, Aalborg Univ, Sect Biol \& Environm Sci, Dept Chem \& Biosci, Fredrik Bajers Vej 7H, DK-9220 Aalborg OST, Denmark.
   Posillico, Mario, Ufficio Terr Carabinieri Biodiversita Castel Sang, Comando Unita Tutela Forestale Ambientale \& Agroa, 45 Via Sangro, I-67031 Castel Di Sangro, AQ, Italy.},
DOI = {10.1007/s10144-017-0587-0},
Keywords = {Apennine brown bear; Hair-snagging; Multievent models; Non-invasive
   genetic sampling; Small populations; Survival},
Keywords-Plus = {CAPTURE-MARK-RECAPTURE; POPULATION-SIZE; DNA; MODELS; RECRUITMENT;
   ABUNDANCE; ANIMALS; QUALITY; BIAS},
Author-Email = {vincenzo.gervasi@libero.it},
Number-of-Cited-References = {53},
