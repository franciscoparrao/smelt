@article{ WOS:000783072600018,
Author = {Gasquoine, Philip G.},
Title = {Performance-based alternatives to race-norms in neuropsychological
   assessment},
Journal = {CORTEX},
Year = {2022},
Volume = {148},
Pages = {231-238},
Month = {MAR},
Abstract = {Groupings of neurologically intact African Americans have mean scores
   below those for Caucasian Americans on a wide range of
   neuropsychological tests. This provided the impetus for the creation of
   race-norms that reduce false positive African American
   mis-classifications (i.e., neurologically intact individuals
   misdiagnosed with neurocognitive impairment). Race-norming of
   neuropsychological tests has proved controversial as evi-denced by a
   recent widely publicized lawsuit filed by African American ex-football
   players against the National Football League (NFL) 2014 concussion
   settlement that prompted the NFL to halt the use of race-norms and to
   review past claims for evidence of racial bias. Here it is argued that
   there is a viable alternative to the use of race-norms in
   neuropsychological assessment whereby false positives are reduced
   through the use of obtained postinjury hold measures to estimate
   preexisting skill levels with standard norms. These performance-based
   estimates: (a) can be used with all race/ethnic minorities; (b) are
   applicable to all neuropsychological tests; (c) are more accurate than
   using the mean of published norms for members of any race/ethnic
   grouping who possess ``true{''} preexisting neuropsychological skill
   levels at either end of the normal curve; (d) promote fairness in
   testing as individuals of differing race/ethnic groupings but otherwise
   similar demographic profiles, test scores, and estimated preexisting
   skill levels have the same assessed level of neurocognitive impairment;
   and (e) the implied causation of lower preexisting estimates in a
   racially diverse patient is not race per se but behavioral correlates of
   race like quality of education and acculturation that have demonstrated
   effects on test scores.(c) 2021 Elsevier Ltd. All rights reserved.},
Type = {Editorial Material},
Affiliation = {Gasquoine, PG (Corresponding Author), Univ Texas Rio Grande Valley, Dept Psychol Sci, 1201 W Univ Dr, Edinburg, TX 78541 USA.
   Gasquoine, Philip G., Univ Texas Rio Grande Valley, Dept Psychol Sci, 1201 W Univ Dr, Edinburg, TX 78541 USA.},
DOI = {10.1016/j.cortex.2021.12.003},
EarlyAccessDate = {MAR 2022},
Keywords = {Race-norms; Individual comparison standard; Hold measures; Preexisting
   neuropsychological skill\&nbsp; level; African American},
Keywords-Plus = {DEMOGRAPHICALLY CORRECTED NORMS; AFRICAN-AMERICAN ACCULTURATION;
   NATIONAL EPIDEMIOLOGIC SURVEY; TRAUMATIC BRAIN-INJURY; READING LEVEL;
   LOW SCORES; DEFINITIONS; DIAGNOSIS; VARIABLES; EDUCATION},
Author-Email = {drgdrg13@yahoo.com},
Number-of-Cited-References = {71},
