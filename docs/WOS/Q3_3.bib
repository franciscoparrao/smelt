@article{ WOS:000312159300001,
Author = {Severus, Emanuel and Seemueller, Florian and Berger, Michael and
   Dittmann, Sandra and Obermeier, Michael and Pfennig, Andrea and Riedel,
   Michael and Frangou, Sophia and Moeller, Hans-Juergen and Bauer, Michael},
Title = {Mirroring everyday clinical practice in clinical trial design: a new
   concept to improve the external validity of randomized double-blind
   placebo-controlled trials in the pharmacological treatment of major
   depression},
Journal = {BMC MEDICINE},
Year = {2012},
Volume = {10},
Month = {JUL 2},
Abstract = {Background: Randomized, double-blind, placebo-controlled trials
   constitute the gold standard in clinical research when testing the
   efficacy of new psychopharmacological interventions in the treatment of
   major depression. However, the blinded use of placebo has been found to
   influence clinical trial outcomes and may bias patient selection.
   Discussion: To improve clinical trial design in major depression so as
   to reflect clinical practice more closely we propose to present patients
   with a balanced view of the benefits of study participation irrespective
   of their assignment to placebo or active treatment. In addition every
   participant should be given the option to finally receive the active
   medication. A research agenda is outlined to evaluate the impact of the
   proposed changes on the efficacy of the drug to be evaluated and on the
   demographic and clinical characteristics of the enrollment fraction with
   regard to its representativeness of the eligible population.
   Summary: We propose a list of measures to be taken to improve the
   external validity of double-blind, placebo-controlled trials in major
   depression. The recommended changes to clinical trial design may also be
   relevant for other psychiatric as well as medical disorders in which
   expectations regarding treatment outcome may affect the outcome itself.},
Type = {Article},
Affiliation = {Severus, E (Corresponding Author), Tech Univ Dresden, Univ Hosp Carl Gustav Carus, Dept Psychiat \& Psychotherapy, Fetscherstr 74, D-01307 Dresden, Germany.
   Severus, Emanuel; Pfennig, Andrea; Bauer, Michael, Tech Univ Dresden, Univ Hosp Carl Gustav Carus, Dept Psychiat \& Psychotherapy, D-01307 Dresden, Germany.
