   QUALITATIVE-ANALYSIS; DECISION-MAKING; BIRTH-CONTROL; WOMENS; HEALTH;
   ATTITUDES; PILL},
Author-Email = {mireille.leguen@uclouvain.be
   clemence.schantz@ird.fr
   arnaud.regnier-loilier@ined.fr
   roche@ined.fr},
Number-of-Cited-References = {124},
