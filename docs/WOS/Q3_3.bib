   Kadlec, Helena, Univ Victoria, Dept Psychol, Victoria, BC, Canada.},
DOI = {10.1080/13803395.2010.532114},
Article-Number = {PII 930995721},
Keywords = {Classification accuracy; Dementia; Skew; Test properties},
