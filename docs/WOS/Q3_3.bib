EarlyAccessDate = {MAY 2020},
Keywords = {Risk calculators; Risk assessment; Patient-reported outcome; Spine
   surgery},
Keywords-Plus = {QUALITY-OF-LIFE; PAIN; MODEL; APPLICABILITY; COMPLICATIONS; DATABASE;
   PROBAST; BIAS},
