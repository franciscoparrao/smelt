   Mayo Clin, Div Epidemiol, Rochester, MN 55905 USA.
   Wake Forest Sch Med, Div Maternal Fetal Med, Dept Obstet \& Gynecol, Winston Salem, NC USA.},
DOI = {10.1097/AOG.0000000000001083},
Keywords-Plus = {ELECTIVE-INDUCTION; FOLEY CATHETER; FETAL WEIGHT; RISK-FACTORS; PRETERM;
   MODELS; ISSUES; TRIAL},
