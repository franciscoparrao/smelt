   Ndiaye, Cheikh Tidiane, Agence Natl Stat \& Demog, Dakar, Senegal.},
DOI = {10.4054/DemRes.2019.40.9},
Article-Number = {9},
Keywords-Plus = {AFRICAN-AMERICAN MORTALITY; CIVIL REGISTRATION; UNITED-STATES; HEALTH;
   POPULATION; CHILDREN; QUALITY; NAMIBIA; IMPACT},
