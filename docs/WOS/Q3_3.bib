   Lee, Ryan C.; Alamuri, Tharun, SUNY Stony Brook, Renaissance Sch Med, Stony Brook, NY USA.},
DOI = {10.1016/j.jacr.2025.10.005},
Keywords = {Large language models; artificial intelligence; radiology reports},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; HEALTH-CARE},
Author-Email = {tim.duong@einsteinmed.edu},
