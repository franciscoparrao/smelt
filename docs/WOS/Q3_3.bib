   Wu, Le; Wang, Meng, Hefei Comprehens Natl Sci Ctr, Inst Artificial Intelligence, Hefei 230088, Peoples R China.},
DOI = {10.1007/s11432-020-3404-y},
Article-Number = {222102},
Keywords = {recommendation systems; fairness; adversarial learning},
Keywords-Plus = {DISCRIMINATION},
