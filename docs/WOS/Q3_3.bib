Keywords = {Personal autonomy; Elderly; Elderly of 80 and over},
Keywords-Plus = {DECISION-MAKING; HEALTH; LIFE; MORALE; CARE; DETERMINANTS; SUPPORT},
Author-Email = {gabicarneirog@gmail.com},
