@incollection{ WOS:000901616406047,
Author = {van Breugel, Boris and Kyono, Trent and Berrevoets, Jeroen and van der
   Schaar, Mihaela},
Editor = {Ranzato, M and Beygelzimer, A and Dauphin, Y and Liang, PS and Vaughan, JW},
Title = {DECAF: Generating Fair Synthetic Data Using Causally-Aware Generative
   Networks},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 34 (NEURIPS 2021)},
Series = {Advances in Neural Information Processing Systems},
Year = {2021},
Volume = {34},
Abstract = {Machine learning models have been criticized for reflecting unfair
   biases in the training data. Instead of solving for this by introducing
   fair learning algorithms directly, we focus on generating fair synthetic
   data, such that any downstream learner is fair. Generating fair
   synthetic data from unfair data- while remaining truthful to the
   underlying data-generating process (DGP) -is non-trivial. In this paper,
   we introduce DECAF: a GAN-based fair synthetic data generator for
   tabular data. With DECAF we embed the DGP explicitly as a structural
   causal model in the input layers of the generator, allowing each
   variable to be reconstructed conditioned on its causal parents. This
   procedure enables inference-time debiasing, where biased edges can be
   strategically removed for satisfying user-defined fairness requirements.
   The DECAF framework is versatile and compatible with several popular
   definitions of fairness. In our experiments, we show that DECAF
   successfully removes undesired bias and- in contrast to existing methods
   -is capable of generating high-quality synthetic data. Furthermore, we
   provide theoretical guarantees on the generator's convergence and the
   fairness of downstream models.},
Type = {Proceedings Paper},
Affiliation = {van Breugel, B (Corresponding Author), Univ Cambridge, Cambridge, England.
   van Breugel, Boris; Berrevoets, Jeroen, Univ Cambridge, Cambridge, England.
   Kyono, Trent, Univ Calif Los Angeles, Los Angeles, CA USA.
   van der Schaar, Mihaela, Univ Calif Los Angeles, Alan Turing Inst, Los Angeles, CA USA.},
Keywords-Plus = {CREDIT},
Author-Email = {bv292@cam.ac.uk
   tmkyono@ucla.edu
   jb2384@cam.ac.uk
   mv472@cam.ac.uk},
Number-of-Cited-References = {48},
