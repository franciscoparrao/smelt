   Goodwin, Andrew J.; Ford, Dee W., Med Univ South Carolina, Dept Med, Div Pulm Crit Care Allergy \& Sleep Med, Charleston, SC USA.},
DOI = {10.1097/CCE.0000000000000642},
Article-Number = {e0642},
Keywords = {early; inter-intensive care unit transfer; later; outcomes; respiratory
   failure; timing},
Keywords-Plus = {CRITICALLY-ILL PATIENTS; INTENSIVE-CARE; MECHANICAL VENTILATION;
