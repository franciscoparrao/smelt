@article{ WOS:000755827300001,
Author = {Moye, Jennifer and Driver, Jane A. and Owsiany, Montgomery T. and Chen,
   Li Qing and Whitley, Jessica Cruz and Auguste, Elizabeth J. and Paik,
   Julie M.},
Title = {Assessing What Matters Most in Older Adults With Multicomplexity},
Journal = {GERONTOLOGIST},
Year = {2021},
Volume = {62},
Number = {4},
Pages = {e224-e234},
Month = {JUL 16},
Abstract = {Background and Objectives Abilities and activities that are often
   simultaneously valued may not be simultaneously achievable for older
   adults with multicomplexity. Because of this, the Geriatrics 5Ms
   framework prioritizes care on ``what matters most.{''} This study aimed
   to evaluate and refine the What Matters Most-Structured Tool (WMM-ST).
   Research Design and Methods About 105 older adults with an average of 4
   chronic conditions completed the WMM-ST along with open-ended questions
   from the Serious Illness Conversation Guide. Participants also provided
   demographic and social information, completed cognitive screening with
   the Telephone-Montreal Cognitive Assessment-Short and frailty screening
   with the Frail scale. Quantitative and qualitative analyses aimed to (a)
   describe values; (b) evaluate the association of patient characteristics
   with values; and (c) assess validity via the tool's acceptability,
   educational bias, and content accuracy. Results Older adults varied in
   what matters most. Ratings demonstrated modest associations with social
   support, religiosity, cognition, and frailty, but not with age or
   education. The WMM-ST was rated as understandable (86\%) and applicable
   to their current situation (61\%) independent of education. Qualitative
   analyses supported the content validity of WMM-ST, while revealing
   additional content. Discussion and Implications It is possible to assess
   what matters most to older adults with multicomplexity using a
   structured tool. Such tools may be useful in making an abstract process
   clearer but require further validation in diverse samples.},
Type = {Article},
Affiliation = {Moye, J (Corresponding Author), VA Boston Healthcare Syst, New England Geriatr Res Educ \& Clin Ctr GRECC, 150 South Huntington Ave, Jamaica Plain, MA 02130 USA.
   Moye, Jennifer; Driver, Jane A.; Owsiany, Montgomery T.; Chen, Li Qing; Whitley, Jessica Cruz; Auguste, Elizabeth J.; Paik, Julie M., VA Boston Healthcare Syst, New England Geriatr Res Educ \& Clin Ctr GRECC, 150 South Huntington Ave, Jamaica Plain, MA 02130 USA.
   Moye, Jennifer, Harvard Med Sch, Dept Psychiat, Boston, MA 02115 USA.
   Driver, Jane A.; Paik, Julie M., Harvard Med Sch, Dept Med, Boston, MA 02115 USA.},
DOI = {10.1093/geront/gnab071},
EarlyAccessDate = {JUL 2021},
Keywords = {Aging; Goals; Multimorbidity; Values},
Keywords-Plus = {DECISION-MAKING; CARE; VALUES; GOALS},
Author-Email = {Jennifer.moye@va.gov},
Number-of-Cited-References = {37},
