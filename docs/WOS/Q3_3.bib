Article-Number = {755817},
Keywords = {open-source EEG dataset; automated EEG analytics; pre-diagnostic EEG
   screening; computer aided diagnosis; computational neurology;
   convolutional neural networks; deep learning; generalization performance},
Keywords-Plus = {CONVOLUTIONAL NEURAL-NETWORKS; DEEP},
