}

@article{ WOS:000860873700027,
Author = {McGurgan, Paul M. and Calvert, Katrina L. and Nathan, Elizabeth A. and
   Narula, Kiran and Celenza, Antonio and Jorm, Christine},
Title = {Why Is Patient Safety a Challenge? Insights From the Professionalism
   Opinions of Medical Students' Research},
Journal = {JOURNAL OF PATIENT SAFETY},
Year = {2022},
Volume = {18},
Number = {7},
Pages = {E1124-E1134},
Month = {OCT},
Abstract = {Objectives Despite increased emphasis on education and training for
   patient safety in medical schools, there is little known about factors
   influencing decision making regarding patient safety behaviors. This
   study examined the nature and magnitude of factors that may influence
   opinions around patient safety-related behaviors as a means of providing
   insights into how Australian doctors and medical students view these
   issues relative to members of the public. Methods A national,
   multicenter, prospective, cross-sectional survey was conducted using
   responses to hypothetical patient safety scenarios involving the
   following: fabricating results, personal protective equipment,
   presenteeism, and reporting concerns. Australian enrolled medical
   students, medical doctors, and members of the public were surveyed.
   Participant responses were compared for the different contextual
   variables within the scenarios and the participants' demographic
   characteristics. Results In total, 2602 medical student, 809 doctors,
   and 503 members of the Australian public participated. The 3 demographic
   groups had significantly differing opinions on many of the patient
   safety dilemmas. Doctors were more tolerant of medical students not
   reporting concerning behaviors and attending placements despite recent
   illness. Medical students' opinions frequently demonstrated a
   ``transition effect,{''} bridging between the doctors and publics'
   attitudes, consistent with professional identity formation. Conclusions
   Opinions on the acceptability of medical students' patient
   safety-related behaviors were influenced by the demographics of the
   cohort and the contextual complexity of the scenario. Although the
   survey used hypothetical scenarios, doctors and medical students'
   opinions seem to be influenced by cognitive dissonances, biases, and
   heuristics, which may negatively affect patient safety.},
Type = {Article},
Affiliation = {McGurgan, PM (Corresponding Author), Univ Western Australia, Div Obstet \& Gynaecol, M550,35 Stirling Hwy, Perth, WA 6009, Australia.
   McGurgan, Paul M.; Nathan, Elizabeth A., Univ Western Australia, Div Obstet \& Gynaecol, M550,35 Stirling Hwy, Perth, WA 6009, Australia.
   Calvert, Katrina L., King Edwards Mem Hosp, Perth, WA, Australia.
   Narula, Kiran, Royal Perth Hosp, Perth, WA, Australia.
   Celenza, Antonio, Univ Western Australia, Div Emergency Med, Perth, WA, Australia.
   Jorm, Christine, Australian Govt Dept Hlth, Hlth \& Med Res Off, Canberra, ACT, Australia.},
DOI = {10.1097/PTS.0000000000001032},
Keywords = {health professional; public; patient safety; medical student; opinions;
   cognitive biases},
Keywords-Plus = {UNPROFESSIONAL BEHAVIORS; QUALITY; DOCTORS; RISK; US},
Author-Email = {paul.mcgurgan@uwa.edu.au},
Number-of-Cited-References = {58},
Times-Cited = {5},
Unique-ID = {WOS:000860873700027},
}

@article{ WOS:000866639900001,
Author = {Montalvo, Victor H. and Saenz-Bolanos, Carolina and Cruz-Diaz, Juan C.
   and Carrillo, Eduardo and Fuller, Todd K.},
Title = {The Use of Camera Traps and Auxiliary Satellite Telemetry to Estimate
   Jaguar Population Density in Northwestern Costa Rica},
Journal = {ANIMALS},
Year = {2022},
Volume = {12},
Number = {19},
Month = {OCT},
Abstract = {Simple Summary We used data from a grid of camera traps, combined with
   satellite telemetry data from one female jaguar, to estimate jaguar
   population density in northwestern Costa Rica. Our estimate of 2.6
   females and 5.0 males per 100 km(2) was influenced by camera placement
   and sex of the jaguar, and indicated the importance of telemetry data to
   improve field design and parameter estimation. We recommend population
   assessments of at least 3 consecutive months, expanding the survey area
   to one several times the size of an individual's home range, and
   including sex and camera placement considerations to reduce bias in
   jaguar density estimates. Regular evaluation of jaguar (Panthera onca)
   population status is an important part of conservation decision-making.
   Currently, camera trapping has become the standard method used to
   estimate jaguar abundance and demographic parameters, though evidence
   has shown the potential for sex ratio biases and density overestimates.
   In this study, we used camera trap data combined with satellite
   telemetry data from one female jaguar to estimate jaguar population
   density in the dry forest of Santa Rosa National Park in the Guanacaste
   Conservation Area of northwestern Costa Rica. We analyzed camera trap
   data collected from June 2016 to June 2017 using spatial
   capture-recapture methods to estimate jaguar density. In total, 19
   individual jaguars were detected (11 males; 8 females) with a resulting
   estimated population density of 2.6 females (95\% {[}CI] 1.7-4.0) and
   5.0 male (95\% {[}CI] 3.4-7.4) per 100 km(2). Based on telemetry and
   camera trap data, camera placement might bias individual detections by
   sex and thus overall density estimates. We recommend population
   assessments be made at several consecutive 3-month intervals, that
   larger areas be covered so as not to restrict surveys to one or two
   individual home ranges, as in our case, and to carry out long-term
   camera monitoring programs instead of short-term studies to better
   understand the local population, using auxiliary telemetry data to
   adjust field designs and density estimations to improve support for
   jaguar conservation strategies.},
Type = {Article},
Affiliation = {Montalvo, VH (Corresponding Author), Univ Nacl, Inst Int Conservac \& Manejo Vida Silvestre, Heredia 13503000, Costa Rica.
   Montalvo, VH (Corresponding Author), Univ Massachusetts, Dept Environm Conservat, Amherst, MA 01003 USA.
   Montalvo, VH (Corresponding Author), Nama Conservat, Heredia 40101, Costa Rica.
   Montalvo, Victor H.; Saenz-Bolanos, Carolina; Carrillo, Eduardo, Univ Nacl, Inst Int Conservac \& Manejo Vida Silvestre, Heredia 13503000, Costa Rica.
   Montalvo, Victor H.; Carrillo, Eduardo; Fuller, Todd K., Univ Massachusetts, Dept Environm Conservat, Amherst, MA 01003 USA.
   Montalvo, Victor H.; Saenz-Bolanos, Carolina; Cruz-Diaz, Juan C.; Carrillo, Eduardo, Nama Conservat, Heredia 40101, Costa Rica.
   Cruz-Diaz, Juan C., Amazon Conservat Team, Arlington, VA 22203 USA.},
DOI = {10.3390/ani12192544},
Article-Number = {2544},
Keywords = {density; dry forest; Panthera onca; spatial capture-recapture; sex ratio},
Keywords-Plus = {PANTHERA-ONCA; LEPIDOCHELYS-OLIVACEA; NATIONAL-PARK; MAMMALS; ABUNDANCE;
   HABITAT},
Author-Email = {victor.montalvo.guadamuz@una.cr},
Number-of-Cited-References = {49},
