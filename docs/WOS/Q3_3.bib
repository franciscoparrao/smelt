@incollection{ WOS:000427050500011,
Author = {Howard, Ayanna and Zhang, Cha and Horvitz, Eric},
Book-Group-Author = {IEEE},
Title = {Addressing Bias in Machine Learning Algorithms: A Pilot Study on Emotion
   Recognition for Intelligent Systems},
Booktitle = {2017 IEEE WORKSHOP ON ADVANCED ROBOTICS AND ITS SOCIAL IMPACTS},
Series = {IEEE Workshop on Advanced Robotics and its Social Impacts},
Year = {2017},
Abstract = {Recently, there has been an explosion of cloud-based services that
   enable developers to include a spectrum of recognition services, such as
   emotion recognition, in their applications. The recognition of emotions
   is a challenging problem, and research has been done on building
   classifiers to recognize emotion in the open world. Often, learned
   emotion models are trained on data sets that may not sufficiently
   represent a target population of interest. For example, many of these
   on-line services have focused on training and testing using a majority
   representation of adults and thus are tuned to the dynamics of mature
   faces. For applications designed to serve an older or younger age
   demographic, using the outputs from these pre-defined models may result
   in lower performance rates than when using a specialized classifier.
   Similar challenges with biases in performance arise in other situations
   where datasets in these large-scale on-line services have a
   non-representative ratio of the desired class of interest. We consider
   the challenge of providing application developers with the power to
   utilize pre-constructed cloud-based services in their applications while
   still ensuring satisfactory performance for their unique workload of
   cases. We focus on biases in emotion recognition as a representative
   scenario to evaluate an approach to improving recognition rates when an
   on-line pre-trained classifier is used for recognition of a class that
   may have a minority representation in the training set. We discuss a
   hierarchical classification approach to address this challenge and show
   that the average recognition rate associated with the most difficult
   emotion for the minority class increases by 41.5\% and the overall
   recognition rate for all classes increases by 17.3\% when using this
   approach.},
Type = {Proceedings Paper},
Affiliation = {Howard, A (Corresponding Author), Georgia Inst Technol, Sch Elect \& Comp Engn, Atlanta, GA 30332 USA.
   Howard, A (Corresponding Author), Microsoft Res, Redmond, WA 98052 USA.
   Howard, Ayanna, Georgia Inst Technol, Sch Elect \& Comp Engn, Atlanta, GA 30332 USA.
   Howard, Ayanna; Zhang, Cha; Horvitz, Eric, Microsoft Res, Redmond, WA 98052 USA.},
Number-of-Cited-References = {30},
Times-Cited = {71},
Unique-ID = {WOS:000427050500011},
}

@article{ WOS:000412260100003,
Author = {Gibbs, Jennifer L. and Sivunen, Anu and Boyraz, Maggie},
Title = {Investigating the impacts of team type and design on virtual team
   processes},
Journal = {HUMAN RESOURCE MANAGEMENT REVIEW},
Year = {2017},
Volume = {27},
Number = {4, SI},
Pages = {590-603},
Month = {DEC},
Abstract = {While much is known about virtual team processes and outcomes, the
   literature relies on a variety of team configurations and types
   (including student versus organizational samples, short-term versus
   long-term teams, functional versus project-based teams, and teams with
   various task types) yet has not systematically examined how these
   differences impact team processes. This is important because much of the
   virtual teams research has been based on student samples, which are
   easier to access and control, with the implicit assumption that the
   findings from student samples will generalize to organizational virtual
   teams. This manuscript reviews the last 15 years of research on virtual
   teams and conducts an analysis of team type and study design on a sample
   of 265 articles. We then analyze several systematic differences based on
   these factors that are apparent in research in three areas: leadership,
   cultural composition, and technology use, and develop propositions to
   guide future research in these areas. Our findings have important
   implications for future virtual teams research by suggesting that
   researchers should be more explicit about the biases carried by
   particular methods and designs and the ways in which they impact our
   knowledge of the field. (C) 2016 Elsevier Inc. All rights reserved.},
Type = {Article},
Affiliation = {Gibbs, JL (Corresponding Author), Univ Calif Santa Barbara, Dept Commun, Santa Barbara, CA 93106 USA.
   Gibbs, Jennifer L., Univ Calif Santa Barbara, Dept Commun, Santa Barbara, CA 93106 USA.
   Sivunen, Anu, Univ Jyvaskyla, Jyvaskyla, Finland.
   Boyraz, Maggie, Calif State Polytech Univ Pomona, Dept Commun, Pomona, CA 91768 USA.},
DOI = {10.1016/j.hrmr.2016.12.006},
Keywords-Plus = {FACE-TO-FACE; GEOGRAPHICALLY DISPERSED TEAMS; MUTUAL KNOWLEDGE PROBLEM;
   DISTRIBUTED TEAMS; DECISION-MAKING; TRANSFORMATIONAL LEADERSHIP;
   DEMOGRAPHIC FAULTLINES; CONFLICT-MANAGEMENT; CULTURAL-DIVERSITY; SHARED
   LEADERSHIP},
