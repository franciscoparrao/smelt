   Zheng, Shasha, Shanxi Prov Hosp Tradit Chinese Med, Dept Oncol, Taiyuan, Shanxi, Peoples R China.},
DOI = {10.1038/s41598-022-17916-3},
Article-Number = {13709},
Keywords-Plus = {BLACK-BOX; ANESTHESIA; RESUSCITATION; SCORE; PREDICTION; SURVIVAL},
Author-Email = {yjyangjj@126.com},
