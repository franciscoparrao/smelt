   Sorocco, Kristen H.; Lovallo, William R., Vet Affairs Med Ctr, Behav Sci Labs, Oklahoma City, OK 73104 USA.
   Sorocco, Kristen H., Univ Oklahoma, Hlth Sci Ctr, Donald W Reynolds Dept Geriatr Med, Oklahoma City, OK USA.},
DOI = {10.1111/j.1530-0277.2011.01507.x},
Keywords = {Delay Discounting; Impulsivity; Family History; Alcohol Use Disorders;
   Substance Use Disorders; Antisocial},
Keywords-Plus = {DECISION-MAKING BIASES; SUBSTANCE USE; DEPENDENT PATIENTS; BEHAVIORAL
   IMPULSIVITY; FOLLOW-UP; PERSONALITY; DRINKING; RELIABILITY; RISK;
