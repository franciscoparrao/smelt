}

@incollection{ WOS:000555729900122,
Author = {Hu, Hui and Liu, Yijun and Wang, Zhen and Lan, Chao},
Editor = {Wang, J and Shim, K and Wu, X},
Title = {A Distributed Fair Machine Learning Framework with Private Demographic
   Data Protection},
Booktitle = {2019 19TH IEEE INTERNATIONAL CONFERENCE ON DATA MINING (ICDM 2019)},
Series = {IEEE International Conference on Data Mining},
Year = {2019},
Pages = {1102-1107},
Abstract = {Fair machine learning has become a significant research topic with broad
   societal impact. However, most fair learning methods require direct
   access to personal demographic data, which is increasingly restricted to
   use for protecting user privacy (e.g. by the EU General Data Protection
   Regulation).
   In this paper, we propose a distributed fair learning framework for
   protecting the privacy of demographic data. We assume this data is
   privately held by a third party, which can communicate with the data
   center (responsible for model development) without revealing the
   demographic information. We propose a principled approach to design fair
   learning methods under this framework, exemplify four methods and show
   they consistently outperform their existing counterparts in both
   fairness and accuracy across two real-world data sets. We theoretically
   analyze the framework, and prove it can learn models with high fairness
   or high accuracy, with their trade-offs balanced by a threshold
   variable.},
Type = {Proceedings Paper},
Affiliation = {Hu, H (Corresponding Author), Univ Wyoming, Dept Comp Sci, Laramie, WY 82071 USA.
   Hu, Hui; Liu, Yijun; Wang, Zhen; Lan, Chao, Univ Wyoming, Dept Comp Sci, Laramie, WY 82071 USA.},
DOI = {10.1109/ICDM.2019.00131},
Author-Email = {hhu1@uwyo.edu
   yliu20@uwyo.edu
   zwang10@uwyo.edu
   clan@uwyo.edu},
Number-of-Cited-References = {38},
Times-Cited = {14},
Unique-ID = {WOS:000555729900122},
}

@incollection{ WOS:000535866906088,
Author = {Zhang, Xueru and Khalili, Mohammad Mahdi and Tekin, Cem and Liu, Mingyan},
Editor = {Wallach, H and Larochelle, H and Beygelzimer, A and d'Alche-Buc, F and Fox, E and Garnett, R},
Title = {Group Retention when Using Machine Learning in Sequential Decision
   Making: the Interplay between User Dynamics and Fairness},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 32 (NIPS 2019)},
Series = {Advances in Neural Information Processing Systems},
Year = {2019},
Volume = {32},
Abstract = {Machine Learning (ML) models trained on data from multiple demographic
   groups can inherit representation disparity {[}7] that may exist in the
   data: the model may be less favorable to groups contributing less to the
   training process; this in turn can degrade population retention in these
   groups over time, and exacerbate representation disparity in the long
   run. In this study, we seek to understand the interplay between ML
   decisions and the underlying group representation, how they evolve in a
   sequential framework, and how the use of fairness criteria plays a role
   in this process. We show that the representation disparity can easily
   worsen over time under a natural user dynamics (arrival and departure)
   model when decisions are made based on a commonly used objective and
   fairness criteria, resulting in some groups diminishing entirely from
   the sample pool in the long run. It highlights the fact that fairness
   criteria have to be defined while taking into consideration the impact
   of decisions on user dynamics. Toward this end, we explain how a proper
   fairness criterion can be selected based on a general user dynamics
   model.},
Type = {Proceedings Paper},
Affiliation = {Zhang, XR (Corresponding Author), Univ Michigan, Ann Arbor, MI 48109 USA.
   Zhang, Xueru; Khalili, Mohammad Mahdi; Liu, Mingyan, Univ Michigan, Ann Arbor, MI 48109 USA.
   Tekin, Cem, Bilkent Univ, Ankara, Turkey.},
Author-Email = {xueru@umich.edu
   khalili@umich.edu
   cemtekin@ee.bilkent.edu.tr
   mingyan@umich.edu},
Number-of-Cited-References = {17},
Times-Cited = {14},
Unique-ID = {WOS:000535866906088},
}

@article{ WOS:000416184500057,
Author = {Carbajal, Jessica M. and Gamboa, Jorge L. and Moore, Jordan and Smith,
   Favrin and Eads, Lou Arm and Clothier, Jeffrey L. and Caceda, Ricardo},
Title = {Response to unfairness across the suicide risk spectrum},
Journal = {PSYCHIATRY RESEARCH},
Year = {2017},
Volume = {258},
Pages = {365-373},
Month = {DEC},
Abstract = {Suicidal behavior is frequently triggered by social crises, such as
   familial, romantic, social or work-related conflict. A variety of
   cognitive and social functioning impairments has been associated with
   suicidal thoughts and acts. One of the precipitating and perpetuating
   factors of social conflict is the desire for retribution after a
   perceived offense, even at one's own detriment. We utilized the
   Ultimatum Game-a behavioral economic task which examines the behavioral
   response to perceived unfairness-in order to characterize the response
   to unfairness across the acute suicide risk spectrum. We examined five
   groups of adult individuals of both genders (n = 204): High- and
   Low-Lethality recent Suicide Attempters, Suicidal Ideators, Non-Suicidal
   Depressed Patients; and Healthy Controls. We also measured demographic
   and clinical variables. Even though all depressed groups showed similar
   rejection rates in the Ultimatum Game, there was a higher likelihood of
   rejecting offers in the low stakes condition in all acutely suicidal
   groups compared with healthy controls. Stake size, offer, education, and
   gender of the proposer were significantly associated with rejection
   rates. Acutely suicidal patients may be more vulnerable to adverse
   interpersonal interactions. Further characterization of social behavior
   may provide targets for secondary and tertiary prevention for high-risk
   individuals.},
Type = {Article},
Affiliation = {Cáceda, R (Corresponding Author), Univ Arkansas Med Sci, Psychiat Res Inst, Little Rock, AR 72205 USA.
   Carbajal, Jessica M., Pinnacle Pointe Behav Hlth Care Syst, Little Rock, AR USA.
   Gamboa, Jorge L., Vanderbilt Univ, Dept Med, Nashville, TN USA.
   Moore, Jordan; Smith, Favrin; Eads, Lou Arm; Clothier, Jeffrey L.; Caceda, Ricardo, Univ Arkansas Med Sci, Psychiat Res Inst, Little Rock, AR 72205 USA.},
DOI = {10.1016/j.psychres.2017.08.071},
Keywords = {Suicide; Social behavior; Decision making; Fairness; Psychological
   distress; Depression; Inpatient},
Keywords-Plus = {MAJOR DEPRESSIVE DISORDER; SOCIAL DECISION-MAKING; ULTIMATUM GAME;
   PERCEIVED BURDENSOMENESS; AUTOBIOGRAPHICAL MEMORY; INTERPERSONAL
   STRESSORS; PSYCHOLOGICAL PAIN; BRAIN RESPONSES; MENTAL PAIN; ATTEMPTERS},
Author-Email = {rcaceda@uams.edu},
Number-of-Cited-References = {81},
Times-Cited = {14},
Unique-ID = {WOS:000416184500057},
}

@article{ WOS:000393308000006,
Author = {Devine, Dennis J. and Krouse, Paige C. and Cavanaugh, Caitlin M. and
   Basora, Jaime Colon},
Title = {Evidentiary, Extraevidentiary, and Deliberation Process Predictors of
   Real Jury Verdicts},
Journal = {LAW AND HUMAN BEHAVIOR},
Year = {2016},
Volume = {40},
Number = {6},
Pages = {670-682},
Month = {DEC},
Abstract = {In contrast to the extensive literature based on mock jurors,
   large-sample studies of decision making by real juries are relatively
   rare. In this field study, we examined relationships between jury
   verdicts and variables representing 3 classes of potential
   determinants-evidentiary, extraevidentiary, and deliberation
   process-using a sample of 114 criminal jury trials. Posttrial data were
   collected from 11 presiding judges, 31 attorneys, and 367 jurors using a
   Web-based questionnaire. The strength of the prosecution's evidence was
   strongly related to the occurrence of a conviction, whereas most
   extraevidentiary and deliberation process variables were only weakly to
   modestly related in bivariate form and when the prosecution's evidence
   strength was controlled. Notable exceptions to this pattern were jury
   demographic diversity as represented by the number of different
   race-gender subgroups (e.g., Black males) present in the jury, and
   several deliberation process variables reflecting advocacy for acquittal
   (e.g., presence of an identifiable proacquittal faction within the jury
   and proacquittal advocacy by the foreperson). Variables reflecting
   advocacy for conviction were essentially unrelated to jury verdict. Sets
   of extraevidentiary and deliberation variables were each able to
   modestly improve the explanation of jury verdicts over prosecution
   evidence strength in multivariate models. This study highlights the
   predictive efficacy of prosecution evidence strength with respect to
   jury verdicts, as well as the potential importance of jury demographic
   diversity and advocacy for acquittal during deliberation.},
Type = {Article},
Affiliation = {Devine, DJ (Corresponding Author), Indiana Univ Purdue Univ, LD 124,402 North Blackford St, Indianapolis, IN 46202 USA.
   Devine, Dennis J.; Krouse, Paige C.; Cavanaugh, Caitlin M.; Basora, Jaime Colon, Indiana Univ Purdue Univ, LD 124,402 North Blackford St, Indianapolis, IN 46202 USA.
   Krouse, Paige C., Univ Manchester, Grants Off, North Manchester, IN USA.
   Cavanaugh, Caitlin M., Quintela Grp LLC, Indianapolis, IN USA.
   Basora, Jaime Colon, Harris Corp, Palm Bay, FL USA.},
DOI = {10.1037/lhb0000209},
Keywords = {jury decision making; verdicts; strength of evidence; extraevidentiary
   bias; deliberation process},
Keywords-Plus = {GROUP DECISION-MAKING; PROCEDURAL INFLUENCE; TRIAL; IMPACT; EXPERIENCE;
   JUDGMENTS; JURIES; BIAS},
Author-Email = {ddevine@iupui.edu},
Number-of-Cited-References = {45},
Times-Cited = {14},
Unique-ID = {WOS:000393308000006},
}

@article{ WOS:000363957700009,
Author = {Rodriguez-Munoz, Rolando and Rodriguez del Valle, Carlos and Jose
   Banuelos, Maria and Mirol, Patricia},
Title = {Revealing the consequences of male-biased trophy hunting on the
   maintenance of genetic variation},
Journal = {CONSERVATION GENETICS},
Year = {2015},
Volume = {16},
Number = {6},
Pages = {1375-1394},
Month = {DEC},
Abstract = {Demographic models accounting for operational sex ratio (OSR) show that
   male numbers can have a substantial influence on the dynamics of wild
   populations. We used the Cantabrian capercaillie, a forest bird, as a
   model to assess the effects of the reduction in the number of breeding
   males (increased OSR) associated to male-biased hunting, on the genetics
   of the population. We based our assessment in the comparison of the
   dynamics of neutral markers transmitted by both parents
   (microsatellites) versus markers transmitted only by females
   (mitochondrial DNA-mtDNA). Parallel to the analysis of field data, we
   ran computer simulations to explore how different levels of OSR and two
   other important demographic factors, population size and connectivity,
   might influence the dynamics of genetic variation of microsatellites and
   mtDNA. We found evidence of a genetic bottleneck and low genetic
   variability affecting microsatellites but not mtDNA early in our study
   period, when male-biased hunting was more intense. This was followed by
   a decline in mtDNA variation around 10-20 years later. Simulations
   suggested that changes in genetic variation associated with high OSR had
   the closest similarity to those observed at the beginning of our study,
   whereas a combination of reduced size and migration rate better
   resembled the patterns found later on. Our findings indicate that
   male-biased hunting might have triggered the ongoing decline of the
   Cantabrian capercaillie, on its own or in combination with habitat
   configuration, and support the need to incorporate OSR into decision
   making for the management and conservation of exploited populations.},
Type = {Article},
Affiliation = {Mirol, P (Corresponding Author), Museo Argentino Ciencias Nat Bernardino Rivadavia, Grp Genet \& Ecol Conservac \& Biodiversidad, Angel Gallardo 470,C1405DJR, Buenos Aires, DF, Argentina.
   Rodriguez-Munoz, Rolando; Rodriguez del Valle, Carlos, Univ Exeter, Ctr Ecol \& Conservat, Penryn TR10 9EZ, Cornwall, England.
