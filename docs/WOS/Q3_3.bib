   Routman, Howard, Atlantis Orthoped, Palm Beach Gardens, FL USA.
   Roche, Christopher P., Exactech, 2320 NW 66th Court, Gainesville, FL 32653 USA.},
DOI = {10.1016/j.jse.2023.08.005},
EarlyAccessDate = {MAR 2024},
