DOI = {10.1016/j.ajem.2023.08.021},
EarlyAccessDate = {AUG 2023},
Keywords = {Cognitive biases; Decision making; Emergency nurses; Emergency severity
   index; Quality care; Patient safety},
Keywords-Plus = {DECISION-MAKING; CARE},
