DOI = {10.3390/app15158409},
Article-Number = {8409},
Keywords = {student performance prediction; logistic regression; explainable AI
   (XAI); SHAP; fairness in education; adversarial debiasing; SMOTE;
   educational data mining; machine learning in education; model
   interpretability},
Author-Email = {kadir@bandirma.edu.tr
