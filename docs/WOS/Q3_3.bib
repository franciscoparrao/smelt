   Santos, Clara; Moita, Joaquim, Coimbra Hosp \& Univ Ctr, Sleep Med Ctr, Coimbra, Portugal.},
DOI = {10.1016/j.smrv.2022.101659},
Article-Number = {101659},
Keywords = {Obstructive sleep apnea; Biomarkers; Diagnosis; Prognosis; Systematic
   review; Meta-analysis},
