   Baumgartner, Thomas; Fehr, Ernst, Univ Zurich, Inst Empir Res Econ, Zurich, Switzerland.
   Fehr, Ernst, Coll Helveticum, Zurich, Switzerland.},
DOI = {10.1177/0956797609360750},
Keywords = {costly punishment behavior; prefrontal cortex; resting EEG; individual
   differences; decision making; source localization},
Keywords-Plus = {FRONTAL EEG ASYMMETRY; PREFRONTAL CORTEX; FAIRNESS; BANDS},
Author-Email = {daria.knoch@unibas.ch
