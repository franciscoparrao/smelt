@article{ WOS:000681134700008,
Author = {Panigutti, Cecilia and Perotti, Alan and Panisson, Andre and Bajardi,
   Paolo and Pedreschi, Dino},
Title = {FairLens: Auditing black-box clinical decision support systems},
Journal = {INFORMATION PROCESSING \& MANAGEMENT},
Year = {2021},
Volume = {58},
Number = {5},
Month = {SEP},
Abstract = {The pervasive application of algorithmic decision-making is raising
   concerns on the risk of unintended bias in AI systems deployed in
   critical settings such as healthcare. The detection and mitigation of
   model bias is a very delicate task that should be tackled with care and
   involving domain experts in the loop. In this paper we introduce
   FairLens, a methodology for discovering and explaining biases. We show
   how this tool can audit a fictional commercial black-box model acting as
   a clinical decision support system (DSS). In this scenario, the
   healthcare facility experts can use FairLens on their historical data to
   discover the biases of the model before incorporating it into the
   clinical decision flow. FairLens first stratifies the available patient
   data according to demographic attributes such as age, ethnicity, gender
   and healthcare insurance; it then assesses the model performance on such
   groups highlighting the most common misclassifications. Finally,
   FairLens allows the expert to examine one misclassification of interest
   by explaining which elements of the affected patients' clinical history
   drive the model error in the problematic group. We validate FairLens'
   ability to highlight bias in multilabel clinical DSSs introducing a
   multilabel-appropriate metric of disparity and proving its efficacy
   against other standard metrics.},
Type = {Article},
Affiliation = {Panigutti, C (Corresponding Author), Scuola Normale Super Pisa, Pisa, Italy.
   Panigutti, Cecilia, Scuola Normale Super Pisa, Pisa, Italy.
   Perotti, Alan; Panisson, Andre; Bajardi, Paolo, ISI Fdn, Turin, Italy.
   Pedreschi, Dino, Univ Pisa, Pisa, Italy.},
DOI = {10.1016/j.ipm.2021.102657},
EarlyAccessDate = {JUN 2021},
Article-Number = {102657},
Keywords = {Clinical decision support systems; Fairness and bias in machine learning
   systems; eXplainable artificial intelligence},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; HEALTH; EXPLANATIONS; PREDICTION; BIAS;
   CLASSIFICATION; REPRESENTATION; ALGORITHM},
Author-Email = {cecilia.panigutti@sns.it},
Number-of-Cited-References = {97},
