   Zhang, Shichao, Guangxi Normal Univ, Guangxi Key Lab Multisource Informat Min \& Secur, Guilin 541004, Guangxi, Peoples R China.},
DOI = {10.1016/j.neunet.2024.106781},
EarlyAccessDate = {OCT 2024},
Article-Number = {106781},
Keywords = {Fair representation learning; Graph neural network; Fairness;
   Causality-inspired machine learning},
Author-Email = {yuanguan@cumt.edu.cn
