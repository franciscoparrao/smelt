   Hartmann, Timo; Floeck, Fabian, GESIS Cologne, Cologne, Germany.
   Wang, Zijian; Jurgens, David, Univ Michigan, Ann Arbor, MI 48109 USA.},
DOI = {10.1145/3308558.3313684},
Keywords = {Demographics; Post-stratification; Social Media; Latent Attribute
   Inference; Inclusion Probabilities; Multilingual; Deep Learning},
Keywords-Plus = {AGE},
