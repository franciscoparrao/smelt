Keywords = {Fairness; Bias; Generative adversarial network; Artificial intelligence},
Keywords-Plus = {DISCRIMINATION},
Author-Email = {amirarsalan@knights.ucf.edu
   ozlem@ucf.edu},
Number-of-Cited-References = {32},
