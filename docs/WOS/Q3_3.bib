   van Witteloostuijn, Arjen, Univ Antwerp, Antwerp, Belgium.
   van Witteloostuijn, Arjen, Tilburg Univ, Econ \& Management, Tilburg, Netherlands.
   van den Berg, Annette, Univ Utrecht, Sch Econ, Utrecht, Netherlands.},
DOI = {10.1177/0143831X15578721},
Keywords = {Cooperation; group composition; procedural justice; works councils},
Keywords-Plus = {INFORMATION-SYSTEM DEVELOPMENT; DECISION-MAKING; DEMOGRAPHIC FAULTLINES;
