   Schoenbrunner, Anna, Univ Calif San Diego, Sch Med, San Diego, CA 92103 USA.
   Unkart, Jonathan; Wallace, Anne M., Univ Calif San Diego, Dept Surg, Moores Canc Ctr, San Diego, CA 92103 USA.},
DOI = {10.1097/SLA.0000000000002698},
Keywords = {breast cancer; breast conservation; decision-making; mastectomy; patient
