   Shoup, Jo Ann, Kaiser Permanente Colorado, Inst Hlth Res, Denver, CO USA.
   Ray, Paula, Kaiser Permanente No Calif, Oakland, CA USA.
   Nordin, James D.; Kuckler, Leslie, HealthPartners Res Fdn, Minneapolis, MN USA.
   Weintraub, Eric S., CDC, Immunizat Safety Off, Atlanta, GA 30333 USA.},
DOI = {10.1016/j.amepre.2009.08.022},
Keywords-Plus = {SELF-REPORT; VALIDATION; WOMEN; OLDER},
