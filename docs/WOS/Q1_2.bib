   Liu, Shang, PKU WUHAN Inst Artificial Intelligence, Wuhan, Hubei, Peoples R China.
   Gu, Weixi, China Acad Ind Internet, Beijing, Peoples R China.},
DOI = {10.1002/itl2.70034},
