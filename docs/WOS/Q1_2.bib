@article{ WOS:001667393200002,
Author = {Duan, Chenghong and Cao, Xiankun and Luo, Xiangpeng and Hao, Xiaojie and
   Xu, Hangcheng},
Title = {Process Optimization and Tribological Performance Investigation on
   Ti6Al4V⁃NiTi Heterogeneous Materials Fabricated by Directed Energy
   Deposition},
Journal = {CHINESE JOURNAL OF LASERS-ZHONGGUO JIGUANG},
Year = {2025},
Volume = {52},
Number = {24},
Month = {DEC},
Abstract = {Objective The directed energy deposition of Ti6Al4V-NiTi heterogeneous
   materials enables complementary characteristics. However, challenges
   remain due to the poor interfacial bonding between the two materials and
   the tendency for internal microdefects during fabrication, which impose
   stringent requirements on the forming parameters. Therefore, this study
   utilizes extensive experimental data and applies machine learning and
   deep learning techniques to uncover the underlying relationships within
   the data. The goal is to establish an optimized process route for the
   directed energy deposition of Ti6Al4V-NiTi heterogeneous materials with
   different powder mass ratios, providing an efficient solution to the
   above--mentioned issues. Furthermore, based on the optimized process
   parameters, high-performance coatings are fabricated to investigate the
   evolution of solidified microstructures under different powder mass
   ratios. Their effects on hardness and tribological performance are also
   tested and analyzed. This study aims to reveal the ``
   ``process--structure--property-property{''} relationships in
   Ti6Al4V-NiTi heterogeneous material coatings fabricated by directed
   energy deposition. The findings could offer methodological and technical
   support for the high--quality fabrication of multi--material metal
   additive--manufacturing components. Methods In this study, a total of
   120 single-track specimens were fabricated using directed energy
   deposition equipment (LAM 150V) under six different Ti6Al4V-NiTi powder
   mass ratios. The machine learning model XGBoost and the deep learning
   model TabPFN were trained on experimentally obtained forming
   morphologies and defect types data. Their predictive performances were
   compared with benchmark models, and the optimal models were selected to
   predict the ideal process windows for different Ti6Al4V-NiTi powder mass
   ratios. Based on these predictions, single--layer and multi--track
   coatings were fabricated using optimized process parameters under each
   powder mass ratio. The solidified microstructures and elemental
   distributions within the molten pools were observed using a scanning
   electron microscope (ZEISS EVO MA 25) and an energy--dispersive
   spectrometer (AZtec X--Max 50). The phase compositions of the specimens
   were analyzed using X-ray diffraction (Rigaku SmartLab SE), and the
   distributions of brittle intermetallic phases were characterized using
   electron back--scatter diffraction and AZtecCrystal software.
   Additionally, the Vickers hardnesses of the fabricated layers were
   measured using a micro--hardness tester (Mitutoyo HM--200). Finally,
   room--temperature dry--wear tests were conducted in air using a
   tribometer (Bruker UMT-TriboLab) to evaluate their wear resistance.
   These comprehensive analyses could provide detailed insights into the ``
   ``process--structure--property-property{''} relationships of
   Ti6Al4V-NiTi heterogeneous materials fabricated by directed energy
   deposition. Results and Discussions For the intelligent models trained
   on the experimental dataset of single-track deposition samples, the deep
   learning models TabPFN and TabPFN\_PHE achieved the highest accuracy in
   forming morphologies prediction. The root--mean-square error (RMSE)
   values for predicting heat--affected zone (HAZ) width, HAZ depth, molten
   pool width, and deposited height ranged from 50.9300 to 103.8703 mu m
   (Table 1). In the defect types prediction, the machine learning models
   XGBoost and Random Forest achieved the highest accuracy (both reaching
   0.9000) and F1--score (both reaching 0.9000) (Table 2).
   Using the optimal models, the ideal process parameters for different
   powder mass ratios were identified (Fig. 3). Under the ideal process
   parameters, single--layer and multi--track specimens with different
   powder mass ratios were fabricated. In the 20 degrees oNiTi deposition
   layer, beta-Ti grains were significantly refined, and irregular
   anomalous eutectic structures (beta-Ti+Ti2Ni) were precipitated at the
   grain boundaries (Fig. 4). In the 40 \% NiTi and 60 \%NiTi deposition
   layers, the content of the high--hardness brittle intermetallic phase
   Ti2Ni gradually increased (Fig. 4), resulting in the 60 degrees oNiTi
   layer attaining the highest Vickers hardness of 788.4 HV (Fig. 5). This
   layer also exhibited the best wear resistance, with no cracks observed
   on the worn surface, only minor wear debris and loose fragments (Fig.
   6). The wear resistance of the 60 \% NiTi layer improved by 25.7 \%and
   36.0 \% compared to the pure NiTi and Ti6Al4V layers, respectively (Fig.
   7). In the 80 degrees oNiTi deposition layer, irregular primary NiTi
   phases appeared within the Ti2Ni matrix, and the pure NiTi deposition
   layer contained 70.2 degrees \%NiTi phase (Fig. 4), leading to a decline
   in wear resistance. Severe plastic deformation and cracks were observed
   on the worn surface of the pure NiTi layer (Fig. 6). Conclusions This
   study focuses on the directed energy deposition of Ti6Al4V-NiTi
   heterogeneous materials. An extensive experimental dataset was
   constructed under different powder mass ratios of the heterogeneous
   materials. State-of-the-art machine learning and deep learning
   algorithms were employed to predict the forming morphologies and defect
   types. Through comparisons with benchmark performances, the optimal
   algorithms were used to identify the ideal process windows for different
   powder mass ratios. Based on the predicted results, single--layer and
   multi--track coatings were fabricated, and their solidified
   microstructures, hardness, and tribological performance were tested and
   analyzed. This study provides process optimization methods and
   references for manufacturing high--quality Ti6Al4V-NiTi heterogeneous
   material coatings via directed energy deposition. It clarifies the
   evolution mechanism of microstructures under different heterogeneous
   powder mass ratios and the principles for regulating their hardness and
   tribological performance. Future research will further integrate deep
   learning models to analyze and predict the microstructure and quality
   performance data of additive--manufactured heterogeneous materials,
   providing theoretical methods and technical support for establishing the
   `` ``process-structure--property-property{''} relationships in greater
   depth.},
Type = {Article},
Affiliation = {Luo, XP (Corresponding Author), Beijing Univ Chem Technol, Coll Mech \& Elect Engn, Beijing 100029, Peoples R China.
   Duan, Chenghong; Cao, Xiankun; Luo, Xiangpeng; Hao, Xiaojie; Xu, Hangcheng, Beijing Univ Chem Technol, Coll Mech \& Elect Engn, Beijing 100029, Peoples R China.},
DOI = {10.3788/CJL250722},
Article-Number = {2402301},
Keywords = {directed energy deposition; heterogeneous materials; machine learning
   and deep learning; process optimization; tribological performance},
Keywords-Plus = {MICROSTRUCTURE},
Author-Email = {xpluo@mail.buct.edu.cn},
Number-of-Cited-References = {26},
Times-Cited = {0},
Unique-ID = {WOS:001667393200002},
}

@article{ WOS:001615345000001,
Author = {Wu, Xiaoyu and Zheng, Rui and Liu, Quan and Jiang, Jianwen},
Title = {Digital Discovery of Synthesizable Metal-Organic Frameworks via
   Molecular Dynamics-Informed, High-Fidelity Deep Learning},
Journal = {ADVANCED FUNCTIONAL MATERIALS},
Year = {2026},
Volume = {36},
Number = {14},
Month = {FEB 1},
Abstract = {Metal-organic frameworks (MOFs) are celebrated for their chemical and
   structural versatility, and in-silico screening has significantly
   accelerated their discovery; yet most hypothetical MOFs (hMOFs) never
   reach the bench because their synthetic feasibility remains unknown.
   Herein, a deep-learning proxy based on the Tabular Prior-Data Fitted
   Network (TabPFN) is introduced that predicts free energy with high
   fidelity. The fine-tuned surrogate attains a coefficient of
   determination (R 2) of 0.96 and a mean absolute error (MAE) of 0.67 on
   the hold-out test set, preserves strong temporal generalization (R 2 =
   0.89 and MAE = 1.35), as well as robust extrapolation on a chemically
   diverse blind set. Applying the surrogate to a well-established hMOF
   library, we rapidly flag prime hMOF candidates that fall within the
   synthetic-likelihood window observed for experimentally realized MOFs.
   This study delivers a practical bridge between digital reticular design
   and laboratory synthesis, transforming synthetic-likelihood assessment
   from a computational bottleneck into a routine, high-throughput step.
   Beyond MOFs, the approach provides a general framework for accelerating
   free-energy-driven materials discovery with minimal loss of accuracy,
   opening a new avenue to data-driven exploration of complex chemical
   spaces.},
Type = {Article},
Affiliation = {Jiang, JW (Corresponding Author), Natl Univ Singapore, Dept Chem \& Biomol Engn, Singapore 117576, Singapore.
   Wu, Xiaoyu; Zheng, Rui; Liu, Quan; Jiang, Jianwen, Natl Univ Singapore, Dept Chem \& Biomol Engn, Singapore 117576, Singapore.
   Liu, Quan, Anhui Univ Sci \& Technol, Analyt \& Testing Ctr, Sch Chem \& Blasting Engn, Huainan 232001, Peoples R China.
   Jiang, Jianwen, Natl Univ Singapore, NUS Grad Sch Integrat Sci \& Engn Programme, Singapore 119077, Singapore.},
DOI = {10.1002/adfm.202519565},
EarlyAccessDate = {NOV 2025},
Keywords = {deep learning; metal-organic frameworks; molecular simulation; synthetic
