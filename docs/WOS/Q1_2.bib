@article{ WOS:001721989200003,
Author = {Deng, Lin and Xie, Linghui and Zhu, Sijia and Li, Zhi and Lin, Fangzhou},
Title = {Enhancing the prediction accuracy of concrete properties with knowledge
   constrained data augmentation and tabular foundation model},
Journal = {APPLIED SOFT COMPUTING},
Year = {2026},
Volume = {195},
Month = {JUN},
Abstract = {Unconstrained data augmentation for small material data can produce
   abnormal synthetic data (SD) that contradicts established material
   science principles. This study proposes a knowledge constrained data
   augmentation (KCDA) strategy to produce high-fidelity synthetic data
   based on domain knowledge derived from real data and utilize a tabular
   foundation model called the Tabular Prior-data Fitted Network (TabPFN)
   to enhance the prediction accuracy of concrete properties based on a
   total of 15 concrete datasets with varied sample sizes and prediction
   targets. Four data augmentation methods are used to produce synthetic
   training data, which is further processed by three anomaly detection
   methods to detect and remove the abnormal samples in the synthetic
   training data to formulate the constrained synthetic training data. Five
   training scenarios are formulated to validate the effectiveness of the
   KCDA strategy by constructing different training data sets. Results show
   that: (1) TabPFN is highly competitive in achieving superior model
   performance with less training time; (2) Combining real and synthetic
   training data significantly enhances model performance over using
   synthetic data alone; (3) The constrained synthetic training data
   enhances model performance over using unconstrained one. (4) The KCDA
   strategy significantly enhances model performance compared with
   performance without using data augmentation, especially when the real
   training data is integrated.},
Type = {Article},
Affiliation = {Lin, FZ (Corresponding Author), Hong Kong Univ Sci \& Technol, Dept Civil \& Environm Engn, Hong Kong, Peoples R China.
   Deng, Lin, Hefei Univ Technol, Sch Management, Hefei, Anhui, Peoples R China.
   Deng, Lin, Anhui Prov Investment Grp Holdings Co Ltd, Hefei, Anhui, Peoples R China.
   Xie, Linghui; Lin, Fangzhou, Hong Kong Univ Sci \& Technol, Dept Civil \& Environm Engn, Hong Kong, Peoples R China.
   Zhu, Sijia, Minist Transport, TianJin Res Inst Water Transport Engn, Tianjin 300456, Peoples R China.
   Li, Zhi, Hong Kong Polytech Univ, Dept Civil \& Environm Engn, Hong Kong, Peoples R China.},
DOI = {10.1016/j.asoc.2026.115037},
Article-Number = {115037},
Keywords = {Concrete property prediction; Domain knowledge; Data augmentation;
   Tabular foundation model},
Author-Email = {flinan@connect.ust.hk},
Number-of-Cited-References = {69},
Times-Cited = {0},
