Keywords-Plus = {EMERGENCY LAPAROTOMY; MORTALITY; SURGERY; COMPLICATIONS; CALCULATOR;
   OUTCOMES; FAILURE; PATIENT; DISEASE; POSSUM},
Author-Email = {thiels.cornelius@mayo.edu},
