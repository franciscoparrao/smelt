   Wang, Xingju, Shijiazhuang Tiedao Univ, Sch Traff \& Transportat, Shijiazhuang 050043, Peoples R China.},
DOI = {10.1109/JSEN.2025.3635347},
Keywords = {Rough surfaces; Roads; Vibrations; Data models; Training; Sensors;
   Estimation; Feature extraction; Radio frequency; Predictive models;
   Intelligent response device (IRD); international roughness index (IRI);
   tabular prior-data fitted network (TabPFN); vibration},
Keywords-Plus = {PAVEMENT ROUGHNESS},
