@article{ WOS:001629819800001,
Author = {Alatefi, Saad and Agwu, Okorie Ekwe and Amar, Menad Nait and Alkouh,
   Ahmad},
Title = {Comparative analysis of robust machine learning models for predicting
   CO2 uptake in porous liquids: Insights for environmental applications},
Journal = {APPLIED SOFT COMPUTING},
Year = {2026},
Volume = {187},
Month = {FEB},
Abstract = {Amid growing efforts to mitigate anthropogenic carbon emissions,
   innovative pathways for selective and efficient CO2 capture are urgently
   needed. Porous liquids (PLs), combining the dynamic nature of liquids
   with the advantages of porous materials, have emerged as a versatile
   platform for next-generation capture technologies. Yet, the experimental
   evaluation of their CO2 uptake performance under diverse compositions
   and conditions remains a time- and resource-intensive challenge. In this
   study, we perform a comparative evaluation of three robust machine
   learning (ML) techniques, including Generalized Regression Neural
   Networks (GRNN), Light Gradient Boosting Machine (LGBM), and Tabular
   Prior data Fitted Network (TabPFN), to predict CO2 uptake across diverse
   PL systems. A large, heterogenous dataset encompassing variations in PL
   type, weight fraction, temperature, and pressure was used to train and
   validate the models. Among them, TabPFN achieved the highest accuracy,
   delivering an average absolute relative error (AARE) of 0.6756 \% and an
   R2 score of 0.9999, exceeding the predictive performance of the
   best-existing paradigms. Error pattern analyses, trend analysis
   assessments, and feature importance investigations based on explainable
   artificial intelligence (XAI) consistently confirmed the reliability and
   transparency of TabPFN's predictions. Furthermore, statistical
   validation through leverage diagnostic revealed that 97 \% of samples
   fell within the model's accepted applicability domain. The proposed
   TabPFN-based predictive tool offers a powerful and efficient alternative
   to experimental screening, facilitating faster material design. Its
   applicability spans academic research and industrial deployment,
   offering a robust foundation for accelerating carbon capture initiatives
   and contributing meaningfully to scalable carbon capture and storage
   solutions. Moreover, by employing soft computing techniques such as
   machine learning and XAI, this work directly addresses modern
   environmental challenges, demonstrating its relevance for sustainable
   engineering applications.},
Type = {Article},
Affiliation = {Alatefi, S (Corresponding Author), PAAET, Coll Technol Studies, Dept Petr Engn Technol, Kuwait 70654, Kuwait.
   Alatefi, Saad; Alkouh, Ahmad, PAAET, Coll Technol Studies, Dept Petr Engn Technol, Kuwait 70654, Kuwait.
   Agwu, Okorie Ekwe, Univ Teknol PETRONAS, Petr Engn Dept, Seri Iskandar 32610, Perak Darul Rid, Malaysia.
   Agwu, Okorie Ekwe, Univ Teknol PETRONAS, Inst Sustainable Energy, Ctr Reservoir Dynam CORED, Seri Iskandar 32610, Perak Darul Rid, Malaysia.
   Amar, Menad Nait, Sonatrach, Dept Etud Thermodynam, Div Labs, Ave 1er Novembre, Boumerdes 35000, Algeria.},
DOI = {10.1016/j.asoc.2025.114325},
EarlyAccessDate = {NOV 2025},
Article-Number = {114325},
Keywords = {Carbon dioxide; Porous liquids; Carbon capture; Machine learning;
   Modeling; TabPFN},
Keywords-Plus = {GAS; CAPTURE; ABSORPTION; PLATFORM},
Author-Email = {se.alatefi@paaet.edu.kw},
