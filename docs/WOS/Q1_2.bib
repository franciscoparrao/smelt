@article{ WOS:001704391000001,
Author = {Kang, Xuming and Zhao, Yanfang and Tan, Zhijun and Yao, Lin and Guo,
   Yingying},
Title = {Enhancing kelp origin prediction accuracy: A TabPFN model with stable
   isotope analysis and explainability techniques for robust insights},
Journal = {FOOD CHEMISTRY},
Year = {2026},
Volume = {509},
Month = {APR 30},
Abstract = {Accurate prediction of kelp origin is essential for effective quality
   and safety management. To this end, we integrated the stable isotope
   ratios and contents of carbon, nitrogen, oxygen, and hydrogen in kelp
   samples from diverse origins with an explainable TabPFN model. The
   results indicated that, with the exception of H, the remaining variables
   showed significant regional variations. Under its default configuration,
   the TabPFN model achieved remarkable performance in 2.5 s, boasting
   accuracy of 100.0\% (95\% CI: 87.5\%-100.0\%), together with precision,
   recall, and F1 score all of 100.0\%, and an AUC of 1.000. Notably, it
   attained a 5782 fold end to end speedup over tuned traditional machine
   learning models. Furthermore, the Local Interpretable Model-agnostic
   Explanations (LIME) tool provided valuable insights into the individual
   contributions of key features and their impact on individual
   predictions. This work presents a robust and innovative approach for
   identifying the geographical origins of kelp in China.},
Type = {Article},
Affiliation = {Guo, YY (Corresponding Author), Chinese Acad Fishery Sci, Yellow Sea Fisheries Res Inst, Key Lab Testing \& Evaluat Aquat Prod Safety \& Qual, Minist Agr \& Rural Affairs, Qingdao 266071, Peoples R China.
