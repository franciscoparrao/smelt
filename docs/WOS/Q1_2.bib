}

@article{ WOS:001706382400002,
Author = {Liu, Bai and Chen, Yun and Yang, Dazhi},
Title = {Evaluating TabPFN for regression tasks in solar energy meteorology},
Journal = {SOLAR ENERGY},
Year = {2026},
Volume = {309},
Month = {MAY 1},
Abstract = {Regression using tabular data is a cornerstone technique in solar energy
   meteorology for prediction, bias correc tion, and trend analysis. For
   over two decades, gradient-boosted trees have dominated this task.
   Recently, how ever, a generative transformer-based foundation model-the
   Tabular Prior-data Fitted Network (TabPFN)-has been proposed as a
   high-performance alternative. To evaluate this claim, we apply TabPFN to
   three well-established problems in solar energy meteorology: bias
   correction of satellite-derived irradiance, decomposition of global
   horizontal irradiance into diffuse and beam components, and solar power
   forecasting with numerical weather prediction. Our results demonstrate
   that TabPFN consistently outperforms gradient-boosted decision trees,
   with the most notable gains observed in nonlinear and high-dimensional
   tasks. More broadly, these find ings suggest that TabPFN has the
   potential to advance predictive analysis using tabular data across
   atmospheric sciences.},
Type = {Article},
Affiliation = {Yang, DZ (Corresponding Author), Harbin Inst Technol, Sch Elect Engn \& Automat, Harbin, Heilongjiang, Peoples R China.
   Liu, Bai; Yang, Dazhi, Harbin Inst Technol, Sch Elect Engn \& Automat, Harbin, Heilongjiang, Peoples R China.
   Chen, Yun, China Meteorol Adm, Publ Meteorol Serv Ctr, Beijing, Peoples R China.
   Chen, Yun; Yang, Dazhi, China Meteorol Adm, Key Lab Energy Meteorol, Beijing, Peoples R China.},
DOI = {10.1016/j.solener.2026.114472},
Article-Number = {114472},
Keywords = {TabPFN; Solar energy meteorology; Regression; Tabular data;
   Gradient-boosted decision trees},
Keywords-Plus = {SITE-ADAPTATION; RESOLUTION},
Author-Email = {yangdz@hit.edu.cn},
