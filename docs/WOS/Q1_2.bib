Keywords = {hybrid model; linear friction weld; machine learning; SVM; weld quality
   prediction},
Keywords-Plus = {MECHANICAL-PROPERTIES; MICROSTRUCTURE; TEMPERATURE; BEHAVIOR; TC11},
Author-Email = {fqxie@nwpu.edu.cn},
Number-of-Cited-References = {35},
