@article{ WOS:001718317600006,
Author = {Li, Hongliang and Zhang, Yueyue and Mei, Hangru and Yuan, Yangguang and
   Wang, Lei and Liu, Weihao and Zeng, Haoyang and Huang, Jinjie and Chai,
   Xiaowei and Wu, Kai and Liu, Hanlin},
Title = {Development and Validation of an Interpretable Machine Learning Model
   for Predicting Adverse Clinical Outcomes in Placenta Accreta Spectrum: A
   Multicenter Study},
Journal = {ACADEMIC RADIOLOGY},
Year = {2025},
Volume = {32},
Number = {11},
Pages = {6707-6715},
Month = {NOV},
Abstract = {Rationale and Objectives: Placenta accreta spectrum (PAS) is a serious
   perinatal complication. Accurate preoperative identification of patients
   at high risk for adverse clinical outcomes is essential for developing
   personalized treatment strategies. This study aimed to develop and
   validate a high-performance, interpretable machine learning model that
   integrates MRI morphological indicators and clinical features to predict
   adverse outcomes in PAS, and to build an online prediction tool to
   enhance its clinical applicability.
   Materials and Methods: This retrospective study included 125 clinically
   confirmed PAS patients from two centers, categorized into high-risk
   (intraoperative blood loss over 1500 mL or requiring hysterectomy) and
   low-risk groups. Data from Center 1 were used for model development, and
   data from Center 2 served as the external validation set. Five MRI
   morphological indicators and six clinical features were extracted as
   model inputs. Three machine learning classifiers-AdaBoost, TabPFN, and
   CatBoost-were trained and evaluated on both internal testing and
   external validation cohorts. SHAP analysis was used to interpret model
   decision-making, and the optimal model was deployed via a
   Streamlit-based web platform.
   Results: The CatBoost model achieved the best performance, with AUROCs
   of 0.90 (95\% CI: 0.73-0.99) and 0.84 (95\% CI: 0.70-0.97) in the
   internal testing and external validation sets, respectively. Calibration
   curves indicated strong agreement between predicted and actual risks.
   SHAP analysis revealed that ``Cervical canal length{''} and
   ``Gestational age{''} contributed negatively to high-risk predictions,
   while ``Prior C-sections number{''}, ``Placental abnormal vasculature
   area{''}, and Parturition were positively associated. The final online
   tool allows real-time risk prediction and visualization of
   individualized force plots and is freely accessible to clinicians and
   patients.
   Conclusions: This study successfully developed an interpretable and
   practical machine learning model for predicting adverse clinical
   outcomes in PAS. The accompanying online tool may support clinical
   decision-making and improve individualized management for PAS patients.},
Type = {Article},
Affiliation = {Liu, HL (Corresponding Author), Shenzhen Univ, Dept Radiol, Affiliated Hosp 3, Luohu Hosp Grp, Shenzhen 518000, Peoples R China.
   Li, Hongliang; Yuan, Yangguang; Wang, Lei; Chai, Xiaowei; Wu, Kai; Liu, Hanlin, Shenzhen Univ, Dept Radiol, Affiliated Hosp 3, Luohu Hosp Grp, Shenzhen 518000, Peoples R China.
   Zhang, Yueyue, Soochow Univ, Dept Radiol, Affiliated Hosp 2, Suzhou 215004, Peoples R China.
   Mei, Hangru, Southern Univ Sci \& Technol Hosp, Dept Urol, Shenzhen 518000, Peoples R China.
   Liu, Weihao; Zeng, Haoyang; Huang, Jinjie, Shantou Univ, Shantou Univ Med Coll, Shantou 515000, Peoples R China.},
DOI = {10.1016/j.acra.2025.08.011},
Keywords = {Placenta Accreta Spectrum; Adverse Clinical Outcomes; Machine Learning;
   Model Interpretability},
Author-Email = {hanlin7450\_cn@sina.com},
Number-of-Cited-References = {36},
Times-Cited = {0},
Unique-ID = {WOS:001718317600006},
}

@article{ WOS:001618360200001,
Author = {Si, Wei and Chen, Zhixiong and Jim, Chi Yung and Tan, Mou Leong and Liu,
   Dong and Yao, Yue and Wei, Lifei and Xu, Shangshang and Zhang, Fei},
Title = {Resolving inherent constraints in eutrophication monitoring of small
   lakes using multi-source satellites and machine learning},
Journal = {NPJ CLEAN WATER},
Year = {2025},
Volume = {8},
Number = {1},
Month = {NOV 18},
Abstract = {Remote sensing monitoring of small-lake eutrophication faces challenges
   such as sparse data, insufficient synergy of multi-source data, and
   limited model generalization performance. Hence, this study developed a
   scenario-aware modeling framework for the trophic level index (TLI) by
   integrating multi-source imagery data from Sentinel-2, GF-1, HJ-2, and
   PlanetScope, using Dongqian Lake in Zhejiang Province, China as the case
   study. The cross-sensor prediction accuracy was evaluated using
   algorithms such as CatBoost Regression (CBR), XGBoost Regression (XGBR),
   TabPFN Regression (TPFNR), and Linear Regression (LR). Meanwhile, the
   influence of input features was quantified by SHapley Additive
   exPlanations (SHAP). The main results found that : (1) Overall annual
   mean values of total nitrogen/total phosphorus ratio (TN/TP) and TLI
   were 22.13 and 37.36 +/- 4.99, respectively, indicating a mesotrophic
   and phosphorus-limited state in Dongqian Lake. (2) TLI exhibited the
   strongest correlation with water color and algal spectral indices,
   including Normalized Difference Water Index (NDWI), Normalized Green-Red
   Difference Index (NGRDI), and Blue-Green Ratio (BGR). (3) CBR
   demonstrated the strongest cross-sensor generalization capability across
   different imagery, with only minor variations in prediction accuracy
   (Delta R approximate to 0.07-0.15). Feature attribution analysis
   identified NDWI, NGRDI, and BGR as primary contributing features for the
   CBR model. (4) Integrating high-frequency multi-source remote sensing
   imagery with 27 field surveys achieved seamless monitoring of the TLI.
   The spatial distribution of TLI showed distinct seasonal variations,
   with higher values observed in nearshore areas and lower values in the
   lake center. TLI values were relatively low in spring, but surged
   sharply and remained elevated in summer. This study provided a reference
   basis for detailed remote sensing monitoring and management of
   eutrophication in small lakes.},
Type = {Article},
Affiliation = {Zhang, F (Corresponding Author), Zhejiang Normal Univ, Coll Geog \& Environm Sci, Jinhua, Peoples R China.
   Si, Wei; Chen, Zhixiong; Xu, Shangshang; Zhang, Fei, Zhejiang Normal Univ, Coll Geog \& Environm Sci, Jinhua, Peoples R China.
   Jim, Chi Yung, Educ Univ Hong Kong, Dept Social Sci \& Policy Studies, Tai Po, Hong Kong, Peoples R China.
   Tan, Mou Leong, Univ Sains Malaysia, Sch Humanities, GeoInformat Unit, Geog Sect, George Town, Penang, Malaysia.
   Tan, Mou Leong, Al Ayen Univ, Sci Res Ctr, Environm \& Atmospher Sci Res Grp, Thi Qar 64001, Nasiriyah, Iraq.
   Liu, Dong, Chinese Acad Sci, Nanjing Inst Geog \& Limnol, Key Lab Watershed Geog Sci, Nanjing, Peoples R China.
   Yao, Yue, Chinese Acad Sci, Aerosp Informat Res Inst, Beijing, Peoples R China.
   Wei, Lifei, Hubei Univ, Fac Resources \& Environm Sci, Wuhan, Peoples R China.},
DOI = {10.1038/s41545-025-00525-8},
Article-Number = {99},
Keywords-Plus = {ATMOSPHERIC CORRECTION; WATER-QUALITY; PHOSPHORUS; NITROGEN; TAIHU},
Author-Email = {zhangfei3s@163.com},
Number-of-Cited-References = {56},
Times-Cited = {1},
Unique-ID = {WOS:001618360200001},
}

@article{ WOS:001658663800049,
Author = {Sun, Xiaohu and Xue, Yong and Kanniah, Kasturi Devi and Cui, Zhiqiang},
Title = {Multi-Parameter Aerosol Retrieval From Landsat Data Under Small Dataset
   Constraints},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Urban aerosols originate from diverse sources and exhibit complex
   characteristics, with substantial variability in their physicochemical
   properties. Retrieving aerosol parameters at high spatial resolution in
   urban areas using satellite data remains challenging due to limitations
   in dataset construction. This study leverages recent advances in deep
   learning (DL) to explore multi-parameter retrieval under small dataset
   constraints. While retrieving multiple parameters solely from satellite
   data without external sources poses challenges for physical
   interpretation, the multilayer nonlinear transformations of DL enable
   the derivation of target variables from correlated inputs. This is an
   innovative experiment for multi-parameter retrieval of aerosol at the
   100-m scale. Validation at global and regional scales demonstrates that
   the method effectively retrieves aerosol optical depth (AOD), \&
   Aring;ngstr \& ouml;m exponent (AE), fine mode fraction (FMF), and
   single scattering albedo (SSA), with correlation coefficients of 0.896,
   0.641, 0.721, and 0.429, and the corresponding mean absolute error (MAE)
   root-mean-square error (RMSE) values of 0.056 (0.106), 0.277 (0.365),
   0.117 (0.153), and 0.049 (0.076). Compared with previous studies, this
   method achieves comparable performance to approaches relying on large
   datasets while effectively mitigating underfitting and performance
   degradation in small dataset scenarios. Moreover, by eliminating the
   need to integrate multiple external data sources, this approach
   overcomes the drawbacks of time-consuming data collection and
   processing. This study offers a novel methodological perspective for
   advancing high-resolution aerosol remote sensing. The retrieved
   multi-parameter results support refined applications, including urban
   pollution source tracing and particulate matter composition
   identification.},
Type = {Article},
Affiliation = {Xue, Y (Corresponding Author), Nanjing Univ Informat Sci \& Technol, Sch Emergency Management, Nanjing 210044, Peoples R China.
   Sun, Xiaohu, Nanjing Univ Informat Sci \& Technol, Sch Atmospher Phys, Nanjing 210044, Peoples R China.
   Xue, Yong, Nanjing Univ Informat Sci \& Technol, Sch Emergency Management, Nanjing 210044, Peoples R China.
   Kanniah, Kasturi Devi, Univ Teknol Malaysia, Fac Built Environm \& Surveying, Dept Geoinformat, Johor Baharu 81310, Malaysia.
   Cui, Zhiqiang, Univ Leeds, Inst Climate \& Atmospher Sci, Leeds LS2 9JT, England.},
DOI = {10.1109/TGRS.2025.3646650},
Article-Number = {4300311},
Keywords = {Aerosols; Earth; Data models; Satellites; Remote sensing; Landsat;
   Artificial satellites; Atmospheric modeling; Training; Reflectivity;
   Aerosol optical depth (AOD), \& Aring;ngstr \& ouml;m exponent (AE);
   fine mode fraction (FMF); single scattering albedo (SSA); TabPFN},
Keywords-Plus = {OPTICAL DEPTH; LONG-TERM; NETWORK; AERONET; ALGORITHM; ACCURACY;
   CLIMATE; SUN},
