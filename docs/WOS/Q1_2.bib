@article{ WOS:001565573200012,
Author = {Zhu, Xiangang and Su, Peidong and Yu, Jiang and Pei, Jiaheng and Teng,
   Zhaoyong and Li, Yougui and Liu, Yuxuan},
Title = {A prediction model for hazard levels of shallow natural gas in tunnel
   based on K-means clustering and tabular prior-data fitted network},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {27},
Month = {SEP},
Abstract = {The hazard level of shallow natural gas in tunnels is jointly determined
   by the distance to oil and gas accumulation zones and the integrity of
   the storage-seal system. However, in some cases, a single dominant
   factor can independently trigger severe disasters. Existing studies have
   not considered the effect of the causative heterogeneity on the
   predictive performance of the model. To address the above problems, a
   shallow natural gas hazard prediction model is proposed by combining the
   K-means clustering classification algorithm. Firstly, seven indicators
   were selected as inputs, and the weights determined by the Analytic
   Hierarchy Process (AHP) were combined to construct a scoring system for
   the risk of shallow natural gas in tunnels. Subsequently, the K-means
   algorithm was used to divide the database into three clusters, each
   representing a distinct disaster-causing mode, in order to differentiate
   the mechanisms associated with various primary control factors in hazard
   formation. Finally, the shallow natural gas hazard classification
   prediction model was constructed for each cluster separately by
   combining the Tabular Prior-data Fitted Network (TabPFN). Comparative
   testing of the proposed model with the unclustered model shows that the
   average classification accuracy is improved by 4 \%, which demonstrates
   that the database based on the hazard-causing pattern segmentation
   significantly improves the prediction performance of the model. In
   addition, compared with other machine learning models, the proposed
   model performs outstandingly in terms of both accuracy and adaptability,
   demonstrating its good potential prediction in future applications of
   shallow natural gas tunnels.},
Type = {Article},
Affiliation = {Su, PD (Corresponding Author), Southwest Petr Univ, Sch Geosci \& Technol, Chengdu 610500, Peoples R China.
   Zhu, Xiangang; Yu, Jiang; Teng, Zhaoyong, China Railway Commun Investment Grp Co Ltd, Nanning 530219, Peoples R China.
   Su, Peidong; Pei, Jiaheng; Li, Yougui, Southwest Petr Univ, Sch Geosci \& Technol, Chengdu 610500, Peoples R China.
   Liu, Yuxuan, Univ Tokyo, Grad Sch Frontier Sci, Dept Socio Cultural Environm Studies, 5-1-5 Kashiwanoha, Kashiwa, Chiba 2778563, Japan.},
DOI = {10.1016/j.rineng.2025.106873},
EarlyAccessDate = {AUG 2025},
Article-Number = {106873},
Keywords = {Shallow natural gas; Tunnel; Risk prediction; TabPFN; Clustering},
