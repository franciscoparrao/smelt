@article{ WOS:001582056600003,
Author = {Lange, Christoph and Altmann, Madeline and Stors, Daniel and Seidel,
   Simon and Moynahan, Kyle and Cai, Linda and Born, Stefan and Neubauer,
   Peter and Bournazou, M. Nicolas Cruz},
Title = {Deep learning for Raman spectroscopy: Benchmarking models for upstream
   bioprocess monitoring},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {258},
Number = {A},
Month = {JAN 30},
Abstract = {Raman spectroscopy serves as a useful Process Analytical Technology in
   biotechnology, allowing us to monitor upstream bioprocesses in real-time
   by estimating substrate and product concentrations from spectral data.
   While there is potential in machine learning models for enhancing
   concentration predictions, we note a lack of systematic comparisons
   among modern deep learning architectures and gradient boosted tree
   methods for this regression task. In this study, we present a new
   reference dataset of 6960 annotated spectra for evaluating machine
   learning models on Raman spectra. We compare eleven different model
   types, including Convolutional Neural Networks, attention-based
   transformers, ensemble methods, and traditional chemometric approaches
   such as Partial Least Squares. The dataset consists of spectra for eight
   key fermentation substrates, generated using an automated pipetting
   system to ensure a broad and unbiased representation of concentration
   variations. Our results show that some deep learning approaches
   significantly outperform Partial Least Squares in terms of coefficient
   of determination and Mean Absolute Error. In particular, we observe that
   the in-context learning approach Tabular Prior-data Fitted Network
   achieves promising results for most substances but remains inconsistent
   across all analytes. By publishing our dataset, we aim to facilitate the
   development of more accurate and generalizable models for Raman
   spectroscopy applications. Our findings underscore the potential of deep
   learning for spectroscopic methods bioprocess monitoring while
   highlighting the need for further research on attention-based and
   in-context learning approaches for spectral data analysis.},
Type = {Article},
Affiliation = {Lange, C (Corresponding Author), Tech Univ Berlin, Inst Biotechnol, Fac Process Sci 3, Chair Bioprocess Engn, Str 17 Juni 135, D-10623 Berlin, Germany.
   Lange, Christoph; Altmann, Madeline; Stors, Daniel; Seidel, Simon; Moynahan, Kyle; Cai, Linda; Neubauer, Peter; Bournazou, M. Nicolas Cruz, Tech Univ Berlin, Inst Biotechnol, Fac Process Sci 3, Chair Bioprocess Engn, Str 17 Juni 135, D-10623 Berlin, Germany.
   Born, Stefan, Tech Univ Berlin, Orientierungsstudium MINTgrun, Str 17 Juni 135, D-10623 Berlin, Germany.},
DOI = {10.1016/j.measurement.2025.118884},
EarlyAccessDate = {SEP 2025},
