@article{ WOS:001666631200001,
Author = {Wu, Jishu and Chen, Li},
Title = {Prediction of bond strength between FRP bars and UHPC using explainable
   machine learning algorithms},
Journal = {JOURNAL OF BUILDING ENGINEERING},
Year = {2026},
Volume = {119},
Month = {FEB 1},
Abstract = {The superior bond between FRP bars and Ultra-High Performance Concrete
   (UHPC) is fundamental for ensuring the composite action of
   FRP-reinforced UHPC structures. However, formulas derived from
   traditional experimental methods for calculating bond strength often
   fail to adequately capture the influence of numerous affecting factors.
   Utilizing a database of 475 bond strength samples from existing
   literature, this study selected the following as input variables: types
   of FRP bars, surface texture of FRP bars, bar diameter (d), concrete
   compressive strength (fc), embedment length-to-diameter ratio (l/d),
   steel fiber content (rho SF), and cover thickness-todiameter ratio
   (c/d). The ultimate bond strength (tau u) was set as the sole output
   variable. 12 machine learning (ML) algorithms were employed for
   training. The predictions were compared against selected design codes
   and empirical models. The influence of each input parameter on the bond
   strength was investigated through explainable analysis techniques,
   including SHAP analysis, Individual Conditional Expectation (ICE), and
   Partial Dependence Plots (PDP). A graphical user interface (GUI) was
   also developed to facilitate the visual design for bond strength
   prediction. The results indicate that the TabPFN model achieved the
   highest accuracy, with an R2 of 0.895, RMSE of 3.467, and MAE of 2.145.
   The parameters l/d, rho SF, c/d, d, and fc were identified as the key
   factors influencing the bond strength between FRP bars and UHPC. This
   research provides a novel approach for predicting the bond strength of
   FRP bars in UHPC.},
Type = {Article},
Affiliation = {Chen, L (Corresponding Author), Tongji Univ, Coll Civil Engn, Shanghai 200092, Peoples R China.
   Wu, Jishu; Chen, Li, Tongji Univ, Coll Civil Engn, Shanghai 200092, Peoples R China.},
DOI = {10.1016/j.jobe.2025.115174},
EarlyAccessDate = {JAN 2026},
Article-Number = {115174},
Keywords = {FRP bars; UHPC; Bond strength; Machine learning; SHAP analysis},
Keywords-Plus = {REINFORCED POLYMER BARS; GFRP BARS; DEVELOPMENT LENGTH; CONCRETE BEAMS;
   BEHAVIOR},
Author-Email = {lichen914@foxmail.com},
Number-of-Cited-References = {60},
Times-Cited = {0},
Unique-ID = {WOS:001666631200001},
}

@article{ WOS:001333989500001,
Author = {Durmaz, Emine Sebnem and Karabacak, Mert and Ozkara, Burak Berksu and
   Kargin, Osman Aykan and Demir, Bilal and Raimoglou, Damla and Aygun,
   Ahmet Atil and Adaletli, Ibrahim and Bas, Ahmet and Durmaz, Eser},
Title = {Machine learning and radiomics for ventricular tachyarrhythmia
   prediction in hypertrophic cardiomyopathy: insights from an MRI-based
   analysis},
Journal = {ACTA RADIOLOGICA},
Year = {2024},
Volume = {65},
Number = {12},
Pages = {1473-1481},
Month = {DEC},
Abstract = {Background Myocardial fibrosis is often detected in patients with
   hypertrophic cardiomyopathy (HCM), which causes left ventricular (LV)
   dysfunction and tachyarrhythmias.Purpose To evaluate the potential value
   of a machine learning (ML) approach that uses radiomic features from
   late gadolinium enhancement (LGE) and cine images for the prediction of
   ventricular tachyarrhythmia (VT) in patients with HCM.Material and
   Methods Hyperenhancing areas of LV myocardium on LGE images were
   manually segmented, and the segmentation was propagated to corresponding
   areas on cine images. Radiomic features were extracted using the
   PyRadiomics library. The least absolute shrinkage and selection operator
   (LASSO) method was employed for radiomic feature selection. Our model
   development employed the TabPFN algorithm, an adapted Prior-Data Fitted
   Network design. Model performance was evaluated graphically and
   numerically over five-repeat fivefold cross-validation. SHapley Additive
   exPlanations (SHAP) were employed to determine the relative importance
   of selected radiomic features.Results Our cohort consisted of 60
   patients with HCM (73.3\% male; median age = 51.5 years), among whom 17
   had documented VT during the follow-up. A total of 1612 radiomic
   features were extracted for each patient. The LASSO algorithm led to a
   final selection of 18 radiomic features. The model achieved a mean area
   under the receiver operating characteristic curve of 0.877,
   demonstrating good discrimination, and a mean Brier score of 0.119,
   demonstrating good calibration.Conclusion Radiomics-based ML models are
   promising for predicting VT in patients with HCM during the follow-up
   period. Developing predictive models as clinically useful
   decision-making tools may significantly improve risk assessment and
   prognosis.},
Type = {Article},
Affiliation = {Durmaz, ES (Corresponding Author), Istanbul Univ Cerrahpasa, Cerrahpasa Fac Med, Dept Radiol, TR-34149 Istanbul, Turkiye.
   Durmaz, Emine Sebnem; Kargin, Osman Aykan; Demir, Bilal; Adaletli, Ibrahim; Bas, Ahmet, Istanbul Univ Cerrahpasa, Cerrahpasa Fac Med, Dept Radiol, TR-34149 Istanbul, Turkiye.
   Karabacak, Mert; Ozkara, Burak Berksu, Istanbul Univ Cerrahpasa, Cerrahpasa Fac Med, Istanbul, Turkiye.
   Karabacak, Mert, Mt Sinai Hlth Syst, Dept Neurosurg, New York, NY USA.
   Ozkara, Burak Berksu, MD Anderson Canc Ctr, Dept Neuroradiol, Houston, TX USA.
   Raimoglou, Damla; Aygun, Ahmet Atil; Durmaz, Eser, Istanbul Univ Cerrahpasa, Cerrahpasa Fac Med, Dept Cardiol, Istanbul, Turkiye.},
DOI = {10.1177/02841851241283041},
EarlyAccessDate = {OCT 2024},
Keywords = {Cardiac magnetic resonance imaging; hypertrophic cardiomyopathy;
   radiomics; machine learning},
Keywords-Plus = {CALIBRATION; DIAGNOSIS; MODELS},
