   Costantino, Giorgio; Solbiati, Monica, Univ Milan, Fdn IRCCS Ca Granda Osped Maggiore Policlin, Emergency Dept, Milan, Italy.
   Furlan, Raffaello; Dipaola, Franca, IRCCS Human Res Hosp, Syncope Unit, Internal Med, Via A Manzoni 56, I-20089 Milan, Italy.},
DOI = {10.1007/s11739-025-04034-x},
EarlyAccessDate = {JUL 2025},
Keywords = {Artificial intelligence; Machine learning; Syncope; Risk prediction;
   Canadian Syncope Risk Score (CSRS); Gradient boosting; Large language
   models},
Keywords-Plus = {RISK-STRATIFICATION; CLINICAL-PRACTICE},
