   Schirrmeister, Robin Tibor, Univ Freiburg, Med Phys, Dept Diagnost \& Intervent Radiol, Med Ctr,Fac Med, Freiburg, Germany.
   Hutter, Frank, ELLIS Inst Tubingen, Tubingen, Germany.},
DOI = {10.1038/s41586-024-08328-6},
Keywords-Plus = {GAME; GO},
Author-Email = {noah@priorlabs.ai
   samuelgabrielmuller@gmail.com
   fh@cs.uni-freiburg.de},
Number-of-Cited-References = {70},
