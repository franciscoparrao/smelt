Keywords = {Artificial intelligence; Clinical oncology; Deep learning; Digital
   oncology; Genitourinary cancer; Machine learning; Multidisciplinary
   cancer conferences; Renal cell carcinoma; Treatment recommendation;
   Urothelial cell cancer},
Keywords-Plus = {PROSTATE; GUIDELINES},
