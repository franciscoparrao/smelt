@article{ WOS:001630465700014,
Author = {Li, Bowen and Qiu, Zilin and Liu, Li and Zhang, Peng},
Title = {Regulation of current density distribution and machine learning-based
   passivation prediction for mitigating anode passivation in
   electrocoagulation},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {6},
Month = {DEC},
Abstract = {The anode passivation leads to rising operation costs and declining
   treatment efficiency in electrocoagulation (EC), limiting its
   sustainable application and widespread development. Existing strategies
   to address anode passivation suffer from extra manpower/equipment costs,
   potential adverse impacts on treatment performance or increased
   complexity in electrode preparation and electrical connection. Herein,
   this study proposed a novel anode splitting method using the insulating
   material to regulate current density (CD) distribution for passivation
   mitigation, and further developed a machine learning (ML)-based
   prediction platform to realize rapid and accurate quantification of
   passivation distribution. The results demonstrate that splitting the
   complete anode (CA) into 4 equal parts (SA4) and 9 equal parts (SA9)
   effectively mitigated passivation with energy consumption reducing by
   43.33 \% and 68.38 \%, while maintaining 97 \% humic acid (HA) removal
   after EC for 30 min. The passive layer formation on SA9 exhibits the
   dual edge effect, which was confirmed to be the response to its CD
   distribution. Furthermore, the tabular prior-data fitted network
   (TabPFN) demonstrated its accurate capture capability for passivation
   behaviour variations under varying EC conditions. This work provides a
   low-cost, scalable strategy for anode passivation mitigation and a
   practical tool to facilitate its utility in scenarios requiring balanced
   performance and cost-effectiveness.},
Type = {Article},
Affiliation = {Zhang, P (Corresponding Author), 122 Luoshi Rd, Wuhan 430070, Peoples R China.
   Li, Bowen, Nankai Univ, Coll Environm Sci \& Engn, Tianjin 300350, Peoples R China.
   Zhang, Peng, Wuhan Univ Technol, Sch Resources \& Environm Engn, Wuhan 430070, Peoples R China.
   Qiu, Zilin, Tianjin Univ Sci \& Technol, Coll Marine \& Environm Sci, Tianjin 300457, Peoples R China.
   Liu, Li, Tianjin Med Univ, Gen Hosp, Tianjin 300052, Peoples R China.},
