   Amar, Menad Nait, Sonatrach, Dept Etud Thermodynam, Div Labs, Ave 1er Novembre, Boumerdes 35000, Algeria.},
DOI = {10.1016/j.chemolab.2026.105679},
Article-Number = {105679},
Keywords = {Natural gas; Carbon dioxide; Machine learning; Tabular prior-data fitted
