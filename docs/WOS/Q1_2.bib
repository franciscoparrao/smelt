   Hofner, Thomas, Ordensklinikum Linz Elisabethinen, Dept Urol, Fadinger Str 1, A-4020 Linz, Austria.},
DOI = {10.1016/j.ejca.2025.115367},
EarlyAccessDate = {MAR 2025},
