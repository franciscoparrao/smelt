   Sun, Weijie, Univ Alberta, Dept Comp Sci, Edmonton, AB T6G 2R3, Canada.
   Cui, Guanzhe, Univ Melbourne, Dept Mech Engn, Melbourne, Vic 3010, Australia.
   Tu, Jiyuan; Li, Xueren, RMIT Univ, Sch Engn, POB 71, Bundoora, Vic 3083, Australia.
   Li, Xueren, China Univ Min \& Technol, Sch Safety Engn, Xuzhou 221116, Peoples R China.},
DOI = {10.1016/j.energy.2025.138693},
