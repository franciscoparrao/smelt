@article{ WOS:001698758700001,
Author = {Barkov, Viacheslav and Schmidinger, Jonas and Gebbers, Robin and
   Atzmueller, Martin},
Title = {Modern Neural Networks for Small Tabular Datasets: The New Default for
   Field-Scale Digital Soil Mapping?},
Journal = {EUROPEAN JOURNAL OF SOIL SCIENCE},
Year = {2026},
Volume = {77},
Number = {2},
Month = {FEB 24},
Abstract = {In the field of pedometrics, tabular machine learning is the predominant
   method for soil property prediction from remote and proximal soil
   sensing data, forming a central component of Digital Soil Mapping (DSM).
   At the field-scale, this pedometric modeling task is typically
   constrained by small training sample sizes and high feature-to-sample
   ratios, particularly when using spectroscopic data. Traditionally, these
   conditions have proven challenging for conventional deep learning
   methods. Classical machine learning algorithms, particularly tree-based
   models like Random Forest and linear models such as Partial Least
   Squares Regression, have long been the default choice for pedometric
   modeling within DSM. Recent advances in artificial neural networks (ANN)
   for tabular data challenge this view, yet their suitability for
   field-scale DSM has not been proven. We introduce a comprehensive
   benchmark that evaluates state-of-the-art ANN architectures, including
   the latest multilayer perceptron (MLP)-based models (TabM, RealMLP),
   attention-based transformer variants (FT-Transformer, ExcelFormer,
   T2G-Former, AMFormer), retrieval-augmented approaches (TabR, ModernNCA),
   and an in-context learning foundation model (TabPFN). Our evaluation
   encompasses 31 field- and farm-scale datasets containing 30-460 soil
   samples and three critical soil properties: soil organic matter or soil
   organic carbon, pH, and clay content. Our results reveal that modern
   ANNs consistently outperform classical methods on the majority of tasks,
   demonstrating that deep learning has matured sufficiently to overcome
   the long-standing dominance of classical machine learning for soil
   property prediction. Notably, TabPFN delivers the strongest overall
   performance, showing robustness across varying conditions. We therefore
   recommend the adoption of modern ANNs for field-scale DSM and propose
   TabPFN as the new default choice in the toolkit of every pedometrician.},
Type = {Article},
Affiliation = {Barkov, V (Corresponding Author), Osnabruck Univ, Joint Lab Artificial Intelligence \& Data Sci, Osnabruck, Germany.
   Barkov, V (Corresponding Author), Leibniz Inst Agr Engn \& Bioecon ATB, Dept Agromechatron, Potsdam, Germany.
   Barkov, Viacheslav; Schmidinger, Jonas; Atzmueller, Martin, Osnabruck Univ, Joint Lab Artificial Intelligence \& Data Sci, Osnabruck, Germany.
   Barkov, Viacheslav; Schmidinger, Jonas; Gebbers, Robin, Leibniz Inst Agr Engn \& Bioecon ATB, Dept Agromechatron, Potsdam, Germany.
   Atzmueller, Martin, German Res Ctr Artificial Intelligence DFKI, Res Dept Cooperat \& Autonomous Syst CAS, Osnabruck, Germany.},
DOI = {10.1111/ejss.70299},
Article-Number = {e70299},
Keywords = {artificial neural networks; benchmarking; deep learning; machine
   learning; pedometrics; soil property prediction; TabPFN},
Keywords-Plus = {UNCERTAINTY; PREDICTION},
Author-Email = {viacheslav.barkov@uni-osnabrueck.de},
Number-of-Cited-References = {76},
Times-Cited = {0},
Unique-ID = {WOS:001698758700001},
}

@article{ WOS:001655409400001,
Author = {Tian, Yuping and Wu, Zechuan and Liu, Kai and Li, Mingze},
Title = {Dynamic assessment of ecological quality in China from 2000 to 2024
   based on artificial intelligence},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {666},
Month = {FEB},
Abstract = {The assessment of spatial disparities in ecological quality and the
   factors influencing them plays a vital role in shaping effective
   ecological protection and land-use strategies. However,
   nationwide-scale, unified, and data-driven approaches remain limited,
   particularly in integrating advanced artificial intelligence models into
   impact assessment. This study developed a long-term RSEI dataset using
   Google Earth Engine to evaluate spatiotemporal patterns of ecological
   quality across China's seven geographic regions from 2000 to 2024. We
   employed trend and spatial autocorrelation analyses to assess regional
   evolution and clustering dynamics. This study is the first in the field
   to apply the tabular foundation model TabPFN, integrating it with SHAP
   analysis to assess the impacts of both natural and human-induced
   factors. The results indicated a general improvement in ecological
   quality, accompanied by notable spatial aggregation and distinct
   regional variation. TabPFN outperformed traditional models (Random
   Forest, XGBoost, TabNet), with R2 values ranging from 0.7215 to 0.8969
   and accuracy improvements of 6.3 \%-14.7 \%. Key drivers included net
   primary productivity, vegetation coverage, precipitation, temperature,
   and land cover, with GDP typically exerting negative impacts. The
   findings offer new insights into ecological quality dynamics and
   highlight the effectiveness of TabPFN-SHAP in transparent impact
   assessment. Beyond the China context, the proposed framework is
   adaptable for regional and urban planning worldwide, contributing a
   scalable and innovative methodology to the toolbox of environmental
   impact assessment and management.},
Type = {Article},
Affiliation = {Li, MZ (Corresponding Author), Northeast Forestry Univ, Coll Forestry, Key Lab Sustainable Forest Ecosyst Management, Minist Educ, Harbin 150040, Peoples R China.
   Tian, Yuping; Wu, Zechuan; Li, Mingze, Northeast Forestry Univ, Coll Forestry, Key Lab Sustainable Forest Ecosyst Management, Minist Educ, Harbin 150040, Peoples R China.
   Liu, Kai, Heilongjiang Acad Forestry, Harbin 150081, Peoples R China.},
DOI = {10.1016/j.jhydrol.2025.134849},
EarlyAccessDate = {FEB 2025},
Article-Number = {134849},
Keywords = {Ecological quality; Artificial intelligence; Tabular foundation model;
   Spatiotemporal heterogeneity},
Keywords-Plus = {FOREST},
Author-Email = {mingzelee@nefu.edu.cn},
Number-of-Cited-References = {71},
Times-Cited = {0},
Unique-ID = {WOS:001655409400001},
}

@article{ WOS:001721276800001,
Author = {Chen, Woruo and Tian, Yao and Liao, Nian and Deng, Youchao and Jiang,
   Dejun and Cao, Dongsheng},
Title = {TabPFN Opens New Avenues for Small-Data Tabular Learning in Drug
   Discovery},
Journal = {JOURNAL OF CHEMICAL INFORMATION AND MODELING},
Year = {2026},
Month = {2026 MAR 23},
Abstract = {Early-stage drug discovery often suffers from data scarcity and
   out-of-distribution (OOD) shifts, which constrain the reliability of
   predictive models. While deep learning has advanced representation
   learning from molecular and biological data, tabular modeling remains
   indispensable, particularly in small-sample and OOD scenarios. For more
   than a decade, gradient-boosted decision trees (GBDTs), such as XGBoost,
   have been the dominant choice, yet their robustness is limited under
   such conditions. TabPFN, a recently introduced transformer-based tabular
   foundation model, enables accurate predictions on small data sets
   without task-specific retraining. Applying TabPFN to a variety of
   molecular data sets, we find that TabPFN performs on par with XGBoost in
   classification but demonstrates clear and stable advantages in
   regression, with its strongest gains on small and medium data sets and
   under OOD evaluations. Feature and data ablations (10-90\%) further
   highlight its robustness, as performance degrades gracefully and
   exhibits minimal sensitivity compared with tree ensembles. On quantum
   tasks, TabPFN shows competitive accuracy on QM7 but is challenged by the
   larger QM8 data set, where tree ensembles regain strength. Beyond
   metrics, embedding analyses indicate smoother structure-property
   relationships of TabPFN and enhanced class separability, reflecting
   beneficial inductive biases rather than overfitting. Collectively, these
   findings demonstrate that TabPFN offers a robust and data-efficient
   alternative for tabular learning in drug discovery, shedding new light
   on predictive modeling under small-data and OOD challenges.},
Type = {Article; Early Access},
Affiliation = {Jiang, DJ; Cao, DS (Corresponding Author), Cent South Univ, Xiangya Sch Pharmaceut Sci, Changsha 410013, Hunan, Peoples R China.
   Chen, Woruo; Tian, Yao; Liao, Nian; Deng, Youchao; Jiang, Dejun; Cao, Dongsheng, Cent South Univ, Xiangya Sch Pharmaceut Sci, Changsha 410013, Hunan, Peoples R China.},
DOI = {10.1021/acs.jcim.5c02823},
EarlyAccessDate = {MAR 2026},
Keywords-Plus = {RANDOM FOREST; PREDICTIONS; ACCURATE},
Author-Email = {jiang\_dj@zju.edu.cn
   oriental-cds@163.com},
Number-of-Cited-References = {46},
Times-Cited = {0},
Unique-ID = {WOS:001721276800001},
}

@incollection{ WOS:001658892200020,
Author = {Kearney, Sophie and Yang, Shu and Wen, Zixuan and Hou, Bojian and Duy
   Duong-Tran and Chen, Tianlong and Moore, Jason and Ritchie, Marylyn and
   Shen, Li},
Book-Group-Author = {ACM},
Title = {Enabling Few-Shot Alzheimer's Disease Diagnosis on Biomarker Data with
   Tabular LLMs},
Booktitle = {16TH ACM CONFERENCE ON BIOINFORMATICS, COMPUTATIONAL BIOLOGY, AND HEALTH
   INFORMATICS, ACM-BCB 2025},
Year = {2025},
Abstract = {Early and accurate diagnosis of Alzheimer's disease (AD), a complex
   neurodegenerative disorder, requires analysis of heterogeneous
   biomarkers (e.g., neuroimaging, genetic risk factors, cognitive tests,
   and cerebrospinal fluid proteins) typically represented in a tabular
   format. With flexible few-shot reasoning, multimodal integration, and
   natural-language-based interpretability, large language models (LLMs)
   offer unprecedented opportunities for prediction with structured
   biomedical data. We propose a novel framework called TAP-GPT, Tabular
   Alzheimer's Prediction GPT, that adapts TableGPT2, a multimodal
   tabular-specialized LLM originally developed for business intelligence
   tasks, for AD diagnosis using structured biomarker data with small
   sample sizes. Our approach constructs few-shot tabular prompts using
   in-context learning examples from structured biomedical data and
   finetunes TableGPT2 using the parameter-efficient qLoRA adaption for a
   clinical binary classification task of AD or cognitively normal (CN).
   The TAP-GPT framework harnesses the powerful tabular understanding
   ability of TableGPT2 and the encoded prior knowledge of LLMs to
   outperform more advanced general-purpose LLMs and a tabular foundation
   model (TFM) developed for prediction tasks. To our knowledge, this is
   the first application of LLMs to the prediction task using tabular
   biomarker data, paving the way for future LLM-driven multi-agent
   frameworks in biomedical informatics.},
Type = {Proceedings Paper},
Affiliation = {Shen, L (Corresponding Author), Univ Penn, Philadelphia, PA 19104 USA.
   Kearney, Sophie; Yang, Shu; Wen, Zixuan; Hou, Bojian; Ritchie, Marylyn; Shen, Li, Univ Penn, Philadelphia, PA 19104 USA.
