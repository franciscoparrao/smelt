   Jiang, Zekun, Sichuan Univ, West China Hosp, West China Biomed Big Data Ctr, 37 Guoxue Alley, Chengdu 610041, Peoples R China.},
DOI = {10.21037/gs-2025-183},
Keywords = {Hypervascular thyroid nodules; ultrasound; power Doppler imaging (PDI);
   artificial intelligence (AI)},
Author-Email = {121586214@qq.com
   zekun\_jiang@163.com},
Number-of-Cited-References = {37},
Times-Cited = {4},
Unique-ID = {WOS:001570982600014},
}

@article{ WOS:001664326200001,
Author = {Huang, Xun and Yao, Rongwen and Zhang, Yunhui and Li, Xiao and Yu,
   Zhongyou and Guo, Hongyang},
Title = {A novel irrigation water quality index (PCIWQI) assessment and
   prediction: Insights into model performance and computational efficiency
   from TabPFN and tree-based models},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2026},
Volume = {14},
Number = {1},
Month = {FEB},
Abstract = {Groundwater is a vital resource for irrigation and plays a key role in
   maintaining agricultural productivity and ensuring food security. This
   study proposes a principal-component-weighted irrigation water quality
   index (PCIWQI), integrating sodium percentage (Na\%), sodium adsorption
   ratio (SAR), residual sodium carbonate (RSC), permeability index (PI),
   magnesium hazard (MH), and other hydrochemical parameters for a
   comprehensive assessment. Based on 624 groundwater samples during dry
   and wet seasons from 2011 to 2016, Lasso (baseline), XGBoost, LightGBM,
   and TabPFN models with feature selection were employed to predict
   irrigation water quality, balancing accuracy and computational
   efficiency. All groundwater samples were classified as ``Good{''} (75 <=
   PCIWQI < 150) and ``Excellent{''} (PCIWQI < 75) ranks, indicating their
   suitability for irrigation and low salinity, sodium, and alkalinity
   hazards to crops. In predictive modeling, the TabPFN model outperformed
   in precision (R-dry(2) = 0.97, R-wet(2) = 0.94, RMSEdry = 1.00, RMSEwet
   = 1.16) and hyperparameter tuning (0.1 s). SHAP (Shapley Additive
   exPlanations) analysis indicated that the TabPFN's high performance was
   attributable to the identification of salinity, sodium, permeability,
   and alkalinity hazards. In contrast, the LightGBM model excelled in
   computational efficiency, with quick training (68.9 ms), prediction (0.9
   ms), and low memory usage (similar to 395 MiB). However, it required
   substantial time (89.8 s) for hyperparameter tuning. Consequently,
   TabPFN achieved high accuracy without any hyperparameter tuning,
   offering a significant advantage in saving time and simplifying usage.
   These findings demonstrate the potential capability of prior-data-fitted
   models for groundwater-quality prediction and establish a low-cost and
   high-precision framework for rapid irrigation-water assessment},
Type = {Article},
Affiliation = {Guo, HY (Corresponding Author), Chengdu Univ Technol, Coll Environm \& Civil Engn, State Key Lab Geohazard Prevent \& Geoenvironm Prot, Chengdu 610059, Peoples R China.
   Guo, HY (Corresponding Author), Southwest Jiaotong Univ, Fac Geosci \& Engn, Chengdu 611756, Peoples R China.
   Huang, Xun; Zhang, Yunhui; Li, Xiao; Yu, Zhongyou; Guo, Hongyang, Chengdu Univ Technol, Coll Environm \& Civil Engn, State Key Lab Geohazard Prevent \& Geoenvironm Prot, Chengdu 610059, Peoples R China.
   Huang, Xun; Yao, Rongwen; Zhang, Yunhui; Guo, Hongyang, Southwest Jiaotong Univ, Fac Geosci \& Engn, Chengdu 611756, Peoples R China.},
DOI = {10.1016/j.jece.2025.120934},
EarlyAccessDate = {JAN 2026},
Article-Number = {120934},
Keywords = {Irrigation water quality index; Machine learning; Uncertainty analysis;
   Shapley Additive exPlanations},
Author-Email = {guohongyang855@163.com},
Number-of-Cited-References = {79},
Times-Cited = {0},
Unique-ID = {WOS:001664326200001},
}

@article{ WOS:001703502900001,
Author = {Esmaeilzadeh, Soleiman and Rezvantalab, Sima and Mihandoost, Sara},
Title = {Predicting polymer melt flow index and catalytic activity in ethylene
   polymerization using a pretrained transformer-based model},
Journal = {POLYMER BULLETIN},
Year = {2026},
Volume = {83},
Number = {6},
Month = {FEB 28},
Abstract = {Predicting catalyst activity and melt flow index (MFI) is critical for
   optimizing industrial polyethylene (PE) production but remains
   challenging due to complex nonlinear relationships between process
   parameters and polymer properties. This study employs machine learning
   (ML) to predict MFI and catalytic activity in a gas-phase fluidized bed
   reactor producing linear low-density polyethylene (LLDPE) and
   high-density polyethylene (HDPE). Using an industrial dataset (903 data
   points), seven regression models were evaluated including Linear
   Regression (LR), Random Forest (RF), AdaBoost (AB), Light Gradient
   Boosting Machine (LightGBM), eXtreme Gradient Boosting (XGB),
   Categorical Boosting (CatBoost) and the pretrained transformer-based
   TabPFN. TabPFN demonstrated superior performance, achieving test R \&
   sup2; values of 0.957 for MFI and 0.993 for catalytic activity,
   significantly outperforming conventional models. SHAP (SHapley Additive
   exPlanations) analysis revealed hydrogen concentration ({[}H-2]) as the
   dominant feature for MFI prediction, acting primarily as a chain
   transfer agent, while temperature exerted the strongest influence on
   catalytic activity. Correlation analysis identified key operational
   clusters, including thermal-catalytic coordination and hydrogen
   management. The results highlight TabPFN's robustness and
   generalizability for real-time process optimization, providing
   actionable insights for tuning polymerization conditions within fixed
   catalyst constraints to enhance product quality and efficiency.},
Type = {Article},
Affiliation = {Rezvantalab, S (Corresponding Author), Urmia Univ Technol, Chem Engn Dept, Orumiyeh 57166419, Iran.
   Mihandoost, S (Corresponding Author), Urmia Univ Technol, Elect Engn Dept, Mahabad 57166419, Iran.
   Esmaeilzadeh, Soleiman; Rezvantalab, Sima, Urmia Univ Technol, Chem Engn Dept, Orumiyeh 57166419, Iran.
   Esmaeilzadeh, Soleiman, Mahabad Petrochem Co, Polymerizat Unit, Mahabad 5947146776, Iran.
   Mihandoost, Sara, Urmia Univ Technol, Elect Engn Dept, Mahabad 57166419, Iran.},
DOI = {10.1007/s00289-026-06341-5},
