   Liu, Yanlin, Nanjing Univ Chinese Med, Affiliated Hosp Integrated Tradit Chinese \& Wester, Nanjing, Peoples R China.
   Wang, Jin, Tianjin Med Univ, Dept Tradit Chinese Med, Hosp 2, Tianjin, Peoples R China.},
DOI = {10.1177/20552076251379379},
