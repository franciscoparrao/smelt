   Tian, Chengcheng, Shanghai Inst Pollut Control \& Ecol Secur, Shanghai 200092, Peoples R China.},
DOI = {10.1021/acssuschemeng.5c08858},
EarlyAccessDate = {OCT 2025},
Keywords = {catalytic pyrolysis; machinelearning; TabPFN; plastics; zeolite ZSM-5;
   SHAP interpretability},
