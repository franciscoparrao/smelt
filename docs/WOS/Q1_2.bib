   Wang, Qingzhi, Minist Transport, Key Lab Highway Construction \& Maintenance Technol, Qinghai Sci Res Observat Base, Xining 810016, Qinghai, Peoples R China.
   Wang, Gang, Hong Kong Univ Sci \& Technol, Dept Civil \& Environm Engn, Hong Kong 999077, Peoples R China.},
DOI = {10.1016/j.rse.2026.115338},
Article-Number = {115338},
Keywords = {Thaw hazard; Permafrost; Machine learning; TabPFN; Small-sample
   modeling; Climate warming},
Keywords-Plus = {PREDICTIONS},
