@incollection{ WOS:001447151900040,
Author = {Tang, Haoyang and Li, Yanhong and Yao, Xinyue and Fan, Chenyang},
Book-Group-Author = {IEEE},
Title = {Virtual Screening of Natural Anti-Senescent Compounds Based on Sq-TabPFN},
Booktitle = {2024 5TH INTERNATIONAL CONFERENCE ON ARTIFICIAL INTELLIGENCE AND
   COMPUTER ENGINEERING, ICAICE},
Year = {2024},
Pages = {213-218},
Abstract = {To address the issue of feature redundancy and mutual interference in
   the screening of anti-aging compounds, a novel screening method based on
   Sq-TabPFN is proposed. Sq-TabPFN adaptively selects the most important
   features through a sequential attention mechanism, employs a sparse
   activation function to enhance feature sparsity, and utilizes a prior
   scale term to improve the flexibility of feature selection. This
   approach effectively removes redundant features, resulting in more
   accurate predictions of the anti-aging properties of natural compounds.
   Experimental results demonstrate that the proposed method outperforms
   baseline models in accuracy and successfully identifies 9 compounds with
   potential anti-aging activity. This study provides an efficient tool for
   the virtual screening of natural anti-aging compounds, which can
   accelerate drug discovery and reduce the cost of drug development.},
Type = {Proceedings Paper},
Affiliation = {Tang, HY (Corresponding Author), Xian Univ Posts \& Telecommun, Sch Automat, Xian, Peoples R China.
   Tang, Haoyang; Li, Yanhong; Yao, Xinyue; Fan, Chenyang, Xian Univ Posts \& Telecommun, Sch Automat, Xian, Peoples R China.},
