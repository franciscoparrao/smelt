Keywords = {Tabular-to-image methods; Transfer learning; Low-dimensional data;
   Mixed-type data; Cardiovascular disease prediction},
Keywords-Plus = {CONVOLUTIONAL NEURAL-NETWORKS; RISK-FACTORS; FOLLOW-UP; CLASSIFICATION;
