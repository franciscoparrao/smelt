   Zhang, Jiang-shan; Lan, Mo; Liu, Qing, Univ Sci \& Technol Beijing, State Key Lab Adv Met, 30 Xueyuan Rd, Beijing 100083, Peoples R China.},
DOI = {10.2355/isijinternational.ISIJINT-2025-191},
Keywords = {activity prediction; TabPFN; SHAP analysis; small data},
Keywords-Plus = {ACTIVITY-COEFFICIENTS; SIO2; EQUILIBRIA},
