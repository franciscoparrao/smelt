}

@article{ WOS:001669703600001,
Author = {Guo, Xuanru and Zheng, Ziming and Dai, Anlu and Wang, Pan and Chen,
   Mingtao and Niu, Mengfan and Liao, Xuanyu and Cheng, Kexin and Cao, Liyu
   and Cheng, Zhengdong and Jiang, Haiteng},
Title = {Tabular prior-data fitted networks for objective depression screening
   with portable EEG and ECG},
Journal = {BIOMEDICAL SIGNAL PROCESSING AND CONTROL},
Year = {2026},
Volume = {117},
Month = {MAY 15},
Abstract = {Major depressive disorder (MDD) is common and disabling, yet early
   detection still relies largely on subjective assessment. The real-world
   performance of portable single-channel electroencephalogram
   (EEG)-electrocardiogram (ECG) systems, particularly when paired with
   small-sample models such as tabular prior-data fitted networks (TabPFN),
   remains insufficiently characterized. Here, we present an integrated,
   exploratory evaluation of a portable multimodal system combining
   single-channel EEG and ECG signals with a TabPFN classifier for rapid
   depression assessment in naturalistic settings. Data were collected from
   30 healthy controls and 26 MDD patients during resting states,
   negative-emotion viewing, and a structured interview. Group-level
   analyses showed consistently higher heart rate in MDD, whereas
   differences in EEG power and heart rate variability (HRV) were limited
   and condition-specific. Exploratory brain-heart correlation analyses
   suggested altered EEG-cardiac relationships and reduced autonomic
   flexibility in MDD, particularly during negative-emotion processing.
   Using a TabPFN classifier with 10-fold cross-validation and within-fold
   feature selection, multimodal EEG + ECG features achieved the best
   internal discrimination (accuracy 78.57 \%, AUC 0.853), outperforming
   EEG-only, ECG-only, and conventional classifiers. Applying the fixed
   TabPFN model to two independent EEG/ ECG datasets yielded accuracies of
   80.8 \% and 76.7 \% with AUCs of 0.92 and 0.862, providing preliminary
   evidence of external generalizability. Overall, these findings support
   the feasibility and promise of portable multimodal EEG-ECG assessment
   with a small-sample TabPFN framework, while the single-center sample and
   cross-sectional design warrant confirmation in larger, multi-site
   studies.},
Type = {Article},
Affiliation = {Cheng, ZD (Corresponding Author), Zhejiang Univ, Coll Chem \& Biol Engn, Hangzhou 310058, Peoples R China.
   Jiang, HT (Corresponding Author), Zhejiang Univ, MOE Frontier Sci Ctr Brain Sci \& Brain Machine In, Liangzhu Lab, State Key Lab Brain Machine Intelligence, Hangzhou 311121, Peoples R China.
