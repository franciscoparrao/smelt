Keywords = {Polyethylene; Catalyst activity; Melt flow index; Machine learning;
   SHAP; TabPFN},
Keywords-Plus = {PROSPECTS},
Author-Email = {s.rezvantalab@uut.ac.ir
   s.mihandoost@uut.ac.ir},
Number-of-Cited-References = {40},
