   Granitto, Pablo M., CONICET UNR, CIFASIS, Ocampo \& Esmeralda, Rosario, Argentina.},
DOI = {10.1038/s41598-025-29128-6},
Article-Number = {164},
Keywords = {TabPFN; Volatile Organic Compounds; PTR-ToF-MS},
Author-Email = {granitto@cifasis-conicet.gov.ar
   franco.biasioli@fmach.it},
