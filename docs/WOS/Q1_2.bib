   Limay-Rios, Antonio; Campana-Acuna, Andres; Sanca-Valeriano, Silvia, Inst Nacl Materno Perinatal, Unidad Func Invest, Lima, Peru.},
DOI = {10.1177/20552076251342012},
Article-Number = {20552076251342012},
Keywords = {Fetal weight; ultrasonography; prenatal; artificial intelligence;
   machine learning; pregnancy; perinatal care},
Keywords-Plus = {STANDARDS},
Author-Email = {marcos.espinola@upn.edu.pe},
Number-of-Cited-References = {31},
Times-Cited = {1},
