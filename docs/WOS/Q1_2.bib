@article{ WOS:001711509300001,
Author = {Nikzad, Mohammad Hossein and Heidari-Rarani, Mohammad and Sareh, Pooya},
Title = {From classical machine learning algorithms to modern
   transformer-inspired neural networks for multi-target prediction of
   fracture properties in concrete structures},
Journal = {MACHINE LEARNING WITH APPLICATIONS},
Year = {2026},
Volume = {24},
Month = {JUN},
Abstract = {Concrete fracture properties, including fracture energy (Gc) and Mode I
   fracture toughness (KIC), are critical parameters for structural
   performance. Accurate prediction of these parameters remains challenging
   due to their nonlinear dependence on geometric and mechanical factors.
   This study develops a comprehensive, explainable artificial intelligence
   (AI) framework for the simultaneous prediction of Gc and KIC in
   concrete. A dataset comprising 330 data points with six input features,
   including beam depth, span length, beam width, notch length, tensile
   strength, and elastic modulus, was analyzed. Twenty-five machine
   learning algorithms, including 22 classical models and three modern
   transformer-inspired models (i.e., TabPFN, TabNet, and FTTr), were
   systematically trained and evaluated. Hyperparameter tuning was
   performed through grid search and 5-fold cross-validation, while early
   stopping was applied for neural network-based models to prevent
   overfitting. Results show that the TabPFN algorithm, a state-of-the-art
   transformer-based algorithm, achieved the highest accuracy with an R2 of
   87.89\% on the test set, outperforming all other algorithms. To enhance
   interpretability, Shapley Additive Explanations (SHAP) analysis was
   conducted on TabPFN test-set predictions. The results revealed that Gc
   is predominantly governed by tensile strength and ligament-related
   geometry, whereas KIC is strongly influenced by beam depth and notch
   length. Importantly, the SHAP results also highlighted nonlinear and
   interaction-driven effects that were not captured by simple correlation
   analysis. Overall, the findings demonstrate that advanced
   transformer-based algorithms, combined with explainable AI, provide a
   powerful framework for the multi-target prediction of concrete fracture
   properties, offering valuable insights for structural design and
   material optimization.},
Type = {Article},
Affiliation = {Heidari-Rarani, M (Corresponding Author), Univ Isfahan, Fac Engn, Dept Mech Engn, Esfahan 8174673441, Iran.
   Nikzad, Mohammad Hossein; Heidari-Rarani, Mohammad, Univ Isfahan, Fac Engn, Dept Mech Engn, Esfahan 8174673441, Iran.
   Sareh, Pooya, Newcastle Univ, Sch Engn, Creat Design Engn Lab, Newcastle Upon Tyne NE1 7RU, England.},
DOI = {10.1016/j.mlwa.2026.100877},
Article-Number = {100877},
Keywords = {Explainable artificial intelligence; Multi-target prediction;
   Transformer-inspired neural network; Concrete structure; Fracture
   toughness},
Author-Email = {m.h.nikzad@eng.ui.ac.ir
   m.heidarirarani@eng.ui.ac.ir
   pooya.sareh@ncl.ac.uk},
Number-of-Cited-References = {46},
Times-Cited = {0},
Unique-ID = {WOS:001711509300001},
}

@article{ WOS:001583418300001,
Author = {Pacheco-Cardin, Mayra and Hernandez-Arellano, Juan Luis and Mejia-Munoz,
   Jose-Manuel and Maldonado-Macias, Aide Aracely},
Title = {Comparison of machine learning and deep learning models in manual
   strength prediction using anthropometric variables},
Journal = {INTERNATIONAL JOURNAL OF OCCUPATIONAL SAFETY AND ERGONOMICS},
Year = {2025},
Month = {2025 SEP 20},
Abstract = {Objective. This study evaluated the predictive performance of machine
   learning and deep learning models in estimating manual strength in men
   and women using anthropometric variables. Methods. Anthropometric and
   strength data were collected from 382 participants from the economically
   active population of Campeche, Mexico. Predictive models implemented
   included linear regression, random forest, AdaBoost, extreme gradient
   boosting, TabNet, TabPFN and a custom convolutional neural network.
   Their performance was assessed using the mean absolute error, mean
   squared error and explained variance score. Additionally, SHAP (SHapley
   Additive exPlanations) analysis was conducted to interpret feature
   importance across models. Results. Deep learning models such as TabNet
   and TabPFN demonstrated superior prediction accuracy for torque
   strength, capturing complex non-linear interactions. Linear regression
   exhibited better generalization, particularly for grip strength
   prediction. SHAP analysis consistently identified palmar length and
   elbow-to-fingertip length as the most influential anthropometric
   predictors. Ensemble methods like random forest and AdaBoost performed
   well on training data but showed a tendency to overfit. Conclusions.
   Although advanced models enhanced performance in specific tasks, linear
   regression remained the most robust for generalization. Feature
   importance analysis confirmed the biomechanical relevance of the
   selected predictors. Future applications should balance model complexity
   with the need for interpretability, depending on ergonomic objectives.},
Type = {Article; Early Access},
Affiliation = {Pacheco-Cardin, M (Corresponding Author), Calle 38 106 X 21 \& 23 Col Buenavista, Merida 97127, Yucatan, Mexico.
   Pacheco-Cardin, Mayra; Hernandez-Arellano, Juan Luis; Mejia-Munoz, Jose-Manuel; Maldonado-Macias, Aide Aracely, Autonomous Univ Ciudad Juarez, Dept Elect Engn \& Comp Sci, Chihuahua, Mexico.
   Pacheco-Cardin, Mayra, Natl Technol Inst Mexico, Dept Ind Engn, Merida Campus, Guanajuato, Mexico.},
DOI = {10.1080/10803548.2025.2554461},
EarlyAccessDate = {SEP 2025},
Keywords = {anthropometric variables; grip strength; torque strength; regression
   models; deep learning; SHAP analysis; ergonomics prediction},
Author-Email = {al220727@alumnos.uacj.mx},
Number-of-Cited-References = {23},
Times-Cited = {0},
Unique-ID = {WOS:001583418300001},
}

@article{ WOS:001685386700001,
Author = {Li, Peng and Zhan, Dongping and Huang, Bingqian and Zhang, Yan and
   Jiang, Zhouhua and Zhang, Huishu},
Title = {Structural causal relationship and residual adversarial transfer network
   in small sample data},
Journal = {IRONMAKING \& STEELMAKING},
Year = {2026},
Month = {2026 FEB 9},
Abstract = {To address the challenge of predicting converter oxygen consumption
   under small-sample conditions, this article proposes a model that
   integrates residual adversarial transfer learning with structural causal
   inference. The model performs adversarial training using a TabResNet
   feature extractor and a domain discriminator to extract shared invariant
   features between data-rich source and sample-scarce target domains.
   Subsequently, the TabResNet extractor is frozen, and its trained
   parameters - comprising weights and biases of residual BasicBlocks,
   LayerNorm normalisation layers and linear transformation layers -
   extract invariant features from the target domain. These features are
   input into a TabPFN model based on structural causal relationships,
   enabling one-shot forward prediction using a limited set of target
   domain features. Experimental results on 4,695 source domain samples
   (Q195) and 638 target domain samples (Q235) demonstrate that the
   proposed model predicts oxygen consumption predominantly within
   4400-4600 m 3 . Compared to baseline models, the approach achieves an
   RMSE of 40.09 m 3 and R 2 of 0.964, facilitating enhanced process
   control and endpoint determination in industrial steelmaking practice.},
Type = {Article; Early Access},
Affiliation = {Zhan, DP (Corresponding Author), Northeastern Univ, Sch Met, Shenyang 110819, Peoples R China.
   Li, Peng; Zhan, Dongping; Huang, Bingqian; Zhang, Yan; Jiang, Zhouhua, Northeastern Univ, Sch Met, Shenyang 110819, Peoples R China.
   Zhang, Huishu, Liaoning Inst Sci \& Technol, Sch Met Engn, Benxi, Peoples R China.},
DOI = {10.1177/03019233251394429},
EarlyAccessDate = {FEB 2026},
Keywords = {TabResNet; TabPFN; steelmaking; causal inference; transfer learning},
Keywords-Plus = {CONTROL MODEL; PREDICTION; STEEL},
Author-Email = {zhandp1906@163.com},
Number-of-Cited-References = {62},
Times-Cited = {0},
Unique-ID = {WOS:001685386700001},
}

@article{ WOS:001696651600001,
Author = {Liang, Zhijian and Zhu, Guang and Li, Lun and Zhang, Tao and Zhao, Jibin
   and Wangyang},
Title = {Control model for material removal depth of blade robot grinding based
   on Optuna optimized Tabular Prior-data Fitted Network},
Journal = {PRECISION ENGINEERING-JOURNAL OF THE INTERNATIONAL SOCIETIES FOR
   PRECISION ENGINEERING AND NANOTECHNOLOGY},
Year = {2026},
Volume = {99},
Pages = {615-631},
Month = {MAY},
Abstract = {Robot belt grinding, characterized by its flexible and cost-effective
   advantages, has been extensively employed in the machining of aerospace
   casting blades. Nonetheless, these casting blades present challenges
   owing to their uneven machining allowance distribution and intricate
   curved surface structures, necessitating precise material removal to
   meet the stringent processing quality standards. Consequently, the
   development of an intelligent grinding method for precise point-by-point
   material removal has become a pressing issue in the aviation sector. A
   control model for the material removal depth in blade robot grinding was
   proposed by utilizing Optuna optimized Tabular Prior-data Fitted Network
   (O-TabPFN). The theoretical analysis revealed that this model could
   accurately adjust the process parameters to optimize the grinding
   process. The verification experiments demonstrated a prediction accuracy
   of 95.81\% with an average forecast error of 0.007316 mm. These findings
   further substantiated that the intelligent grinding method for
   point-by-point precise removal could flexibly adjust the processing
   parameters based on the allowance distribution, thereby significantly
   enhancing processing accuracy and surface consistency. It indicated that
   this method was particularly applicable to the high-precision
   manufacturing of complex curved surface workpieces.},
Type = {Article},
Affiliation = {Zhu, G (Corresponding Author), Chinese Acad Sci, Shenyang Inst Automat, Shenyang, Liaoning, Peoples R China.
   Liang, Zhijian; Zhu, Guang; Li, Lun; Zhang, Tao; Zhao, Jibin; Wangyang, Chinese Acad Sci, Shenyang Inst Automat, Shenyang, Liaoning, Peoples R China.
   Liang, Zhijian, Univ Chinese Acad Sci, Beijing, Peoples R China.},
DOI = {10.1016/j.precisioneng.2026.02.013},
EarlyAccessDate = {FEB 2026},
Keywords = {Cast blades; Material removal depth; TabPFN; Grinding},
Author-Email = {zhuguang@sia.cn},
Number-of-Cited-References = {26},
Times-Cited = {0},
Unique-ID = {WOS:001696651600001},
}

@incollection{ WOS:001665554100509,
Author = {Liu, Kailong and Zhao, Shiwen and Du, Liang and Peng, Qiao and Duan, Bin
   and Zhang, Chenghui},
Book-Group-Author = {IEEE},
Title = {Impedance Spectroscopy-Based Detection of Internal Short Circuits in
   Sodium-Ion Batteries for Safer Transportation Systems},
Booktitle = {2025 IEEE ENERGY CONVERSION CONFERENCE CONGRESS AND EXPOSITION, ECCE},
Series = {IEEE Energy Conversion Congress and Exposition},
Year = {2025},
Abstract = {The development of sodium-ion batteries (SIBs) is essential for
   advancing transportation electrification. However, internal short
   circuit (ISC) faults pose severe safety risks and may lead to thermal
   runaway. To address this challenge, this study proposes a novel ISC
   fault diagnosis framework that integrates electrochemical impedance
   spectroscopy (EIS) with artificial intelligence. EIS data from three 10
   Ah SIBs under different states of charge are collected, and the
   diagnostic importance of each frequency point is quantified to extract
   key features. The tabular prior-data fitted network (TabPFN) model,
   well-suited for small-scale tabular data, is then employed to detect ISC
   faults. Experimental results show that the proposed method achieves an
   accuracy of 92.9\% and an AUC value of 0.962. Further analysis reveals
   that high-frequency impedance (1 kHz-10 kHz) plays a critical role in
   fault identification and that the TabPFN model maintains robust
   performance across varying temperatures. Compared to classical methods
   such as XGBoost and random forest, the proposed approach delivers
   superior performance, especially under limited data conditions. These
   findings confirm the effectiveness and practicality of the proposed
   framework and highlight its strong potential for enhancing SIB safety in
   real-world energy storage and transportation applications.},
Type = {Proceedings Paper},
Affiliation = {Liu, KL (Corresponding Author), Shandong Univ, Sch Control Sci \& Engn, Jinan, Peoples R China.
   Liu, Kailong; Zhao, Shiwen; Duan, Bin; Zhang, Chenghui, Shandong Univ, Sch Control Sci \& Engn, Jinan, Peoples R China.
   Du, Liang, Villanova Univ, Dept Elect \& Comp Engn, Villanova, PA 19085 USA.
   Peng, Qiao, Queens Univ Belfast, Informat Technol Analyt \& Operat Grp, Belfast, Antrim, North Ireland.},
