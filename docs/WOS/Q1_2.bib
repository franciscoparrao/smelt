@incollection{ WOS:001633222900177,
Author = {Gardner, Josh and Perdomo, Juan C. and Schmidt, Ludwig},
Editor = {Globerson, A and Mackey, L and Belgrave, D and Fan, A and Paquet, U and Tomczak, J and Zhang, C},
Title = {Large Scale Transfer Learning for Tabular Data via Language Modeling},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 37 (NEURIPS 2024)},
Series = {Advances in Neural Information Processing Systems},
Year = {2024},
Abstract = {Tabular data - structured, heterogeneous, spreadsheet-style data with
   rows and columns - is widely used in practice across many domains.
   However, while recent foundation models have reduced the need for
   developing task-specific datasets and predictors in domains such as
   language modeling and computer vision, this transfer learning paradigm
   has not had similar impact in the tabular domain. In this work, we seek
   to narrow this gap and present TABULA-8B, a language model for tabular
   prediction. We define a process for extracting a large, high-quality
   training dataset from the TabLib corpus, proposing methods for tabular
   data filtering and quality control. Using the resulting dataset, which
   comprises over 2.1B rows from 4.2M unique tables, we fine-tune a Llama
   3-8B large language model (LLM) for tabular data prediction
   (classification and binned regression) using a novel packing and
   attention scheme for tabular prediction. Through evaluation across a
   test suite of 329 datasets, we find that TABULA-8B has zero-shot
   accuracy on unseen tables that is over 15 percentage points (pp) higher
   than random guessing, a feat that is not possible with existing
   state-of-the-art tabular prediction models (e.g. XGBoost, TabPFN). In
   the few-shot setting (1-32 shots), without any fine-tuning on the target
   datasets, TABULA-8B is 5-15 pp more accurate than XGBoost and TabPFN
   models that are explicitly trained on equal, or even up to 16x more
   data. We release our model, code, and data along with the publication of
   this paper. 1},
Type = {Proceedings Paper},
Affiliation = {Gardner, J (Corresponding Author), Univ Washington, Seattle, WA 98195 USA.
   Gardner, Josh; Schmidt, Ludwig, Univ Washington, Seattle, WA 98195 USA.
   Perdomo, Juan C., Harvard Univ, Cambridge, MA USA.
   Schmidt, Ludwig, Stanford Univ, Stanford, CA USA.},
Author-Email = {jpgard@cs.washington.edu},
Number-of-Cited-References = {66},
Times-Cited = {1},
Unique-ID = {WOS:001633222900177},
}

@article{ WOS:001724418300001,
Author = {Yin, Hang and Chen, Jiawei and Guo, Fan and Yang, Jiangang},
Title = {Surrogate-assisted multi-objective optimization of leaf-vein textured
   journal bearings under thermohydrodynamic lubrication},
Journal = {TRIBOLOGY INTERNATIONAL},
Year = {2026},
Volume = {220},
Month = {AUG},
Abstract = {Surface texturing can improve the thermohydrodynamic (THD) lubrication
   of journal bearings, yet THD benefits depend strongly on texture
   topology. This study proposes a symmetric leaf-vein (SLV) texture and
   evaluates its THD lubrication performance using a three-dimensional
   CFD-THD multiphase flow model, surrogate-assisted multi-objective
   optimization, and tribological experiments. Relative to the smooth
   surface, rectangular and herringbone textures, the SLV texture promotes
   lateral lubricant transport and hydrodynamic pressure build-up, leading
   to lower friction and a reduced maximum oil-film temperature Tmax under
   the investigated operating condition. A parametric study shows that
   localized texturing in the converging wedge maximizes the dimensionless
   load-carrying capacity (LCC) (up to +23.36\% versus the smooth bearing),
   whereas full-coverage texturing most effectively suppresses Tmax (up to
   -2.77 K). An optimal dimensionless depth of hp{*}approximate to 1.0 is
   identified; deeper grooves intensify lubricant entrapment and
   vortex-related viscous dissipation, degrading LCC and causing a
   temperature rebound. For design optimization, a TabPFN surrogate is
   constructed to map key SLV parameters (L{*}, D1{*}, hp{*}, theta) to THD
   metrics (friction f, LCC, Tmax) and is coupled with NSGA-II; an
   entropyweighted TOPSIS method selects a representative optimum. Compared
   with the smooth bearing, the optimized SLV design reduces cavitation
   area and dimensionless friction by 23.02\% and 19.3\%, increases LCC by
   14.2\%, and lowers Tmax by 2.22 K. Experiments corroborate these trends,
   with the optimized texture reducing the coefficient of friction by up to
   26.7\% and the measured oil-film temperature by up to 4.3 K.},
Type = {Article},
Affiliation = {Yang, JA (Corresponding Author), Southeast Univ, Sch Energy \& Environm, Southeast Univ Rd 2, Nanjing 211102, Jiangsu, Peoples R China.
   Yin, Hang; Chen, Jiawei; Guo, Fan; Yang, Jiangang, Southeast Univ, Sch Energy \& Environm, Southeast Univ Rd 2, Nanjing 211102, Jiangsu, Peoples R China.},
DOI = {10.1016/j.triboint.2026.111936},
Article-Number = {111936},
Keywords = {Journal bearing; Leaf-vein texture; Thermo-hydrodynamic lubrication;
   Multi-objective optimization; TabPFN; Surrogate model},
Keywords-Plus = {SURFACE TEXTURE; SHAPE; PRESSURE; DESIGN},
Author-Email = {230228160@seu.edu.cn
   2571161928@qq.com
   1216351222@qq.com
   15996255667@163.com},
Number-of-Cited-References = {68},
Times-Cited = {0},
Unique-ID = {WOS:001724418300001},
}

@article{ WOS:001659253000001,
Author = {Zhang, Weixing and Yue, Dongbei and Liu, Deqian and Li, Xiuchun and Lv,
   Feng and Cao, Zhicheng and Wei, Liying and Wang, Yongjun and Zhang, Yang
   and Xie, Zhucan and Xie, Wei and Liang, Dingcheng},
Title = {Screening of activated carbon by machine learning and its synergistic
   ozone catalytic oxidation for the removal of organic compounds in
   concentrated brine},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2026},
Volume = {14},
Number = {1},
Month = {FEB},
Abstract = {The highly complex organic substances in coal chemical concentrated
   brine often compromise the purity of crystalline salts and increase
   mixed salt yield during near-zero liquid discharge (NZLD) processes.
   Adsorption shows great potential for removing organic contaminants.
   However, given the wide variety of available adsorbents, selecting
   efficient adsorbents and optimizing processes may be critical for
   addressing the challenges associated with concentrated brine treatment.
   This study uses TabPFN model to establish a structure-activity
   relationship between activated carbon's physicochemical properties and
   its organic adsorption performance. Furthermore, the adsorption and
   catalytic oxidation processes are coupled and arranged in series, and
   threedimensional fluorescence spectroscopy and Fourier transform ion
   cyclotron resonance mass spectrometry to clarify organic physicochemical
   transformations under different process configurations. Results confirm
   activated carbon's high selectivity for organics in high-salinity
   environments, verifying its suitability for concentrated brine organic
   removal. A quantitative structure-activity relationship model (TabPFN
   model) linking activated carbon's structural parameters to total organic
   carbon (TOC) removal capacity is further developed, enabling the
   screening activated carbon tailored to coal chemical concentrated brine.
   This model exhibits strong predictive accuracy (MSE = 2.32, R2 = 0.903),
   confirming its effectiveness in material selection. Additionally, an
   optimized activated carbon-centered process is proposed: activated
   carbon adsorption followed by ozone-catalyzed oxidation achieves 81.64
   \% TOC removal. Activated carbon preferentially adsorbs aliphatic and
   nonoxygenated organics, while ozone-catalyzed oxidation converts
   macromolecular organics into small oxygen-containing molecules. This
   sequence avoids excessive small, oxygenated molecules and heat
   generation that would reduce adsorption efficiency when oxidation is
   performed first.},
Type = {Article},
Affiliation = {Yue, DB; Liang, DC (Corresponding Author), D11 Xueyuan Rd, Beijing 100083, Peoples R China.
   Zhang, Weixing; Yue, Dongbei, Tsinghua Univ, Sch Environm, Beijing 100084, Peoples R China.
   Liu, Deqian, Anqing Normal Univ, Sch Chem \& Chem Engn, Anhui Prov Key Lab Adv Catalysis \& Energy Mat, Anqing 246133, Peoples R China.
   Li, Xiuchun, China Coal Huali Xinjiang Carbon Technol Co Ltd, Hami 839200, Xinjiang, Peoples R China.
   Lv, Feng; Wang, Yongjun; Zhang, Yang, Inner Mongolia Elion Chem Ind Co Ltd, Eerduosi 014300, Peoples R China.
   Cao, Zhicheng; Wei, Liying, Ordos Yongsheng Water Treatment Co LTD, Ordos 014300, Peoples R China.
   Xie, Zhucan; Liang, Dingcheng, China Univ Min \& Technol Beijing, Sch Chem \& Environm Engn, Beijing 100083, Peoples R China.
   Xie, Wei, China Coal Huali Energy Holdings Corp Ltd, Beijing 100011, Peoples R China.
   Liang, Dingcheng, Univ Toyama, Grad Sch Engn, Dept Appl Chem, Gofuku 3190, Toyama 9308555, Japan.},
DOI = {10.1016/j.jece.2025.121014},
EarlyAccessDate = {JAN 2026},
Article-Number = {121014},
Keywords = {Coal chemical concentrated brine; Organic pollutants; Activated carbon;
   Machine learning prediction; Catalytic oxidation},
Keywords-Plus = {ADSORPTION},
Author-Email = {yuedb@tsinghua.edu.cn
   liangdc@cumtb.edu.cn},
Number-of-Cited-References = {47},
