   Al-Hashem, Fahaid, King Khalid Univ, Coll Med, Dept Physiol, Abha 61421, Saudi Arabia.
   Ardigo, Luca Paolo, NLA Univ Coll, Dept Teacher Educ, Linstows Gate 3, N-0166 Oslo, Norway.},
DOI = {10.3390/medicina61050833},
Article-Number = {833},
Keywords = {rheumatoid arthritis; metabolomics; biomarker; machine learning;
   explainable artificial intelligence; explainable boosting machines},
