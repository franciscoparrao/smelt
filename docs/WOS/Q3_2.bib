@article{ WOS:000619177800010,
Author = {Zihan, Zia U. A. and Elseifi, Mostafa A. and Gaspard, Kevin and Zhang,
   Zhongjie},
Title = {Asphalt Concrete Stripping Detection Using Deflection Measurements from
   Traffic Speed Deflection Devices},
Journal = {JOURNAL OF TRANSPORTATION ENGINEERING PART B-PAVEMENTS},
Year = {2020},
Volume = {146},
Number = {4},
Month = {DEC},
Abstract = {Asphalt concrete stripping is a critical distress that occurs underneath
   the pavement surface due to the accumulation of moisture with no visual
   indication at the surface. Past studies have suggested the feasibility
   of using nondestructive methods, such as a ground penetrating radar and
   portable seismic property analyzer, to identify stripping-affected
   pavements. However, these devices are yet to reach widespread
   implementation potential due to some limitations in their operation and
   measurement system. In the present study, the deflection measurements of
   a traffic speed deflection device (TSDD), namely, the Rolling Wheel
   Deflectometer (RWD), were evaluated to identify pavement sections that
   may suffer from stripping and moisture damage. Statistical and
   artificial neural network (ANN) models, which used RWD measured
   deflections, pavement characteristics, and performance data as inputs,
   were developed to predict the probability of stripping damage in the
   tested sections. A logistic model that considers the linearity between
   the predictor and response variables was developed and validated with
   reasonable accuracy in estimating stripping probability. The nonlinear
   relationship between the input and output variables was simulated using
   a generalized additive model (GAM) and was found to have improved
   stripping prediction accuracy. To further address the complex
   relationship between the predictor and response variable, an ANN-based
   pattern recognition system was developed; this approach was more
   accurate than the previous models and is recommended as a
   cross-validation tool for the results of the logistic and GAM models. A
   regression-based classification tree was developed based on the
   available dataset that is easy to interpret and is convenient for
   highway agencies for preliminary stripping evaluation. The analyses and
   methods presented in the study may be used for stripping damage
   detection and as an additional benefit of TSDD testing. (C) 2020
   American Society of Civil Engineers.},
Type = {Article},
Affiliation = {Elseifi, MA (Corresponding Author), Louisiana State Univ, Dept Civil \& Environm Engn, 3256 Patrick Taylor Hall, Baton Rouge, LA 70803 USA.
   Zihan, Zia U. A.; Elseifi, Mostafa A., Louisiana State Univ, Dept Civil \& Environm Engn, 3256 Patrick Taylor Hall, Baton Rouge, LA 70803 USA.
   Gaspard, Kevin; Zhang, Zhongjie, Louisiana Transportat Res Ctr, 4101 Gourrier Ave, Baton Rouge, LA 70808 USA.},
DOI = {10.1061/JPEODX.0000220},
Article-Number = {04020061},
Keywords = {Traffic speed deflection devices (TSDD); Rolling wheel deflectometer
   (RWD); Stripping; Logistic model; Generalized additive model (GAM);
   Artificial neural network (ANN); Decision tree},
Author-Email = {zzihan1@lsu.edu
   elseifi@lsu.edu
   kevin.gaspard@la.gov
   doczhang@dotd.la.gov},
Number-of-Cited-References = {24},
Times-Cited = {5},
Unique-ID = {WOS:000619177800010},
}

@article{ WOS:000539774700001,
Author = {Zereg, Elamine and Chaussenot, Annabelle and Morel, Godelieve and
   Bannwarth, Sylvie and Sacconi, Sabrina and Soriani, Marie-Helene and
   Attarian, Shahram and Cano, Aline and Pouget, Jean and Bellance, Remi
   and Tranchant, Christine and Lannes, Beatrice and de Paula, Andre Maues
   and Ait-El-Mkadem, Samira Saadi and Chafino, Bernadette and Berthet,
   Mathieu and Fragaki, Konstantina and Paquis-Flucklinger, Veronique and
   Rouzier, Cecile},
Title = {Single-fiber studies for assigning pathogenicity of eight mitochondrial
   DNA variants associated with mitochondrial diseases},
Journal = {HUMAN MUTATION},
Year = {2020},
Volume = {41},
Number = {8},
Pages = {1394-1406},
Month = {AUG},
Abstract = {Whole mitochondrial DNA (mtDNA) sequencing is now systematically used in
   clinical laboratories to screen patients with a phenotype suggestive of
   mitochondrial disease. Next Generation Sequencing (NGS) has
   significantly increased the number of identified pathogenic mtDNA
   variants. Simultaneously, the number of variants of unknown significance
   (VUS) has increased even more, thus challenging their interpretation.
   Correct classification of the variants' pathogenicity is essential for
   optimal patient management, including treatment and genetic counseling.
   Here, we used single muscle fiber studies to characterize eight
   heteroplasmic mtDNA variants, among which were three novel variants. By
   applying the pathogenicity scoring system, we classified four variants
   as ``definitely pathogenic{''} (m.590A>G, m.9166T>C, m.12293G>A, and
   m.15958A>T). Two variants remain ``possibly pathogenic{''} (m.4327T>C
   and m.5672T>C) but should these be reported in a different family, they
   would be reclassified as ``definitely pathogenic.{''} We also illustrate
   the contribution of single-fiber studies to the diagnostic approach in
   patients harboring pathogenic variants with low level heteroplasmy.},
Type = {Article},
Affiliation = {Paquis-Flucklinger, V; Rouzier, C (Corresponding Author), Hop Archet 2, Lab Biol Mol, Serv Genet Med, Ctr Reference Malad Mitochondriales, 151 Route St Antoine de Ginestiere, F-06200 Nice, France.
