   Peng, Haorong, Tongji Univ, Key Lab Infrastruct Durabil \& Operat Safety Airfie, 4800 Caoan Rd, Shanghai 201804, Peoples R China.},
DOI = {10.1038/s41598-023-36495-5},
Article-Number = {10939},
Keywords-Plus = {TERRAIN-INDUCED TURBULENCE; AIRCRAFT; TESTS; SHEAR; LIDAR},
Author-Email = {fengchen@tongji.edu.cn},
