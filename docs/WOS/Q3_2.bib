   Katsaros, Christos, Univ Bern, Dept Orthodont \& Dentofacial Orthoped, Bern, Switzerland.},
DOI = {10.1597/09-208},
Keywords = {BCLP; dental arch relationship; scoring system},
Keywords-Plus = {MAXILLARY ARCH CONSTRICTION; AGE},
Author-Email = {orthodontics@dent.umcn.nl},
Number-of-Cited-References = {11},
