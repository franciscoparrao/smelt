DOI = {10.1080/03610918.2013.875570},
Keywords = {Bootstrap resampling methods; Count regression function; Discrete
   kernel; Generalized linear and additive models; Optimal bandwidth
   selections; Wood formation},
Keywords-Plus = {GENERALIZED ADDITIVE-MODELS; BOUNDARY CORRECTION; KERNEL; BANDWIDTH},
