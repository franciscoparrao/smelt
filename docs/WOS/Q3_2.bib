   Cohen, David J., Cardiovasc Res Fdn, New York, NY USA.
   Harrell, Frank, Vanderbilt Univ, Dept Biostat, Sch Med, Nashville, TN USA.
   Lombardi, William, Univ Washington, Div Cardiol, Seattle, WA USA.
   Karmpaliotis, Dimitrios; Moses, Jeffrey, Columbia Univ, Med Ctr, New York, NY USA.
   Sapontis, James, Monash Heart, Melbourne, Vic, Australia.},
DOI = {10.1161/JAHA.121.024056},
