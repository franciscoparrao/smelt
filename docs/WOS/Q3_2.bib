Keywords-Plus = {MAGNETIC-RESONANCE; SCORING SYSTEM; ADNEXAL MASS; MANAGEMENT;
   ULTRASOUND; SENSITIVITY; VALIDATION; ACCURACY; RISK},
Author-Email = {andrea.cozzi@gmail.com},
