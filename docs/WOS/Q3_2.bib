   Neves, Nuno, Univ Nova Lisboa, E GEO, Res Ctr Geog \& Reg Planning, Fac Ciencias Sociais \& Humanas, P-1200 Lisbon, Portugal.},
DOI = {10.1007/s10457-014-9757-7},
