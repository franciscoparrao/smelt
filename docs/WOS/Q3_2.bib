}

@article{ WOS:000720779600001,
Author = {Cui, Erjia and Thompson, E. Christi and Carroll, Raymond J. and Ruppert,
   David},
Title = {A semiparametric risk score for physical activity},
Journal = {STATISTICS IN MEDICINE},
Year = {2022},
Volume = {41},
Number = {7},
Pages = {1191-1204},
Month = {MAR 30},
Abstract = {We develop a generalized partially additive model to build a single
   semiparametric risk scoring system for physical activity across multiple
   populations. A score comprised of distinct and objective physical
   activity measures is a new concept that offers challenges due to the
   nonlinear relationship between physical behaviors and various health
   outcomes. We overcome these challenges by modeling each score component
   as a smooth term, an extension of generalized partially linear
   single-index models. We use penalized splines and propose two
   inferential methods, one using profile likelihood and a nonparametric
   bootstrap, the other using a full Bayesian model, to solve additional
   computational problems. Both methods exhibit similar and accurate
   performance in simulations. These models are applied to the National
   Health and Nutrition Examination Survey and quantify nonlinear and
   interpretable shapes of score components for all-cause mortality.},
Type = {Article},
Affiliation = {Thompson, EC (Corresponding Author), Texas A\&M Univ, Dept Stat, 3143 TAMU, College Stn, TX 77843 USA.
   Cui, Erjia, Johns Hopkins Bloomberg Sch Publ Hlth, Dept Biostat, Baltimore, MD USA.
   Thompson, E. Christi; Carroll, Raymond J., Texas A\&M Univ, Dept Stat, 3143 TAMU, College Stn, TX 77843 USA.
   Carroll, Raymond J., Univ Technol Sydney, Sch Math \& Phys Sci, Broadway, NSW, Australia.
   Ruppert, David, Cornell Univ, Dept Stat \& Data Sci, New York, NY 10021 USA.
   Ruppert, David, Cornell Univ, Sch ORIE, New York, NY 10021 USA.},
DOI = {10.1002/sim.9262},
EarlyAccessDate = {NOV 2021},
Keywords = {accelerometry; Bayesian inference; generalized additive model; NHANES;
   penalized splines},
Keywords-Plus = {REGRESSION; INFERENCE; PATTERNS},
Author-Email = {elizabeth@stat.tamu.edu},
