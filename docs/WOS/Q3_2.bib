   Lu, Yaxin; Liu, Zifeng, Sun Yat Sen Univ, Dept Clin Data Ctr, Affiliated Hosp 3, Guangzhou, Peoples R China.
   Shi, Xietong; Zhong, Shaolong, Sun Yat Sen Univ, Dept Infect Dis, Jieyang Affiliated Hosp, Jieyang Peoples Hosp, Jieyang, Peoples R China.},
DOI = {10.3389/fmed.2021.748915},
Article-Number = {748915},
Keywords = {prediction model; machine learning; recursive feature elimination
