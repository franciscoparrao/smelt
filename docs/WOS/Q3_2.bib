}

@article{ WOS:001136778600001,
Author = {Gross, Zofia and Veyrat-Masson, Richard and Grange, Beatrice and Huet,
   Sarah and Verney, Aurelie and Traverse-Glehen, Alexandra and Ruminy,
   Philippe and Baseggio, Lucile},
Title = {Diagnosis of chronic B-cell lymphoproliferative disease in peripheral
   blood = how machine learning may help to the interpretation of flow
   cytometry data},
Journal = {HEMATOLOGICAL ONCOLOGY},
Year = {2024},
Volume = {42},
Number = {1},
Month = {JAN 5},
Abstract = {Flow cytometry (FCM) has become a method of choice for immunologic
   characterization of chronic lymphoproliferative disease (CLPD). To
   reduce the potential subjectivities of FCM data interpretation, we
   developed a machine learning random forest algorithm (RF) allowing
   unsupervised analysis. This assay relies on 16 parameters obtained from
   our FCM screening panel, routinely used in the exploration of peripheral
   blood (PB) samples (mean fluorescence intensity values (MFI) of CD19,
   CD45, CD5, CD20, CD200, CD23, HLA-DR, CD10 in CD19-gated B cells, ratio
   of kappa/Lambda, and different ratios of MFI B-cells/T-cells {[}CD20,
   CD200, CD23]). The RF algorithm was trained and validated on a large
   cohort of more than 300 annotated different CLPD cases (chronic B-cell
   leukemia, mantle cell lymphoma, marginal zone lymphoma, follicular
   lymphoma, splenic red pulp lymphoma, hairy cell leukemia) and
   non-tumoral selected from PB samples. The RF algorithm was able to
   differentiate tumoral from non-tumoral B-cells in all cases and to
   propose a correct CLPD classification in more than 90\% of cases. In
   conclusion the RF algorithm could be proposed as an interesting help to
   FCM data interpretation allowing a first B-cells CLPD diagnostic
   hypothesis and/or to guide the management of complementary analysis
   (additional immunologic markers and genetic).},
Type = {Article},
Affiliation = {Baseggio, L (Corresponding Author), Hosp Civils Lyon, Groupement Hosp Lyon Sud, Lab Hematol Specialisee, F-69495 Pierre Benite, France.
   Gross, Zofia, Hosp Civils Lyon, Groupement Hosp Lyon Sud, Serv Clin Hematol, Pierre Benite, France.
   Veyrat-Masson, Richard, CHU ESTAING, Lab Hematol, Clermont Ferrand, France.
   Grange, Beatrice; Huet, Sarah; Baseggio, Lucile, Hosp Civils Lyon, Groupement Hosp Lyon Sud, Lab Hematol Specialisee, F-69495 Pierre Benite, France.
   Grange, Beatrice; Huet, Sarah; Verney, Aurelie; Baseggio, Lucile, Univ Claude Bernard Lyon 1, Ctr Int Rech Infectiol CIRI, INSERM U1111, CNRS UMR5308, Lyon, France.
   Traverse-Glehen, Alexandra, Hosp Civils Lyon, Groupement Hosp Lyon Sud, Serv Anat Pathol, Pierre Benite, France.
   Traverse-Glehen, Alexandra; Ruminy, Philippe, Univ Normandie, Ctr Henri Becquerel, INSERM U1245, UNIROUEN, Rouen, France.},
DOI = {10.1002/hon.3245},
Article-Number = {e3245},
Keywords = {chronic lymphoproliferative disease; flow cytometry; genetic; lymphoma;
   machine learning},
Keywords-Plus = {SCORING SYSTEM; EXPRESSION; DISORDERS; LYMPHOMA},
Author-Email = {lucile.baseggio@chu-lyon.fr},
