@article{ WOS:001702691400001,
Author = {Gracia-Ramos, Abraham Edgar and Guyatt, Gordon H. and Colunga-Lozano,
   Luis Enrique},
Title = {Teaching evidence-based principles in Rheumatology},
Journal = {RHEUMATOLOGY INTERNATIONAL},
Year = {2026},
Volume = {46},
Number = {3},
Month = {FEB 26},
Abstract = {Evidence-based medicine (EBM) integrates the best available evidence
   with clinical expertise and patients' values and preferences to support
   high-quality, patient-centered care. While early EBM education
   emphasized critical appraisal of primary studies, it has progressively
   shifted toward a pragmatic approach that prioritizes the use of evidence
   summaries to enable timely, informed clinical decisions. Accordingly,
   EBM training may benefit from an emphasis on developing skills related
   to interpreting effect sizes, appreciating the certainty of the
   evidence, understanding the strength of recom-mendations, and applying
   research findings in clinical contexts through shared decision-making.
   This evolution reflects the realities of contemporary healthcare, in
   which time constraints and the exponential growth of the medical
   literature limit the feasibility of relying on individual studies for
   routine clinical decision-making. In Rheumatology, these com-petencies
   are particularly important for selecting synthetic or biologic
   disease-modifying antirheumatic drugs or targeted therapies, and for
   diagnostic decisions involving classification criteria, imaging, and
   biomarkers, where the certainty of evidence often varies. Moreover,
   rheumatology practice relies heavily on clinical practice guidelines
   that frequently issue conditional recommendations, underscoring the need
   to contextualize evidence in light of patient preferences,
   comorbidi-ties, and treatment burden.},
Type = {Review},
Affiliation = {Colunga-Lozano, LE (Corresponding Author), McMaster Univ, Dept Hlth Res Methods Evidence \& Impact, Hamilton, ON, Canada.
   Colunga-Lozano, LE (Corresponding Author), Univ Guadalajara, Hlth Sci Ctr, Dept Clin Med, Guadalajara, Jalisco, Mexico.
   Gracia-Ramos, Abraham Edgar, Inst Mexicano Seguro Social, Hosp Gen, Ctr Med Nacl Raza, Dept Internal Med, Mexico City, Mexico.
   Guyatt, Gordon H.; Colunga-Lozano, Luis Enrique, McMaster Univ, Dept Hlth Res Methods Evidence \& Impact, Hamilton, ON, Canada.
   Colunga-Lozano, Luis Enrique, Univ Guadalajara, Hlth Sci Ctr, Dept Clin Med, Guadalajara, Jalisco, Mexico.},
DOI = {10.1007/s00296-026-06088-2},
Article-Number = {54},
Keywords = {Evidence-based medicine; Education; Shared-decision making; Statistical
   reasoning; Rheumatology},
Keywords-Plus = {EVIDENCE-BASED MEDICINE; 2021 AMERICAN-COLLEGE; QUALITY; GRADE;
   GUIDELINES; MANAGEMENT; CARE},
Author-Email = {dr.gracia.dmm@gmail.com
