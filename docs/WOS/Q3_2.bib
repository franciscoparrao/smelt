Author-Email = {wuweiying1011@gms.ndhu.edu.tw},
Number-of-Cited-References = {16},
Times-Cited = {1},
Unique-ID = {WOS:000544727200001},
}

@incollection{ WOS:000428311600066,
Author = {Rcbhi, Ibtihel and Malouche, Dhafer},
Book-Group-Author = {IEEE},
Title = {Decision making about products development through consumer preferences
   modeling based on descriptive characteristics of products},
Booktitle = {2017 IEEE/ACS 14TH INTERNATIONAL CONFERENCE ON COMPUTER SYSTEMS AND
   APPLICATIONS (AICCSA)},
Series = {International Conference on Computer Systems and Applications},
Year = {2017},
Pages = {423-430},
Abstract = {Several modeling procedures are employed to explain the relationships
   between human taste preferences and sensory properties of products.
   External preference mapping (EPM) is one of them. It is used to visually
   assess this relationship. It aims to extract high-level knowledge from
   two main datasets : a first hedonic data obtained from evaluations of
   consumers towards products and a second sensory data resulting from
   descriptive properties measurements collected 14 the same products.
   Classically, EPM proceeds in the following steps : first a reduction
   dimension method is used to extract the maximum of information contained
   in the sensory dataset and then construct a new perceptual space where
   the position of the studied product is determined according to its
   sensory characteristics. In a second step, a series of regressions are
   performed on the hedonic data to predict the preference liking on this
   new projection space which may help product developers to make decisions
   how to reformulate existing products to increase consumer appeal.
   Multiple Polynomial Regression (MPR) models are the traditionally used
   models to identify liking drivers.
   A primary objective of this study is to advocate the use of Generalized
   Linear Models (GLM), Generalized Additive Models (GAM) and Locally
   Weighted Scatterplot Smoothing (LOESS) that can be potentially used to
   identify and visually understand the tendencies of consumers'
   preferences. In fact, the fitting of a simple linear or polynomial
   models would not be adequate in some cases and the analysis demands the
   greater flexibility offered by GLM, GAM and LOESS approaches.
   The strategy of analysis presented in this study covers a comparison
   between the performance of the proposed models with casual used models.
   Their performance have been compared using several statistical criteria
   in one hand, and through products positioning on EPM level lines in the
   other hand. The high performance of the LOESS algorithm is rather
   interesting and a smoothing version of EPM is proposed. A case study of
   cookies data is presented and demonstrates the strengths and weaknesses
   of applying these methods to EPM. The efficiency of the proposed method
   is also evaluated by a simulation study.},
Type = {Proceedings Paper},
Affiliation = {Rcbhi, I (Corresponding Author), Natl Engn Sch Tunis, Tunis, Tunisia.
   Rcbhi, I (Corresponding Author), Engn Sch Stat \& Informat Anal, MASE Unit, Tunis, Tunisia.
   Rcbhi, Ibtihel, Natl Engn Sch Tunis, Tunis, Tunisia.
   Rcbhi, Ibtihel; Malouche, Dhafer, Engn Sch Stat \& Informat Anal, MASE Unit, Tunis, Tunisia.
   Malouche, Dhafer, Univ Michigan, Ctr Polit Studies, Ann Arbor, MI 48109 USA.},
DOI = {10.1109/AICCSA.2017.202},
Author-Email = {ibtihel.rebhi@enit.utm.tn},
Number-of-Cited-References = {21},
Times-Cited = {1},
Unique-ID = {WOS:000428311600066},
}

@incollection{ WOS:000414164700052,
Author = {Vanem, E. and Brandster, A. and Gramstad, O.},
Editor = {Walls, L and Revie, M and Bedford, T},
Title = {Regression models for the effect of environmental conditions on the
   efficiency of ship machinery systems},
Booktitle = {RISK, RELIABILITY AND SAFETY: INNOVATING THEORY AND PRACTICE},
Year = {2017},
Pages = {362-371},
Abstract = {Ships operate under varying environmental conditions, and the different
   external factors from the ship environment may have a great impact on
   the safety, reliability and efficiency of ships and various ship
   systems. This paper addresses the effect of weather and other external
   conditions on the efficiency of a ship propulsion system. Data collected
   over a few months from an ocean-going ship are analysed, and various
   statistical regression models are applied to explain the variation in
   different response variables related to the efficiency of the propulsion
   system from variation in variables representing external factors.
   Initial attempts to regress the speed throughwater on the other
   variables are able to explain a large part of the variation in ship
   speed. However, the shaft thrust is responsible for most of the
   explanatory power and such models are not very useful. However, it is
   realized that the ratio of speed to the power of 2 over thrust can be
   used as a proxy for the efficiency of the propulsion system. Thus,
   statistical regression models were developed with this as the dependent
   variable and the various external factors as covariates. Various
   regression models are compared; linear regression models fitted by
   ordinary least squares (OLS) aswell as penalized versions of these,
   generalized additive models (GAM), regression trees and projection
   pursuit regression (PPR) models. Generally, the non-linear models such
   as the projection pursuit regression models as well as some rather
   complex regression trees were found to perform best, indicating that the
   relationships between the response variable and the explanatory
   variables are not linear. The best models are able to explain more than
   50\% of the variation in the efficiency from the various covariates and
   also perform well on the test data. This indicates that the effects of
   external environmental factors on the efficiency are notable, and that
   they can be taken into account by the statistical models applied in this
   study.},
Type = {Proceedings Paper},
Affiliation = {Vanem, E (Corresponding Author), DNV GL Strateg Res \& Innovat, Hovik, Norway.
   Vanem, E (Corresponding Author), Univ Oslo, Oslo, Norway.
   Vanem, E.; Brandster, A.; Gramstad, O., DNV GL Strateg Res \& Innovat, Hovik, Norway.
   Vanem, E.; Brandster, A., Univ Oslo, Oslo, Norway.},
Keywords-Plus = {ENERGY EFFICIENCY; CONSUMPTION},
Number-of-Cited-References = {15},
Times-Cited = {1},
Unique-ID = {WOS:000414164700052},
}

@article{ WOS:000380937700037,
Author = {Saqqur, Maher and Ghrooda, Esseddeeg and Ahmad, Aftab and Khan, Khurshid
   and Hussain, Muhammad S. and Shuaib, Ashfaq},
Title = {The Combination of Clinical Features, Transcranial Doppler, and Alberta
   Stroke Program Early Computed Tomography Score (Computed Tomography
   Angiography) in Predicting Outcome in Intravenous Recombinant Tissue
   Plasminogen Activator-Treated Patients},
Journal = {JOURNAL OF STROKE \& CEREBROVASCULAR DISEASES},
Year = {2016},
Volume = {25},
Number = {8},
Pages = {2019-2023},
Month = {AUG},
Abstract = {Background: Little data exist on using combined baseline clinical
   neuroimaging and transcranial Doppler (TCD) information in predicting
   clinical outcome in stroke patients treated with intravenous (IV)
   thrombolysis. Methods: Stroke patients received IV recombinant tissue
   plasminogen activator (rt-PA) and had diagnostic TCD within 3 hours of
   symptom onset. The TCD result was interpreted using the thrombolysis in
   brain ischemia (TIBI) flow grading system. Following multiple regression
   analysis, a grading system was created with 1 point for each of the
   following: National Institutes of Health Stroke Scale (NIHSS) score of
   16 or higher, TIBI score of 1 or lower, and Alberta Stroke Program Early
   CT Score (ASPECTS) of 6 or lower. The patients' scores were compared to
   modified Rankin Scale (mRS) scores at 90 days. Results: A total of 349
   patients were included. In unvaried analysis, age of 80 years or older
   (P = .002), an ASPECTS of 6 or lower (P < .001), an NIHSS score of 16 or
   higher (P < .001), a TIBI score of 1 or lower (P < .001), and a glucose
   level >= 200 mg/dl (P = .04) were associated with poor outcome (mRS
   score > 2). In the multiple regression analysis, age of 80 years or
   older, an ASPECTS of 6 or lower, an NIHSS score of 16 or higher, and
   hyperglycemia were predictors of poor outcome (P < .05). Based on our
   scoring system, the patients' odds ratios for poor outcome were 7 (95\%
   confidence interval {[}CI]: 2-23, P = .003), 8 (95\% CI: 3-25, P <
   .001), and 24 (95\% CI: 4-151, P = .001) for scores of 1, 2, and 3,
   respectively, after adjustment for common stroke risk factors. The mean
   time to recanalization increased as the score increased (score of 0: 160
   +/- 45 minutes versus score of 3: 186 > 38 (P = .70). Conclusion: A
   multimodal grading system is useful in predicting outcome in patients
   treated with IV rt-PA. Those with higher scores might be candidates for
   interventional therapy.},
Type = {Article},
Affiliation = {Saqqur, M (Corresponding Author), Univ Alberta, Dept Med, Div Neurol, Edmonton, AB, Canada.
   Saqqur, Maher; Ghrooda, Esseddeeg; Khan, Khurshid; Shuaib, Ashfaq, Univ Alberta, Dept Med Neurol, Edmonton, AB, Canada.
   Ahmad, Aftab, Natl Univ Hlth Syst, Natl Neurosci Inst, Dept Med, Div Neurol, Singapore, Singapore.
   Hussain, Muhammad S., Cleveland Clin Fdn, Endovasc Surg Neuroradiol, Cleveland, OH USA.},
DOI = {10.1016/j.jstrokecerebrovasdis.2015.12.013},
Keywords = {TCD; ultrasound; stroke; thrombolysis; outcome; neuroimaging},
Keywords-Plus = {ACUTE ISCHEMIC-STROKE; ENDOVASCULAR TREATMENT; ARTERIAL-OCCLUSION;
   DRAGON SCORE; THROMBOLYSIS; RECANALIZATION; TRIAL; CRITERIA; SITE; CT},
Author-Email = {msaqqur@ualberta.ca},
Number-of-Cited-References = {17},
Times-Cited = {1},
Unique-ID = {WOS:000380937700037},
}

@article{ WOS:000369368100021,
Author = {Dyakov, N. R.},
Title = {SPATIAL DISTRIBUTION OF DOMINANT PLANTS SPECIES ACCORDING TO LOCAL
   ENVIRONMENTAL GRADIENTS},
Journal = {APPLIED ECOLOGY AND ENVIRONMENTAL RESEARCH},
Year = {2016},
Volume = {14},
Number = {1},
Pages = {327-347},
Abstract = {At the current stage of vegetation ecology development as a science it
   has not been reached consensus between the competing theories trying to
   explain vegetation pattern emerging under the influence of underlying
   environmental gradients. It is still not clear what is the response of
   different plant species towards the influence of complex gradients? This
   study tries to revise some classical and temporary hypotheses concerning
   species response surface/curve shape along environmental gradients
   whether it is symmetric (Gaussian) or with other shape. It also attempts
   to check if species modes along complex gradients are distributed
   randomly, uniformly or they are clumped, as well as to inspect the
   species mode distribution among species importance value octaves -
   whether it is lognormal or lograndom. Field samples were gathered using
   gradsect method for laying down sampling plots. Obtained data were
   analyzed in the context of four complex gradients - elevation, habitat
   dryness, slope inclination and slope convexity. CCA ordination, GAM and
   LOEES regression and nonparametric correlation were used as analyzing
   tools. We have found that species response surface/curves do not have
   symmetric shape but rather they show asymmetric and complex forms. Mode
   distribution of dominant tree and shrub species was random but that of
   herbs followed clumped pattern. When species mode distribution was
   divided into octaves, trees and shrubs showed lograndom distribution but
   all species together had lognormal one. Herbs alone do not conform to
   neither lognormal nor lograndom distributional patter. It seems that
   each species has its own response shape towards the environment,
   determined by its physiology, interaction with other species and
   historical events. It is hoped that the current study will add a little
   drop to the vast ocean of vegetation ecology knowledge helping with the
   clarification of the basic understanding of the vegetation pattern.},
Type = {Article},
Affiliation = {Dyakov, NR (Corresponding Author), Univ Forestry, Dendrol Dept, 10 Kliment Ohridski Blvd, Sofia 1797, Bulgaria.
   Dyakov, N. R., Univ Forestry, Dendrol Dept, 10 Kliment Ohridski Blvd, Sofia 1797, Bulgaria.},
Keywords = {elevation; habitat dryness; distribution fitting; response
   surfaces/curves},
Keywords-Plus = {DISTRIBUTION MODELS; ECOLOGICAL THEORY; VEGETATION; DISTURBANCE;
   MOUNTAINS; PATTERN; FOREST},
Author-Email = {nickydyakov@gmail.com},
Number-of-Cited-References = {52},
Times-Cited = {1},
Unique-ID = {WOS:000369368100021},
}

@article{ WOS:000393325900030,
Author = {Fagundes, Thais Ferreira and Poblete Vidal, Leticia Gabriela and Moreira
   Alves, Pedro Afonso and Tassinari, Wagner de Souza and Alves Alcantara
   de Menezes, Rita de Cassia and da Fonseca, Adevair Henrique and Salim
   Pereira, Maria Julia},
Title = {Risk factors for diarrhea in a cohort of dairy heifer calves reared in
   individual outdoor hutches in Pirai, Rio de Janeiro, Brazil},
Journal = {SEMINA-CIENCIAS AGRARIAS},
Year = {2016},
Volume = {37},
Number = {5},
Pages = {3159-3172},
Abstract = {This study aimed to evaluate the association between diarrhea and risk
   factors potentially related to diarrhea incidence, such as
   Cryptosporidium, Giardia, Eimeria and nematode infection, animal age,
   failure to transfer passive immunity, type of fertilization (artificial
   insemination - AI, in vitro production of embryos - IVP and natural
   breeding), mother (heifer/cow) and birth weight of heifer calves reared
   in individual outdoor hutches on a dairy farm. The database used in the
   present study refers to a weekly survey of a cohort of 118 heifer calves
   from birth to 100 days of age. A logistic generalized additive model
   (GAM) was fit to evaluate the functional relationship between the risk
   of diarrhea occurrence and birth weight. For analysis purposes, the
   database was divided into calves up to 30 days old and calves 31 to 100
   days old. Bivariate and multivariate analyses were performed using
   logistic regression models via generalized estimating equations. All
   variables were included in the models and were removed one-by-one
   according to Wald statistics to obtain the final model. The relative
   risks (RR) and their respective 90\% confidence intervals were
   estimated. The final model for calves up to 30 days old showed that IVP
   {[}RR=0.33 (90\% CI 0.14; 0.75)] is a protective factor and that
   Cryptosporidium spp. infection {[}RR=1.95 (90\% CI 1.22; 3.12)] is a
   risk factor. Although not statistically significant {[}RR=1.46 (90\% CI
   0.98; 2.18)], failure to transfer passive immunity increases the risk of
   diarrhea. The final model for calves 31 100 days old showed that IVP
   {[}RR=0.50 (90\% IC 0.28; 0.89)] and birth weight >= 40 kg {[}RR=0.65
   (90\% CI 0.47; 0.89)] are protective factors. In this age group,
   Cryptosporidium spp. infection has no statistical significance
   {[}RR=1.25 (90\% CI 0.95; 1.64)]. These results indicate that some of
   the diarrhea episodes observed in animals up to 30 days old could be
   explained by Cryptosporidium infection; therefore, better monitoring of
   these animals is recommended. Greater care in colostrum administration
   is suggested because animals with hypoglobulinemia are more sensitive to
   diarrhea occurrence. Although attention should be given to all animals
   with a low birth weight, special care should be given to those 31 to 100
   days old.},
Type = {Article},
Affiliation = {Pereira, MJS (Corresponding Author), UFRRJ, Seropedica, RJ, Brazil.
   Fagundes, Thais Ferreira; Poblete Vidal, Leticia Gabriela; Tassinari, Wagner de Souza; Alves Alcantara de Menezes, Rita de Cassia; da Fonseca, Adevair Henrique; Salim Pereira, Maria Julia, UFRRJ, Seropedica, RJ, Brazil.
   Moreira Alves, Pedro Afonso, PESAGRO RIO, Estacao Expt Seropedica, Seropedica, RJ, Brazil.},
DOI = {10.5433/1679-0359.2016v37n5p3159},
Keywords = {Epidemiology; Generalized estimating equations; Logistic regression
   model; Longitudinal study},
Keywords-Plus = {GLUTARALDEHYDE COAGULATION TEST; CRYPTOSPORIDIUM-PARVUM; CALF DIARRHEA;
   BIRTH-WEIGHT; IN-VITRO; PREVALENCE; MORBIDITY; MORTALITY; SERUM;
   HYPOGAMMAGLOBULINEMIA},
Author-Email = {tha.fagundes@gmail.com
