   Groll, Andreas, Georg August Univ Gottingen, Stat, Gottingen, Germany.
   Groll, Andreas, Georg August Univ Gottingen, Econometr, Gottingen, Germany.},
DOI = {10.1177/1471082X17748083},
Keywords = {Cox model; time-varying coefficients; piece-wise exponential model;
