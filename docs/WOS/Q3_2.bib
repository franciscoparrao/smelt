   Allegheny Univ, Hahnemann Sch Med, Ctr Mol Nucl Cardiol MCP, Allegheny, WV USA.
   Stanford Univ, Sch Med, Dept Cardiothorac Surg, Stanford, CA 94305 USA.},
DOI = {10.1016/S0735-1097(98)00084-9},
Keywords-Plus = {CARDIAC ALLOGRAFT-REJECTION; CELLULAR HEART REJECTION; INTERNATIONAL
   SOCIETY; TRANSPLANTATION},
