@article{ WOS:000581368700001,
Author = {Cacolice, Paul A. and Carcia, Christopher R. and Scibek, Jason S. and
   Phelps, Amy L.},
Title = {Ground Reaction Forces Are Predicted with Functional and Clinical Tests
   in Healthy Collegiate Students},
Journal = {JOURNAL OF CLINICAL MEDICINE},
Year = {2020},
Volume = {9},
Number = {9},
Month = {SEP},
Abstract = {Increased vertical and posterior ground reaction forces (GRFs) are
   associated with anterior cruciate ligament (ACL) injury. If a practical
   means to predict these forces existed, ACL injury risk could be
   attenuated. Forty-two active college-age individuals (21 females, 20.66
   +/- 1.46 y, 70.70 +/- 2.36 cm, 82.20 +/- 7.60 kg; 21 males, 21.57 +/-
   1.28 y, 65.52 +/- 1.87 cm, 64.19 +/- 9.05 kg) participated in this
   controlled laboratory study. GRFs were ascertained by having the
   subjects perform a unilateral landing task onto a force plate. Several
   clinical measures (Fat Free Mass (FFM), dorsiflexion passive range of
   motion (DPROM), isometric peak force of the lateral hip rotators, knee
   flexor/extensor peak force ratio (H:Q), the completion of the overhead
   deep squat), two functional tests (Margaria-Kalamen, Single Leg Triple
   Hop (SLTH)), and sex served as the predictor variables. Regression
   models to predict the GRFs normalized to the FFM (nGRFz, nGRFy) were
   generated. nGRFz was best predicted with a linear regression equation
   that included SLTH and DPROM (adjusted R-2 = 0.274; p = 0.001). nGRFy
   was best predicted with a linear regression equation that included H:Q,
   FFM, and DPROM (adjusted R-2 = 0.476; p < 0.001). Simple clinical
   measures and functional tests explain a small to moderate amount of the
   variance associated with the FFM normalized vertical and posterior GRFs
   in active college-age individuals.},
Type = {Article},
Affiliation = {Cacolice, PA (Corresponding Author), Westfield State Univ, Dept Movement Sci Sport \& Leisure Studies, Westfield, MA 01086 USA.
   Cacolice, Paul A., Westfield State Univ, Dept Movement Sci Sport \& Leisure Studies, Westfield, MA 01086 USA.
   Carcia, Christopher R., Colorado Mesa Univ, Dept Kinesiol, Grand Junction, CO 81501 USA.
   Carcia, Christopher R.; Scibek, Jason S., Duquesne Univ, Rangos Sch Hlth Sci, Pittsburgh, PA 15282 USA.
   Phelps, Amy L., Duquesne Univ, Palumbo Donahue Sch Business, Pittsburgh, PA 15282 USA.},
DOI = {10.3390/jcm9092907},
Article-Number = {2907},
Keywords = {anterior cruciate ligament; functional test; injury prediction},
Keywords-Plus = {ANTERIOR CRUCIATE LIGAMENT; ERROR SCORING SYSTEM; LOWER-EXTREMITY
   BIOMECHANICS; ANKLE-DORSIFLEXION RANGE; NONCONTACT ACL INJURIES;
   KNEE-JOINT KINEMATICS; FEMALE TEAM HANDBALL; CROSS-SECTIONAL AREA;
   ANAEROBIC POWER TEST; MENSTRUAL-CYCLE},
Author-Email = {pcacolice@westfield.ma.edu
