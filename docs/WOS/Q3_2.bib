Keywords = {3D high-definition anorectal manometry; anal incontinence; constipation;
   London classification},
Keywords-Plus = {BALLOON EXPULSION TEST; SCORING SYSTEM; CONSTIPATION; DYSFUNCTION;
   DEFECATION},
