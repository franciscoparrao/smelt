   GEN HOSP, DEPT PATHOL, BIRMINGHAM, W MIDLANDS, ENGLAND.},
DOI = {10.1136/gut.35.7.961},
Keywords-Plus = {CROHNS-DISEASE; ULCERATIVE-COLITIS; COLONIC DISEASE; COLONOSCOPY;
   DIAGNOSIS},
