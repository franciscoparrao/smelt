   Costabel, Ulrich, Univ Duisburg Essen, Fac Med, Essen, Germany.
   Kovuru, Mani, E Carolina Univ, Greenville, NC USA.
   Schlenker-Herceg, Rozsa; Flavin, Susan; Lo, Kim Hung; Barnathan, Elliot S., Centocor Inc, Malvern, PA 19355 USA.},
DOI = {10.1378/chest.08-1876},
