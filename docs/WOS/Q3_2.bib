   Boto-Garcia, David, Univ Oviedo, Dept Econ, Oviedo, Spain.
   Leoni, Veronica, Ctr Adv Studies Tourism, Via Anghera 22, I-47921 Rimini, Italy.},
DOI = {10.1016/j.ijhm.2023.103493},
