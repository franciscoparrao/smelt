@article{ WOS:001020892000001,
Author = {Mei, Matthew and Pillai, Raju and Kim, Soyoung and Estrada-Merly, Noel
   and Afkhami, Michelle and Yang, Lixin and Meng, Zhuo and Abid, Muhammad
   Bilal and Aljurf, Mahmoud and Bacher, Ulrike and Beitinjaneh, Amer and
   Bredeson, Christopher and Cahn, Jean-Yves and Cerny, Jan and Copelan,
   Edward and Cutler, Corey and DeFilipp, Zachariah and Diaz Perez, Miguel
   Angel and Farhadfar, Nosha and Freytes, Cesar O. and Gadalla, Shahinaz
