@article{ WOS:001041334300001,
Author = {Swe, Khin Nilar and Takai, Sawa and Noguchi, Noboru},
Title = {Novel approaches for a brix prediction model in Rondo wine grapes using
   a hyperspectral Camera: Comparison between destructive and
   Non-destructive sensing methods},
Journal = {COMPUTERS AND ELECTRONICS IN AGRICULTURE},
Year = {2023},
Volume = {211},
Month = {AUG},
Abstract = {Understanding the oenological parameters of wine grapes is of utmost
   importance for both the assessments of wine quality and the optimum
   harvest. Recent developments in remote-sensing technologies for
   predicting the oenological parameters of wine grapes in precision
   viticulture have focused only on nondestructive measurements. In this
   study, we developed an innovative and simple brix prediction model using
   Hyper Suprime-Cam (HSC) camera (HSC) combined with two machine learning
   approaches. Our findings clarified the most powerful wavelengths that
   have a strong influence on the brix. We compared the two machine
   learning approaches and performed another comparison of destructive and
   nondestructive brix prediction models. The explainable boosting machine
   (EBM) followed by support vector regression (SVR) model can generate
   more simple output to identify powerful wavelengths for brix prediction
   compared to the ridge regression model. The accuracy of the
   nondestructive brix prediction model was better than that of the
   destructive model in both machine learning approaches because of noise
   and climate factors varying with time in the outdoor environment.
   However, considering the shape, slope, and shifting factor of the
   reflectance curve of the outdoor berry samples, a significant
   improvement in accuracy was observed for brix estimation by the
   destructive method. Wavelengths between 705 and 745 nm could have had a
   strong influence on the brix in both the destructive and nondestructive
   measurements, but we observed a small shift from the smaller wavelengths
   to the larger wavelengths in the nondestructive measurement. Our results
   also revealed that wavelengths between 900 and 930 nm based on the shape
   factor also play an important role in the brix prediction after model
   enhancement.},
Type = {Article},
Affiliation = {Swe, KN (Corresponding Author), Hokkaido Univ, Grad Sch Agr, Kita-9,Nishi-9,Kita Ku, Sapporo, Hokkaido 0608589, Japan.
   Swe, Khin Nilar; Takai, Sawa, Hokkaido Univ, Grad Sch Agr, Kita-9,Nishi-9,Kita Ku, Sapporo, Hokkaido 0608589, Japan.
   Noguchi, Noboru, Hokkaido Univ, Res Fac Agr, Kita-9,Nishi-9,Kita Ku, Sapporo, Hokkaido 0608589, Japan.},
DOI = {10.1016/j.compag.2023.108037},
EarlyAccessDate = {JUL 2023},
Article-Number = {108037},
Keywords = {Brix prediction model; Hokkaido; Remote sensing; Machine learning
   approach; Precision viticulture},
Keywords-Plus = {ANTHOCYANIN CONTENT; VINTAGES; BERRIES; PH},
Author-Email = {rubynilar29@gmail.com},
Number-of-Cited-References = {11},
Times-Cited = {9},
Unique-ID = {WOS:001041334300001},
}

@article{ WOS:001043636300009,
Author = {Andina, Nicola and de Meuron, Louise and Schnegg-Kaufmann, Annatina
   Sarah and Sarangdhar, Mayuresh Anant and Ansermet, Camille and Bombaci,
   Giuseppe and Batta, Kiran and Keller, Nino and Porret, Naomi A. and
   Angelillo-Scherrer, Anne and Bonadies, Nicolas and Allam, Ramanjaneyulu},
Title = {Increased Inflammasome Activation Is Associated with Aging and Chronic
   Myelomonocytic Leukemia Disease Severity},
Journal = {JOURNAL OF IMMUNOLOGY},
Year = {2023},
Volume = {210},
Number = {5},
Pages = {580-589},
Month = {MAR 1},
Abstract = {Aging causes chronic low-grade inflammation known as inflamm-aging. It
   is a risk factor for several chronic disorders, including chronic
   myelomonocytic leukemia (CMML), a hematological malignancy that is most
   prevalent in older people. Recent studies suggest a critical role for
   the NLRP3 (NOD-, LRR-and pyrin domain-containing protein 3) inflammasome
   in inflamm-aging. However, the mechanisms involved in NLRP3 activation
   in aging and its involvement in CMML progression are not fully
   understood. In this study, we report that aging increases IL-1b
   production upon NLRP3 activation in human CD14+ monocytes.
   Interestingly, we found that the TLR1/2 agonist Pam3CSK4 directly
   activates the NLRP3 inflammasome in monocytes from older but not from
   younger healthy donors. Furthermore, we observed a dichotomous response
   to NLRP3 inflammasome activation in monocytes from a small cohort of
   CMML patients, and some patients produced high levels of IL-1b and some
   patients produced low levels of IL-1b compared with older healthy
   donors. Intriguingly, CMML patients with heightened NLRP3 activation
   showed increased treatment dependency and disease severity.
   Collectively, our results suggest that aging causes increased
   sensitivity to NLRP3 inflammasome activation at a cellular level, which
   may explain increased inflammation and immune dysregulation in older
   individuals. Furthermore, NLRP3 inflammasome activation was dysregulated
   in a small cohort of CMML patients and was positively correlated with
   disease severity.},
