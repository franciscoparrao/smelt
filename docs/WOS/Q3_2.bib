   Barua, Prabal Datta, Univ Technol Sydney, Fac Engn \& Informat Technol, Sydney, Australia.
   Barua, Prabal Datta; Acharya, U. Rajendra, Univ Southern Queensland, Fac Business Educ Law \& Arts, Sch Business Informat Syst, Toowoomba, Australia.
   Acharya, U. Rajendra, Ngee Ann Polytech, Sch Engn, Singapore, Singapore.
   Acharya, U. Rajendra, Asia Univ, Dept Bioinformat \& Med Engn, Taichung, Taiwan.
   Acharya, U. Rajendra, Kumamoto Univ, Res Org Adv Sci \& Technol IROAST, Kumamoto, Japan.},
DOI = {10.1016/j.cmpb.2022.107161},
EarlyAccessDate = {OCT 2022},
Article-Number = {107161},
Keywords = {Explainable artificial intelligence (XAI); Deep learning; Machine
   learning; PRISMA; SHAP; LIME; GradCAM; LRP; EBM; CBR; Rule-based; Expert
   system; Saliency map; Attention mechanism; Healthcare},
Keywords-Plus = {MACHINE LEARNING-MODEL; DIAGNOSIS; CLASSIFICATION; ENSEMBLES; NETWORKS;
   GLAUCOMA},
