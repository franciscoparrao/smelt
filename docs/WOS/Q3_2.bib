   Yang, Jingyu; Yue, Zuogong; Yuan, Ye, Huazhong Univ Sci \& Technol, Sch Artificial Intelligence \& Automation, Wuhan 430074, Peoples R China.},
DOI = {10.1109/TII.2022.3200428},
Keywords = {Monitoring; Uncertainty; Training; Reliability; Machinery; Gaussian
   processes; Bayes methods; Explainable artificial intelligence; machinery
   health monitoring; reliability; sparse Gaussian processes},
