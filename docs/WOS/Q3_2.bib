   Grill, R., Urol Klin 3 LF UK \& FNKV, Prague, Czech Republic.
   Baca, V., Ustav Anat 3 LF UK, Prague, Czech Republic.},
Keywords = {pelvic ring fractures; surgical treatment; complication; mortality;
   functional outcomes; radiological results},
Keywords-Plus = {INTERNAL-FIXATION; EMERGENCY STABILIZATION; EXTERNAL FIXATION;
   FRACTURES; SCREW; CLASSIFICATION; DISRUPTIONS; DIAGNOSTICS; REDUCTION;
