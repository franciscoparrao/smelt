}

@article{ WOS:000350300400018,
Author = {de Lange-Brokaar, B. J. E. and Ioan-Facsinay, A. and Yusuf, E. and
   Visser, A. W. and Kroon, H. M. and van Osch, G. J. V. M. and Zuurmond,
   A. -M. and Stojanovic-Susulic, V. and Bloem, J. L. and Nelissen, R. G.
   H. H. and Huizinga, T. W. and Kloppenburg, M.},
Title = {Association of Pain in Knee Osteoarthritis With Distinct Patterns of
   Synovitis},
Journal = {ARTHRITIS \& RHEUMATOLOGY},
Year = {2015},
Volume = {67},
Number = {3},
Pages = {733-740},
Month = {MAR},
Abstract = {Objective. To determine possible patterns of synovitis on
   contrast-enhanced magnetic resonance imaging (CE-MRI) and its relation
   to pain and severity in patients with radiographic knee osteoarthritis
   (OA).
   Methods. In total, 86 patients (mean age 62 years, 66\% women, median
   body mass index 29 kg/m(2)) with symptomatic knee OA (Kellgren/Lawrence
   radiographic score 3) were included. T1-weighted,
   gadolinium-chelate-enhanced MRI with fat suppression was used to
   semiquantitatively score the extent of synovitis at 11 knee sites (total
   score range 0-22). Self-reported pain was assessed with 3 standardized
   questionnaires. Principal components analysis (PCA) was used to
   investigate patterns (the location and severity) of synovitis.
   Subsequently, these patterns were assessed for associations with pain
   measures and radiographic severity in adjusted logistic regression
   models.
   Results. Synovitis was observed in 86 patients and was found to be
   generally mild on CE-MRI (median total synovitis score 7, range 0-16).
   The median pain scores were 53 (range 0-96) on the visual analog scale
   for pain, 51.4 (range 2.8-97.2) on the Knee Injury and Osteoarthritis
   Outcome Score (KOOS) for pain, 35 (range 0-75) on the Intermittent and
   Constant Osteoarthritis Pain (ICOAP) score for constant pain, and 40.6
   (range 0-87.5) on the ICOAP score for intermittent pain. PCA resulted in
   extraction of 3 components, explaining 53.4\% of the variance. Component
   1 was characterized by synovitis at 7 sites (mainly medial parapatellar
   involvement) and was associated with scores on the KOOS pain subscale
   and the ICOAP constant pain subscale. Component 2 was characterized by
   synovitis at 4 sites (mainly the site adjacent to the anterior cruciate
   ligament), but was not associated with pain measures or with
   radiographic severity. Component 3, characterized by synovitis at 3
   sites (mainly at the loose body site), was associated with radiographic
   severity.
   Conclusion. Different patterns of synovitis in knee OA were observed.
   The pattern that included several patellar sites was associated with
   pain, whereas other patterns showed no association, suggesting that pain
   perception in patients with knee OA is a localized response.},
Type = {Article},
Affiliation = {Kloppenburg, M (Corresponding Author), Leiden Univ, Med Ctr, Dept Rheumatol, C1-42,Postbus 9600, NL-2300 RC Leiden, Netherlands.
   de Lange-Brokaar, B. J. E.; Ioan-Facsinay, A.; Yusuf, E.; Visser, A. W.; Kroon, H. M.; Bloem, J. L.; Nelissen, R. G. H. H.; Huizinga, T. W.; Kloppenburg, M., Leiden Univ, Med Ctr, NL-2300 RC Leiden, Netherlands.
   van Osch, G. J. V. M., Univ Med Ctr, Erasmus MC, Rotterdam, Netherlands.
   Zuurmond, A. -M., Netherlands Org Appl Sci Res, Leiden, Netherlands.
   Stojanovic-Susulic, V., Janssen Res \& Dev LLC, Spring House, PA USA.},
DOI = {10.1002/art.38965},
Keywords-Plus = {CONTRAST-ENHANCED MRI; SCORING SYSTEM; EFFUSION},
Author-Email = {g.kloppenburg@lumc.nl},
Number-of-Cited-References = {32},
Times-Cited = {64},
Unique-ID = {WOS:000350300400018},
}

@article{ WOS:000272846500036,
Author = {Coussement, Kristof and Benoit, Dries F. and Van den Poel, Dirk},
Title = {Improved marketing decision making in a customer churn prediction
   context using generalized additive models},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2010},
Volume = {37},
Number = {3},
Pages = {2132-2143},
Month = {MAR 15},
Abstract = {Nowadays, companies are investing in a well-considered CRM strategy. One
   of the cornerstones in CRM is customer churn prediction, where one tries
   to predict whether or not a customer will leave the company. This study
   focuses on how to better support marketing decision makers in
   identifying risky customers by using Generalized Additive Models (GAM).
   Compared to Logistic Regression, GAM relaxes the linearity constraint
   which allows for complex non-linear fits to the data. The contributions
   to the literature are three-fold: (i) it is shown that GAM is able to
   improve marketing decision making by better identifying risky customers;
   (ii) it is shown that GAM increases the interpretability of the churn
   model by visualizing the non-linear relationships with customer churn
   identifying a quasi-exponential, a U, an inverted U or a complex trend
   and (iii) marketing managers are able to significantly increase business
   value by applying GAM in this churn prediction context. (C) 2009
   Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Coussement, K (Corresponding Author), Univ Coll HUBrussel, Fac Econ \& Management, Stormstr 2, B-1000 Brussels, Belgium.
   Coussement, Kristof, Univ Coll HUBrussel, Fac Econ \& Management, B-1000 Brussels, Belgium.
   Coussement, Kristof; Benoit, Dries F.; Van den Poel, Dirk, Univ Ghent, Fac Econ \& Business Adm, Dept Mkt, B-9000 Ghent, Belgium.},
DOI = {10.1016/j.eswa.2009.07.029},
Keywords = {Customer Relationship Management (CRM); Churn modeling; Marketing
   decision making; Generalized Additive Models (GAM)},
Keywords-Plus = {ATTRITION; SERVICES},
Author-Email = {Kristof.Coussement@HUBrussel.be
   Dries.Benoit@UGent.be
   Dirk.VandenPoel@UGent.be},
