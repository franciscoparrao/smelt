   Kim, Maeng-Ki, Kongju Natl Univ, Dept Atmospher Sci, Gongju, South Korea.},
DOI = {10.1007/s00477-015-1031-7},
Keywords = {Bayesian spatial regression model; Cross validation; Generalized
   additive model; General linear model; Spatial linear model; Statistical
   spatial interpolation},
Keywords-Plus = {DOWNSCALING MODELS; MAXIMUM-LIKELIHOOD; DAILY TEMPERATURE; SIMULATION;
