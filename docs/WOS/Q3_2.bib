   Nikolaus, Thorsten, Geriatr Ctr, Bethesda Geriatr Clin, D-89073 Ulm, Germany.},
DOI = {10.1007/s11556-014-0137-0},
Keywords = {Geriatric assessment; Inpatient rehabilitation; Psychometric properties;
   Validity; Physical activity},
Keywords-Plus = {OLDER-ADULTS; AMBULATORY SYSTEM; FRAILTY; RECOMMENDATION; ACCELEROMETRY;
