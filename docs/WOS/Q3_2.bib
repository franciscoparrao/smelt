   Tang, Jiao, Chongqing Med Univ, Dept Nursing, Affiliated Hosp 1, Chongqing, Peoples R China.
   Zheng, Zehong, Guizhou Minzu Univ, Engn Training Ctr, Guiyang, Peoples R China.
   Wang, Xiuhong, Guizhou Med Univ, Dept Nursing, Affiliated Hosp, Guiyang, Peoples R China.},
DOI = {10.3389/fped.2022.944067},
Article-Number = {944067},
Keywords = {neurodevelopmental outcomes; weight gain velocity; very low birth weight
