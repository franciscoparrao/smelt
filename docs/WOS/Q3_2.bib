   Shao, Jing; Wang, Qirong, Gen Adm Sport China, Natl Inst Sports Med, Beijing 100029, Peoples R China.
   Zhang, Junfeng (Jim), Duke Univ, Nicholas Sch Environm, Durham, NC 27708 USA.
   Zhang, Junfeng (Jim), Duke Univ, Global Hlth Inst, Durham, NC 27708 USA.
   Zhang, Junfeng (Jim), Duke Kunshan Univ, Kunshan 215316, Peoples R China.},
DOI = {10.1016/j.scitotenv.2024.176415},
