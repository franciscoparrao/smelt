Keywords-Plus = {COMMERCIAL FLOCKS; RISK-FACTORS; ENVIRONMENTAL-FACTORS; PLUMAGE
   CONDITION; HOUSING SYSTEMS; DOMESTIC CHICKS; EGG-PRODUCTION; OPEN-FIELD;
