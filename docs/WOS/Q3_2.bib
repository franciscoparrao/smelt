}

@article{ WOS:000838440800006,
Author = {Albutt, Abigail and Roland, Damian and Lawton, Rebecca and Conner, Mark
   and O'Hara, Jane},
Title = {Capturing Parents' Perspectives of Child Wellness to Support
   Identification of Acutely Unwell Children in the Emergency Department},
Journal = {JOURNAL OF PATIENT SAFETY},
Year = {2022},
Volume = {18},
Number = {5},
Pages = {410-414},
Month = {AUG},
Abstract = {Objective Early signs of serious illness can be difficult to recognize
   in children and a delayed response can result in poor outcomes. Drawing
   on the unique knowledge of parents and carers may improve identification
   of the deteriorating child. However, there is a lack of evidence
   exploring parental perspectives as part of track and trigger systems.
   This study examines the utility of capturing parent-reported child
   wellness, using the Patient Wellness Questionnaire for Pediatrics, to
   support identification of acutely unwell children presenting to the
   Emergency Department. Methods Parent-reported child wellness was
   recorded alongside the Pediatric Observation Priority Score (POPS), a
   multidimensional scoring system akin to a Pediatric Early Warning Score,
   used as part of routine care. Multiple linear regression assessed the
   independent effects of 3 variables (parent-reported child wellness,
   nurse concern, and child age) on POPS and hospital admission. Results
   Data were collected for 407 children. All 3 variables explained a
   statistically significant proportion of variance in POPS (F(3, 403) =
   7.525, P < 0.001, R-2 = 0.053), with parent-reported child wellness (B =
   0.223, SE = 0.054, beta = 0.202, P < 0.001) having the strongest effect.
   Approximately 10\% of the children with no physiological derangement
   were rated as ``very poorly{''} by their parents. Conclusions The
   findings suggest that parents have insight in to the wellness of their
   children that is reflected in the physiological assessment. Some
   parents' perceptions about their child's wellness were not consistent
   with the score captured in the same assessment. More work is needed to
   understand how to use and address parental perspectives and concerns to
   support clinical decision making and the management of acute illness.},
Type = {Article},
Affiliation = {Albutt, A (Corresponding Author), Bradford Royal Infirm, Res Off 2, Yorkshire Qual \& Safety Res Grp, Bradford Inst Hlth Res, Temple Bank House,Duckworth Lane, Bradford BD9 6RJ, W Yorkshire, England.
   Albutt, Abigail; Lawton, Rebecca; O'Hara, Jane, Bradford Royal Infirm, Bradford Inst Hlth Res, Yorkshire Qual \& Safety Res Grp, Bradford, W Yorkshire, England.
   Roland, Damian, Leicester Royal Infirm, Paediat Emergency Med Leicester Acad PEMLA Grp, Childrens Emergency Dept, Leicester, Leics, England.
   Roland, Damian, Univ Leicester, SAPPHIRE Grp, Leicester, Leics, England.
   Lawton, Rebecca; Conner, Mark, Univ Leeds, Sch Psychol, Leeds, W Yorkshire, England.
   O'Hara, Jane, Univ Leeds, Sch Healthcare, Leeds, W Yorkshire, England.},
DOI = {10.1097/PTS.0000000000000949},
Keywords = {pediatric emergency department; patient deterioration; patient and
   family involvement},
Keywords-Plus = {FAMILIES},
Author-Email = {Abigail.albutt@bthft.nhs.uk},
