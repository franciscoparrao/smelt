   Morgenstern, Lewis B.; Lisabeth, Lynda D., Univ Michigan, Sch Publ Hlth, Dept Epidemiol, Ann Arbor, MI 48109 USA.
   Fletcher, Jeffrey J.; Morgenstern, Lewis B., Univ Michigan, Sch Med, Dept Neurosurg, Ann Arbor, MI 48109 USA.},
DOI = {10.1007/s12028-012-9770-5},
Keywords = {Intracerebral hemorrhage; Acute ischemic stroke; Mexican Americans;
   Intensive care unit},
Keywords-Plus = {OF-LIFE CARE; BRAIN ATTACK SURVEILLANCE; ACUTE ISCHEMIC-STROKE;
   INTRACEREBRAL HEMORRHAGE; ADVANCE DIRECTIVES; HYPERGLYCEMIA; RACE;
   DISPARITIES; MORTALITY; SURVIVAL},
