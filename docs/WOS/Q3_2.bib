   Sutter, Raoul; De Marchis, Gian Marco; Hunziker, Sabina; Ruegg, Stephan; Marsch, Stephan, Univ Basel, Fac Med, Basel, Switzerland.
   Kaplan, Peter W., Johns Hopkins Bayview Med Ctr, Dept Neurol, Baltimore, MD 21224 USA.},
DOI = {10.1212/WNL.0000000000007365},
