   UNIV GRONINGEN, CTR COMP, 9700 AB GRONINGEN, NETHERLANDS.},
DOI = {10.1111/j.1600-0528.1992.tb01711.x},
Keywords = {DECISION MAKING; BEHAVIORAL DENTAL SCIENCE; RADIOGRAPHY, ORAL},
Keywords-Plus = {APPROXIMAL CARIOUS LESIONS; DIAGNOSIS},
Number-of-Cited-References = {34},
Times-Cited = {40},
