@article{ WOS:000279785900003,
Author = {Jackson, Lawrence S. and Forster, Piers M.},
Title = {An Empirical Study of Geographic and Seasonal Variations in Diurnal
   Temperature Range},
Journal = {JOURNAL OF CLIMATE},
Year = {2010},
Volume = {23},
Number = {12},
Pages = {3205-3221},
Month = {JUN 15},
Abstract = {The diurnal temperature range (DTR) of surface air over land varies
   geographically and seasonally. The authors have investigated these
   variations using generalized additive models (GAMs), a nonlinear
   regression methodology. With DTR as the response variable,
   meteorological and land surface parameters were treated as explanatory
   variables. Regression curves related the deviation of DTR from its mean
   value to values of the meteorological and land surface variables. Cloud
   cover, soil moisture, distance inland, solar radiation, and elevation
   were combined as explanatory variables in an ensemble of 84 GAM models
   that used data grouped into seven vegetation types and 12 months. The
   ensemble explained 80\% of the geographical and seasonal variation in
   DTR. Vegetation type and cloud cover exhibited the strongest
   relationships with DTR. Shortwave radiation, distance inland, and
   elevation were positively correlated with DTR, whereas cloud cover and
   soil moisture were negatively correlated. A separate analysis of the
   surface energy budget showed that changes in net longwave radiation
   represented the effects of solar and hydrological variation on DTR. It
   is found that vegetation and its associated climate is important for DTR
   variation in addition to the climatic influence of cloud cover, soil
   moisture, and solar radiation. It is also found that surface net
   longwave radiation is a powerful diagnostic of DTR variation, explaining
   over 95\% of the seasonal variation of DTR in tropical regions.},
Type = {Article},
Affiliation = {Jackson, LS (Corresponding Author), Univ Leeds, Sch Earth \& Environm, Leeds LS2 9JT, W Yorkshire, England.
   Jackson, Lawrence S.; Forster, Piers M., Univ Leeds, Sch Earth \& Environm, Leeds LS2 9JT, W Yorkshire, England.},
DOI = {10.1175/2010JCLI3215.1},
Keywords-Plus = {SOIL-MOISTURE; LAND-COVER; TRENDS; IMPACT; PRECIPITATION; VEGETATION;
   AEROSOL; CLOUDS},
Author-Email = {eelsj@leeds.ac.uk},
Number-of-Cited-References = {43},
Times-Cited = {33},
Unique-ID = {WOS:000279785900003},
}

@article{ WOS:000230308200006,
Author = {de Lima, MLC and Ximenes, RAD and de Souza, ER and Luna, CF and de
   Albuquerque, MDFPM},
Title = {Spatial analysis of socioeconomic determinants of homicide in Brazil},
Journal = {REVISTA DE SAUDE PUBLICA},
Year = {2005},
Volume = {39},
Number = {2},
Pages = {176-182},
Month = {APR},
Abstract = {Objective: To investigate the association between homicide rates and
   socio-economic variables taking into account the spatial site of the
   indicators.
   Methods: An ecological study was conducted. The dependent variable was
   the rate of homicides among the male population aged 15 to 49 years,
   residing in the districts of the State of Pernambuco from 1995 to 1998.
   The independent variables were all index of the living conditions, per
   capita family income, Theil inequality index, Gini index, average income
   of the head of the family, poverty index, rate of illiteracy, and
   demographic density. The following techniques were used in the analysis:
   a spatial autocorrelation test determined by the Moran index, multiple
   linear regression, a spatial regression model (CAR) and a generalized
   additive model for the detection of spatial trend (LOESS).
   Results: The illiteracy and the poverty index explained 24.6\% of the
   total variability of the homicide rates and there was an inverse
   relationship. Moran's I statistics indicated spatial autocorrelation
   between municipalities. The multiple linear regression model best fitted
   for the purposes of this study was the Conditional Auto Regressive (CAR)
   model. The latter confirmed the association between the poverty index,
   illiteracy and homicide rates.
   Conclusions: The inverse association observed between socio-economic
   indicators and homicides may be expressing a process that propitiates
   improvement in living conditions and that is linked predominantly to
   conditions that generate violence, such as drug traffic.},
Type = {Article},
Affiliation = {de Lima, MLC (Corresponding Author), R Frei Jaboatao,280 Apto 604 Bloco P Torre, BR-50710030 Recife, PE, Brazil.
   Univ Pernambuco, Fac Ciencias Med, Recife, PE, Brazil.
   Escola Nacl Saude Publica, Ctr Latino Amer Estudos Violencia \& Saude Jorge C, Fundacao Oswaldo Cruz, Rio De Janeiro, RJ, Brazil.
   Fundacao Oswaldo Cruz, Ctr Pesquisas Aggeu Magalhaes, Recife, PE, Brazil.},
DOI = {10.1590/S0034-89102005000200006},
Keywords = {homicide; residence characteristics; socioeconomicfactors; spatial
   analysis},
Keywords-Plus = {RATES; LIFE},
Author-Email = {luiza@cpqam.fiocruz.br},
Number-of-Cited-References = {20},
