@article{ WOS:000719484500001,
Author = {Matsumoto, Takuji and Yamada, Yuji},
Title = {Comprehensive and Comparative Analysis of GAM-Based PV Power Forecasting
   Models Using Multidimensional Tensor Product Splines against Machine
   Learning Techniques},
Journal = {ENERGIES},
Year = {2021},
Volume = {14},
Number = {21},
Month = {NOV},
Abstract = {In recent years, as photovoltaic (PV) power generation has rapidly
   increased on a global scale, there is a growing need for a highly
   accurate power generation forecasting model that is easy to implement
   for a wide range of electric utilities. Against this background, this
   study proposes a PV power forecasting model based on the generalized
   additive model (GAM) and compares its forecasting accuracy with four
   popular machine learning methods: k-nearest neighbor, artificial neural
   networks, support vector regression, and random forest. The empirical
   analysis provides an intuitive interpretation of the multidimensional
   smooth trends estimated by the GAM as tensor product splines and
   confirms the validity of the proposed modeling structure. The
   effectiveness of GAM is particularly evident in trend completion for
   missing data, where it is able to flexibly express the tangled trend
   structure inherent in time series data, and thus has an advantage not
   only in interpretability but also in improving forecast accuracy.},
Type = {Article},
Affiliation = {Matsumoto, T (Corresponding Author), Cent Res Inst Elect Power Ind, Socioecon Res Ctr, Chiyoda Ku, Tokyo 1008126, Japan.
   Yamada, Y (Corresponding Author), Univ Tsukuba, Fac Business Sci, Bunkyo Ku, Tokyo 1120012, Japan.
   Matsumoto, Takuji, Cent Res Inst Elect Power Ind, Socioecon Res Ctr, Chiyoda Ku, Tokyo 1008126, Japan.
   Yamada, Yuji, Univ Tsukuba, Fac Business Sci, Bunkyo Ku, Tokyo 1120012, Japan.},
DOI = {10.3390/en14217146},
Article-Number = {7146},
Keywords = {forecasting method; machine learning; non-parametric regression;
