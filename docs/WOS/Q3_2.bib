   Manuel Hernandez-Padilla, Jose, Middlesex Univ, Sch Hlth \& Educ, Adult Child \& Midwifery Dept, London, England.},
DOI = {10.1097/DCR.0000000000000877},
Keywords = {Anal fistula; Psychometrics; Quality of life; Reliability; Validity},
Keywords-Plus = {IN-ANO; CROHNS-DISEASE; MANAGEMENT},
Author-Email = {J.Hernandez-Padilla@mdx.ac.uk},
Number-of-Cited-References = {31},
