}

@article{ WOS:001165244000001,
Author = {Wolfe, William W. and Murgulet, Dorina and Gyawali, Bimal and
   Sterba-Boatwright, Blair},
Title = {Modeling time series radon inventory and constraints on the submarine
   groundwater discharge mass balance of a well-mixed, highly dynamic
   estuary},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2023},
Volume = {625},
Number = {B},
Month = {OCT},
Abstract = {Although often diffuse and over-shadowed by surface-water inputs,
   submarine groundwater discharge (SGD) represents a significant source of
   freshwater and solutes to many sensitive marine environments. Radon
   (Rn-222) is an effective naturally occurring tracer of SGD due to its
   non-reactive nature and dominant terrestrial source. However, limited
   continuous measurements and poor constraints on temporal Rn-222
   variability in shallow-turbulent estuaries introduce large uncertainties
   to SGD rate estimation. We hypothesize that nonlinear regression
   analysis (e.g., generalized additive model {[}GAM]) and machine learning
   (ML) algorithms could explain radon trends and resolve limitations of
   the traditionally used mass balance for estimating SGD in shallow and
   vertically mixed estuaries, thus enabling preliminary insights related
   to wind-driven mixing losses using sporadic groundwater tracer
   measurements and publicly available hydroclimatic parameters.
   Cross-correlation functions and a generalized additive model {[}GAM]
   were employed to quantify atmospheric and hydrologic controls and
   predict, respectively, Rn-222 inventory variability modulated by
   windspeed and direction. Two ML models, neural network (deep-learning
   neural network {[}DNN]) and decision tree (random forest {[}RF]) based
   models, were trained on an intermittent 24-month Rn-222 (n = 10,660, 30
   min interval) dataset (2019-2021) collected from a well-mixed
   northwestern Gulf of Mexico estuary (Corpus Christi Bay, Texas) with
   publicly available inputs (e.g., windspeed/direction, tide levels, water
   temperature, creek discharge and barometric pressure, n = 35,088). Both
   ML models can predict observed radon concentrations with r(2) > 0.90,
   however, only the RF model is able to predict within the observed range
   of the Rn-222 magnitude dataset and finds the relevant hydroclimatic
   parameters (e.g., streamflow and wind direction) highly responsible for
   the seasonal and daily variability in the inventory, respectively. The
   DNN model can more closely predict extremely high inventories, but it
   overpredicts lows, resulting in numerous negative values, which suggests
   that large data gaps in the groundwater tracer cause overfitting and
   underperformance of this model in a wind-mixed estuary. Using the GAM
   predicted Rn-222 dependency on wind direction and speed, the adjusted
   mass balance reduces overestimation of wind-mixing losses and results in
   overall lower fluxes. This research provides new opportunities to: 1)
   predict radon inventories in regions with large temporal data gaps using
   only publicly available hydroclimatic parameters and 2) better constrain
   SGD estimates in windy coastal areas, allowing for insights that can be
   used to plan field excursions and management strategies for coastal
   water and solute budgets.},
Type = {Article},
Affiliation = {Murgulet, D (Corresponding Author), Texas A\&M Univ Corpus Christi, Ctr Water Supply Studies, Corpus Christi, TX 78412 USA.
   Wolfe, William W.; Murgulet, Dorina; Gyawali, Bimal, Texas A\&M Univ Corpus Christi, Ctr Water Supply Studies, Corpus Christi, TX 78412 USA.
   Gyawali, Bimal, Univ Houston, Dept Earth \& Atmospher Sci, Houston, TX USA.
   Sterba-Boatwright, Blair, Texas A\&M Univ Corpus Christi, Dept Math \& Stat, Corpus Christi, TX USA.},
DOI = {10.1016/j.jhydrol.2023.130065},
Article-Number = {130065},
Keywords = {Time series modeling; Radon inventory; Corpus Christi Bay; Machine
   learning for radon prediction; Gap filling},
Keywords-Plus = {MACHINE LEARNING-METHODS; CONTINUOUS RN-222; NUTRIENT INPUTS; COASTAL
   ZONE; DAYA BAY; RIVER; SGD; QUANTIFICATION; VULNERABILITY; INFILTRATION},
Author-Email = {dorina.murgulet@tamucc.edu},
