   Ampountolas, Apostolos, Boston Univ, Sch Hospitality Adm, 928 Commonwealth Ave, Boston, MA 02215 USA.
   Chiodi, Marcello, Univ Palermo, Viale Sci Ed 13, Palermo, Italy.},
DOI = {10.1016/j.annals.2026.104150},
Article-Number = {104150},
Keywords = {Climate change; Tourism resilience; Segmented regression; Extreme
   weather events; Hotel demand; Tourism adaptation},
Keywords-Plus = {RESILIENCE; MANAGEMENT; DISASTERS},
