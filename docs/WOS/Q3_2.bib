@article{ WOS:001081149700001,
Author = {Bosschieter, Tomas M. and Xu, Zifei and Lan, Hui and Lengerich, Benjamin
   J. and Nori, Harsha and Painter, Ian and Souter, Vivienne and Caruana,
   Rich},
Title = {Interpretable Predictive Models to Understand Risk Factors for Maternal
   and Fetal Outcomes},
Journal = {JOURNAL OF HEALTHCARE INFORMATICS RESEARCH},
Year = {2024},
Volume = {8},
Number = {1},
Pages = {65-87},
Month = {MAR},
Abstract = {Although most pregnancies result in a good outcome, complications are
   not uncommon and can be associated with serious implications for mothers
   and babies. Predictive modeling has the potential to improve outcomes
   through a better understanding of risk factors, heightened surveillance
   for high-risk patients, and more timely and appropriate interventions,
   thereby helping obstetricians deliver better care. We identify and study
   the most important risk factors for four types of pregnancy
   complications: (i) severe maternal morbidity, (ii) shoulder dystocia,
   (iii) preterm preeclampsia, and (iv) antepartum stillbirth. We use an
   Explainable Boosting Machine (EBM), a high-accuracy glass-box learning
   method, for the prediction and identification of important risk factors.
   We undertake external validation and perform an extensive robustness
   analysis of the EBM models. EBMs match the accuracy of other black-box
   ML methods, such as deep neural networks and random forests, and
   outperform logistic regression, while being more interpretable. EBMs
   prove to be robust. The interpretability of the EBM models reveal
   surprising insights into the features contributing to risk (e.g.,
   maternal height is the second most important feature for shoulder
   dystocia) and may have potential for clinical application in the
   prediction and prevention of serious complications in pregnancy.},
Type = {Article},
Affiliation = {Bosschieter, TM (Corresponding Author), Stanford Univ, Stanford, CA 94305 USA.
   Caruana, R (Corresponding Author), Microsoft Res, Redmond, WA 98052 USA.
   Souter, V (Corresponding Author), Fdn Healthcare Qual, Seattle, WA 98104 USA.
   Bosschieter, Tomas M.; Xu, Zifei; Lan, Hui, Stanford Univ, Stanford, CA 94305 USA.
   Lengerich, Benjamin J., MIT, Cambridge, MA 02139 USA.
   Nori, Harsha; Caruana, Rich, Microsoft Res, Redmond, WA 98052 USA.
   Painter, Ian; Souter, Vivienne, Fdn Healthcare Qual, Seattle, WA 98104 USA.},
DOI = {10.1007/s41666-023-00151-4},
EarlyAccessDate = {OCT 2023},
Keywords = {Interpretability; Explainable models; AI for healthcare; Pregnancy
   complications; Stillbirth; Preeclampsia},
Author-Email = {tomasbos@stanford.edu
   vsouter@qualityhealth.org
   rcaruana@microsoft.com},
Number-of-Cited-References = {46},
Times-Cited = {8},
