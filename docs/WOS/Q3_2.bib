   van Koningsveld, Rinske, Elkerliek Ziekenhuis, Dept Neurol, Helmond, Netherlands.
   Garssen, Marcel J. P., Jeroen Bosch Ziekenhuis, Dept Neurol, Shertogenbosch, Netherlands.
   Jacobs, Bart C., Erasmus MC, Dept Immunol, NL-3000 CA Rotterdam, Netherlands.},
DOI = {10.1002/ana.21976},
Keywords-Plus = {MECHANICAL VENTILATION; CLINICAL-FEATURES; FAILURE; MORBIDITY; TRIAL},
Author-Email = {b.jacobs@erasmusmc.nl},
Number-of-Cited-References = {32},
