DOI = {10.1016/j.hjc.2024.08.003},
EarlyAccessDate = {FEB 2025},
Keywords = {Interpretable machine; learning; Kawasaki disease; Early diagnosis;
   Clinical decision; Electroni cal medical record},
Keywords-Plus = {DECISION TREE; PREDICTION; IMPUTATION},
