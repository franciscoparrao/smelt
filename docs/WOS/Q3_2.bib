   Mardan, Lamiya, Adnan Menderes Univ, Fac Med, Deparment Med Genet, Aydin, Turkey.},
DOI = {10.1016/j.repbio.2019.12.006},
Keywords = {Heteromorphism; Chromosome; Infertility; Recurrent miscarriage;
   Recurrent implantation failure},
