Keywords = {COVID-19; Mortality prediction; Resource-limited settings; Scoring
   system; Clinical decision-making},
Keywords-Plus = {IN-HOSPITAL MORTALITY; PERFORMANCE; CONFLICT; SYSTEMS; SYRIA; CARE},
