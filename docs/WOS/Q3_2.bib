@article{ WOS:000852879100021,
Author = {Tham, See Wan and Rollins, Michael D. and Reeder, Ron W. and Lewis,
   Katelyn E. and Calkins, Casey M. and Avansino, Jeffrey R. and Palermo,
   Tonya M.},
Title = {Health-related quality of life in children with Hirschsprung disease and
   children with functional constipation: Parent-child variability},
Journal = {JOURNAL OF PEDIATRIC SURGERY},
Year = {2022},
Volume = {57},
Number = {8},
Pages = {1694-1700},
Month = {AUG},
Abstract = {Background: Health-related quality of life (HRQOL) is an important
   outcome among children with Hirschsprung Disease (HD), but there are
   challenges in interpreting findings in previous studies owing to the
   choice of a comparator group and informant. We compared parent-proxy
   versus child self-report HRQOL in children with HD to children with
   functional constipation (FC) and examined predictors of HRQOL.
   Methods: Data of 126 children (5-18 years, 60.3\% male, HD: n = 52, FC:
   n = 74) were acquired from the Pediatric Colorectal and Pelvic Learning
   Consortium. Demographics, clinical variables, HRQOL (Pediatric Quality
   of Life Inventory parent-proxy; child self-report) and functional
   outcomes (Baylor Continence Scale, Cleveland Clinic Constipation Scoring
   System) were collected.
   Results: Parent and child HRQOL was similar for both cohorts, with
   higher scores on physical functioning and lower scores on emotional and
   school functioning. For children with HD, demographics and clinical
   variables did not predict HRQOL in multivariable regression models. For
   children with FC, greater severity of constipation predicted lower HRQOL
   (parent-proxy: B = -2.14, p < 0.001; child: B = -1.75, p = 0.001).
   Parent-child agreement on HRQOL scores was poor to moderate in the HD
   group (intraclass correlations (ICC)=0.38-0.74), but moderate to
   excellent in the FC group (ICC=0.63-0.84). Furthermore, parents of
   children with FC and = 10 years overestimated children's HRQOL
   (proportional OR 4.59 (1.63, 13.85); p = 0.004).
   Conclusion: Clinical symptoms and demographic factors did not predict
   HRQOL among children with HD, highlighting the need to examine other
   biopsychosocial factors to understand long term HRQOL. Low parent-child
   HRQOL agreement in children with HD demonstrates the importance of
   obtaining parent and child perspectives. (C) 2022 Elsevier Inc. All
   rights reserved.},
Type = {Review},
Affiliation = {Tham, SW (Corresponding Author), Seattle Childrens Res Inst, MS CURE 3,POB 5371, Seattle, WA 98145 USA.
   Tham, See Wan; Palermo, Tonya M., Univ Washington, Sch Med, Dept Anesthesiol \& Pain Med, Seattle, WA USA.
   Tham, See Wan; Palermo, Tonya M., Seattle Childrens Res Inst, MS CURE 3,POB 5371, Seattle, WA 98145 USA.
   Rollins, Michael D., Univ Utah, Salt Lake City, UT USA.
   Rollins, Michael D., Pimary Childrens Hosp, Div Pediat Surg, Salt Lake City, UT USA.
   Reeder, Ron W.; Lewis, Katelyn E., Univ Utah, Div Pediat Crit Care, Salt Lake City, UT USA.
   Calkins, Casey M., Childrens Hosp Wisconsin, Div Pediat Surg, Milwaukee, WI 53201 USA.
   Avansino, Jeffrey R., Univ Washington, Sch Med, Dept Surg, Div Pediat Gen \& Thorac Surg, Seattle, WA 98195 USA.},
DOI = {10.1016/j.jpedsurg.2022.04.009},
