   Lepeule, Johanna; Robert, Celine; Valette, Jean-Paul; Jacquet, Sandrine; Denoix, Jean-Marie, INRA, USC BPLC 957, F-94700 Maisons Alfort, France.
   Lepeule, Johanna; Robert, Celine; Valette, Jean-Paul, Univ Paris Est, Ecole Natl Vet Alfort, USC BPLC 957, F-94700 Maisons Alfort, France.
   Lepeule, Johanna, Harvard Univ, Sch Publ Hlth, Dept Environm Hlth, Boston, MA 02115 USA.
   Jacquet, Sandrine; Denoix, Jean-Marie, Univ Paris Est, Ecole Natl Vet Alfort, CIRALE, F-14430 Goustranville, France.},
DOI = {10.1016/j.tvjl.2013.03.041},
Keywords = {Horse; Joint; Radiograph; Scoring system; Repeatability},
Keywords-Plus = {THOROUGHBRED YEARLINGS; HIGH AGREEMENT; LOW KAPPA; PREVALENCE;
   OSTEOCHONDROSIS; RELIABILITY; FOALS},
Author-Email = {jlepeule@hsph.harvard.edu},
