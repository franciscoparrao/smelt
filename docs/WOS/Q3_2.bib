   Jimenez-Rueda, Alba, Univ Barcelona, Fac Biol, Barcelona, Spain.
   Miljkovic, Milos, Cartesian Therapeut, Gaithersburg, MD USA.},
DOI = {10.1080/10408363.2022.2114418},
EarlyAccessDate = {SEP 2022},
Keywords = {CLL; flow cytometry; score; classification; lymphoproliferative disorder},
Keywords-Plus = {CHRONIC LYMPHOCYTIC-LEUKEMIA; DIFFERENTIAL-DIAGNOSIS; SCORING SYSTEM;
   CELL LYMPHOMA; TREE APPROACH; B-CELLS; EXPRESSION; CD200; BLOOD; CD43},
Author-Email = {msorigue@iconcologia.net},
