   Jassem, Manaf, Damascus Hosp, Dept Internal Med, Minist Hlth, Damascus, Syria.
   Alsoudi, Rahaf, Damascus Univ, Fac Med, Dept Oncol, Damascus, Syria.},
DOI = {10.1186/s12879-025-11870-x},
