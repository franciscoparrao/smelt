   CTR DIS CONTROL \& PREVENT,NIOSH,DIV RESP DIS STUDIES,MORGANTOWN,WV.
   CONSOLIDATED EDISON,NEW YORK,NY.},
DOI = {10.1097/00043764-199601000-00016},
Keywords-Plus = {INDUCED PLEURAL FIBROSIS; RESTRICTIVE LUNG-FUNCTION; NONSMOKING
   INDIVIDUALS; BRONCHOALVEOLAR LAVAGE; PULMONARY-FUNCTION;
   CIGARETTE-SMOKING; DISEASE; CT; ABNORMALITIES; RADIOGRAPHY},
