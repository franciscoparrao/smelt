   Joffe, Erel; Oster, Howard S.; Kirgner, Ilya; Raanani, Pia; Avivi, Irit; Man-El, Gili; Mittelman, Moshe, Tel Aviv Univ, Sackler Med Sch, Tel Aviv, Israel.
   Filanovsky, Kalman, Kaplan Med Ctr, Rehovot, Israel.
   Filanovsky, Kalman, Hadassah Med Sch, Jerusalem, Israel.
   Oster, Howard S.; Kirgner, Ilya; Avivi, Irit; Mittelman, Moshe, Tel Aviv Sourasky Med Ctr, Tel Aviv, Israel.},
DOI = {10.1111/ejh.13134},
Keywords = {bone marrow cellularity; bone marrow failure; MDS; myelodysplastic
