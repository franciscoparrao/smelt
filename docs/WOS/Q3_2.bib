Unique-ID = {WOS:000543343800001},
}

@article{ WOS:000524752700043,
Author = {Wang, Yuxue and Wang, Songjiao and Zhang, Jun and Zhang, Maona and
   Zhang, Hong and Gong, Guofu and Luo, Min and Wang, Teng and Mao, Xiaolu},
Title = {Salusin-β is superior to salusin-α as a marker for evaluating coronary
   atherosclerosis},
Journal = {JOURNAL OF INTERNATIONAL MEDICAL RESEARCH},
Year = {2020},
Volume = {48},
Number = {2},
Month = {FEB},
Abstract = {Objective
   This study was performed to evaluate the interaction effect of
   salusin-alpha and salusin-beta on coronary artery injury or stenosis.
   Methods
   The salusin-alpha and salusin-beta concentrations were measured by
   enzyme-linked immunosorbent assay in 256 patients who underwent coronary
   angiography for chest pain, and coronary artery stenosis was assessed by
   the SYNTAX scoring system. Multivariate logistic regression was used to
   analyze the correlation between variables and coronary artery stenosis.
   The interaction of salusin-alpha and salusin-beta on coronary artery
   stenosis was further explored by multiple linear regression.
   Results
   The model goodness of fit (R) for the interaction effect of
   salusin-alpha and salusin-beta on coronary artery stenosis was 0.863,
   and the adjusted R value revealed that the interaction could explain
   74.3\% of the variation in SYNTAX scores. The F-statistic exceeded
   F-0.05 (3.031485935) and P < 0.001, further showing that salusin-alpha
   and salusin-beta had a significant interaction effect on coronary artery
   stenosis. The standard coefficient for salusin-beta (0.797) was higher
   than that for salusin-alpha (-0.367, indicating an inhibitory effect),
   showing that salusin-beta had a greater effect on coronary artery
   stenosis.
   Conclusions
   Salusin-beta, a potential marker for assessing coronary atherosclerosis,
   was superior to salusin-alpha, contributing to our understanding of the
   etiology of coronary artery stenosis.},
Type = {Article},
Affiliation = {Mao, XL (Corresponding Author), Huazhong Univ Sci \& Technol, Tongji Med Coll, Cent Hosp Wuhan, Dept Clin Lab, 26 Shengli St, Wuhan 430014, Peoples R China.
   Wang, Yuxue; Wang, Songjiao; Luo, Min, Hubei Univ Chinese Med, Dept Lab Med, Wuhan, Peoples R China.
   Zhang, Jun; Zhang, Maona; Zhang, Hong, Wuhan Univ, Peoples Hosp, Ezhou Hosp, Dept Pathol, Ezhou, Peoples R China.
   Gong, Guofu, Wuhan Univ, Ezhou Hosp, Peoples Hosp, Dept Clin Lab, Ezhou, Peoples R China.
   Wang, Teng, Wuhan Univ, Renmin Hosp, Dept Cardiol, Wuhan, Peoples R China.
