   Abbate, Carlo; Trimarchi, Pietro Davide; Giunco, Fabrizio, IRCCS Fdn Don Carlo Gnocchi, Via Capecelatro 66, I-20148 Milan, Italy.},
DOI = {10.1016/j.eswa.2022.119226},
EarlyAccessDate = {NOV 2022},
