   Chien, Kuo-Liong, Natl Taiwan Univ, Coll Publ Hlth, Inst Prevent Med, Taipei 100, Taiwan.
   Tsai, Yuh-Show, Chung Yuan Christian Univ, Dept Biomed Engn, Chungli 32023, Taiwan.
   Wu, Yuh-Ming, Natl Taiwan Univ Hosp, Dept Biomed Engn, Taipei 100, Taiwan.},
DOI = {10.1186/1475-925X-9-3},
Article-Number = {3},
Keywords-Plus = {THERMOGRAPHY; CANCER},
