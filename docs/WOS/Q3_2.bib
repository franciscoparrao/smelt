   Javidi, Giti, Univ S Florida, Muma Coll Business, Dept Informat Syst \& Management, 8350 N Tamiami Trail,C251, Sarasota, FL 34243 USA.},
DOI = {10.1016/j.dss.2024.114308},
EarlyAccessDate = {SEP 2024},
Article-Number = {114308},
Keywords = {Cybersecurity; CVE; CVSS; Machine learning; Situational awareness},
