Times-Cited = {140},
Unique-ID = {WOS:A1994NV15100017},
}

@article{ WOS:001157101600001,
Author = {Saba, Luca and Cau, Riccardo and Murgia, Alessandro and Nicolaides,
   Andrew N. and Wintermark, Max and Castillo, Mauricio and Staub, Daniel
   and Kakkos, Stavros K. and Yang, Qi and Paraskevas, Kosmas I. and Yuan,
   Chun and Edjlali, Myriam and San Filippo, Roberto and Hendrikse, Jeroen
   and Johansson, Elias and Mossa-Basha, Mahmud and Balu, Niranjan and
   Dichgans, Martin and Saloner, David and Bos, Daniel and Jager, H. Rolf
   and Naylor, Ross and Faa, Gavino and Suri, Jasjit S. and Costello,
   Justin and Auer, Dorothee P. and McNally, J. Scott and Bonati, Leo H.
   and Nardi, Valentina and Lugt, Aad van der and Griffin, Maura and
   Wasserman, Bruce A. and Kooi, M. Eline and Gillard, Jonathan and
   Lanzino, Giuseppe and Mikhailidis, Dimitri P. and Mandell, Daniel M. and
   Benson, John C. and van Dam-Nolen, Dianne H. K. and Kopczak, Anna and
   Song, Jae W. and Gupta, Ajay and DeMarco, J. Kevin and Chaturvedi,
   Seemant and Virmani, Renu and Hatsukami, Thomas S. and Brown, Martin and
   Moody, Alan R. and Libby, Peter and Schindler, Andreas and Saam, Tobias},
Title = {Carotid Plaque-RADS A Novel Stroke Risk Classification System},
Journal = {JACC-CARDIOVASCULAR IMAGING},
Year = {2024},
Volume = {17},
Number = {1},
Pages = {62-75},
Month = {JAN},
Abstract = {BACKGROUND Carotid artery atherosclerosis is highly prevalent in the
   general population and isa well-established risk factor for acute
   ischemic stroke. Although the morphological characteristics of
   vulnerable plaques are well recognized, there is a lack of consensus in
   reporting and interpreting carotid plaque features. OBJECTIVES The aim
   of this paper is to establish a consistent and comprehensive approach
   for imaging and reporting carotid plaque by introducing the Plaque-RADS
   (Reporting and Data System) score. METHODS A panel of experts recognized
   the necessity to develop a classification system for carotid plaque and
   its defining characteristics. Using a multimodality analysis approach,
   the Plaque -RADS categories were established through consensus, drawing
   on existing published reports. RESULTS The authors present a universal
   classification that is applicable to both researchers and clinicians.
   The PlaqueRADS score offers a morphological assessment in addition to
   the prevailing quantitative parameter of ``stenosis.{''} The Plaque
   -RADS score spans from grade 1 (indicating complete absence of plaque)
   to grade 4 (representing complicated plaque). Accompanying visual
   examples are included to facilitate a clear understanding of the Plaque
   -RADS categories. CONCLUSIONS Plaque -RADS is a standardized and
   reliable system of reporting carotid plaque composition and morphology
   via different imaging modalities, such as ultrasound, computed
   tomography, and magnetic resonance imaging. This scoring system has the
   potential to help in the precise identification of patients who may
   benefit from exclusive medical intervention and those who require
   alternative treatments, thereby enhancing patient care. A standardized
