   Scaife, Courtney; Johnston, W. Cory, Univ Utah, Sch Med, Dept Surg, Salt Lake City, UT 84132 USA.
   Siddiqui, Ali, Thomas Jefferson Univ, Sch Med, Div Gastroenterol \& Hepatol, Philadelphia, PA 19107 USA.},
DOI = {10.1002/dc.22924},
Keywords = {cytology; brushing; ERCP; biliary},
Keywords-Plus = {PRIMARY SCLEROSING CHOLANGITIS; SERUM TUMOR-MARKERS; ENDOSCOPIC
   RETROGRADE CHOLANGIOPANCREATICOGRAPHY; BILE-DUCT STRICTURES; DETECTING
   CHOLANGIOCARCINOMA; CYTOLOGY; DIAGNOSIS; CARCINOMA; TRACT},
