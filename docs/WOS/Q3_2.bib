   Stratigos, Alexander; Liakou, Aikaterini, I, Natl \& Kapodistrian Univ Athens, Andreas Syggros Hosp Skin Dis, Dermatol Dept 1, Athens, Greece.},
DOI = {10.5826/dpc.1404a4566},
