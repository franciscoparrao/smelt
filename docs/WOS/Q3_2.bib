   Rios, Jose, Univ Autonoma Barcelona, Biostat Unit, Fac Med, Bellaterra, Spain.
   Torner, Pere, Univ Autonoma Barcelona, Hosp Univ Parc Tauli, Barcelona, Spain.},
DOI = {10.1007/s00167-020-06225-9},
EarlyAccessDate = {OCT 2020},
