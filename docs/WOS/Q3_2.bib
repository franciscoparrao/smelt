   Bai, Yating, Jilin Univ, Sch Econ, Changchun, Peoples R China.
   Zhu, Hongyu, Univ Macau, Fac Business Adm, Taipa, Macau, Peoples R China.},
DOI = {10.1108/MD-10-2024-2258},
EarlyAccessDate = {DEC 2025},
Keywords = {Heavily polluting enterprises; Firms' digital orientation (DO); ESG
   performance; Inverted U-shaped relationship},
