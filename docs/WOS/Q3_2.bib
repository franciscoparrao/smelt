@article{ WOS:001695980900004,
Author = {Dumaev, R. I. and Molodyakov, S. A. and Utkin, L. V.},
Title = {A Model for the Explainable Malignancy Assessment of Pulmonary Nodules
   on CT Images},
Journal = {SCIENTIFIC AND TECHNICAL INFORMATION PROCESSING},
Year = {2025},
Volume = {52},
Number = {6},
Pages = {760-768},
Month = {DEC},
Abstract = {To increase the transparency of modern computer-aided diagnosis (CAD)
   systems for assessing the malignancy of lung nodules, an interpretable
   model based on the application of generalized additive models and
   concept-based learning is proposed. This model detects a set of
   clinically significant attributes in addition to a final malignancy
   regression score and learns the association between the attributes of
   lung nodules and a final diagnosis decision, as well as their
   contributions into the decision. The proposed concept-based learning
   framework provides human-readable explanations in terms of different
   concepts (numerical and categorical), their values, and their
   contribution to the final prediction. Numerical experiments with the
   LIDC-IDRI dataset demonstrate that the diagnosis results obtained using
   the proposed model, which explicitly explores internal relationships,
   are in line with similar patterns observed in clinical practice.
   Additionally, the proposed model shows the competitive classification
   and the nodule attribute scoring performance, highlighting its potential
   for effective decision-making in the lung nodule diagnosis.},
Type = {Article},
Affiliation = {Dumaev, RI (Corresponding Author), Peter Great St Petersburg Polytech Univ, St Petersburg, Russia.
   Dumaev, R. I.; Molodyakov, S. A.; Utkin, L. V., Peter Great St Petersburg Polytech Univ, St Petersburg, Russia.},
DOI = {10.3103/S0147688225700637},
Keywords = {explainable artificial intelligence; medical image processing; pulmonary
   nodules; generalized additive model; neural network; concept-based
   learning},
Keywords-Plus = {LEARNING-MODELS},
Author-Email = {dumaevrinat@gmail.com
   samolodyakov@mail.ru
   lev.utkin@gmail.com},
