   Liu, Hanlin, Shenzhen Univ, Affiliated Hosp 3, Luohu Hosp Grp, Dept Radiol, 47 Youyi Rd, Shenzhen 518000, Peoples R China.},
DOI = {10.21037/qims-23-142},
