EarlyAccessDate = {AUG 2023},
Keywords = {Civil aviation safety; Go-around; Machine learning; Explainable boosting
   machine},
Keywords-Plus = {DECISION-MAKING; AVIATION},
Author-Email = {fengchen@tongji.edu.cn},
