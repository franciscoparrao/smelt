   De Deyn, Peter Paul, Univ Med Ctr Groningen, Dept Neurol, Groningen, Netherlands.
   De Deyn, Peter Paul, Univ Med Ctr Groningen, Alzheimer Ctr, Groningen, Netherlands.
   Biessels, Geert Jan, Univ Med Ctr Utrecht, UMC Utrecht Brain Ctr, Dept Neurol, Utrecht, Netherlands.
   Claassen, Jurgen A. H. R., Radboud Univ Nijmegen, Med Ctr, Nijmegen, Netherlands.
   Middelkoop, Huub A. M., Leiden Univ, Med Ctr, Dept Neurol \& Neuropsychol, Leiden, Netherlands.
   Middelkoop, Huub A. M., Leiden Univ, Inst Psychol, Hlth Med \& Neuropsychol Unit, Leiden, Netherlands.
   van der Flier, Wiesje M., Univ Amsterdam, Med Ctr, VUmc, Amsterdam, Netherlands.
   Ramakers, Inez H. G. B., Maastricht Univ, Med Ctr, Alzheimer Ctr Limburg, Sch Mental Hlth \& Neurosci MHeNS, Maastricht, Netherlands.},
DOI = {10.1007/978-3-031-47401-9\_7},
Keywords = {Alzheimer's disease; MRI; Convolutional neural network; Explainable
   boosting machine; Interpretable AI},
Keywords-Plus = {BRAIN; MRI},
Author-Email = {w.kang@erasmusmc.nl},
