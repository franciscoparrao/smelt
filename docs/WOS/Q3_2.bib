}

@article{ WOS:000364606200003,
Author = {Boe-Hansen, G. B. and Rego, J. P. A. and Crisp, J. M. and Moura, A. A.
   and Nouwens, A. S. and Li, Y. and Venus, B. and Burns, B. M. and
   McGowan, M. R.},
Title = {Seminal plasma proteins and their relationship with percentage of
   morphologically normal sperm in 2-year-old Brahman (Bos indicus)
   bulls},
Journal = {ANIMAL REPRODUCTION SCIENCE},
Year = {2015},
Volume = {162},
Pages = {20-30},
Month = {NOV},
Abstract = {The objective was to determine the relationship between seminal plasma
   proteins and sperm morphology in Bos indicus bulls of the Brahman breed.
   Fifty-six 24-month-old Australian Brahman bulls were electroejaculated
   and samples were examined to determine the percentage of morphologically
   normal sperm (PNS24) and the seminal plasma protein composition was
   identified and quantified by 2-D gel electrophoresis. The total
   integrated optical density of 152 seminal plasma protein spots (SPPs)
   across all gels was determined using the PDQuest software version 8.0
   (Bio Rad, USA). Using a single regression mixed model with the density
   of individual spots as a covariate for PNS24, 17 SPPs were significantly
   associated with PNS24 (p<0.05). A multiple regression analyses of these
   SPPs, using three models; non-parametric Tree Model, Generalized
   Additive Model, and a step-wise selection method were conducted, and 6
   SPPs could be used to predict PNS24; four SPPs had positive and two had
   negative association with PNS24. Together these spots explained 35\% of
   the phenotypic variation in PNS24. Using mass spectrometry (MALDI-ToF
   and TripleToF-MS)the SPPs with positive relationship contained mainly
   apolipoprotein A-I (1310), protein DJ-1 and glutathione peroxidase 3
   (2308), phosphoglycerate kinase 1 (6402) and apolipoprotein A-I and
   secretoglobin family 1D member (8008). The SPPs inversely associated
   with PNS24 were clusterin/seminal plasma protein A3 (1411) and
   epididymal secretory protein El (8108). This is the first comprehensive
   report on the association between seminal plasma protein composition in
   Bos indicus Brahman bulls and sperm morphology. (C) 2015 Elsevier B.V.
   All rights reserved.},
Type = {Article},
Affiliation = {Boe-Hansen, GB (Corresponding Author), Univ Queensland, Sch Vet Sci, St Lucia, Qld, Australia.
   Boe-Hansen, G. B.; Crisp, J. M.; McGowan, M. R., Univ Queensland, Sch Vet Sci, St Lucia, Qld, Australia.
   Rego, J. P. A.; Moura, A. A., Univ Fed Ceara, Dept Anim Sci, Fortaleza, Ceara, Brazil.
   Nouwens, A. S., Univ Queensland, Sch Chem \& Mol Biosci, St Lucia, Qld, Australia.
   Li, Y., CSIRO Agr Flagship, St Lucia, Qld, Australia.
   Venus, B., Univ Queensland, Ctr Anim Sci, Queensland Alliance Agr \& Food Innovat, St Lucia, Qld, Australia.
   Burns, B. M., Queensland Alliance Agr \& Food Innovat, Rockhampton, Qld, Australia.},
DOI = {10.1016/j.anireprosci.2015.09.003},
Keywords = {Seminal plasma proteomics; Sperm morphology; Brahman cattle},
Keywords-Plus = {TESTICULAR VASCULAR CONE; SEX GLAND FLUID; PROTEOMIC ANALYSIS; SEMEN
