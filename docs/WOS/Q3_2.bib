   Lotti, Francesco, Univ Florence, Azienda Osped Univ Carreggi, Female Endocrinol \& Gender Incongruence Unit, Dept Expt \& Clin Biomed Sci Mario Serio,Androl, Florence, Italy.},
DOI = {10.1111/andr.13053},
EarlyAccessDate = {JUN 2021},
Keywords = {classification; infertility; pitfalls; varicocele},
Keywords-Plus = {TESTICULAR VOLUME; VARICOCELE; ULTRASOUND; MEN; ADOLESCENTS; DIAGNOSIS;
   CRITERIA; ADULTS; REFLUX},
