@article{ WOS:000880945100001,
Author = {de Abreu, Rafael Cesario and Hallak, Ricardo and da Rocha, Humberto
   Ribeiro},
Title = {Effects of Local Vegetation and Regional Controls in Near-Surface Air
   Temperature for Southeastern Brazil},
Journal = {ATMOSPHERE},
Year = {2022},
Volume = {13},
Number = {11},
Month = {NOV},
Abstract = {The spatial range of near-surface air temperature average and trends for
   Southeast Brazil in recent decades motivated us to investigate the
   causality of local vegetation and other geophysical controls at the
   regional scale to explain the spatial variability of the average maximum
   and minimum temperature (Tmax and Tmin). We used measurements from 52
   weather stations between 1985 and 2010. Using linear regression, NDVI
   and cloud cover were significant to explain spatial variability of Tmax
   and Tmin. With the Generalized Additive Model (GAM), we improved
   temperature-dependent relationships with regional geophysical controls,
   and local scale NDVI. The modeling of Tmax and Tmin showed non-linear
   and combined relationships with geographical position (lat,lon) jointly
   expressing the effects of zonality and continentality, and NDVI at
   distances of 300 m and 3000 m. For Tmin, geographical position and
   altitude responded with an amplitude of similar or equal to 5 degrees C
   each, and NDVI with similar or equal to 3 degrees C. Similarly, the
   geographical position and altitude were significant for Tmax, with an
   amplitude of similar or equal to 5 degrees C each, and cloud cover with
   similar or equal to 3.5 degrees C. Our findings help to clarify the
   local scale controls of near-surface air temperature and stress the need
   to increase resilience against adversities of global climate change and
   increasing urbanization, by providing metrics to predict the effects of
   nature-based solutions within the urban space.},
Type = {Article},
Affiliation = {de Abreu, RC (Corresponding Author), Inst Astron Geofis \& Ciencias Atmosfer IAG USP, BR-05508090 Sao Paulo, Brazil.
   de Abreu, Rafael Cesario; Hallak, Ricardo; da Rocha, Humberto Ribeiro, Inst Astron Geofis \& Ciencias Atmosfer IAG USP, BR-05508090 Sao Paulo, Brazil.},
DOI = {10.3390/atmos13111758},
Article-Number = {1758},
Keywords = {near-surface air temperature; land cover change; generalized additive
   model; climate change; urban heat island; regional climate; Brazil;
   weather stations},
Keywords-Plus = {URBAN HEAT-ISLAND; SAO-PAULO; LAND-COVER; CLIMATE; SCALE; URBANIZATION;
   HOMOGENEITY; RECORDS; TRENDS; CHINA},
Author-Email = {rafael.abreu@iag.usp.br},
Number-of-Cited-References = {59},
Times-Cited = {2},
Unique-ID = {WOS:000880945100001},
}

@article{ WOS:000831963700001,
Author = {Liu, Jiarong and He, Jingyuan and Chai, Lei and Zhong, Xun and Jia, Bo
   and Wang, Xinjie},
Title = {A Comparison of Models of Stand Volume in Spruce-Fir Mixed Forest in
   Northeast China},
Journal = {FORESTS},
Year = {2022},
Volume = {13},
Number = {7},
Month = {JUL},
Abstract = {Based on a multiple linear regression model, random forest algorithm and
   generalized additive model, a stand volume model was constructed to
   provide a theoretical basis for sustainable management. A total of 224
   fixed plots in the Jingouling forest farm, Wangqing County, Jilin
   Province, were used as data sources. Specifically, 157 plots were used
   as training data, and 77 plots were used as test data. The effects of
   stand structure variables, topography variables, cutting variables,
   diversity variables and climate variables on stand volume were analyzed.
   The random forest algorithm explained 95.51\% of the stand volume, and
   the generalized additive model explained 95.45\% of the stand volume.
   Stand structure variables and topography variables had more influence on
   the stand volume of spruce-fir than other variables. Among the diversity
   variables, the evenness index, Shannon index and Simpson index had a
   relatively greater impact on the stand volume. The cutting times and the
   intensity of the first cutting had a direct relationship with stand
   volume. The influence of climate variables on the stand volume was
   relatively small in the study area.},
Type = {Article},
Affiliation = {Wang, XJ (Corresponding Author), Beijing Forestry Univ, Coll Forestry, Beijing 100091, Peoples R China.
   Liu, Jiarong; He, Jingyuan; Chai, Lei; Zhong, Xun; Jia, Bo; Wang, Xinjie, Beijing Forestry Univ, Coll Forestry, Beijing 100091, Peoples R China.},
