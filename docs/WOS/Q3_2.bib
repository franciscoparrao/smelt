   Victoria Gen Hosp, Halifax, NS B3H 2Y9, Canada.
   Univ Padua, Inst Med Semeiot, I-35100 Padua, Italy.
   Univ Amsterdam, Acad Med Ctr, Ctr Hemostas Thrombos Atheroscleros \& Inflamm Res, NL-1105 AZ Amsterdam, Netherlands.},
Keywords = {impedance plethysmography; phlebography; thrombophlebitis; thrombosis},
Keywords-Plus = {VENOUS THROMBOSIS; COMPRESSION ULTRASONOGRAPHY; OUTPATIENTS; ACCURACY;
   SURGERY; LEG; HIP},
Number-of-Cited-References = {16},
