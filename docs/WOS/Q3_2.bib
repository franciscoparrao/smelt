@article{ WOS:001239466300001,
Author = {Haugen, Ida K. and Felson, David T. and Abhishek, Abhishek and
   Berenbaum, Francis and Bierma-Zeinstra, Sita and Dziedzic, Krysia S. and
   Edwards, John James and Englund, Martin and Hermann-Eriksen, Merete and
