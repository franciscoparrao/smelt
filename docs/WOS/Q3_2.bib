Unique-ID = {WOS:000410650600013},
}

@article{ WOS:000382224800046,
Author = {Pires, Nelson and Joana Fernandes, M. and Gommenginger, Christine and
   Scharroo, Remko},
Title = {A Conceptually Simple Modeling Approach for Jason-1 Sea State Bias
   Correction Based on 3 Parameters Exclusively Derived from Altimetric
   Information},
Journal = {REMOTE SENSING},
Year = {2016},
Volume = {8},
Number = {7},
Month = {JUL},
Abstract = {A conceptually simple formulation is proposed for a new empirical sea
   state bias (SSB) model using information retrieved entirely from
   altimetric data. Nonparametric regression techniques are used, based on
   penalized smoothing splines adjusted to each predictor and then combined
   by a Generalized Additive Model. In addition to the significant wave
   height (SWH) and wind speed (U10), a mediator parameter designed by the
   mean wave period derived from radar altimetry, has proven to improve the
   model performance in explaining some of the SSB variability, especially
   in swell ocean regions with medium-high SWH and low U10. A collinear
   analysis of scaled sea level anomalies (SLA) variance differences shows
   conformity between the proposed model and the established SSB models.
   The new formulation aims to be a fast, reliable and flexible SSB model,
   in line with the well-settled SSB corrections, depending exclusively on
   altimetric information. The suggested method is computationally
   efficient and capable of generating a stable model with a small training
   dataset, a useful feature for forthcoming missions.},
Type = {Article},
Affiliation = {Pires, N (Corresponding Author), Univ Porto, Dept Geosci Environm \& Spatial Planning, Fac Sci, P-4169007 Oporto, Portugal.
   Pires, Nelson; Joana Fernandes, M., Univ Porto, Dept Geosci Environm \& Spatial Planning, Fac Sci, P-4169007 Oporto, Portugal.
   Gommenginger, Christine, NERC, Natl Oceanog Ctr, Southampton SO14 3ZH, Hants, England.
   Scharroo, Remko, European Org Exploitat Meteorol Satellites, D-64295 Darmstadt, Germany.},
DOI = {10.3390/rs8070576},
Article-Number = {576},
Keywords = {satellite altimetry; sea state bias; mean wave period; nonparametric
