   Xiao, Xianming; Feng, Wei; Fan, Linxiao; Xiang, Chenzhu; Wang, Zhili; Hou, Jinping; Liu, Wei; Guo, Zhenhua; Wang, Yi, Chongqing Key Lab Struct Birth Defect \& Reconstru, Chongqing, Peoples R China.
   Zhu, Jin, Chongqing Med Univ, Childrens Hosp, Dept Pathol, Chongqing, Peoples R China.},
DOI = {10.1055/a-2557-8073},
EarlyAccessDate = {APR 2025},
Keywords = {anorectal malformation; Hirschsprung's disease; histopathological
   assessment; barium enema; anaorectal manometry},
Keywords-Plus = {PATHOLOGY; ZONE},
