   Ur Rehman, Mobeen, United Arab Emirates Univ, Coll Informat Technol, Al Ain 17551, Abu Dhabi, U Arab Emirates.
   Won Lee, Seung, Sungkyunkwan Univ, Dept Metabiohlth, Seoul 16419, South Korea.
   Won Lee, Seung, Sungkyunkwan Univ, Sch Med, Personalized Canc Immunotherapy Res Ctr, Suwon 16419, South Korea.
   Won Lee, Seung, Sungkyunkwan Univ, Sch Med, Kangbuk Samsung Hosp, Dept Family Med, 29 Saemunan Ro, Seoul 03181, South Korea.},
DOI = {10.1093/bib/bbag087},
