   Hammami, Raouf, Manouba Univ, Higher Inst Sport \& Phys Educ Ksar Said, Tunis, Tunisia.
   Lyons, Mark, Univ Limerick, Sport \& Human Performance Res Ctr, Limerick, Ireland.},
DOI = {10.1123/pes.2025-0039},
EarlyAccessDate = {NOV 2025},
Keywords = {motor competence; ACL; pediatric injury prevention; screening},
Keywords-Plus = {ANTERIOR CRUCIATE LIGAMENT; ERROR SCORING SYSTEM; SCREENING TOOL; SPORT;
