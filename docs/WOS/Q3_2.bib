}

@article{ WOS:001625244000001,
Author = {Yang, Hao and Qi, Zixuan and Huang, Wei and Li, Bo and Cheng, Guanhui
   and Cai, Yanpeng},
Title = {Evaluating the impact of ``source-sink{''} landscape composition and
   configuration changes on sediment yield in watersheds using a coupled
   multi-model framework},
Journal = {JOURNAL OF CLEANER PRODUCTION},
Year = {2025},
Volume = {534},
Month = {DEC 1},
Abstract = {In recent years, the coupled effects of climate change and human
   activities have significantly altered the sources, transport pathways,
   and total flux of river sediments. Particularly in river basins with
   cascade hydropower plants operating in tandem, as the significant
   reduction in upstream sediment transport, accurately simulating sediment
   yield (SY) from non-point sources becomes critically important for
   sediment regulation in the downstream river systems. This study
   developed the ``source-sink{''} landscape composition and
   configuration-generalized additive model (SSLCC-GAM), which integrated
   the ``source-sink{''} landscape composition and configuration, to
   improve the accuracy of watershed SY simulation. We employed the
   SSLCC-GAM to simulate the variations in SY across the fluctuating
   backwater zone basin (FBZB) of the Three Gorges Reservoir in China from
   1990 to 2020. Additionally, employing explainable machine learning
   techniques (XGBoost and SHAP values), we quantified the relative
   contributions of key driving factors to SY variations. The results
   showed that: (1) In the FBZB, soil erosion (SE) risk gradually
   decreased, with most areas exhibiting a significant downward trend from
   1990 to 2020, with notable increases observed only in localized areas,
   such as the central part of the Dadu River-Minjiang River Basin and the
   northwestern part of the Jinsha River Basin. (2) Based on the
   ``source-sink{''} landscape composition classification system, three
   primary ``source-sink{''} landscape composition types (LCTsink dominated
   by forests and grasslands, LCTsource dominated by cropland and
   construction land, and LCTsource-sink represented a hybrid landscape
   composition type) and eight subtypes were identified. The SE varied
   across different ``source-sink{''} landscape types, following the order:
   LCTsink > LCTsource-sink > LCTsource. Among these, higher patch
   aggregation, greater within-class connectivity, and lower landscape
   diversity of LCT\_32 mitigated SE and reduced SY, whereas changes in the
   LCT\_31 class had the opposite effect; (3) ``Source-sink{''} landscape
   composition and configuration, SE, NDVI, and rainfall collectively
   explained 91.5 \% of SY variations. NDVI (SHAP value: 0.82) and F-source
   (SHAP value: 0.31) were the two most influential contributors to
   variations in SY. After excluding the influence of ``source-sink{''}
   landscape composition in the model, the deviance explained of the
   deviance in SY explained by the remaining variables decreased to 86.4
   \%. This study provides a novel perspective on the impact of landscape
   composition and configuration on SY variations, offering valuable
   guidance for the development of future SY models and improving their
   accuracy.},
Type = {Review},
Affiliation = {Cai, YP (Corresponding Author), Guangdong Univ Technol, Sch Ecol Environm \& Resources, Guangzhou 510006, Peoples R China.
   Yang, Hao; Qi, Zixuan; Cheng, Guanhui; Cai, Yanpeng, Guangdong Univ Technol, Guangdong Basic Res Ctr Excellence Ecol Secur \& Gr, Sch Ecol Environm \& Resources, Guangdong Prov Key Lab Water Qual Improvement \& Ec, Guangzhou 510006, Peoples R China.
   Huang, Wei, China Inst Water Resources \& Hydropower Res, Dept Water Environm, Beijing 100038, Peoples R China.
   Li, Bo, Chongqing Three Gorges Univ, Chongqing Key Lab Water Environm Evolut \& Pollut C, Chongqing 404020, Peoples R China.
   Cai, Yanpeng, Guangdong Univ Technol, Sch Ecol Environm \& Resources, Guangzhou 510006, Peoples R China.},
DOI = {10.1016/j.jclepro.2025.146998},
EarlyAccessDate = {DEC 2025},
Article-Number = {146998},
Keywords = {Fluctuating backwater zone basin; Landscape composition and
   configuration; ``Source-sink{''}, landscape theory; Sediment yield
   modeling; Sediment yield modeling},
Keywords-Plus = {3 GORGES RESERVOIR; LEVEL FLUCTUATION ZONE; SOIL-EROSION; LAND-USE; FLOW
   REGULATION; YANGTZE-RIVER; PATTERNS; MODEL; BASIN; PHOSPHORUS},
Author-Email = {yanpeng.cai@gdut.edu.cn},
