   Gomes, Marilia Brito; Ferreira Campos, Carlos Frederico; Machado-Silva, Lilian; Perez, Renata Mello, Univ Estado Rio De Janeiro, Rio De Janeiro, Brazil.
   Paiva, Fernando Fernandes, Univ Sao Paulo, Inst Phys Sao Carlos, Sao Carlos, SP, Brazil.
   Lanzoni, Valeria, Univ Fed Sao Paulo, Sao Paulo, Brazil.},
DOI = {10.1111/jgh.13903},
Keywords = {liver biopsy; non-alcoholic fatty liver disease; preperitoneal fat;
   steatohepatitis; type 2 diabetes},
