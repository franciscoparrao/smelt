}

@article{ WOS:000461395300007,
Author = {Bras-Geraldes, Carlos and Papoila, Ana and Xufre, Patricia},
Title = {Generalized additive neural network with flexible parametric link
   function: model estimation using simulated and real clinical data},
Journal = {NEURAL COMPUTING \& APPLICATIONS},
Year = {2019},
Volume = {31},
Number = {3},
Pages = {719-736},
Month = {MAR},
Abstract = {Artificial neural networks have been proposed in medical research as an
   alternative to some regression models such as the generalized linear
   models, being the multilayer perceptron (MLP) the most used
   architecture. However, inspired in the generalized additive models
   (GAM), recent studies proposed the more transparent generalized additive
   neural network (GANN) architecture. In fact, while a MLP may be seen as
   a black box in which the effect of a variable on the outcome is not
   clear, a GANN has the advantage of being able to study objectively,
   through a graphical approach, the effect of an input variable on a
   certain outcome of interest {[}9]. In this study, the GANN's
   architecture was updated, considering some features already available in
   the GAM, namely the use of a flexible parametric link function based on
   the Aranda-Ordaz transformations family for a binary response. Also, the
   interpretability was improved by obtaining the partial functions with
   the corresponding confidence intervals through the bootstrap method. The
   performance of the proposed model was evaluated with simulated data and
   further applied to a real clinical dataset.},
Type = {Article},
Affiliation = {Brás-Geraldes, C (Corresponding Author), NOVA Med Sch, Campo Martires da Patria 130, P-1169056 Lisbon, Portugal.
   Brás-Geraldes, C (Corresponding Author), Univ Lisbon, Ctr Estat \& Aplicacoes, Campo Grande, P-1749016 Lisbon, Portugal.
   Bras-Geraldes, Carlos; Papoila, Ana, NOVA Med Sch, Campo Martires da Patria 130, P-1169056 Lisbon, Portugal.
   Bras-Geraldes, Carlos; Papoila, Ana, Univ Lisbon, Ctr Estat \& Aplicacoes, Campo Grande, P-1749016 Lisbon, Portugal.
   Xufre, Patricia, NOVA Sch Business \& Econ, Campus Campolide, P-1099032 Lisbon, Portugal.},
DOI = {10.1007/s00521-017-3105-6},
Keywords = {Generalized additive neural network; Flexible link function; Mortality
   prediction; Aranda-Ordaz transformations family},
Author-Email = {cgeraldes@nms.unl.pt
   ana.papoila@nms.unl.pt
   patricia.xufre@novasbe.pt},
Number-of-Cited-References = {32},
