Times-Cited = {87},
Unique-ID = {WOS:000842980100002},
}

@article{ WOS:A1993LW15400002,
Author = {NEWMAN, RB and PEACOCK, BS and VANDORSTEN, JP and HUNT, HH},
Title = {PREDICTING SUCCESS OF EXTERNAL CEPHALIC VERSION},
Journal = {AMERICAN JOURNAL OF OBSTETRICS AND GYNECOLOGY},
Year = {1993},
Volume = {169},
Number = {2, 1},
Pages = {245-250},
Month = {AUG},
Abstract = {OBJECTIVE: Many authors have identified prognostic factors for external
   cephalic version success, but there has not been an attempt to integrate
   these factors into a simple, quantitative scoring system for predicting
   version success. Nor have any prognostic factors been prospectively
   tested.
   STUDY DESIGN: We examined the clinical characteristics of 108
   consecutive breech versions performed between 1984 and 1986. These
   characteristics were evaluated by stepwise linear regression and
   discriminate analysis to identify those factors associated with success.
   Five factors explained the majority of the variability in outcome
   (parity, placental location, dilation, station, and estimated fetal
   weight). A model was developed to incorporate the trends identified
   among these five variables to create a scoring system similar to that of
   Bishop. This scoring system was then applied to 286 women undergoing
   external cephalic version since October 1986.
   RESULTS: There was a positive relationship between a rising version
   score and the likelihood of successful breech version. No versions were
   successful with a score less-than-or-equal-to 2, and all breech versions
   were successful with a score of 9 or 10. The results of the version
   score may have significantly altered physician recommendations in more
   than one third of cases.
   CONCLUSION: We believe that this simple, quantifiable scoring system is
   a refinement in our ability to predict the likelihood of external
   cephalic version success.},
Type = {Article; Proceedings Paper},
Affiliation = {NEWMAN, RB (Corresponding Author), MED UNIV S CAROLINA,DEPT OBSTET \& GYNECOL,171 ASHLEY AVE,CHARLESTON,SC 29425, USA.
   MED UNIV S CAROLINA,DEPT BIOSTAT EPIDEMIOL \& STAT SCI,CHARLESTON,SC 29425.},
DOI = {10.1016/0002-9378(93)90071-P},
Keywords = {EXTERNAL CEPHALIC VERSION; BREECH PRESENTATION},
Keywords-Plus = {LATE PREGNANCY; BREECH PRESENTATION; TOCOLYSIS; TRIAL; TERM},
Number-of-Cited-References = {15},
Times-Cited = {87},
Unique-ID = {WOS:A1993LW15400002},
}

@article{ WOS:000090057900006,
Author = {O'Brien, MJ and Keating, NM and Elderiny, S and Cerda, S and Keaveny, AP
   and Afdhal, NH and Nunes, DP},
Title = {An assessment of digital image analysis to measure fibrosis in liver
   biopsy specimens of patients with chronic hepatitis C},
Journal = {AMERICAN JOURNAL OF CLINICAL PATHOLOGY},
Year = {2000},
Volume = {114},
Number = {5},
Pages = {712-718},
Month = {NOV},
Abstract = {The aim tvas to assess the validity of a digitally computed fibrosis
   ratio as a measure of fibrosis stage in liver biopsy specimens. We
   scored 230 liver biopsy specimens from patients with chronic hepatitis C
   for fibrosis using modified Knodell criteria; fibrosis ratios were
   computed from digital images that encompassed the complete
   trichrome-stained section of each case. Although an overall correlation
   between fibrosis ratio and ordinal score was present, subset analysis
   showed that this correlation existed only among biopsy specimens with
   high scores (3-6, early bridging fibrosis to established cirrhosis).
   There was no correlation or difference between category means found
   among biopsy specimens with low scores (0-3, normal to early bridging
   fibrosis). Furthermore, concordance by both estimates in direction of
   fibrosis change among serial liver biopsy specimens was found in only 11
   (30\%) of 37 pairs compared. The findings suggest that a qualitative
   assessment of the computerized fibrosis pattern is necessary for the
   interpretation of computerized fibrosis ratio measurements, particularly
   in patients with early stage fibrosis.},
Type = {Article},
Affiliation = {O'Brien, MJ (Corresponding Author), Boston Med Ctr, Dept Pathol, Mallory Bldg,784 Massachusetts Ave, Boston, MA 02118 USA.
   Boston Univ, Sch Med, Dept Pathol, Boston, MA 02118 USA.
   Boston Univ, Sch Med, Dept Med, Gastroenterol Sect, Boston, MA 02118 USA.},
DOI = {10.1309/D7AU-EYW7-4B6C-K08Y},
Keywords = {classification; Knodell; fibrosis ratio; cirrhosis; validity},
Keywords-Plus = {INTERFERON THERAPY; SCORING SYSTEM; CIRRHOSIS; DIAGNOSIS; PROGRESSION;
   INFECTION; RIBAVIRIN; MARKERS; VIRUS},
Number-of-Cited-References = {24},
