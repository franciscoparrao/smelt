   Du, Wala, Chinese Acad Agr Sci, Grassland Res Inst, Hohhot 010022, Inner Mongolia, Peoples R China.
   Du, Wala, Arshan Forest \& Grassland Disaster Prevent \& Mitig, Arshan 137400, Inner Mongolia, Peoples R China.},
DOI = {10.1007/s11222-024-10559-6},
Article-Number = {30},
Keywords = {Geographically and temporally weighted regression; Spatiotemporal
   heterogeneity; Standard deviation; Hat matrix; Scale effect},
Author-Email = {zhmhong@imut.edu.cn
   20231800074@imut.edu.cn
   20231100071@imut.edu.cn
   duwala@caas.cn},
Number-of-Cited-References = {23},
