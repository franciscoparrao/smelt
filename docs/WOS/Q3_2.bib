   Teresa Cedena, Maria, Hosp Univ 12 Octubre, Dept Hematol, Madrid, Spain.
   Morado, Marta, Hosp Univ La Paz, Dept Hematol, Madrid, Spain.
   Maria Bellon, Jose, IiSGM, Madrid, Spain.},
DOI = {10.1002/cyto.b.21538},
Keywords = {myelodysplastic syndromes; low-risk MDS; CD34+cells; flow cytometry;
