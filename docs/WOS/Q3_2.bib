   Galve, Jorge Pedro, Univ Granada, Dept Geodynam, Ave Fuente Nueva S-N CP, Granada 18071, Spain.},
DOI = {10.1016/j.catena.2020.104630},
Article-Number = {104630},
Keywords = {Landslide inventories; Landslide susceptibility; Data-driven methods;
   Receiving operator curve; Cohen's Kappa coefficient},
Keywords-Plus = {LAND-USE SETTINGS; LOGISTIC-REGRESSION; QUANTITATIVE-ANALYSIS;
