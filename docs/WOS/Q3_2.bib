Unique-ID = {WOS:001005447300001},
}

@article{ WOS:001013154400011,
Author = {Lee, Chiyoung and Min, Se Hee and Niitsu, Kosuke},
Title = {Nonlinear Relationship Between C-Reactive Protein and Depression Among
   Obese Middle-Aged Adults},
Journal = {NURSING RESEARCH},
Year = {2023},
Volume = {72},
Number = {3},
Pages = {236-245},
Month = {MAY-JUN},
Abstract = {BackgroundDespite the agreement on the significance of the relationship
   between the C-reactive protein (CRP) and depression, research results
   have been discrepant by gender.ObjectiveWe attempted to address this
   uncertainty via a generalized additive model and more carefully analyzed
   the shape of the CRP-depression relationship in terms of sex.MethodsThis
   is a secondary data analysis using the National Health and Nutrition
   Examination Survey (2017-2020) data targeting 1,581 obese middle-aged
   adults (40-70 years, 51.4\% women) with CRP \& LE; 10 mg/L. The study
   outcome was depression severity, assessed by the nine-item Patient
   Health Questionnaire. Several models were built, adjusting for relevant
   sociodemographic, lifestyle, and clinical covariates. The value of the
   effective degree of freedom (EDF) quantifies curvature of the
   relationship. The threshold effect was investigated using a
   two-piecewise linear regression model, when needed.ResultsAmong men, an
   increasing linear pattern was found (EDF \& AP; 1). Contrastingly among
   women, the EDF value was > 2 in all unadjusted and adjusted models,
   indicating the smooth (curved) association. The threshold level affected
   the association pattern particularly for women, among whom the
   depression severity related to CRP significantly increased as the CRP
   level increased to an inflection point of 3.6 mg/L but decreased
   thereafter.DiscussionAssuming linearity for the CRP association with
   depression may not be appropriate for middle-aged obese women. Although
   we do not claim to provide a definite method of assessing the
   CRP-depression relationship, we hope to offer a different perspective
   when exploring this relationship. Thus, the results should be
   interpreted cautiously, and future studies on this topic should
   replicate this approach with generalized additive models.},
Type = {Article},
Affiliation = {Lee, CY (Corresponding Author), Univ Washington Bothell, Sch Nursing \& Hlth Studies, 18115 Campus Way NE, Bothell, WA 98011 USA.
   Lee, Chiyoung; Niitsu, Kosuke, Univ Washington Bothell, Sch Nursing \& Hlth Studies, 18115 Campus Way NE, Bothell, WA 98011 USA.
   Min, Se Hee, Columbia Univ, Sch Nursing, New York, RN, Brazil.},
DOI = {10.1097/NNR.0000000000000646},
Keywords = {C-reactive protein; depression; inflammation; obesity},
Keywords-Plus = {RISK-FACTOR; SYMPTOMS; CRP; DISEASE; HEALTH; MEN; INFLAMMATION;
   ASSOCIATION; MARKERS},
Author-Email = {clee33@uw.edu
   sm4394@cumc.columbia.edu
   kniitsu@uw.edu},
Number-of-Cited-References = {39},
Times-Cited = {4},
Unique-ID = {WOS:001013154400011},
}

@article{ WOS:000972745500001,
Author = {Kliegr, Tomas and Izquierdo, Ebroul},
Title = {QCBA: improving rule classifiers learned from quantitative data by
   recovering information lost by discretisation},
Journal = {APPLIED INTELLIGENCE},
Year = {2023},
Volume = {53},
Number = {18},
Pages = {20797-20827},
Month = {SEP},
Abstract = {A prediscretisation of numerical attributes which is required by some
   rule learning algorithms is a source of inefficiencies. This paper
   describes new rule tuning steps that aim to recover lost information in
   the discretisation and new pruning techniques that may further reduce
   the size of rule models and improve their accuracy. The proposed QCBA
   method was initially developed to postprocess quantitative attributes in
   models generated by Classification based on associations (CBA)
   algorithm, but it can also be applied to the results of other rule
   learning approaches. We demonstrate the effectiveness on the
   postprocessing of models generated by five association rule
   classification algorithms (CBA, CMAR, CPAR, IDS, SBRL) and two
   first-order logic rule learners (FOIL2 and PRM). Benchmarks on 22
   datasets from the UCI repository show smaller size and the overall best
   predictive performance for FOIL2+QCBA compared to all seven baselines.
   Postoptimised CBA models have a better predictive performance compared
   to the state-of-the-art rule learner CORELS in this benchmark. The
   article contains an ablation study for the individual postprocessing
   steps and a scalability analysis on the KDD'99 Anomaly detection
   dataset.},
Type = {Article},
Affiliation = {Kliegr, T (Corresponding Author), Univ Econ Prague, Fac Informat \& Stat, Dept Informat \& Knowledge Engn, W Churchill sq 4, Prague, Czech Republic.
   Kliegr, Tomas, Univ Econ Prague, Fac Informat \& Stat, Dept Informat \& Knowledge Engn, W Churchill sq 4, Prague, Czech Republic.
   Izquierdo, Ebroul, Queen Mary Univ London, Sch Elect Engn \& Comp Sci, Mile End Rd, London, England.},
DOI = {10.1007/s10489-022-04370-x},
EarlyAccessDate = {APR 2023},
Keywords = {Association rule classification; CBA; Quantitative association rule
   learning; Rule list optimisation; Interpretable machine learning},
Keywords-Plus = {FUZZY CLASSIFICATION RULES; FRAMEWORK; ALGORITHM},
Author-Email = {tomas.kliegr@vse.cz},
Number-of-Cited-References = {70},
Times-Cited = {4},
Unique-ID = {WOS:000972745500001},
}

@article{ WOS:000939183800001,
Author = {Berbesi, Lina and Pritchard, Geoffrey},
Title = {Modelling Energy Data in a Generalized Additive Model-A Case Study of
   Colombia},
Journal = {ENERGIES},
Year = {2023},
Volume = {16},
Number = {4},
Month = {FEB},
Abstract = {Energy demand modelling is essential for reliable informing and framing
   energy policy decisions. More accurate modelling betters ensuring
   availability of energy and energy quality. Energy availability is
   related to energy access across the country and defines important
   economic measures such as energy poverty, which plays a critical role in
   developing countries. Energy quality is related to the reliability of
   the supply for correctly estimating energy needs. To incorporate spatial
   and temporal components of energy in a way that availability and quality
   are accurately assessed, this article discussed a number of suitable
   task methods for this (Second-generation GAMs with one-dimensional
   smoothers: Cyclic/Non-Cyclic Cubic Splines and two-dimensional
   smoothers: Markov Random Fields/Tensor Splines Interactions). The
   results showed that the complete consideration of both temporal and
   spatial aspects leads to a better fitted model which explains more of
   the data variation.},
