@article{ WOS:001477676300001,
Author = {Carvalho, Jessica and Cherubin, Laurent M. and O'Corry-Crowe, Greg},
Title = {Autonomous wave gliders as a tool to characterize delphinid habitats
   along the Florida Atlantic coast},
Journal = {PEERJ},
Year = {2025},
Volume = {13},
Month = {APR 4},
Abstract = {As climate change and anthropogenic activities continue to impact
   cetacean species, it becomes increasingly urgent to efficiently monitor
   cetacean populations. Continuing technological advances enable
   innovative research methodologies which broaden monitoring approaches.
   In our study, we utilized an autonomous wave glider equipped with
   acoustic and environmental sensors to assess delphinid species presence
   on the east Florida shelf and compared this approach with traditional
   marine mammal monitoring methods. Acoustic recordings were analyzed to
   detect delphinid presence along the glider track in conjunction with
   subsurface environmental variables such as temperature, salinity,
   current velocity, and chlorophyll-a concentration. Additionally,
   occurrences of soniferous fish and anthropogenic noise were also
   documented. These in-situ variables were incorporated into generalized
   additive models (GAMs) to identify predictors of delphinid presence. The
   top-performing GAM found that location, sound pressure level (SPL),
   temperature, and chlorophyll-a concentration explained 50.8\% of the
   deviance in the dataset. The use of satellite environmental variables
   with the absence of acoustic variables found that location, derived
   current speed and heading, and chlorophyll-a explained 44.8\% of
   deviance in the dataset. Our research reveals the explanatory power of
   acoustic variables, measurable with autonomous platforms such as wave
   gliders, in delphinid presence drivers and habitat characterization.},
Type = {Article},
Affiliation = {Carvalho, J (Corresponding Author), Florida Atlantic Univ, Harbor Branch Campus, Ft Pierce, FL 34946 USA.
   Carvalho, Jessica; Cherubin, Laurent M.; O'Corry-Crowe, Greg, Florida Atlantic Univ, Harbor Branch Campus, Ft Pierce, FL 34946 USA.},
DOI = {10.7717/peerj.19204},
Article-Number = {e19204},
Keywords = {Autonomous gliders; Habitat characterization; Generalized additive
   models; Passive acoustic monitoring; Marine mammal monitoring;
   Delphinids},
Keywords-Plus = {BOTTLE-NOSED DOLPHINS; SEA-SURFACE TEMPERATURE; TURSIOPS-TRUNCATUS;
   MARINE MAMMALS; CLASSIFICATION; ECHOLOCATION; CETACEANS; ABUNDANCE;
   PATTERNS; WATERS},
Author-Email = {jcarvalho@fau.edu},
Number-of-Cited-References = {80},
Times-Cited = {1},
Unique-ID = {WOS:001477676300001},
}

@article{ WOS:001467639000001,
Author = {Fukasawa, Atsuki and Watanabe, Shinya},
Title = {Estimation of floc condition in a dewatering process by image analysis
   using machine learning},
Journal = {ARTIFICIAL LIFE AND ROBOTICS},
Year = {2025},
Volume = {30},
Number = {3},
Pages = {439-448},
Month = {AUG},
Abstract = {Dewatering is a crucial process in sludge treatment plants, and
   appropriate mixing of polymer and sludge is an important factor in
   achieving efficient dewatering. This study focused on the condition of
   flocs produced by mixing sludge and polymer, and estimated the floc
   condition through visual analysis of images. In this study, the
   estimation of floc condition was assumed to be a classification problem
   of mixer speed, and validation was conducted to classify the appropriate
   speed based on the images. The proposed methodology involved the
   development of a machine learning model characterized by high accuracy
   and transparency. This model was formulated using two features extracted
   from the images, i.e., the gaps between flocs and their texture, which
   are the parameters used by human operators to estimate floc condition.
   Explainable Boosting Machine was used as the machine learning model,
   which allows interpretation of the model's contents and can be applied
   easily. The classification accuracy of this model was validated using
   both interpolated and extrapolated data, yielding accuracies exceeding
   95\% in both scenarios. Furthermore, comparative analysis was performed
   between the proposed transparent box model and a conventional
   Convolutional Neural Network (CNN) model. Despite its transparent box
   nature, the proposed approach demonstrated a comparable level of
   accuracy to the CNN model in this comparative study.},
Type = {Article},
Affiliation = {Fukasawa, A (Corresponding Author), Tsukishima JFE Aqua Solut Co Ltd, Yokohama, Kanagawa, Japan.
   Fukasawa, A (Corresponding Author), Muroran Inst Technol, Muroran, Hokkaido, Japan.
   Fukasawa, Atsuki, Tsukishima JFE Aqua Solut Co Ltd, Yokohama, Kanagawa, Japan.
   Fukasawa, Atsuki; Watanabe, Shinya, Muroran Inst Technol, Muroran, Hokkaido, Japan.},
DOI = {10.1007/s10015-025-01014-4},
EarlyAccessDate = {MAR 2025},
Keywords = {Dewatering process; Floc; Texture; Explainable boosting machine;
   Convolutional neural network},
Keywords-Plus = {AUTOMATIC-CONTROL; SLUDGE},
Author-Email = {atsuki\_fukasawa@tjas.co.jp
   sin@muroran-it.ac.jp},
Number-of-Cited-References = {16},
Times-Cited = {1},
Unique-ID = {WOS:001467639000001},
}

@article{ WOS:001423596900001,
Author = {You, You and Zheng, Hui and Lei, Xiaohui and Zhou, Hai and Huang, Lijia
   and Zhang, Yong and Xie, Zongyi and He, Qiuguang},
Title = {Development of a falls risk assessment scale for middle-aged and elderly
   patients with cardiovascular diseases in Chinese community based on
   AutoScore: A CHARLS study},
Journal = {PUBLIC HEALTH},
Year = {2025},
Volume = {240},
Pages = {167-173},
Month = {MAR},
Abstract = {Objectives: Falls among middle-aged and elderly patients with
   cardiovascular diseases (CVD) frequently occur in non-hospital settings.
   However, there is a lack of simple forecasting tools for fall risk in
   middle-aged and elderly patients with CVD in Chinese community. We aimed
   to develop an easy-to-use scoring system, even for nonprofessionals, to
   facilitate the implementation of individualized fall prevention
   measures. Study design: Nationwide cohort study. Methods: The study
   included 2280 patients over the age of 45 with CVD from the China Health
   and Retirement Longitudinal Study (CHARLS). The data was divided into
   training (70 \%) and testing (30 \%) sets. Least Absolute Shrinkage and
   Selection Operator (LASSO) regression was used to refine 134 candidate
   variables in the training set. After that, six machine learning
   algorithms were employed to construct predictive models for
   post-diagnosis fall risk. AutoScore, an interpretable machine
   learning-based clinical score generation algorithm, was then utilized to
   establish a fall risk prediction score. Finally, the models' performance
   was evaluated using Area Under the Curve (AUC), Accuracy, Sensitivity,
   Specificity, and Brier Score. Results: LASSO regression identified 16
   predictive variables for input into various models. In the test set,
   AutoScore achieved the highest AUC (0.7447) among the six machine
   learning models, showing statistically significant differences with
   LightGBM, Random Forest, and XGBoost. Ultimately, a percentage-based
   questionnaire scale was developed by used AutoScore, including variables
   such as physical condition, psychological state, and surrounding
   environment, among others. The optimal threshold for predicting falls
   was determined to be 31 points. Conclusion: We have developed a
   practical and easily interpretable fall prediction score for middle-aged
   and elderly patients with CVD in community.},
Type = {Article},
Affiliation = {Xie, ZY; He, QG (Corresponding Author), Chongqing Med Univ, Affiliated Hosp 2, Dept Neurosurg, 76 Linjiang Rd, Chongqing 400010, Peoples R China.
   You, You; Zheng, Hui; Zhou, Hai; Huang, Lijia; Xie, Zongyi; He, Qiuguang, Chongqing Med Univ, Affiliated Hosp 2, Dept Neurosurg, 76 Linjiang Rd, Chongqing 400010, Peoples R China.
   Lei, Xiaohui, Chongqing Med Univ, Affiliated Hosp 2, Dept Endocrinol, Chongqing 400010, Peoples R China.
   Zhang, Yong, Chongqing Med Univ, Sch Publ Hlth, Chongqing 400010, Peoples R China.},
DOI = {10.1016/j.puhe.2025.01.031},
EarlyAccessDate = {FEB 2025},
Keywords = {Machine learning; AutoScore; Cardiovascular disease; Middle-aged and
   elderly; Fall prediction; Simplified scoring system},
Keywords-Plus = {HEALTH},
Author-Email = {zyxie2008@cqmu.edu.cn
   heqiuguang1992@cqmu.edu.cn},
Number-of-Cited-References = {32},
