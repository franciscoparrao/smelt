   Jin, Feifei, Peking Univ, Key Lab Trauma treatment \& Neural Regenerat, Minist Educ, Beijing, Peoples R China.
   Jin, Feifei, Natl Ctr Trauma Med China, Beijing, Peoples R China.},
DOI = {10.1093/ehjdh/ztae100},
