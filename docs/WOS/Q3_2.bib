   Baron, M.; Hudson, M., Jewish Gen Hosp, Div Rheumatol, Room A-725,3755 Cote St Catherine Rd, Montreal, PQ H3T 1E2, Canada.},
DOI = {10.1016/j.semarthrit.2020.02.013},
Keywords-Plus = {COST SAVINGS; METAANALYSIS; PREVALENCE; GUIDELINES; ALGORITHM;
