DOI = {10.1016/j.scitotenv.2018.01.196},
Keywords = {Severe fever with thrombocytopenia syndrome; Meteorological factor;
   Forecast model; Autoregressive integrated moving average model; Negative
   binomial regression model; Generalized additive model},
Keywords-Plus = {TO-PERSON TRANSMISSION; SYNDROME BUNYAVIRUS; SYNDROME VIRUS;
