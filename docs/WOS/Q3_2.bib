   Morrison, William B., Thomas Jefferson Univ Hosp, Dept Radiol, Philadelphia, PA USA.
   Chhabra, Avneesh, UT Southwestern Med Ctr, Dept Orthopaed Surg, Dallas, TX 75390 USA.},
DOI = {10.1186/s13244-025-02185-1},
