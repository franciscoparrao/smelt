DOI = {10.1016/j.ins.2022.08.018},
EarlyAccessDate = {AUG 2022},
Keywords = {Cross-domain decision making; Parameter transfer; Value function;
   Sturm?s theorem; Diagnosis of breast lesions},
Keywords-Plus = {ADDITIVE VALUE-FUNCTIONS; PREFERENCE DISAGGREGATION; NETWORK;
