   Chen, Tianshi, Chinese Univ Hong Kong, Shenzhen Res Inst Big Data, Shenzhen, Peoples R China.},
DOI = {10.1137/19M1267349},
Keywords = {numerical linear algebra; rank structured matrices; smoothing spline
   regression},
Author-Email = {mskan@dtu.dk
   tschen@cuhk.edu.cn},
Number-of-Cited-References = {20},
Times-Cited = {14},
Unique-ID = {WOS:000546981500002},
}

