   Kato, Kenta; Matsuno, Fumitoshi, Kyoto Univ, Grad Sch Engn, Dept Mech Engn \& Sci, Kyoto 6068501, Japan.},
DOI = {10.1109/TRO.2016.2632739},
Keywords = {Learning and adaptive systems; multiobjective optimization (MOO);
   response surface method (RSM)},
Keywords-Plus = {EVOLUTIONARY ALGORITHMS; BAYESIAN OPTIMIZATION; MARGINAL LIKELIHOOD;
