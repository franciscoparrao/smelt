   Abouzied, Amr S., Natl Org Drug Control \& Res NODCAR, Dept Pharmaceut Chem, Giza 12553, Egypt.},
DOI = {10.1016/j.molliq.2023.121471},
EarlyAccessDate = {FEB 2023},
Article-Number = {121471},
Keywords = {Supercritical technique; Green processing; Machine learning;
   Computational modeling},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; MULTILAYER PERCEPTRON; GAUSSIAN-PROCESSES;
   REGRESSION},
Author-Email = {b.huwaimel@uoh.edu.sa},
