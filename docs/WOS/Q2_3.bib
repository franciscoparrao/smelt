   Uddin, Mohammad Monir; Mahbub, Zaid Bin, North South Univ, Dept Math \& Phys, Dhaka 1229, Bangladesh.},
DOI = {10.1109/ACCESS.2021.3095380},
Keywords = {Feature extraction; Estimation; Electrocardiography; Motion artifacts;
   Motion segmentation; Monitoring; Machine learning algorithms;
   Photoplethysmogram; respiration rate; machine learning; feature
   selection; motion artifact correction; Gaussian process regression},
Keywords-Plus = {ELECTROCARDIOGRAM; DECOMPOSITION; ALGORITHMS; EXTRACTION; PNEUMONIA;
