   Ceylan, Zeynep, Samsun Univ, Fac Engn, Ind Engn Dept, TR-55420 Samsun, Turkiye.},
DOI = {10.1016/j.biombioe.2023.106993},
EarlyAccessDate = {NOV 2023},
Article-Number = {106993},
Keywords = {Hydrochar; Hydrothermal carbonization; Biomass; Machine learning;
   Metadata analysis; Bayesian optimization},
