   Wang, Yang; Zhang, Jin; Chen, Yihao; Yuan, Hao; Wu, Cheng, Soochow Univ, Sch Rail Transportat, Suzhou 215006, Peoples R China.},
DOI = {10.1109/TII.2024.3353874},
EarlyAccessDate = {JAN 2024},
Keywords = {Semantic segmentation; Training; Data models; Adaptation models; Feature
   extraction; Semantics; Labeling; Automated machine learning; interactive
