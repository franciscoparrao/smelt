   Kotthoff, Lars, Univ Wyoming, Dept Comp Sci, Laramie, WY 82071 USA.},
DOI = {10.1016/j.carbon.2020.05.087},
Keywords-Plus = {OXIDE-FILMS; GRAPHITE; DEPENDENCE; REDUCTION; FEATURES; SCIENCE},
Author-Email = {pjohns27@uwyo.edu},
Number-of-Cited-References = {63},
