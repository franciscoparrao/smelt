   Mac Aodha, Oisin; Oyarzun, Diego A., Alan Turing Inst, London NW1 2DB, England.
   Oyarzun, Diego A., Univ Edinburgh, Sch Biol Sci, Edinburgh EH9 3JH, Scotland.},
DOI = {10.1021/acssynbio.3c00120},
EarlyAccessDate = {JUN 2023},
Keywords = {Bayesian optimization; machine learning; dynamicpathway control; genetic
   circuit design; multiscalebiological systems; metabolic engineering},
Keywords-Plus = {DYNAMIC CONTROL; SYNTHETIC BIOLOGY; PATHWAY; PRINCIPLES; SYSTEM; FLUX},
