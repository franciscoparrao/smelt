   Medina-Esquivel, Ruben Arturo, Univ Autonoma Yucatan, Fac Ingn, Av Ind Contaminantes, Merida, Yucatan, Mexico.},
DOI = {10.1016/j.tsep.2023.102131},
EarlyAccessDate = {SEP 2023},
Article-Number = {102131},
Keywords = {Surrogate model; Solar system application; Economic study; Dryer
