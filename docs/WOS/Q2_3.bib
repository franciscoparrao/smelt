   Ong, Yew-Soon, Nanyang Technol Univ, Data Sci \& Artificial Intelligence Res Ctr, Singapore 639798, Singapore.},
DOI = {10.1016/j.knosys.2017.12.034},
Keywords = {Multi-output Gaussian process; Symmetric/asymmetric MOGP;
   Multi-fidelity; Output correlation; Knowledge transfer},
Keywords-Plus = {COMPUTER CODE; DESIGN; OPTIMIZATION; SIMULATION; MODEL; APPROXIMATION;
