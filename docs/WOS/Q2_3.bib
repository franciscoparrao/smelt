   Aslan, Emrah, Mardin Artuklu Univ, Fac Engn \& Architecture, Dept Comp Engn, TR-47000 Mardin, Turkiye.},
DOI = {10.1007/s11270-025-08122-8},
Article-Number = {464},
Keywords = {Air Quality Prediction; Machine Learning; Bayesian Optimization;
   Regression Models; SVR},
Author-Email = {yildirim.ozupak@dicle.edu.tr
   feyyaz.alpsalaz@bozok.edu.tr
   emrahaslan@artuklu.edu.tr},
