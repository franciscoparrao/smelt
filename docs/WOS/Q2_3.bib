@article{ WOS:000343048300005,
Author = {Ming, Wuyi and Zhang, Guojun and Li, He and Guo, Jianwen and Zhang, Zhen
   and Huang, Yu and Chen, Zhi},
Title = {A hybrid process model for EDM based on finite-element method and
   Gaussian process regression},
Journal = {INTERNATIONAL JOURNAL OF ADVANCED MANUFACTURING TECHNOLOGY},
Year = {2014},
Volume = {74},
Number = {9-12},
Pages = {1197-1211},
Month = {OCT},
Abstract = {This paper proposed a hybrid intelligent process model, based on
   finite-element method (FEM) and Gaussian process regression (GPR), for
   electrical discharge machining (EDM) process. A model of single-spark
   EDM process has been constructed based on FEM method, considering the
   latent heat, variable heat distribution coefficient of cathode (f (c) ),
   and plasma flushing efficiency (PFE), to predict material removal rate
   (MRR) and surface roughness (Ra). This model was validated using
   reported analytical and experimental results. Then, a GPR model was
   proposed to establish relationship between input process parameters
   (pulse current, pulse duration, and discharge voltage) and the process
   responses (MRR and Ra) for EDM process. The GPR model was trained,
   tested, and tuned using the data generated from the numerical
   simulations. Through the GPR model, it was found that responses of EDM
   process can be accurately predicted for the chosen process conditions.
   Therefore, for the selection of optimum parameters, the hybrid
   intelligent model proposed in this paper can be used in EDM process.},
