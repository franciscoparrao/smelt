   Lee, Suyong, Sejong Univ, Dept Food Sci \& Biotechnol, 209 Neungdong ro Gwangjin-gu, Seoul, South Korea.},
DOI = {10.1002/jsfa.13334},
EarlyAccessDate = {FEB 2024},
Keywords = {artificial intelligence; AI; deep learning; rheology; meat alternative},
Keywords-Plus = {MULTILAYER PERCEPTRON; NEURAL-NETWORK; FLOW BEHAVIOR; GUM; SHEAR},
