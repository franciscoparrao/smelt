@article{ WOS:000364340100002,
Author = {Gramacy, Robert B. and Bingham, Derek and Holloway, James Paul and
   Grosskopf, Michael J. and Kuranz, Carolyn C. and Rutter, Erica and
   Trantham, Matt and Drake, R. Paul},
Title = {CALIBRATING A LARGE COMPUTER EXPERIMENT SIMULATING RADIATIVE SHOCK
   HYDRODYNAMICS},
Journal = {ANNALS OF APPLIED STATISTICS},
Year = {2015},
Volume = {9},
Number = {3},
Pages = {1141-1168},
Month = {SEP},
Abstract = {We consider adapting a canonical computer model calibration apparatus,
   involving coupled Gaussian process (GP) emulators, to a computer
   experiment simulating radiative shock hydrodynamics that is orders of
   magnitude larger than what can typically be accommodated. The
   conventional approach calls for thousands of large matrix inverses to
   evaluate the likelihood in an MCMC scheme. Our approach replaces that
   costly ideal with a thrifty take on essential ingredients, synergizing
   three modern ideas in emulation, calibration and optimization: local
   approximate GP regression, modularization, and mesh adaptive direct
   search. The new methodology is motivated both by necessity-considering
   our particular application-and by recent trends in the supercomputer
   simulation literature. A synthetic data application allows us to explore
   the merits of several variations in a controlled environment and,
   together with results on our motivating real-data experiment, lead to
   noteworthy insights into the dynamics of radiative shocks as well as the
   limitations of the calibration enterprise generally.},
Type = {Article},
Affiliation = {Gramacy, RB (Corresponding Author), Univ Chicago, Booth Sch Business, Chicago, IL 60637 USA.
   Gramacy, Robert B., Univ Chicago, Booth Sch Business, Chicago, IL 60637 USA.
   Bingham, Derek, Simon Fraser Univ, Dept Stat \& Actuarial Sci, Burnaby, BC V5A 1S6, Canada.
   Holloway, James Paul; Grosskopf, Michael J.; Kuranz, Carolyn C.; Rutter, Erica; Trantham, Matt; Drake, R. Paul, Univ Michigan, Ctr Radiat Shock Hydrodynam, Ann Arbor, MI 48109 USA.},
DOI = {10.1214/15-AOAS850},
Keywords = {Emulator; tuning; nonparametric regression; big data; local Gaussian
   process; mesh adaptive direct search (MADS); modularization},
Keywords-Plus = {GAUSSIAN PROCESS MODELS; PREDICTION; EMULATORS; SEARCH; DESIGN},
