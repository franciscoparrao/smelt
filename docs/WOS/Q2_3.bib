   Mohamed, Ahmed Ali A., CUNY City Coll, Grove Sch Engn, Dept Elect Engn, New York, NY 10031 USA.},
DOI = {10.1155/2023/1934188},
Article-Number = {1934188},
Keywords-Plus = {CHARGING DEMAND},
