Keywords = {Ship maneuvering; Nonparametric modeling; Gaussian process regression;
   Hybrid -kernel function; Genetic algorithm},
Keywords-Plus = {PARAMETRIC IDENTIFICATION; MATHEMATICAL-MODELS; VECTOR; ALGORITHM},
Author-Email = {zjzou@sjtu.edu.cn},
