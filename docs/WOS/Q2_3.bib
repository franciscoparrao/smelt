}

@article{ WOS:001415683500001,
Author = {Li, Chen and Xie, Guixian and Li, Jingwen and Chen, Xu and Ma, Huiqiang
   and Wang, Bo},
Title = {Machine learning-driven prediction of nitrate-N adsorption efficiency by
   Fe-modified biochar: Refined model tuning and identification of crucial
   features},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2025},
Volume = {70},
Month = {FEB},
Abstract = {Biochar is widely recognized in water treatment due to its environmental
   benefits, particularly in reducing nitrate and nitrogen levels. However,
   its unmodified adsorption efficiency is limited. Fe-modified biochar
   (Fe-BC) is widely utilized for its efficient adsorption properties.
   However, its nitrate-N adsorption performance is influenced by numerous
   factors. Traditional methods for examining these influences require
   extensive experimentation, which is both labor-intensive and limited in
   predictive capacity. Thus, new technological approaches are essential to
   accurately describe and predict the nitrate-N adsorption efficiency of
   Fe-BC. This study employed machine learning techniques to analyze 10
   critical features impacting Fe-BC nitrate-N adsorption. Six machine
   learning models-artificial neural networks, random forests, support
   vector machines, decision trees, K-nearest neighbors, and XGBoost-were
   evaluated and optimized using Bayesian optimization to enhance
   prediction accuracy. The optimized XGBoost model exhibited high
   predictive accuracy (R-2 = 0.922, RMSE = 0.052). Additionally, the
   Shapley Additive Explanations (SHAP) method was used to conduct an
   in-depth analysis of the factors affecting Fe-BC nitrate-N adsorption
   efficiency. Results indicated that adsorption conditions were the most
   significant factor in predicting adsorption efficiency, contributing
   46.3 \%, followed by preparation conditions at 36.9 \% and
   physicochemical properties at 16.8 \%. Crucial features identified
   included Fe loading, initial concentration, pyrolysis temperature, and
   adsorption time. Further analysis revealed that Fe loading enhanced
   adsorption efficiency up to 233 mg<middle dot>g(-1), beyond which its
   impact declined. This study demonstrates that machine learning optimized
   Fe-BC has great potential in treating nitrate-nitrogen polluted
   wastewater, especially agricultural and industrial wastewater. It offers
   novel strategies for the design and application of Fe-BC materials in
   nitrate-nitrogen removal.},
Type = {Article},
Affiliation = {Ma, HQ; Wang, B (Corresponding Author), Liaoning Petrochem Univ, Sch Environm \& Safety Engn, Fushun 113001, Peoples R China.
   Li, Chen; Xie, Guixian; Li, Jingwen; Chen, Xu; Ma, Huiqiang; Wang, Bo, Liaoning Petrochem Univ, Sch Environm \& Safety Engn, Fushun 113001, Peoples R China.},
DOI = {10.1016/j.jwpe.2025.107026},
EarlyAccessDate = {JAN 2025},
Article-Number = {107026},
Keywords = {Machine learning; Fe-modified biochar; Nitrate-N; Adsorption; Prediction},
