   Hu, Lin, Changsha Univ Sci \& Technol, Sch Automot \& Mech Engn, Changsha 410114, Peoples R China.},
DOI = {10.1109/TVT.2021.3055811},
Keywords = {Batteries; Predictive models; Data models; Degradation; Data mining;
   Protocols; Estimation; Batteries; remaining useful life; health
   management; transfer learning; predictive maintenance},
