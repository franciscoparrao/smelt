   Jahanbakhshi, Ahmad, Univ Mohaghegh Ardabili, Dept Biosyst Engn, Ardebil, Iran.},
DOI = {10.1016/j.compbiomed.2021.104704},
EarlyAccessDate = {AUG 2021},
