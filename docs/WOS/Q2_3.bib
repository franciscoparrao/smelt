@article{ WOS:000641162100031,
Author = {Li, Caoyuan and Xie, Hong-Bo and Fan, Xuhui and Xu, Richard Yi Da and
   Van Huffel, Sabine and Mengersen, Kerrie},
Title = {Kernelized Sparse Bayesian Matrix Factorization},
Journal = {IEEE TRANSACTIONS ON NEURAL NETWORKS AND LEARNING SYSTEMS},
Year = {2021},
Volume = {32},
Number = {1},
Pages = {391-404},
Month = {JAN},
Abstract = {Extracting low-rank and/or sparse structures using matrix factorization
   techniques has been extensively studied in the machine learning
   community. Kernelized matrix factorization (KMF) is a powerful tool to
   incorporate side information into the low-rank approximation model,
   which has been applied to solve the problems of data mining, recommender
   systems, image restoration, and machine vision. However, most existing
   KMF models rely on specifying the rows and columns of the data matrix
   through a Gaussian process prior and have to tune manually the rank.
   There are also computational issues of existing models based on
   regularization or the Markov chain Monte Carlo. In this article, we
   develop a hierarchical kernelized sparse Bayesian matrix factorization
   (KSBMF) model to integrate side information. The KSBMF automatically
   infers the parameters and latent variables including the reduced rank
   using the variational Bayesian inference. In addition, the model
   simultaneously achieves low-rankness through sparse Bayesian learning
   and columnwise sparsity through an enforced constraint on latent factor
   matrices. We further connect the KSBMF with the nonlocal image
   processing framework to develop two algorithms for image denoising and
   inpainting. Experimental results demonstrate that KSBMF outperforms the
   state-of-the-art approaches for these image-restoration tasks under
   various levels of corruption.},
Type = {Article},
Affiliation = {Xie, HB; Mengersen, K (Corresponding Author), Queensland Univ Technol, ARC Ctr Excellence Math \& Stat Frontiers, Brisbane, Qld 4001, Australia.
   Li, Caoyuan, Beijing Inst Technol, Sch Comp Sci \& Technol, Beijing 100081, Peoples R China.
   Li, Caoyuan; Xu, Richard Yi Da, Univ Technol Sydney, Fac Engn \& Informat Technol, Ultimo, NSW 2007, Australia.
   Xie, Hong-Bo; Mengersen, Kerrie, Queensland Univ Technol, ARC Ctr Excellence Math \& Stat Frontiers, Brisbane, Qld 4001, Australia.
   Fan, Xuhui, Univ New South Wales, Sch Math \& Stat, Sydney, NSW 2033, Australia.
   Van Huffel, Sabine, Katholieke Univ Leuven, ESAT Stadius Div, Dept Elect Engn, B-3001 Leuven, Belgium.},
DOI = {10.1109/TNNLS.2020.2978761},
Keywords = {Sparse matrices; Bayes methods; Matrix decomposition; Covariance
   matrices; Data models; Kernel; Computational modeling; Image
   restoration; low-rankness; matrix factorization; sparse Bayesian
   learning; variational Bayesian (VB) inference},
Keywords-Plus = {AUTOMATIC RELEVANCE DETERMINATION; LOW-RANK; REPRESENTATION; COMPLETION;
   MODELS},
Author-Email = {hongbo.xie@qut.edu.au},
Number-of-Cited-References = {53},
Times-Cited = {15},
Unique-ID = {WOS:000641162100031},
}

@incollection{ WOS:000945292900013,
Author = {Sabelhaus, Andrew P. and Majidi, Carmel},
Book-Group-Author = {IEEE},
Title = {Gaussian Process Dynamics Models for Soft Robots with Shape Memory
   Actuators},
Booktitle = {2021 IEEE 4TH INTERNATIONAL CONFERENCE ON SOFT ROBOTICS (ROBOSOFT)},
Year = {2021},
Pages = {191-198},
Abstract = {Efficient and tractable dynamics models of soft robots are needed for
   many purposes. For soft robots powered by shape memory actuators, models
   must simultaneously capture actuator dynamics alongside material
   deformations. This article examines one possible modeling framework
   using Gaussian Process (GP) regression, applied in two settings. First,
   we attempt predictions of bending deformation in a low-dimensional
   hardware task of a single limb with one shape memory alloy (SMA)
   actuator, where the SMA temperature is estimated in open loop. Second,
   we consider locomotion in a simulation of a rolling robot, where the
   actuator state is known perfectly but the state space is
   high-dimensional and hybrid. Our locomotion tests examine the
   applicability of standard model selection choices for a GP, particularly
   the commonly-used squared exponential (SE) kernel, by studying the
   hyperparameter optimization problem. We cross-validate one-step-ahead
   dynamics predictions for both robots. All results have significant
   noise, but for the single limb in bending, the GP predictions are
   sufficient to simulate motions over a time horizon of 30 seconds. With
   further work to address issues with data quality, underfitting, and
   other sources of error, these dynamics models have the potential to
   assist in trajectory generation and control for soft robots.},
Type = {Proceedings Paper},
Affiliation = {Sabelhaus, AP (Corresponding Author), Carnegie Mellon Univ, Dept Mech Engn, Pittsburgh, PA 15213 USA.
   Sabelhaus, Andrew P.; Majidi, Carmel, Carnegie Mellon Univ, Dept Mech Engn, Pittsburgh, PA 15213 USA.},
DOI = {10.1109/RoboSoft51838.2021.9479294},
Keywords-Plus = {SIMULATION},
Author-Email = {apsabelhaus@cmu.edu
   cmajidi@andrew.cmu.edu},
Number-of-Cited-References = {36},
Times-Cited = {15},
Unique-ID = {WOS:000945292900013},
}

@article{ WOS:000552053300001,
Author = {Lin, Jingliang and Li, Haiyan and Huang, Yunbao and Huang, Zeying and
   Luo, Zhiqian},
Title = {Adaptive Artificial Neural Network Surrogate Model of Nonlinear
   Hydraulic Adjustable Damper for Automotive Semi-Active Suspension System},
Journal = {IEEE ACCESS},
Year = {2020},
Volume = {8},
Pages = {118673-118686},
Abstract = {Artificial neural network surrogate models are often used in the design
   optimization of the automotive semi-active suspension system. To realize
   the desired damping force, a surrogate model needs to be constructed to
   approximate the regulating mechanism of the hydraulic adjustable damper.
   However, very few of the existing studies discuss how to guarantee the
   modeling accuracy. To this end, this work constructs a novel surrogate
   model by using radial basis function neural network. Meanwhile, an
   adaptive modeling method based on modified hyperband and
   trust-region-based mode pursuing sampling is presented. Concretely,
   modified hyperband is used to fast select a seed model by early-stopping
   and dynamic resource allocation. Mode pursuing sampling is then
   performed in the neighborhood of the seed model, to systematically
   generate more sample points while statistically covering the entire
   neighborhood (i.e., trust region). In particular, in the mode pursuing
   sampling procedure, quadratic regression is performed around the current
   optimum as the second detection. Moreover, as the position or size of
   the trust region changes, the sampling and detection process iterate
   until the accuracy of the model is no longer improved. To avoid falling
   into the local optimum, the seed model selection and mode pursuing
   sampling process iterate until the termination criterion is met. The
   experimental results show that compared with the benchmarks, the
   modeling accuracy of hydraulic adjustable damper can be improved by up
   to 48\%, and the iteration resources can be reduced by up to 84\%.},
Type = {Article},
Affiliation = {Li, HY; Huang, YB (Corresponding Author), Guangdong Univ Technol, Coll Mech \& Elect Engn, Guangzhou 510006, Peoples R China.
   Huang, YB (Corresponding Author), Foshan Chuwei Technol Co Ltd, Foshan 528200, Peoples R China.
   Lin, Jingliang; Li, Haiyan; Huang, Yunbao; Huang, Zeying, Guangdong Univ Technol, Coll Mech \& Elect Engn, Guangzhou 510006, Peoples R China.
   Huang, Yunbao, Foshan Chuwei Technol Co Ltd, Foshan 528200, Peoples R China.
   Luo, Zhiqian, Guangzhou Automobile Grp Co Ltd, Engn Inst, Guangzhou 510640, Peoples R China.},
DOI = {10.1109/ACCESS.2020.3004886},
Keywords = {Semi-active suspension systems; hydraulic adjustable damper; artificial
   neural network; hyperparameter optimization},
Keywords-Plus = {ACTIVE SUSPENSION; VEHICLE; SEARCH},
Author-Email = {cathylhy@gdut.edu.cn
   huangyb@gdut.edu.cn},
Number-of-Cited-References = {47},
Times-Cited = {15},
Unique-ID = {WOS:000552053300001},
}

@incollection{ WOS:000399128000060,
Author = {Dernoncourt, Franck and Lee, Ji Young},
Book-Group-Author = {IEEE},
Title = {OPTIMIZING NEURAL NETWORK HYPERPARAMETERS WITH GAUSSIAN PROCESSES FOR
   DIALOG ACT CLASSIFICATION},
Booktitle = {2016 IEEE WORKSHOP ON SPOKEN LANGUAGE TECHNOLOGY (SLT 2016)},
Series = {IEEE Workshop on Spoken Language Technology},
Year = {2016},
Pages = {406-413},
Abstract = {Systems based on artificial neural networks (ANNs) have achieved
   state-of-the-art results in many natural language processing tasks.
   Although ANNs do not require manually engineered features, ANNs have
   many hyperparameters to be optimized. The choice of hyperparameters
   significantly impacts models' performances. However, the ANN
   hyperparameters are typically chosen by manual, grid, or random search,
   which either requires expert experiences or is computationally
   expensive. Recent approaches based on Bayesian optimization using
   Gaussian processes (GPs) is a more systematic way to automatically
   pinpoint optimal or near-optimal machine learning hyperparameters. Using
   a previously published ANN model yielding state-of-the-art results for
   dialog act classification, we demonstrate that optimizing
   hyperparameters using GP further improves the results, and reduces the
   computational time by a factor of 4 compared to a random search.
   Therefore it is a useful technique for tuning ANN models to yield the
   best performances for NLP tasks.},
Type = {Proceedings Paper},
Affiliation = {Dernoncourt, F (Corresponding Author), MIT CSAIL, Cambridge, MA 02139 USA.
   Dernoncourt, Franck; Lee, Ji Young, MIT CSAIL, Cambridge, MA 02139 USA.},
Keywords = {Natural language processing; Dialog systems; Artificial neural networks;
   Gaussian processes; Hyperparameter optimization},
Author-Email = {francky@mit.edu
   jjylee@mit.edu},
Number-of-Cited-References = {30},
Times-Cited = {15},
Unique-ID = {WOS:000399128000060},
}

@incollection{ WOS:000263676700089,
Author = {Kim, Hyun-Chul and Ghahramani, Zoubin},
Editor = {DaVitoria Lobo, N and Kasparis, T and Roli, F and Kwok, JT and Georgiopoulos, M and Anagnostopoulos, GC and Loog, M},
Title = {Outlier Robust Gaussian Process Classification},
Booktitle = {STRUCTURAL, SYNTACTIC, AND STATISTICAL PATTERN RECOGNITION},
Series = {Lecture Notes in Computer Science},
Year = {2008},
Volume = {5342},
Pages = {896+},
Abstract = {Gaussian process classifiers (GPCs) axe, a fully statistical model for
   kernel classification. We present a form of G PC which is robust, to
   labeling errors in the data set. This model allows label noise not only
   near the class boundaries, but also far from the class boundaries which
   can result from mistakes in labelling or gross errors in measuring the
   input features. We derive an outlier robust algorithm for training this
   model which alternates iterations based on the EP approximation and
   hyperparameter updates until convergence. We show the usefulness of the
   proposed algorithm with model selection method through simulation
   results.},
Type = {Proceedings Paper},
