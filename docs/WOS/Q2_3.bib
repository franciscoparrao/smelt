   Kalinin, Sergei, V, Univ Tennessee, Mat Sci \& Engn, Knoxville, TN 37996 USA.},
DOI = {10.1088/2632-2153/acb316},
Article-Number = {015011},
Keywords = {high-dimensional problem; Bayesian optimization; latent space;
