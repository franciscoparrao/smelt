   Bokde, Neeraj Dhanraj, iCLIMATE Aarhus Univ, Interdisciplinary Ctr Climate Change, DK-8830 Foulum, Denmark.},
DOI = {10.3390/en16031243},
Article-Number = {1243},
Keywords = {short term load forecasting; machine learning; Bayesian optimization;
   grid search; random search},
Keywords-Plus = {NEURAL-NETWORK; RANDOM SEARCH},
