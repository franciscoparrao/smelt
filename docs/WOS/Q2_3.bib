   Hannaford, Blake, Univ Washington, Dept Mech Engn, Seattle, WA 98195 USA.
   Hannaford, Blake, Univ Washington, Dept Surg, Seattle, WA 98195 USA.},
DOI = {10.1109/LRA.2017.2666420},
Keywords = {Sensorless grip force estimation; elongated cable-driven instrument;
   Gaussian process regression (GPR); surgical robot; minimally invasive
   surgery},
Keywords-Plus = {ROBOTICS},
