   Jamil, Mohsin, Mem Univ Newfoundland, Dept Elect \& Comp Engn, St John, NF A1B 3X5, Canada.},
DOI = {10.1109/ACCESS.2023.3308298},
Keywords = {Bitcoin; Ransomware; Fraud; Blockchains; Anomaly detection; Feature
   extraction; Stacking; Parameter estimation; Smart cities; Bitcoin
   transaction; hyperparameter tuning; machine learning; ransomware attack;
   stacking model; smart cities},
Keywords-Plus = {BLOCKCHAIN NETWORKS; ANOMALY DETECTION; MACHINE},
