   Zhu, Yong, Minist Emergency Management, Key Lab Fire Emergency Rescue Equipment, Shanghai 200032, Peoples R China.
   Tang, Shengnan, Jiangsu Univ, Inst Adv Mfg \& Modern Equipment Technol, Zhenjiang 212013, Peoples R China.},
DOI = {10.1016/j.isatra.2022.01.013},
EarlyAccessDate = {OCT 2022},
Keywords = {Hydraulic pump; Intelligent fault diagnosis; Convolutional neural
   network; Bayesian optimization},
Keywords-Plus = {CONVOLUTIONAL NEURAL-NETWORK; VIBRATION},
Author-Email = {zhuyong@ujs.edu.cn},
Number-of-Cited-References = {40},
Times-Cited = {154},
