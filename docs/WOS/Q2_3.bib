Keywords = {Ground source heat pump system; Coefficient of performance; Machine
   learning; Artificial neural network; Prediction model; Bayesian
   optimization},
Keywords-Plus = {HEAT-PUMP SYSTEM; ARTIFICIAL NEURAL-NETWORKS; PERFORMANCE},
