@article{ WOS:001040875600007,
Author = {Hwang, Seung-gyu and L'Huillier, Benjamin and Keeley, Ryan E. and Jee,
   M. James and Shafieloo, Arman},
Title = {How to use GP: effects of the mean function and hyperparameter selection
   on Gaussian process regression},
Journal = {JOURNAL OF COSMOLOGY AND ASTROPARTICLE PHYSICS},
Year = {2023},
Number = {2},
Month = {FEB},
Abstract = {Gaussian processes have been widely used in cosmology to reconstruct
   cosmological quantities in a model-independent way. However, the
   validity of the adopted mean function and hyperparameters, and the
   dependence of the results on the choice have not been well explored. In
   this paper, we study the effects of the underlying mean function and the
   hyperparameter selection on the reconstruction of the distance moduli
   from type Ia supernovae. We show that the choice of an arbitrary mean
   function affects the reconstruction: a zero mean function leads to
   unphysical distance moduli and the best-fit Lambda CDM to biased
   reconstructions. We propose to marginalize over a family of mean
   functions and over the hyperparameters to effectively remove their
   impact on the reconstructions. We further explore the validity and
   consistency of the results considering different kernel functions and
   show that our method is unbiased.},
Type = {Article},
Affiliation = {Hwang, SG (Corresponding Author), Sejong Univ, Dept Phys \& Astron, 209 Neungdong Ro, Seoul 05006, South Korea.
   Hwang, SG (Corresponding Author), Yonsei Univ, Dept Astron \& Space Sci, 50 Yonsei Ro, Seoul 03722, South Korea.
   Hwang, Seung-gyu; L'Huillier, Benjamin, Sejong Univ, Dept Phys \& Astron, 209 Neungdong Ro, Seoul 05006, South Korea.
   Hwang, Seung-gyu; Jee, M. James, Yonsei Univ, Dept Astron \& Space Sci, 50 Yonsei Ro, Seoul 03722, South Korea.
   Keeley, Ryan E.; Shafieloo, Arman, Korea Astron \& Space Sci Inst, 776 Daedeok Daero, Daejeon 34055, South Korea.
   Keeley, Ryan E., Univ Calif Merced, Dept Phys, 5200 North Lake Rd, Merced, CA 95343 USA.
   Shafieloo, Arman, Univ Sci \& Technol, 217 Gajeong Ro, Daejeon 34113, South Korea.},
DOI = {10.1088/1475-7516/2023/02/014},
Article-Number = {014},
Keywords = {Bayesian reasoning; Machine learning; Statistical sampling techniques;
   supernova type Ia - standard candles},
Keywords-Plus = {EXPANSION HISTORY; UNIVERSE; CONSTRAINTS},
