   Mohammed, Kamel K.; Hassanien, Aboul Ella; Afify, Heba M., Sci Res Grp Egypt SRGE, Cairo, Egypt.},
DOI = {10.1007/s10278-022-00617-8},
EarlyAccessDate = {MAR 2022},
Keywords = {Ear imagery database; Convolutional neural networks (CNN);
   Hyperparameters; Bayesian Optimization; Long short-term memory (LSTM)},
Keywords-Plus = {OTITIS-MEDIA DIAGNOSIS; PEDIATRICIANS; MANAGEMENT; ACCURACY},
