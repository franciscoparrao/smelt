@article{ WOS:001539792600005,
Author = {Elshaarawy, Mohamed Kamel and Zelenakova, Martina and Armanuos, Asaad M.},
Title = {Hydraulic Performance Modeling of Inclined Double Cutoff Walls Beneath
   Hydraulic Structures Using Optimized Ensemble Machine Learning},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {15},
Number = {1},
Month = {JUL 29},
Abstract = {This study investigates the effectiveness of inclined double cutoff
   walls installed beneath hydraulic structures by employing five machine
   learning models: Random Forest (RF), Adaptive Boosting (AdaBoost),
   eXtreme Gradient Boosting (XGBoost), Light Gradient Boosting Machine
   (LightGBM), and Categorical Boosting (CatBoost). A comprehensive dataset
   of 630 samples was gathered from previous studies, including key input
   variables such as the relative distance between the cutoff wall and the
   structure's apron width (L/B), the inclination angle ratio between
   downstream and upstream cutoffs (theta 2/theta 1), the depth ratio of
   downstream to upstream cutoff walls (d2/d1), and the relative downstream
   cutoff depth to the permeable layer depth (d2/D). Outputs considered
   were the relative uplift force (U/Uo), the relative exit hydraulic
   gradient (iR/iRo), and the relative seepage discharge per unit structure
   length (q/qo). The dataset was split with a 70:30 ratio for training and
   testing. Hyperparameter optimization was conducted using Bayesian
   Optimization (BO) coupled with five-fold cross-validation to enhance
   model performance. Results showed that the CatBoost model demonstrated
   superior performance over other models, consistently yielding high R2
   values, specifically surpassing 0.95, 0.93, and 0.97 for U/Uo, iR/iRo,
   and q/qo, respectively, along with low RMSE scores below 0.022, 0.089,
   and 0.019 for the same variables. A feature importance analysis is
   conducted using SHapley Additive exPlanations (SHAP) and Partial
   Dependence Plot (PDP). The analysis revealed that L/B was the most
   influential predictor for U/Uo and iR/iRo, while d2/D played a crucial
   role in determining q/qo. Moreover, PDPs illustrated a positive linear
   relationship between L/B and U/Uo, a V-shaped impact of d2/d1 on iR/iRo
   and q/qo, and complex nonlinear interactions for theta 2/theta 1 across
   all target variables. Furthermore, an interactive Graphical User
   Interface (GUI) was developed, enabling engineers to efficiently predict
   output variables and apply model insights in practical scenarios.},
Type = {Article},
Affiliation = {Elshaarawy, MK (Corresponding Author), Horus Univ Egypt, Fac Engn, Civil Engn Dept, New Damietta 34517, Egypt.
   Armanuos, AM (Corresponding Author), Tanta Univ, Fac Engn, Irrigat \& Hydraul Engn Dept, Tanta 31733, Egypt.
   Elshaarawy, Mohamed Kamel, Horus Univ Egypt, Fac Engn, Civil Engn Dept, New Damietta 34517, Egypt.
   Zelenakova, Martina, Tech Univ Kosice, Inst Environm Engn, Fac Civil Engn, Kosice 04200, Slovakia.
   Armanuos, Asaad M., Tanta Univ, Fac Engn, Irrigat \& Hydraul Engn Dept, Tanta 31733, Egypt.},
DOI = {10.1038/s41598-025-10990-3},
Article-Number = {27592},
Keywords = {Hydraulic structure design; Cutoff walls; Machine learning models;
   Uplift force control; Seepage discharge prediction; Feature importance
   analysis},
Keywords-Plus = {UPLIFT PRESSURE; COEFFICIENT; LOCATION; ANGLE},
Author-Email = {melshaarawy@horus.edu.eg
   asaad.matter@f-eng.tanta.edu.eg},
Number-of-Cited-References = {79},
Times-Cited = {13},
