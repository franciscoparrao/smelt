DOI = {10.3390/app14062554},
Article-Number = {2554},
Keywords = {steel hardenability; Bayesian optimization; k-fold cross-validation;
   hyperparameter tuning; neural network regression; steel alloy;
   predictive model; heat treatment; hardenability band; Jominy end-quench},
Keywords-Plus = {PREDICTION},
