   Pal, Saurabh; Mitra, Madhuchhanda, Univ Calcutta, Dept Appl Phys, Kolkata, W Bengal, India.},
DOI = {10.1016/j.displa.2022.102213},
Article-Number = {102213},
Keywords = {Diabetic Maculopathy; Hard exudates; Multi-class; Multi-layer stacking;
   Soft exudates},
