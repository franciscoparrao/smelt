   Solera-Rico, Alberto; Nieto-Centenero, Javier; Vila, Carlos Sanmiguel; Castellanos, Rodrigo, Univ Carlos III De Madrid, Dept Aerosp Engn, Leganes, Spain.},
DOI = {10.1063/5.0232644},
