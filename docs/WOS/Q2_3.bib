   decomposition; Bayesian optimization; wind speed; wave height;
   artificial intelligence; design optimization; design theory and
   methodology; machine learning; multidisciplinary design and
   optimization; wind energy},
Keywords-Plus = {WIND-SPEED; OPTIMIZATION; DESIGN; LAGS},
