@article{ WOS:000540720800018,
Author = {Ucar, Ferhat and Korkmaz, Deniz},
Title = {COVIDiagnosis-Net: Deep Bayes-SqueezeNet based diagnosis of the
   coronavirus disease 2019 (COVID-19) from X-ray images},
Journal = {MEDICAL HYPOTHESES},
Year = {2020},
Volume = {140},
Month = {JUL},
Abstract = {The Coronavirus Disease 2019 (COVID-19) outbreak has a tremendous impact
   on global health and the daily life of people still living in more than
   two hundred countries. The crucial action to gain the force in the fight
   of COVID-19 is to have powerful monitoring of the site forming infected
   patients. Most of the initial tests rely on detecting the genetic
   material of the coronavirus, and they have a poor detection rate with
   the time-consuming operation. In the ongoing process, radiological
   imaging is also preferred where chest X-rays are highlighted in the
   diagnosis. Early studies express the patients with an abnormality in
   chest X-rays pointing to the presence of the COVID-19. On this
   motivation, there are several studies cover the deep learning-based
   solutions to detect the COVID-19 using chest X-rays. A part of the
   existing studies use non-public datasets, others perform on complicated
   Artificial Intelligent (AI) structures. In our study, we demonstrate an
   AI-based structure to outperform the existing studies. The SqueezeNet
   that comes forward with its light network design is tuned for the
   COVID-19 diagnosis with Bayesian optimization additive. Fine-tuned
   hyperparameters and augmented dataset make the proposed network perform
   much better than existing network designs and to obtain a higher
   COVID-19 diagnosis accuracy.},
Type = {Article},
Affiliation = {Ucar, F (Corresponding Author), Firat Univ, Fac Technol, Dept Elect \& Elect Engn, TR-23119 Elazig, Turkey.
   Ucar, Ferhat, Firat Univ, Fac Technol, Dept Elect \& Elect Engn, TR-23119 Elazig, Turkey.
   Korkmaz, Deniz, Malatya Turgut Ozal Univ, Fac Engn \& Nat Sci, Dept Elect Engn, TR-44210 Malatya, Turkey.},
DOI = {10.1016/j.mehy.2020.109761},
Article-Number = {109761},
Keywords = {Coronavirus Disease 2019; SARS-CoV-2; Rapid Diagnosis of COVID-19; Deep
   Learning; Bayesian Optimization},
Keywords-Plus = {CLASSIFICATION; WUHAN},
Author-Email = {fucar@firat.edu.tr},
Number-of-Cited-References = {36},
Times-Cited = {460},
Unique-ID = {WOS:000540720800018},
}

@incollection{ WOS:000455787300161,
Author = {Golovin, Daniel and Solnik, Benjamin and Moitra, Subhodeep and
   Kochanski, Greg and Karro, John and Sculley, D.},
Book-Group-Author = {ACM},
Title = {Google Vizier: A Service for Black-Box Optimization},
Booktitle = {KDD'17: PROCEEDINGS OF THE 23RD ACM SIGKDD INTERNATIONAL CONFERENCE ON
   KNOWLEDGE DISCOVERY AND DATA MINING},
Year = {2017},
Pages = {1487-1496},
Abstract = {Any sufficiently complex system acts as a black box when it becomes
   easier to experiment with than to understand. Hence, black-box
   optimization has become increasingly important as systems have become
   more complex. In this paper we describe Google Vizier, a Google-internal
   service for performing black-box optimization that has become the de
   facto parameter tuning engine at Google. Google Vizier is used to
   optimize many of our machine learning models and other systems, and also
   provides core capabilities to Google's Cloud Machine Learning HyperTune
   subsystem. We discuss our requirements, infrastructure design,
   underlying algorithms, and advanced features such as transfer learning
   and automated early stopping that the service provides.},
Type = {Proceedings Paper},
Affiliation = {Golovin, D (Corresponding Author), Google Res, Mountain View, CA 94043 USA.
   Golovin, Daniel; Solnik, Benjamin; Moitra, Subhodeep; Kochanski, Greg; Karro, John; Sculley, D., Google Res, Mountain View, CA 94043 USA.},
