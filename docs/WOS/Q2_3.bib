   torbjorn.eltoft@uit.no
   marit.reigstad@uit.no},
Number-of-Cited-References = {73},
Times-Cited = {20},
Unique-ID = {WOS:000659548900008},
}

@article{ WOS:000476652500028,
Author = {Nakamura, Ippei and Kanemura, Atsunori and Nakaso, Takumi and Yamamoto,
   Ryuta and Fukuhara, Takeshi},
Title = {Non-standard trajectories found by machine learning for evaporative
   cooling of 87Rb atoms},
Journal = {OPTICS EXPRESS},
Year = {2019},
Volume = {27},
Number = {15},
Pages = {20435-20443},
Month = {JUL 22},
Abstract = {We present a machine-learning experiment involving evaporative cooling
   of gaseous Rb-87 atoms. The evaporation trajectory was optimized to
   maximize the number of atoms cooled down to a Bose-Einstein condensate
   using Bayesian optimization. After 300 trials within 3 hours, Bayesian
   optimization discovered trajectories that achieved atom numbers
   comparable with those of manual tuning by a human expert. Analysis of
   the machine-learned trajectories revealed minimum requirements for
   successful evaporative cooling. We found that the manually obtained
   curve and the machine-learned trajectories were quite similar in terms
   of evaporation efficiency, although the manual and machine-learned
   evaporation ramps were significantly different. (C) 2019 Optical Society
   of America under the terms of the OSA Open Access Publishing},
Type = {Article},
Affiliation = {Fukuhara, T (Corresponding Author), RIKEN Ctr Emergent Matter Sci CEMS, Wako, Saitama 3510198, Japan.
   Nakamura, Ippei; Yamamoto, Ryuta; Fukuhara, Takeshi, RIKEN Ctr Emergent Matter Sci CEMS, Wako, Saitama 3510198, Japan.
