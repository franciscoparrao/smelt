DOI = {10.1007/s10115-023-01935-1},
EarlyAccessDate = {AUG 2023},
Keywords = {AutoML; Algorithm selection; Hyper-parameter optimisation; Neural
   architecture search; Workflow composition; Systematic literature review},
Keywords-Plus = {NEURAL-ARCHITECTURE-SEARCH; PARTICLE SWARM OPTIMIZATION; ALGORITHM
   SELECTION; GENETIC ALGORITHM; HYPERPARAMETER OPTIMIZATION; BAYESIAN
   OPTIMIZATION; FEATURE CONSTRUCTION; EVOLUTIONARY SEARCH; MODEL
   SELECTION; TIME-SERIES},
