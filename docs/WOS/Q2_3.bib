   Bakir, Halit, Sivas Univ Sci \& Technol, Fac Engn \& Nat Sci, Dept Comp Engn, Sivas, Turkiye.},
DOI = {10.1007/s13369-023-07917-3},
EarlyAccessDate = {MAY 2023},
Keywords = {Sandwich structure; Cutout effects; Free vibration; Machine learning;
