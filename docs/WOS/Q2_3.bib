   Zhang, Miao; Pan, Shirui, Monash Univ, Fac Informat Technol, Melbourne, Vic 3800, Australia.
   Lyu, Juan, Harbin Engn Univ, Informat \& Commun Engn, Harbin 150001, Peoples R China.},
DOI = {10.1109/TEVC.2021.3060833},
Keywords = {Optimization; Kernel; Neural networks; Lung; Feature extraction;
   Gaussian processes; Convolutional neural networks; AutoML; evolutionary
   algorithm; hyperparameter optimization; lung nodule classification;
   nonstationary kernel},
Keywords-Plus = {IMAGE DATABASE CONSORTIUM; MALIGNANCY; LIDC},
Author-Email = {miaozhang1991@gmail.com
