DOI = {10.1016/j.ijheatmasstransfer.2022.123420},
EarlyAccessDate = {OCT 2022},
Article-Number = {123420},
Keywords = {XPINN; PINN; Deep learning; Thermal resistance; Multiphase materials},
Keywords-Plus = {INFORMED NEURAL-NETWORKS; DEEP LEARNING TECHNIQUES},
