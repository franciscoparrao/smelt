}

@article{ WOS:000468234400009,
Author = {Xu, Yue and Yin, Feng and Xu, Wenjun and Lin, Jiaru and Cui, Shuguang},
Title = {Wireless Traffic Prediction With Scalable Gaussian Process: Framework,
   Algorithms, and Verification},
Journal = {IEEE JOURNAL ON SELECTED AREAS IN COMMUNICATIONS},
Year = {2019},
Volume = {37},
Number = {6},
Pages = {1291-1306},
Month = {JUN},
Abstract = {The cloud radio access network (C-RAN) is a promising paradigm to meet
   the stringent requirements of the fifth generation (SG) wireless
   systems. Meanwhile, the wireless traffic prediction is a key enabler for
   C-RANs to improve both the spectrum efficiency and energy efficiency
   through load-aware network managements. This paper proposes a scalable
   Gaussian process (GP) framework as a promising solution to achieve
   large-scale wireless traffic prediction in a cost-efficient manner. Our
   contribution is three-fold. First, to the hest of our knowledge, this
   paper is the first to empower GP regression with the alternating
   direction method of multipliers (ADMM) for parallel hyper-parameter
   optimization in the training phase, where such a scalable training
   framework well balances the local estimation in baseband units (BBUs)
   and information consensus among BBUs in a principled way for large-scale
   executions. Second, in the prediction phase, we fuse local predictions
   obtained from the BBUs via a cross-validation-based optimal strategy,
   which demonstrates itself to be reliable and robust for general
   regression tasks. Moreover, such a cross-validation-based optimal fusion
   strategy is built upon a well acknowledged probabilistic model to retain
   the valuable closed-form GP inference properties. Third, we propose a
   C-RAN-based scalable wireless prediction architecture, where the
   prediction accuracy and the time consumption can be balanced by tuning
   the number of the BBUs according to the real-time system demands. The
   experimental results show that our proposed scalable GP model can
   outperform the state-of-the-art approaches considerably, in terms of
   wireless traffic prediction performance.},
Type = {Article},
Affiliation = {Xu, WJ (Corresponding Author), Beijing Univ Posts \& Telecommun, Key Lab Universal Wireless Commun, Minist Educ, Beijing 100876, Peoples R China.
   Yin, F (Corresponding Author), Chinese Univ Hong Kong, Hong Kong, Peoples R China.
   Xu, Yue; Xu, Wenjun; Lin, Jiaru, Beijing Univ Posts \& Telecommun, Key Lab Universal Wireless Commun, Minist Educ, Beijing 100876, Peoples R China.
   Yin, Feng, Chinese Univ Hong Kong, Hong Kong, Peoples R China.
   Yin, Feng, Shenzhen Res Inst Big Data, Shenzhen 518172, Peoples R China.
   Cui, Shuguang, Univ Calif Davis, Dept Elect \& Comp Engn, Davis, CA 95616 USA.
   Cui, Shuguang, Chinese Univ Hong Kong, Sch Sci \& Engn, Shenzhen Res Inst Big Data, Hong Kong, Peoples R China.},
DOI = {10.1109/JSAC.2019.2904330},
Keywords = {C-RANs; Gaussian processes; parallel processing; ADMM; cross-validation;
   machine learning; wireless traffic},
Keywords-Plus = {MODELS},
Author-Email = {xuy@bupt.edu.cn
   yinfeng@cuhk.edu.cn
   wjxu@bupt.edu.cn
