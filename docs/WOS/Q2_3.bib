Unique-ID = {WOS:000780583000001},
}

@incollection{ WOS:000458973702054,
Author = {Wu, Jian and Frazier, I, Peter},
Editor = {Lee, DD and Sugiyama, M and Luxburg, UV and Guyon, I and Garnett, R},
Title = {The Parallel Knowledge Gradient Method for Batch Bayesian Optimization},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 29 (NIPS 2016)},
Series = {Advances in Neural Information Processing Systems},
Year = {2016},
Volume = {29},
Abstract = {In many applications of black-box optimization, one can evaluate
   multiple points simultaneously, e.g. when evaluating the performances of
   several different neural networks in a parallel computing environment.
   In this paper, we develop a novel batch Bayesian optimization algorithm
   - the parallel knowledge gradient method. By construction, this method
   provides the one-step Bayes optimal batch of points to sample. We
   provide an efficient strategy for computing this Bayes-optimal batch of
   points, and we demonstrate that the parallel knowledge gradient method
   finds global optima significantly faster than previous batch Bayesian
   optimization algorithms on both synthetic test functions and when tuning
   hyperparameters of practical machine learning algorithms, especially
   when function evaluations are noisy.},
Type = {Proceedings Paper},
Affiliation = {Wu, J (Corresponding Author), Cornell Univ, Ithaca, NY 14853 USA.
   Wu, Jian; Frazier, Peter, I, Cornell Univ, Ithaca, NY 14853 USA.},
Author-Email = {jw926@cornell.edu},
