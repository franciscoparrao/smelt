   Yang, Ling, Nanjing Normal Univ, Sch Geog, Nanjing 210023, Peoples R China.
   Xiang, Xuekun, Chongqing Inst Geol \& Mineral Resources, Minist Nat Resources, Technol Innovat Ctr Geohazards Automat Monitoring, Chongqing 401120, Peoples R China.},
DOI = {10.1016/j.eswa.2023.122682},
EarlyAccessDate = {NOV 2023},
Article-Number = {122682},
Keywords = {Flood hazard mapping; Random forest; Hyperparameteroptimization; SHAP;
   Robust},
Keywords-Plus = {REMOTE-SENSING DATA; SPATIAL PREDICTION; RISK-ASSESSMENT; SUSCEPTIBILITY
   ASSESSMENT; CONDITIONING FACTORS; REGRESSION; RESOLUTION; BIVARIATE;
   COUNTY; CHINA},
