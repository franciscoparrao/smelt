   Huri, David; Mankovits, Tamas, Univ Debrecen, Fac Engn, Dept Mech Engn, Otemet U 2-4, H-4028 Debrecen, Hungary.},
DOI = {10.3390/app12115451},
Article-Number = {5451},
Keywords = {finite element analysis; hyperelastic material model; support vector
   regression; engineering optimization; simulated annealing; parameter
   tuning},
