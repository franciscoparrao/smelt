DOI = {10.3390/w10101428},
Article-Number = {1428},
Keywords = {shallow lake; Chl-a; CDOM; TSM; Gaussian process regression; automatic
   model selection algorithm},
Keywords-Plus = {MERIS; VALIDATION; PHYTOPLANKTON; ALGORITHMS; REGRESSION; RETRIEVAL;
