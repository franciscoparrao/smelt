   Alshehri, Sameer, Taif Univ, Coll Pharm, Dept Pharmaceut \& Ind Pharm, POB 11099, Taif 21944, Saudi Arabia.},
DOI = {10.1016/j.engappai.2023.106910},
EarlyAccessDate = {AUG 2023},
