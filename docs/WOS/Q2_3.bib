DOI = {10.3390/rs14020264},
Article-Number = {264},
Keywords = {deep learning model; oil spill detection; polarization feature; SAR
   images},
Keywords-Plus = {AUTOMATIC DETECTION; CLASSIFICATION; IDENTIFICATION; POLARIZATION;
