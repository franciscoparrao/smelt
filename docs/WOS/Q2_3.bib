   Abioui, Mohamed, Univ Coimbra, Fac Sci \& Technol, MARE Marine \& Environm Sci Ctr Sedimentary Geol Gr, Dept Earth Sci, Coimbra, Portugal.},
DOI = {10.1016/j.aej.2025.03.022},
