}

@article{ WOS:000702805800005,
Author = {Taherdangkoo, Reza and Liu, Quan and Xing, Yixuan and Yang, Huichen and
   Viet Cao and Sauter, Martin and Butscher, Christoph},
Title = {Predicting methane solubility in water and seawater by machine learning
   algorithms: Application to methane transport modeling},
Journal = {JOURNAL OF CONTAMINANT HYDROLOGY},
Year = {2021},
Volume = {242},
Month = {OCT},
Abstract = {The upward migration of methane from natural gas wells associated with
   fracking operations may lead to contamination of groundwater resources
   and surface leakage. Numerical simulations of methane transport in the
   subsurface environment require knowledge of methane solubility in the
   aqueous phase. This study employs machine learning (ML) algorithms to
   predict methane solubility in aquatic systems for temperatures ranging
   from 273.15 to 518.3 K and pressures ranging from 1 to 1570 bar. Four
   regression algorithms including regression tree (RT), boosted regression
   tree (BRT), least square support vector machine (LSSVM) and Gaussian
   process regression (GPR) were utilized for predicting methane solubility
   in pure water and mixed aquatic systems containing Na+, K+, Ca2+,
   Mg2+,Cl-, and SO4-2. The experimental data collected from the literature
   were used to implement the models. We used Grid search (GS), Random
   search (RS) and Bayesian optimization (BO) for tuning hyper-parameters
   of the ML models. Moreover, the predicted values of methane solubility
   were compared against Spivey et al. (2004) and Duan and Mao (2006)
   equations of state. The results show that the BRT-BO model is the most
   rigorous model for the prediction task. The coefficient of determination
   (R-2) between experimental and predicted values is 0.99 and the mean
   squared error (MSE) is 1.19 x 10(-7). The performance of the BRT-BO
   model is satisfactory, showing an acceptable agreement with experimental
   data. The comparison results demonstrated the superior performance of
   the BRT-BO model for predicting methane solubility in aquatic systems
   over a span of temperature, pressure and ionic strength that occurs in
   deep marine environments.},
Type = {Article},
Affiliation = {Taherdangkoo, R (Corresponding Author), TU Bergakad Freiberg, Inst Geotech, Gustav Zeuner Str 1, D-09599 Freiberg, Germany.
   Taherdangkoo, Reza; Butscher, Christoph, TU Bergakad Freiberg, Inst Geotech, Gustav Zeuner Str 1, D-09599 Freiberg, Germany.
   Liu, Quan; Xing, Yixuan; Yang, Huichen; Sauter, Martin, Univ Gottingen, Geosci Ctr, Dept Appl Geol, Goldschmidtstr 3, D-37077 Gottingen, Germany.
   Viet Cao, Hung Vuong Univ, Fac Nat Sci, Nguyen Tat Thanh Str, Viet Tri 35120, Phu Tho, Vietnam.},
DOI = {10.1016/j.jconhyd.2021.103844},
EarlyAccessDate = {JUN 2021},
Article-Number = {103844},
Keywords = {Methane; Solubility; Groundwater; Seawater; Machine learning; Equation
   of state},
Keywords-Plus = {GAUSSIAN-PROCESSES; GAS SOLUBILITY; SALT SOLUTIONS; TEMPERATURES;
   MIXTURES; PRESSURE; DENSITY; LIQUIDS; FIELD; HYDROCARBONS},
Author-Email = {reza.Taherdangkoo@ifgt.tu-freiberg.de},
