@article{ WOS:000788739200005,
Author = {Mittendorf, Malte and Nielsen, Ulrik D. and Bingham, Harry B.},
Title = {Data-driven prediction of added-wave resistance on ships in oblique
   waves-A comparison between tree-based ensemble methods and artificial
   neural networks},
Journal = {APPLIED OCEAN RESEARCH},
Year = {2022},
Volume = {118},
Month = {JAN},
Abstract = {The present paper implements machine learning methods for the prediction
   of the added-wave resistance of ships in head to beam wave conditions.
   The study is focused on non-linear regression algorithms namely Random
   Forests, Extreme Gradient Boosting Machines and Multilayer Perceptrons.
   The employed dataset is derived from results of three different
   potential flow methods covering a wide range of operational conditions
   and 18 hull forms in total. The rational data preprocessing makes up the
   core part of the paper having its focal point on practical application.
   Moreover, a rigorous hyperparameter study based on Bayesian optimization
   is conducted, and the validation of the final models for three case
   studies against numerical and experimental data as well as two
   established prediction techniques shows satisfactory generalization in
   case of the neural network. The tree-based ensemble methods, on the
   other hand, are not able to generalize sufficiently from the given
   parameter discretization of the underlying dataset.},
Type = {Article},
Affiliation = {Mittendorf, M (Corresponding Author), Tech Univ Denmark, DTU Mech Engn, DK-2800 Lyngby, Denmark.
   Mittendorf, Malte; Nielsen, Ulrik D.; Bingham, Harry B., Tech Univ Denmark, DTU Mech Engn, DK-2800 Lyngby, Denmark.
   Nielsen, Ulrik D., NTNU Ctr Autonomous Marine Operat \& Syst, N-7052 Trondheim, Norway.},
DOI = {10.1016/j.apor.2021.102964},
Article-Number = {102964},
Keywords = {Ship hydrodynamics; Added-wave resistance; Machine learning; Tree-based
   ensemble methods; Artificial neural networks},
Keywords-Plus = {KVLCC2},
