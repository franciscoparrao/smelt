}

@article{ WOS:001134684900001,
Author = {Xu, Liuliu and Fan, Dingqiang and Liu, Kangning and Xu, Wangyang and Yu,
   Rui},
Title = {A machine learning framework for intelligent development of Ultra-High
   performance concrete (UHPC): From dataset cleaning to performance
   predicting},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2024},
Volume = {242},
Month = {MAY 15},
Abstract = {This study proposes a new machine learning (ML) framework, which mainly
   includes dataset cleaning processing as well as performance predicting,
   for property prediction of ultra-high performance concrete (UHPC).
   Firstly, the missing data in original dataset is interpolated and
   discussed by visualization results. Then, the existing outliers in the
