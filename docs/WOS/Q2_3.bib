   Puchalski, Michael, Johns Hopkins All Childrens Hosp, Heart Inst, Div Cardiol, St Petersburg, FL USA.
   Smith, Andrew, Johns Hopkins All Childrens Hosp, Heart Inst, Div Cardiac Crit Care, St Petersburg, FL USA.
   Ashfaq, Awais, Johns Hopkins All Childrens Hosp, Cardiovasc Surg, Heart Insitute, St Petersburg, FL 33701 USA.},
DOI = {10.1016/j.healun.2023.06.006},
EarlyAccessDate = {SEP 2023},
Keywords = {pediatric heart transplantation; machine learning; survival},
Keywords-Plus = {PREDICTION},
