Affiliation = {Lahmiri, S (Corresponding Author), Concordia Un, John Molson Sch Business, Dept Supply Chain \& Business Technol Management, Montreal, PQ, Canada.
   Lahmiri, Salim, Concordia Un, John Molson Sch Business, Dept Supply Chain \& Business Technol Management, Montreal, PQ, Canada.},
DOI = {10.1016/j.bspc.2022.104375},
