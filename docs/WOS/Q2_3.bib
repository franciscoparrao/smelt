   Karim, Sarkhel H. Taher, Univ Halabja, Coll Sci, Comp Sci Dept, Halabja, Kurdistan Regio, Iraq.},
DOI = {10.1016/j.tafmec.2023.103876},
EarlyAccessDate = {MAR 2023},
