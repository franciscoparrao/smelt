   Hassan, Ahmed M., Future Univ Egypt, Mech Engn, New Cairo 11835, Egypt.
   Farooq, Furqan, Minist Def MoD, Mil Engineer Serv MES, Rawalpindi 43600, Pakistan.},
DOI = {10.1016/j.jmrt.2023.06.007},
