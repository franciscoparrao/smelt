   Li, Ling, Ningbo Univ Technol, Vehicle Energy \& Safety Lab, Ningbo, Peoples R China.
   Li, Ling, Ningbo Univ Technol, Dept Mech Engn, Ningbo 315336, Peoples R China.},
DOI = {10.1002/ese3.1678},
EarlyAccessDate = {JAN 2024},
Keywords = {Bayesian optimization; Gaussian process regression; Gray relational
   analysis; minorly deformed battery; state of health},
Keywords-Plus = {USEFUL LIFE PREDICTION; OF-HEALTH; MODEL},
Author-Email = {lingl@nbut.edu.cn},
