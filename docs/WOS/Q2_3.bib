}

@article{ WOS:000658671600004,
Author = {Morabito, Alessandro and Vagnoni, Elena and Di Matteo, Mariano and
   Hendrick, Patrick},
Title = {Numerical investigation on the volute cutwater for pumps running in
   turbine mode},
Journal = {RENEWABLE ENERGY},
Year = {2021},
Volume = {175},
Pages = {807-824},
Month = {SEP},
Abstract = {The hydropower sector has recently raised the interest in pump as
   turbine (PaT) that can be a valid trade-off between capital cost and
   performance in micro-scale installations. Nevertheless, the modest
   efficiency of PaTs often restricts their exploitation. In this paper,
   available experimental data are used to tune a numerical model which
   aims to investigate the effect of the pump cutwater design on the PaT
   performance to improve the hydraulic efficiency. Because of its finite
   thickness, the cutwater interferes with the flow at the runner inlet,
   and generates local flaws in the velocity field such as swirl and
   deviations of the streamlines which limit the machine performance. To
   identify the geometrical characteristics of the cutwater impacting on
   the PaT performances, different values of stretching and thickness of
   the cutwater are studied at variable inclination by computational fluid
   dynamics (CFD) simulations. A multivariate regression method is applied
   on the CFD results to build a surrogate model of the PaT hydraulic
   characteristics as a function of the geometrical parameters of the
   machine cutwater. Based on this model, an optimization problem is solved
   to identify the most advantageous geometrical asset of the PaT cutwater
   to maximize the efficiency. The results highlight that the length and
   the cutwater angle are the most affecting variables in favouring a
   tangential component at the entrance of the runner. The hydraulic
   efficiency peak of the optimized geometry results to be 86.3\%, while
   the baseline configuration records an efficiency of 82.4\%, and the Psi
   - phi characteristic moves the best efficiency point towards higher head
   (+7.5\%) and lower discharge (-13.0\%). The proposed methodology allows
   identifying the best geometrical characteristics of the PaT cutwater to
   maximize the performances while significantly reducing the computational
   time. (C) 2021 Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Morabito, A; Hendrick, P (Corresponding Author), Univ Libre Bruxelles ULB, Aerothermomech Dept, Brussels, Belgium.
   Morabito, Alessandro; Di Matteo, Mariano; Hendrick, Patrick, Univ Libre Bruxelles ULB, Aerothermomech Dept, Brussels, Belgium.
   Vagnoni, Elena, Ecole Polytech Fed Lausanne EPFL, Lab Hydraul Machines, Lausanne, Switzerland.},
DOI = {10.1016/j.renene.2021.04.112},
EarlyAccessDate = {MAY 2021},
Keywords = {Pump as turbine; Computational fluid dynamic; Optimization; Hydraulic
   efficiency},
Keywords-Plus = {CENTRIFUGAL PUMPS; HYDROPOWER; PERFORMANCE; ENERGY; GENERATION;
   PREDICTION; IMPELLER; DESIGN},
Author-Email = {alessandro.morabito@ulb.be
   patrick.hendrick@ulb.be},
Number-of-Cited-References = {78},
Times-Cited = {35},
Unique-ID = {WOS:000658671600004},
}

@incollection{ WOS:000667722805041,
Author = {Dang Nguyen and Gupta, Sunil and Rana, Santu and Shilton, Alistair and
   Venkatesh, Svetha},
Book-Group-Author = {Assoc Advancement Artificial Intelligence},
Title = {Bayesian Optimization for Categorical and Category-Specific Continuous
   Inputs},
Booktitle = {THIRTY-FOURTH AAAI CONFERENCE ON ARTIFICIAL INTELLIGENCE, THE
   THIRTY-SECOND INNOVATIVE APPLICATIONS OF ARTIFICIAL INTELLIGENCE
   CONFERENCE AND THE TENTH AAAI SYMPOSIUM ON EDUCATIONAL ADVANCES IN
   ARTIFICIAL INTELLIGENCE},
Series = {AAAI Conference on Artificial Intelligence},
Year = {2020},
Volume = {34},
Pages = {5256-5263},
Abstract = {Many real-world functions are defined over both categorical and
   category-specific continuous variables and thus cannot be optimized by
   traditional Bayesian optimization (BO) methods. To optimize such
   functions, we propose a new method that formulates the problem as a
   multi-armed bandit problem, wherein each category corresponds to an arm
   with its reward distribution centered around the optimum of the
   objective function in continuous variables. Our goal is to identify the
   best arm and the maximizer of the corresponding continuous function
   simultaneously. Our algorithm uses a Thompson sampling scheme that helps
   connecting both multi-arm bandit and BO in a unified framework. We
   extend our method to batch BO to allow parallel optimization when
   multiple resources are available. We theoretically analyze our method
   for convergence and prove sub-linear regret bounds. We perform a variety
   of experiments: optimization of several benchmark functions.
   hyper-parameter tuning of a neural network, and automatic selection of
   the best machine learning model along with its optimal hyper-parameters
   (a.k.a automated machine learning). Comparisons with other methods
   demonstrate the effectiveness of our proposed method.},
Type = {Proceedings Paper},
Affiliation = {Nguyen, D (Corresponding Author), Deakin Univ, Appl Artificial Intelligence Inst A2I2, Geelong, Vic, Australia.
   Dang Nguyen; Gupta, Sunil; Rana, Santu; Shilton, Alistair; Venkatesh, Svetha, Deakin Univ, Appl Artificial Intelligence Inst A2I2, Geelong, Vic, Australia.},
Keywords-Plus = {EFFICIENT GLOBAL OPTIMIZATION; BANDIT},
Author-Email = {d.nguyen@deakin.edu.au
   sunil.gupta@deakin.edu.au
   santu.rana@deakin.edu.au
   alistair.shilton@deakin.edu.au
   svetha.venkatesh@deakin.edu.au},
Number-of-Cited-References = {26},
Times-Cited = {35},
Unique-ID = {WOS:000667722805041},
}

@article{ WOS:000490730400007,
Author = {Wang, Zhi-Lei and Ogawa, Toshio and Adachi, Yoshitaka},
Title = {Influence of Algorithm Parameters of Bayesian Optimization, Genetic
   Algorithm, and Particle Swarm Optimization on Their Optimization
   Performance},
Journal = {ADVANCED THEORY AND SIMULATIONS},
Year = {2019},
Volume = {2},
Number = {10},
Month = {OCT},
Abstract = {In response to modern materials research, a data-driven
   properties-to-microstructure-to-processing inverse analysis is proposed
   for use in material design. In the present work, machine learning
   optimization algorithms of Bayesian optimization, genetic algorithm, and
   particle swarm optimization are used to perform inverse analysis with a
   maximum property search. The use of machine learning algorithms readily
   involves careful tuning of learning parameters, which is often carried
   out by a trial-and-error method requiring expert experience or general
   guidelines, and the choices of such parameters can play a critical role
   in attaining good optimization performance. Thus, the influence of
   various parameters on the optimization performance of the aforementioned
   algorithms are systematically investigated to provide a protocol for
   selecting adequate algorithm parameters for a given optimization problem
   in data-driven material design.},
Type = {Article},
Affiliation = {Adachi, Y (Corresponding Author), Nagoya Univ, Dept Mat Sci \& Engn, Chikusa Ku, Furo Cho, Nagoya, Aichi 4648601, Japan.
   Wang, Zhi-Lei; Ogawa, Toshio; Adachi, Yoshitaka, Nagoya Univ, Dept Mat Sci \& Engn, Chikusa Ku, Furo Cho, Nagoya, Aichi 4648601, Japan.},
DOI = {10.1002/adts.201900110},
Article-Number = {1900110},
Keywords = {Bayesian optimization; data-driven material design; genetic algorithm;
   inverse analysis; particle swarm optimization},
Keywords-Plus = {PROPERTY},
Author-Email = {adachi.yoshitaka@material.nagoya-u.ac.jp},
Number-of-Cited-References = {9},
