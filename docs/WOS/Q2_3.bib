Article-Number = {105519},
Keywords = {Microseismic events; Blasting events; Machine learning; Fuzzy
   comprehensive evaluation},
Keywords-Plus = {HYDROPOWER STATION; SEISMIC EVENTS; DISCRIMINATION; EXPLOSIONS; BLASTS;
