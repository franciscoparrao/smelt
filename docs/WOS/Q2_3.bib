Keywords = {Unmanned aerial vehicles (UAVs); Sensing enhancement; Fusion state space
   model; Multi-output Gaussian process regression (GPR)},
Keywords-Plus = {REMAINING USEFUL LIFE; PREDICTION; REGRESSION; NETWORK},
