@article{ WOS:000401392200013,
Author = {Yao, Chengwei and Cai, Deng and Bu, Jiajun and Chen, Gencai},
Title = {Pre-training the deep generative models with adaptive hyperparameter
   optimization},
Journal = {NEUROCOMPUTING},
Year = {2017},
Volume = {247},
Pages = {144-155},
Month = {JUL 19},
Abstract = {The performance of many machine learning algorithms depends crucially on
   the hyperparameter settings, especially in Deep Learning. Manually
   tuning the hyperparameters is laborious and time consuming. To address
   this issue, Bayesian optimization (BO) methods and their extensions have
   been proposed to optimize the hyperparameters automatically. However,
   they still suffer from highly computational expense when applying to
   deep generative models (DGMs) due to their strategy of the black-box
   function optimization. This paper provides a new hyperparameter
   optimization procedure at the pre-training phase of the DGMs, where we
   avoid combining all layers as one black-box function by taking advantage
   of the layer-by-layer learning strategy. Following this procedure, we
   are able to optimize multiple hyperparameters in an adaptive way by
   using Gaussian process. In contrast to the traditional BO methods, which
   mainly focus on the supervised models, the pre-training procedure is
   unsupervised where there is no validation error can be used. To
   alleviate this problem, this paper proposes a new holdout loss, the free
   energy gap, which takes into account both factors of the model fitting
   and over-fitting. The empirical evaluations demonstrate that our method
   not only speeds up the process of hyperparameter optimization, but also
   improves the performances of DGMs significantly in both the supervised
   and unsupervised learning tasks. (C) 2017 Elsevier B.V. All rights
   reserved.},
Type = {Article},
Affiliation = {Yao, CW (Corresponding Author), Zhejiang Univ, Coll Comp Sci \& Technol, Hangzhou, Zhejiang, Peoples R China.
   Yao, Chengwei; Bu, Jiajun; Chen, Gencai, Zhejiang Univ, Coll Comp Sci \& Technol, Hangzhou, Zhejiang, Peoples R China.
   Cai, Deng, Zhejiang Univ, Coll Comp Sci \& Technol, State Key Lab CAD\&CG, Hangzhou, Zhejiang, Peoples R China.},
DOI = {10.1016/j.neucom.2017.03.058},
Keywords = {Deep generative model; Hyperparameter optimization; Sequential
   model-based optimization; Contrastive divergence},
Author-Email = {yaochw@zju.edu.cn},
Number-of-Cited-References = {68},
Times-Cited = {38},
Unique-ID = {WOS:000401392200013},
}

@article{ WOS:000334256100014,
Author = {Bhattacharya, Anirban and Pati, Debdeep and Dunson, David},
Title = {ANISOTROPIC FUNCTION ESTIMATION USING MULTI-BANDWIDTH GAUSSIAN PROCESSES},
Journal = {ANNALS OF STATISTICS},
Year = {2014},
Volume = {42},
Number = {1},
Pages = {352-381},
Month = {FEB},
Abstract = {In nonparametric regression problems involving multiple predictors,
   there is typically interest in estimating an anisotropic multivariate
   regression surface in the important predictors while discarding the
   unimportant ones. Our focus is on defining a Bayesian procedure that
   leads to the minimax optimal rate of posterior contraction (up to a log
   factor) adapting to the unknown dimension and anisotropic smoothness of
   the true surface. We propose such an approach based on a Gaussian
   process prior with dimension-specific scalings, which are assigned
   carefully-chosen hyperpriors. We additionally show that using a
   homogenous Gaussian process with a single bandwidth leads to a
   sub-optimal rate in anisotropic cases.},
Type = {Article},
Affiliation = {Bhattacharya, A (Corresponding Author), Texas A\&M Univ, Dept Stat, College Stn, TX 77843 USA.
   Bhattacharya, Anirban, Texas A\&M Univ, Dept Stat, College Stn, TX 77843 USA.
   Pati, Debdeep, Florida State Univ, Dept Stat, Tallahassee, FL 32306 USA.
   Dunson, David, Duke Univ, Dept Stat Sci, Durham, NC 27708 USA.},
DOI = {10.1214/13-AOS1192},
Keywords = {Adaptive; anisotropic; Bayesian nonparametrics; function estimation;
   Gaussian process; rate of convergence},
Keywords-Plus = {BAYESIAN DENSITY-ESTIMATION; POSTERIOR DISTRIBUTIONS; VARIABLE
   SELECTION; CONVERGENCE-RATES; MODEL SELECTION; INFERENCE; BOUNDS},
Author-Email = {anirbanb@stat.tamu.edu
   debdeep@stat.fsu.edu
   dunson@stat.duke.edu},
Number-of-Cited-References = {36},
Times-Cited = {38},
