   Park, Geon Yeong; Ham, Dong Seok, Korea Res Inst Chem Technol KRICT, Chem Mat Solut Ctr, Daejeon 34114, South Korea.},
DOI = {10.1021/acsomega.3c05622},
Keywords-Plus = {METAL HALIDE PEROVSKITES; 2-STEP DEPOSITION; TRANSPORT LAYER; IDEALITY
