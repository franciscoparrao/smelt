   El Hmaidi, Abdellah, Moulay Ismail Univ, Dept Geol, Lab Water Sci \& Environm Engn, Fac Sci, BP 11201, Zitoune 11201, Meknes, Morocco.},
DOI = {10.14710/ijred.2022.41451},
Keywords = {Feature selection; Mean Decrease in Accuracy; Mean Decrease in Impurity;
