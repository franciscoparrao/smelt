@article{ WOS:000886578600001,
Author = {Hamza, Ameer and Khan, Muhammad Attique and Wang, Shui-Hua and
   Alhaisoni, Majed and Alharbi, Meshal and Hussein, Hany S. and Alshazly,
   Hammam and Kim, Ye Jin and Cha, Jaehyuk},
Title = {COVID-19 classification using chest X-ray images based on
   fusion-assisted deep Bayesian optimization and Grad-CAM visualization},
Journal = {FRONTIERS IN PUBLIC HEALTH},
Year = {2022},
Volume = {10},
Month = {NOV 4},
Abstract = {The COVID-19 virus's rapid global spread has caused millions of
   illnesses and deaths. As a result, it has disastrous consequences for
   people's lives, public health, and the global economy. Clinical studies
   have revealed a link between the severity of COVID-19 cases and the
   amount of virus present in infected people's lungs. Imaging techniques
   such as computed tomography (CT) and chest x-rays can detect COVID-19
   (CXR). Manual inspection of these images is a difficult process, so
   computerized techniques are widely used. Deep convolutional neural
   networks (DCNNs) are a type of machine learning that is frequently used
   in computer vision applications, particularly in medical imaging, to
   detect and classify infected regions. These techniques can assist
   medical personnel in the detection of patients with COVID-19. In this
   article, a Bayesian optimized DCNN and explainable AI-based framework is
   proposed for the classification of COVID-19 from the chest X-ray images.
   The proposed method starts with a multi-filter contrast enhancement
   technique that increases the visibility of the infected part. Two
   pre-trained deep models, namely, EfficientNet-B0 and MobileNet-V2, are
   fine-tuned according to the target classes and then trained by employing
   Bayesian optimization (BO). Through BO, hyperparameters have been
   selected instead of static initialization. Features are extracted from
   the trained model and fused using a slicing-based serial fusion
   approach. The fused features are classified using machine learning
   classifiers for the final classification. Moreover, visualization is
   performed using a Grad-CAM that highlights the infected part in the
   image. Three publically available COVID-19 datasets are used for the
   experimental process to obtain improved accuracies of 98.8, 97.9, and
   99.4\%, respectively.},
Type = {Article},
Affiliation = {Khan, MA (Corresponding Author), HITEC Univ, Dept Comp Sci, Taxila, Pakistan.
   Cha, JHY (Corresponding Author), Hanyang Univ, Dept Comp Sci, Seoul, South Korea.
   Hamza, Ameer; Khan, Muhammad Attique, HITEC Univ, Dept Comp Sci, Taxila, Pakistan.
   Wang, Shui-Hua, Univ Leicester, Dept Math, Leicester, England.
   Alhaisoni, Majed, Princess Nourah Bint Abdulrahman Univ, Coll Comp \& Informat Sci, Comp Sci Dept, Riyadh, Saudi Arabia.
   Alharbi, Meshal, Prince Sattam Bin Abdulaziz Univ, Coll Comp Engn \& Sci, Dept Comp Sci, Al Kharj, Saudi Arabia.
   Hussein, Hany S., King Khalid Univ, Coll Engn, Elect Engn Dept, Abha, Saudi Arabia.
   Hussein, Hany S., Aswan Univ, Fac Engn, Elect Engn Dept, Aswan, Egypt.
   Alshazly, Hammam, South Valley Univ, Fac Comp \& Informat, Qena, Egypt.
   Kim, Ye Jin; Cha, Jaehyuk, Hanyang Univ, Dept Comp Sci, Seoul, South Korea.},
DOI = {10.3389/fpubh.2022.1046296},
Article-Number = {1046296},
Keywords = {corona virus; multi-filters contrast enhancement; deep learning;
   Bayesian optimization; hyperparameters; fusion},
Keywords-Plus = {FEATURES},
Author-Email = {attique.khan@hitecuni.edu.pk
   chajh@hanyang.ac.kr},
Number-of-Cited-References = {48},
