   Ping, Ping, China Univ Petr East China, Coll Chem Engn, Qingdao 266580, Peoples R China.},
DOI = {10.1002/er.7548},
EarlyAccessDate = {DEC 2021},
Keywords = {Bayesian optimization; deep learning; Lithium-ion battery; remaining
   useful life; state-of-health},
Keywords-Plus = {CHARGE ESTIMATION; MODEL; PREDICTION; PROGNOSTICS; REGRESSION; NETWORK},
