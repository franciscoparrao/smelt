   Kanemura, Atsunori, LeapMind Inc, Tokyo 1500044, Japan.
   Nakamura, Ippei, Kanagawa Inst Ind Sci \& Technol KISTEC, Ebina, Kanagawa 2430435, Japan.},
DOI = {10.1364/OE.27.020435},
Keywords-Plus = {QUANTUM SIMULATIONS; OPTIMIZATION},
Author-Email = {takeshi.fukhara@riken.jp},
