   Sojka, Mariusz, Poznan Univ Life Sci, Dept Land Improvement Environm Dev \& Spatial Manag, Piatkowska 94E, PL-60649 Poznan, Poland.},
DOI = {10.1016/j.scitotenv.2023.164323},
EarlyAccessDate = {MAY 2023},
