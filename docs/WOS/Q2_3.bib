Keywords = {machine learning; Dst index; probabilistic forecasting; Gaussian
   process; space weather},
Keywords-Plus = {RING CURRENT; DST INDEX; CURRENT SYSTEMS; SOLAR; MODELS; PREDICTION;
   INJECTION; DECAY},
Author-Email = {mandar.chandorkar@cwi.nl},
Number-of-Cited-References = {47},
