@article{ WOS:000485694800004,
Author = {Purisha, Zenith and Jidlina, Carl and Wahlstrom, Niklas and Schon,
   Thomas B. and Sarkka, Simo},
Title = {Probabilistic approach to limited-data computed tomography
   reconstruction},
Journal = {INVERSE PROBLEMS},
Year = {2019},
Volume = {35},
Number = {10},
Month = {OCT},
Abstract = {In this work, we consider the inverse problem of reconstructing the
   internal structure of an object from limited x-ray projections. We use a
   Gaussian process (GP) prior to model the target function and estimate
   its (hyper)parameters from measured data. In contrast to other
   established methods, this comes with the advantage of not requiring any
   manual parameter tuning, which usually arises in classical
   regularization strategies. Our method uses a basis function expansion
   technique for the GP which significantly reduces the computational
   complexity and avoids the need for numerical integration. The approach
   also allows for reformulation of come classical regularization methods
   as Laplacian and Tikhonov regularization as GP regression, and hence
   provides an efficient algorithm and principled means for their parameter
   tuning. Results from simulated and real data indicate that this approach
   is less sensitive to streak artifacts as compared to the commonly used
   method of filtered backprojection.},
Type = {Article},
Affiliation = {Purisha, Z (Corresponding Author), Aalto Univ, Dept Elect Engn \& Automat, Espoo, Finland.
   Purisha, Zenith; Sarkka, Simo, Aalto Univ, Dept Elect Engn \& Automat, Espoo, Finland.
   Jidlina, Carl; Wahlstrom, Niklas; Schon, Thomas B., Uppsala Univ, Dept Informat Technol, Uppsala, Sweden.},
DOI = {10.1088/1361-6420/ab2e2a},
Article-Number = {105004},
Keywords = {x-ray tomography; probabilistic model; Gaussian processes; limited data;
   computed tomography},
Keywords-Plus = {X-RAY TOMOGRAPHY; STATISTICAL INVERSION; IMAGE-RECONSTRUCTION;
   BAYESIAN-ESTIMATION; LINE INTEGRALS; REPRESENTATION; RADIOGRAPHS},
Author-Email = {zenith.purisha@aalto.fi},
Number-of-Cited-References = {47},
Times-Cited = {13},
Unique-ID = {WOS:000485694800004},
}

@article{ WOS:000462370000012,
Author = {Elias Rangel-Patino, Francisco and Ernesto Rayas-Sanchez, Jose and
   Viveros-Wacher, Andres and Luis Chavez-Hurtado, Jose and Andrei
   Vega-Ochoa, Edgar and Hakim, Nagib},
Title = {Post-Silicon Receiver Equalization Metamodeling by Artificial Neural
   Networks},
Journal = {IEEE TRANSACTIONS ON COMPUTER-AIDED DESIGN OF INTEGRATED CIRCUITS AND
   SYSTEMS},
Year = {2019},
Volume = {38},
Number = {4},
Pages = {733-740},
Month = {APR},
Abstract = {As microprocessor design scales to the 10-nm technology and beyond,
   traditional pre- and post-silicon validation techniques are unsuitable
   to get a full system functional coverage. Physical complexity and
   extreme technology process variations severely limits the effectiveness
   and reliability of presilicon validation techniques. This scenario
   imposes the need of sophisticated post-silicon validation approaches to
   consider complex electromagnetic phenomena and large manufacturing
   fluctuations observed in actual physical platforms. One of the major
   challenges in electrical validation of high-speed input/output (HSIO)
   links in modern computer platforms lies in the physical layer (PHY)
   tuning process, where equalization techniques are used to cancel
   undesired effects induced by the channels. Current industrial practices
   for PHY tuning in HSIO links are very time consuming since they require
   massive laboratory measurements. An alternative is to use machine
   learning techniques to model the PHY, and then perform equalization
   using the resultant surrogate model. In this paper, a metamodeling
   approach based on neural networks is proposed to efficiently simulate
   the effects of a receiver equalizer PHY tuning settings. We use several
   design of experiments techniques to find a neural model capable of
   approximating the real system behavior without requiring a large amount
   of actual measurements. We evaluate the models performance by comparing
   with measured responses on a real server HSIO link.},
Type = {Article},
Affiliation = {Rayas-Sánchez, JE (Corresponding Author), ITESO, Dept Elect Syst \& Informat, Tlaquepaque 45604, Mexico.
   Elias Rangel-Patino, Francisco; Viveros-Wacher, Andres; Andrei Vega-Ochoa, Edgar, Intel Corp, Zapopan 45109, Mexico.
   Ernesto Rayas-Sanchez, Jose; Luis Chavez-Hurtado, Jose, ITESO, Dept Elect Syst \& Informat, Tlaquepaque 45604, Mexico.
   Hakim, Nagib, Intel Corp, Santa Clara, CA 95052 USA.},
DOI = {10.1109/TCAD.2018.2834403},
Keywords = {Artificial neural network (ANN); equalization; high-speed input/output
   (HSIO); metamodels; post-silicon validation; receiver; simulation;
   system margining},
Keywords-Plus = {MICROWAVE CIRCUITS; OPTIMIZATION; DESIGN; ANALOG; RF},
Author-Email = {francisco.rangel@intel.com
   erayas@iteso.mx},
Number-of-Cited-References = {41},
Times-Cited = {13},
Unique-ID = {WOS:000462370000012},
}

@article{ WOS:000505565500005,
Author = {Roman, Ibai and Santana, Roberto and Mendiburu, Alexander and Lozano,
   Jose A.},
Title = {An Experimental Study in Adaptive Kernel Selection for Bayesian
   Optimization},
Journal = {IEEE ACCESS},
Year = {2019},
Volume = {7},
Pages = {184294-184302},
Abstract = {Bayesian Optimization has been widely used along with Gaussian Processes
   for solving expensive-to-evaluate black-box optimization problems.
   Overall, this approach has shown good results, and particularly for
   parameter tuning of machine learning algorithms. Nonetheless, Bayesian
   Optimization has to be also configured to achieve the best possible
   performance, being the selection of the kernel function a crucial
   choice. This paper investigates the convenience of adaptively changing
   the kernel function during the optimization process, instead of fixing
   it a priori. Six adaptive kernel selection strategies are introduced and
   tested in well-known synthetic and real-world optimization problems. In
   order to provide a more complete evaluation of the proposed kernel
   selection variants, two major kernel parameter setting approaches have
   been tested. According to our results, apart from having the advantage
   of removing the selection of the kernel out of the equation, adaptive
   kernel selection criteria show a better performance than fixed-kernel
   approaches.},
Type = {Article},
Affiliation = {Roman, I (Corresponding Author), Univ Basque Country, UPV EHU, Intelligent Syst Grp, Donostia San Sebastian 20018, Spain.
   Roman, Ibai; Santana, Roberto; Mendiburu, Alexander; Lozano, Jose A., Univ Basque Country, UPV EHU, Intelligent Syst Grp, Donostia San Sebastian 20018, Spain.
   Lozano, Jose A., BCAM Alameda Mazarredo, Basque Ctr Appl Math, Bilbao 48009, Spain.},
DOI = {10.1109/ACCESS.2019.2960498},
Keywords = {Adaptive kernel selection; Bayesian optimization; Gaussian process;
