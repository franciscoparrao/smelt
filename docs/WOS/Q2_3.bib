DOI = {10.1109/TMECH.2023.3311435},
EarlyAccessDate = {SEP 2023},
Keywords = {Deep learning; physics-guided data model; tool condition monitoring},
Keywords-Plus = {GAUSSIAN PROCESS REGRESSION; MODEL; PROGNOSIS; DIAGNOSIS; CONTACT;
   NETWORK},
Author-Email = {liss1997@wust.edu.cn
