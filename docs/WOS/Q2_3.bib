   Ernst, Sabine, Royal Brompton Hosp, London, England.},
DOI = {10.1007/s11548-017-1587-4},
Keywords = {Radiofrequency catheter ablation; Cardiac mapping; Learning from
   demonstration; Active learning; Catheter robot guidance},
