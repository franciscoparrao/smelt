   Biedron, Sandra G., Element Aero, Chicago, IL 60643 USA.},
DOI = {10.1109/ACCESS.2022.3170438},
Keywords = {Virtual telescope for X-ray observation (VTXO); space mission design;
   Monte-Carlo simulation; optimal control; machine learning; optimization;
   satellites; real-time control; surrogate models; high performance
   computing; hyperparameters optimization},
Keywords-Plus = {ATTITUDE-TRACKING CONTROL; SELF-OPTIMIZATION; NEURAL-NETWORKS},
Author-Email = {rpirayeshs@gmail.com},
Number-of-Cited-References = {83},
