@article{ WOS:000643273300007,
Author = {Hadji, Amine and Szabo, Botond},
Title = {Can We Trust Bayesian Uncertainty Quantification from Gaussian Process
   Priors with Squared Exponential Covariance Kernel?},
Journal = {SIAM-ASA JOURNAL ON UNCERTAINTY QUANTIFICATION},
Year = {2021},
Volume = {9},
Number = {1},
Pages = {185-230},
Abstract = {We investigate the frequentist coverage properties of credible sets
   resulting from Gaussian process priors with squared exponential
   covariance kernel. First, we show that by selecting the scaling
   hyperparameter using the maximum marginal likelihood estimator in the
   (slightly modified) squared exponential covariance kernel, the
   corresponding L-2-credible sets will provide overconfident, misleading
   uncertainty statements for a large, representative subclass of the
   functional parameters in the context of the Gaussian white noise model.
   Then we show that by either blowing up the credible sets with a
   logarithmic factor or modifying the maximum marginal likelihood
   estimator with a logarithmic term, one can get reliable uncertainty
   statements and adaptive size of the credible sets under some additional
   restriction. Finally, we demonstrate in a numerical study that the
   derived negative and positive results extend beyond the Gaussian white
   noise model to the nonparametric regression and classification models
   for small sample sizes as well. The performance of the squared
   exponential covariance kernel is also compared to the
   Mat\textbackslash{}'ern covariance kernel.},
Type = {Article},
Affiliation = {Hadji, A (Corresponding Author), Leiden Univ, Math Inst, NL-2333 CA Leiden, Netherlands.
   Hadji, Amine, Leiden Univ, Math Inst, NL-2333 CA Leiden, Netherlands.
   Szabo, Botond, Vrije Univ Amsterdam, Dept Math, NL-1081 HV Amersterdam, Netherlands.},
DOI = {10.1137/19M1253010},
Keywords = {credible set; frequentist coverage; empirical Bayes; adaptation;
   asymptotics},
Keywords-Plus = {VON MISES THEOREMS; CREDIBLE SETS; POSTERIOR DISTRIBUTIONS; ASYMPTOTIC
   EQUIVALENCE; FREQUENTIST COVERAGE; CONVERGENCE-RATES; CONTRACTION;
   REGRESSION; INFERENCE},
Author-Email = {m.ahadji@math.leidenuniv.nl
   b.t.szabo@vu.nl},
Number-of-Cited-References = {41},
Times-Cited = {9},
Unique-ID = {WOS:000643273300007},
}

@incollection{ WOS:000696765400035,
