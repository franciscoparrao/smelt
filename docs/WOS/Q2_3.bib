   Wen, Haijia, Chongqing Univ, Sch Civil Engn, Chongqing 400045, Peoples R China.},
DOI = {10.1016/j.geomorph.2020.107201},
Article-Number = {107201},
Keywords = {Bayes algorithm; Random forest; Landslide susceptibility mapping;
   Hyperparameter optimization; Factor screening},
Keywords-Plus = {LOGISTIC-REGRESSION; SPATIAL PREDICTION; HYPER-PARAMETERS;
   CLASSIFICATION; BIVARIATE; COUNTY; TREE},
