   Adegboye, Mutiu Adesina, Robert Gordon Univ, Commun \& Autonomous Syst Grp, Aberdeen AB10 7GJ, Scotland.
   Salawudeen, Ahmed Tijani, Univ Jos, Dept Elect \& Elect Engn, Jos 930222, Nigeria.},
DOI = {10.3390/app12031186},
Article-Number = {1186},
