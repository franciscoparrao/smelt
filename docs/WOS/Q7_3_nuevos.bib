@incollection{ WOS:000662554702039,
Author = {Boulegane, Dihia and Bifet, Albert and Elghazel, Haytham and Madhusudan,
   Giyyarpuram},
Editor = {Wu, XT and Jermaine, C and Xiong, L and Hu, XH and Kotevska, O and Lu, SY and Xu, WJ and Aluru, S and Zhai, CX and Al-Masri, E and Chen, ZY and Saltz, J},
Title = {Streaming Time Series Forecasting using Multi-Target Regression with
   Dynamic Ensemble Selection},
Booktitle = {2020 IEEE INTERNATIONAL CONFERENCE ON BIG DATA (BIG DATA)},
Series = {IEEE International Conference on Big Data},
Year = {2020},
Pages = {2170-2179},
Abstract = {In mining temporal data streams, Dynamic Ensemble Selection (DES) has
   emerged as one of the most promising approaches of ensemble methods
   based on the assumption that each member of the ensemble is an expert in
   some local area of the stream. The aim is to select, on the fly,
   according to a given test instance x, a subset of experts from a pool of
   various models. To this end, meta-learning has been widely studied to
   predict the performance of each base-model and accordingly select the
   best ones and combine their outputs to compute the final prediction.
   However, most of the existing selection methods for time series
   forecasting on data streams do not handle model's dependencies, and
   therefore maybe missing useful insights. In this paper, we propose a
   novel approach to harness the potential dependencies within base-models'
   behavior based on Incremental Multi-Target Regression (MTR) to achieve
   Dynamic Ensemble Selection (DES). We show that explicitly considering
   models' dependencies improves overall performance. This work is the
   first to use Incremental MTR for learning the behavior of each component
   in an ensemble of forecasters on data streams. Finally, we conduct an
   extensive experimental study to compare the performance of the proposed
   methods against state-of-the-art approaches.},
Type = {Proceedings Paper},
Affiliation = {Boulegane, D (Corresponding Author), Telecom Paris, LTCI, IP Paris, Paris, France.
   Boulegane, D (Corresponding Author), Orange Labs, Grenoble, France.
   Boulegane, Dihia; Bifet, Albert, Telecom Paris, LTCI, IP Paris, Paris, France.
   Bifet, Albert, Univ Waikato, Hamilton, New Zealand.
   Elghazel, Haytham, Polytech Lyon, LIRIS Lab, UMR CNRS 5205, Lyon, France.
   Boulegane, Dihia; Madhusudan, Giyyarpuram, Orange Labs, Grenoble, France.},
DOI = {10.1109/BigData50022.2020.9378264},
Keywords = {Dynamic Ensemble Selection; Meta-Learning; Multi-Target Regression; Data
   Stream Mining; Time Series forecasting},
Keywords-Plus = {ONLINE; CLASSIFIERS},
Author-Email = {dihia.boulegane@telecom-paris.fr
   albert.bifet@telecom-paris.fr
   haytham.elghazel@univ-lyon1.fr
   giyyarpuram.madhusudan@orange.com},
Number-of-Cited-References = {52},
Times-Cited = {6},
