   cross-validation},
Keywords-Plus = {PROSTATIC ACID-PHOSPHATASE; UNKNOWN PRIMARY; MOLECULAR CLASSIFICATION;
   COLON-CANCER; PRIMARY SITE; CARCINOMA; TUMOR; IMMUNOHISTOCHEMISTRY;
   ADENOCARCINOMA; IDENTIFICATION},
Author-Email = {hbscsmu@163.com
   bpping@163.com
   tiang@geneis.cn
   yangjl@geneis.cn},
