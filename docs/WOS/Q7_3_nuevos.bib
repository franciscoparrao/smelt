   Gomez-Jemes, Lola, ETSI Informat, Avda Reina Mercedes S-N, Seville 41012, Spain.},
DOI = {10.3390/electronics11193240},
Article-Number = {3240},
Keywords = {machine learning; multilabel classification; pre-eclampsia; intrauterine
   growth restriction; pregnancy disorders},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; PREVENTION; ASPIRIN},
Author-Email = {mcromerot@us.es},
Number-of-Cited-References = {32},
Times-Cited = {14},
