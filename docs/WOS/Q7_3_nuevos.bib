   Bi, Xia-an; Hu, Xi; Xie, Yiming; Wu, Hao, Hunan Normal Univ, Coll Informat Sci \& Engn, Changsha 410081, Peoples R China.},
DOI = {10.1016/j.media.2020.101830},
