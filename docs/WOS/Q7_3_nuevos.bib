   Kocev, Dragi; Ceci, Michelangelo, Univ Bari Aldo Moro, Dept Comp Sci, Bari, Italy.
   Kocev, Dragi; Ceci, Michelangelo; Stepisnik, Tomaz, Jozef Stefan Inst, Dept Knowledge Technol, Ljubljana, Slovenia.
   Kocev, Dragi; Stepisnik, Tomaz, Jozef Stefan Int Postgrad Sch, Ljubljana, Slovenia.
   Ceci, Michelangelo, CINI Consorzio Interuniv Nazl Informat, Rome, Italy.},
DOI = {10.1007/s10994-020-05894-4},
EarlyAccessDate = {AUG 2020},
