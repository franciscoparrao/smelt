@article{ WOS:001674936300001,
Author = {Li, Mingchao and Ma, Jiamei and Ren, Qiubing and Qi, Zhiyong and Du,
   Xuhuang and Tan, Dawen},
Title = {Multi-point joint prediction of zone-wise arch dam displacements based
   on spatial partition and deep ensemble selective regression chain},
Journal = {ENGINEERING STRUCTURES},
Year = {2026},
Volume = {353},
Number = {A},
Month = {APR 15},
Abstract = {Dam displacement, as a key indicator of structural health, demands
   accurate forecast for timely anomaly detection and risk prevention. Due
   to the arch dam's monolithic integrity, each structural element is
   interrelated and interactive. However, existing predictive models
   primarily adopt point-wise displacement modeling, ignoring the spatial
   correlations among monitoring points, which makes it difficult to reveal
   the zonal evolution patterns of arch dam displacements. In this work, we
   propose a multi-point joint monitoring model, which integrates deep
   ensemble selective regression chain (DESRC) with spatial clustering
   analysis, for zone-wise displacement prediction of high arch dams. A
   spatial partition index system is firstly constructed using composite
   similarity indicators based on displacement patterns both temporally and
   spatially. Then, the unsupervised fuzzy C-means (FCM) approach and Jaya
   algorithm are hybridized for adaptive zonal clustering of displacement
   time series, thus achieving spatial partition across the entire dam.
   Next, the stacked long short-term memory (LSTM) network is augmented
   with multi-input multi-output formulation, enabling concurrent modeling
   and prediction of displacement behavior at multiple monitoring points.
   In further exploiting the interaction among multi-point displacements
   within each clustered zone, a stacked LSTM-embedded ensemble strategy of
   selective regressor chains, referred to as DESRC, is developed through
   sequential target selection and greedy stacking generalization. Finally,
   we apply the proposed model to the Jinping-I High Arch Dam monitoring
   data consistently serving as a benchmark dataset for verification
   analysis, and a set of predictive methods are implemented to compare the
   performances. Empirical results indicate that the self-adaptive FCM
   approach can reasonably describe the zonal deformation laws of the arch
   dam, and our DESRC can effectively estimate future displacements with
   high accuracy and generalization ability, making it an advanced tool for
   structural health monitoring of large-scale dams.},
Type = {Article},
Affiliation = {Ren, QB (Corresponding Author), Tianjin Univ, State Key Lab Hydraul Engn Intelligent Construct \&, Tianjin 300350, Peoples R China.
   Li, Mingchao; Ma, Jiamei; Ren, Qiubing, Tianjin Univ, State Key Lab Hydraul Engn Intelligent Construct \&, Tianjin 300350, Peoples R China.
