}

@article{ WOS:001509048900001,
Author = {Mo, Xuandong and Mei, Shenping and Hu, Xiaofeng},
Title = {Semi-supervised multi-task learning approach for simultaneously
   monitoring tool wear and breakage using reliable pseudo-labels},
Journal = {JOURNAL OF MANUFACTURING PROCESSES},
Year = {2025},
Volume = {149},
Pages = {610-631},
Month = {SEP 15},
Abstract = {As the direct executor of the machine tool, the condition of the cutting
   tool has a significant impact on product quality, production efficiency
   and manufacturing cost. Therefore, tool condition monitoring (TCM) has
   become a research hotspot in recent years. Although a large number of
   researchers have made contributions to data-driven TCM, we are
   astonished to discover that they almost universally regarded tool wear
   prediction and tool breakage monitoring (TBM) as two independent tasks,
   despite their close correlation. Besides, while the widely used
   datadriven techniques are highly effective at extracting tool
   degradation information, their performance is heavily contingent upon
   the quantity of labeled data. To address these issues, we construct a
   semi-supervised multi-task learning (MTL) framework to simultaneously
   monitor tool wear and breakage. Firstly, we introduce the tool wear
   stage classification task as an auxiliary task to build a MTL framework,
   shared information among related tasks can enhance the model
   performance. Then, we propose a pseudo-labeling technique based on the
   teacher-student framework to assign reliable labels for the large amount
   of unlabeled data generated in the actual manufacturing process, which
   can alleviate the adverse effects of limited labeled data on model
   training. On this basis, we further develop an ensemble learning
   mechanism to exploit the complex coupling relationship between wear and
   breakage by using shared parameters extracted by MTL. Experimental
   results on the PHM2010 dataset and realworld machining dataset of the
   aero-engine casing demonstrate that the proposed method can effectively
   perform tool wear prediction and breakage monitoring simultaneously with
   a small amount of labeled data. Compared with the baseline, the proposed
   method reduces the root mean square error (RMSE) on the two datasets by
   49.82 \% and 62.06 \%, respectively, and improves f1 scores by 12.13 \%
   and 9.65 \%, respectively. We further discuss several key
   hyperparameters of our method and conduct corresponding analysis and
   suggestions.},
