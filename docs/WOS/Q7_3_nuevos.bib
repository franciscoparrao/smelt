   Sharma, Bhisham, Chitkara Univ, Chitkara Univ Inst Engn \& Technol, Rajpura 140401, Punjab, India.
   Chowdhury, Subrata, Sreenivasa Inst Technol \& Management Studies, Dept Comp Sci \& Engn, Chittoor 517127, Andhra Pradesh, India.
   Rabie, Khaled, Manchester Metropolitan Univ, Dept Engn, Manchester M15GD, England.
   Rabie, Khaled; Shongwe, Thokozani, Univ Johannesburg, Dept Elect \& Elect Engn Technol, ZA-2006 Johannesburg, South Africa.},
DOI = {10.3390/s23156836},
