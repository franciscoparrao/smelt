   Qian, Quan, Shanghai Univ, Mat Genome Inst, 99 Shangda Rd, Shanghai 200444, Peoples R China.},
DOI = {10.1016/j.mtcomm.2021.102314},
EarlyAccessDate = {APR 2021},
Article-Number = {102314},
Keywords = {Multi-task learning; Imbalanced data preprocessing; Materials property
   prediction; Negative thermal expansion},
Author-Email = {oyqb@sjtu.edu.cn
   qqian@shu.edu.cn},
Number-of-Cited-References = {46},
