@incollection{ WOS:001413988900006,
Author = {Zhou, Chunlin and Liu, Haoran and Yang, Zongqing and Yu, Hong},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Spectral Clustering Enhanced Classifier Chain Ensemble for Multi-Disease
   Prediction},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON MEDICAL ARTIFICIAL INTELLIGENCE,
   MEDAI 2024},
Year = {2024},
Pages = {44-49},
Abstract = {In the clinical diagnosis scenario, most patients suffer from multiple
   diseases simultaneously. Multi-disease prediction models can effectively
   predict the risk of patients suffering from multiple diseases based on
   electronic health record (EHR) data, which has become a typical
   multi-label classification (MLC) problem in the field of machine
   learning. However, there are few multi-disease prediction models that
   can address the problem of imbalanced class distribution in the data.
   Additionally, most existing MLC algorithms focus solely on solving the
   data imbalance problem without considering label correlations. To solve
   the aforementioned problems, this paper proposes an enhanced classifier
   chain ensemble (SC-ECCE) algorithm based on spectral clustering for
   multi-disease prediction. The dynamic sample-specific oversampling
   algorithm (DSSO) is proposed to mitigate the negative impact of
   imbalanced class distribution. In order to verify the effectiveness and
   superiority of the SC-ECCE algorithm, experiments are conducted on ten
   multi-label datasets from different fields and a real-world multi-label
   medical dataset, NHANES(2017-2018). The experimental results demonstrate
   that the proposed SC-ECCE, algorithm outperforms the MLC baselines in
   three evaluation indicators.},
Type = {Proceedings Paper},
Affiliation = {Yu, H (Corresponding Author), Chongqing Univ Posts \& Telecommun, Chongqing Key Lab Computat Intelligence, Chongqing, Peoples R China.
   Zhou, Chunlin; Liu, Haoran; Yang, Zongqing; Yu, Hong, Chongqing Univ Posts \& Telecommun, Chongqing Key Lab Computat Intelligence, Chongqing, Peoples R China.},
DOI = {10.1109/MedAI62885.2024.00013},
Keywords = {multi-disease prediction; multi-label classification; imbalanced class
   distribution; label correlations},
Keywords-Plus = {FRAMEWORK},
Author-Email = {s230233060@stu.cqupt.edu.cn
   d220201020@stu.cqupt.edu.cn
   1054705706@qq.com
   yuhong@cqupt.edu.cn},
