   Sun, Jihong; Li, Zhaowen; Qian, Ye; Li, Tong, Yunnan Agr Univ, Key Lab Crop Prod \& Smart Agr Yunnan Prov, Kunming, Yunnan, Peoples R China.
   Sun, Chen; Li, Zhaowen; Qian, Ye; Li, Tong, Yunnan Agr Univ, Big Data Sch, Kunming, Yunnan, Peoples R China.},
DOI = {10.1371/journal.pone.0312444},
Article-Number = {e0312444},
Keywords-Plus = {WHEAT YIELD; MODEL; MODIS; CROP},
Author-Email = {tli@ynu.edu.cn},
Number-of-Cited-References = {46},
Times-Cited = {4},
