   Zhang, Lintong, Univ Sci \& Technol Beijing, Basic Expt Ctr Nat Sci, Beijing 100083, Peoples R China.},
DOI = {10.1016/j.culher.2025.09.005},
EarlyAccessDate = {NOV 2025},
Keywords = {Waterlogged archaeological wood; Near-infrared spectroscopy;
