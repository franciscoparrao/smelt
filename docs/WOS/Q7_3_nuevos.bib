@incollection{ WOS:001706379900030,
Author = {Gonzalez Rodarte, Jose G. and Mauricio-Gonzalez, Alejandro and
   Martinez-Fierro, Margarita L.},
Book-Group-Author = {IEEE},
Title = {Detection of Suicidal Behaviors in Medical Students using Machine
   Learning Techniques},
Booktitle = {2025 MEXICAN INTERNATIONAL CONFERENCE ON COMPUTER SCIENCE, ENC},
Series = {Proceedings of the Mexican Conference on Computer Science},
Year = {2025},
Abstract = {According to the World Health Organization (WHO) suicide is the third
   leading cause of death among individuals aged fifteen to twenty-nine
   years. This age group often coincides with higher education, where high
   levels of stress, anxiety and depression-factors that have a significant
   influence on suicide behavior-have been detected. The incidence is
   higher among medical students even during their professional practice.
   To address this issue, we developed machine learning models to perform a
   binary classification: 0 = no suicidal behaviors, 1 = suicidal
   behaviors.
   The dataset used in this study comprised 688 instances and 342 features,
   collected from an original self-reported questionnaire developed by
   experts and applied to medical students. The instrument includes items
   on socioeconomic status, substance use, trauma and related factors, and
   all responses were labeled by domain experts. The dataset was processed
   and transformed using techniques such as Frequency Encoding, Multi-Label
   Binarizer, Forward and Backward Selection. Two algorithms were
   trained-Support Vector Machines (SVM) and Random Forest (RF)-and
   evaluated, achieving an AUC (area under the curve) of 0.81 and 0.80,
   respectively.},
Type = {Proceedings Paper},
Affiliation = {Rodarte, JGG (Corresponding Author), Univ Autonoma Zacatecas, Acad Unit Elect Engn, Zacatecas, Zacatecas, Mexico.
   Gonzalez Rodarte, Jose G.; Mauricio-Gonzalez, Alejandro, Univ Autonoma Zacatecas, Acad Unit Elect Engn, Zacatecas, Zacatecas, Mexico.
   Martinez-Fierro, Margarita L., Univ Autonoma Zacatecas, Acad Unit Human Med \& Hlth Sci, Mol Med Lab, Zacatecas, Zacatecas, Mexico.},
DOI = {10.1109/ENC68268.2025.11311893},
Keywords = {suicidal behaviors; medical students; machine learning; support vector
   machines; random forest},
Author-Email = {38192814@uaz.edu.mx},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001706379900030},
}

@incollection{ WOS:001706358800134,
Author = {Sajwani, Ahmed and AlKaabi, Fatima and Tamer, Amr and Yaqoob, Mohamed
   and Liatsis, Panos},
Book-Group-Author = {IEEE},
Title = {A Comprehensive Comparison of LLaMA 3.1 and Traditional ML Approaches in
   Automated Vulnerability Detection},
Booktitle = {2025 IEEE/ACS 22ND INTERNATIONAL CONFERENCE ON COMPUTER SYSTEMS AND
   APPLICATIONS, AICCSA},
Series = {International Conference on Computer Systems and Applications},
Year = {2025},
Abstract = {Software vulnerability detection has traditionally relied on classical
   machine learning (ML) models with handcrafted features, which are
   lightweight but limited in performance. Transformer-based Large Language
   Models (LLMs) trained on source code provide deeper semantic
   understanding and stronger generalization. This work presents a direct
   comparison between ML- and LLM-based approaches across binary and
   multi-label tasks. We benchmark Random Forest, SVM, and LSTM against
   LoRA-finetuned LLaMA 3.1 models on both synthetic and real-world
   datasets. Our LLaMA 3.1 8B model achieves 87\% macro F1 in binary
   classification and 82\% in multi-label classification on real-world
   data-substantially outperforming ML and DL baselines. Despite higher
   computational demands, parameter-efficient fine-tuning with Unsloth and
   LoRA makes LLMs viable for practical deployment. These findings
   highlight the superiority of LLMs in security-critical code analysis and
   establish strong baselines for future research.},
Type = {Proceedings Paper},
Affiliation = {Sajwani, A (Corresponding Author), Khalifa Univ, Abu Dhabi, U Arab Emirates.
   Sajwani, Ahmed; AlKaabi, Fatima; Tamer, Amr; Yaqoob, Mohamed; Liatsis, Panos, Khalifa Univ, Abu Dhabi, U Arab Emirates.},
Keywords = {Software vulnerability; Large Language Models; Code Security Analysis;
