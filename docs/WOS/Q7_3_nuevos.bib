   Nakano, Felipe Kenji; Pliakos, Konstantinos; Vens, Celine, Katholieke Univ Leuven, Imec Res Grp, Itec, Etienne Sabbelaan 53, B-8500 Kortrijk, Belgium.},
DOI = {10.1016/j.patcog.2021.108211},
EarlyAccessDate = {AUG 2021},
Article-Number = {108211},
Keywords = {Ensemble learning; Deep-forest; Multi-output prediction; Multi-target
