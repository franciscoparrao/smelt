   Im, Sio-Kei, Macao Polytech Univ, Macau, Macao, Peoples R China.},
DOI = {10.1016/j.neucom.2025.130498},
EarlyAccessDate = {JUN 2025},
Article-Number = {130498},
Keywords = {Multi-label recognition; Missing labels; Computer vision;
   Weakly-supervised learning; Deep learning},
Keywords-Plus = {NEURAL-NETWORK},
