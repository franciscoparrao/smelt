@article{ WOS:001680952500001,
Author = {Meena, Jyotisana and Unni, Sujatha Narayanan},
Title = {Transparent non-destructive estimation of moisture content in vegetables
   using hyperspectral imaging, multi-target regression pipeline approach
   and explainable AI},
Journal = {ENGINEERING RESEARCH EXPRESS},
Year = {2026},
Volume = {8},
Number = {3},
Month = {FEB 1},
Abstract = {The estimation of moisture content (MC) has become a significant part of
   assessing the nutrient value, freshness, and shelf life of
   post-harvested fruits and vegetables. Hence, early intervention can help
   maintain quality and reduce postharvest spoilage. However, manual
   assessment of MC requires skilled manpower and specialised equipment,
   which makes it costly and prone to errors. This study presents an
   innovative approach that integrates explainable AI (XAI) and a machine
   learning model to overcome such challenges. The study develops the
   multi-target regression (MTR) pipeline for simultaneously automated MC
   estimation in various agricultural samples. Hyperspectral imaging (HSI)
   data of broccoli, leek, and mushrooms were utilised for experimentation
   purposes. The MTR pipeline comprises three stages: classification,
   feature extraction, and regression. Random forest classifier, Partial
   least square, and Stacking regression models (SRM) were used for
   classification, feature extraction, and regression purposes. The study
   used 788 VIS-NIR reflectance spectra obtained from the HSI data of
   broccoli, leek, and mushrooms. The proposed MTR pipeline was evaluated
   using the coefficient of determination (R2), root mean squared error
   (RMSE), mean squared error (MSE), and mean absolute error (MAE) scores.
   The overall performance score of the MTR pipeline for MC prediction on
   unseen datasets in the VIS to NIR range was 90.17 R2, 0.07 MSE, 1.91
   RMSE, and 1.33 MAE. The individual proposed SRMs achieved R2 scores of
   81.31 +/- 7.36\% for broccoli, 98.09 +/- 0.34\% for leek, and 98.54 +/-
   1.21\% for mushroom. The corresponding RMSE scores were 0.65 +/- 0.13\%,
   0.32 +/- 0.05\%, and 3.08 +/- 1.18\% for broccoli, leek, and mushroom,
   respectively. The proposed pipeline outperforms the existing
   state-of-the-art (SOA) methods reported in the literature. The study
   highlighted the importance of wavelengths for MC estimation in
   agricultural samples, utilising the Explainable AI (XAI) Shapley
   Additive Explanations (SHAP) tool. The promising result of the study
   demonstrates that the involvement of XAI with the proposed pipeline
   facilitates transparent MC prediction in crops, ensuring supplies of
   higher-quality products to consumers.},
Type = {Article},
Affiliation = {Unni, SN (Corresponding Author), Indian Inst Technol Madras, Dept Appl Mech \& Biomed Engn, Biophoton Lab, Chennai 600036, India.
   Meena, Jyotisana; Unni, Sujatha Narayanan, Indian Inst Technol Madras, Dept Appl Mech \& Biomed Engn, Biophoton Lab, Chennai 600036, India.},
DOI = {10.1088/2631-8695/ae3ba0},
Article-Number = {035214},
Keywords = {hyperspectral imaging; moisture content; multi-target regression;
   stacking regressor model; explainable AI; SHAP},
Keywords-Plus = {VEGETATION WATER-CONTENT; REFLECTANCE},
Author-Email = {nsujatha@smail.iitm.ac.in},
Number-of-Cited-References = {32},
Times-Cited = {0},
Unique-ID = {WOS:001680952500001},
}

@article{ WOS:001681816900001,
Author = {Dey, Shourav and Hasan, Mohammad Kamrul and Adhikary, Apurba and Akter,
   Sanjida and Ejaz, Md Sabbir},
Title = {SwinGhost-ClustNet: An explainable deep ensemble model for papaya leaf
   disease detection and field deployment in Bangladeshi agriculture},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2026},
Volume = {13},
Month = {MAR},
Abstract = {Early detection of papaya leaf disease is essential for Bangladeshi
   farmers who experience 39.9\% post-harvest losses and pesticide misuse
   risks. The proposed research presents SwinGhost-ClustNet, which is an
   ensemble of Swin Transformer to capture the global context, GhostNet to
   capture the local textures, cross-attention fusion, and K-means
   clustering (k = 8, silhouette score 0.67) on a 9342-image dataset across
   eight classes (anthracnose, bacterial spot, healthy, leaf curl,
   mealybug, mite, mosaic, ring spot) in eight districts. The model reached
   99.25\% accuracy, 99.28\% precision, 99.25\% recall, 99.25\% F1-score,
   and 1.000 ROC-AUC on 1401 test images, which is 2.10\% higher than base
   models using pseudo-labels and cross-attention (ablationvalidated).
   Explainable AI (Grad-CAM++ IoU 0.72, Layer-CAM 0.68, and Grad-CAM 0.65)
   visualizes diseasespecific features such as lesions and webbing, and
   enables building farmer trust. An API based on Flask provides real-time
   diagnostic, confidence ratings (>70\% criterion), and recommendations of
   pesticides in the Bengali language, which makes it possible to deploy it
   to the field regardless of singlelabel restrictions. Future efforts:
   severity scoring + dosage recommendations, multi-label classification,
   model pruning (<100 MB), cloud deployment (AWS/GCP), and multi-crop
   validation with domain adaptation (e.g., 98.89\% on lemon leaves;
   Section 4.7) to address domain shift and species differences. This
   promotes precision farming, which minimizes losses and excess of
   chemicals in Bangladesh.},
Type = {Article},
Affiliation = {Hasan, MK (Corresponding Author), Noakhali Sci \& Technol Univ, Dept Informat \& Commun Engn, Noakhali 3814, Bangladesh.
   Dey, Shourav; Hasan, Mohammad Kamrul; Adhikary, Apurba; Akter, Sanjida; Ejaz, Md Sabbir, Noakhali Sci \& Technol Univ, Dept Informat \& Commun Engn, Noakhali 3814, Bangladesh.},
DOI = {10.1016/j.atech.2026.101824},
EarlyAccessDate = {JAN 2026},
Article-Number = {101824},
Keywords = {Papaya leaf disease; Ensemble learning; Swin transformer; K -means
   clustering; XAI; Flask-based API},
Keywords-Plus = {NEURAL-NETWORK},
Author-Email = {kamrul.ice@nstu.edu.bd},
Number-of-Cited-References = {60},
