@article{ WOS:001208701400001,
Author = {Ding, Song and Qian, Quan},
Title = {Enhancing glass forming ability prediction in bulk metallic glasses: A
   multi-task learning with differentiation between primary and auxiliary
   tasks},
Journal = {COMPUTATIONAL MATERIALS SCIENCE},
Year = {2024},
Volume = {237},
Month = {MAR 25},
Abstract = {In the field of materials informatics, data -driven approaches have
   become indispensable for advancing materials research. Within this
   context, bulk metallic glasses (BMGs) stand out as a unique class of
   alloy materials, extensively utilized in a wide range of applications.
   BMGs exhibit a diverse array of properties, including high strength,
   wear resistance, and exceptional corrosion resistance. However, the
   predictability of these properties varies due to their distinct
   underlying mechanisms. Notably, the pursuit of an enhanced glass
   -forming ability (GFA) emerges as a fundamental and challenging
   objective in this multifaceted domain. Currently, the lack of an
   accurate method for predicting GFA restricts further applications of
   these materials. This study addresses this gap by introducing a multi
   -task learning algorithm. The primary task focuses on predicting GFA,
   while the auxiliary task involves predicting other properties related to
   GFA. The algorithm incorporates an attention mechanism that
   automatically assigns different expert network weights to various tasks.
   This approach allows the model to prioritize the primary task while
   gathering valuable information from the auxiliary tasks, thus avoiding
   the `seesaw' phenomenon often observed in multi -task learning.
   Additionally, a dynamic loss weighting method has been implemented to
   balance the learning rates of primary and auxiliary tasks. The results
   demonstrate that, thanks to the additional feature information provided
   by the auxiliary tasks, the model achieved higher accuracy in predicting
   GFA based on composition. The R2, RMSE, and MAE were 0.815, 2.177, and
   1.667, respectively. In these metrics, the model surpasses comparative
   models, including Support Vector Regression, Ridge, Random Forest,
   Extreme Gradient Boosting, and Multi -gate Mixture -of -Experts.},
Type = {Article},
Affiliation = {Qian, Q (Corresponding Author), Shanghai Univ, Sch Comp Engn \& Sci, Shanghai, Peoples R China.
   Ding, Song; Qian, Quan, Shanghai Univ, Sch Comp Engn \& Sci, Shanghai, Peoples R China.
   Qian, Quan, Shanghai Univ, Res Ctr Urban Informat, Ctr Mat Informat \& Data Sci, Shanghai 200444, Peoples R China.
   Qian, Quan, Shanghai Univ, Key Lab Silicate Cultural Rel Conservat, Minist Educ, Shanghai, Peoples R China.},
DOI = {10.1016/j.commatsci.2024.112897},
EarlyAccessDate = {MAR 2024},
Article-Number = {112897},
Keywords = {Bulk metallic glass; Glass formation ability; Multi-task learning;
   Feature information sharing},
Keywords-Plus = {SUPERCOOLED LIQUID},
Author-Email = {dingsong@shu.edu.cn
   qqian@shu.edu.cn},
Number-of-Cited-References = {32},
Times-Cited = {1},
Unique-ID = {WOS:001208701400001},
}

@article{ WOS:001188285400002,
Author = {Das, Pranab and Mazumder, Dilwar Hussain},
Title = {Advances in Predicting Drug Functions: A Decade-Long Survey in Drug
   Discovery Research},
Journal = {IEEE TRANSACTIONS ON MOLECULAR BIOLOGICAL AND MULTI-SCALE COMMUNICATIONS},
Year = {2024},
Volume = {10},
Number = {1},
Pages = {75-91},
Month = {MAR},
Abstract = {Drug function study is vital in current drug discovery, design, and
   development. Determining the drug functions of a novel drug is
   time-consuming, complicated, expensive, and requires many experts and
   clinical testing phases. The computational-based drug function
   prediction activity has recently become more attractive due to its
   capability to reduce drug development design complexity, time, human
   resources, cost, chemical waste, and the risk of failure. The evolution
   of the computational model has advanced as an effective tool for
   predicting and analyzing drug functions, which are derived from Medical
   Subject Headings (MeSH). However, predicting drug functions still faces
   several difficulties. Therefore, an exhaustive literature survey was
   conducted that discusses the application of computational methods to
   predict drug functions in the past decade. Additionally, this paper
   discusses the utilization of drug functions as an input feature to
   predict adverse drug reactions and disease classification. This work
   also provides an overview of the computational models with their
   performance, multi-label problem transformation methods, drug
   properties, and their sources needed for the task of drug function
   prediction. Finally, unsolved issues, research gaps, and difficulties
   with the drug function prediction task have been summarized.},
Type = {Article},
Affiliation = {Mazumder, DH (Corresponding Author), Natl Inst Technol Nagaland, Dept Comp Sci \& Engn, Nagaland 797103, India.
   Das, Pranab; Mazumder, Dilwar Hussain, Natl Inst Technol Nagaland, Dept Comp Sci \& Engn, Nagaland 797103, India.},
DOI = {10.1109/TMBMC.2023.3345145},
Keywords = {Drug function; drug properties; drug development; deep learning; machine
   learning},
Keywords-Plus = {BIOPHYSICAL MODEL; BINARY RELEVANCE; ADVERSE EVENTS; DATABASE; GENE;
   CLASSIFICATION; INFORMATION; ENSEMBLE; NETWORKS; DYNAMICS},
Author-Email = {dpranavdas@gmail.com
   dilwar2k4@yahoo.co.in},
Number-of-Cited-References = {139},
Times-Cited = {5},
Unique-ID = {WOS:001188285400002},
}

@article{ WOS:001173051200001,
Author = {Asadollah, Seyed Babak Haji Seyed and Sharafati, Ahmad and Motta, Davide},
Title = {Satellite-based ensemble intelligent approach for predicting forest
   fire: a case of the Hyrcanian forest in Iran},
Journal = {ENVIRONMENTAL SCIENCE AND POLLUTION RESEARCH},
Year = {2024},
Month = {2024 FEB 27},
Abstract = {A machine learning-based approach is applied to simulate and forecast
   forest fires in the Golestan province in Iran. A dataset for no-fire,
   medium confidence (MC) fire events, and high confidence (HC) fire events
   is constructed from MODIS-MOD14A2. Nine climate variables from NASA's
   FLDAS are used as input variables, and 12 dates and 915 study points are
   considered. Three machine learning ensemble multi-label classifiers,
   gradient boosting (GBC), random forest (RFC), and extremely randomized
   tree (ETC), are used for forest fire simulation for the period 2000 to
   2021, and ETC is found to be the most accurate classifier. Future fire
   projection for the near-future period of 2030 to 2050 is carried out
   with the ETC model, using CMIP6 EC-Earth3-SSP245 General Circulation
   Model (GCM) data. It is projected that MC forest fire occurrences will
   decrease, while HC forest fire occurrences will increase, and that the
   summer months, especially September, will be the most affected by fire.},
