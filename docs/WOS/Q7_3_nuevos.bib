   Zhong, Guoqiang; Dong, Junyu, Ocean Univ China, Dept Comp Sci \& Technol, Qingdao 266100, Peoples R China.},
DOI = {10.1007/s12559-021-09912-y},
EarlyAccessDate = {AUG 2021},
Keywords = {Multi-label learning; Graph-based Semi-supervised Learning; Anchors;
   Label Correlation Consistency},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {zhang\_qin1005@163.com
   gqzhong@ouc.edu.cn
