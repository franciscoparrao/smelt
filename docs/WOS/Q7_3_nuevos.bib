@incollection{ WOS:001565032400029,
Author = {Nbili, Salma and Bouazizi, Samar and Ltifi, Hela},
Editor = {Antonacopoulos, A and Chaudhuri, S and Chellappa, R and Liu, CL and Bhattacharya, S and Pal, U},
Title = {Ensemble Multi-task Learning Approach for Explainable EEG-Based Stroke
   Prediction},
Booktitle = {PATTERN RECOGNITION, ICPR 2024, PT VIII},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15308},
Pages = {439-454},
Abstract = {Stroke is a major cause of long-term disability. Early and accurate
   diagnosis of stroke severity can improve patient outcomes. EEG is a
   non-invasive way to analyze brain activity changes during stroke, but
   interpreting complex EEG data remains challenging. This study develops
   an explainable multi-task learning approach for EEG-based stroke
   analysis. Feedforward neural networks extract hierarchical
   spatial-temporal EEG features. An ensemble of models with different
   architectures and electrode combinations is trained for robustness. A
   multi-task framework jointly models stroke diagnosis, type, location,
   and severity prediction with high accuracies of 98.11\%, 100\%, 100\%,
   and 100\% respectively. Explainability methods like LIME and SHAP are
   used to visualize influential EEG channels and time windows for each
   prediction. The models are evaluated on a public stroke EEG dataset and
   achieve state-of-the-art performance on multilabel classification and
   severity regression. Explanation methods provide clinically
