   Akbari, Mohammad, Amirkabir Univ Technol, Tehran Polytech, Dept Math \& Comp Sci, Tehran, Iran.
   Akbari, Mohammad, Inst Res Fundamental Sci IPM, Sch Comp Sci, Tehran, Iran.},
DOI = {10.1016/j.eswa.2022.118991},
EarlyAccessDate = {OCT 2022},
Article-Number = {118991},
Keywords = {Autoencoder; Ensemble learning; Multi-task learning; Imbalanced data;
   Credit scoring},
Keywords-Plus = {SUPPORT VECTOR MACHINES; ENSEMBLE MODEL; FEATURE-SELECTION;
