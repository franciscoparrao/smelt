}

@article{ WOS:001327415100001,
Author = {Sharma, Deepawali and Gupta, Vedika and Singh, Vivek Kumar and Pinto,
   David},
Title = {Should we stay silent on violence? An ensemble approach to detect
   violent incidents in Spanish social media texts},
Journal = {NATURAL LANGUAGE PROCESSING},
Year = {2025},
Volume = {31},
Number = {2, SI},
Pages = {457-476},
Month = {MAR},
Abstract = {There has been a steep rise in user-generated content on the Web and
   social media platforms during the last few years. While the ease of
   content creation allows anyone to create content, at the same time it is
   difficult to monitor and control the spread of detrimental content.
   Recent research in natural language processing and machine learning has
   shown some hope for the purpose. Approaches and methods are now being
   developed for the automatic flagging of problematic textual content,
   namely hate speech, cyberbullying, or fake news, though mostly for
   English language texts. This paper presents an algorithmic approach
   based on deep learning models for the detection of violent incidents
   from tweets in the Spanish language (binary classification) and
   categorizes them further into five classes - accident, homicide, theft,
   kidnapping, and none (multi-label classification). The performance is
   evaluated on the recently shared benchmark dataset, and it is found that
   the proposed approach outperforms the various deep learning models, with
   a weighted average precision, recall, and F1-score of 0.82, 0.81, and
   0.80, respectively, for the binary classification. Similarly, for the
   multi-label classification, the proposed model reports weighted average
   precision, recall, and F1-score of 0.54, 0.79, and 0.64, respectively,
   which is also superior to the existing results reported in the
   literature. The study, thus, presents meaningful contribution to
   detection of violent incidents in Spanish language social media posts.},
Type = {Article},
Affiliation = {Singh, VK (Corresponding Author), Banaras Hindu Univ, Dept Comp Sci, Varanasi, India.
   Singh, VK (Corresponding Author), Univ Delhi, Dept Comp Sci, Delhi, India.
   Sharma, Deepawali, Banaras Hindu Univ, Dept Comp Sci, Varanasi, India.
   Gupta, Vedika, OP Jindal Global Univ, Jindal Global Business Global Sch, Sonipat, Haryana, India.
   Singh, Vivek Kumar, Banaras Hindu Univ, Dept Comp Sci, Varanasi, India.
   Singh, Vivek Kumar, Univ Delhi, Dept Comp Sci, Delhi, India.
   Pinto, David, Benemerita Univ Autonoma Puebla BUAP Mex, Fac Comp Sci, Puebla, Mexico.},
DOI = {10.1017/nlp.2024.25},
EarlyAccessDate = {SEP 2024},
Keywords = {Deep learning; social media text analytics; Spanish language; violent
   incident detection},
Author-Email = {vivek@bhu.ac.in},
Number-of-Cited-References = {34},
Times-Cited = {1},
Unique-ID = {WOS:001327415100001},
}

@article{ WOS:001308826000001,
Author = {Cai, Qizhe and Lin, Mingming and Zhang, Miao and Qin, Yunyun and Meng,
   Yuanlong and Wang, Jiangtao and Leng, Chenlei and Zhu, Weiwei and Li,
   Jie and You, Junjie and Lu, Xiuzhang},
Title = {Automated echocardiographic diastolic function grading: A hybrid
   multi-task deep learning and machine learning approach},
Journal = {INTERNATIONAL JOURNAL OF CARDIOLOGY},
Year = {2024},
Volume = {416},
Month = {DEC 1},
Abstract = {Background: Assessing left ventricular diastolic function (LVDF) with
   echocardiography as per ASE guidelines is tedious and time-consuming.
   The study aims to develop a fully automatic approach of this procedure
   by a lightweight hybrid algorithm combining deep learning (DL) and
   machine learning (ML). Methods: The model features multi-modality input
   and multi-task output, measuring LV ejection fraction (LVEF), left
   atrial end-systolic volume (LAESV), and Doppler parameters: mitral E
   wave velocity (E), A wave velocity (A), mitral annulus e' velocity (e'),
   and tricuspid regurgitation velocity (TRmax). The algorithm was trained
   and tested on two internal datasets (862 and 239 echocardiograms) and
   validated using three external datasets, including EchoNet-Dynamic and
   CAMUS. The ASE diastolic function decision tree and total probability
   theory were used to provide diastolic grading probabilities. Results:
   The algorithm, named MMnet, demonstrated high accuracy in both test and
   validation datasets, with Dice coefficients for segmentation between
   0.922 and 0.932 and classification accuracies between 0.9977 and 1.0.
   The mean absolute errors (MAEs) for LVEF and LAESV were 3.7 \% and 5.8
   ml, respectively, and for LVEF in external validation, MAEs ranged from
   4.9 \% to 5.6 \%. The diastolic function grading accuracy was 0.88 with
   hard criteria and up to 0.98 with soft criteria which account for the
   top two probability in total probability theory. Conclusions: MMnet can
   automatically grade ASE diastolic function with high accuracy and
   efficiency by annotating 2D videos and Doppler images.},
Type = {Article},
Affiliation = {Cai, QZ; Lu, XZ (Corresponding Author), Capital Med Univ, Beijing Chaoyang Hosp, Dept Ultrasound, 8 Gongren Tiyuchang Nanlu, Beijing 100020, Peoples R China.
   Cai, Qizhe; Lin, Mingming; Zhang, Miao; Qin, Yunyun; Leng, Chenlei; Zhu, Weiwei; Li, Jie; You, Junjie; Lu, Xiuzhang, Capital Med Univ, Beijing Chaoyang Hosp, Dept Ultrasound, 8 Gongren Tiyuchang Nanlu, Beijing 100020, Peoples R China.
   Meng, Yuanlong; Wang, Jiangtao, GE HealthCare, Beijing, Peoples R China.},
DOI = {10.1016/j.ijcard.2024.132504},
EarlyAccessDate = {SEP 2024},
Article-Number = {132504},
Keywords = {Left ventricular diastolic function; Deep learning; Machine learning;
   Multi-task out-put},
Author-Email = {echocaiqizhe@163.com
   lxz\_echo@163.com},
Number-of-Cited-References = {31},
Times-Cited = {11},
Unique-ID = {WOS:001308826000001},
}

