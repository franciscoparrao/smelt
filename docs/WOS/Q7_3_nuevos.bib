@incollection{ WOS:001545311800164,
Author = {Sun, Linjin and Ji, Yangjian and Peng, Tao},
Editor = {Tang, Y and Yan, CB and Darabi, H and Huang, Q and Jia, QS and Liu, X and Seatzu, C and Sheng, W and Yi, J},
Title = {Multi-task regression with process knowledge-based forest learners in
   process industries},
Booktitle = {2023 IEEE 19TH INTERNATIONAL CONFERENCE ON AUTOMATION SCIENCE AND
   ENGINEERING, CASE},
Series = {IEEE International Conference on Automation Science and Engineering},
Year = {2023},
Pages = {1065-1070},
Abstract = {The multi-task regression is of great significance for engineers in
   process control. It can not only help achieve more than one target
   variable estimation at once, but more importantly, it offers an
   opportunity for target variables to share knowledge. However, due to the
   complexity and nonlinearity of the production process that contains
   interconnected variables in process industries, it is challenging for
   conventional regression methods to obtain accurate results. To fill the
   gaps, more blackbox artificial intelligence models are proposed and
   applied to multi-task regression, while the process knowledge is often
   ignored during modeling. In this paper, a solution for adopting process
   knowledge-based learners for multi-task regression is proposed.
   Specifically, a two-stage learning structure with multiplicative
   integration weighted-random forest is offered. The initial estimated
   values of target variables are achieved from the separated base learners
   in the first stage, and then an integrated model is learned based on the
   previous predictions. In this manner, the knowledge of target variables
   and process knowledge among process data can ultimately be learned after
   training. The proposed method is finally applied to a VRM system in a
   case study, and the results verify its superiority over baseline
   methods.},
Type = {Proceedings Paper},
Affiliation = {Ji, YJ (Corresponding Author), Zhejiang Univ, Sch Mech Engn, State Key Lab Fluid Power \& Mech Syst, Zhejiang Key Lab Adv Mfg Technol, Hangzhou 310058, Peoples R China.
   Sun, Linjin; Ji, Yangjian; Peng, Tao, Zhejiang Univ, Sch Mech Engn, State Key Lab Fluid Power \& Mech Syst, Zhejiang Key Lab Adv Mfg Technol, Hangzhou 310058, Peoples R China.},
DOI = {10.1109/CASE56687.2023.10260502},
Keywords-Plus = {PREDICTIVE CONTROL},
Author-Email = {11825068@zju.edu.cn
   mejyj@zju.edu.cn
   tao\_peng@zju.edu.cn},
Number-of-Cited-References = {28},
Times-Cited = {0},
