@article{ WOS:001492605300002,
Author = {Abdennaji, Tarek Salem and Tipu, Rupesh Kumar and Alassaf, Yahya},
Title = {Predicting compressive and tensile strength of concrete with different
   sand types using machine learning},
Journal = {AIN SHAMS ENGINEERING JOURNAL},
Year = {2025},
Volume = {16},
Number = {8},
Month = {AUG},
Abstract = {The study evaluates the prediction accuracy of concrete compressive and
   tensile strength using machine learning and deep learning models with
   diverse sand materials, cement types, and filler combinations. A dataset
   of 587 concrete mix samples was compiled from literature. Seven
   prediction algorithms, including Linear Regression, Support Vector
   Regression, Decision Tree Regressor, Random Forest Regressor, Gradient
   Boosting Regressor, Extreme Gradient Boosting, and Multi-Layer
   Perceptron, were employed. Preprocessing involved handling missing data,
   outlier detection, encoding, and feature normalization for Principal
   Component Analysis. Performance was assessed using coefficient of
   determination (R2), root mean squared error, mean absolute error, and
   mean absolute percentage error with cross-validation. Extreme Gradient
   Boosting showed superior accuracy (R2 = 0.954 for compressive and 0.952
   for tensile strength). SHapley Additive Explanations identified curing
   age, water-to-binder ratio, and filler density as key features. A
   real-time GitHub interface allows strength predictions, aiding
   sustainable construction optimization.},
Type = {Article},
Affiliation = {Tipu, RK (Corresponding Author), KR Mangalam Univ, Sch Engn \& Technol, Dept Civil Engn, Gurugram 122103, Haryana, India.
   Abdennaji, Tarek Salem; Alassaf, Yahya, Northern Border Univ, Coll Engn, Dept Civil Engn, Ar Ar 73222, Saudi Arabia.
