   Yu, Shaoqing, Tongji Univ, Sch Med, Tongji Hosp, Dept Otolaryngol, 389 Xinchun Rd, Shanghai 200065, Peoples R China.},
DOI = {10.1016/j.bspc.2021.102821},
EarlyAccessDate = {JUN 2021},
Article-Number = {102821},
Keywords = {Rhinitis prediction; Class imbalance; Cascaded under-sampling; Ensemble
   learning},
Keywords-Plus = {ALLERGIC RHINITIS},
Author-Email = {eerfriend@yeah.net
   yu\_shaoqing@163.com},
Number-of-Cited-References = {28},
Times-Cited = {2},
