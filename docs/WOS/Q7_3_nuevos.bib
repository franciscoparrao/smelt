   Cosar, Ahmet, Ankara Sci Univ, Dept Comp Engn, TR-06200 Ankara, Turkey.},
DOI = {10.1109/ACCESS.2020.3022317},
Keywords = {Feature extraction; Prediction algorithms; Optimization; Dimensionality
