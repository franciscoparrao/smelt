   Iqbal, Jawaid, Riphah Int Univ, Fac Comp, Islamabad 44000, Pakistan.},
DOI = {10.3390/a16120548},
Article-Number = {548},
Keywords = {classification; multi-labeling; natural language processing; deep
   learning; optimization method; sentiment analysis},
Keywords-Plus = {SUPPORT VECTOR MACHINE; BINARY RELEVANCE; SENTIMENT ANALYSIS;
   NEURAL-NETWORK; CLASSIFIERS; FRAMEWORK},
Author-Email = {nasir.ayub@mail.au.edu.pk
