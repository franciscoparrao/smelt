DOI = {10.1109/ACCESS.2020.3004908},
Keywords = {Electrocardiogram; multi-label classification; ensemble classification;
   mutual information},
Keywords-Plus = {FEATURE-EXTRACTION; EFFICIENT; ALGORITHM; KNN},
Author-Email = {sunzhq@usst.edu.cn},
Number-of-Cited-References = {42},
