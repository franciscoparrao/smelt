   Tsui, Kwok Leung, Virginia Polytech Inst \& State Univ, Grad Dept Ind \& Syst Engn, Blacksburg, VA 24061 USA.},
DOI = {10.1109/JBHI.2024.3447705},
Keywords = {Feature extraction; Older adults; Risk management; Support vector
