}

@article{ WOS:001627875400034,
Author = {Metwalli, Ahmed and Fayed, Heba A. and Aly, Moustafa H.},
Title = {Intelligent 18-Tupling Optical Links: PSO-Tuned ML for Predicting and
   Minimizing Signal Penalties},
Journal = {JOURNAL OF LIGHTWAVE TECHNOLOGY},
Year = {2025},
Volume = {43},
Number = {23},
Pages = {10470-10477},
Month = {DEC 1},
Abstract = {A novel Machine Learning (ML) framework is proposed, in this paper to
   predict and optimize key performance indicators in an 18-tupling optical
   communication system. It starts with delivering and training on a public
   24,572-row OptiSystem dataset along with an open-source Python package,
   tupling\_ml, containing rigorous preprocessing that includes
   correlation-based feature selection and dimensionality reduction through
   Principal Components Analysis (PCA). This procedure reduces the feature
   space from 68 to 4 dimensions while preserving over 80\% of the
   variance. Several multi-output regression models are then evaluated,
   including multioutput Linear Regression (LR), Random Forest (RF),
   K-Nearest Neighbors (KNN), and a Regressor Chain of RF (RCRF).
   Validation is performed by means of 5-fold cross-validation (CV). The
   RCRF approach produces the best results, with a Mean Absolute Error
   (MAE) of 0.476, Mean Squared Error (MSE) of 0.963, and a coefficient of
   determination (R-2) of 0.893 on the test set. Finally, Particle Swarm
   Optimization (PSO) is employed to fine-tune two critical hyperparameters
   of the RF regressor: number of estimators and maximum depth, thereby
   further enhancing model performance by 3.3\% better than the untuned RF
   chain. By enabling proactive resource allocation and lowering signal
   penalties, the proposed framework expedites the deployment of
   next-generation (>100 Gb/s) optical fronthaul and fixed-wireless
   backhaul links.},
Type = {Article},
Affiliation = {Métwalli, A (Corresponding Author), Arab Acad Sci, Technol \& Maritime Transport, Alexandria 3650111, Egypt.
   Metwalli, Ahmed; Fayed, Heba A.; Aly, Moustafa H., Arab Acad Sci, Technol \& Maritime Transport, Alexandria 3650111, Egypt.},
DOI = {10.1109/JLT.2025.3604100},
Keywords = {Optical fiber communication; Optical receivers; Optical polarization;
   Radio frequency; Optical variables control; Optical modulation; Optical
   filters; Jitter; Optical coupling; Phase modulation; 18-tupling; machine
   learning; optical link; regressor chain random forest; particle swarm},
Author-Email = {ametwalli@aast.edu
   hebam@aast.edu
   mosaly@aast.edu},
Number-of-Cited-References = {27},
Times-Cited = {3},
Unique-ID = {WOS:001627875400034},
}

@article{ WOS:001621399900008,
Author = {Kang, Heewon and Farhan, Muhammad and Park, Sohwi and Cai, Li and
   Gomez-Flores, Allan and Kim, Hyunjung},
Title = {Chelating extraction of critical metals from cathode of end-of-life
   lithium titanium oxide batteries: Experiments, machine learning and
   validation},
Journal = {INTERNATIONAL JOURNAL OF MINERALS METALLURGY AND MATERIALS},
Year = {2025},
Volume = {32},
Number = {12},
Pages = {2958-2972},
Month = {DEC},
Abstract = {Lithium-ion batteries (LIBs) that reached their end-of-life (EoL)
   require recycling, rather than disposal, to recirculate valuable metals
   and protect the environment. This led us to investigate the extraction
   of metals from the cathodes of EoL lithium-titanate batteries using
   ethylenediaminetetraacetic acid disodium (EDTA-2Na). In this work, an
   orthogonal array was used to design experiments and signal-to-noise
   calculations were used to define the optimal conditions, which were 0.50
   mol/L EDTA-2Na, pH = 6, 75 degrees C, 180 min, 2\% pulp density, and 300
   r/min, resulting in 97.96\%, 94.79\%, 96.45\%, and 98.89\% leaching
   efficiencies for Li, Ni, Co, and Mn, respectively. Statistically
   significant interactions between variables were then identified using
   Pearson's correlation at the 95\% confidence interval, and the pH and
   temperature were found to be significant. The extraction efficiency
   decreased as the pH increased, but increased as the temperature
   increased. Machine learning fitting using linear regression for
   multi-output prediction was unsatisfactory, whereas random forest
   regression (RFR) produced satisfactory results. Permutation importance
   was computed on the fitted RFR to determine feature importance, and
   confirmed that the pH and temperature were influential variables;
   however, the time and pulp density were also noted. As the fitted RFR
   failed to satisfactorily predict leaching efficiencies in additional
   validation experiments, we recommend increasing the number of
   experiments and using additional fitting models. An additional analysis
   that included the initial oxidation-reduction potential (optimal 33.3
   mV) revealed this to be the most important variable, the effect of which
   largely overshadows those of all the other variables. Finally, an
   environmental assessment highlighted the benefits of the chelating
   extraction; however, the economic assessment indicated room for
   improvement.},
Type = {Article},
Affiliation = {Gomez-Flores, A; Kim, H (Corresponding Author), Hanyang Univ, Dept Earth Resources \& Environm Engn, 222 Wangsimni Ro, Seoul 04763, South Korea.
   Kang, Heewon; Farhan, Muhammad; Park, Sohwi; Gomez-Flores, Allan; Kim, Hyunjung, Hanyang Univ, Dept Earth Resources \& Environm Engn, 222 Wangsimni Ro, Seoul 04763, South Korea.
   Cai, Li, Donghua Univ, Coll Environm Sci \& Engn, Shanghai 201620, Peoples R China.},
DOI = {10.1007/s12613-025-3216-5},
Keywords = {end-of-life lithium-ion battery; lithium titanium oxide battery;
   hydrometallurgy; chelating extraction; machine learning},
Keywords-Plus = {ION BATTERIES; EDTA; COBALT; PRECIPITATION; SEPARATION; HYDROXIDE;
   RECOVERY; DENSITY},
Author-Email = {allanchito@gmail.com
   kshjkim@hanyang.ac.kr},
Number-of-Cited-References = {99},
Times-Cited = {1},
Unique-ID = {WOS:001621399900008},
}

@article{ WOS:001635008200001,
Author = {Wen, Tengteng and Cai, Xianfa and Li, Jincheng},
Title = {Graph Neural Networks vs. Traditional QSAR: A Comprehensive Comparison
   for Multi-Label Molecular Odor Prediction},
Journal = {MOLECULES},
Year = {2025},
Volume = {30},
Number = {23},
Month = {NOV 30},
Abstract = {Molecular odor prediction represents a fundamental challenge in
   computational chemistry with significant applications in fragrance
   design, food science, and chemical safety assessment. While traditional
   Quantitative Structure-Activity Relationship (QSAR) methods rely on
   hand-crafted molecular descriptors, recent advances in graph neural
   networks (GNNs) enable direct end-to-end learning from molecular graph
   structures. However, systematic comparison between these approaches for
   multi-label odor prediction remains limited. This study presents a
   comprehensive evaluation of traditional QSAR methods compared with
   modern GNN approaches for multi-label molecular odor prediction. Using
   the GoodScent dataset containing 3304 molecules with six high-frequency
   odor types (fruity, green, sweet, floral, woody, herbal), we
   systematically evaluate 23 model configurations across traditional
   machine learning algorithms (Random Forest, SVM, GBDT, MLP, XGBoost,
   LightGBM) with three feature-processing strategies and three GNN
   architectures (GCN, GAT, NNConv). The results demonstrate that GNN
   models achieve significantly superior performance, with GCN achieving
   the highest macro F1-score of 0.5193 compared to 0.4766 for the best
   traditional method (MLP with basic preprocessing), representing a 24.1\%
   relative improvement. Critically, we discover that threshold
   optimization is essential for multi-label chemical classification. These
   findings establish GNNs as the preferred approach for molecular property
   prediction tasks and provide crucial insights for handling class
   imbalance in chemical informatics applications.},
Type = {Article},
Affiliation = {Li, JC (Corresponding Author), Pharmaceut Univ, Guangdong Coll Med Informat Engn, Guangzhou 510006, Peoples R China.
   Wen, Tengteng; Cai, Xianfa; Li, Jincheng, Pharmaceut Univ, Guangdong Coll Med Informat Engn, Guangzhou 510006, Peoples R China.},
DOI = {10.3390/molecules30234605},
Article-Number = {4605},
Keywords = {molecular odor prediction; graph neural network (GNN); multi-label
   classification; threshold optimization},
Author-Email = {wentengteng@gdpu.edu.cn
   xianfacai@gdpu.edu.cn
   lijincheng@gdpu.edu.cn},
Number-of-Cited-References = {26},
Times-Cited = {1},
Unique-ID = {WOS:001635008200001},
}

@article{ WOS:001633423700005,
Author = {Lin, Huangbo and Ning, Zhihan and Zhang, David and Men, Shaoyang},
Title = {MetaLink: An imbalanced multi-label classification approach for
   automatic tongue diagnosis},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {302},
Month = {MAR 15},
Abstract = {Tongue diagnosis serves as a pivotal visual indicator in clinical
   assessment, yet its subjective nature, reliant on practitioner
   expertise, raises concerns regarding diagnostic consistency. This study
   advocates for computerized tongue image analysis as an objective
   measurement technique to automate diagnosis. To align with clinical
   realities, we address the inherent imbalanced and multi-label
   characteristics of medical data by constructing the first multi-label
   tongue image dataset, comprising 2059 samples annotated for nine
   diseases. We further introduce MetaLink, a novel ensemble framework with
   a linked-list architecture. Its core innovation lies in leveraging
   meta-features to capture high-order label correlations while mitigating
   class imbalance at the meta-level, thus eliminating the need for
   resampling the original training data. Extensive evaluations on our
   dataset and public benchmarks validate that MetaLink surpasses 18
   state-of-the-art methods, advancing the frontier of robust, objective
   tongue diagnosis. The dataset and code are publicly available to
   catalyze further research.},
Type = {Article},
Affiliation = {Men, S (Corresponding Author), Guangzhou Univ Chinese Med, Sch Med Informat Engn, 232 Waihuan East Rd, Guangzhou 510006, Guangdong, Peoples R China.
