@article{ WOS:001650399400001,
Author = {Mishra, Priyanshu and Saxena, Kanika and Brighu, Urmila and Gupta, A. B.},
Title = {A hybrid AI framework for multi-target prediction of organic pollutants
   removal and power consumption in sewage treatment plant: A case study of
   Jaipur, India},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2026},
Volume = {81},
Month = {JAN},
Abstract = {Considering the government's impetus for expansion of sewage treatment
   and reuse facilities, there is a crucial need for upgrading Sewage
   Treatment Plants (STPs) for maximum pollutant removal with minimum input
   of energy for achieving energy-efficient urban sanitation goals. In this
   study, a hybrid Artificial-Intelligence (AI) framework is developed to
   predict the removal efficiency of Total Suspended Solids (TSS),
   Biochemical Oxygen Demand (BOD), Chemical Oxygen Demand (COD), and Oil
   \& Grease (Oil), along with daily Power Consumption, in full-scale
   Sewage Treatment Plants (STPs) in Jaipur, India. The dataset contains
   996 records collected from four Sequencing Batch Reactor (SBR) Plants
   over two years. After data cleaning, missing-value imputation, and
   advanced feature engineering that expanded 18 original parameters to 64
   features, three Machine Learning (ML) models, Random Forest, Gradient
   Boosting, and Support Vector Regression (SVR) and two Deep Learning (DL)
   models, Multi-Layer Perceptron (MLP) and Long-Short Term Memory (LSTM)
   were combined. The hybrid model achieved R2 > 0.92 for all pollutants
   and energy prediction, improving accuracy over single models. Feature
   importance analysis showed inflow rate, influent COD, and total
   pollutant load as dominant predictors. The results demonstrated that
   hybrid AI can provide better process control for STP operations and
   serve as a decision support tool for process monitoring and optimization
   for regulatory compliance with effluent disposal standards with minimum
   energy input.},
Type = {Article},
Affiliation = {Mishra, P; Saxena, K (Corresponding Author), Motilal Nehru Natl Inst Technol Allahabad, Dept Civil Engn, Prayagraj 211004, Uttar Pradesh, India.
   Mishra, Priyanshu; Saxena, Kanika, Motilal Nehru Natl Inst Technol Allahabad, Dept Civil Engn, Prayagraj 211004, Uttar Pradesh, India.
   Brighu, Urmila; Gupta, A. B., Malaviya Natl Inst Technol Jaipur, Dept Civil Engn, Jaipur 302017, Rajasthan, India.},
DOI = {10.1016/j.jwpe.2025.109361},
EarlyAccessDate = {DEC 2025},
