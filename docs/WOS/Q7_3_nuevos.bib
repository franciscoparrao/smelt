@article{ WOS:001006510300001,
Author = {Liu, Tong and Chen, Sheng and Yang, Po and Zhu, Yunpeng and Harris,
   Chris J.},
Title = {Efficient adaptive deep gradient RBF network for multi-output nonlinear
   and nonstationary industrial processes},
Journal = {JOURNAL OF PROCESS CONTROL},
Year = {2023},
Volume = {126},
Pages = {1-11},
Month = {JUN},
Abstract = {Due to the complexity of process operation, industrial process data are
   often nonlinear and non -stationary, high dimensional, and multivariate
   with complex interactions between multiple outputs. To address all these
   issues, this paper proposes a novel industrial predictive model that
   integrates deep feature extraction and fast online adaptation, and can
   effectively deal with multiple process outputs. Specifically, a
   multi-output gradient radial basis function network (MGRBF) with
   excellent predictive capacity of nonstationary data is first used to
   provide preliminary prediction of target outputs. This prior quality
   information is combined with the original process input for deep feature
   learning and dimensional reduction. Through layer-wise feature
   extraction by the stacked autoencoder (SAE), deep quality-enhanced
   features can be obtained, which is further fed into a MGRBF tracker for
   online prediction. In order to timely capture the fast-changing process
   characteristics, the first two modules, namely, preliminary MGRBF
   predictor and SAE feature extractor are frozen after training, while the
   structure and parameters of the MGRBF tracker are updated online in an
   efficient manner. Two industrial case studies demonstrate that the
   proposed adaptive deep MGRBF network outperforms existing
   state-of-the-art online modeling approaches as well as deep learning
   models, in terms of both multi-output modeling accuracy and online
   computational complexity.(c) 2023 Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Yang, P (Corresponding Author), Univ Sheffield, Dept Comp Sci, Sheffield S1 4DP, England.
   Liu, Tong, Imperial Coll London, Dept Chem Engn, London SW7 2AZ, England.
   Chen, Sheng; Harris, Chris J., Univ Southampton, Sch Elect \& Comp Sci, Southampton SO17 1BJ, England.
   Chen, Sheng, Ocean Univ China, Fac Informat Sci \& Engn, Qingdao, Peoples R China.
   Yang, Po, Univ Sheffield, Dept Comp Sci, Sheffield S1 4DP, England.
   Zhu, Yunpeng, Queen Mary Univ London, Sch Engn \& Mat Sci, London E1 4NS, England.},
DOI = {10.1016/j.jprocont.2023.04.002},
EarlyAccessDate = {MAY 2023},
Keywords = {Multivariate nonlinear and nonstationary; industrial process;
   Multi-output gradient radial basis function\&nbsp; network; Stacked
   autoencoder; Quality-enhanced feature extraction; Online adaptive
   tracking},
Keywords-Plus = {SYSTEM IDENTIFICATION; ENSEMBLE REGRESSION; ALGORITHM; ANALYTICS},
