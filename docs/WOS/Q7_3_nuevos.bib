   He, Guangguo, Peoples Hosp Fengjie, Dept Ophthalmol, Chongqing 404600, Peoples R China.},
DOI = {10.1016/j.pdpdt.2025.105209},
EarlyAccessDate = {OCT 2025},
Article-Number = {105209},
Keywords = {Radiomic features; Arteriovenous ratio; Fundus imaging; Machine
   learning; Retinal vessel segmentation; Transformer networks; Deep
   learning; Multiclass classification; Diabetic retinopathy; Hypertensive
   retinopathy},
Keywords-Plus = {FEATURES; IMAGES},
