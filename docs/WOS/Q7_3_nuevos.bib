   Wan, Yin; Liu, Ding; Ren, Jun -Chao, Xian Univ Technol, Shaanxi Key Lab Complex Syst Control \& Intelligent, Xian, Shaanxi, Peoples R China.},
DOI = {10.1016/j.aei.2023.102255},
EarlyAccessDate = {NOV 2023},
Article-Number = {102255},
Keywords = {Broad Learning; Attention mechanism; Broad random forest; Multi-output
   soft sensor},
Author-Email = {liud@xaut.edu.cn},
Number-of-Cited-References = {26},
Times-Cited = {40},
Unique-ID = {WOS:001165960500001},
}

@article{ WOS:001118987900001,
Author = {Duan, Jicong and Yang, Xibei and Gao, Shang and Yu, Hualong},
Title = {A partition-based problem transformation algorithm for classifying
   imbalanced multi-label data},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2024},
Volume = {128},
Month = {FEB},
Abstract = {Multi-label learning has garnered much research interest due to its wide
   range of real-world applications. Many multi-label learning methods have
   been proposed; however, few have addressed the class imbalance problem
   existing in multi-label data. Even though some studies have taken this
   issue into account, most of them have ignored the label correlations or
   only considered random correlations between them. In this study, we
   propose a novel partition-based imbalanced multi-label learning
   algorithm, named Multi-label Learning based on Hierarchical Clustering
   (MLHC), to tackle this problem. MLHC first carries out hierarchical
   clustering on the original label space to divide it into several
   disconnected subspaces, each of which contains several labels that are
   strongly correlated with each other. Then, for each label subspace, we
   use the problem transformation strategy to convert it into a multi-class
   problem by binary coding. Any multi-class imbalance learning algorithm
   can be applied to the transformed multi-class data. Finally, the
   classification results will be decoded to retrieve the corresponding
   label subspace, and all label subspace results are combined to show the
   predicted label vector in the original label space. We conducted
   experiments not only on thirteen benchmark multi-label datasets but also
   carried out them on XJTU-SY which is a multi-label engineering
   application dataset, and the results indicated that our proposed MLHC
   learning algorithm outperforms several state-of-the-art class imbalance
   multi-label learning algorithms, demonstrating the effectiveness and
   necessity of discovering label correlations and transforming the
   original imbalanced multi-label learning problem into multiple strongly
   correlated multi-class imbalanced learning problems.},
Type = {Article},
Affiliation = {Yu, HL (Corresponding Author), Jiangsu Univ Sci \& Technol, Sch Comp, 666 Changhui Rd, Zhenjiang 212100, Jiangsu, Peoples R China.
   Duan, Jicong; Yang, Xibei; Gao, Shang; Yu, Hualong, Jiangsu Univ Sci \& Technol, Sch Comp, Zhenjiang 212003, Peoples R China.
   Yu, Hualong, Jiangsu Univ Sci \& Technol, Sch Comp, 666 Changhui Rd, Zhenjiang 212100, Jiangsu, Peoples R China.},
DOI = {10.1016/j.engappai.2023.107506},
EarlyAccessDate = {NOV 2023},
Article-Number = {107506},
Keywords = {Multi-label learning; Class imbalance learning; Hierarchical clustering;
   Problem transformation; Label correlations},
Keywords-Plus = {EXTREME LEARNING-MACHINE; SUPPORT VECTOR MACHINE; NEURAL-NETWORKS;
   STATISTICAL COMPARISONS; ENSEMBLE; CLASSIFIERS; FRAMEWORK; SMOTE},
Author-Email = {yuhualong@just.edu.cn},
Number-of-Cited-References = {64},
Times-Cited = {16},
Unique-ID = {WOS:001118987900001},
}

@article{ WOS:001160804800001,
Author = {Zhang, Shuying and Luo, Xiaojun and Mai, Bixian},
Title = {Multi-task machine learning models for simultaneous prediction of
   tissue-to-blood partition coefficients of chemicals in mammals},
Journal = {ENVIRONMENTAL RESEARCH},
Year = {2024},
Volume = {241},
Month = {JAN 15},
Abstract = {Tissue-to-blood partition coefficients (P-tb) are crucial for assessing
   the distribution of chemicals in organisms. Given the lack of
   experimental data and laborious nature of experimental methods, there is
   an urgent need to develop efficient predictive models. With the help of
   machine learning algorithms, i,e., random forest (RF), and artificial
   neural network (ANN), this study developed multi-task (MT) models that
   can simultaneously predict P-tb values for various mammalian tissues,
   including liver, muscle, brain, lung, and adipose. Single-task (ST)
   models using partial least squares regression, RF, and ANN algorithms
   for each endpoint were established for comparison. Overall, the
   performances of MT models were superior to those of ST models. The MT
   model using ANN algorithms showed the highest prediction accuracy with
   determination coefficients ranging from 0.704 to 0.886, root mean square
   errors between 0.223 and 0.410, and mean absolute errors ranging from
   0.178 to 0.285 log units. Results showed that lipophilicity and
   polarizability of molecules significantly influence their partition
   behavior in organisms. Applicability domains (ADs) of the models were
   characterized by weighted molecular similarity density, and weighted
   inconsistency in molecular activities of structure-activity landscapes.
   When constrained by ADs, the models displayed enhanced predictive
   accuracy, making them valuable tools for the risk assessment and
   management of chemicals.},
Type = {Article},
Affiliation = {Luo, XJ (Corresponding Author), Chinese Acad Sci, State Key Lab Organ Geochem, Guangzhou 510640, Peoples R China.
   Zhang, Shuying; Luo, Xiaojun; Mai, Bixian, Chinese Acad Sci, State Key Lab Organ Geochem, Guangzhou 510640, Peoples R China.
   Chinese Acad Sci, Guangzhou Inst Geochem, Guangdong Key Lab Environm Resources Utilizat \& Pr, Guangzhou 510640, Peoples R China.},
DOI = {10.1016/j.envres.2023.117603},
EarlyAccessDate = {NOV 2023},
Article-Number = {117603},
Keywords = {Risk assessment; Applicability domain; Artificial neural network;
   Tissue-to-blood partition coefficient; Multi-task learning; Random
   forest},
Keywords-Plus = {VOLATILE ORGANIC-COMPOUNDS; CHANNEL CATFISH; WILD FISH;
   BIOCONCENTRATION; AIR; DRUGS; PHARMACEUTICALS; PLASMA; MUSCLE; LIVER},
Author-Email = {luoxiaoj@gig.ac.cn},
Number-of-Cited-References = {46},
Times-Cited = {5},
Unique-ID = {WOS:001160804800001},
}

@article{ WOS:001100103900001,
Author = {Karuppiah, Marimuthu and Ramana, T. V. and Mohanty, Rajanikanta and
   Devarajan, Ganesh Gopal and Nagarajan, Senthil Murugan},
Title = {UIoTN-PMSE: Ubiquitous IoT network-based predictive modeling in smart
   environment},
Journal = {INTERNATIONAL JOURNAL OF COMMUNICATION SYSTEMS},
Year = {2025},
Volume = {38},
Number = {1},
Month = {JAN 10},
Abstract = {We proposed a three-stage intrusion detection system that utilizes a
   predictive machine learning model to identify and mitigate attacks on
   ubiquitous network. In the first stage, we applied Apriori-enabled
   Association Rule Mining (AARM) feature selection with support vector
   machine (SVM) for classification of flow of network. Second, we proposed
   ensemble learning-based AARM model (PAEL) for behavior analysis.
   Finally, for classification of multi-task labels, we proposed swarm bat
   optimization-based PAEL model. The trained model is applied to edge and
   fog computing devices to obtain lower resource utilization and improve
   the efficiency of the system. The intrusion detection process is
   performed in three stages: (i) at the edge devices, where abnormal data
   from network traffic from IoT devices were identified, (ii) the abnormal
   data sample is sent to fog computing deivce to confirm the attacks and
   abnormalities, (iii) final identified data sample is sent to cloud
   server. At cloud, proposed predictive machine learning (ML)-based
   generalized weight sum-enabled ensemble learning (PML-GWEL) model is
   trained on sample data, including new detected samples, to continually
   improve its accuracy. Once the model is trained, it is published to all
   nodes in the network to update their primary detector models and clear
   out any outdated pre-detector models. This process helps to reduce the
   hardware resources used by the pre-detector models and improve the
   overall efficiency of the system. The proposed model is compared with
   other existing techniques.
   This proposed architecture is a three-stage predictive machine learning
   enable intrusion detection (three-stage PML-ID) system for ubiquitous
   infrastructure including smart city, smart healthcare, smart
   transportation, smart farming, smart grid, and smart manufacturing.
   image},
