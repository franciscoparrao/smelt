   Pires, Ivan Miguel, Univ Aveiro, Escola Super Tecnol \& Gestao Agueda, Inst Telecomunicacoes, Agueda, Portugal.},
DOI = {10.1007/s10115-024-02113-7},
EarlyAccessDate = {APR 2024},
Keywords = {Multi-label text classification; Biomedical question classification;
   Feature engineering; Machine learning; Natural language processing
   (NLP); Lexical answer (LAT); Ensemble learning},
Author-Email = {21001279011@skt.umt.edu.pk
   muhammad-wasim@skt.umt.edu.pk
   sehrish.munawar@umt.edu.pk
   impires@ua.pt},
