   Xiong, Yifei, Shanghai Astron Observ, Shanghai 200030, Peoples R China.
   Liu, Yanli; Cui, Xuehui, China Univ Petr, Coll Sci, Beijing 102249, Peoples R China.
   Lei, Gang, King Fahd Univ Petr \& Minerals, Dept Petr Engn, CPG, Dhahran 31261, Saudi Arabia.},
DOI = {10.1016/j.petrol.2020.107801},
