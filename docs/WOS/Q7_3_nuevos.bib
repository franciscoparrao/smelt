   Rezaie, Fatemeh, Korea Univ Sci \& Technol, Dept Geophys Explorat, 217 Gajeong Ro, Daejeon 34113, South Korea.},
DOI = {10.1016/j.marpolbul.2026.119307},
EarlyAccessDate = {JAN 2026},
Article-Number = {119307},
Keywords = {Water quality index; Remote sensing; Coastal regions; Random forest;
   Meta-heuristic optimization; China},
Keywords-Plus = {QUALITY INDEX WQI; RIVER ESTUARY; SEDIMENT; AREAS; CHINA; JAPAN},
