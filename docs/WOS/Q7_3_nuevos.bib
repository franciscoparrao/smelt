   Katona, Tamas; Harangi, Balazs, Univ Debrecen, Fac Informat, Dept Data Sci \& Visualizat, H-4028 Debrecen, Hungary.
   Toth, Gabor, Univ Debrecen, Fac Med, Dept Lab Med, H-4032 Debrecen, Hungary.
   Petro, Matyas, Univ Debrecen, Med Imaging Inst, Fac Med, Dept Radiol, H-4032 Debrecen, Hungary.},
DOI = {10.3390/make6020060},
Keywords = {multi-label classification; convolutional neural networks; deep
   learning; ensemble},
Keywords-Plus = {COMPUTER ANALYSIS; NETWORKS},
Author-Email = {katona.tamas@inf.unideb.hu
   tothgab@med.unideb.hu
   harangi.balazs@inf.unideb.hu},
