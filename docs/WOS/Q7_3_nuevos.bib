@incollection{ WOS:001595166800003,
Author = {Bardos, Avraam and Mylonas, Nikolaos and Mollas, Ioannis and Tsoumakas,
   Grigorios},
Editor = {Silvestri, F and Meo, R},
Title = {Local Interpretability of Random Forests for Multi-target Regression},
Booktitle = {MACHINE LEARNING AND PRINCIPLES AND PRACTICE OF KNOWLEDGE DISCOVERY IN
   DATABASES, ECML PKDD 2023, PT I},
Series = {Communications in Computer and Information Science},
Year = {2025},
Volume = {2133},
Pages = {38-45},
Abstract = {Multi-target regression is useful in a plethora of applications.
   Although random forest models perform well in these tasks, they are
   often difficult to interpret. Interpretability is crucial in machine
   learning, especially when it can directly impact human well-being.
   Although model-agnostic techniques exist for multi-target regression,
   specific techniques tailored to random forest models are not available.
   To address this issue, we propose a technique that provides rule-based
   interpretations for instances made by a random forest model for
   multi-target regression, inspired by a recent model-specific technique
   for random forest interpretability. The proposed technique was evaluated
   through extensive experiments and shown to offer competitive
   interpretations compared to state-of-the-art techniques.},
Type = {Proceedings Paper},
Affiliation = {Mylonas, N (Corresponding Author), Aristotle Univ Thessaloniki, Thessaloniki 54632, Greece.
   Bardos, Avraam; Mylonas, Nikolaos; Mollas, Ioannis; Tsoumakas, Grigorios, Aristotle Univ Thessaloniki, Thessaloniki 54632, Greece.},
