   Carvalho-Filho, Marco A., Univ Groningen, Univ Med Ctr Groningen, Wenckebach Inst, Res program LEARN, Groningen, Netherlands.},
DOI = {10.1007/s10278-024-01344-y},
EarlyAccessDate = {DEC 2024},
