   Osmanli, Suleyman, Erciyes Univ, Fac Engn, Dept Mech Engn, TR-38280 Kayseri, Turkiye.},
DOI = {10.1080/15567036.2023.2230930},
Keywords = {VAWT; turbine; wind; feature selection; multi-output regression; machine
   learning; energy},
Keywords-Plus = {ENERGY; OPTIMIZATION; CYLINDER; WAVE},
Author-Email = {steksin@erciyes.edu.tr},
Number-of-Cited-References = {46},
Times-Cited = {6},
Unique-ID = {WOS:001023860400001},
}

@article{ WOS:001039749900001,
Author = {Choudhury, Shatabdi},
Title = {Multi-target modeling of spine movements for signing Avatar},
Journal = {UNIVERSAL ACCESS IN THE INFORMATION SOCIETY},
Year = {2025},
Volume = {24},
Number = {1},
Pages = {5-17},
Month = {MAR},
Abstract = {Virtual avatars are increasingly used in sign language interpretation
   (McDonald and Wolfe in Comput Speech Lang 54:1-20, 2019), and education
   (De Martino et al. in Univ Access Inf Soc 16(3):793-808, 2017) to
   facilitate communication between deaf and hard-of-hearing and hearing
   individuals. While technological advances have allowed the creation of
   avatars that can portray sign language with more realistic and
   believable motion, many of these avatars still lack naturalness and
   supporting movements. Often not included in linguistic annotations,
   these details are crucial for creating lifelike and communicative
   animations (Jancso et al. in International conference on computers
   helping people with special needs, Springer, Berlin, pp 438-445, 2016).
   This paper proposes using multi-target modeling of spine angle movements
   in signing avatars using motion capture data. We first describe the data
   collection and pre-processing steps of the motion capture data,
   including input features such as the spine angles and left and right
   wrist positions. We explore various modeling techniques, including deep
   learning, linear regression, and random forest. We examine the
   visualization of partial dependence plots (PDP) (Friedman in Ann Stat
   29(5):1189-1232, 2001) and individual conditional expectation (ICE)
   plots to understand the relationships between the input and output
   variables. Our findings indicate that the deep learning model is the
   most effective and produces a smooth prediction. PDP and ICE plots
   provided valuable visualization insight into the behavior of the models
   and could be helpful in further analysis (Petch et al. in Can J Cardiol
   38(2):204-213, 2021). The approach represents a promising step toward
   creating more realistic and expressive signing avatars, ultimately
   improving the engagement and user experience with the avatar.},
Type = {Review},
Affiliation = {Choudhury, S (Corresponding Author), DePaul Univ, Sch Comp, 243 S Wabash Ave, Chicago, IL 60604 USA.
   Choudhury, Shatabdi, DePaul Univ, Sch Comp, 243 S Wabash Ave, Chicago, IL 60604 USA.},
DOI = {10.1007/s10209-023-01019-5},
EarlyAccessDate = {JUL 2023},
Keywords = {Sign language; Avatar; Deep learning; Multi-target regression; Partial
   dependence plots; Motion capture data},
Keywords-Plus = {HEAD},
Author-Email = {schoud12@depaul.edu},
Number-of-Cited-References = {41},
Times-Cited = {2},
Unique-ID = {WOS:001039749900001},
}

@article{ WOS:001047155800001,
Author = {Qian, Lili and Ni, Jun and Luo, Ming and Lu, Yi and Wang, Shuang and
   Yuan, Chuan and Zhu, Kai and Zhang, Bo and Gu, Heng},
Title = {Machine learning models for fast and isothermal hydrothermal
   liquefaction of biomass: Comprehensive experiment and prediction of
   various product fraction yields},
Journal = {ENERGY CONVERSION AND MANAGEMENT},
Year = {2023},
Volume = {292},
Month = {SEP 15},
Abstract = {Hydrothermal liquefaction (HTL) shows promise in biocrude productions
   from wet biomass. In this study, phycocyanin conversion was performed
   under an extensive range of conditions (set-point temperatures of
   300-500 degrees C and holding times of 20-1800 s), covering both
   isothermal and fast HTL processes. Based on 226 sets of product fraction
   yields obtained from this study and literature, machine learning models,
   such as multiple linear regression, decision regression tree, random
   forest, gradient boosting regression, and support vector regression were
   developed. The model with the highest predictive accuracy for biocrude
   yield was further used to perform both single and multi-task predictions
   of other product yields. The results show that fast HTL at 500 degrees C
   and 40 s produced the highest biocrude yield (35.0 wt\%) and energy
   recovery (55.2\%), which were 11.9 wt\% and 15.9\% higher than those
   obtained by conventional isothermal HTL at 300 degrees C and 1800 s.
   Biocrude predominantly consisted of nitrogenous heterocyclic compounds,
   leading to its high nitrogen content (similar to 10 wt\%). In addition,
   water quality analysis shows that the chemical oxygen demand, ammonia
   and total phosphorus contents of the aqueous phase by-products were much
   higher than the discharge standards and required further treatments.
   Cross-validation and testing error analysis show that the random forest
   model exhibited the highest predictive accuracy for the biocrude yield,
   with a testing R-2 of 0.93. Additionally, the random forest model could
   predict other product fraction yields with desirable accuracies.
   According to the feature importance analysis, the most important factor
   for biocrude production from fast HTL was the residence time, followed
   by the reaction temperature.},
Type = {Article},
Affiliation = {Wang, S (Corresponding Author), Jiangsu Univ, Sch Energy \& Power Engn, Zhenjiang 212013, Jiangsu, Peoples R China.
   Qian, Lili; Ni, Jun; Luo, Ming; Wang, Shuang; Zhu, Kai, Jiangsu Univ, Sch Energy \& Power Engn, Zhenjiang 212013, Jiangsu, Peoples R China.
   Lu, Yi, Nanjing Audit Univ, Sch Stat \& Data Sci, Nanjing 211815, Jiangsu, Peoples R China.
   Yuan, Chuan, Jiangsu Univ, Sch Agr Engn, Zhenjiang 212013, Jiangsu, Peoples R China.
   Zhang, Bo, Jiangsu Univ, Inst Energy Res, Zhenjiang 212013, Jiangsu, Peoples R China.
   Gu, Heng, Jiangsu Univ, Sch Mech Engn, Zhenjiang 212013, Jiangsu, Peoples R China.},
DOI = {10.1016/j.enconman.2023.117430},
EarlyAccessDate = {JUL 2023},
Article-Number = {117430},
Keywords = {Fast hydrothermal liquefaction; Isothermal hydrothermal liquefaction;
   Biocrude; Phycocyanin; Machine learning; Random forest},
Keywords-Plus = {SEWAGE-SLUDGE; SPIRULINA-PLATENSIS; SUPERCRITICAL WATER; OIL; PATHWAYS;
   BIOCRUDE},
