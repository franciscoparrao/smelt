   Ghazouani, Haythem; Barhoumi, Walid, Univ Carthage, Ecole Natl Ingn Carthage, 45 Rue Entrepreneurs, Tunis 2035, Carthage, Tunisia.},
DOI = {10.1007/s12065-024-00969-w},
EarlyAccessDate = {AUG 2024},
Keywords = {Facial expression recognition in-the-wild; Stacking; Dynamic selection
   ensemble; Multi-task learning; Cross-dataset evaluation},
