   Hao, Yong, Yangtze Univ, Coll Urban Construct, Jingzhou 434025, Peoples R China.},
DOI = {10.1016/j.atech.2025.101644},
EarlyAccessDate = {NOV 2025},
Article-Number = {101644},
Keywords = {Tea seedlings; Arbuscular mycorrhizal fungi; Nitrogen nutrition; Root
   architecture; Machine learning; Phenomics},
Keywords-Plus = {SOIL; GROWTH; CARBON},
Author-Email = {201573031@yangtzeu.edu.cn
