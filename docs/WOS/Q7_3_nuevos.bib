   annisa.divayu.ft20@mail.umy.ac.id},
Number-of-Cited-References = {16},
Times-Cited = {0},
Unique-ID = {WOS:001291237000045},
}

@incollection{ WOS:001289421700005,
Author = {Joshi, Sharvari and Parikh, Aayush and Walavalkar, Praniket and Vekaria,
   Varun and Sonawane, Pankaj},
Editor = {Sharma, H and Shrivastava, V and Tripathi, AK and Wang, L},
Title = {A Multi-label Classification Approach to Detect Types of Traumas on
   Social Media},
Booktitle = {COMMUNICATION AND INTELLIGENT SYSTEMS, VOL 1, ICCIS 2023},
Series = {Lecture Notes in Networks and Systems},
Year = {2024},
Volume = {967},
Pages = {67-81},
Abstract = {In an age of blooming virtual communities, social media is the apex of
   mass divulgence and idea expression. Access to a plethora of social
   media platforms allows people to publicly share their joys and sorrows.
   However, deciphering a message or comment's genuine sentiment or trauma
   is challenging. This study aims to categorize text information mined
   from Reddit posts or comments into one or more of the 22 distinct
   categories of trauma. The proposed workflow starts with the collection
   of textual data followed by generation of text embeddings for each text.
   After being processed, the data is fed to Light Gradient Boosting
   Machine (LGBM), Support Vector Classifier (SVC), and Random Forest (RF)
   classifiers for single-label classification and LGBM with Binary
   Relevance and Random k-Label sets with Overlap (RAKELO) for multi-label
   classification. The maximum accuracy for single-label classification was
   yielded by LGBM (94\%), whereas the highest accuracy for multi-label
   data was achieved by RAKELO (72\%).},
Type = {Proceedings Paper},
Affiliation = {Joshi, S (Corresponding Author), Dwarkadas J Sanghvi Coll Engn, Mumbai, India.
   Joshi, Sharvari; Parikh, Aayush; Walavalkar, Praniket; Vekaria, Varun; Sonawane, Pankaj, Dwarkadas J Sanghvi Coll Engn, Mumbai, India.},
DOI = {10.1007/978-981-97-2053-8\_5},
Keywords = {Multi-label classification; Random forest; Support vector machine;
