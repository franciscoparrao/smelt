   Famiglini, Lorenzo; Campagner, Andrea; Cabitza, Federico, Univ Milano Bicocca, Dept Informat Syst \& Commun, Viale Sarca 336, I-20126 Milan, Italy.
   Campagner, Andrea; Cabitza, Federico, IRCCS Ist Ortoped Galeazzi, Via Riccardo Galeazzi 4, I-20161 Milan, Italy.},
DOI = {10.1016/j.inffus.2023.101978},
EarlyAccessDate = {AUG 2023},
