@incollection{ WOS:001392668202046,
Author = {Wu, Yu-Hsuan and Lee, Ching-Chih and Chuang, Cheng-Hsin and Tsai,
   Chun-Wei},
Book-Group-Author = {IEEE},
Title = {An Effective Adaptive Ensemble Survival Model for Risk Prediction},
Booktitle = {2024 INTERNATIONAL JOINT CONFERENCE ON NEURAL NETWORKS, IJCNN 2024},
Series = {IEEE International Joint Conference on Neural Networks (IJCNN)},
Year = {2024},
Abstract = {Several machine learning based methods were presented to generate the
   survival model for predicting the hazard ratio of the covariates of
   patients in recent years. To enhance the risk prediction for survival
   analysis, an adaptive ensemble survival model (AESurv) is presented in
   this paper. The proposed method combines a set of well-known survival
   models-namely, Cox proportional hazards model, random survival forest,
   DeepSurv, DeepHit, neural multi-task logistic regression model, and
   CoxTime-as an ``ensemble model{''} to improve the generalization ability
   for risk prediction. Also proposed in this paper are an ``adaptive
   voting neural network{''} to optimize the prediction results of the
   proposed ensemble model for different datasets and a ``hyperparameter
   optimization method{''} based on simulated annealing to fine-tune the
   hyperparameters for the voting neural network to maximize the predictive
   performance. Experimental results show that AESurv outperforms seven
   state-of-the-art survival models on five public medical datasets in
   terms of the concordance index.},
Type = {Proceedings Paper},
Affiliation = {Wu, YH (Corresponding Author), Natl Sun Yat Sen Univ, Dept Comp Sci \& Engn, Kaohsiung, Taiwan.
   Wu, Yu-Hsuan; Tsai, Chun-Wei, Natl Sun Yat Sen Univ, Dept Comp Sci \& Engn, Kaohsiung, Taiwan.
   Lee, Ching-Chih, Kaohsiung Vet Gen Hosp, Dept Otolaryngol Head \& Neck Surg, Kaohsiung, Taiwan.
   Chuang, Cheng-Hsin, Natl Sun Yat Sen Univ, Inst Med Sci \& Technol, Kaohsiung, Taiwan.},
DOI = {10.1109/IJCNN60899.2024.10651004},
Keywords = {survival analysis; risk prediction; deep learning; and ensemble learning},
Keywords-Plus = {CENSORED-DATA; REGRESSION},
Number-of-Cited-References = {53},
