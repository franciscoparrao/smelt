   Qi, Zhiquan; Tian, YingJie; Shi, Yong, Univ Chinese Acad Sci, Sch Econ \& Management, Beijing 100190, Peoples R China.},
DOI = {10.1016/j.patcog.2022.108767},
EarlyAccessDate = {MAY 2022},
