@article{ WOS:001705849400001,
Author = {Kumari, Kirti and Jha, Shirish Shekhar},
Title = {Lightweight emotion classification in Urdu: A multi-head attention and
   hybrid approach},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {171},
Month = {MAY 1},
Abstract = {Emotion classification in low-resource languages like Urdu is obstructed
   by limited annotated data and complex linguistic structures. The present
   research addresses these challenges by proposing and evaluating two
   novel approaches: a hybrid model incorporating multi-head attention and
   an ensemble of machine learning and deep learning classifiers. The
   multi-head attention mechanism is specifically used to capture the
   contextual nuances essential for accurate emotion detection in Urdu
   text. The proposed ensemble model achieves a state-of-the-art weighted
   average F1-Score of 76.68\% and a recall of 75.00\% on a benchmark
   dataset, outperforming existing methods. The current work demonstrates
   the effectiveness of hybrid architectures in creating robust and
   efficient emotion classification models for low-resource languages,
   establishing a new performance benchmark for the task. The research
   discovers the effective application of Artificial Intelligence in
   emotion classification and the importance of lightweight models for
   low-resource languages.},
Type = {Article},
Affiliation = {Kumari, K (Corresponding Author), Indian Inst Informat Technol, Dept Comp Sci \& Engn, Ranchi 835217, Jharkhand, India.
   Jha, SS (Corresponding Author), Indian Inst Sci Educ \& Res Bhopal, Dept Elect Engn \& Comp Sci, Bhopal 462066, India.
   Kumari, Kirti, Indian Inst Informat Technol, Dept Comp Sci \& Engn, Ranchi 835217, Jharkhand, India.
   Jha, Shirish Shekhar, Indian Inst Sci Educ \& Res Bhopal, Dept Elect Engn \& Comp Sci, Bhopal 462066, India.},
DOI = {10.1016/j.engappai.2026.114265},
Article-Number = {114265},
Keywords = {Multi-label emotion detection; Sentence embedding; Multi-head attention;
   Ensemble techniques; Urdu; Lightweight model},
Author-Email = {kirti@iiitranchi.ac.in
   shirish24@iiserb.ac.in},
