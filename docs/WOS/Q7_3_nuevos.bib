@article{ WOS:001596198300005,
Author = {Dowlatshahi, Mohammad Bagher and Hashemi, Amin and Rafsanjani, Marjan
   Kuchaki and Fu, Yulong},
Title = {Ant colony optimization enhanced with ensemble of pheromone vectors
   using multi-criteria decision making: A case study in multi-label text
   feature selection},
Journal = {APPLIED SOFT COMPUTING},
Year = {2025},
Volume = {185},
Number = {B},
Month = {DEC},
Abstract = {Ant Colony Optimization (ACO) deals with complex combinatorial
   optimization problems by simulating the foraging behavior of ants. While
   many enhancements have been proposed, effectively balancing exploitation
   and exploration remains a key challenge, heavily influenced by the
   pheromone evaporation rate. In this paper, we introduce a novel
   strategy-EPAnt-which, for the first time, employs an ensemble of
   multiple pheromone evaporation rates in ACO. This ensemble generates
   multiple pheromone trail vectors that are intelligently fused using a
   Multi-Criteria Decision-Making (MCDM) approach to produce a robust and
   adaptive pheromone update. This innovation enhances the algorithm's
   global search capabilities and resilience against premature convergence.
   We apply the proposed method to a multi-label text feature selection
   task, demonstrating significant performance improvements over existing
   methods. Across 10 benchmark datasets, EPAnt achieves better
   classification performance based on multiple metrics (accuracy, average
   precision, one-error, hamming loss, and coverage), and statistically
   outperforms 9 state-of-the-art algorithms under the Friedman test.},
Type = {Article},
Affiliation = {Rafsanjani, MK (Corresponding Author), Shahid Bahonar Univ Kerman, Fac Math \& Comp, Dept Comp Sci, Kerman, Iran.
   Dowlatshahi, Mohammad Bagher; Hashemi, Amin, Lorestan Univ, Fac Engn, Dept Comp Engn, Khorramabad, Iran.
