Keywords = {High-resolution remote sensing; Ipomoea batatas; K-nearest neighbors;
   Random Forest; Smart harvesting; Transformative agriculture},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; MODEL; FRAMEWORK},
Author-Email = {danilo.tedesco@unesp.br},
