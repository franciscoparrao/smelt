   Hu, Xuegang; Wu, Xindong, Hefei Univ Technol, Sch Comp Sci \& Informat Engn, Hefei 230002, Anhui, Peoples R China.},
DOI = {10.1109/TKDE.2022.3200068},
Keywords = {Multi-label data stream; classification; high-dimensional data; feature
   selection; concept drift},
