   Wang, Yuanyuan, Australian Natl Univ, Canberra, ACT 650500, Australia.},
DOI = {10.1504/IJCSM.2022.127831},
Keywords = {multi-label classification; ensemble chains; ReliefF; feature selection;
   bagging method},
Author-Email = {tjom2008@163.com
