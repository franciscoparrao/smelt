   Son, Nguyen Minh; Truong, Do Si, Lac Hong Univ, Fac Informat Technol, Bien Hoa 810000, Dong Nai, Vietnam.
   Nguyen, Thanh Q., Nguyen Tat Thanh Univ, Inst Interdisciplinary Sci, Ho Chi Minh City 700000, Vietnam.
   Nguyen, Thanh Q., Nguyen Tat Thanh Univ, NTT Hitech Inst, Ho Chi Minh City 700000, Vietnam.},
DOI = {10.1007/s10489-025-06876-6},
Article-Number = {1081},
Keywords = {Hybrid model; Multi-output regression; Random forest; Linear regression;
   Smart agriculture; Environmental indicators; Precision farming; IoT;
   Model interpretability},
