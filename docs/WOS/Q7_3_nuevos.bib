DOI = {10.1109/INDICON56171.2022.10040158},
Keywords = {agriculture; crop recommendation; voting; K-Nearest Neighbor},
Author-Email = {mail2dhaya@gmail.com},
Number-of-Cited-References = {15},
Times-Cited = {0},
Unique-ID = {WOS:000978286100400},
}

@incollection{ WOS:000967781000038,
Author = {Grzeszczyk, Michal K. and Plotka, Szymon and Sitek, Arkadiusz},
Editor = {Camara, O and Puyol-Anton, E and Qin, C and Sermesant, M and Suinesiaputra, A and Wang, S and Young, A},
Title = {Multi-task Swin Transformer for Motion Artifacts Classification and
   Cardiac Magnetic Resonance Image Segmentation},
Booktitle = {STATISTICAL ATLASES AND COMPUTATIONAL MODELS OF THE HEART: REGULAR AND
   CMRXMOTION CHALLENGE PAPERS, STACOM 2022},
Series = {Lecture Notes in Computer Science},
Year = {2022},
Volume = {13593},
Pages = {409-417},
Abstract = {Cardiac Magnetic Resonance Imaging is commonly used for the assessment
   of the cardiac anatomy and function. The delineations of left and right
   ventricle blood pools and left ventricular myocardium are important for
   the diagnosis of cardiac diseases. Unfortunately, the movement of a
   patient during the CMR acquisition procedure may result in motion
   artifacts appearing in the final image. Such artifacts decrease the
   diagnostic quality of CMR images and force redoing of the procedure. In
   this paper, we present a Multi-task Swin UNEt TRansformer network for
   simultaneous solving of two tasks in the CMRxMotion challenge: CMR
   segmentation and motion artifacts classification. We utilize both
   segmentation and classification as a multi-task learning approach which
   allows us to determine the diagnostic quality of CMR and generate masks
   at the same time. CMR images are classified into three diagnostic
   quality classes, whereas, all samples with non-severe motion artifacts
   are being segmented. Ensemble of five networks trained using 5-Fold
   Cross-validation achieves segmentation performance of DICE coefficient
   of 0.871 and classification accuracy of 0.595.},
Type = {Proceedings Paper},
Affiliation = {Grzeszczyk, MK (Corresponding Author), Sano Ctr Computat Med, Krakow, Poland.
   Grzeszczyk, Michal K.; Plotka, Szymon, Sano Ctr Computat Med, Krakow, Poland.
   Plotka, Szymon, Univ Amsterdam, Inst Informat, Amsterdam, Netherlands.
   Sitek, Arkadiusz, Harvard Med Sch, Massachusetts Gen Hosp, Boston, MA USA.},
DOI = {10.1007/978-3-031-23443-9\_38},
Keywords = {Multi-task learning; Cardiac magnetic resonance imaging; Segmentation;
   Image quality assessment},
Author-Email = {m.grzeszczyk@sanoscience.org},
Number-of-Cited-References = {20},
Times-Cited = {6},
