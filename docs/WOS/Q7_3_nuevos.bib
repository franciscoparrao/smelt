}

@article{ WOS:001453816400001,
Author = {Jalali, Hamed and Kasneci, Gjergji},
Title = {Multilabel Classification for Entry-Dependent Expert Selection in
   Distributed Gaussian Processes},
Journal = {ENTROPY},
Year = {2025},
Volume = {27},
Number = {3},
Month = {MAR 14},
Abstract = {By distributing the training process, local approximation reduces the
   cost of the standard Gaussian process. An ensemble method aggregates
   predictions from local Gaussian experts, each trained on different data
   partitions, under the assumption of perfect diversity among them. While
   this assumption ensures tractable aggregation, it is frequently violated
   in practice. Although ensemble methods provide consistent results by
   modeling dependencies among experts, they incur a high computational
   cost, scaling cubically with the number of experts. Implementing an
   expert-selection strategy reduces the number of experts involved in the
   final aggregation step, thereby improving efficiency. However, selection
   approaches that assign a fixed set of experts to each data point cannot
   account for the unique properties of individual data points. This paper
   introduces a flexible expert-selection approach tailored to the
   characteristics of individual data points. To achieve this, we frame the
   selection task as a multi-label classification problem in which experts
   define the labels, and each data point is associated with specific
   experts. We discuss in detail the prediction quality, efficiency, and
   asymptotic properties of the proposed solution. We demonstrate the
   efficiency of the proposed method through extensive numerical
   experiments on synthetic and real-world datasets. This strategy is
   easily extendable to distributed learning scenarios and multi-agent
   models, regardless of Gaussian assumptions regarding the experts.},
Type = {Article},
Affiliation = {Jalali, H (Corresponding Author), Univ Tubingen, Ctr Plant Mol Biol ZMBP, D-72076 Tubingen, Germany.
   Jalali, Hamed, Univ Tubingen, Ctr Plant Mol Biol ZMBP, D-72076 Tubingen, Germany.
   Kasneci, Gjergji, Tech Univ Munich, Sch Social Sci \& Technol, D-80333 Munich, Germany.},
DOI = {10.3390/e27030307},
Article-Number = {307},
Keywords = {distributed learning; Gaussian processes; multi-agent systems;
   multi-label classification; conditional dependency; ensemble learning},
Author-Email = {hamed.jalali@uni-tuebingen.de
   gjergji.kasneci@tum.de},
Number-of-Cited-References = {53},
Times-Cited = {0},
Unique-ID = {WOS:001453816400001},
}

@article{ WOS:001445491100006,
Author = {Kumar, Thinesh and Seelam, Naresh Kumar and Rao, G. Srinivasa},
Title = {Estimating coal proximate parameters and Gross Calorific Value from
   geophysical logs in Talcher coalfield using multi-layer perceptron,
   multi-output regression, and ensemble machine learning},
Journal = {JOURNAL OF EARTH SYSTEM SCIENCE},
Year = {2025},
Volume = {134},
Number = {2},
Month = {MAR 14},
Abstract = {Gross Calorific Value (GCV) is one of the critical parameters in coal
   exploration. It defines the amount of energy released during coal
   burning that helps to fix the coal seams' grade. In this study, machine
   learning (ML) tools based on Multi-Layer Perceptron (MLP), multi-output
   regression, and ensemble-based models (Random Forest (RF), extreme
   gradient boosting (XGBoost), and stacking) were used to estimate the
   proximate parameters (ash, moisture, volatile matter (VM), and fixed
   carbon (FC)) and GCV from geophysical logs. All these ML models were
   trained and tested using geophysical log data (natural gamma, density,
   and resistivity logs) and lab analysis data from four boreholes drilled
   in Talcher coalfield. The performance of the ML models is evaluated
   using mean absolute error, root mean square error, and analysis of
   variance. Results of the study reveal that XGBoost and stack-4 (RF +
   MLP) exhibited better performance in predicting all target variables,
   while other ML models showed inconsistencies in the prediction of VM,
   FC, and GCV. The potentiality of ML models for GCV prediction was
   further supported by the goodness of fit (R-square) >0.80 against
   laboratory outputs of core samples standardized at 40 degrees C and 60\%
   relative humidity. However, ML models predicted slightly over/under
   grade values for a few coal seams than lab data, possibly due to
   splitting and sudden spatial composition changes in the area. Adding
   more data to training from intricate geological conditions may further
   improve the performance of ML models.},
Type = {Article},
Affiliation = {Rao, GS (Corresponding Author), Indian Inst Technol, Dept Earth Sci, Mumbai 400076, India.
   Kumar, Thinesh; Seelam, Naresh Kumar, Coal India Ltd, CMPDIL, Ranchi 834008, Jharkhand, India.
   Rao, G. Srinivasa, Indian Inst Technol, Dept Earth Sci, Mumbai 400076, India.},
DOI = {10.1007/s12040-025-02517-1},
Article-Number = {66},
Keywords = {Well logs; Gross Calorific Value; machine learning; stacking; coal
   exploration},
Keywords-Plus = {PREDICTION},
Author-Email = {srinivasarao@iitb.ac.in},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001445491100006},
}

@article{ WOS:001447162300001,
Author = {Luo, Jiaqi and Yuan, Yuan and Xu, Shixin},
Title = {Improving GBDT performance on imbalanced datasets: An empirical study of
   class-balanced loss functions},
Journal = {NEUROCOMPUTING},
Year = {2025},
Volume = {634},
Month = {JUN 14},
Abstract = {Class imbalance poses a persistent challenge in machine learning,
   particularly for tabular data classification tasks. While Gradient
   Boosting Decision Trees (GBDT) models are widely regarded as
   state-of-the-art for these tasks, their effectiveness diminishes in the
   presence of imbalanced datasets. This paper is the first to
   comprehensively explore the integration of class-balanced loss functions
   into three popular GBDT algorithms, addressing binary, multi-class, and
   multi-label classification. We present a novel benchmark, derived from
   extensive experiments across diverse datasets, to evaluate the
   performance gains from class-balanced losses in GBDT models. Our
   findings establish the efficacy of these loss functions in enhancing
   model performance under class imbalance, providing actionable insights
   for practitioners tackling real-world imbalanced data challenges. To
   bridge the gap between research and practice, we introduce an
   open-source Python package that simplifies the application of
   class-balanced loss functions within GBDT workflows, democratizing
   access to these advanced methodologies. The code is available at
   https://github.com/Luojiaqimath/ClassbalancedLoss4GBDT.},
Type = {Article},
Affiliation = {Xu, SX (Corresponding Author), Duke Kunshan Univ, Data Sci Res Ctr, 8 Duke Ave, Kunshan 215000, Jiangsu, Peoples R China.
   Luo, Jiaqi, Soochow Univ, Sch Math Sci, 1 Shizi St, Suzhou 215006, Jiangsu, Peoples R China.
   Yuan, Yuan; Xu, Shixin, Duke Kunshan Univ, Data Sci Res Ctr, 8 Duke Ave, Kunshan 215000, Jiangsu, Peoples R China.},
DOI = {10.1016/j.neucom.2025.129896},
EarlyAccessDate = {MAR 2025},
Article-Number = {129896},
