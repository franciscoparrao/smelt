   Hesamirostami, Mohammadhossein; Ghorbani, Mojtaba, Mazandaran Univ Med Sci, Plast \& Reconstruct Surg, Daneshgah Blvd, Sari 4815733971, Mazandaran, Iran.},
DOI = {10.1186/s12911-025-03311-1},
