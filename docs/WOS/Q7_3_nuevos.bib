DOI = {10.1016/j.asoc.2025.114001},
EarlyAccessDate = {OCT 2025},
Article-Number = {114001},
Keywords = {Multi-Criteria Decision-Making; Ant Colony Optimization; Ensemble of
   pheromones; Complex Combinatorial Optimization; Multi-label text feature
   selection},
Keywords-Plus = {UPDATE STRATEGY; ALGORITHMS; ASSIGNMENT},
