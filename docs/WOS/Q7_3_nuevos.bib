}

@incollection{ WOS:000950545700017,
Author = {Agarwal, Nancy and Wani, Mudasir Ahmad and ELAffendi, Mohammed},
Editor = {El-Latif, AAA and Maleh, Y and Mazurczyk, W and ELAffendi, M and Alkanhal, MI},
Title = {Hybrid Feature-Based Multi-label Text Classification-A Framework},
Booktitle = {ADVANCES IN CYBERSECURITY, CYBERCRIMES, AND SMART EMERGING TECHNOLOGIES},
Series = {Engineering Cyber-Physical Systems and Critical Infrastructures},
Year = {2023},
Volume = {4},
Pages = {211-221},
Abstract = {Multi-label Text Classification (MLTC) as a problem is a scenario in
   which a text document can belong to one or more classes simultaneously.
   Such classification tasks pose several general as well as specific
   research challenges. The general challenges include dependency among
   classes, imbalanced data, and scalability in the presence of an
   excessive number of labels. On the other hand, the MLTC-specific
   challenges include high dimensional feature space, obtaining contextual
   and semantic knowledge from the text, and understanding content
   diversity. This paper provides a brief description of the multi-label
   classification approaches such as problem transformation, algorithm
   adaptation, and ensemble learning along with their strengths and
   weaknesses. Furthermore, we proposed an MLTC framework referred to as
   HMTCS (Hybrid feature-based Multi-label Text Classification System) that
   handles both general multi-labeling issues and text
   categorization-specific issues. The proposed framework has three
   modules, namely, Labels Knowledge Base, Hybrid Feature Extraction, and
   Ensemble Learning.},
Type = {Proceedings Paper},
Affiliation = {Agarwal, N (Corresponding Author), Norwegian Univ Sci \& Technol, N-2814 Gjovik, Norway.
   Agarwal, Nancy, Norwegian Univ Sci \& Technol, N-2814 Gjovik, Norway.
   Wani, Mudasir Ahmad; ELAffendi, Mohammed, Prince Sultan Univ PSU, Coll Comp \& Informat Sci CCIS, Riyadh 11586, Saudi Arabia.},
DOI = {10.1007/978-3-031-21101-0\_17},
Keywords = {Multi-label text classification; Natural language processing; Ensemble
   learning; Deep learning},
Keywords-Plus = {SYSTEM},
Author-Email = {nancya@ntnu.no
   mwani@psu.edu.sa
   afffendi@psu.edu.sa},
Number-of-Cited-References = {29},
