   Gajardo, Joaquin, Swiss Fed Inst Technol, Inst Agr Sci, Univ Str 2, CH-8092 Zurich, Switzerland.},
DOI = {10.1016/j.ophoto.2025.100091},
EarlyAccessDate = {AUG 2025},
Article-Number = {100091},
Keywords = {Deep learning; Agriculture; Satellite images; Time series; Land cover;
   Large-scale mapping; Sentinel},
Keywords-Plus = {TIME-SERIES; LAND-COVER; CLASSIFICATION; ATTENTION},
