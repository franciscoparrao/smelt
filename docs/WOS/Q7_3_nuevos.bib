DOI = {10.1080/00207543.2023.2275635},
EarlyAccessDate = {OCT 2023},
Keywords = {Environment, health and safety (EHS); maintenance safety;
   Lockout/Tagout; text mining; neural network; smart manufacturing},
Keywords-Plus = {INDUSTRY; CLASSIFICATION; INJURIES},
Author-Email = {lucas.hof@etsmtl.ca},
