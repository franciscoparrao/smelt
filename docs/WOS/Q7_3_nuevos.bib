@incollection{ WOS:001139644800038,
Author = {Durand, Julie and Stassopoulou, Athena and Katakis, Ioannis},
Book-Group-Author = {IEEE},
Title = {Adverse Drug Reaction Classification in Social Media: A Multi-label
   Approach},
Booktitle = {2023 IEEE INTERNATIONAL CONFERENCE ON WEB INTELLIGENCE AND INTELLIGENT
   AGENT TECHNOLOGY, WI-IAT},
Year = {2023},
Pages = {280-286},
Abstract = {Many patients readily share experiences about their medical conditions
   and treatments on online social media, which makes these platforms a
   potentially valuable source of information on adverse drug reactions
   (ADRs). In this work, the detection of mentions of ADRs in Reddit posts
   is approached as a multi-label classification problem. A dataset of 537
   annotated posts was created by supplementing a publicly available
   dataset with freshly collected and annotated posts. The labels were
   mapped to the Medical Dictionary for Regulatory Activities (MedDRA) and
   their distribution within each MedDRA level guided the creation of 12
   data subsets. On each data subset, we applied 4 different multi-label
   learning methods - Binary Relevance (BR), Classifier Chains (CC), Label
   Powerset (LP) and random k-labelsets (RAkEL), each associated with 4
   different base classifiers: Decision Trees (DT), Naive Bayes (NB),
   Random Forest (RF) and Support Vector Machine (SVM). The best F-scores
   were with DT on the data subset based on the 20 most frequent labels at
   MedDRA Preferred Term (PT) level. The best hamming loss was with the
   data subset based on all labels at PT level. The type of multi-label
   learning method did not appear to influence performance significantly.
   Our results show a promising direction in the use of multi-label
   classification of ADRs from social media posts for pharmacovigilance
   purposes.},
Type = {Proceedings Paper},
Affiliation = {Durand, J (Corresponding Author), Univ Nicosia, Sch Sci \& Engn, Dept Comp Sci, CY-2417 Nicosia, Cyprus.
   Durand, J (Corresponding Author), European Med Agcy, Pharmacovigilance Off, Amsterdam, Netherlands.
   Durand, Julie; Stassopoulou, Athena; Katakis, Ioannis, Univ Nicosia, Sch Sci \& Engn, Dept Comp Sci, CY-2417 Nicosia, Cyprus.
   Durand, Julie, European Med Agcy, Pharmacovigilance Off, Amsterdam, Netherlands.},
DOI = {10.1109/WI-IAT59888.2023.00045},
Keywords = {multi-label classification; adverse drug reaction; social media},
Keywords-Plus = {PHARMACOVIGILANCE; MENTIONS; NETWORK},
Author-Email = {durand.j@live.unic.ac.cy
   stassopoulou.a@unic.ac.cy
   katakis.i@unic.ac.cy},
Number-of-Cited-References = {24},
