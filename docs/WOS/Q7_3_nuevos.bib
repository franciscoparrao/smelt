DOI = {10.1016/j.ins.2023.119769},
EarlyAccessDate = {OCT 2023},
Article-Number = {119769},
Keywords = {Multi-target regression; Regressor chains; Tree-based data-driven
   modeling; Ensemble and adaptive strategies; Muti-target engineering
   design},
Keywords-Plus = {MULTIOBJECTIVE OPTIMIZATION; MODEL},
