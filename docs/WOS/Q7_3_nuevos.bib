   Han, Ye, Jilin Agr Univ, Sch Informat Technol, Changchun, Peoples R China.},
DOI = {10.1186/s12859-021-04445-5},
Article-Number = {519},
Keywords = {Protein ubiquitylation site; Protein SUMOylation site; Convolution
   neural network; Deep learning; Ensemble learning},
Keywords-Plus = {UBIQUITIN},
Author-Email = {zhaoxw303@nenu.edu.cn
   yeh@jlau.edu.cn},
