}

@incollection{ WOS:001616250100085,
Author = {Tiwari, Rajneesh and Rastogi, Pranshu},
Editor = {Kochmar, E and Alhafni, B and Bexte, M and Burstein, J and Horbach, A and Laarmann-Quante, R and Tack, A and Yaneva, V and Yuan, Z},
Title = {Phaedrus at BEA 2025 Shared Task: Assessment of Mathematical Tutoring
   Dialogues through Tutor Identity Classification and Actionability
   Evaluation},
Booktitle = {PROCEEDINGS OF THE 20TH WORKSHOP ON INNOVATIVE USE OF NLP FOR BUILDING
   EDUCATIONAL APPLICATIONS, BEA 2025},
Year = {2025},
Pages = {1098-1107},
Abstract = {As Large Language Models (LLMs) are increasingly deployed in educational
   environments, two critical challenges emerge: identifying the source of
   tutoring responses and evaluating their pedagogical effectiveness. This
   paper presents Phaedrus' comprehensive approach to the BEA 2025 Shared
   Task, addressing both tutor identity classification (Track 5) and
   actionability assessment (Track 4) in mathematical tutoring dialogues.
   For tutor identity classification, we distinguish between human tutors
   (expert/novice) and seven distinct LLMs using cross-response context
   augmentation and ensemble techniques. For actionability assessment, we
   evaluate whether responses provide clear guidance on student next steps
   using selective attention masking and instruction-guided training. Our
   multi-task approach combines transformer-based models with innovative
   contextual feature engineering, achieving state-of-the-art performance
   with a CV macro F1 score of 0.9596 (test set 0.9698) for identity
   classification and 0.655 (test set Strict F1 0.6906) for actionability
   assessment. We were able to score rank 5(th) in Track 4 and rank 1(st)
   in Track 5. Our analysis reveals that despite advances in human-like
   responses, LLMs maintain detectable fingerprints while showing varying
   levels of pedagogical actionability, with important implications for
   educational technology development and deployment. Our code and
   implementation details are publicly available at
   https://github.com/Rajneesh-Tiwari/BEA\_2025\_shared\_task.},
Type = {Proceedings Paper},
Author-Email = {rajneesh.vish1@gmail.com
   rastogipranshu29@gmail.com},
Number-of-Cited-References = {16},
Times-Cited = {0},
Unique-ID = {WOS:001616250100085},
}

@incollection{ WOS:001625870200018,
Author = {Aono, Masaki and Asakawa, Tetsuya and Inoue, Koki and Shimizu, Kazuki
   and Hashimoto, Masashi and Miyaji, Tateshi and Nomura, Kei},
Editor = {Osten, W and Jiang, X and Qian, K},
Title = {Stenosis Segment Estimation in Coronary Arteries Using Ensemble Learning
   of 3D CNN Models},
Booktitle = {EIGHTH INTERNATIONAL CONFERENCE ON MACHINE VISION AND APPLICATIONS,
   ICMVA 2025},
Series = {Proceedings of SPIE},
Year = {2025},
Volume = {13734},
Abstract = {In recent years, coronary artery disease diagnosis relies on
   contrast-enhanced CT and coronary angiography; however, these methods
   pose risks such as contrast agent side effects and physical burden due
   to catheter insertion. In contrast, non-contrast CT images do not
   clearly capture coronary arteries, making stenosis diagnosis
   challenging. This research utilizes a 3D convolutional neural network
   (3D CNN) with six pre- and post-lesion non-contrast CT images as input
   to perform multi-label, multi-class classification for stenosis segment
   estimation. We focus on eight of the 15 coronary artery segments with
   the highest data availability. We conducted experiments using
   non-contrast CT images from Toyohashi Heart Center and compared 3D CNN
   models (I3D, R3D) with 2D CNN models (DenseNet-121, ResNet-152).
   Furthermore, we applied ensemble learning techniques (stacking and
   averaging) to 3D CNN models to enhance classification performance.
   Evaluation metrics included accuracy, precision, recall, and F1-score,
   as well as multi- label classification-specific indices (Jaccard index
   and Hamming distance). Experimental results showed that the proposed
   method (3D CNN + ensemble learning) achieved the highest accuracy,
   demonstrating that 3D CNN models outperform 2D CNN models in this task.
   The stacking-based ensemble model performed best across all evaluation
   metrics, suggesting that stenosis segment estimation is feasible using
   only non-contrast CT images. This study contributes to advancing
   non-invasive coronary artery disease diagnosis and reducing patient
   burden.},
Type = {Proceedings Paper},
Affiliation = {Aono, M (Corresponding Author), Toyohashi Univ Technol, Toyohashi, Aichi, Japan.
   Aono, Masaki; Asakawa, Tetsuya; Inoue, Koki, Toyohashi Univ Technol, Toyohashi, Aichi, Japan.
   Shimizu, Kazuki; Hashimoto, Masashi; Miyaji, Tateshi; Nomura, Kei, Toyohashi Heart Ctr, Toyohashi, Aichi, Japan.},
DOI = {10.1117/12.3081528},
Article-Number = {137340J},
Keywords = {coronary artery disease; non-contrast Computed Tomography; 3D CNN;
   ensemble; multi-label multi-class classification},
Author-Email = {masaki.aono.ss@tut.jp},
Number-of-Cited-References = {20},
Times-Cited = {0},
Unique-ID = {WOS:001625870200018},
}

@incollection{ WOS:001613942200008,
Author = {Yu, Renjie and Cai, Yunrui and Zhou, Yixuan and Ye, Runchuan and Wu,
   Zhiyong},
Book-Group-Author = {ACM},
Title = {A Dual-Branch Ensemble Framework for Personality Recognition Based on
   Multimodal Emotion Features},
Booktitle = {PROCEEDINGS OF THE 3RD INTERNATIONAL WORKSHOP ON MULTIMODAL AND
   RESPONSIBLE AFFECTIVE COMPUTING, MRAC 2025},
Year = {2025},
Pages = {51-57},
Abstract = {Personality and emotion both shape human behavior, but most personality
   recognition models handle them separately or use only one type of data.
   We present a multimodal, emotion-aware ensemble framework for the
   MER2025 MER-PR track, predicting the Big Five traits from subjects'
   visual, audio, and text reactions. Our method combines two parts: a
   multi-target regression model for accurate trait scores and a
   coarse-to-fine classification model to capture links between traits.
   Their outputs are merged with ensemble learning to improve accuracy and
   stability. In the MDPE data set, our model achieves a root mean square
   error (RMSE) of 0.1359, outperforming the official baseline by
   approximately 14\%. These results show that combining emotion cues with
   multimodal ensemble methods can improve personality prediction.},
Type = {Proceedings Paper},
Affiliation = {Wu, ZY (Corresponding Author), Tsinghua Univ, Shenzhen Int Grad Sch, Shenzhen, Peoples R China.
