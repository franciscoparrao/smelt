DOI = {10.1016/j.neucom.2020.01.102},
Keywords = {Classification; Classifier; Experimental comparison; Multi-label;
   Multilabel},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {edward\_yapp@simtech.a-star.edu.sg
   xli@simtech.a-star.edu.sg
   mpelwf@nus.edu.sg
