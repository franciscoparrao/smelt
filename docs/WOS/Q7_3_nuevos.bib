   Goesmann, Alexander; Schwengers, Oliver, Justus Liebig Univ Giessen, Dept Bioinformat \& Syst Biol, Giessen, Germany.},
DOI = {10.1016/j.csbj.2022.03.007},
EarlyAccessDate = {MAR 2022},
Keywords = {Multi-drug resistance; Machine learning; Multi-label classification},
Keywords-Plus = {CROSS-RESISTANCE; ANTIMICROBIAL RESISTANCE; ANTIBIOTICS; INFORMATION;
