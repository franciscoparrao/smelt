   Wei, Lisi, Shandong First Med Univ \& Shandong Acad Med Sci, Clin Coll 1, 16766 Jingshi Rd, Jinan 250014, Peoples R China.},
DOI = {10.1186/s40001-025-03204-z},
Article-Number = {910},
Keywords = {Hippocampal radiomics; Alzheimer's disease classification; Deep
   learning; Transformer segmentation; Nomogram prediction},
Keywords-Plus = {RADIOMICS; VALIDATION; DIAGNOSIS},
Author-Email = {zg\_sdfmu2025@163.com},
Number-of-Cited-References = {60},
