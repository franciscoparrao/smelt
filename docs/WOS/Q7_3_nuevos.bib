   Kheyrikoochaksarayee, Naghme; Shabani, Amir, Simon Fraser Univ, Sch Sustainable Energy Engn, Burnaby, BC, Canada.},
DOI = {10.1016/j.enconman.2023.117376},
EarlyAccessDate = {JUL 2023},
Article-Number = {117376},
Keywords = {Machine learning; Big data; Membrane-based absorbers; Sorption heat
   transformers; Support vector regression; Random forest regression},
Keywords-Plus = {GLOBAL SOLAR-RADIATION; MASS-TRANSFER; ABSORPTION; PERFORMANCE;
   PREDICTION; DESIGN; OPTIMIZATION; PUMP; FILM},
