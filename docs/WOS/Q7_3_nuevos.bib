@article{ WOS:001710234800024,
Author = {Yi, Hao and Wen-pu, Xu and Lu-yuan, Cui and Yu-hang, Zhang and Wen,
   Xiong and Qing-lin, Zhu},
Title = {Application of Deep Convolutional Neural Networks for Soil Parameter
   Prediction Based on the Lucas Dataset},
Journal = {SPECTROSCOPY AND SPECTRAL ANALYSIS},
Year = {2025},
Volume = {45},
Number = {12},
Pages = {212-221},
Month = {DEC},
Abstract = {Accurate knowledge of soil properties is fundamental to the effective
   management and sustainable improvement of land resources. Compared with
   traditional laboratory testing and field sampling methods for obtaining
   soil information, which face high costs and low efficiency, predicting
   soil properties using visible and near-infrared spectroscopy has been
   widely applied in recent years. This study explores the potential of
   deep learning methods, which offer advantages in feature extraction, for
   analyzing large-scale spectral datasets. Using raw absorbance spectra
   from the Land Use/Cover Area Frame Survey (LUCAS) soil dataset, a deep
   convolutional neural network (DCNN) regression model was employed to
   predict seven soil properties. The inversion accuracy was compared with
   that of recurrent neural networks (LSTM) and three machine learning
   models: random forests, extreme gradient boosting (XGBoost), and light
   gradient boosting machine (LightGBM). Differences in modeling accuracy
   between single-task and multi-task DCNN models were also compared. SHAP
   values were used to interpret the outputs of both machine learning and
   deep learning models. The DCNN model demonstrated superior modeling
   accuracy compared to recurrent neural networks and traditional machine
   learning methods, The inversion accuracy for soil organic carbon, soil
   nitrogen, soil pH, and soil calcium carbonate was relatively high, with
   R values of 0.806 5, 0.767 9. 0.715 1, and 0.923 5. respectively,
   indicating strong correlations. The root mean square error were 17.1368
   gkg(-1).264 4 g.g(-1), 0.734 3, and 45.974 1 g g(-1), respectively,
   demonstrating good predictive performance. Compared to the multi-task
   regression model, the single-task DCNN model achieved higher accuracy.
   Different soil properties correspond to distinct characteristic
   wavelength bands, with multiple characteristic peaks commonly observed.
   The DGNN model proposed in this study effectively improves modeling
   accuracy and can serve as a reference for regression-based prediction of
   soil properties from large-scale spectral data. 1},
Type = {Article},
Affiliation = {Yi, H (Corresponding Author), China Res Inst Radiowave Propagat, Qingdao 266107, Peoples R China.
   Yi, Hao; Wen-pu, Xu; Yu-hang, Zhang; Wen, Xiong; Qing-lin, Zhu, China Res Inst Radiowave Propagat, Qingdao 266107, Peoples R China.
   Lu-yuan, Cui, Qingdao Inst Measurement Technol, Qingdao 266101, Peoples R China.},
DOI = {10.3964/j.issn.1000-0593(2025)ZI-0212-10},
Keywords = {Deep learning; Convolutional neural networks; Lucas soil dataset; Soil
   spectral properties; Characteristic bands},
Author-Email = {haoy@crirp.ac.cn},
Number-of-Cited-References = {19},
Times-Cited = {0},
Unique-ID = {WOS:001710234800024},
}

@article{ WOS:001640273000016,
Author = {Yuan, Dawei and Liang, Guojun and Liu, Bin and Liu, Suping},
Title = {Qwen TextCNN and BERT models for enhanced multilabel news classification
   in mobile apps},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {15},
Number = {1},
Month = {DEC},
Abstract = {Mobile news classification systems face significant challenges due to
   their large scale and complexity. In this paper, we perform a
   comprehensive comparative study between traditional classification
   models, such as TextCNN and BERT based models and Large Language Models
   (LLMs), for the purpose of multi-label news categorization in mobile
   apps about the Chinese mobile news application. We evaluated the
   performance of conventional techniques, including a BERT model, along
   with Qwen models that have been tuned with instruction and fine-tuned
   using the LoRA technique, to optimize their effectiveness while
   preserving classification accuracy. Our experimental results show that
   BERT models perform best for multi-label classification with balanced
   datasets, while textCNN performs better for binary classification tasks.
   Our results also reveal that the LSTM and MLP classifiers consistently
   achieve the highest accuracy with text instruction prompts, while random
   embeddings achieve competitive accuracy. Furthermore, despite the low
   macro F1 scores due to class imbalance, consistent relative performance
   confirms the validity of our analysis. Our research reveals crucial
   information about the classification of automotive news, highlighting
   the importance of weighing technical prowess against deployment
   constraints when choosing model architectures.},
Type = {Article},
Affiliation = {Yuan, DW (Corresponding Author), Guangdong Univ Sci \& Technol, Sch Comp Sci, Dongguan 523083, Peoples R China.
   Yuan, DW (Corresponding Author), Beijing Bitauto Informat Technol Co Ltd, Beijing 100102, Peoples R China.
   Yuan, Dawei; Liu, Suping, Guangdong Univ Sci \& Technol, Sch Comp Sci, Dongguan 523083, Peoples R China.
   Yuan, Dawei, Beijing Bitauto Informat Technol Co Ltd, Beijing 100102, Peoples R China.
   Liang, Guojun, Halmstad Univ, Sch Informat Technol, S-30118 Halmstad, Sweden.
   Liu, Bin, Jilin Univ, Sch Comp Sci \& Technol, Changchun 130012, Peoples R China.},
DOI = {10.1038/s41598-025-27497-6},
Article-Number = {43787},
Keywords = {Multilabel classification; Large language models; BERT; TextCNN; Qwen},
Keywords-Plus = {LABEL; CHALLENGES; ENSEMBLE},
