Keywords = {Dam health monitoring; Displacement prediction; Multi-point joint
   modeling; Spatial clustering partition; Selective regressor chain},
Keywords-Plus = {MODEL; NETWORK; FCM},
Author-Email = {qbren@tju.edu.cn},
