DOI = {10.32604/cmc.2020.010914},
Keywords = {Internet of Medical Things (IoMT); medical disputes; medical dispute
   document (MDD); multi-label classification (MLC); key sentence
   extraction; class imbalance},
Keywords-Plus = {INTERNET; PRIVACY},
Author-Email = {zhangbl@seu.edu.cn},
Number-of-Cited-References = {20},
Times-Cited = {5},
