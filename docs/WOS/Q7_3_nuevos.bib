   Juneja, Sapna, KIET Grp Inst, Delhi NCR, Ghaziabad 201206, India.
   Alwan, Ali A., Ramapo Coll, Sch Theoret \& Appl Sci, Mahwah, NJ 07430 USA.
   Nauman, Ali, Yeungnam Univ, Dept Informat \& Commun Engn, Gyongsan 38541, South Korea.},
DOI = {10.3390/su15021695},
Article-Number = {1695},
