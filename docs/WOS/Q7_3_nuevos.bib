   Safari, Mir Jafar Sadegh, Yasar Univ, Dept Civil Engn, Izmir, Turkiye.
   Safari, Mir Jafar Sadegh, Yasar Univ, Dept Civil Engn, TR-35100 Izmir, Turkiye.},
DOI = {10.1089/big.2022.0125},
EarlyAccessDate = {MAR 2023},
Keywords = {cutoff wall; dummy variable; fast multi-output relevance vector
   regression; porous medium; tracer},
Keywords-Plus = {HYDRAULIC CONDUCTIVITY; RANDOM FOREST; FLOW; MACHINE},
Author-Email = {jafar.safari@yasar.edu.tr},
