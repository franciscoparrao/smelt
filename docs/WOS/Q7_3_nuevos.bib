   Wang, Man; Zhang, Bo, China Pingmei Shenma Holding Grp Co Ltd, Pingdingshan 467000, Henan, Peoples R China.},
DOI = {10.1007/s10661-024-13040-z},
Article-Number = {876},
Keywords = {Mine water source; Pingdingshan coalfield; CatBoost; SHAP; Bayesian
   optimization algorithm},
