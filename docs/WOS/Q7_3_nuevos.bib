   Schietgat, Leander, Vrije Univ Brussel, Artificial Intelligence Lab, Brussels, Belgium.
   Triguero, Isaac, Univ Nottingham, Sch Comp Sci, Computat Optimisat \& Learning COL Lab, Nottingham, England.
   Vens, Celine, KU Leuven Kulak, Dept Publ Hlth \& Primary Care, Kortrijk, Belgium.},
DOI = {10.1016/j.ins.2021.08.022},
EarlyAccessDate = {AUG 2021},
Keywords = {Multi-target regression; Multi-label classification; Predictive
   clustering trees; Random forests; Genetic algorithms},
Keywords-Plus = {MULTI-LABEL CLASSIFICATION; STATISTICAL COMPARISONS; CLASSIFIERS;
   PREDICTION; REGRESSION; ENSEMBLES},
Author-Email = {basgalupp@unifesp.br
