   Qin, Jiamin, Sichuan Mianyang 404 Hosp, Mianyang 621010, Sichuan, Peoples R China.},
DOI = {10.1002/ima.23164},
Article-Number = {e23164},
Keywords = {class imbalance; convolutional neural network; dermoscopy image; dynamic
   network; skin lesion classification},
Keywords-Plus = {NONMELANOMA; CANCER; MODEL},
Author-Email = {zhouyingyue@swust.edu.cn},
Number-of-Cited-References = {50},
