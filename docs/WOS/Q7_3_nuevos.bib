   Nakano, Felipe Kenji; Vens, Celine, Katholieke Univ Leuven, Itec, imec Res Grp, Etienne Sabbelaan 53, B-8500 Kortrijk, Belgium.},
DOI = {10.1016/j.compbiomed.2022.106423},
