@incollection{ WOS:001594456200010,
Author = {Tsai, Tsuang Han and Hsu, Sung Ting and Huang, Yu Cheng and Hsueh, Shan
   Ting and Yao, Yuan Chen},
Book-Group-Author = {IEEE},
Title = {Fine-tuning DistilBERT for Toxic Comment Detection and Classification},
Booktitle = {2025 IEEE GAMING, ENTERTAINMENT, AND MEDIA CONFERENCE, GEM},
Series = {IEEE Games Media Entertainment},
Year = {2025},
Pages = {53-56},
Abstract = {The threat of online abuse and harassment is increasingly prevalent in
   online communities. To address this issue, many platforms have
   implemented relevant policies. However, these policies require the prior
   identification of inappropriate and offensive content. Furthermore, the
   data may contain various negative sentiments. For example, a single
   comment could simultaneously express toxic, insults, and threats. This
   indicates that the negativity or toxicity expressed in comments can have
   multiple facets. Therefore, the challenge lies in identifying the
   specific toxic elements within a comment to formulate and enforce
   appropriate policies to penalize offenders. This study adopts two
   approaches to identify potential toxic factors in comments. The first
   approach trains separate classifiers to detect whether toxic terms are
   present in a comment. The second approach treats the task as a
   multi-label classification problem. The study employs the DistilBERT
   structure as the backbone of the deep learning model and leverages
   training techniques such as Data Augmentation, Focal Loss, and Ensemble
   Learning to address the class imbalance in the training data. The
   dataset for this research is sourced from Kaggle's Jigsaw Toxic Comment
   Classification Challenge.},
Type = {Proceedings Paper},
Affiliation = {Tsai, TH (Corresponding Author), Natl Cent Univ, Dept Elect Engn, Taoyuan, Taiwan.
   Tsai, Tsuang Han; Hsu, Sung Ting; Huang, Yu Cheng; Hsueh, Shan Ting; Yao, Yuan Chen, Natl Cent Univ, Dept Elect Engn, Taoyuan, Taiwan.},
DOI = {10.1109/GEM66882.2025.11155272},
Keywords = {DistilBERT; toxic comments; data augment; focal loss; ensemble learning},
Author-Email = {han@dsp.ee.ncu.edu.tw
