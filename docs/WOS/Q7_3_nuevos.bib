DOI = {10.1016/j.afres.2025.101396},
EarlyAccessDate = {OCT 2025},
Article-Number = {101396},
Keywords = {Antimicrobial activity; Biopreservation; Plantaricin; Random forest
   classification},
Keywords-Plus = {2-PEPTIDE BACTERIOCIN; PURIFICATION; LOCUS},
