@incollection{ WOS:001666499200035,
Author = {Dewangan, Kunal and Srinivasu, G.},
Book-Group-Author = {ASME},
Title = {EFFECTIVENESS OF SAMPLING METHODS FOR DATA IMBALANCE IN PREDICTING
   MULTIOUTPUT RESPONSES OF EXTRUDED POLYMERS IN ADDITIVE MANUFACTURING},
Booktitle = {PROCEEDINGS OF ASME 2025 INTERNATIONAL MECHANICAL ENGINEERING CONGRESS
   AND EXPOSITION - INDIA, IMECE-INDIA2025, VOL 1},
Year = {2025},
Abstract = {This study advances material extrusion additive manufacturing for
   aerospace and biomedical applications by optimizing polymer mechanical
   properties through machine learning. Data imbalance in material datasets
   often compromises predictive accuracy for underrepresented polymers. A
   dataset of 171 samples, including polylactic acid, acrylonitrile
   butadiene styrene, polyether ether ketone, polyethylene terephthalate
   glycol, and nylon, was analyzed using parameters such as layer
   thickness, infill density, and print speed. To mitigate imbalance,
   random oversampling, synthetic minority oversampling, and a hybrid
   oversamplingdata cleaning method were applied. Multi-output regression
   models decision tree regression, linear regression, and support vector
   regression were developed to predict tensile strength and elongation at
   break. The decision tree regression model, combined with the synthetic
   minority oversampling technique, achieved superior performance, with
   high coefficients of determination (0.989 for training, 0.940 for
   testing, 0.998 for validation) and low mean absolute errors for tensile
   strength. For elongation, the model yielded coefficients of
   determination of 0.882 (training), 0.893 (testing), and 0.987
   (validation). These results demonstrate the potential of machine
   learning and data balancing to enhance the predictability of polymer
   properties, enabling optimized process parameters for reliable additive
   manufacturing outcomes.},
Type = {Proceedings Paper},
Affiliation = {Dewangan, K (Corresponding Author), Natl Inst Technol, Raipur, Chhattisgarh, India.
   Dewangan, Kunal; Srinivasu, G., Natl Inst Technol, Raipur, Chhattisgarh, India.},
Keywords = {Material extrusion additive manufacturing; Decision tree regression;
   Sampling techniques; Data imbalance.},
Keywords-Plus = {MECHANICAL-PROPERTIES; PRINTING PARAMETERS},
Number-of-Cited-References = {27},
Times-Cited = {0},
Unique-ID = {WOS:001666499200035},
}

@incollection{ WOS:001671135600745,
Author = {Li, Jia and Wang, Yang and Qian, Wenhao and Hu, Jialong and Hu, Zhenzhen
   and Hong, Richang and Wang, Meng},
Book-Group-Author = {ACM},
Title = {Listening to the Unspoken: Exploring ``365{''} Aspects of Multimodal
   Interview Performance Assessment},
Booktitle = {PROCEEDINGS OF THE 33RD ACM INTERNATIONAL CONFERENCE ON MULTIMEDIA (MM
   2025)},
Year = {2025},
Pages = {13909-13916},
Abstract = {Interview performance assessment is essential for determining
   candidates' suitability for professional positions. To ensure holistic
   and fair evaluations, we propose a novel and comprehensive framework
   that explores ``365{''} aspects of interview performance by integrating
   three modalities (video, audio, and text), six responses per candidate,
   and five key evaluation dimensions. The framework employs
   modality-specific feature extractors to encode heterogeneous data
   streams and subsequently fused via a Shared Compression Multi-layer
   Perceptron. This module compresses multimodal embeddings into a unified
   latent space, facilitating efficient feature interaction. To enhance
   prediction robustness, we incorporate a two-level ensemble learning
   strategy: (1) independent regression heads predict scores for each
   response, and (2) predictions are aggregated across responses using a
   mean-pooling mechanism to produce final scores for the five target
   dimensions. By listening to the unspoken, our approach captures both
   explicit and implicit cues from multimodal data, enabling comprehensive
   and unbiased assessments. Achieving a multi-dimensional average MSE of
   0.1824, our framework secured first place in the AVI Challenge 2025,
   demonstrating its effectiveness and robustness in advancing automated
   and multimodal interview performance assessment. The full implementation
   is available at https://github.com/Qianvenh/AVI2025-Track2.},
