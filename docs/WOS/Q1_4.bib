@article{ WOS:000964156800002,
Author = {Liu, Junjian and Feng, Huicong and Tang, Yifan and Zhang, Lupeng and Qu,
   Chiwen and Zeng, Xiaomin and Peng, Xiaoning},
Title = {A novel hybrid algorithm based on Harris Hawks for tumor feature gene
   selection},
Journal = {PEERJ COMPUTER SCIENCE},
Year = {2023},
Volume = {9},
Month = {FEB 13},
Abstract = {Background. Gene expression data are often used to classify cancer
   genes. In such high-dimensional datasets, however, only a few feature
   genes are closely related to tumors. Therefore, it is important to
   accurately select a subset of feature genes with high contributions to
   cancer classification. Methods. In this article, a new three-stage
   hybrid gene selection method is proposed that combines a variance
   filter, extremely randomized tree and Harris Hawks (VEH). In the first
   stage, we evaluated each gene in the dataset through the variance filter
   and selected the feature genes that meet the variance threshold. In the
   second stage, we use extremely randomized tree to further eliminate
   irrelevant genes. Finally, we used the Harris Hawks algorithm to select
   the gene subset from the previous two stages to obtain the optimal
   feature gene subset. Results. We evaluated the proposed method using
   three different classifiers on eight published microarray gene
   expression datasets. The results showed a 100\% classification accuracy
   for VEH in gastric cancer, acute lymphoblastic leukemia and ovarian
   cancer, and an average classification accuracy of 95.33\% across a
   variety of other cancers. Compared with other advanced feature selection
   algorithms, VEH has obvious advantages when measured by many evaluation
   criteria.},
Type = {Article},
Affiliation = {Liu, JJ (Corresponding Author), Hunan Normal Univ, Coll Math \& Stat, Dept Stat, Changsha, Hunan, Peoples R China.
   Feng, HC (Corresponding Author), Hunan Normal Univ, Sch Med, Dept Pathol \& Pathophysiol, Changsha, Hunan, Peoples R China.
