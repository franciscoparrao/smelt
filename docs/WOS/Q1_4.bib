Keywords = {Machine learning; Prediction modelling; Air pollution prediction;
   Multiple linear regression; Random forest; XGboost; Air quality},
Keywords-Plus = {ENSEMBLE; CHINA},
Author-Email = {abdul.samad@ifk.uni-stuttgart.de},
