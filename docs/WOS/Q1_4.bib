Keywords-Plus = {SATELLITE-OBSERVATIONS; CONVECTIVE INITIATION; BIOMASS ESTIMATION; DEEP
   CONVECTION; VALIDATION; EVOLUTION; MOISTURE; FUSION; OCEAN; AREA},
