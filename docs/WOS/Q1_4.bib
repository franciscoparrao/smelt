@article{ WOS:000519564600098,
Author = {Shang, Ke and Yao, Yunjun and Li, Yufu and Yang, Junming and Jia, Kun
   and Zhang, Xiaotong and Chen, Xiaowei and Bei, Xiangyi and Guo,
   Xiaozheng},
Title = {Fusion of Five Satellite-Derived Products Using Extremely Randomized
   Trees to Estimate Terrestrial Latent Heat Flux over Europe},
Journal = {REMOTE SENSING},
Year = {2020},
Volume = {12},
Number = {4},
Month = {FEB},
Abstract = {An accurate estimation of spatially and temporally continuous latent
   heat flux (LE) is essential in the assessment of surface water and
   energy balance. Various satellite-derived LE products have been
   generated to enhance the simulation of terrestrial LE, yet each
   individual LE product shows large discrepancies and uncertainties. Our
   study used Extremely Randomized Trees (ETR) to fuse five
   satellite-derived terrestrial LE products to reduce uncertainties from
   the individual products and improve terrestrial LE estimations over
   Europe. The validation results demonstrated that the estimation using
   the ETR fusion method increased the R-2 of five individual LE products
   (ranging from 0.53 to 0.61) to 0.97 and decreased the RMSE (ranging from
   26.37 to 33.17 W/m(2)) to 5.85 W/m(2). Compared with three other machine
   learning fusion models, Gradient Boosting Regression Tree (GBRT), Random
   Forest (RF), and Gaussian Process Regression (GPR), ETR exhibited the
   best performance in terms of both training and validation accuracy. We
   also applied the ETR fusion method to implement the mapping of average
   annual terrestrial LE over Europe at a resolution of 0.05 ? in the
   period from 2002 to 2005. When compared with global LE products such as
   the Global Land Surface Satellite (GLASS) and the Moderate Resolution
   Imaging Spectroradiometer (MODIS), the fusion LE using ETR exhibited a
   relatively small gap, which confirmed that it is reasonable and reliable
   for the estimation of the terrestrial LE over Europe.},
Type = {Article},
Affiliation = {Yao, YJ (Corresponding Author), Beijing Normal Univ, Fac Geog Sci, State Key Lab Remote Sensing Sci, Beijing 100875, Peoples R China.
   Shang, Ke; Yao, Yunjun; Yang, Junming; Jia, Kun; Zhang, Xiaotong; Chen, Xiaowei; Bei, Xiangyi; Guo, Xiaozheng, Beijing Normal Univ, Fac Geog Sci, State Key Lab Remote Sensing Sci, Beijing 100875, Peoples R China.
   Li, Yufu, Jincheng Meteorol Adm, Jincheng 048026, Peoples R China.},
DOI = {10.3390/rs12040687},
Article-Number = {687},
Keywords = {terrestrial latent heat flux; machine learning method; Europe},
Keywords-Plus = {EDDY COVARIANCE MEASUREMENTS; LAND-SURFACE EVAPORATION;
   EVAPOTRANSPIRATION ESTIMATION; 2-SOURCE MODEL; ENERGY FLUXES;
