DOI = {10.3390/electronics11030486},
Article-Number = {486},
Keywords = {botnet detection; Histogram of Oriented Gradients; image processing;
   android botnets; machine learning},
Keywords-Plus = {MALWARE CLASSIFICATION; ENSEMBLE; TREES},
Author-Email = {syerima@dmu.ac.uk
   abashar@pmu.edu.sa},
