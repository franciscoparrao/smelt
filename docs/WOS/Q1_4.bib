@incollection{ WOS:000230923100005,
Author = {Marée, R and Geurts, P and Piater, J and Wehenkel, L},
Editor = {Schmid, C and Soatto, S and Tomasi, C},
Title = {Random subwindows for robust image classification},
Booktitle = {2005 IEEE COMPUTER SOCIETY CONFERENCE ON COMPUTER VISION AND PATTERN
   RECOGNITION, VOL 1, PROCEEDINGS},
Series = {IEEE Conference on Computer Vision and Pattern Recognition},
Year = {2005},
Pages = {34-40},
Abstract = {We present a novel, generic image classification method based on a
   recent machine learning algorithm (ensembles of extremely randomized
   decision trees). Images are classified using randomly extracted
   subwindows that are suitably normalized to yield robustness to certain
   image transformations. Our method is evaluated on four very different,
   publicly available datasets (COIL-100, ZuBuD, ETH80, WANG). Our results
   show that our automatic approach is generic and robust to illumination,
   scale, and viewpoint changes. An extension of the method is proposed to
   improve its robustness with respect to rotation changes.},
Type = {Proceedings Paper},
Affiliation = {Marée, R (Corresponding Author), Univ Liege, Inst Montefiore, Dept Elect Engn \& Comp Sci, B-4000 Liege, Belgium.
