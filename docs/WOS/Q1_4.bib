   Wimmer, Wilhelm, Tech Univ Munich, Dept Otorhinolaryngol, Klinikum Rrechts Isar, D-80333 Munich, Germany.},
DOI = {10.1109/TBME.2024.3509527},
Keywords = {Electrodes; Computed tomography; Impedance; Telemetry; Location
   awareness; Surgery; Recording; Biomedical measurement; Soft sensors;
   Predictive models; Anatomy-based fitting; cochlear coverage; cochlear
   implants; follow-up; machine learning; objective measures;
   radiation-free},
Keywords-Plus = {ARRAY INSERTION; REGRESSION; SELECTION},
Author-Email = {wilhelm.wimmer@tum.de},
Number-of-Cited-References = {65},
Times-Cited = {8},
