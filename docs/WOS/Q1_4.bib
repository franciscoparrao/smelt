   Madavan, R., PSR Engn Coll, Elect \& Elect Engn Dept, Sivakasi 626140, Tamilnadu, India.},
DOI = {10.1109/TDEI.2023.3271609},
Keywords = {Power transformer insulation; Oil insulation; Machine learning; Support
   vector machines; Random forests; Feature extraction; Classification tree
   analysis; Dissolved gas analysis (DGA); fault classification; machine
   learning (ML); multi-criteria decision-making (MCDM)},
Keywords-Plus = {FAULT-DIAGNOSIS; MACHINE},
Author-Email = {saroja@nitt.edu
