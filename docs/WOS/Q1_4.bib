   Moussa, Isseini; Daira, Djoret, Resources Consulting Serv SARL, Ndjamena, Chad.},
DOI = {10.1080/10106049.2021.2007298},
EarlyAccessDate = {NOV 2021},
Keywords = {Remote sensing; groundwater exploration; machine learning; Lake Chad
   basin},
Keywords-Plus = {MODELS; GIS; MACHINE},
