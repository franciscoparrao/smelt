   Tohma, Yoshiki, Hyogo Prefectural Kakogawa Med Ctr, Dept Emergency \& Crit Care Med, Kakogawa, Hyogo, Japan.},
DOI = {10.1089/neu.2018.6276},
EarlyAccessDate = {SEP 2019},
Keywords = {artificial intelligence; machine learning; outcome predictor; traumatic
   brain injury},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; SEVERE HEAD-INJURY; PROGNOSIS;
   CLASSIFICATION; VALIDATION; SURGERY; MODELS},
