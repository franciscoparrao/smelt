   Laga, Hamid, Murdoch Univ, Harry Butler Inst, Ctr Biosecur \& One Hlth, Murdoch, WA 6150, Australia.
   Jones, Michael G. K., Murdoch Univ, Sch Agr Sci, Murdoch, WA 6150, Australia.},
DOI = {10.1016/j.eja.2024.127359},
EarlyAccessDate = {SEP 2024},
Article-Number = {127359},
Keywords = {Deep learning; Transfer learning; Plant disease detection; Image
   classification; Field Trials; Barley disease management; Computer vision},
Author-Email = {F.Sohel@murdoch.edu.au},
Number-of-Cited-References = {54},
