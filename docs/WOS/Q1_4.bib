   Fang, Gang, Guangdong Prov Tradit Chinese Med Hosp, Dept Neurol, Guangzhou 510120, Peoples R China.},
DOI = {10.1109/ACCESS.2020.3004977},
Keywords = {Machine learning; ischemic stroke subtype; feature selection; IST},
Keywords-Plus = {CLASSIFICATION; NORMALITY; BURDEN},
Author-Email = {gangf@gzhu.edu.cn},
Number-of-Cited-References = {27},
Times-Cited = {21},
Unique-ID = {WOS:000549121800001},
}

@article{ WOS:000470824900013,
Author = {Singh, Tanvi and Pal, Mahesh and Arora, V. K.},
Title = {Modeling oblique load carrying capacity of batter pile groups using
   neural network, random forest regression and M5 model tree},
Journal = {FRONTIERS OF STRUCTURAL AND CIVIL ENGINEERING},
Year = {2019},
Volume = {13},
Number = {3},
Pages = {674-685},
Month = {JUN},
Abstract = {M5 model tree, random forest regression (RF) and neural network (NN)
   based modelling approaches were used to predict oblique load carrying
   capacity of batter pile groups using 247 laboratory experiments with
   smooth and rough pile groups. Pile length (L), angle of oblique load (),
   sand density (), number of batter piles (B), and number of vertical
   piles (V) as input and oblique load (Q) as output was used. Results
   suggest improved performance by RF regression for both pile groups. M5
   model tree provides simple linear relation which can be used for the
   prediction of oblique load for field data also. Model developed using RF
   regression approach with smooth pile group data was found to be in good
   agreement for rough piles data. NN based approach was found performing
   equally well with both smooth and rough piles. Sensitivity analysis
   using all three modelling approaches suggest angle of oblique load ()
   and number of batter pile (B) affect the oblique load capacity for both
   smooth and rough pile groups.},
Type = {Article},
Affiliation = {Singh, T (Corresponding Author), Natl Inst Technol, Dept Civil Engn, Kurukshetra 136119, Haryana, India.
   Singh, Tanvi; Pal, Mahesh; Arora, V. K., Natl Inst Technol, Dept Civil Engn, Kurukshetra 136119, Haryana, India.},
DOI = {10.1007/s11709-018-0505-3},
Keywords = {batter piles; oblique load test; neural network; M5 model tree; random
