   Yu, Xianyu, Hubei Univ Technol, Sch Civil Engn Architecture \& Environm, Wuhan 430068, Hubei, Peoples R China.
   Wang, Run, Geol Environm Ctr Hubei Prov, Wuhan 430034, Peoples R China.},
DOI = {10.1007/s12665-024-11521-5},
Article-Number = {227},
Keywords = {Slope-unit-based; Landslide susceptibility; Three Gorges Reservoir;
