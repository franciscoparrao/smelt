   Gul, Sarah, Int Islamic Univ, Dept Biol Sci, FBAS, Islamabad, Pakistan.},
DOI = {10.1016/j.chemolab.2022.104682},
EarlyAccessDate = {OCT 2022},
Article-Number = {104682},
Keywords = {Antiviral peptides; PSSM-DWT; PSSM-Segmentation; SHAP analysis; Ensemble
   classification},
Keywords-Plus = {IMMUNODEFICIENCY-VIRUS TYPE-1; REVERSE-TRANSCRIPTASE; GENETIC ALGORITHM;
   CORROSION TYPE; CHOUS PSEAAC; CLASSIFIER; PROTEIN; INHIBITION; MODEL},
Author-Email = {m.hayat@awkum.edu.pk},
