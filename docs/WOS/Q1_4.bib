   Wang, Charles C. N., Asia Univ, Dept Bioinformat \& Med Engn, 500,Lioufeng Rd, Taichung 413305, Taiwan.},
DOI = {10.1186/s12873-024-01152-1},
Article-Number = {237},
Keywords = {Natural Language Processing; Triage; Emergency Department; Disposition
   Prediction; Machine Learning},
Keywords-Plus = {IN-HOSPITAL MORTALITY; TAIWAN TRIAGE; ACUITY SCALE; ADMISSION; SEVERITY;
   SYSTEM; VALIDATION; AREAS; SCORE; TOOL},
Author-Email = {ercwk@mail.cmuh.org.tw
   cnwang@asia.edu.tw},
