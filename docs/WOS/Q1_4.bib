   Fraihat, Salam; Makhadmeh, Sharif; Awad, Mohammed; Al-Betar, Mohammed Azmi; Al-Redhaei, Anessa, Amer Univ Ras Al Khaimah, Dept Comp Sci \& Engn, POB 72603, Ras Al Khaymah, U Arab Emirates.},
DOI = {10.1016/j.iot.2023.100819},
EarlyAccessDate = {MAY 2023},
Article-Number = {100819},
Keywords = {Intrusion detection system; NetFlow; Internet of Things; Arithmetic
   optimization algorithm; Machine learning; Prediction; Classification;
   Feature selection; Optimization},
Keywords-Plus = {DATASET},
