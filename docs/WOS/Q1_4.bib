DOI = {10.1016/j.cscm.2024.e03670},
EarlyAccessDate = {AUG 2024},
Article-Number = {e03670},
Keywords = {Machine learning; Bending capacity; ECC-concrete composite beams; Hybrid
   reinforcement},
Keywords-Plus = {STRENGTH; COLUMNS},
