@article{ WOS:001448999400002,
Author = {Pathak, Jaivik and Joshi, Unnati and Jain, Prince and Joshi, Anand and
   Thakor, Sanketsinh and Parikh, Swapnil and Rathore, Mahendra Singh},
Title = {Dielectric properties of green synthesized Ag-doped ZnO NPs in epoxy
   resin polymer nanocomposites},
Journal = {JOURNAL OF POLYMER RESEARCH},
Year = {2025},
Volume = {32},
Number = {4},
Month = {APR},
Abstract = {This study investigates the dielectric properties of green synthesized
   ZnO and Ag-doped ZnO with different wt.\% of Ag concentration in ZnO
   nanoparticles with epoxy polymer nanocomposites. To confirm their
   structural properties and chemical interactions with the neat epoxy,
   composite was characterized using X-ray Diffraction (XRD) and Fourier
   Transform Infrared Spectroscopy (FTIR). Scanning electron microscope
   (SEM) used to study the surface morphology of the prepared
   nanocomposites. The energy dispersive spectroscopy (EDS) measurement was
   carried out to determine the elemental composition in the samples. The
   LCR was used to study dielectric properties in the frequency range of 1
   k Hz to 2 MHz The result shows that doping concentration and particle
   dispersion significantly influence dielectric properties. Among the
   Ag-doped ZnO epoxy composite, 2 wt.\% exhibited the achieving high
   dielectric constant and low losses due to superior filler dispersion. AC
   conductivity trends aligned with dielectric measurements, confirming the
   critical role of doping and dispersion in tailoring dielectric behavior
   for advanced applications. This study also investigates machine learning
   techniques to predict the target variables epsilon ` and epsilon `'
   using Gradient Boosting, Extra Trees, and XGBoost. Gradient Boosting
   achieved the best performance with an R2 of 0.9993 and MAE of 0.0101 for
   epsilon `, while the Ensemble model provided robust and consistent
   predictions, outperforming Extra Trees and XGBoost in specific metrics.
   Diese Studie untersucht die dielektrischen Eigenschaften von gr \&
   uuml;n synthetisiertem ZnO und Ag-dotiertem ZnO mit unterschiedlichen
   Ag-Konzentrationen in ZnO-Nanopartikeln mit
   Epoxidpolymer-Nanokompositen. Um ihre strukturellen Eigenschaften und
   chemischen Wechselwirkungen mit dem reinen Epoxid zu best \& auml;tigen,
   wurde das Komposit mithilfe von R \& ouml;ntgenbeugung (XRD) und
   Fourier-Transformations-Infrarotspektroskopie (FTIR) charakterisiert.
   Ein Rasterelektronenmikroskop (SEM) wurde verwendet, um die Oberfl \&
   auml;chenmorphologie der hergestellten Nanokomposite zu untersuchen. Die
   energiedispersive Spektroskopie (EDS) wurde durchgef \& uuml;hrt, um die
   Elementzusammensetzung in den Proben zu bestimmen. Die LCR wurde
   verwendet, um die dielektrischen Eigenschaften im Frequenzbereich von 1
   kHz bis 2 MHz zu untersuchen. Das Ergebnis zeigt, dass die
   Dotierungskonzentration und die Partikeldispersion die dielektrischen
   Eigenschaften erheblich beeinflussen. Unter den Ag-dotierten
   ZnO-Epoxid-Kompositen wiesen 2 Gew.-\% aufgrund der besseren F \&
   uuml;llstoffdispersion eine hohe Dielektrizit \& auml;tskonstante und
   geringe Verluste auf. Die Trends der Wechselstromleitf \& auml;higkeit
   stimmten mit dielektrischen Messungen \& uuml;berein und best \&
   auml;tigten die entscheidende Rolle von Dotierung und Dispersion bei der
   Anpassung des dielektrischen Verhaltens f \& uuml;r fortschrittliche
   Anwendungen. Diese Studie untersucht au ss erdem maschinelle
   Lernverfahren zur Vorhersage der Zielvariablen epsilon ` und epsilon `'
   mithilfe von Gradient Boosting, Extra Trees und XGBoost. Gradient
   Boosting erzielte die beste Leistung mit einem R2 von 0,9993 und einem
   MAE von 0,0101 f \& uuml;r epsilon `, w \& auml;hrend das
   Ensemble-Modell robuste und konsistente Vorhersagen lieferte und Extra
   Trees und XGBoost in bestimmten Metriken \& uuml;bertraf.},
Type = {Article},
Affiliation = {Thakor, S; Rathore, MS (Corresponding Author), Parul Univ, Dept Phys Appl Sci, Vadodara 391760, Gujarat, India.
