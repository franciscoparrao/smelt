   Lu, Qikai; Wei, Lifei, Hubei Univ, Hubei Key Lab Reg Dev \& Environm Response, Wuhan 430062, Peoples R China.},
DOI = {10.1016/j.scitotenv.2022.159171},
EarlyAccessDate = {OCT 2022},
Article-Number = {159171},
Keywords = {Digital soil mapping; Soil properties; LUCAS; Model comparison; Spatial
