   Ittichaiwong, Piyalitt; Veerakanjana, Kanyakorn, Mahidol Univ, Fac Med Siriraj Hosp, Siriraj Informat \& Data Innovat Ctr, Bangkok, Thailand.
   Luksanapruksa, Panya, Mahidol Univ, Fac Med Siriraj Hosp, Dept Orthopaed Surg, Div Spine Surg, 2 Wanglang Rd, Bangkok 10700, Thailand.},
DOI = {10.31616/asj.2023.0051},
