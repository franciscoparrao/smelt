   Samad, A., Univ Stuttgart, Dept Flue Gas Cleaning \& Air Qual Control, Inst Combust \& Power Plant Technol IFK, Pfaffenwaldring 23, D-70569 Stuttgart, Germany.},
DOI = {10.1016/j.atmosenv.2023.119987},
EarlyAccessDate = {JUL 2023},
