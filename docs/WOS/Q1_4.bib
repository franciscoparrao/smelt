   Yang, Mengying, Jiangsu Univ, Sch Mat Sci \& Engn, Zhenjiang 212013, Peoples R China.},
DOI = {10.1016/j.scienta.2024.113908},
EarlyAccessDate = {DEC 2024},
Article-Number = {113908},
Keywords = {Tea plant; Canopy images; Cultivars identification; Deep learning;
   Training strategy},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {deerhu@ujs.edu.cn},
Number-of-Cited-References = {56},
