Keywords = {enhancers; bioinformatics; sequence analysis; machine learning;
   integrated framework; ensemble learning},
Keywords-Plus = {IDENTIFYING ENHANCERS; DNA; REPRESENTATION; RESOURCE; STRENGTH},
Author-Email = {weileyi@sdu.edu.cn
