@article{ WOS:001024785200001,
Author = {Yadav, Manoj Kumar and Arora, Kumud and Kumar, Sudhir and Kumar, Ajay},
Title = {Micro-hardness evaluation of the bobbin tool-friction stir welded AA6063
   using regression-based machine learning},
Journal = {MATERIALS LETTERS},
Year = {2023},
Volume = {349},
Month = {OCT 15},
Abstract = {This research work focuses on the prediction of micro-hardness in Bobbin
   tool friction stir welding (BT-FSW) of AA6063 plates using machine
   learning (ML) models. The objectives are to determine the effect of
   process parameters on micro-hardness and to compare the performance of
   various ML techniques. The dataset obtained from experimental runs is
   subjected to classical supervised learning techniques such as LR, SVR,
   DTR, KNN, as well as ensemble techniques including Bagging, Random
   Forest, Extra Trees, AdaBoost, Gradient Boosting, and Extreme Gradient
   Boosting. The results show that ML models effectively predict
   micro-hardness, with ensemble methods outperforming individual
   techniques. The tool rotational speed is identified as the most
   influential parameter affecting micro-hardness.},
Type = {Article},
Affiliation = {Yadav, MK (Corresponding Author), Ajay Kumar Garg Engn Coll, Mech Engn Dept, Ghaziabad, India.
