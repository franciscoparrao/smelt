   Zhen, Rong, Jimei Univ, Natl Local Joint Engn Res Ctr Marine Nav Aids Ser, Nav Coll, Xiamen 361000, Peoples R China.},
DOI = {10.3390/jmse9040449},
Article-Number = {449},
Keywords = {fuel consumption; real-time prediction; hybrid model; sensor data;
