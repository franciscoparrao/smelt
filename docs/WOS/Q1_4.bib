   Azizan, Muhammad Mokhzaini, Univ Sains Islam Malaysia, Fac Engn \& Built Environm, Dept Elect \& Elect Engn, Nilai 71800, Negeri Sembilan, Malaysia.},
DOI = {10.32604/cmc.2023.038045},
Keywords = {Water quality classification; imbalanced data; SMOTE; stacked ensemble
   deep learning; sensitivity analysis},
Keywords-Plus = {OVER-SAMPLING METHODS; BORDERLINE-SMOTE; CLASSIFICATION},
Author-Email = {khairunnisa@um.edu.my},
