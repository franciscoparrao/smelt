}

@article{ WOS:001399158700001,
Author = {Xiang, Shang and Lu, Shaowen and Li, Jiawei and Xie, Kai and Zhu, Rui
   and Wang, Huanan and Huang, Kai and Li, Chaoen and Wu, Jiang and Chen,
   Shibo and Shen, Yuhui and Chen, Yuelin and Wen, Zhengyang},
Title = {Ionic Conductivity Study of Antiperovskite Solid-State Electrolytes
   Based on Interpretable Machine Learning},
Journal = {ACS APPLIED ENERGY MATERIALS},
Year = {2025},
Volume = {8},
Number = {3},
Pages = {1620-1628},
Month = {JAN 16},
Abstract = {The development of high-performance all-solid-state ion batteries
   necessitates the design of solid-state electrolytes (SSEs) with high
   ionic conductivity and excellent electrochemical stability.
   Antiperovskite (AP) X3BA, as the electronically inverted derivative of
   perovskite ABX3, has garnered significant attention in the field of
   energy storage batteries due to its superior ionic conductivity.
   However, the relationship between their structure and ion diffusion
   behavior warrants further investigation. In this work, we constructed a
   machine learning (ML) framework for predicting and analyzing the ionic
   conductivity of the AP SSE, which encompasses data collection, feature
   selection, and training of various ML models. The optimal ML model
   demonstrated an exceptional classification performance, achieving an
   accuracy rate as high as 94\%. Furthermore, we employed the ion
   substitution method to expand the sample size from 168 to 150,000 orders
   of magnitude. Based on this expanded data set, we examined and analyzed
   the mechanisms underlying high ionic conductivity from a big data
   perspective. The findings reveal a strong correlation between the ionic
   conductivity and atomic-scale characteristics at the A-site. The
   electronegativity, density, and ionic radius at the A-site are
   identified as the three most critical features influencing ionic
   conductivity. The interpretable ML model constructed in this study
   enables high-precision prediction of the ionic conductivity of AP
   materials, provides insightful design principles, and significantly
   accelerates the development and application of AP SSEs.},
Type = {Article},
Affiliation = {Huang, K; Wu, J (Corresponding Author), Shanghai Univ Elect Power, Coll Energy \& Mech Engn, Shanghai 200090, Peoples R China.
   Li, CE (Corresponding Author), Ningbo Univ Technol, Sch Civil \& Transportat Engn, Ningbo 315016, Zhejiang, Peoples R China.
   Xiang, Shang; Li, Jiawei; Xie, Kai; Huang, Kai; Wu, Jiang; Chen, Shibo; Shen, Yuhui; Chen, Yuelin; Wen, Zhengyang, Shanghai Univ Elect Power, Coll Energy \& Mech Engn, Shanghai 200090, Peoples R China.
   Lu, Shaowen, Shanghai Tongtianbixiang Environm Protect Technol, Shanghai 200082, Peoples R China.
   Zhu, Rui, Shanghai Univ Elect Power, Coll Math \& Phys, Shanghai 200090, Peoples R China.
   Wang, Huanan, Shanghai Inst Special Equipment Inspect \& Tech Res, Shanghai 200062, Peoples R China.
   Li, Chaoen, Ningbo Univ Technol, Sch Civil \& Transportat Engn, Ningbo 315016, Zhejiang, Peoples R China.},
DOI = {10.1021/acsaem.4c02759},
EarlyAccessDate = {JAN 2025},
Keywords = {antiperovskite solid-state electrolytes; machine learning; ionic
   conductivity; extra trees; structure-propertyrelationships},
