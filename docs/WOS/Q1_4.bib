   Ali, Farman, Nanjing Univ Sci \& Technol, Sch Comp Sci \& Engn, Nanjing 210094, Peoples R China.},
DOI = {10.1109/ACCESS.2023.3268523},
Keywords = {Amyloid proteins; K-separated bigrams; eXtreme gradient boosting;
