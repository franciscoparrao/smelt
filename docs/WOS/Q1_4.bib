   Max Planck Inst Extraterr Phys, D-85740 Garching, Germany.
   Univ Space Res Assoc, Seabrook, MD 20706 USA.
   Michigan State Univ, E Lansing, MI 48834 USA.},
DOI = {10.1086/424955},
Keywords = {methods : statistical; surveys; X-rays : binaries; X-rays : general;
