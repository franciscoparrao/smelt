DOI = {10.1002/cphc.202300162},
EarlyAccessDate = {JUN 2023},
Keywords = {Nucleophilicity; Electrophilicity; Machine learning; Molecular
   descriptors; Prediction},
Keywords-Plus = {SOLVENT POLARITY; REACTIVITY; SCALE; SOLVATOCHROMISM; PARAMETERS; INDEX;
