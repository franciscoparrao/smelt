   Alqahtani, Abdulrahman, Majmaah Univ, Coll Appl Med Sci, Dept Med Equipment Technol, Majmaah 11952, Saudi Arabia.},
DOI = {10.1186/s12931-024-02753-x},
Article-Number = {216},
Keywords = {Pediatric mortality; Respiratory diseases; Pediatric ICU; Mortality
   prediction; Early recognition; Machine learning},
Keywords-Plus = {RISK},
