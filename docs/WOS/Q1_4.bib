   He, Lijie, Huazhong Agr Univ, Coll Publ Adm, Wuhan 430070, Peoples R China.
   Wang, Lunche, China Univ Geosci, Sch Earth Sci, Lab Crit Zone Evolut, Wuhan 430074, Peoples R China.},
DOI = {10.3390/en15093463},
Article-Number = {3463},
Keywords = {solar energy resource potential; tree-based ensemble models; prediction
   accuracy; model stability; computational efficiency},
Keywords-Plus = {PHOTOSYNTHETICALLY ACTIVE RADIATION; DAILY REFERENCE EVAPOTRANSPIRATION;
