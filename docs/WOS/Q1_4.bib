DOI = {10.3390/rs14051053},
Article-Number = {1053},
Keywords = {aerosol optical depth; machine learning; Landsat; high resolution},
Keywords-Plus = {ATMOSPHERIC CORRECTION; RETRIEVAL; ALGORITHM; NETWORK; AERONET; ALBEDO;
