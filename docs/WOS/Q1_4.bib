   Sylaios, Georgios, Democritus Univ Thrace, Dept Environm Engn, Lab Ecol Engn \& Technol, Xanthi 67100, Greece.},
DOI = {10.1016/j.scitotenv.2023.162580},
EarlyAccessDate = {MAR 2023},
Article-Number = {162580},
Keywords = {Time series; Forecasting; Regression; Machine learning; Environment},
