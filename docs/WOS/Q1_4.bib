}

@article{ WOS:001286656500001,
Author = {Ismail, Shereen and Dandan, Salah and Dawoud, Diana W. and Reza, Hassan},
Title = {A Comparative Study of Lightweight Machine Learning Techniques for
   Cyber-Attacks Detection in Blockchain-Enabled Industrial Supply Chain},
Journal = {IEEE ACCESS},
Year = {2024},
Volume = {12},
Pages = {102481-102491},
Abstract = {The security of Industrial Supply Chain (ISC) has emerged through the
   integration of Industrial Internet of Things (IIoT) and Blockchain (BC)
   technology. This new era involves effectively protecting IIoT systems
   from various threats and ensuring their smooth operation and resilience
   against potential cyber-attacks. Within the ISC ecosystem, combining
   machine learning (ML)-based security models for cyber-attack detection
   can play a crucial role in enhancing the ISC security and proactively
   identifying potential threats. This paper presents a BC-enabled ISC that
   embed ML security model integrated within a multi-layered approach. We
   conducted a comparative study and performance analysis of several ML
   classification techniques, with a focus on supervised methods to
   identify the lightweight model for cyber-attack detection suitable for
   deployment in resource-constrained IIoT environment. We investigate the
   performance of Gaussian Naive Bayes (NB), K-Nearest Neighbors (KNN),
   Random Forest (RF), Decision Tree (DT), and three ensemble techniques,
   namely Bagging, Stacking, and Boosting. The study employs the
   WUSTL-IIOT-2021 imbalanced dataset, which contains samples representing
   four types of attacks, including denial of service (DoS), SQL injection,
   reconnaissance, and backdoor. The paper addresses the imbalance in class
   representation by customizing the dataset for training and testing the
   ML models. Both Mutual Information (MI) and Extra-trees (ET) are applied
   as a one-stage ensemble feature selection. The performance of the ML
   models are investigated using classification accuracy (Acc), precision,
   recall, F1 score, Matthews correlation coefficient (MCC), model size
   (Mem), training time (TT) and prediction time (PT).},
Type = {Article},
Affiliation = {Ismail, S (Corresponding Author), Univ Michigan, Merit Network Inc, Ann Arbor, MI 48108 USA.
   Ismail, Shereen, Univ Michigan, Merit Network Inc, Ann Arbor, MI 48108 USA.
   Dandan, Salah; Reza, Hassan, Univ North Dakota, Sch Elect Engn \& Comp Sci, Grand Forks, ND 58202 USA.
   Dawoud, Diana W., Univ Dubai, Coll Engn \& Informat Technol, Dubai, U Arab Emirates.},
DOI = {10.1109/ACCESS.2024.3432454},
Keywords = {Industrial Internet of Things; Security; Cyberattack; Biological system
   modeling; Nearest neighbor methods; Radio frequency; Monitoring; Supply
   chains; Detection algorithms; Blockchains; Industrial supply chain;
   industrial Internet of Things; security; cyber-attacks; detection;
   machine learning; blockchain; lightweight},
Author-Email = {drismail@umich.edu},
Number-of-Cited-References = {46},
Times-Cited = {11},
Unique-ID = {WOS:001286656500001},
}

@article{ WOS:001100377700001,
Author = {Mubarak, Hamza and Sanjari, Mohammad J. and Stegen, Sascha and
   Abdellatif, Abdallah},
Title = {Improved Active and Reactive Energy Forecasting Using a Stacking
   Ensemble Approach: Steel Industry Case Study},
Journal = {ENERGIES},
Year = {2023},
Volume = {16},
Number = {21},
Month = {NOV},
Abstract = {The prevalence of substantial inductive/capacitive loads within the
   industrial sectors induces variations in reactive energy levels. The
   imbalance between active and reactive energy within the network leads to
   heightened losses, diminished network efficiency, and an associated
   escalation in operating costs. Therefore, the forecasting of active and
   reactive energy in the industrial sector confers notable advantages,
   including cost reduction, heightened operational efficiency,
   safeguarding of equipment, enhanced energy consumption management, and
   more effective assimilation of renewable energy sources. Consequently, a
   range of specialized forecasting methods for different applications have
   been developed to address these challenges effectively. This research
   proposes a stacked ensemble methodology, denoted as Stack-XGBoost,
   leveraging three distinct machine learning (ML) methods: extra trees
   regressor (ETR), adaptive boosting (AdaBoost), and random forest
   regressor (RFR), as foundational models. Moreover, the incorporation of
   an extreme gradient boosting (XGBoost) algorithm as a meta-learner
   serves to amalgamate the predictions generated by the base models,
   enhancing the precision of the active/reactive energy consumption
   forecasting using real time data for steel industry. To assess the
   efficacy of the proposed model, diverse performance metrics were
   employed. The results show that the proposed Stack-XGBoost model
   outperformed other forecasting methods. Additionally, a sensitivity
   analysis was conducted to assess the robustness of the proposed method
   against variations in input parameters.},
Type = {Article},
Affiliation = {Sanjari, MJ (Corresponding Author), Griffith Univ, Sch Engn \& Built Environm, Southport, Qld 4222, Australia.
   Mubarak, Hamza; Sanjari, Mohammad J., Griffith Univ, Sch Engn \& Built Environm, Southport, Qld 4222, Australia.
   Stegen, Sascha, Griffith Univ, Sch Engn \& Built Environm, Nathan, Qld 4111, Australia.
   Abdellatif, Abdallah, Univ Malaya, Fac Engn, Dept Elect Engn, Kuala Lumpur 50603, Malaysia.},
DOI = {10.3390/en16217252},
Article-Number = {7252},
Keywords = {active/reactive energy forecasting; industrial energy consumption;
   short-term forecasting; energy management; machine learning; ensemble
   model},
Keywords-Plus = {RANDOM FOREST; PREDICTION; TIME},
Author-Email = {hamza.mubarak@griffithuni.edu.au
   m.sanjari@griffith.edu.au
   s.stegen@griffith.edu.au
   17221028@siswa.um.edu.my},
Number-of-Cited-References = {54},
Times-Cited = {11},
