   Cui, Songxue; Zhu, Haitian, Minist Nat Resources, Key Lab Space Ocean Remote Sensing \& Applicat, Beijing 100081, Peoples R China.},
DOI = {10.1109/JSTARS.2021.3064311},
Keywords = {Feature extraction; Data mining; Training; Spatial resolution;
   Monitoring; Image segmentation; Satellites; Automatic sample extraction
   strategy; change detection (CD); Gaussian-weighted Dempster\&\#8211;
   Shafer evidence theory; high resolution image; multilevel matching
   feature; sequential spectral change vector analysis},
Keywords-Plus = {UNSUPERVISED CHANGE DETECTION; CHANGE VECTOR ANALYSIS; USE/LAND-COVER
   CHANGE; TIME-SERIES; LAND-COVER; IMPERVIOUS SURFACES; CLASSIFICATION;
   IMAGES; INFORMATION; MRF},
