   Ewane, Ewane Basil, Yeungnam Univ, Coll Nat Resources, Dept Forest Resources, 280 Daehak Ro, Gyongsan Si 712749, Gyeongsangbuk D, South Korea.},
DOI = {10.1007/s00267-023-01902-0},
EarlyAccessDate = {OCT 2023},
Keywords = {Ecosystem restoration initiative; Community motivations; Community
   challenges/barriers; Community participation; Conservation initiative;
   Cameroon},
Keywords-Plus = {ENVIRONMENTAL STEWARDSHIP; CONSERVATION; MOTIVATIONS; BIODIVERSITY;
   VOLUNTEERISM; PSYCHOLOGY; KNOWLEDGE; SUCCESS; VALUES; PAY},
Author-Email = {ewane.basil@ubuea.cm},
