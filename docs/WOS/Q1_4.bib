Keywords = {Extremely randomized trees; Decision tree based ensembles; Flood
   susceptibility; Machine learning},
Keywords-Plus = {SPATIAL PREDICTION; FREQUENCY RATIO; AREAS; REGRESSION; GIS},
Author-Email = {sachdeva\_shruti@yahoo.in},
Number-of-Cited-References = {67},
