Keywords = {Baseline prediction; Demand flexibility; Commercial buildings; Machine
   learning; Smart meters; Sliding-window training; Pipeline optimization},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; DEMAND RESPONSE; VALIDATION; CUSTOMER;
   SYSTEMS; MODEL; POWER},
