   Zhang, Yan, Qingdao Univ Sci \& Technol, Coll Electromech Engn, Qingdao 266061, Peoples R China.},
DOI = {10.1016/j.compbiomed.2020.103899},
Article-Number = {103899},
Keywords = {Protein-protein interactions; Multi-information fusion; XGBoost; Stacked
   ensemble classifier},
Keywords-Plus = {GENE-EXPRESSION; HYPERPLANES; INFORMATION; PROFILES; NETWORKS; DATABASE},
