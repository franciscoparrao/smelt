   Li, Delin, Northern Qinghai Tibet Plateau, Key Lab Geol Proc \& Mineral Resources, Xining, Qinghai, Peoples R China.},
DOI = {10.1080/26395940.2022.2102543},
Keywords = {Hyperspectral remote sensing; petroleum hydrocarbon content; LASSO
   algorithm; ERT; GBDT},
Keywords-Plus = {POLLUTION; SHRINKAGE; SELECTION; TPH},
Author-Email = {linnan@jlju.edu.cn},
Number-of-Cited-References = {64},
Times-Cited = {11},
