   Kasongo, Sydney Mambwe, Stellenbosch Univ, Sch Data Sci \& Computat Thinking, ZA-7599 Stellenbosch, South Africa.},
DOI = {10.1109/ACCESS.2021.3104113},
Keywords = {Industrial Internet of Things; Feature extraction; Intrusion detection;
