   Li, Tao, Nanjing Univ Posts \& Telecommun, Sch Comp Sci \& Technol, Nanjing 210046, Jiangsu, Peoples R China.},
DOI = {10.1109/TNB.2015.2491303},
Keywords = {ETs; PETs; sampling strategy; stability},
Keywords-Plus = {BINDING-SITES; CLASSIFIER; ENSEMBLE; BLAST},
Author-Email = {ben.binxia@gmail.com
   liqianmu@126.com},
