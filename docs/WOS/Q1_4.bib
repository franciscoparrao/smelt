}

@article{ WOS:001007635100001,
Author = {Xie, Yunxin and Jin, Liangyu and Zhu, Chenyang and Wu, Siyu},
Title = {A semi-supervised coarse-to-fine approach with bayesian optimization for
   lithology identification},
Journal = {EARTH SCIENCE INFORMATICS},
Year = {2023},
Month = {2023 JUN 7},
Abstract = {Lithology identification is critical in the interpretation of
   well-logging data for petroleum exploration and development. However,
   the limited availability of labeled well-logging data for machine
   learning model training can lead to compromised accuracy in lithology
   classification models. Here, we propose a semi-supervised lithology
   identification model to overcome this challenge. Our framework consists
   of Bayesian optimization for tuning ensemble algorithms, including
   random forest, gradient boosting decision tree, extremely randomized
   trees, and adaptive boosting, to establish a high-quality baseline model
   for semi-supervised learning. We also employ a self-training strategy to
   increase the number of labeled samples in the training set and use the
   predicted label with the highest confidence as a pseudo-label to reduce
   the accumulation of deviation caused by incorrect pseudo-labels. Our
   semi-supervised coarse-to-fine framework improves rock classification
   accuracy, particularly for sandstone. Testing our model on well-logging
   data from two real regions, we found that the ExtraRF-based
   semi-supervised model in the HGF area performs the best, with a maximum
   classification accuracy of 91.6\%, which is 5\% higher than the original
   coarse-to-fine model without using Bayesian optimization and
   pseudo-labeling techniques.},
Type = {Article; Early Access},
Affiliation = {Zhu, CY (Corresponding Author), Univ Southampton, Sch Elect \& Comp Sci, Southampton SO17 1BJ, Southampton, England.
   Xie, Yunxin; Jin, Liangyu; Wu, Siyu, Changzhou Univ, Sch Petr \& Nat Gas Engn, Changzhou 213000, Jiangsu, Peoples R China.
   Zhu, Chenyang, Univ Southampton, Sch Elect \& Comp Sci, Southampton SO17 1BJ, Southampton, England.},
DOI = {10.1007/s12145-023-01014-7},
EarlyAccessDate = {JUN 2023},
Keywords = {Lithology classification; Ensemble methods; Semi-supervised learning;
   Bayesian optimization; Pseudo labels},
Keywords-Plus = {GAUSSIAN-PROCESSES; MACHINE},
Author-Email = {xieyx@cczu.edu.cn
   s21040820014@smail.cczu.edu.cn
