DOI = {10.1007/s12539-023-00552-4},
EarlyAccessDate = {JAN 2023},
Keywords = {Comprehensive features; Ensemble learning; sORFs; Small peptides;
   LncRNAs},
Keywords-Plus = {COMPARATIVE GENOMICS; PROTEIN; TRANSLATION; IDENTIFICATION; PEPTIDES;
   DATABASE; NETWORK; ENOD40; RNA; DNA},
Author-Email = {mengjun@dlut.edu.cn},
