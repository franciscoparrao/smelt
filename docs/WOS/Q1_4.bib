@article{ WOS:001138006900001,
Author = {Ma, Mengjie and Sun, Zhuo and Han, Peixiu and Yang, Huirong},
Title = {A stacking ensemble learning for ship fuel consumption prediction under
   cross-training},
Journal = {JOURNAL OF MECHANICAL SCIENCE AND TECHNOLOGY},
Year = {2024},
Volume = {38},
Number = {1},
Pages = {299-308},
Month = {JAN},
Abstract = {Accurate ship fuel consumption prediction is vital for the shipping
   industry. In this study, a stacking ensemble learning is developed to
   predict tanker fuel consumption precisely, built on cross-training of
   the first-level learner. Among comparative experiments, stacking with
   Bayesian regression (BR) as the meta-learner and extremely randomized
   trees (ET), gradient boosting decision tree (GBDT) and light gradient
   boosting machine (LGBM) as firstlevel learners achieves superior
   performance, yielding the best results. The root mean square error
   (RMSE) on the test dataset is 0.2679, and on the training dataset is
   0.1327. Ensemble model-based feature importance analysis reveals that
   ship attributes (speed, draught, trim) contribute around 80 \%, while
   meteorological features contribute about 20 \%.},
Type = {Article},
Affiliation = {Sun, Z (Corresponding Author), Dalian Maritime Univ, Coll Transportat Engn, Dalian, Liaoning, Peoples R China.
   Ma, Mengjie; Sun, Zhuo; Han, Peixiu; Yang, Huirong, Dalian Maritime Univ, Coll Transportat Engn, Dalian, Liaoning, Peoples R China.},
DOI = {10.1007/s12206-023-1224-9},
