@article{ WOS:000838504800041,
Author = {Mao, Zehui and Xia, Mingxuan and Jiang, Bin and Xu, Dezhi and Shi, Peng},
Title = {Incipient Fault Diagnosis for High-Speed Train Traction Systems via
   Stacked Generalization},
Journal = {IEEE TRANSACTIONS ON CYBERNETICS},
Year = {2022},
Volume = {52},
Number = {8},
Pages = {7624-7633},
Month = {AUG},
Abstract = {Diagnosing the fault as early as possible is significant to guarantee
   the safety and reliability of the high-speed train. Incipient fault
   always makes the monitored signals deviate from their normal values,
   which may lead to serious consequences gradually. Due to the obscure
   early stage symptoms, incipient faults are difficult to detect. This
   article develops a stacked generalization (stacking)-based incipient
   fault diagnosis scheme for the traction system of high-speed trains. To
   extract the fault feature from the faulty data signals, which are
   similar to the normal ones, the extreme gradient boosting (XGBoost),
   random forest (RF), extra trees (ET), and light gradient boosting
   machine (LightGBM) are chosen as the base estimators in the first layer
   of the stacking. Then, the logistic regression (LR) is taken as the meta
   estimator in the second layer to integrate the results from the base
   estimators for fault classification. Thanks to the generalization
   ability of stacking, the incipient fault diagnosis performance of the
   proposed stacking-based method is better than that of the single model
   (XGBoost, RF, ET, and LightGBM), although they can be used to detect the
   incipient faults, separately. Moreover, to find out the optimal
   hyperparameters of the base estimators, a swarm intelligent optimization
   algorithm, pigeon-inspired optimization (PIO), is employed. The proposed
   method is tested on a semiphysical platform of the CRH2 traction system
   in CRRC Zhuzhou Locomotive Company Ltd. The results show that the fault
   diagnosis rate of the proposed scheme is over 96\%.},
Type = {Article},
Affiliation = {Jiang, B (Corresponding Author), Nanjing Univ Aeronaut \& Astronaut, Coll Automat Engn, Nanjing 210016, Peoples R China.
   Mao, Zehui; Xia, Mingxuan; Jiang, Bin, Nanjing Univ Aeronaut \& Astronaut, Coll Automat Engn, Nanjing 210016, Peoples R China.
   Xu, Dezhi, Jiangnan Univ, Sch Internet Things Engn, Wuxi 214122, Jiangsu, Peoples R China.
   Shi, Peng, Univ Adelaide, Sch Elect \& Elect Engn, Adelaide, SA 5005, Australia.},
DOI = {10.1109/TCYB.2020.3034929},
Keywords = {Fault diagnosis; Circuit faults; Stacking; Sensors; Sensor systems;
   Mathematical model; Radio frequency; Fault diagnosis; high-speed train;
   incipient faults; pigeon-inspired optimization (PIO); stacked
   generalization},
Keywords-Plus = {TOLERANT CONTROL; OBSERVER; FAILURES},
Author-Email = {zehuimao@nuaa.edu.cn
   binjiang@nuaa.edu.cn
   xudezhi@jiangnan.edu.cn
   peng.shi@adelaide.edu.au},
Number-of-Cited-References = {43},
