   Mporas, Iosif, Univ Hertfordshire, Sch Phys Engn \& Comp Sci, Hatfield, Herts, England.},
DOI = {10.1108/JEDT-05-2022-0238},
EarlyAccessDate = {SEP 2022},
Keywords = {Big data analytics; Buildings; Energy efficiency; Machine learning;
