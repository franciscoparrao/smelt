   telescopes; gamma; hadron separation; image analysis; pattern
   recognition},
Keywords-Plus = {MULTIVARIATE-ANALYSIS; CRAB-NEBULA; OPTIMIZATION; TELESCOPES; SYSTEM;
   TEV},
