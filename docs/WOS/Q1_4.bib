Keywords = {Hyperspectral image quality assessment (HIQA); No-reference image
   quality assessment (NR-IQA); Machine learning (ML); Multi-feature
   fusion; Unmanned aerial vehicles (UAV)},
Keywords-Plus = {QUALITY ASSESSMENT},
Author-Email = {zqz\_inf@shzu.edu.cn},
