DOI = {10.3390/brainsci11060735},
Article-Number = {735},
Keywords = {brain functional networks; link selection; statistics; machine learning},
Keywords-Plus = {REJECTIVE MULTIPLE TEST; CONNECTIVITY NETWORKS; COVARIANCE MATRICES;
