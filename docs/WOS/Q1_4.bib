   Sila-Nowicka, Katarzyna, Univ Glasgow, Urban Big Data Ctr, Glasgow, Lanark, Scotland.
   Sila-Nowicka, Katarzyna, Univ Auckland, Sch Environm, Auckland, New Zealand.},
DOI = {10.1080/1573062X.2020.1734947},
EarlyAccessDate = {MAR 2020},
Keywords = {Short-term forecasting; water demand; water consumption; geolocated
   data; classical forecasting; machine learning},
Keywords-Plus = {NETWORKS},
