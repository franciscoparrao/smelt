   Sun, Yu tong; Xia, Li heng, Minist Nat Resources, Land Engn Technol Innovat Ctr, Shaanxi Prov Land Engn Construct Grp, Xian 710075, Peoples R China.},
DOI = {10.1016/j.csite.2024.104285},
EarlyAccessDate = {MAR 2024},
Article-Number = {104285},
Keywords = {Adsorption; Separation; Computational fluid dynamics; Mass transfer;
   Gradient boosting; Machine learning},
Author-Email = {2018129010@chd.edu.cn},
Number-of-Cited-References = {22},
