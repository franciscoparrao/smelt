   Tan, Kun; Zhang, Yusha; Wang, Xue; Chen, Yu, China Univ Min \& Technol, NASG, Key Lab Land Environm \& Disaster Monitoring, Xuzhou 221116, Jiangsu, Peoples R China.},
DOI = {10.3390/rs11030359},
Article-Number = {359},
Keywords = {change detection; multi-feature; ensemble classifiers; multi-scale
   uncertainty analysis},
Keywords-Plus = {SENSING IMAGE CLASSIFICATION; BUILDING CHANGE DETECTION; SELECTION;
   FEATURES; SYSTEM; INFORMATION; MACHINE; FUSION; LAND},
Author-Email = {tankuncu@gmail.com
