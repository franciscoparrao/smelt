   Sun, Lin, Shandong Univ Sci \& Technol, Coll Geodesy \& Geomat, Qingdao, Peoples R China.
   Xue, Wenhao, Qingdao Univ, Sch Econ, Qingdao, Peoples R China.},
DOI = {10.1016/j.rse.2021.112775},
EarlyAccessDate = {JAN 2022},
Article-Number = {112775},
Keywords = {Ozone; Air pollution; Ensemble learning; COVID-19; China},
