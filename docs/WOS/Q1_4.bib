EarlyAccessDate = {JAN 2023},
Article-Number = {107761},
Keywords = {Seismic risk assessment; Machine learning method; Seismic fragility
   curve prediction; Seismic limit-state capacity; Seismic vulnerability
   assessment; Reinforced concrete},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; STRENGTH},
Author-Email = {farzin.kazemi@pg.edu.pl},
Number-of-Cited-References = {66},
