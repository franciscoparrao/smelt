   Albayati, Talib M., Univ Technol Iraq, Dept Chem Engn, 52 Alsinaa St,POB 35010, Baghdad, Iraq.},
DOI = {10.1016/j.ijhydene.2025.01.502},
EarlyAccessDate = {FEB 2025},
Keywords = {Hydrogen; Formic acid; Dehydrogenation; Machine learning; Catalysis;
   Activated carbon-supported palladium},
Keywords-Plus = {SUPPORTED PALLADIUM NANOPARTICLES; ABSOLUTE ERROR MAE; PD/C CATALYSTS;
   DECOMPOSITION; GENERATION; SIZE; ENERGY; METAL; STORAGE; CHAIN},
Author-Email = {szendehboudi@mun.ca},
