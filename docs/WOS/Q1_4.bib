Keywords-Plus = {MACHINE-LEARNING APPROACH; ENERGY-CONSUMPTION; MARITIME TRANSPORT;
   INLAND SHIPS; OPTIMIZATION; EFFICIENCY; SPEED; MANAGEMENT; PROPULSION;
