   Kim, Young Taeg; Kwon, Seok Jae, Korea Hydrog \& Oceanog Agcy, Busan 49111, South Korea.},
DOI = {10.3390/s21155232},
Article-Number = {5232},
Keywords = {sea fog dissipation; prediction of fog dissipation; machine learning;
