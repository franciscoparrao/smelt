Article-Number = {1543},
Keywords = {machine learning; unifloral honeys; botanical origin; physicochemical
   parameters; classification},
Keywords-Plus = {BOTANICAL ORIGIN; PHYSICOCHEMICAL PARAMETERS; SHRUNKEN CENTROIDS;
   FEATURE-SELECTION; ELECTRONIC NOSE; FLORAL ORIGIN; AUTHENTICATION;
