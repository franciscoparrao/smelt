}

@incollection{ WOS:000426813700046,
Author = {Motamedidehkordi, Nassim and Amini, Sasan and Hoffmann, Silja and Busch,
   Fritz and Fitriyanti, Mustika Riziki},
Book-Group-Author = {IEEE},
Title = {Modeling Tactical Lane-change Behavior for Automated Vehicles: A
   Supervised Machine Learning Approach},
Booktitle = {2017 5TH IEEE INTERNATIONAL CONFERENCE ON MODELS AND TECHNOLOGIES FOR
   INTELLIGENT TRANSPORTATION SYSTEMS (MT-ITS)},
Year = {2017},
Pages = {268-273},
Abstract = {In recent years, due to growing interest in automated driving, the need
   for better understanding the humans driving behavior, and particularly
   the lane changing and car following behavior, has further increased.
   Despite its great importance, lane changing has not been studied as
   extensively as longitudinal behavior and remains one of the most
   challenging driving behavior maneuvers to understand and to predict.
   Drivers take into account many factors while making a tactical decision,
   which cannot be precisely represented by the conventional rule based
   models. In this paper, we compare the results of different supervised
   machine learning classifiers to better understand the lane change
   decision of drivers using the NGSIM database. For this aim, after
   choosing the relevant features, the ones which contribute the most to
   the model were chosen with the help of feature importance analysis.
   Afterward, the training dataset was used to train the model with naive
   Bayes, support vector machines, logic regression, nearest neighborhoods,
   decision trees, extra trees and random forest classifiers. The accuracy
   of predictions for test dataset indicates that extra trees classifier,
   decision trees and random forest had the best performance in predicting
   the lane change decisions of human drivers.},
Type = {Proceedings Paper},
Affiliation = {Motamedidehkordi, N (Corresponding Author), Tech Univ Munich, Chair Traff Engn \& Control, Munich, Germany.
   Motamedidehkordi, Nassim; Amini, Sasan; Hoffmann, Silja; Busch, Fritz, Tech Univ Munich, Chair Traff Engn \& Control, Munich, Germany.
   Fitriyanti, Mustika Riziki, Tech Univ Munich, Dept Informat, Munich, Germany.},
Keywords = {lane change; machine learning; big data},
Author-Email = {nassim.motamedidehkordi@tum.de
   sasan.amini@tum.de
   silja.hoffmann@tum.de
   fritz.busch@tum.de
   mustika.fitriyanti@tum.de},
