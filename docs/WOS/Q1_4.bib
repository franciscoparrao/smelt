@article{ WOS:000896946300003,
Author = {Liu, Jian and Liu, Fangyu and Zheng, Chuanfeng and Fanijo, Ebenezer O.
   and Wang, Linbing},
Title = {Improving asphalt mix design considering international roughness index
   of asphalt pavement predicted using autoencoders and machine learning},
Journal = {CONSTRUCTION AND BUILDING MATERIALS},
Year = {2022},
Volume = {360},
Month = {DEC 19},
Abstract = {Scientific asphalt mix design can improve the engineering properties of
   asphalt mixture, thus further slowing the growth of international
   roughness index (IRI). To avoid the occurrence of high IRI values in
   pavement design life, this study improved the current asphalt mix design
   by introducing a machine learning (ML) model to predict pavement IRI.
   The data relating to the IRI of flexible pavements were collected from
   the long-term pavement performance (LTPP) program database. A total of
   37 input features about climate condition, traffic, pavement structure,
   and pavement materials properties were selected based on backward
   elimination and recursive feature elimination methods. The effect of
   five different dimensionality reduction techniques on the performance of
   ML models was analyzed. Six different ML algorithms including support
   vector regression (SVR), random forest, artificial neural networks
   (ANN), Gaussian process regression (GPR), Extra-trees, and gradient
   boosting (GB) were trained to predict IRI, and the performance metrics
   (R2, RMSE, MAE, MAPE, and SI) of these ML models were computed and
   compared. The IRI criterion and the best IRI prediction model were then
   added to the asphalt mix design procedure. The results showed that
   compared to other dimensionality reduction methods, the combination of
   autoencoders makes ANN and GB perform better. The AE-GPR was the best
   approach to pre-dicting IRI (R2 = 0.94). The proposed mix design
   procedure was operated to design the asphalt concrete for the surface
   layer of a construction project. The predicted IRIs of the initial trial
   blends (including the traditionally designed mix) do not exceed the
   range of the IRI criterion in the procedure, and the recommended mixture
   remains the same as the traditionally designed one.},
Type = {Article},
Affiliation = {Wang, LB (Corresponding Author), Univ Georgia, Sch Environm Civil Agr \& Mech Engn, Athens, GA 30602 USA.
   Liu, Jian; Liu, Fangyu; Fanijo, Ebenezer O., Virginia Polytech Inst \& State Univ, Dept Civil \& Environm Engn, Blacksburg, VA 24061 USA.
   Zheng, Chuanfeng, Jilin Univ, Coll Construct Engn, Changchun 130026, Peoples R China.
   Wang, Linbing, Univ Georgia, Sch Environm Civil Agr \& Mech Engn, Athens, GA 30602 USA.},
DOI = {10.1016/j.conbuildmat.2022.129439},
EarlyAccessDate = {NOV 2022},
Article-Number = {129439},
Keywords = {IRI; Asphalt mix design; Machine learning; Autoencoders; LTPP; MEPDG},
Keywords-Plus = {SUPPORT VECTOR MACHINE; ARTIFICIAL NEURAL-NETWORKS; REMAINING SERVICE
   LIFE; DYNAMIC MODULUS; MODELS; PERFORMANCE; REGRESSION; CONCRETE;
   MIXTURES; STRENGTH},
