   Ye, Bojia; Liu, Bo; Tian, Yong; Wan, Lili, Nanjing Univ Aeronaut \& Astronaut, Coll Civil Aviat, Nanjing 210016, Peoples R China.},
DOI = {10.3390/su12072749},
Article-Number = {2749},
Keywords = {air traffic; departure delay prediction; aggregate characteristics;
