@article{ WOS:001397532900001,
Author = {Fan, Lin and Wang, Dexi and Yu, Honglei and Gong, Ze and He, Yan and
   Guo, Jinyuan},
Title = {Application of machine learning to predict the fluoride removal
   capability of MgO},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {1},
Month = {FEB},
Abstract = {Fluorine pollution poses a significant threat to environmental
   sustainability and public health, while fluoride ion removal from
   wastewater remains challenging. Magnesium oxide is an efficient
   adsorbent for fluoride ions, but its performance depends on factors such
   as adsorbent properties, reaction conditions, and co-existing ions. In
   contrast to traditional experimental methods, machine learning
   techniques are adept at managing complex multivariate data,
   significantly improving prediction accuracy while concurrently reducing
   experimental costs. This study developed a high-precision predictive
   model for fluoride removal using MgO, integrated with advanced machine
   learning methods. After evaluating 16 models, Extra Trees, CatBoost,
   Random Forest, and XGBoost were identified as top performers.
   Hyperparameter optimization using Optuna and Hyperband further enhanced
   model accuracy. By applying ensemble techniques, XGBoost and CatBoost
   were combined to create the XGBoost-Cat model, which achieved R2 values
   of 0.995 on the training set and 0.922 on the test set, demonstrating
   strong predictive performance and interpretability. An online, web-based
   prediction platform was developed using this model, enabling real-time
   predictions by inputting experimental conditions. SHapley Additive
   exPlanations and partial dependence plots analyses revealed that MgO
   concentration, reaction time, and pH were critical factors affecting
   fluoride removal. Notably, increasing MgO concentration under low pH
   conditions significantly improved removal efficiency. This study
   provides significant insights into optimizing the fluoride ion removal
   process and underscores the potential of machine learning models in
   fluoride wastewater treatment.},
Type = {Article},
Affiliation = {Wang, DX (Corresponding Author), Shenyang Univ Technol, Sch Mech Engn, Shenyang 110870, Liaoning, Peoples R China.
   Yu, HL (Corresponding Author), Shenyang Univ Technol, Sch Chem Equipment, Liaoyang 111000, Liaoning, Peoples R China.
