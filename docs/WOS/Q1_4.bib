   Li, Junpeng, Cent South Univ, Business Sch, Changsha 410083, Peoples R China.},
DOI = {10.3390/atmos14101517},
Article-Number = {1517},
Keywords = {data mining; extremely randomized trees model; PM2.5 prediction; random
   forest model; ridge regression model; support vector machine model},
