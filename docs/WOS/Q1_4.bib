   Vo Thi Tam Minh; Tran Trung Tin; To Thi Hien, Vietnam Natl Univ, Ho Chi Minh City, Vietnam.
   Tran Trung Tin, Univ Technol, Fac Appl Sci, Ho Chi Minh City, Vietnam.},
DOI = {10.4209/aaqr.210108},
