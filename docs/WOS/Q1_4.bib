   Yu, Daren, Harbin Inst Technol, Sch Energy Sci \& Engn, Harbin 150001, Peoples R China.},
DOI = {10.1016/j.knosys.2014.06.005},
Keywords = {Ensemble learning; Margin distribution; Diversity; Fusion strategy;
   Rotation},
Keywords-Plus = {CLASSIFIER ENSEMBLES; NEURAL-NETWORKS},
