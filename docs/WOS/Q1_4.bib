Keywords = {Soil health; Soil functions; Digital soil mapping; Aluminium; Iron;
   Agriculture},
Keywords-Plus = {SPATIAL PREDICTION; NEURAL-NETWORKS; ORGANIC-CARBON; SATURATION;
   PYROPHOSPHATE; ACCUMULATION; PHOSPHATE; FRAMEWORK},
Author-Email = {maarten.vandoorn@nmi-agro.nl},
