   Zeng, Xiaomin, Cent South Univ, Xiangya Publ Hlth Sch, Dept Epidemiol \& Hlth Stat, Changsha, Hunan, Peoples R China.},
DOI = {10.7717/peerj-cs.1229},
Keywords = {Gene selection; Microarray gene expression; Harris Hawks algorithm;
