DOI = {10.1016/j.cageo.2016.10.013},
Keywords = {Bathymetry; Topography; Seamounts; Random forests; Extremely randomized
   trees},
Keywords-Plus = {TOPOGRAPHY; ALGORITHMS; ARC},
Author-Email = {fpetry@nrlssc.navy.mil},
Number-of-Cited-References = {28},
Times-Cited = {21},
