   He, Can, Sun Yat Sen Univ, Sch Earth Sci \& Engn, Guangzhou 510275, Peoples R China.
   Gao, Shang-de; Xu, Ren-jun, Zhejiang Univ, Ctr Data Sci, Hangzhou 310058, Peoples R China.},
DOI = {10.2138/am-2022-8189},
Keywords = {Clinopyroxene; Fe3+/Sigma Fe; machine learning; geothermometer; redox},
Keywords-Plus = {DEEP UPPER-MANTLE; OXIDATION-STATE; ELECTRON-MICROPROBE;
