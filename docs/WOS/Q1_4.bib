@incollection{ WOS:000698977000050,
Author = {Lima, Bruno Monteiro Rocha and da Fonseca, Vinicius Prado and de
   Oliveira, Thiago Eustaquio Alves and Zhu, Qi and Petriu, Emil M.},
Book-Group-Author = {IEEE},
Title = {Dynamic Tactile Exploration for Texture Classification using a
   Miniaturized Multi-modal Tactile Sensor and Machine Learning},
Booktitle = {2020 14TH ANNUAL IEEE INTERNATIONAL SYSTEMS CONFERENCE (SYSCON2020)},
Series = {Annual IEEE Systems Conference},
Year = {2020},
Abstract = {The findings of this paper enhance the knowledge of machine learning in
   tactile texture recognition. Synthetic perception of textures was
   achieved using a recently developed miniaturized multi-modal tactile
   sensor. Thirteen commonly used textures were dynamically explored and
   classified using supervised learning classifiers. The best result was
   achieved by the Extra Trees classifier with an average accuracy score of
   95\%. Other classifiers also had high-performance results with an
   average accuracy score of 92\% (Random Forest), 91\% (Support-Vector
   Machines), and 88\% (Multilayer Perceptron). Among pressure,
   acceleration and magnetic flux, the sensor's angular velocity proved to
   be the most efficient feature to classify textures. The results also
   showed a correct classification between two textures that were
   originated from the same anisotropic material. This indicated that the
   exploration in different directions produced distinctive outputs and,
   therefore, the exploration in two dimensions have to be analyzed in
   future works.},
Type = {Proceedings Paper},
Affiliation = {Lima, BMR (Corresponding Author), Univ Ottawa, Sch Elect Engn \& Comp Sci, Ottawa, ON, Canada.
   Lima, Bruno Monteiro Rocha; da Fonseca, Vinicius Prado; Zhu, Qi; Petriu, Emil M., Univ Ottawa, Sch Elect Engn \& Comp Sci, Ottawa, ON, Canada.
   de Oliveira, Thiago Eustaquio Alves, Lakehead Univ, Dept Comp Sci, Thunder Bay, ON, Canada.},
DOI = {10.1109/syscon47679.2020.9275871},
Keywords = {texture classification; dynamic exploration; tactile sensor; artificial
