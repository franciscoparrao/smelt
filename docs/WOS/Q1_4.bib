   Sheng, Victor S., Texas Tech Univ, Dept Comp Sci, Lubbock, TX 79409 USA.},
DOI = {10.3389/fenrg.2021.686616},
Article-Number = {686616},
Keywords = {fault detection; fault diagnosis; cost-sensitive learning; extremely
   randomized trees; class imbalance; wind turbine generator},
Keywords-Plus = {GREY WOLF OPTIMIZER; FEATURE-SELECTION; TOLERANT CONTROL; DIAGNOSIS;
