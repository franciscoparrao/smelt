@article{ WOS:000560911900001,
Author = {Yong, Binbin and Wei, Wei and Li, Kuan-Ching and Shen, Jun and Zhou,
   Qingguo and Wozniak, Marcin and Polap, Dawid and Damasevicius, Robertas},
Title = {Ensemble machine learning approaches for webshell detection in Internet
   of things environments},
Journal = {TRANSACTIONS ON EMERGING TELECOMMUNICATIONS TECHNOLOGIES},
Year = {2022},
Volume = {33},
Number = {6, SI},
Month = {JUN},
Abstract = {The Internet of things (IoT), made up of a massive number of sensor
   devices interconnected, can be used for data exchange, intelligent
   identification, and management of interconnected ``things.{''} IoT
   devices are proliferating and playing a crucial role in improving the
   living quality and living standard of the people. However, the real IoT
   is more vulnerable to attack by countless cyberattacks from the
   Internet, which may cause privacy data leakage, data tampering and also
   cause significant harm to society and individuals. Network security is
   essential in the IoT system, and Web injection is one of the most severe
   security problems, especially the webshell. To develop a safe IoT
   system, in this article, we apply essential machine learning models to
   detect webshell to build secure solutions for IoT network. Future,
   ensemble methods including random forest (RF), extremely randomized
   trees (ET), and Voting are used to improve the performances of these
   machine learning models. We also discuss webshell detection in
   lightweight and heavyweight computing scenarios for different IoT
   environments. Extensive experiments have been conducted on these models
   to verify the validity of webshell intrusion. Simulation results show
   that RF and ET are suitable for lightweight IoT scenarios, and Voting
   method is effective for heavyweight IoT scenarios.},
Type = {Article},
Affiliation = {Zhou, QG (Corresponding Author), Lanzhou Univ, Sch Informat Sci \& Engn, Lanzhou, Gansu, Peoples R China.
   Yong, Binbin; Zhou, Qingguo, Lanzhou Univ, Sch Informat Sci \& Engn, Lanzhou, Gansu, Peoples R China.
   Wei, Wei, Xian Univ Technol, Sch Comp Sci \& Engn, Xian, Peoples R China.
   Li, Kuan-Ching, Providence Univ, Dept Comp Sci \& Informat Engn, Taichung, Taiwan.
   Shen, Jun, Univ Wollongong, Sch Comp \& Informat Technol, Wollongong, NSW, Australia.
   Wozniak, Marcin; Polap, Dawid, Silesian Tech Univ, Inst Math, Gliwice, Poland.
   Damasevicius, Robertas, Kaunas Univ Technol, Multimedia Engn Dept, Kaunas, Lithuania.},
DOI = {10.1002/ett.4085},
EarlyAccessDate = {AUG 2020},
Article-Number = {e4085},
Keywords-Plus = {CLASSIFICATION; NAVIGATION; NETWORK; SECURE},
Author-Email = {zhouqg@lzu.edu.cn},
