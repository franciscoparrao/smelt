DOI = {10.1061/(ASCE)WR.1943-5452.0001146},
Article-Number = {04019072},
Keywords = {Hydropower; Environmental impacts; Reservoir operation; Decision tree;
   Climate change; Artificial intelligence},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; NINO-SOUTHERN OSCILLATION; EL-NINO;
