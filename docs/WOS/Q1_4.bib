}

@article{ WOS:000484875200009,
Author = {Munoz-Mas, Rafael and Gil-Martinez, Enric and Oliva-Paterna, Francisco
   J. and Belda, Eduardo J. and Martinez-Capel, Francisco},
Title = {Tree-based ensembles unveil the microhabitat suitability for the
   invasive bleak (Alburnus alburnus L.) and pumpkinseed (Lepomis
   gibbosus L.): Introducing XGBoost to eco-informatics},
Journal = {ECOLOGICAL INFORMATICS},
Year = {2019},
Volume = {53},
Month = {SEP},
Abstract = {Random Forests (RFs) and Gradient Boosting Machines (GBMs) are popular
   approaches for habitat suitability modelling in environmental flow
   assessment. However, both present some limitations theoretically solved
   by alternative tree-based ensemble techniques (e.g. conditional RFs or
   oblique RFs). Among them, eXtreme Gradient Boosting machines (XGBoost)
   has proven to be another promising technique that mixes subroutines
   developed for RFs and GBMs. To inspect the capabilities of these
   alternative techniques, RFs and GBMs were compared with: conditional
   RFs, oblique RFs and XGBoost by modelling, at the micro-scale, the
   habitat suitability for the invasive bleak (Alburnus alburnus L.) and
   pumpkinseed (Lepomis gibbosus L). XGBoost outperformed the other
   approaches, particularly conditional and oblique RFs, although there
   were no statistical differences with standard RFs and GBMs. The partial
   dependence plots highlighted the lacustrine origins of pumpkinseed and
   the preference for lentic habitats of bleak. However, the latter
   depicted a larger tolerance for rapid microhabitats found in run-type
   river segments, which is likely to hinder the management of flow regimes
   to control its invasion. The difference in the computational burden and,
   especially, the characteristics of datasets on microhabitat use (low
   data prevalence and high overlapping between categories) led us to
   conclude that, in the short term, XGBoost is not destined to replace
   properly optimised RFs and GBMs in the process of habitat suitability
   modelling at the micro-scale.},
Type = {Article},
Affiliation = {Muñoz-Mas, R (Corresponding Author), Univ Politecn Valencia, Inst Invest Gestio Integrada Zones Costaneres IGI, Paranimf 1, Valencia 46730, Pais Valencia, Spain.
   Munoz-Mas, Rafael; Gil-Martinez, Enric; Belda, Eduardo J.; Martinez-Capel, Francisco, Univ Politecn Valencia, Inst Invest Gestio Integrada Zones Costaneres IGI, Paranimf 1, Valencia 46730, Pais Valencia, Spain.
   Munoz-Mas, Rafael, Univ Girona, Inst Aquat Ecol, GRECO, Girona 17003, Catalunya, Spain.
   Oliva-Paterna, Francisco J., Univ Murcia, Dept Zool \& Antropol Fis, Avda Teniente Flomesta 5, Murcia 30003, Spain.},
DOI = {10.1016/j.ecoinf.2019.100974},
Article-Number = {100974},
Keywords = {Conditional random forests; eXtreme Gradient Boosting machine; Gradient
   boosting machine; Oblique random forests; Random forests; SMOTE},
Keywords-Plus = {SPECIES DISTRIBUTION MODELS; SUPPORT VECTOR MACHINES; TROUT
   SALMO-TRUTTA; VARIABLE SELECTION; POPULATION TRAITS; FISH HABITAT; RHONE
   RIVER; GRADIENT; CLASSIFICATION; PREVALENCE},
Author-Email = {rafa.m.mas@gmail.com},
