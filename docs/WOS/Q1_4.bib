Keywords = {Shield tunneling; Ground settlement; Intelligent prediction;
   Construction parameters; Intelligent optimization; Generalization
   ability},
Keywords-Plus = {NEURAL-NETWORKS; SURFACE; ANN},
Author-Email = {ldj@cumtb.edu.cn},
