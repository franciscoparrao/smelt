   Castelletti, Andrea, Politecn Milan, Dept Elect Informat \& Bioengn, I-20133 Milan, Italy.
   Antenucci, Jason P., Hatch Associates Perth Western Australia, Perth, WA, Australia.},
DOI = {10.1002/wrcr.20268},
Keywords = {input variable selection; data-driven modeling; ecological modeling;
   phytoplankton dynamics; water transfers},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; INPUT VARIABLE SELECTION; REGULATED RIVER;
   ALGAL BLOOM; ALGORITHM; TREES; DISTURBANCE; ENSEMBLES; QUALITY; SYSTEM},
Author-Email = {fornarel@cwr.uwa.edu.au},
Number-of-Cited-References = {74},
Times-Cited = {39},
