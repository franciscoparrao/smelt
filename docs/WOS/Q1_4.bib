@incollection{ WOS:001108757100143,
Author = {Aminifar, Amin and Rabbi, Fazle and Pun, Ka I. and Lamo, Yngve},
Book-Group-Author = {ACM},
Title = {Privacy Preserving Distributed Extremely Randomized Trees},
Booktitle = {36TH ANNUAL ACM SYMPOSIUM ON APPLIED COMPUTING, SAC 2021},
Year = {2021},
Pages = {1102-1105},
Abstract = {Applying machine learning and data mining algorithms over data
   distributed in multiple sources is challenging. One complication is to
   perform data analysis without compromising personal information, which
   is a primary concern in healthcare applications. Another issue involves
   communication overhead incurred from the transfer of raw data from one
   party to others for conducting centralized data mining. In healthcare
   applications, we are particularly interested in running data mining
   algorithms over big data without disclosing sensitive information about
   data subjects due to privacy and legal concerns. In this paper, we
   consider the classification problem and show how the Extremely
   Randomized Trees (ERT) algorithm could be adapted for settings where
   (structured) data is distributed over multiple sources. We propose the
   Privacy-Preserving Distributed ERT approach for privacy-preserving
   utilization of the ERT algorithm in a distributed setting. To the best
   of our knowledge, this is the first application of the ERT algorithm in
   the distributed setting, with privacy consideration (without sharing the
   raw data or intermediate training values), without any loss in
   classification performance.},
Type = {Proceedings Paper},
Affiliation = {Aminifar, A (Corresponding Author), Western Norway Univ Appl Sci, Bergen, Norway.
   Aminifar, Amin; Rabbi, Fazle; Pun, Ka I.; Lamo, Yngve, Western Norway Univ Appl Sci, Bergen, Norway.
   Rabbi, Fazle, Univ Bergen, Bergen, Norway.
   Pun, Ka I., Univ Oslo, Oslo, Norway.},
DOI = {10.1145/3412841.3442110},
Keywords = {Distributed Learning; Extremely Randomized Trees; Privacy-Preserving
   Data Mining; Structured Data},
Author-Email = {amin.aminifar@hvl.no
   fazle.rabbi@hvl.no
   ka.i.pun@hvl.no
   yngve.lamo@hvl.no},
Number-of-Cited-References = {26},
Times-Cited = {12},
