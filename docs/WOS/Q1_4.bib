   Arroyave, Juan Sebastian; Connors, Christopher; Palese, Michael A., Icahn Sch Med Mt Sinai, Dept Urol, New York, NY USA.},
DOI = {10.1089/end.2023.0702},
EarlyAccessDate = {JUL 2024},
Keywords = {artificial intelligence; diet; kidney calculi; risk factors;
   urolithiasis},
Keywords-Plus = {STONE DISEASE; NEURAL-NETWORKS; MANAGEMENT},
Author-Email = {juanfulla@gmail.com},
