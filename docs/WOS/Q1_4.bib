DOI = {10.1007/s40846-018-0411-0},
Keywords = {ECG quality assessment; Nonlinear features; Encoding Lempel-Ziv
   complexity; LS-SVM; Random forest},
Keywords-Plus = {SUPPORT VECTOR MACHINE; SIGNAL QUALITY; DATA FUSION; ALGORITHM;
