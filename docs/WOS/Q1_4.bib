   Abdollahzadeh, Reza, Cent European Univ, Dept Environm Sci \& Policy, Vienna, Austria.
   Dehghan, Aliakbar, Mashhad Univ Med Sci, Social Determinants Hlth Res Ctr, Mashhad, Iran.},
DOI = {10.1038/s41598-025-99432-8},
