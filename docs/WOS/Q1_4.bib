   de Sa, Joaquim Marques, Univ Porto, Dept Eng Elect \& Comp, Fac Eng, Porto, Portugal.
   Santos, Jorge M., Inst Super Engn Inst Politecn Porto, Dept Matemat, Porto, Portugal.},
DOI = {10.1007/978-3-319-11758-4\_32},
Keywords = {Transfer learning; Deep learning; Stacked auto-encoders},
