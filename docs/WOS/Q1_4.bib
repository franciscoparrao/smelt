   Chen, James Ming, Silver Leaf Capital LLC, New York, NY 91324 USA.},
DOI = {10.1007/s11294-021-09815-6},
EarlyAccessDate = {MAR 2021},
Keywords = {Machine learning; Bias-variance tradeoff; Decision trees; Random
   forests; Extra trees; XGBoost; Learning ensembles; Boosting; Support
   vector machines; Neural networks},
Author-Email = {chenjame@law.msu.edu},
