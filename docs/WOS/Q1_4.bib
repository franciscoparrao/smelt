@article{ WOS:001523407300018,
Author = {Takara, Lucas de Azevedo and Mariani, Viviana Cocco and Coelho, Leandro
   dos Santos},
Title = {Novel engine fault diagnosis framework based on machine learning and
   MiniRocket feature extraction using mmulti-correlation feature selection
   and predictive power score},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {293},
Month = {DEC 1},
Abstract = {Engine fault diagnosis is important for ensuring automotive reliability,
   safety, and operational efficiency, yet the dynamic and high-dimensional
   nature of engine sensor data poses challenges for traditional diagnostic
   methods. This study introduces a novel fault diagnosis framework that
   integrates MiniRocket-based feature extraction with machine learning
   classifiers, enhanced by a two-step feature selection process combining
   multi-correlation filtering and Predictive Power Score (PPS). The
   framework is evaluated across four standard driving cycles, Federal Test
   Procedure 75 (FTP-75), Worldwide Harmonized Light Vehicles Test
   Procedure (WLTP), New European Driving Cycle (NEDC), and Extra Urban
   Driving Cycle (EUDC), using five machine learning models: Random Forest,
   Support Vector Machine, eXtreme Gradient Boosting, Extremely Randomized
   Trees, and Extreme Learning Machine (ELM). MiniRocket transforms raw
   sensor signals into high-dimensional features using predefined
   convolutional kernels, while PPS identifies the most informative
   features for classification. Experimental results demonstrate that ELM
   combined with MiniRocket and the top 30 features achieves the highest
   performance, with F1-scores of 0.9759 (FTP-75), 0.9861 (WLTP), 0.9861
   (NEDC), and 0.9883 (EUDC), outperforming the deep learning baselines
   Temporal Convolutional Network and InceptionTimePlus in both accuracy
   and computational efficiency. Visualization via t-SNE reveals distinct
   class separability, particularly in NEDC and EUDC, though challenges
   remain in FTP-75 and WLTP due to transient-rich conditions. The proposed
   framework offers a robust, scalable, and efficient solution for engine
   fault diagnosis, with MiniRocket and ELM achieving superior performance
   while reducing training time by approximately 21x compared to deep
   learning models.},
Type = {Article},
Affiliation = {Takara, LD (Corresponding Author), Fed Univ Parana UFPR, Grad Program Elect Engn PPGEE, Curitiba, PR, Brazil.
   Takara, Lucas de Azevedo; Coelho, Leandro dos Santos, Fed Univ Parana UFPR, Grad Program Elect Engn PPGEE, Curitiba, PR, Brazil.
   Mariani, Viviana Cocco, Fed Univ Parana UFPR, Grad Program Mech Engn PGMec, Curitiba, PR, Brazil.
   Mariani, Viviana Cocco; Coelho, Leandro dos Santos, Fed Univ Parana UFPR, Dept Elect Engn DELT, Curitiba, PR, Brazil.},
DOI = {10.1016/j.eswa.2025.128662},
EarlyAccessDate = {JUN 2025},
Article-Number = {128662},
Keywords = {Fault diagnosis; Time series classification; Feature extraction;
   MiniRocket; Machine learning; Extreme learning machine},
Keywords-Plus = {DECISION TREE; ALGORITHMS},
Author-Email = {lucastakara2@gmail.com
