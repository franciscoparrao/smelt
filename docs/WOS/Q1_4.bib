   Shi, Zhou, Minist Agr, Key Lab Spect Sensing, Hangzhou 310058, Peoples R China.
   Huang, Yuanfang, China Agr Univ, Coll Land Sci \& Technol, Beijing 100193, Peoples R China.},
DOI = {10.3390/rs15205033},
