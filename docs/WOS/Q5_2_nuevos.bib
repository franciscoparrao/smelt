Unique-ID = {WOS:001639153100001},
}

@article{ WOS:001634670300007,
Author = {Zhang, Rui and Song, Caixia and Zhang, Zichen and Xie, Jinbao and Chen,
   Tianyu and Xu, Tong},
Title = {Machine learning for soil moisture analysis: a survey and emerging
   perspectives},
Journal = {INTERNATIONAL JOURNAL OF DATA SCIENCE AND ANALYTICS},
Year = {2025},
Volume = {21},
Number = {1},
Month = {DEC 9},
Abstract = {Soil moisture, the amount of water stored in the soil, is a critical
   factor influencing agricultural productivity, ecosystem health, and
   land-atmosphere interactions. However, its spatial and temporal
   variability is highly nonlinear and scale-dependent, making accurate
   estimation and prediction a persistent challenge. Traditional physically
   based and empirical models often require extensive parameterization and
   struggle to capture large-scale heterogeneity. In contrast, recent
   advances in machine learning (ML) offer adaptive, data-driven approaches
   that excel at modeling complex interactions between soil properties,
   vegetation, and meteorological variables. This review presents a
   comprehensive overview of ML-based soil moisture modeling, focusing on
   key methodological advancements, algorithmic classifications, and
   notable applications across agriculture, hydrology, and climate science.
   We categorize existing models into time-series, integrated, deep
   learning, and nonlinear regression frameworks and discuss their
   strengths, data sources, and limitations. Additionally, we explore
   emerging research directions, including multimodal data fusion,
   physics-informed and explainable ML, uncertainty quantification, and
   transfer learning for cross-climatic zone applications. Finally, the
   review outlines the future potential of next-generation, physically
   consistent, and interpretable ML models to improve soil moisture
   predictions and advance environmental understanding.},
Type = {Review},
Affiliation = {Song, CX (Corresponding Author), Qingdao Agr Univ, Coll Sci \& Informat, Qingdao 266109, Shandong, Peoples R China.
   Zhang, Rui; Song, Caixia; Zhang, Zichen; Xie, Jinbao; Chen, Tianyu; Xu, Tong, Qingdao Agr Univ, Coll Sci \& Informat, Qingdao 266109, Shandong, Peoples R China.},
DOI = {10.1007/s41060-025-00977-8},
Article-Number = {66},
Keywords = {Soil moisture estimation; Machine learning; Remote sensing; Scale
   effects; Physics-informed learning; Explainable AI; Causal modeling;
   Environmental prediction},
Keywords-Plus = {AREAS},
Author-Email = {cassiesong@qau.edu.cn},
Number-of-Cited-References = {135},
Times-Cited = {0},
Unique-ID = {WOS:001634670300007},
}

@article{ WOS:001634644500002,
Author = {Bhargavi, Kempakkagari and Roy, Dipankar and Nakkeeran, G. and Reddy,
   Narala Gangadhara},
Title = {A review of remote sensing and GIS applications in flood monitoring and
   management},
Journal = {SADHANA-ACADEMY PROCEEDINGS IN ENGINEERING SCIENCES},
Year = {2025},
Volume = {50},
Number = {4},
Month = {DEC 9},
Abstract = {Floods are becoming increasingly frequent and severe due to climate
   change and rapid urbanization, posing significant threats to lives,
   infrastructure and economies. This review synthesizes recent
   advancements in Remote Sensing (RS) and Geographic Information System
   (GIS) technologies for comprehensive flood monitoring, mapping and
   management. A bibliometric and thematic analysis of 6154 publications
   from 2000 to 2023 was conducted using VOS viewer and Scopus-based
   filtering. The study focuses on RS platforms such as Landsat, Synthetic
   Aperture Radar (SAR) and Sentinel-1, as well as the integration of
   GIS-based hydrological models and emerging technologies. Findings reveal
   that over 75\% of studies published after 2020 integrate SAR data with
   machine learning techniques for improved flood detection, while
   limitations persist with Landsat's 30-metre resolution in urban areas.
   Light Detection and Ranging (LiDAR) and Sentinel-1 offer enhanced
   spatial accuracy, yet only 15\% of studies address real-time forecasting
   challenges in data-scarce regions. Notably, SAR-based flood mapping
   exceeds 90\% accuracy in 68\% of analysed studies. This review
   highlights a critical research gap in integrating social vulnerability
   metrics and crowd-sourced data for rapid flood response. It recommends
   future work to prioritize the fusion of UAVs, IoT-based sensors, and
   artificial intelligence to develop real-time, sub-hourly flood alert
   systems, especially for densely populated megacities and under-resourced
   regions.},
