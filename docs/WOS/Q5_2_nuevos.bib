@article{ WOS:001717553500004,
Author = {Nguyen, Phuong D. M. and Nguyen, Duy A. and Nguyen, Thanh T. N.},
Title = {Adaptive Modeling for Air Quality: A Continual Learning Framework for
   PM2.5 Estimation in Vietnam},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Fine particulate matter (PM2.5) poses severe health risks, particularly
   in rapidly developing and heavily polluted regions such as Vietnam,
   where sparse monitoring networks and evolving environmental conditions
   challenge accurate air quality estimation. To bridge this data gap,
   large-scale pollution maps are typically generated using machine
   learning or statistical models. However, the widely adopted
   ``one-off{''} training paradigm, where a single static model is trained
   on all available historical data, struggles with data drift, is
   computationally inefficient to update, and generalizes poorly to yearly
   updated data and station variation. In this study, we investigate
   continual learning (CL) as an adaptive framework to overcome these
   limitations. We use multisource data, including ground measurements,
   meteorological data, land use, emissions, and satellite products, to
   implement geoiLSTM-based knowledge-transfer models. We benchmark against
   two representative one-off baselines that bracket common practice, an
   all-years geoiLSTM and a current-year geoiLSTM, under two evaluation
   regimes: 1) tenfold cross-validation (CV) to assess temporal accuracy
   and 2) spatial CV (leave -location-out) to test generalization to unseen
   areas. The results show that our CL approach significantly outperforms
   traditional models, especially in generalizing to unseen areas. Under
   tenfold CV, geoiLSTM\_MOF achieves comparable accuracy to all-years
   training (R approximate to 0.88 , RMSE approximate to 10.10 mu g/m(3))
   while requiring only incremental updates. Under the more challenging
   spatial tenfold CV (SCV) setting, geoiLSTM\_MOF substantially
   outperforms baselines, achieving a 26\%-70\% improvement in correlation
   (R = 0.65), 14\%-20\% lower RMSE ( 17.02 mu g/m(3)), and 41\%-64\%
   reduced bias. These findings highlight CL as a promising approach for
   robust PM(2.5 )estimation in data-scarce, nonstationary environments,
   enabling timely and accurate air quality assessments for public health
   and policy.},
Type = {Article},
Affiliation = {Nguyen, TTN (Corresponding Author), Vietnam Natl Univ Hanoi, Univ Engn \& Technol, Hanoi 100000, Vietnam.
   Nguyen, Phuong D. M.; Nguyen, Duy A.; Nguyen, Thanh T. N., Vietnam Natl Univ Hanoi, Univ Engn \& Technol, Hanoi 100000, Vietnam.},
DOI = {10.1109/TGRS.2026.3668935},
Article-Number = {4104311},
Keywords = {Data models; Atmospheric modeling; Spatial resolution; Monitoring;
   Accuracy; Urban areas; Training; Computational modeling; Adaptation
   models; Pollution measurement; Continual learning (CL); machine
   learning; particulate matter (PM2.5); remote sensing},
Author-Email = {thanhntn@vnu.edu.vn},
Number-of-Cited-References = {27},
Times-Cited = {0},
Unique-ID = {WOS:001717553500004},
}

@article{ WOS:001719543100011,
Author = {Perez-Carrasco, Manuel and Nasr, Maya and Roche, Sebastien and Miller,
   Christopher Chan and Zhang, Zhan and Park, Core Francisco and Walker,
   Eleanor and Garraffo, Cecilia and Finkbeiner, Douglas and Ayvazov, Sasha
   and Franklin, Jonathan E. and Luo, Bingkun and Liu, Xiong and Gautam,
   Ritesh and Wofsy, Steven C.},
Title = {Deep Learning for Clouds and Cloud Shadow Segmentation in Methane
   Satellite and Airborne Imaging Spectroscopy},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {cloud and cloud shadow detection is a critical prerequisite for accurate
   retrieval of concentrations of atmospheric methane (CH4) or other trace
   gases in hyperspectral remote sensing. This challenge is especially
   pertinent for MethaneSAT, a satellite mission launched in March 2024, to
   fill a significant data gap in terms of resolution, precision, and swath
   between coarse-resolution global mappers and fine-scale point-source
   imagers of methane, and for its airborne companion mission, MethaneAIR.
   MethaneSAT delivers hyperspectral data at an intermediate spatial
   resolution (similar to 100 \& times; 400 m), whereas MethaneAIR provides
   even finer resolution (similar to 25 m), enabling the development of
   highly detailed maps of concentrations that enable quantification of
   both the sources and rates of emissions. In this study, we use machine
   learning methods to address the cloud and cloud shadow detection problem
   for sensors with these high spatial resolutions. Cloud and cloud shadows
   in remote sensing data need to be effectively screened out as they bias
   methane retrievals in remote sensing imagery and impact the
   quantification of emissions. We deploy and evaluate conventional
   techniques-including iterative logistic regression (ILR) and multilayer
   perceptron (MLP)-with advanced deep learning architectures, namely,
   U-Net and a spectral channel attention network (SCAN) method. Our
   results show that conventional methods struggle with spatial coherence
   and boundary definition, affecting the detection of clouds and cloud
   shadows. Deep learning models substantially improve detection quality:
   U-Net performs best in preserving spatial structure, while SCAN excels
   at capturing fine boundary details. Notably, SCAN surpasses U-Net on
   MethaneSAT data, underscoring the benefits of incorporating spectral
   attention for satellite-specific features. In addition, we combine the
   predictions of both U-Net and SCAN through a convolutional neural
   network (CNN). This ensemble method achieves the best performance on
   both MethaneAIR (F1: 78.50 +/- 3.08\%) and MethaneSAT (F1: 78.80 +/-
   1.28\%) datasets, representing improvements of 2\% and 10\% over
   conventional methods (U-Net: 78.50 +/- 3.08\% and 68.56 +/- 0.36\% F1,
   respectively), while maintaining efficient inference (4.1 ms per 1000
   km(2)). This in-depth assessment of various disparate machine learning
   techniques, as applied to MethaneSAT and MethaneAIR imaging
   spectroscopic data at varying spatial resolutions, demonstrates the
   strengths and effectiveness of advanced deep learning architectures in
   providing robust, scalable solutions for clouds and cloud shadow
   screening toward enhancing methane emission quantification capacity of
   existing and next-generation hyperspectral missions. Our data and code
   are publicly available at: https://doi.org/10.7910/DVN/IKLZOJ},
Type = {Article},
Affiliation = {Pérez-Carrasco, M (Corresponding Author), Univ Concepcion, Ctr Data \& AI, Concepcion 4030000, Bio Bio, Chile.
