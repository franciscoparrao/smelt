   Gao, Fenghua, Anhui Prov Ctr Dis Control \& Prevent, Hefei 230601, Anhui, Peoples R China.},
DOI = {10.1016/j.actatropica.2026.108044},
Article-Number = {108044},
Keywords = {Schistosomiasis; Snail habitat mapping; Deep learning; Semi-supervised
   learning; Ensemble modeling},
Author-Email = {honglu@fudan.edu.cn
   ahxfbb@126.com
   huyi@fudan.edu.cn},
Number-of-Cited-References = {69},
