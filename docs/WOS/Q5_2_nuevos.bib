   Muthusamy, Suresh, Kongu Engn Coll Autonomous, Dept Elect \& Elect Engn, Erode, Tamil Nadu, India.},
DOI = {10.1007/s11831-025-10466-7},
EarlyAccessDate = {JAN 2026},
Keywords-Plus = {LAND-COVER; IMAGERY; CLASSIFICATION; TRENDS; CROP},
