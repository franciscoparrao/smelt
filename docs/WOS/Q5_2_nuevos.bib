}

@article{ WOS:001552180900001,
Author = {Tian, Hongzhen and Zhang, Zheng and Liu, Qinping and Yang, Mengmeng and
   Wei, Na},
Title = {A method for automatically extracting long-term and large-scale land use
   and land cover information},
Journal = {EUROPEAN JOURNAL OF REMOTE SENSING},
Year = {2025},
Volume = {58},
Number = {1},
Month = {DEC 31},
Abstract = {Accurate and comprehensive Land Use and Land Cover (LULC) information is
   essential for applications such as urban planning and crop monitoring.
   However, traditional manual sampling is labor-intensive and
   time-consuming. This study presents an automated approach, implemented
   on the Google Earth Engine platform, to extract LULC information by
   identifying stable areas where land use types remain unchanged over the
   years. Long-term sample points were collected within these areas and
   used with Landsat imagery and a Random Forest classifier to produce
   annual maps from 1987 to 2022 for four regions: Arizona (USA),
   central-western Brazil, the Beijing-Tianjin-Hebei region (China), and
   Portugal. Improvements in imagery quality and sample quantity led to
   steadily increasing classification accuracy over time. After
   post-processing and validation through visual interpretation, the KAPPA
   and OA values for the study areas ranged from 0.79 to 0.87 and 0.82 to
   0.89, respectively. These metrics indicate a high level of
   classification accuracy, comparable to the claimed overall accuracy of
   other regional-scale LULC products. The results demonstrate that the
   automated method can extract long-term LULC information with sufficient
   coverage from remote sensing imagery on a global scale, significantly
   saving researchers time and manpower costs.},
Type = {Article},
Affiliation = {Liu, QP (Corresponding Author), Tiangong Univ, Sch Econ \& Management, Tianjin 300387, Peoples R China.
   Tian, Hongzhen; Zhang, Zheng; Liu, Qinping; Wei, Na, Tiangong Univ, Sch Econ \& Management, Tianjin 300387, Peoples R China.
   Yang, Mengmeng, Taishan Univ, Sch Informat Sci \& Technol, Tai An, Peoples R China.},
DOI = {10.1080/22797254.2025.2545341},
Article-Number = {2545341},
Keywords = {Land use and land cover; Google Earth Engine; sampling; Landsat;
   automated classification; stable area},
Keywords-Plus = {GOOGLE EARTH ENGINE; RANDOM FOREST; CLASSIFICATION; DYNAMICS; IMAGERY;
   TRENDS},
Author-Email = {liuqinping@tiangong.edu.cn},
Number-of-Cited-References = {44},
Times-Cited = {2},
Unique-ID = {WOS:001552180900001},
}

@article{ WOS:001552361600001,
Author = {Lv, Qianwen and Qi, Zhixin and Li, Haibo and Song, Wenxuan and Huang, Di
   and Ding, Zihao and Shi, Qian},
Title = {Evaluating The potential of multi-source remote sensing and urban big
   data for urban land use classification},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2025},
Volume = {18},
Number = {1},
Month = {DEC 31},
Abstract = {Accurate urban land use classification is critical for urban planning
   but is often hindered by spectral and morphological similarities
   inherent in single-source remote sensing imagery. This study provides a
   systematic evaluation of how the integration of multi-source remote
   sensing imagery and urban big data enhances the accuracy of urban land
   use classification. We utilized GF-1 high-resolution (HR), Sentinel-1
   SAR, Sentinel-2 multispectral, and Luojia-1 nighttime light (NTL)
   imagery, along with Points of Interest (POI), Tencent location-based
   data (LocBigData), and electricity consumption records. An object-based
   random forest model was employed to classify 12 urban land use
   categories. The data fusion approach achieved an overall accuracy of
   92.17\% and a Kappa coefficient of 0.91, significantly outperforming the
   GF-1 baseline (82.76\%, Kappa 0.80). Each data source made distinct
   contributions: Sentinel-2 enhanced grassland discrimination through
   red-edge spectral bands; Sentinel-1 SAR effectively distinguished water
   bodies from buildings due to surface roughness sensitivity; LocBigData
   captured spatiotemporal population patterns to distinguish commercial
   and residential areas; POI data provided semantic context to identify
   residential, educational, and industrial zones; and electricity
   consumption patterns highlighted commercial activity. These findings
   demonstrate the complementary strengths of diverse data sources and
   provide a foundation for optimizing data fusion strategies in urban land
   use mapping.},
Type = {Article},
Affiliation = {Qi, ZX (Corresponding Author), Sun Yat Sen Univ, Sch Geog \& Planning, Guangzhou 510006, Peoples R China.
   Lv, Qianwen; Qi, Zhixin; Song, Wenxuan; Huang, Di; Ding, Zihao; Shi, Qian, Sun Yat Sen Univ, Sch Geog \& Planning, Guangzhou 510006, Peoples R China.
   Li, Haibo, Dongguan Nat Resources Technol Ctr, Dongguan, Peoples R China.
   Shi, Qian, Guangdong Prov Key Lab Urbanizat \& Geosimulat, Guangzhou, Peoples R China.},
DOI = {10.1080/17538947.2025.2546519},
Article-Number = {2546519},
Keywords = {Urban land use; data fusion; remote sensing; urban big data},
Keywords-Plus = {IMAGE TIME-SERIES; COVER CLASSIFICATION; RANDOM FOREST; FUTURE;
   URBANIZATION; EXPANSION; CITIES; SCALE},
Author-Email = {qizhixin@mail.sysu.edu.cn},
Number-of-Cited-References = {65},
