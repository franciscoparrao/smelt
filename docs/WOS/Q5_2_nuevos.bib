   Adam, Mohammed Sani, Univ Kebangsaan Malaysia, Fac Engn \& Built Environm, Dept Elect Elect \& Syst Engn, Ukm Bangi 43600, Selangor, Malaysia.},
DOI = {10.1016/j.icte.2026.01.002},
