   Arabameri, Alireza, Tarbiat Modares Univ, Dept Geomorphol, Tehran 1411713116, Iran.
   Santosh, M., China Univ Geosci Beijing, Sch Earth Sci \& Resources, 29 Xueyuan Rd, Beijing 100083, Peoples R China.
   Santosh, M., Yonsei Univ, Yonsei Frontier Lab, Seoul, South Korea.
   Naqvi, Hasan Raja; Ramiz, Mohd, Jamia Millia Islamia, Fac Sci, Dept Geog, New Delhi 110025, India.},
DOI = {10.1016/j.asr.2025.10.047},
EarlyAccessDate = {DEC 2025},
