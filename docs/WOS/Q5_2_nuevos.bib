@article{ WOS:001701464300001,
Author = {Sierra, Sergio and Ramo, Ruben and Padilla, Marc and Cobo, Adolfo},
Title = {Assessing the Impact of LiDAR Density and Input Features on Forest
   Canopy Height Estimation Through XGBoost, CNN, and CNN plus Transformer
   Approaches},
Journal = {REMOTE SENSING},
Year = {2026},
Volume = {18},
Number = {4},
Month = {FEB 13},
Abstract = {Highlights What are the main findings? CNN-based architectures
   consistently outperform classical Machine Learning for forest canopy
   height estimation, with hybrid CNN-Transformer models achieving the
   highest accuracy (MAE 3.37, R2 of 0.66) in high-density LiDAR scenarios.
   Model performance degrades significantly when reference LiDAR density
   drops from 5 to 1-2 points/m2, likely due to the reduced ability of
   sparse reference data to capture canopy peaks and structure, though deep
   learning models remain more robust than traditional methods. What are
   the implications of the main findings? The superior performance of
   hybrid deep learning models supports their operational use for
   generating accurate regional canopy height maps using open-access
   Sentinel-1 and Sentinel-2 data, even in areas without wall-to-wall LiDAR
   coverage. Sensitivity analysis results guide cost-effective forest
   monitoring strategies, suggesting that future workflows should
   prioritize higher-density LiDAR for training while leveraging deep
   learning to handle heterogeneous data quality across large
   scales.Highlights What are the main findings? CNN-based architectures
   consistently outperform classical Machine Learning for forest canopy
   height estimation, with hybrid CNN-Transformer models achieving the
   highest accuracy (MAE 3.37, R2 of 0.66) in high-density LiDAR scenarios.
   Model performance degrades significantly when reference LiDAR density
   drops from 5 to 1-2 points/m2, likely due to the reduced ability of
   sparse reference data to capture canopy peaks and structure, though deep
   learning models remain more robust than traditional methods. What are
   the implications of the main findings? The superior performance of
   hybrid deep learning models supports their operational use for
   generating accurate regional canopy height maps using open-access
   Sentinel-1 and Sentinel-2 data, even in areas without wall-to-wall LiDAR
   coverage. Sensitivity analysis results guide cost-effective forest
   monitoring strategies, suggesting that future workflows should
   prioritize higher-density LiDAR for training while leveraging deep
   learning to handle heterogeneous data quality across large
   scales.Abstract Accurate estimation of forest Canopy Height Model (CHM)
   is essential for understanding ecosystem structure, biomass, and carbon
   dynamics. Machine learning (ML) and deep learning (DL) models have shown
   strong potential when trained using LiDAR-derived (Light Detection and
   Ranging) canopy heights as reference data. However, the influence of
   LiDAR point density on model performance remains poorly understood. This
   study systematically evaluates three modeling frameworks, Extreme
   Gradient Boosting (XGBoost), Convolutional Neural Networks (CNN) and
   hybrid CNN-Transformer architectures, for predicting CHM across multiple
   regions in Spain, using LiDAR data with varying point densities (1-5
   points/m2) from the Plan Nacional de Ortofotograf \& iacute;a A \&
   eacute;rea (PNOA). Models were trained using multiple sources of remote
   sensing data: Sentinel-2 spectral bands (visible and near-infrared bands
   at 10 m) and Sentinel-1 VH backscatter and topographic variables (slope
   and elevation). Model performance was assessed in terms of predictive
   accuracy, generalization capacity and sensitivity to LiDAR point density
   data. Results show that CNN-based approaches outperform classical ML
   across all datasets, and that integrating Transformer modules further
   improves performance particularly in areas with higher LiDAR density.
   The best results were achieved on the dataset with higher point density
   (5 points/m2), where the CNN + Transformer model reached a Mean Absolute
   Error (MAE) of 3.37 +/- 0.1 m and an R2 of 0.66 +/- 0.02. Lower-density
   LiDAR datasets degraded the accuracy for all methods. These findings
   highlight that both model architecture and LiDAR point density
   critically influence CHM estimation. The results provide practical
   guidance for designing large-scale structural mapping workflows in
   regions with heterogeneous LiDAR coverage, helping to support forest
   management, carbon accounting and environmental decision-making.},
Type = {Article},
Affiliation = {Sierra, S (Corresponding Author), Complutum Tecnol Informac Geograf COMPLUTIG, Alcala De Henares 28801, Spain.
   Sierra, S (Corresponding Author), Univ Cantabria, Photon Engn Grp, Santander 39005, Spain.
   Sierra, Sergio; Padilla, Marc, Complutum Tecnol Informac Geograf COMPLUTIG, Alcala De Henares 28801, Spain.
   Sierra, Sergio; Cobo, Adolfo, Univ Cantabria, Photon Engn Grp, Santander 39005, Spain.
   Ramo, Ruben, Indra Space, Carr Loeches 9, Torrejon De Ardoz 28850, Spain.
   Cobo, Adolfo, Inst Invest Sanitaria Valdecilla IDIVAL, Santander 39011, Spain.
   Cobo, Adolfo, Inst Salud Carlos III, CIBER Bioingn Biomat \& Nanomed CIBER BBN, Madrid 28029, Spain.},
DOI = {10.3390/rs18040584},
Article-Number = {584},
Keywords = {canopy height model; LiDAR; machine learning; deep learning;
   convolutional neural networks; transformers},
Keywords-Plus = {TREE HEIGHT; VEGETATION; CARBON; WATER},
Author-Email = {sergio.sierra@complutig.com
