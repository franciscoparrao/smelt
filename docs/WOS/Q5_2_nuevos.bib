   josef.taher@maanmittauslaitos.fi
   harri.kaartinen@nls.fi
   teemu.hakala@nls.fi
   kirsi.karila@nls.fi
   leena.matikainen@nls.fi
   marjut.turtiainen@arktisetaromit.fi
   antero.kukko@nls.fi
