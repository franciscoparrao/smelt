Keywords = {Climate change; Fragmentation; Machine learning; Remote sensing},
Keywords-Plus = {ABOVEGROUND BIOMASS; CLIMATE-CHANGE; GENETIC ALGORITHM; STORM DAMAGE;
   DUST STORMS; REMOTE; FRAGMENTATION; CLASSIFICATION; REGION;
   SUSCEPTIBILITY},
