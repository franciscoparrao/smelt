   Zhou, Huijun; Zhang, Jing, Capital Normal Univ, Key Lab Dimens Informat Acquisit \& Applicat 3, Beijing, Peoples R China.
   Zhou, Huijun; Zhang, Jing, Capital Normal Univ, Natl Expt Teaching Ctr Urban Environm Proc \& Digit, Beijing, Peoples R China.},
DOI = {10.1080/17538947.2025.2611487},
Article-Number = {2611487},
Keywords = {Hypergraph neural networks; higher-order Markov inference; urban land
   use; regional heterogeneity; geographic artificial intelligence},
Keywords-Plus = {SCENE CLASSIFICATION; MODEL},
Author-Email = {zhangjings@mail.cnu.edu.cn},
Number-of-Cited-References = {103},
Times-Cited = {0},
Unique-ID = {WOS:001656807000001},
}

@article{ WOS:001715694800001,
Author = {Mashaire, Patience and Basupi, Lenyeletse Vincent and Tsidu, Gizaw
   Mengistu},
Title = {Spatiotemporal patterns of forest fires in the Eastern Okavango
   Panhandle, Botswana: Implications for vegetation cover and forest
   management},
Journal = {FOREST ECOLOGY AND MANAGEMENT},
Year = {2026},
Volume = {610},
Month = {JUN 15},
Abstract = {Fire regimes in African savannas are changing under the combined
   influence of climate variability and human activity, yet long-term,
   integrated assessments remain scarce in critical regions such as the
   Eastern Okavango Panhandle, Botswana, part of the globally significant
   Okavango Delta. This study provides a 22-year (2003-2024) analysis of
   fire dynamics using Moderate Resolution Imaging Spectroradiometer
   (MODIS) burned area data, rainfall records, and vegetation
   classifications. We assessed temporal trends, climatic drivers, spatial
   patterns, and vegetation-specific fire responses, and evaluated
   implications for fire management planning. Results indicate a
   significant decline in rainfall, while annual burned area showed no
   long-term trend, reflecting a fuel-limited system (r = 0.619 with
   antecedent rainfall). Fires were concentrated in central-southeastern
   grasslands and woodlands, driven by the interaction of climate-driven
   fuel availability and recurrent human ignitions, including agricultural
   burning in communal areas (NG11) and poaching-related fires in remote
   wildlife zones (NG13). Fire regimes in the region are shaped primarily
   by grass-layer fuel continuity and human ignitions, rather than by
   canopy traits or species differences. Vegetation responses show that
   dominant Woodland types (Miombo, Mopane, Baikiaea, Burkea) and open
   grasslands accounted for over 78\% of total burned area, whereas
   seasonally flooded and sparsely vegetated areas acted as natural fire
   buffers. Rapid post-fire recovery of grasses and woody vegetation
   sustains recurrent burning and reinforces fire-prone conditions. These
   findings highlight the need for proactive, risk-based fire management
   that addresses both fuel continuity and ignition pressure. By addressing
   gaps identified in the Okavango Delta Management Plan (2021-2028), this
   study provides a scientific foundation for targeted, adaptive fire
   management in this ecologically important landscape.},
Type = {Article},
Affiliation = {Mashaire, P (Corresponding Author), Botswana Int Univ Sci \& Technol, Dept Sustainable Nat Resources, Private Bag 16, Palapye, Botswana.
   Mashaire, Patience; Basupi, Lenyeletse Vincent; Tsidu, Gizaw Mengistu, Botswana Int Univ Sci \& Technol, Dept Sustainable Nat Resources, Private Bag 16, Palapye, Botswana.},
DOI = {10.1016/j.foreco.2026.123679},
Article-Number = {123679},
Keywords = {African Savannah; MODIS data; Random Forest; Okavango Delta; Remote
   sensing},
Keywords-Plus = {CLASSIFICATION; PRECIPITATION; CONSEQUENCES; DELTA},
Author-Email = {mp15000284@biust.ac.bw
   basupiv@biust.ac.bw
   mengistug@biust.ac.bw},
Number-of-Cited-References = {77},
Times-Cited = {0},
Unique-ID = {WOS:001715694800001},
}

@article{ WOS:001707945300004,
Author = {Bedi, Shine and Samal, Ashok and Scott, Stephen},
Title = {Modeling social unrest: The geographical influence on social unrest
   prediction},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {316},
Month = {JUN 15},
Abstract = {Social unrest, a collective expression of discontent, is a salient
   indicator of deeper societal problems. Its prediction, especially at
   higher spatial resolutions, is challenging due to its complex dependence
   on socioeconomic, political, and environmental factors. Accurately
   forecasting social unrest will provide a better understanding of its
   drivers and help develop mitigation strategies. This study evaluates the
   role of geographic context in predicting social unrest by proposing two
   different and novel approaches to predict social unrest using machine
   learning techniques: (a) a geographic context-independent model using
   eXtreme Gradient Boosting (XGBoost), which predicts unrest based on
   features at a single point, and (b) a geographic context-dependent model
   using a Convolutional Neural Network (CNN), which incorporates features
   from the surrounding geospatial neighborhood. The models use remote
   sensing imagery and rasters of geographic, socio-demographic, and
   economic variables (and their proxies). In addition, the study presents
   a detailed and unique analysis to identify the significance of the
   features in predicting social unrest using Shapley values. Another key
   innovation of this research is the estimation of the confidence in the
   models' predictions using a Monte Carlo dropout technique. This provides
   valuable insights into the model's reliability and uncertainty in
   prediction as a function of geographic space. Results show that VIIRS
   nighttime light and land use are among the significant predictors of
   social unrest. Furthermore, prediction performance comparison shows that
   context-dependent CNNs outperform the context-independent XGBoost model
   in accuracy and F1 scores in both binary and multiclass classification
   tasks. The findings demonstrate the potential of machine learning in
   accurately understanding complex social science processes.},
Type = {Article},
Affiliation = {Bedi, S (Corresponding Author), Univ Nebraska Lincoln, Sch Comp, 256 Avery Hall, Lincoln, NE 68588 USA.
   Bedi, Shine; Samal, Ashok; Scott, Stephen, Univ Nebraska Lincoln, Sch Comp, 256 Avery Hall, Lincoln, NE 68588 USA.},
DOI = {10.1016/j.eswa.2026.131640},
Article-Number = {131640},
Keywords = {Social unrest; Geospatial modeling; Convolutional neural networks (CNN);
   eXtreme gradient boosting (XGBoost); Confidence estimation; Data-driven
   policy making},
Keywords-Plus = {SATELLITE IMAGERY; NIGHTTIME LIGHTS; SCIENCE; CLASSIFICATION;
   OPPORTUNITIES; INEQUALITY; CONFLICT; SPACE},
