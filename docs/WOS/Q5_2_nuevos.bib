@article{ WOS:001654585900001,
Author = {Karimi, Neamat and Torabi, Omid},
Title = {Remote sensing-based bathymetry mapping in shallow lakes: comparative
   analysis of Sentinel-2 and Landsat-8 imagery integrated with machine
   learning techniques},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2026},
Volume = {77},
Number = {2},
Pages = {1439-1463},
Month = {JAN 15},
Abstract = {Accurate bathymetric mapping of shallow inland waters is critical for
   water resource management, sediment budgeting, and hydrodynamic
   modeling, yet repeated in-situ surveys are costly and often impractical.
   This study assesses the potential of medium-resolution multispectral
   satellite imagery (Sentinel-2 and Landsat-8) integrated with machine
   learning to generate high-quality bathymetry for Chah Nimeh No. 3
   reservoir in southeastern Iran. Four widely used algorithms (Multi-Layer
   Perceptron (MLP), Random Forest (RF), Support Vector Regression (SVR),
   and XGBoost) were trained and evaluated using 52,000 in-situ water depth
   measurements collected via a remotely operated hydrographic survey
   vehicle. The MLP model achieved the highest accuracy, with Landsat-8
   inputs yielding RMSE approximate to 0.82 m (R-2 approximate to 0.97) and
   Sentinel-2 inputs RMSE approximate to 1.10 m (R-2 approximate to 0.95),
   and was selected for sensor performance comparison. Hyperparameters,
   including the number of hidden layers, neurons per layer, and learning
   rate, were optimized via systematic grid search, identifying
   sensor-specific configurations (Sentinel-2: 9 layers, 16 neurons/layer,
   LR = 1e-3; Landsat-8: 11 layers, 16 neurons/layer, LR = 1e-4). Both
   sensors demonstrated strong predictive capability; however, the
   Landsat-8 model incorporating all optical and thermal infrared bands
   outperformed Sentinel-2. Landsat-8 achieved MAD = 0.50 m, RMSE = 0.78 m,
   and MAPE = 9.6 \%, while Sentinel-2 produced MAD = 0.58 m, RMSE = 0.88
   m, and MAPE = 10.4 \% (test data: 30 \% of total in-situ points). Direct
   spatial comparison of final bathymetric products showed a high
   coefficient of determination (R-2 = 0.90) and minimal mean difference
   (+0.11 m, STD = 1.7 m), indicating strong agreement between the two
   datasets. Correlation analysis revealed unexpectedly strong associations
   between Landsat-8 thermal bands and depth (Band 10: R-2 = 0.52; Band 11:
   R-2 = 0.53). To quantify their contribution, two MLP models were
   compared: one using all Landsat-8 bands and another excluding thermal
   bands. Thermal inclusion improved performance substantially (R2 = 0.98,
   RMSE = 0.78 m) relative to the thermal-excluded model (R-2 = 0.93, RMSE
   = 1.30 m), representing a 67 \% increase in RMSE without thermal data.
   This enhancement likely reflects depth-linked thermal patterns driven by
   differential heat capacity, sediment heating in shallow zones, and
   depth-dependent sediment-water heat exchanges. These findings
   demonstrate that integrating freely available medium-resolution
   multispectral and thermal imagery with MLP can yield sub-metre
   bathymetric products (<5\% error relative to an 18 m depth range in Chah
   Nimeh reservoir) in optically clear shallow lakes, providing a
   cost-effective and operationally valuable tool for monitoring and
   managing data-sparse inland reservoirs. (c) 2025 COSPAR. Published by
   Elsevier B.V. All rights are reserved, including those for text and data
   mining, AI training, and similar technologies.},
Type = {Article},
Affiliation = {Karimi, N (Corresponding Author), Water Res Inst, Dept Water Resources Study \& Res, Tehran, Iran.
   Karimi, Neamat; Torabi, Omid, Water Res Inst, Dept Water Resources Study \& Res, Tehran, Iran.},
DOI = {10.1016/j.asr.2025.10.028},
EarlyAccessDate = {DEC 2025},
Keywords = {Bathymetry; Machine learning; Multi-Layer Perceptron (MLP); Landsat-8;
   Sentinel-2},
Keywords-Plus = {TEMPERATURE},
Author-Email = {n.karimi@wri.ac.ir},
Number-of-Cited-References = {73},
Times-Cited = {0},
Unique-ID = {WOS:001654585900001},
}

@article{ WOS:001654792000001,
Author = {Chen, Xiaohui and Arabameri, Alireza and Santosh, M. and Naqvi, Hasan
   Raja and Ramiz, Mohd},
Title = {Gully erosion prediction using weight of evidence and advanced machine
   learning models},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2026},
Volume = {77},
Number = {2},
Pages = {1570-1592},
Month = {JAN 15},
Abstract = {Spatial modelling and susceptibility mapping of soil erosion are crucial
   for planning effective control strategies and land-use changes to
   mitigate future degradation and aid soil conservation. In this study we
   employed an ensemble statistical data-driven based prediction of gully
   erosion (GUE) susceptibility in Central Iran using the Weight of
   Evidence (WOE) method combined with four models: Stochastic Gradient
   Descent (SGD), Entropy (ENT), Multi-layer Perceptron (MLP), and Rotation
   Forest (RF). We used, 424 gully erosion locations, with 292 samples used
   to train the models and the rest for validation. Sixteen conditioning
   factors were considered in predicting gully erosion susceptibility
   zones. For accuracy assessment, the ROC curve was used, and the results
   show that the RF-WOE surpassed all other ensemble models with an
   accuracy of 93 \%. This was followed by the SGD-WOE model at 92.6 \%.
   Conversely, WOE model alone had the lowest accuracy at 89 \%. Meanwhile,
   the MLP-WOE and ENT-WOE models showed accuracies of and 92.0 \%,
   respectively. According to the RF-WOE model, about 40 \% and 47.17 \%
   land was classified under high and very high ceptible zone respectively
   that are dominantly located in the north, northeast, and southwest of
   the study region. Furthermore, analysis using the entropy model
   indicated that geomorphology, with a value of 0.684, was the highest
   contributing factor to gully erosion ceptibility, followed by distance
   to streams at 0.449. Conversely, soil depth was the least contributing
   factor. In conclusion, study demonstrates that machine learning-based
   ensemble models, particularly RF-WOE, effectively identify gully erosion
   susceptibility zones high accuracy, providing a valuable tool. This
   finding is significant for land managers and policymakers aiming to
   implement effective soil conservation measures invulnerable regions. (c)
   2025 COSPAR. Published by Elsevier B.V. All rights are reserved,
   including those for text and data mining, AI training, and technologies.},
Type = {Article},
Affiliation = {Chen, XH (Corresponding Author), Jilin Univ Architecture \& Technol, Coll Civil Engn, Changchun 130114, Peoples R China.
