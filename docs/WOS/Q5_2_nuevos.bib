Keywords = {Remote Sensing; Water Environment; Pond Aquaculture; Taihu Basin},
Keywords-Plus = {CYANOBACTERIAL BLOOMS; WATER-QUALITY; IMPACTS; TRENDS},
Author-Email = {jiaqichen@hhu.edu.cn},
Number-of-Cited-References = {65},
