@article{ WOS:001656473800001,
Author = {Kozlov, V. and Sheleg, A. and Vovchuk, D. and Melnitsky, R. and Glam, A.
   and Boag, A. and Ginzburg, P.},
Title = {Micro-Doppler radar deception and camouflage of airborne targets},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {16},
Number = {1},
Month = {DEC 4},
Abstract = {Micro-Doppler signatures are ubiquitous in radar-based object
   recognition and classification, as they contain information about the
   internal structure of observed targets. While modern machine learning
   algorithms achieve unprecedented accuracy in target classification, they
   are susceptible to deceptive manipulation by introducing intelligent
   artificial modulation to the target's backscattered echoes. Here, we
   present the required foundations for successful passive deception,
   demonstrating experimentally the ability to camouflage a drone as a
   helicopter in the eyes of the investigating radar while maintaining
   radio silence. The concept can be used, for example, to manufacture
   low-cost, lightweight, and low-power devices that can, as an
   illustrative example, make a flock of birds appear as a swarm of drones
   to radar-based remote sensing platforms. This concept is applicable for
   implementation by passive time-dependent metasurfaces.},
Type = {Article},
Affiliation = {Vovchuk, D (Corresponding Author), Riga Tech Univ, Inst Photon Elect \& Telecommun, Azenes St 12, LV-1048 Riga, Latvia.
   Vovchuk, D (Corresponding Author), Tel Aviv Univ, Sch Elect Engn, Tel Aviv, Israel.
   Kozlov, V., City Univ New York, Adv Sci Res Ctr, Photon Initiat, New York, NY 10031 USA.
   Vovchuk, D., Riga Tech Univ, Inst Photon Elect \& Telecommun, Azenes St 12, LV-1048 Riga, Latvia.
   Sheleg, A.; Vovchuk, D.; Melnitsky, R.; Boag, A.; Ginzburg, P., Tel Aviv Univ, Sch Elect Engn, Tel Aviv, Israel.
   Glam, A., Rafael Adv Def Syst Ltd, Haifa, Israel.},
DOI = {10.1038/s41598-025-30442-2},
Article-Number = {847},
Keywords = {Radar deception; Micro-doppler camouflage; Electronic warfare;
   Electronic countermeasures},
Keywords-Plus = {MODULATION},
