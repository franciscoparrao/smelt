@article{ WOS:001702908800010,
Author = {Chen, Chao and Ren, Taohua and Liu, Pingping and Lv, Shuo and Liu,
   Zhisong and Yang, Xiaoyan and Gao, Jian},
Title = {Spatiotemporal Dynamics of Terrestrial Carbon Storage Driven by Land-Use
   and Land-Cover Change in Island Ecosystems: Insights From Long-Term
   Remote Sensing},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {7042-7057},
Abstract = {Archipelago surface environments undergo intense modifications due to
   tidal dynamics and complex marine conditions, which lead to ambiguous
   ecosystem boundaries and decreased land-use and land-cover (LULC)
   classification accuracy, restricting the precision of carbon storage
   quantification. Employing the long-term sequence analysis method, this
   research implemented a random forest algorithm integrating multifeature
   parameters to extract LULC information from satellite imagery. Then, the
   Integrated Valuation of Ecosystem Services and Tradeoffs (InVEST) model
   was deployed to quantify carbon storage and evaluate the effects of
   land-use and land-cover change on carbon storage within the Zhoushan
   Archipelago. Empirical analysis reveals that: 1) The multifeature random
   forest classifier achieved high accuracy in LULC mapping for the
   archipelago. The total terrestrial area has increased by a cumulative
   182.15 km(2). Specifically, construction land, aquaculture ponds, inland
   waters, bare land, coastal reclamation, and salt marsh vegetation all
   expanded in extent, whereas woodland, cropland/grassland, salt pans, and
   bare intertidal flats experienced overall declines. 2) Total regional
   carbon storage experienced a minor reduction from 160.87 to 154.03 Mt
   between 1985 and 2024. Woodland consistently constituted over 69\% of
   total carbon storage, establishing itself as the dominant carbon sink
   alongside cropland/grassland. Construction land's carbon contribution
   rose markedly from 1.13\% to 9.44\%, indicating substantial urbanization
   pressure on natural ecosystems. The carbon pool distribution showed soil
   carbon > aboveground biomass > underground biomass > dead organic
   matter. 3) Spatial analysis showed that the centre of gravity for carbon
   storage migration shifted southwest to northeast, aligning with the
   standard deviation ellipse's major axis, which was concentrated in
   central island regions characterized by substantial vegetation coverage
   and larger land areas. The variation pattern exhibits pronounced changes
   in peripheral areas, whereas the interior remains relatively stable.
   These findings could support the achievement of the dual-carbon policy
   in the Zhoushan Archipelago.},
Type = {Article},
Affiliation = {Gao, J (Corresponding Author), Hubei Univ Technol, Sch Civil \& Environm, Key Lab Intelligent Hlth Percept \& Ecol Restorat R, Minist Educ, Wuhan 430068, Peoples R China.
   Chen, Chao; Lv, Shuo, Suzhou Univ Sci \& Technol, Sch Geog Sci \& Geomat Engn, Suzhou 215009, Peoples R China.
   Ren, Taohua; Liu, Zhisong, Zhejiang Ocean Univ, Sch Informat Engn, Zhoushan 316022, Peoples R China.
   Liu, Pingping, Shandong Bur Coal Geol Explorat Geophys Prospectin, Jinan 250104, Peoples R China.
   Yang, Xiaoyan, Inner Mongolia Autonomous Reg Surveying \& Mapping, Hohhot 750306, Peoples R China.
