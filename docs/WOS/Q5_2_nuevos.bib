   Zare, Salman, Univ Tehran, Nat Resources Fac, Tehran, Iran.
   Wang, Shaokun; Zare, Salman, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, State Key Lab Ecol Safety \& Sustainable Dev Arid L, Urat Desert Grassland Res Stn, Lanzhou 730000, Peoples R China.},
DOI = {10.1016/j.agwat.2026.110213},
EarlyAccessDate = {FEB 2026},
