   Garg, Harish, Thapar Inst Engn \& Technol Univ, Dept Math, Patiala 147004, Punjab, India.},
DOI = {10.37256/cm.7120267816},
Keywords = {satellite imagery; optimization algorithms; ensemble learning; pattern
   recognition; local minima},
Keywords-Plus = {SATELLITE},
Author-Email = {zaahmed@imamu.edu.sa},
Number-of-Cited-References = {28},
