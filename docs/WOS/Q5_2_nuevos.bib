@article{ WOS:001713922300001,
Author = {Chen, Jianbing and Liu, Xiaona and Li, Ming and Li, Jinping and Chen,
   Pan and Long, Xiang and Cui, Fuqing and Liu, Zhiyun},
Title = {Spatial Zoning Characteristics of Thaw Settlement in Separated Subgrades
   in Permafrost Regions of the Qinghai-Tibet Engineering Corridor},
Journal = {REMOTE SENSING},
Year = {2026},
Volume = {18},
Number = {5},
Month = {MAR 9},
Abstract = {Highlights What are the main findings? Thaw settlement exhibits strong
   spatial variability (dominated by Level III at 40.85\%), primarily
   driven by MAGT and ICT through differentiated mechanisms:
   high-temperature zones are controlled by ice content, whereas
   low-temperature zones are governed by temperature. Among multi-source
   remote-sensing predictors, land surface temperature (LST) and the
   thawing index (TI) demonstrate the strongest significant correlations
   with thaw settlement. What are the implications of the main findings?
   High-resolution (30 m) spatial zoning along separated subgrades provides
   precise decision support for corridor-scale risk management and route
   alternative selection. LST and TI can serve as reliable, low-cost, and
   scalable indicators for the rapid screening and long-term monitoring of
   settlement hazards in remote, high-altitude environments.Highlights What
   are the main findings? Thaw settlement exhibits strong spatial
   variability (dominated by Level III at 40.85\%), primarily driven by
   MAGT and ICT through differentiated mechanisms: high-temperature zones
   are controlled by ice content, whereas low-temperature zones are
   governed by temperature. Among multi-source remote-sensing predictors,
   land surface temperature (LST) and the thawing index (TI) demonstrate
   the strongest significant correlations with thaw settlement. What are
   the implications of the main findings? High-resolution (30 m) spatial
   zoning along separated subgrades provides precise decision support for
   corridor-scale risk management and route alternative selection. LST and
   TI can serve as reliable, low-cost, and scalable indicators for the
   rapid screening and long-term monitoring of settlement hazards in
   remote, high-altitude environments.Abstract Thaw settlement (TS) in warm
   and ice-rich permafrost presents a challenge to highway subgrade
   stability in the Qinghai-Tibet Engineering Corridor (QTEC). To conduct a
   regional risk assessment, this study develops a framework coupling
   multi-source data fusion with Random Forest (RF) machine learning. By
   connecting site-specific thermo-mechanical simulations with
   corridor-scale remote sensing predictors, a 30 m resolution thaw
   settlement zoning map for 13 m wide separated subgrades was generated.
   The results indicate the following: (1) Thaw settlement exhibits
   significant spatial variability, with Level III settlement (20-30 cm)
   being the dominant category, accounting for 40.85\% of the total area;
   Level IV and V settlements are mainly distributed in warm and ice-rich
   permafrost regions such as the Chumar River, Wuli, and Tuotuo River
   areas. (2) Mean annual ground temperature (MAGT) and ice content type
   (ICT) are key factors influencing the spatial settlement pattern, with
   differentiated dominant mechanisms: 50\% of the zones are dominated by
   ICT, corresponding to higher settlement (26.76-43.31 cm); 35.71\% are
   influenced by both MAGT and ICT; and 14.29\% are dominated by MAGT, with
   lower settlement (16.23-24.19 cm). This suggests a distinct spatial
   pattern where ``high-temperature zones are largely controlled by ice
   content, while low-temperature zones are controlled by temperature.{''}
   (3) Among multi-source remote sensing factors, land surface temperature
   (LST) and the thawing index (TI) show significant correlations with thaw
   settlement, confirming their applicability for hazard identification in
   high-altitude regions. This study provides a scientific reference and
   decision support for engineering maintenance and route selection on the
   Qinghai-Tibet Plateau.},
Type = {Article},
Affiliation = {Cui, FQ (Corresponding Author), Changan Univ, Coll Geol Engn \& Geomat, Xian 710054, Peoples R China.
