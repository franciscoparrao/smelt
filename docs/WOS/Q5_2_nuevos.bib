@article{ WOS:001703028000001,
Author = {Ahmed, Sherif and Meselhe, Ehab and Hu, Kelin and Allison, Mead},
Title = {Unraveling drivers of crevasse splay evolution: A case study of the Fort
   St. Philip crevasse on the Mississippi River Delta},
Journal = {JOURNAL OF HYDROLOGY-REGIONAL STUDIES},
Year = {2026},
Volume = {64},
Month = {APR},
Abstract = {Study region: The Fort St. Philip (FSP) crevasse on the Mississippi
   River Delta, Louisiana, USA, represents a dynamic sediment diversion
   system connecting the river to the Breton Sound Basin. This region is
   characterized by rapid subsidence, tidal influence, and
   vegetation-hydrology interactions that shape deltaic land building.
   Study focus: This study quantifies the morphodynamic evolution of the
   FSP crevasse splay between 2013 and 2019 and evaluates the relative
   roles of vegetation, tides, waves, and diverted sediment in controlling
   land building. We applied a Delft3D-FM morphodynamic model validated
   using satellite-derived elevations generated through a Random Forest
   machine-learning approach. The model incorporates site-specific sediment
   properties, subsidence rates, and seasonal vegetation dynamics. New
   Hydrological Insights for the Region: Results show that vegetation and
   diverted riverine sediment were the dominant positive drivers of splay
   growth, while tides and waves acted as erosional forces. Vegetation
   increased splay volume above 0.00 m NAVD88 by 77 \% in comparison to the
   simulation without vegetation, whereas tidal and wave processes produced
   substantial net erosion. Hydroperiod analysis reveals persistent
   inundation in distal and medial zones, enhancing sediment receiving and
   retention, while proximal areas remain strongly controlled by seasonal
   river discharge. The integration of machine-learning-derived topography
   with process-based modeling provides a transferable framework for
   assessing sediment diversion performance and wetland resilience in
   river-dominated deltas worldwide.},
Type = {Article},
Affiliation = {Ahmed, S (Corresponding Author), Tulane Univ, Dept River Coastal Sci \& Engn, New Orleans, LA 70118 USA.
   Ahmed, Sherif; Meselhe, Ehab; Hu, Kelin; Allison, Mead, Tulane Univ, Dept River Coastal Sci \& Engn, New Orleans, LA 70118 USA.},
DOI = {10.1016/j.ejrh.2026.103276},
Article-Number = {103276},
Keywords = {Crevasse splay; Mississippi delta; Remote sensing; Morphodynamics;
   Delft3D-FM},
Keywords-Plus = {SEDIMENT TRANSPORT; UNIFIED VIEW; WAVES; SUSTAINABILITY; CLASSIFICATION;
   MORPHODYNAMICS; DIVERSIONS; LOUISIANA; CURRENTS; FOREST},
Author-Email = {sahmed12@tulane.edu},
Number-of-Cited-References = {56},
Times-Cited = {0},
Unique-ID = {WOS:001703028000001},
}

@article{ WOS:001704425100001,
Author = {Li, Yuxuan and Yang, Xuchao and Luo, Wei and Le, Chengfeng},
Title = {Mapping snow algae in West Antarctic Peninsula from Sentinel-2 images
   using a machine learning based approach},
Journal = {ISPRS JOURNAL OF PHOTOGRAMMETRY AND REMOTE SENSING},
Year = {2026},
Volume = {234},
Pages = {275-290},
Month = {APR},
Abstract = {Snow algae are crucial terrestrial carbon sinks and light-absorbing
   impurities in Antarctica. However, the distribution of snow algae across
   the West Antarctic Peninsula (WAP) remains poorly understood due to
   their high spatiotemporal variability and complex polar imaging
   conditions. This study develops a robust, large-scale mapping framework
   for green and red snow algae using machine learning. Our approach
   outperformed traditional spectral-index and spectral-unmixing methods
   across multiple challenging scenes, with the Kappa score improving from
   0.51 and 0.49 to 0.82. By synthesizing 2676 Sentinel-2 images, the
   2019-2024 composite distribution of WAP snow algae and the interannual
   variability of bloom intensity were assessed. Results reveal a total
   bloom area of 54.34 km2, and uncover significant negative association
   between bloom intensity and the Antarctic Oscillation index. This
   research establishes a novel, transferable tool for mapping snow algae
   in cryosphere systems and provides a baseline for evaluating their
   ecological implications in a changing climate.},
Type = {Article},
Affiliation = {Yang, XC; Le, CF (Corresponding Author), Zhejiang Univ, Ocean Coll, Zhoushan, Peoples R China.
   Li, Yuxuan; Yang, Xuchao; Le, Chengfeng, Zhejiang Univ, Ocean Coll, Zhoushan, Peoples R China.
   Luo, Wei, Polar Res Inst China, Shanghai, Peoples R China.},
DOI = {10.1016/j.isprsjprs.2026.02.026},
Keywords = {Snow algae; Antarctica; Remote sensing; Machine learning; Sentinel-2
   images},
Keywords-Plus = {ICE; COMMUNITIES; MICROBES; ALBEDO},
Author-Email = {yangxuchao@zju.edu.cn
   chengfengle@zju.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001704425100001},
}

@article{ WOS:001698963100001,
Author = {Currie, James and Reinke, Karin},
Title = {Assessing the transferability of post-disaster building damage
   assessment using synthetic aperture radar and machine learning},
Journal = {INTERNATIONAL JOURNAL OF DISASTER RISK REDUCTION},
Year = {2026},
Volume = {136},
Month = {APR 1},
Abstract = {A timely understanding of the scale and distribution of damage to
   infrastructure such as buildings and dwellings following disasters is
   crucial for efficient and effective response and recovery. Synthetic
   Aperture Radar (SAR) is a valuable tool for remotely assessing damage,
   and when coupled with Machine Learning (ML) has the potential to safely
   and effectively map damage at an individual building level. For
   practical disaster response, SAR ML models must generalise to new
   disaster events beyond their training data. Model transferability to new
   disaster events in differing contexts has been untested with medium
   resolution SAR. Therefore, this study evaluates transferability of
   medium resolution SAR ML models using Sentinel-1 coherence and intensity
   for mapping damage across 11 disaster events of various types (including
   earthquakes, hurricanes, wildfires, tsunamis and volcanic eruptions)
   across different global locations. Models were trained and tested under
   three scenarios: a reference scenario requiring no transferability, and
   two transferability scenarios utilising event-based cross-validation:
   (a) a global scenario and (b) a firespecific scenario. Model performance
   decreased substantially under the global transferability scenario
   compared to the reference scenario, indicating the models struggled to
   adapt to varying disaster characteristics and geographic contexts. The
   fire specific scenario outperformed the disaster-agnostic global
   scenario, suggesting that further research may benefit from focusing on
   disaster-type specific models. Although performance across all scenarios
   was inconsistent, several disaster events saw positive performance,
   particularly in the fire-specific scenario. Further research is
   necessary before models should be operationally utilised for disaster
   response.},
Type = {Article},
Affiliation = {Reinke, K (Corresponding Author), RMIT Univ, Sch Sci, Math \& Geospatial Sci, Melbourne, Australia.
   Currie, James; Reinke, Karin, RMIT Univ, Sch Sci, Math \& Geospatial Sci, Melbourne, Australia.},
DOI = {10.1016/j.ijdrr.2026.106048},
Article-Number = {106048},
Keywords = {Synthetic aperture radar; Random forest; Building damage; Disaster;
   Generalisation; Remote sensing},
Keywords-Plus = {IMAGERY},
Author-Email = {Jcurrie987@gmail.com
   karin.reinke@rmit.edu.au},
Number-of-Cited-References = {67},
Times-Cited = {0},
Unique-ID = {WOS:001698963100001},
}

@article{ WOS:001723326700001,
Author = {Hardiana, Arpin and Nurdin, Nurjannah and Adhawati, Sri Suro and
   Fakhriyyah, Sitti and Aziz, Hasni Yulianti and Ibnu Hajar, M. Abduh and
   Demmallino, Eymal B.},
Title = {Mapping the relocation and expansion of Kappaphycus alvarezii
   cultivation units based on rainfall and sea surface temperature from
   high and low resolution satellite data in Bone Bay, Indonesia},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2026},
Month = {2026 MAR 26},
Abstract = {Climate variability increases the pressure on the sustainability of
   seaweed cultivation in tropical regions. This study aimed to analyse the
   dynamics of relocation and expansion of Kappaphycus alvarezii
   cultivation in Bone Bay, Indonesia, by integrating high-resolution
   multitemporal PlanetScope imagery with sea surface temperature (SST) and
   rainfall data obtained from MODIS and CHIRPS during the period
   2022-2024. An Object-Based Image Analysis (OBIA) approach combined with
   the Random Forest algorithm was applied to map the spatial distribution
   of cultivation areas and quantify temporal changes in the area and
   number of cultivation units. Classification results showed consistent
   performance with a moderate level of accuracy, with overall accuracy
   values ranging from 68.4\% to 72.5\% and Kappa coefficients between 0.58
   and 0.67, indicating that high-resolution optical imagery is capable and
   temporally stable in detecting seaweed cultivation areas in complex
   coastal environments. Temporal analysis revealed clear seasonal and
   interannual variability, with a tendency for cultivation area expansion
   during the monsoon transition period (March-September) and contraction
   during the rainy season (October-December). Statistical analysis showed
   a consistent negative relationship between increasing sea surface
   temperature and the area and number of cultivation units, whereas
   rainfall only had a positive effect at moderate intensity levels. This
   study confirms the novelty of an integrative approach between
   high-resolution satellite imagery and climate variables as a basis for
   developing a seaweed cultivation management system that is adaptive to
   future climate variability and changes.},
Type = {Article; Early Access},
Affiliation = {Nurdin, N (Corresponding Author), Hasanuddin Univ, Fac Marine Sci \& Fisheries, Marine Sci Dept, Makassar, Indonesia.
   Nurdin, N (Corresponding Author), Hasanuddin Univ, Res Ctr \& Dev Marine Coastal \& Small Isl, Makassar, Indonesia.
   Hardiana, Arpin; Demmallino, Eymal B., Hasanuddin Univ, Grad Sch, Environm Sci Dept, Makassar, Indonesia.
   Nurdin, Nurjannah, Hasanuddin Univ, Fac Marine Sci \& Fisheries, Marine Sci Dept, Makassar, Indonesia.
   Nurdin, Nurjannah, Hasanuddin Univ, Res Ctr \& Dev Marine Coastal \& Small Isl, Makassar, Indonesia.
   Adhawati, Sri Suro; Fakhriyyah, Sitti; Aziz, Hasni Yulianti; Ibnu Hajar, M. Abduh, Hasanuddin Univ, Fac Marine Sci \& Fisheries, Fisheries Dept, Makassar, Indonesia.},
DOI = {10.1080/01431161.2026.2648101},
EarlyAccessDate = {MAR 2026},
Keywords = {<italic>Kappaphycus alvarezii</italic>; OBIA; sea surface temprature;
   rainfall; Bone Bay},
Keywords-Plus = {WATER; AREAS},
Author-Email = {nurjannahnurdin@unhas.ac.id},
Number-of-Cited-References = {60},
Times-Cited = {0},
