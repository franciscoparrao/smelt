   Xie, Yifan; Wang, Jiahao; Aierken, Nuermaimaitijiang; Wang, Geng; Zhang, Xiaoli, Beijing Forestry Univ, State Key Lab Efficient Prod Forest Resources, Beijing 100083, Peoples R China.
   Xie, Yifan; Wang, Jiahao; Aierken, Nuermaimaitijiang; Wang, Geng; Zhang, Xiaoli, Beijing Forestry Univ, Coll Forestry, Beijing Key Lab Precis Forestry, Beijing 100083, Peoples R China.
   Xie, Yifan; Wang, Jiahao; Aierken, Nuermaimaitijiang; Wang, Geng; Zhang, Xiaoli, Beijing Forestry Univ, Key Lab Forest Cultivat \& Protect, Minist Educ, Beijing 100083, Peoples R China.
   Chen, Long, Chinese Acad Forestry, Inst Forest Resource Informat Tech, Beijing 100091, Peoples R China.},
DOI = {10.1109/JSTARS.2025.3645613},
Keywords = {Forestry; Trees (botanical); Remote sensing; Training; Adaptation
   models; Accuracy; Feature extraction; Data models; Surveys; Clouds;
