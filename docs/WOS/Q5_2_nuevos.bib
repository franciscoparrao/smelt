   Cao, Jinjin, Anhui Jinyuan Construct Co Ltd, Wuhu, Anhui, Peoples R China.
   Ouyang, Xiaoying, Int Res Ctr Big Data Sustainable Dev Goals CBAS, Beijing, Peoples R China.
   Ouyang, Xiaoying, Chinese Acad Sci, Aerosp Informat Res Inst AlR, Key Lab Digital Earth Sci, Beijing, Peoples R China.},
DOI = {10.1016/j.jag.2026.105210},
Article-Number = {105210},
Keywords = {Positive sample augmentation; Spatio-temporal stratification; Wildfire
   susceptibility; Burned area; Machine learning},
Keywords-Plus = {CLIMATE-CHANGE; FIRE; ALGORITHM},
Author-Email = {zhangrui@swjtu.edu.cn},
