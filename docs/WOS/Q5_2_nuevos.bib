Unique-ID = {WOS:001675936300001},
}

@article{ WOS:001675611400001,
Author = {Ogweno, Vincent Wayuga and Moore, Nathan and Andresen, Jeff},
Title = {Semi-supervised machine learning for montane vegetation mapping:
   Integrating PlanetScope imagery with climatic and topographic gradients
   to characterize short-term land cover transitions in Mount Kenya's
   montane ecosystems},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {Mount Kenya's montane ecosystems face accelerating threats from climate
   variability and anthropogenic pressures, demanding scalable monitoring
   frameworks for evidence-based conservation. Traditional supervised
   classification methods struggle with fragmented vegetation, limited
   reference data, and topographic complexity in such heterogeneous
   landscapes. We developed a semi-supervised machine learning (SSML)
   framework integrating high-resolution PlanetScope NICFI imagery (4.77
   m), topographic derivatives (NASADEM), and climatic variables
   (ERA5-Land) to classify vegetation and assess land cover transitions
   between 2017-2019 and 2021-2023. Spectral indices derived from visible
   and red-edge bands: the Red-Edge Normalized Difference Vegetation Index
   (RENDVI) and Red-Green Ratio Index (RGRI), enhanced discrimination of
   vegetation stress and biomass heterogeneity despite the absence of
   near-infrared channels. The temporal comparison explicitly omitted 2020
   to isolate stable climate regimes, avoiding transitional El Ni \&
   ntilde;o-Southern Oscillation (ENSO) and Indian Ocean Dipole (IOD) phase
   shifts that confound baseline vegetation states. The SSML framework
   achieved 93.5\% overall accuracy with minimal quantity disagreement (48
   pixels) and moderate allocation disagreement (3465 pixels). Upper
   montane zones (bamboo, nival) exhibited relative stability, while
   lower-elevation agricultural/mixed vegetation declined 7.8\% and sparse
   vegetation/bare soil expanded 5.6\%, reflecting coupled land-use
   intensification and hydroclimatic anomalies during the 2021-2023 La Ni
   \& ntilde;a phase. This study demonstrates that integrating
   high-resolution remote sensing, semi-supervised learning, and
   multi-resolution environmental predictors enables robust vegetation
   monitoring in data-scarce mountain regions. The approach provides
   actionable insights for adaptive conservation planning and
   climate-resilient land management strategies in tropical montane
   ecosystems globally},
Type = {Article},
Affiliation = {Ogweno, VW (Corresponding Author), Michigan State Univ, Dept Geog Environm \& Spatial Sci, 673 Auditorium Rd, E Lansing, MI 48824 USA.
   Ogweno, Vincent Wayuga; Moore, Nathan; Andresen, Jeff, Michigan State Univ, Dept Geog Environm \& Spatial Sci, 673 Auditorium Rd, E Lansing, MI 48824 USA.
   Moore, Nathan; Andresen, Jeff, Michigan State Univ, Ctr Global Change \& Earth Observat, 1405 S Harrison Rd, E Lansing, MI 48823 USA.},
DOI = {10.1016/j.rsase.2026.101886},
EarlyAccessDate = {JAN 2026},
Article-Number = {101886},
Keywords = {Montane vegetation; Remote sensing; Planet NICFI imagery;
   Semi-supervised classification; Iterative retraining; Land cover
   mapping; Google Earth Engine; Climate teleconnections; ENSO; Indian
   Ocean},
Keywords-Plus = {FOREST; DYNAMICS},
Author-Email = {ogwenovi@msu.edu},
Number-of-Cited-References = {87},
Times-Cited = {0},
Unique-ID = {WOS:001675611400001},
}

@article{ WOS:001675628500001,
Author = {Li, Xingrong and Yang, Gaoxiang and He, Meng and Xiong, Yuan and Liu,
   Leilei and Mariam, Hifza and Ali, Iftikhar and Jiang, Chongya and Yao,
   Xia and Zhu, Yan and Cao, Weixing and Cheng, Tao},
Title = {Automated rice mapping under diverse cropping patterns and establishment
   methods by integrating phenological knowledge and synergy of optical and
   SAR imagery},
Journal = {REMOTE SENSING OF ENVIRONMENT},
Year = {2026},
Volume = {335},
Month = {MAR 15},
Abstract = {Accurate and timely information on rice cultivation areas and cropping
   intensity is essential for precision crop management, food security and
   environmental sustainability. However, the generation of high-quality
   rice products is often hindered by the lack of ground truth samples,
   particularly in the regions with complex cropping patterns. While most
   rice mapping methods rely on the use of remotely sensed flooding signal
   from the transplanting period to distinguish rice from other crops, they
   face significant challenges from the increasingly prevalent
   direct-seeded rice for which the flooding signal at the beginning of
   season is weak due to the unique management measures. To address these
   issues and achieve the comprehensive extraction of rice under diverse
   cropping patterns and establishment methods, this study proposed the
   phenological knowledge-guided automatic rice mapping approach using
   optical and synthetic aperture radar (SAR) data (PHAROS). This method
   first determined the cropping intensity of rice and its concurrent crops
   using harmonized multi-resource Normalized Difference Vegetation Index
   (NDVI) time series and phenological knowledge. Subsequently, the Double
   Phase SAR Index (DPSI) was constructed to extract candidate rice samples
   by synthesizing the early and peak growth phases retrieved from NDVI
   time series and the corresponding SAR polarization features.
   Consequently, training data were generated automatically and fed into a
   machine learning classifier for rice mapping. The effectiveness of the
   PHAROS was evaluated over the Middle and Lower Reaches of the Yangtze
   River (MLRYR) of China and four other major rice production regions in
   Asia. Furthermore, the earliest timing of early, middle and late rice in
   the MLRYR was also quantified via the PHAROS and cross-year model
   transfer. The results demonstrated that the PHAROS could identify rice
   of diverse cropping pattern with an overall accuracy (OA) from 0.965 to
   0.976 in the MLRYR from 2019 to 2023. The classification maps exhibited
   welldelineated rice parcels and clear separation between single- and
   double-cropping rice. The PHAROS also yielded OA values of 0.902-0.979
   and similar distribution pattern with the reference rice products in
   Suihua of China, Sataka of Japan, An Giang of Vietnam and Punjab of
   Pakistan, which represent diverse climatic conditions and cropping
