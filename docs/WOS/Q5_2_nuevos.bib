   Rouse, Matthew N., ARS, USDA, Sugarcane Field Stn, 12990 US Hwy 441 N, Canal Point, FL 33438 USA.},
DOI = {10.1016/j.atech.2025.101714},
EarlyAccessDate = {JAN 2026},
Article-Number = {101714},
Keywords = {UAV hyperspectral imaging; Wheat disease classification; Transformer
   neural network; Spectral band selection; Remote sensing},
Keywords-Plus = {XANTHOMONAS-TRANSLUCENS; IMAGE CLASSIFICATION; STRAINS; INDEXES},
