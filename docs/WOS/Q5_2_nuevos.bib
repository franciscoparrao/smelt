   Sun, Yeran, Chinese Acad Sci, Aerosp Informat Res Inst, State Key Lab Remote Sensing \& Digital Earth, Beijing, Peoples R China.
   Sun, Yeran, Univ Chinese Acad Sci, Beijing, Peoples R China.},
DOI = {10.1080/17445647.2026.2633880},
