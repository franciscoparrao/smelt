@article{ WOS:001693020800001,
Author = {Chen, Ke and Guo, Jian and Liu, Linyi and Cheng, Xiangzhe and Zhuang,
   Shujia and Huang, Wenjiang and Dong, Yingying and Liu, Chunming and
   Huang, Kun and Hou, Qiuqiang and Shan, Shuanglu and Guo, Yiwei and Wang,
   Xiaomeng and Zhou, Tong and Zhong, Mei and Liang, Siyu and Chen, Lihua
   and Luo, Sijie},
Title = {Classification of tobacco leaf diseases based on multi-source remote
   sensing data},
Journal = {FRONTIERS IN PLANT SCIENCE},
Year = {2026},
Volume = {17},
Month = {FEB 4},
Abstract = {Accurate classification of tobacco leaf diseases is critical for
   objective disease assessment and management. However, traditional manual
   observation methods are inherently subjective, and classification
   approaches based on single-feature extraction often exhibit limited
   robustness. To address these limitations, this study proposes a tobacco
   leaf disease classification method based on multi-source data.
   Hyperspectral reflectance data, leaf area index, and chlorophyll content
   were selected as the original data sources, and corresponding feature
   extraction strategies were applied. Continuous wavelet transform was
   employed to extract discriminative features from hyperspectral
   reflectance data, while leaf area index and chlorophyll content were
   normalized using the Z-score method. A random forest algorithm was then
   used for model training and validation. Experimental results demonstrate
   that the proposed method achieves an overall classification accuracy of
   88.7\% with a Kappa coefficient of 0.83, indicating strong
   classification performance and robustness. These results confirm that
   the proposed multi-source data-based model provides a reliable and
   effective approach for tobacco leaf disease classification and offers
   valuable insights for future research using multi-source remote sensing
   data.},
Type = {Article},
Affiliation = {Dong, YY (Corresponding Author), Chinese Acad Sci, Aerosp Informat Res Inst, State Key Lab Remote Sensing \& Digital Earth, Beijing, Peoples R China.
   Chen, Ke; Liu, Linyi; Cheng, Xiangzhe; Zhuang, Shujia; Huang, Wenjiang; Dong, Yingying, Chinese Acad Sci, Aerosp Informat Res Inst, State Key Lab Remote Sensing \& Digital Earth, Beijing, Peoples R China.
   Guo, Jian; Liu, Chunming; Huang, Kun; Hou, Qiuqiang; Shan, Shuanglu; Guo, Yiwei; Wang, Xiaomeng; Zhou, Tong; Zhong, Mei; Liang, Siyu; Chen, Lihua; Luo, Sijie, Yunnan Tobacco Co, Honghe Branch, Yunnan Mile, Peoples R China.},
DOI = {10.3389/fpls.2026.1727082},
Article-Number = {1727082},
Keywords = {continuous wavelet transform; hyperspectral reflectance data; random
   forest; remote sensing; tobacco leaf},
Author-Email = {dongyy@aircas.ac.cn},
Number-of-Cited-References = {34},
Times-Cited = {0},
