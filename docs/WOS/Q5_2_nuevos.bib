@article{ WOS:001648647500001,
Author = {Aghababaei, Masoumeh and Ebrahimi, Ataollah and Naghipour, Ali Asghar
   and Asadi, Esmaeil and Verrelst, Jochem},
Title = {Enhancing Plant Ecological Unit Mapping Accuracy with Auxiliary Data
   from Landsat-8 in a Heterogeneous Rangeland},
Journal = {REMOTE SENSING},
Year = {2025},
Volume = {17},
Number = {24},
Month = {DEC 13},
Abstract = {Mapping Plant Ecological Units (PEUs) support sustainable rangeland
   management. Yet, distinguishing them from multispectral imagery remains
   challenging due to high intra-class variability and spectral overlap.
   This study evaluates the contribution of auxiliary data layers to
   improve PEU classification from Landsat-8 OLI imagery in semi-arid
   rangelands of northeastern Iran. A random forest (RF) classifier was
   trained using field samples and multiple feature combinations, including
   spectral indices, topographic variables (DEM, slope, aspect), and
   principal component analysis (PCA) components. Classification
   performance was assessed using overall accuracy (OA), kappa coefficient,
   and non-parametric Friedman and post hoc tests to determine significant
   differences among scenarios. The results show that auxiliary features
   consistently enhanced classification performance as opposed to spectral
   bands alone. Integrating DEM and PCA layers yielded the highest accuracy
   (OA = 79.3\%, kappa = 0.71), with statistically significant improvement
   (p < 0.05). The findings demonstrate that incorporating topographic and
   transformed spectral information can effectively reduce class confusion
   and improve the separability of PEUs in complex rangeland environments.
   The proposed workflow provides a transferable approach for ecological
   unit mapping in other semi-arid regions facing similar environmental and
   management challenges.},
Type = {Article},
Affiliation = {Ebrahimi, A (Corresponding Author), Shahrekord Univ, Fac Nat Resources \& Earth Sci, Dept Nat Engn, Shahrekord 8818634141, Iran.
   Aghababaei, Masoumeh; Ebrahimi, Ataollah; Naghipour, Ali Asghar; Asadi, Esmaeil, Shahrekord Univ, Fac Nat Resources \& Earth Sci, Dept Nat Engn, Shahrekord 8818634141, Iran.
   Verrelst, Jochem, Univ Valencia, Image Proc Lab IPL, Parc Cient, Paterna 46980, Spain.},
DOI = {10.3390/rs17244025},
Article-Number = {4025},
Keywords = {vegetation mapping; auxiliary data; random forest; accuracy assessment;
   plant ecological units},
Keywords-Plus = {LAND-COVER CLASSIFICATION; VEGETATION CLASSIFICATION; ANCILLARY DATA;
