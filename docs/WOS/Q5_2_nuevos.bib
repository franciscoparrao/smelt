}

@article{ WOS:001641773100001,
Author = {Blasch, Gerald and Lesne, Louise and Wolter, Jolan and Alemayehu, Yoseph
   and Bontemps, Sophie and Hodson, David P. and Defourny, Pierre},
Title = {Rainfed wheat extent (2020/21) across Ethiopia's complex and highly
   fragmented agricultural smallholder landscape},
Journal = {JOURNAL OF MAPS},
Year = {2025},
Volume = {21},
Number = {1},
Month = {DEC 31},
Abstract = {Crop-type maps are critical for addressing food insecurity, yet
   national-scale, high-resolution maps of staple crops like wheat remain
   unavailable for many African countries due to limited, publicly
   available ground reference data. Ethiopia's complex and fragmented
   agricultural smallholder landscape and frequent cloud cover during
   rainfed seasons make crop mapping particularly challenging. This study
   presents the first national-scale, high-resolution wheat area map for
   Ethiopia, generated through a satellite-based workflow integrating (i)
   gap-filled, cloud-masked Sentinel-2 time series; (ii) Random Forest
   classification using temporal-spectral profiles and the EthCT2020
   reference dataset; (iii) cropland masking; (iv) multistep validation;
   and (v) confidence-based consolidation with sub-national statistics. The
   resulting map estimates approximately 3.19 million hectares of wheat for
   the 2020/21 rainfed season, with 10 m spatial resolution and temporal
   coverage from April to December 2020. The dataset, openly accessible via
   CIMMYT Dataverse, provides a critical resource for operational wheat
   disease early warning and advisory systems in Ethiopia.},
Type = {Article},
Affiliation = {Blasch, G (Corresponding Author), CIMMYT Global Headquarters, Carretera Mexico Veracruz Km 45, Texcoco 56237, Mexico.
   Blasch, Gerald, CIMMYT, Sustainable Agrifood Syst Program SAS, Texcoco, Mexico.
   Lesne, Louise; Wolter, Jolan; Bontemps, Sophie; Defourny, Pierre, Catholic Univ Louvain, Earth \& Life Inst, Louvain La Neuve, Belgium.
   Alemayehu, Yoseph, CIMMYT, Sustainable Agrifood Syst Program SAS, Addis Ababa, Ethiopia.
   Hodson, David P., CIMMYT, Sustainable Agrifood Syst Program SAS, Kathmandu, Nepal.},
DOI = {10.1080/17445647.2025.2602338},
Article-Number = {2602338},
Keywords = {Remote sensing; crop type mapping; machine learning; random forest;
   sentinel-2; satellite},
Keywords-Plus = {CROPPING SYSTEMS},
Author-Email = {g.blasch@cgiar.org},
Number-of-Cited-References = {51},
Times-Cited = {0},
