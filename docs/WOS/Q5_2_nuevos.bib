@article{ WOS:001719543100047,
Author = {Euler, Quentin and Gerlein-Safdi, Cynthia},
Title = {Rethinking the Flow: A Canal-Based Machine Learning Approach to Urban
   Flood Detection},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Machine learning (ML) methods have proven effective for mapping urban
   flood extents using remotely sensed data. However, the availability of
   suitable datasets remains a key challenge when training such models.
   Here, we present a novel approach to address this limitation. Instead of
   focusing on individual pixels, we use streets as the primary unit of
   analysis. This change allows us to use an entirely new type of
   ground-truth dataset: canal cities such as Venice, Italy. Here, we
   construct a reliable training dataset by labeling canals as flooded
   streets and regular streets as dry. We then use Sentinel-2 optical
   remote sensing data to develop an improved neural network architecture
   specifically designed to accurately classify canals and streets in
   complex urban environments: the custom street flood index (CSFI).
   Several other methods are evaluated, ranging from a simple normalized
   difference water index (NDWI) thresholding approach to more advanced ML
   techniques such as XGBoost, support vector machine (SVM), random forest,
   and neural networks. All advanced models yield promising results,
   significantly outperforming the classic NDWI baseline. However, among
   them, our new CSFI achieves the best performance, with an accuracy of
   86\% and a Matthews correlation coefficient (MCC) of 72\% on our new
   training dataset. It also shows a strong ability to generalize to
   previously unseen cities. Finally, the new CFSI is tested on the
   real-world flood event of Porto Alegre, Brazil, in early May 2024,
   successfully mapping the extent of the urban flooding with 90\% accuracy
   and an MCC of 70\%. This makes our CSFI a new, efficient way to map
   flood extent at a street scale. The code is made available for users to
   apply the method to their own urban flood mapping needs.},
Type = {Article},
Affiliation = {Gerlein-Safdi, C (Corresponding Author), Univ Calif Berkeley, Dept Civil \& Environm Engn, Berkeley, CA 94720 USA.
   Gerlein-Safdi, C (Corresponding Author), Univ Calif Berkeley, Lawrence Berkeley Natl Lab, Berkeley, CA 94720 USA.
   Euler, Quentin, Ecole Polytech, F-91120 Palaiseau, France.
   Euler, Quentin, Univ Calif Berkeley, Dept Civil \& Environm Engn, Berkeley, CA 94720 USA.
