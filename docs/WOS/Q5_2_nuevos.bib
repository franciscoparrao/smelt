@article{ WOS:001680396800001,
Author = {Zhang, Fanghao and Jiang, Feirui and Zhang, Yuanshuo and Xu, Junzu and
   Ye, Yang and Jia, Zhaoliang},
Title = {A study on the refined population spatialization method integrating
   multi-source data: A case study of Yuxi city},
Journal = {PLOS ONE},
Year = {2026},
Volume = {21},
Number = {1},
Month = {JAN 23},
Abstract = {The precise assessment of earthquake disasters requires high accuracy in
   population spatialization data. With the rapid development of
   technologies such as remote sensing and social sensing (social
   perception), and the growing availability of large-scale geographic
   data, high-resolution remote sensing data and vast geographical spatial
   data provide new opportunities for inferring more accurate population
   data. This paper proposes a method that integrates social perception big
   data, building attribute data, and multi-source remote sensing data.
   Using Random Forest, XGBoost, LGBM, Gradient Boosting, AdaBoost, and
   CatBoost models as base learners, and RidgeCV regression as the
   secondary learner, a higher-performing Stacking ensemble learning
   prediction model is constructed. The method system is employed to
   spatialize the population data of Yuxi City for the year 2020 at a 50m
   resolution using the Partition Density Mapping technique. The results
   show that: (1) The population estimation model proposed in this paper
   outperforms the WorldPop dataset and LandScan dataset by more than 40\%
   in terms of accuracy at the administrative village scale, providing
   higher simulation accuracy for regions with different population
   densities. This result highlights the refined spatial features of the
   population depicted in satellite remote sensing images, offering richer
   and more realistic population distribution information. (2) By measuring
   the SHAP feature contributions and importance of the variables, it is
   found that residential building area, POI, and nighttime light intensity
   are the most significant indicators of population distribution in Yuxi
   City, suggesting a higher correlation of social factors in population
   spatial redistribution.},
Type = {Article},
Affiliation = {Jiang, FR (Corresponding Author), Yunnan Earthquake Agcy, Kunming, Peoples R China.
   Zhang, Fanghao; Jiang, Feirui; Zhang, Yuanshuo; Xu, Junzu; Ye, Yang; Jia, Zhaoliang, Yunnan Earthquake Agcy, Kunming, Peoples R China.},
DOI = {10.1371/journal.pone.0340430},
Article-Number = {e0340430},
Keywords-Plus = {CHINA},
Author-Email = {zfh125@sina.com},
Number-of-Cited-References = {30},
Times-Cited = {0},
Unique-ID = {WOS:001680396800001},
}

@article{ WOS:001677599300001,
Author = {Kuang, Xiaohui and Cheng, Qian and Chen, Deshan and Fu, Wanna and Li,
   Hao and Chen, Zhen},
Title = {Intelligent diagnosis of winter wheat water stress based on UAV
   multi-modal remote sensing},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2026},
Volume = {13},
Month = {MAR},
Abstract = {Water stress severely affects the normal growth and development of
   winter wheat, resulting in a decrease in both yield and quality. To
   address the limitations and time lags of traditional water stress
   monitoring methods, this study develops a winter wheat water stress
   classification model using Unmanned Aerial Vehicle (UAV)-based
   multi-source remote sensing data and machine learning algorithms. The
   experiment was conducted at the Xinxiang Experimental Base of the
   Chinese Academy of Agricultural Sciences in Henan Province, China,
   during the winter wheat growing season, involving 120 plots under four
   irrigation levels. Vegetation indices (VIs) and thermal infrared (TIR)
   features were extracted by acquiring water stress imagery during three
   critical growth stages of wheat: heading stage, flowering stage, and
   filling stage. Unlike many previous UAVbased water stress studies that
   mainly focus on a single growth stage or a single type of sensor, this
   study evaluates VI and TIR fusion across multiple key growth stages
   under controlled irrigation gradients and systematically compares three
   machine-learning classifiers. The performance of three classifiers,
   Random Forest (RF), eXtreme Gradient Boosting (XGBoost), and Support
   Vector Machine (SVM), in water stress identification was evaluated. The
   results indicated that classification performance varied across single
   growth stages. Notably, multi-source sensor data fusion consistently
   achieved the highest classification accuracy across all stages,
   outperforming single-source data. The SVM model achieved classification
   accuracy, recall, and F1score all exceeding 91\%, with the flowering
   stage being particularly outstanding, achieving an accuracy of 97.22\%,
   precision of 97.78\%, recall of 97.22\%, and F1score of 97.27\%. After
   merging multiple growth stages, the fusion of multi-source sensor data
   still showed the best performance. The SVM model had the highest
   classification accuracy (82.41\%), precision (83.71\%), recall
   (82.41\%), and F1score (81.93\%). In summary, the SVM classifier fusing
   VIs and TIR features exhibited excellent performance in classifying
   wheat water stress. This study effectively achieved non-destructive,
   accurate, and rapid monitoring of winter wheat water stress, providing
   technical support for precision agriculture and water management.},
Type = {Article},
Affiliation = {Li, H (Corresponding Author), Henan Univ, Coll Agr, Sch Life Sci, State Key Lab Crop Stress Adaptat \& Improvement, Kaifeng 475004, Henan, Peoples R China.
   Chen, Z (Corresponding Author), Chinese Acad Agr Sci, Inst Farmland Irrigat, Xinxiang 453002, Peoples R China.
   Li, H (Corresponding Author), Shennong Lab, Zhengzhou 450002, Henan, Peoples R China.
   Kuang, Xiaohui; Li, Hao, Henan Univ, Coll Agr, Sch Life Sci, State Key Lab Crop Stress Adaptat \& Improvement, Kaifeng 475004, Henan, Peoples R China.
   Kuang, Xiaohui; Cheng, Qian; Chen, Deshan; Fu, Wanna; Chen, Zhen, Chinese Acad Agr Sci, Inst Farmland Irrigat, Xinxiang 453002, Peoples R China.
   Li, Hao, Shennong Lab, Zhengzhou 450002, Henan, Peoples R China.},
DOI = {10.1016/j.atech.2026.101781},
EarlyAccessDate = {JAN 2026},
Article-Number = {101781},
Keywords = {Winter wheat; Water stress; UAV remote sensing; Machine learning; Water
   management},
Keywords-Plus = {INDEX},
Author-Email = {lihao@henu.edu.cn
   chenzhen@caas.cn},
Number-of-Cited-References = {58},
Times-Cited = {1},
Unique-ID = {WOS:001677599300001},
}

@article{ WOS:001677362200002,
Author = {Qiu, Jinkai and Xu, Xiuying and Qi, Liqiang and Kang, Ye and Zhang, Wei
   and Zhang, Yanliang},
Title = {Field-scale mapping of soil available phosphorus in cropland via
   interpretable machine learning and multispectral remote sensing},
Journal = {SOIL \& TILLAGE RESEARCH},
Year = {2026},
Volume = {259},
Month = {JUL},
Abstract = {Soil available phosphorus (SAP) is a key indicator for assessing crop
   fertilization requirements. Accurately and quickly mapping the spatial
   distribution of SAP in cropland is crucial for guiding variable
   fertilization decisions. To explore a suitable model for estimating SAP
   at the field scale and enhance its credibility and interpretability,
   this study focused on multiple croplands at the Jianshan Farm in
   Heilongjiang Province. Soil samples were collected during the autumn
   bare soil period, and synchronous Sentinel-2 satellite imagery was
   acquired. A dataset was constructed by integrating spectral remote
   sensing factors with topographic variables. Random Forest Regression
   (RFR), Categorical Boosting (CatBoost), and Back Propagation Neural
   Network (BPNN) were employed to establish models for estimating SAP
   content in cropland. The zebra optimization algorithm (ZOA) was used to
   perform hyperparameter optimization and performance analysis on the
   best-performing model. On this basis, the Shapley additive explanations
   (SHAP) method was adopted to quantitatively analyze the contribution and
   impact of environmental variables on model predictions. Spatial
   distribution mapping of SAP content was conducted for both the
   experimental and newly added plots to evaluate the model's
   applicability. The results indicated that the ZOA-BPNN-G model,
   developed using raw bands, soil indices, and topographic variables,
   achieved the highest accuracy in estimating SAP (R2=0.6229, r = 0.8385,
   RMSE=8.4359 mg/kg, MAE=5.9816 mg/kg, MAPE=15.5123 \%). Compared with the
   estimation model before optimization, R2 increased by 9.55 \%age points,
   and r increased by 7.91 \%age points, while the values of other
   evaluation indicators decreased. The raw bands and soil indices are the
   primary explanatory variables for estimating SAP content, with key
   features including NDSI, B8A, BI, and B3. Interpretability analysis and
   uncertainty analysis improved the transparency and credibility of the
   model. The proposed estimation model achieved good SAP mapping results
   on the experimental plots and had a strong correspondence with the SAP
   measured data. The MAPE for the newly added plot reached 13.1288 \%,
   confirming the application feasibility of the proposed method to the
   autumn bare soil in the study area. It can provide theoretical and
   technical support for the rapid detection of SAP content and the
   generation of variable fertilization prescription maps.},
Type = {Article},
Affiliation = {Zhang, W (Corresponding Author), Heilongjiang Bayi Agr Univ, Coll Engn, Daqing 163319, Peoples R China.
   Zhang, YL (Corresponding Author), Heilongjiang Acad Agr Machinery Engn Sci, Harbin 150081, Peoples R China.
   Qiu, Jinkai; Xu, Xiuying; Qi, Liqiang; Kang, Ye; Zhang, Wei, Heilongjiang Bayi Agr Univ, Coll Engn, Daqing 163319, Peoples R China.
