@article{ WOS:001713931700001,
Author = {Xiang, Qin and Wei, Rong and Qin, Chaoguan and Fu, Lianjin and Li,
   Zhengying and He, Hailin and Shu, Qingtai},
Title = {Forest Aboveground Carbon Storage in the Three Parallel Rivers Region: A
   Remote Sensing and Machine Learning Perspective},
Journal = {REMOTE SENSING},
Year = {2026},
Volume = {18},
Number = {5},
Month = {MAR 2},
Abstract = {Highlights What are the main findings? We generated the first
   high-resolution (30 m), long-term (2003-2024) forest carbon dynamics map
   for the topographically complex Three Parallel Rivers Region using a
   machine learning framework. A net forest carbon increase of 67.05 Tg was
   revealed, providing empirical evidence for the effectiveness of regional
   ecological protection policies. We identified the interaction between
   temperature and population density as the dominant driver of carbon
   storage spatial heterogeneity. What are the implications of the main
   findings? The study provides an effective reference for monitoring
   forest carbon sinks in globally complex terrains, which aids in
   supporting ecological management and conservation decision-making. It
   clarifies both the tangible carbon sequestration outcomes of ecological
   protection policies and the dominant driving mechanism of the
   ``temperature-population density{''} interaction, offering a scientific
   basis for formulating future differentiated and targeted policies to
   enhance carbon sequestration.Highlights What are the main findings? We
   generated the first high-resolution (30 m), long-term (2003-2024) forest
   carbon dynamics map for the topographically complex Three Parallel
   Rivers Region using a machine learning framework. A net forest carbon
   increase of 67.05 Tg was revealed, providing empirical evidence for the
   effectiveness of regional ecological protection policies. We identified
   the interaction between temperature and population density as the
   dominant driver of carbon storage spatial heterogeneity. What are the
   implications of the main findings? The study provides an effective
   reference for monitoring forest carbon sinks in globally complex
   terrains, which aids in supporting ecological management and
   conservation decision-making. It clarifies both the tangible carbon
   sequestration outcomes of ecological protection policies and the
   dominant driving mechanism of the ``temperature-population density{''}
   interaction, offering a scientific basis for formulating future
   differentiated and targeted policies to enhance carbon
   sequestration.Abstract Accurate estimation of forest aboveground carbon
   (AGC) is crucial for understanding the carbon cycle and formulating
   climate policies, yet it remains challenging in complex mountainous
   regions. This study used machine learning framework to estimate the
   spatiotemporal dynamics of AGC in the Three Parallel Rivers region of
   China from 2003 to 2024. By integrating China's National Forest
   Continuous Inventory (NFCI) data with multispectral satellite imagery,
   we employed a two-stage feature selection strategy to identify key
   predictor variables. Among three ensemble algorithms tested, the Random
   Forest model achieved the optimal performance (R2 = 0.74). The results
   indicated a net increase of 67.05 Tg in total AGC over the two decades,
   with a spatial pattern characterized by higher densities in the west and
   north. Geographical Detector analysis revealed that the driving forces
   were synergistic, with the interaction between temperature and
   population density exhibiting the most prominent explanatory capacity.
   This study provides a high-resolution (30 m) benchmark for AGC in a
   global biodiversity hotspot and underscores the critical role of
   ecological protection policies in enhancing carbon sequestration,
   offering valuable insights for managing similar mountain ecosystems
   worldwide.},
Type = {Article},
Affiliation = {Shu, QT (Corresponding Author), Southwest Forestry Univ, Coll Forestry, Kunming 650224, Peoples R China.
