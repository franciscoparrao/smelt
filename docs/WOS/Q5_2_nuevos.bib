@article{ WOS:001720194300001,
Author = {Bhomi, Arun Kumar and Poudyal, Rabina and Parajuli, Prawal and Upadhyay,
   Pradeep Kumar and Kawar, Yubraj},
Title = {Assessing coral reef changes through supervised classification and its
   correlation with SST and chlorophyll-a: A remote sensing approach},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {42},
Month = {APR},
Abstract = {This study demonstrates a multidisciplinary approach combining remote
   sensing, machine learning, and time series analysis to monitor coral
   reefs and investigate their relationship with environmental indicators,
   particularly sea surface temperature (SST) and chlorophyll indices. By
   applying supervised classification algorithms on freely accessible
   satellite imagery (Landsat 8 and Sentinel 2), coral/algae distribution
   maps were produced for the study area. Among the tested classifiers, the
   Support Vector Machine (SVM) model showed the highest validation
   performance based on references samples derived from the Allen Coral
   Atlas, with an overall accuracy if 91.81\% and a Kappa coefficient of
   0.90, and was therefore selected for the temporal analysis. Time series
   analysis, coupled with ARIMA modeling, was used to analyze trends in SST
   and predict future patterns, offering insights into potential
   environmental impacts on coral ecosystems. The findings revealed a weak
   negative correlation (r=-0.270) between coral reefs and SST, suggesting
   possible environmental influences on reef health. Additionally, a weak
   positive correlation (r=0.138-0.243) was observed between coral reefs
   and chlorophyll-A concentrations, suggesting a subtle but relevant
   connection between coral health and nutrient levels or water quality. By
   integrating supervised classification, and time series analysis, the
   research assessed the current and previous status of coral reefs. These
   results underscore the critical role of remote sensing in monitoring
   coral reefs and contribute valuable insights for developing effective
   conservation strategies. By utilizing open-source datasets and advanced
   analytical methods in a highbiodiversity region, this study demonstrates
   the effectiveness of cost-efficient approaches for monitoring coral
   reefs. Overall, the study advances the understanding of coral reef
   ecosystems and their response to environmental stressors, aiding in the
   preservation of these essential underwater habitats.},
Type = {Article},
Affiliation = {Bhomi, AK (Corresponding Author), Kathmandu Univ, Dept Geomat Engn, Dhulikhel, Nepal.
   Bhomi, Arun Kumar; Poudyal, Rabina; Parajuli, Prawal; Upadhyay, Pradeep Kumar; Kawar, Yubraj, Kathmandu Univ, Dept Geomat Engn, Dhulikhel, Nepal.},
DOI = {10.1016/j.rsase.2026.101976},
Article-Number = {101976},
Keywords = {Corals; Sea surface temperature; Chlorophyll-A; ARIMA model},
Author-Email = {arunbhomi12345@gmail.com},
Number-of-Cited-References = {18},
Times-Cited = {0},
Unique-ID = {WOS:001720194300001},
}

@article{ WOS:001717293200001,
Author = {Amodu, Oluwatosin Ahmed and Hanapi, Zurina Mohd and Mahmood, Raja Azlina
   Raja and Jarray, Chedia and Saif, Faten A. and Althumali, Huda and
   Bukar, Umar Ali and Adam, Mohammed Sani},
Title = {A systematic mapping and review on machine learning for non-terrestrial
   networks assisted Internet of Things: Enabling technologies},
Journal = {ICT EXPRESS},
Year = {2026},
Volume = {12},
Number = {2},
Pages = {422-443},
Month = {APR},
Abstract = {Non-terrestrial networks (NTNs), comprising unmanned aerial vehicles
   (UAVs), high-altitude platforms (HAPs), and satellites, are increasingly
   studied as complements to terrestrial infrastructures for extending
   connectivity to Internet of Things (IoT) devices and sensor networks.
   NTN-assisted IoT has been investigated across diverse application
   scenarios, including environmental monitoring, data collection,
   emergency response, intelligent transportation, disaster management,
   remote sensing, and smart city services. To address challenges such as
   energy constraints, dynamic network conditions, and heterogeneous
   communication links, a wide range of machine learning (ML) techniques
   have been explored, including deep learning, reinforcement learning,
   deep reinforcement learning, and federated learning. These methods have
   been applied to problems such as energy efficiency optimization,
   resource allocation, data collection, trajectory planning, task
   scheduling, and security enhancement. Given the rapid growth of this
   research area, with hundreds of related publications identified,
   developing a structured overview remains challenging. This paper
   addresses this need by presenting a largescale bibliometric and thematic
   cluster analysis of ML-based NTN-assisted IoT research with a focus on
   enabling technologies. The analysis organizes the literature into
   thematic clusters, examines co-occurrence patterns among enabling
   technologies and applications, and highlights recurring research
   directions and emerging topics such as edge intelligence, reconfigurable
   intelligent surfaces, non-orthogonal multiple access, digital twins, and
   explainable AI. Finally, the paper discusses current challenges and
   outlines potential directions for future research, with an emphasis on
   scalable and deployable NTN-assisted IoT systems.},
Type = {Review},
Affiliation = {Amodu, OA (Corresponding Author), Univ Putra Malaysia, Fac Comp Sci \& Informat Technol, Dept Commun Technol \& Network, Upm Serdang 43400, Selangor, Malaysia.
   Amodu, Oluwatosin Ahmed; Hanapi, Zurina Mohd; Mahmood, Raja Azlina Raja, Univ Putra Malaysia, Fac Comp Sci \& Informat Technol, Dept Commun Technol \& Network, Upm Serdang 43400, Selangor, Malaysia.
