   Ghezelbash, Reza, Univ Tehran, Coll Engn, Sch Min Engn, Tehran 1439957131, Iran.},
DOI = {10.1016/j.envsoft.2026.106883},
EarlyAccessDate = {FEB 2026},
Article-Number = {106883},
Keywords = {Bayesian-Hyperband tuning; AdaBoost; Mineral prospectivity mapping;
