Keywords = {Google earth engine; Electrical conductivity; Vegetation indices;
   Ensemble learning; Random forest; LightGBM},
Keywords-Plus = {TECHNOLOGY; RETRIEVAL},
Author-Email = {rajaranganathans@outlook.com},
