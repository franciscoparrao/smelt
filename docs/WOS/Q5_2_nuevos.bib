@article{ WOS:001685370200001,
Author = {Wang, Yixuan and Li, Peng and Bi, Naishuang and Wu, Xiao and Wang,
   Houjie},
Title = {Distribution pattern of carbon storage by native vegetation in the
   Yellow River Estuary},
Journal = {ESTUARINE COASTAL AND SHELF SCIENCE},
Year = {2026},
Volume = {332},
Month = {MAY},
Abstract = {Native vegetation plays a crucial role in wetland ecosystems, which in
   the Yellow River Estuary (YRE) is mainly composed of Phragmites
   australis (P. australis), Suaeda salsa (S. salsa) and Tamarix chinensis
   (T. chinensis). However, the rapid invasion of Spartina alterniflora (S.
   alterniflora) has caused significant damage to native vegetation. In
   2020, China launched the S. alterniflora remediation plan in the YRE.
   Here we investigated the impact of ecological management on native
   vegetation carbon storage in the YRE by generating a monthly 10-m
   resolution classification dataset of salt marsh vegetation, derived from
   multi-source remote sensing monthly composites images for 2019 and 2024.
   Field investigations and Google Earth Engine were employed to analyze
   changes in carbon storage across different vegetation communities, and
   the interannual dynamics from 2019 to 2024 were systematically assessed
   to evaluate the long-term effects of ecological management. Compared
   with Support Vector Machine and Gradient Boosting Decision Tree, the
   Random Forest presents the best performance with an overall accuracy of
   95.50\%. The results indicate that ecological management has led to
   significant changes in the distribution of native vegetation in the YRE,
   particularly in some areas once dominated by S. alterniflora. Carbon
   storage of P. australis and T. chinensis decreased, whereas that of S.
   salsa increased, especially along the eastern and northern intertidal
   zones. These spatial patterns may be associated with interspecific
   differences in salt tolerance and zonation along the salinity gradient.
   We suggest that S. salsa exhibits greater salt tolerance and
   environmental adaptability than P. australis and T. chinensis, appears
   better adapted to colonize high-salinity zones following the removal of
   S. alterniflora. The recovery of P. australis likely reflects both
   hydrological fluctuations and ecological management. Emphasizing the
   distinct responses and traits of different vegetation types is essential
   for promoting recovery and maintaining ecosystem stability in estuarine
   wetlands. As current management practices are maintained, S. salsa is
   likely to assume a more prominent role in the wetland carbon
   sequestration.},
Type = {Article},
Affiliation = {Wang, HJ (Corresponding Author), Ocean Univ China, Coll Marine Geosci, Key Lab Submarine Geosci \& Prospecting Technol, Minist Educ, Qingdao 266100, Peoples R China.
   Wang, Yixuan; Li, Peng; Bi, Naishuang; Wu, Xiao; Wang, Houjie, Ocean Univ China, Coll Marine Geosci, Key Lab Submarine Geosci \& Prospecting Technol, Minist Educ, Qingdao 266100, Peoples R China.
   Wang, Yixuan; Li, Peng; Bi, Naishuang; Wu, Xiao; Wang, Houjie, Qingdao Marine Sci \& Technol Ctr, Lab Marine Geol, Qingdao 266237, Peoples R China.},
DOI = {10.1016/j.ecss.2026.109740},
EarlyAccessDate = {FEB 2026},
Article-Number = {109740},
Keywords = {Coastal wetland; Carbon storage; Ecological management; Vegetation
   restoration; Yellow River Estuary},
Keywords-Plus = {PHRAGMITES-AUSTRALIS; TIME-SERIES; SALT; WETLANDS; DELTA; SALINITY;
   GROWTH; SOIL},
Author-Email = {hjwang@mail.ouc.edu.cn},
Number-of-Cited-References = {67},
Times-Cited = {0},
Unique-ID = {WOS:001685370200001},
}

@article{ WOS:001685899100001,
Author = {Derakhshan-Babaei, Farzaneh and Boloorani, Ali Darvishi and Mirghaed,
   Farhan Ahmadi and Alavi, Seyed Jalil and Dematte, Jose A. M. and Huang,
   Kan},
Title = {Assessment of land degradability and water quality in a semiarid region:
   Machine learning approach and multi scale analysis},
Journal = {JOURNAL OF ARID ENVIRONMENTS},
Year = {2026},
Volume = {234},
Month = {MAR},
Abstract = {A significant environmental challenge is to examine the relationship
   between agricultural land abandonment (ALA), land degradation, and soil
   properties, as well as their effects on water quality. This study
   developed a geo-environmental modeling approach to assess the
   connections between ALA, land degradability, and water quality in the
   Khuzestan Plain of southwestern Iran. The Random Forest (RF) was
   employed to map land degradability, and spatial correlation analysis was
   utilized to assess its relationship with water quality at various
   spatial scales during both dry and wet periods. The RF-based land
   degradability map revealed the presence of low to moderate land
   degradation in the region. The eastern and southeastern parts of the
   region exhibited the highest levels of degradation, while the central
   parts, as well as those in the north and west, demonstrated the least
   degradation. Severely degraded regions corresponded to abandoned
   agricultural lands. The Water Quality Index (WQI) results showed that
   54\% of water samples were classified as poor (50 <= WQI <75) during the
   dry period, while 96.5\% were deemed unsuitable (WQI >= 100) during the
   wet period. The correlation between land degradability and WQI was
   slightly stronger in the dry period, peaking at the 500 m buffer. This
   finding highlights the importance of collecting data from various
   sources for land degradability mapping, exploring different spatial and
   temporal scales of water quality, and comprehending the impact of buffer
   zones on land degradation. These insights are essential for effective
   water and land protection as well as the development of sustainable,
   nature-based policies.},
Type = {Article},
Affiliation = {Boloorani, AD (Corresponding Author), Univ Tehran, Fac Geog, Dept Remote Sensing \& GIS, Tehran, Iran.
   Derakhshan-Babaei, Farzaneh; Boloorani, Ali Darvishi, Univ Tehran, Fac Geog, Dept Remote Sensing \& GIS, Tehran, Iran.
   Mirghaed, Farhan Ahmadi, Univ Mazandaran, Fac Marine \& Environm Sci, Dept Environm Sci, Babolsar, Iran.
   Alavi, Seyed Jalil, Tarbiat Modares Univ, Fac Nat Resources \& Marine Sci, Noor 4641776489, Mazandaran, Iran.
   Dematte, Jose A. M., Univ Sao Paulo, Luiz de Queiroz Coll Agr, Dept Soil Sci, Sao Paulo, Brazil.
   Huang, Kan, Fudan Univ, Dept Environm Sci \& Engn, Shanghai Key Lab Atmospher Particle Pollut \& Preve, Natl Observat \& Res Stn Wetland Ecosyst Yangtze Es, Shanghai 200433, Peoples R China.},
DOI = {10.1016/j.jaridenv.2026.105562},
EarlyAccessDate = {FEB 2026},
Article-Number = {105562},
Keywords = {Land degradability; Water quality index; Random forest;
   Geo-environmental modelling; Soil properties; Remote sensing; Soil
   health},
Keywords-Plus = {APPARENT THERMAL INERTIA; SOIL ORGANIC-CARBON; AGRICULTURAL LAND;
