@article{ WOS:001696839300001,
Author = {Wang, Ran and Zhang, Junhua and Li, Guodong and Liu, Shu and Sun, Xixi
   and Wang, Shengxin and Shang, Hua},
Title = {Exploring the spatial distributions and driving factors of soil organic
   carbon in farmland of the Yellow River alluvial/sedimentary areas},
Journal = {SOIL \& TILLAGE RESEARCH},
Year = {2026},
Volume = {260},
Month = {AUG},
Abstract = {The alluvial/sedimentary areas of the Yellow River, a vital agricultural
   and population hub in China, face challenges in balancing intensive
   farming with soil organic carbon (SOC) depletion. Therefore, an accurate
   map of farmland SOC in this region is crucial to improving agricultural
   productivity and guaranteeing food security. Natural factors are crucial
   for SOC mapping, while farmland management, including crop rotation
   intensity and crop residue cover, also influences SOC storage in
   farmland. However, the quantitative impacts of farmland management on
   SOC dynamics remain poorly characterized at regional scales. To map
   regional farmland SOC and assess the effects of farmland management, we
   calculated crop rotation intensity from NDVI time series data and
   retrieved crop residue cover from Landsat images. Based on the extreme
   gradient boosting (XGBoost) model and Shapley additive explanation
   (SHAP) model, SOC was mapped in the study area and the interactions
   among multiple factors affecting SOC were analyzed. The findings
   indicated that: (1) compared to the baseline model without farmland
   management (XGBoost-B), the accuracy of the model with all variables
   (XGBoost-A) was improved, with R2 of 0.75. (2) The SOC distribution was
   low in the west and high in the east. Double-cropping systems generally
   exhibited higher SOC content than single-cropping systems, and farmland
   with higher crop residue cover showed a significant advantage in SOC
   accumulation. (3) The contribution of human activities to SOC prediction
   was second only to climate, and farmland management contributed the most
   among human activities. This highlighted the significant role of
   farmland management in enhancing the accuracy of farmland SOC
   predictions. Our results demonstrate that incorporating farmland
   management factors improves regional SOC mapping and highlights the
   potential of optimizing crop rotation and residue management to enhance
   soil carbon sequestration.},
Type = {Article},
Affiliation = {Zhang, JH (Corresponding Author), Henan Univ, Coll Geog Sci, Fac Geog Sci \& Engn, Zhengzhou 450046, Peoples R China.
   Zhang, JH (Corresponding Author), Henan Univ, Key Lab Geospatial Technol Middle, Lower Yellow River Reg Minist Educ, Kaifeng 475004, Peoples R China.
