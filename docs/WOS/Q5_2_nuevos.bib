@article{ WOS:001644570900001,
Author = {Katharria, Aashu and Pant, Millie and Velasquez, Juan D. and Snasel,
   Vaclav and Rajwar, Kanchan and Deep, Kusum},
Title = {Information fusion in smart agriculture: machine learning applications
   and future research directions},
Journal = {INFORMATION FUSION},
Year = {2026},
Volume = {129},
Month = {MAY},
Abstract = {This review presents a comprehensive analysis of machine learning (ML)
   applications in agriculture, with a particular emphasis on the
   increasing role of data fusion and advanced AI techniques in precision
   farming. It addresses a notable gap in existing surveys by providing an
   in-depth examination of the transition from traditional ML approaches to
   modern techniques, offering a cohesive synthesis of their evolution and
   impact. Structured around four key research objectives (RO-1 to RO-4),
   the study explores ML integration across pre-harvest, harvest, and
   post-harvest stages; demonstrates the benefits of multi-source data
   fusion, including remote sensing, IoT, and biological data for ML
   models; examines current research trends; and compiles essential public
   datasets to support future model development. The paper highlights the
   use of emerging methods, such as transformers, GANs, federated learning,
   continual learning, and explainable AI, in addressing modern
   agricultural challenges. Furthermore, the paper outlines challenges such
   as data heterogeneity, privacy, and infrastructure gaps, and proposes
   future research directions to guide sustainable and inclusive
   agricultural innovation.},
Type = {Article},
Affiliation = {Pant, M (Corresponding Author), Indian Inst Technol Roorkee, Mehta Family Sch Data Sci \& Artificial Intelligenc, Roorkee, Uttarakhand, India.
