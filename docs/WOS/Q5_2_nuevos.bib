}

@article{ WOS:001712274500001,
Author = {Son, Nguyen-Thanh and Syu, Chein-Hui and Chen, Chi-Farn and Chen,
   Cheng-Ru and Lin, Huan-Sheng and Zhang, Yi-Ting and Liu, Tsang-Sen and
   Yen, Chun-Chien},
Title = {Multi-source remote sensing for spatial mapping of salt-affected
   agricultural soils in Taiwan},
Journal = {APPLIED GEOMATICS},
Year = {2026},
Volume = {18},
Number = {1},
Month = {MAR 6},
Abstract = {Soil salinity and sodicity are significant environmental concerns
   contributing to land degradation, hampering plant growth, disrupting
   microbial functions, reducing crop yields, and limiting arable land for
   agriculture. Understanding these soil properties from spatiotemporal
   perspectives is essential for decision-makers to devise effective crop
   management and agricultural planning strategies. This study aims to
   develop an approach integrating multi-source remote sensing data with an
   emsenble random forest (ERF) for soil salinity and sodicity assessment
   in Taiwan. The data spanning from 2012 to 2020 were processed, and
   predicted electrical conducitivty (EC) and sodium adsorption ratio (SAR)
   results were validated against field observations, demonstrating a
   robust agreement with correlation coefficient (r) values of 0.78 and
   0.79, respectively. Although these models effectively captured the
   spatial patterns of soil salinity and sodicity, the root mean square
   error (RMSE) values of 1.04 and 1.4 for EC and SAR models indicated a
   room for further improving predictive accuracy and consistency. Salinity
   and sodicity classes derived from predicted results showed that slight
   salinity was widely distributed across the study region, whereas
   moderate to strong salinity and slight to moderate sodicity were more
   concentrated in low-lying coastal areas, highlighting the significant
   impact of saltwater intrusion and poor drainage. Finally, these salinity
   and sodicity classes were overlaid with township-level cultivated areas
   for targeted management interventions and improved agricultural
   practices.},
Type = {Article},
Affiliation = {Son, NT (Corresponding Author), Natl Cent Univ, Ctr Space \& Remote Sensing Res, Taoyuan 320317, Taiwan.
   Son, Nguyen-Thanh; Chen, Chi-Farn; Chen, Cheng-Ru; Lin, Huan-Sheng, Natl Cent Univ, Ctr Space \& Remote Sensing Res, Taoyuan 320317, Taiwan.
   Syu, Chein-Hui; Zhang, Yi-Ting; Liu, Tsang-Sen; Yen, Chun-Chien, Agr Res Inst Taiwan, Taichung 41362, Taiwan.},
DOI = {10.1007/s12518-026-00689-z},
Article-Number = {55},
Keywords = {Remote sensing; Ensemble random forest; Salt-affected soils; Taiwan},
Keywords-Plus = {MODIS TIME-SERIES; SALINITY ASSESSMENT; GLOBAL VEGETATION; INDEX;
   REGION; POTENTIALS; PREDICTION; REGRESSION; SODICITY; IMAGES},
Author-Email = {ntson@csrsr.ncu.edu.tw},
Number-of-Cited-References = {83},
Times-Cited = {0},
Unique-ID = {WOS:001712274500001},
}

@article{ WOS:001712360900001,
Author = {Singh, Kunwar Abhishek and Ryu, Dongryeol and Arora, Meenakshi and
   Tiwari, Manoj Kumar and Sahoo, Bhabagrahi},
Title = {Machine learning and remote sensing-based hierarchical framework for
   assessing non-optically observable riverine water quality parameters},
Journal = {JOURNAL OF HAZARDOUS MATERIALS ADVANCES},
Year = {2026},
Volume = {22},
Month = {MAY},
Abstract = {Optical Remote Sensing (RS)-based satellite imagery have been
   increasingly used for monitoring water quality in large riverine
   ecosystems, especially for water quality parameters with high optical
   sensitivity, such as suspended solids, turbidity and chlorophyll
   content. However, for non-optically observable components (NOOCs) of
   water quality, such as dissolved oxygen (DO), electrical conductivity
   (EC), biochemical oxygen demand (BOD), calcium (Ca2+), sulphate (SO42-),
   chloride (C1-), pH, and fecal coliform, their no direct correlation with
   reflectance of water necessitates the development of improved
   techniques. To address this, the present study demonstrated four
   hierarchical Machine Learning (ML) tool-integrated RS-based methods for
   assessing these NOOCs using Sentinel-2 (S2) imagery and reanalysis
   meteorological datasets as the proxy inputs. These ML tools
   included-Partial Least Squares Regression (PLSR), Random Forest
   Regression (RFR), Extreme Gradient Boosting (XGBoost), and Support
   Vector Regression (SVR), wherein the input datasets were the S2 data
   (bands, spectral indices), RS-derived total suspended solids (TSS) and
   turbidity, air temperature from the European Centre for Medium-Range
   Weather Forecasts Reanalysis version 5 (ERA5). To enhance the
   radiometric quality of Sentinel-2 imagery affected by clouds and cloud
   shadows, a Gaussian Mixture Model (GMM) was applied to mask the impacted
   pixels. These hierarchical methods were assessed in the
   urban-waste-dominated, ungauged lower reaches of the Ganges (Hooghly
   River) as a typical case. The results demonstrated that ML models using
   only remotely sensed and reanalysis temperature data can outperform
   models that incorporate ground-based measurements, underscoring the
   potential of remotely sensed and climate reanalysis inputs to assess the
   NOOCs. Examination of predictor variables using SHapely Additive
   exPlanations (SHAP) and Variance Importance in Projection (VIP) scores
   identified the influential predictors in estimating NOOCs. The proposed
   approach offers a replicable, scalable solution for assessing the
   non-optically observable water quality parameters in data-scarce and
   urban-impacted river systems.},
Type = {Article},
Affiliation = {Singh, KA (Corresponding Author), Indian Inst Technol Kharagpur, Sch Water Resources, Kharagpur 721302, W Bengal, India.
   Singh, KA (Corresponding Author), Indian Inst Technol Kanpur, Kotak Sch Sustainabil, Kanpur 208016, Uttar Pradesh, India.
   Singh, KA (Corresponding Author), Univ Melbourne, Dept Infrastructure Engn, Parkville, VIC 3010, Australia.
   Singh, Kunwar Abhishek; Sahoo, Bhabagrahi, Indian Inst Technol Kharagpur, Sch Water Resources, Kharagpur 721302, W Bengal, India.
   Singh, Kunwar Abhishek; Ryu, Dongryeol; Arora, Meenakshi, Indian Inst Technol Kanpur, Kotak Sch Sustainabil, Kanpur 208016, Uttar Pradesh, India.
   Singh, Kunwar Abhishek; Ryu, Dongryeol; Arora, Meenakshi, Univ Melbourne, Dept Infrastructure Engn, Parkville, VIC 3010, Australia.
   Tiwari, Manoj Kumar, Indian Inst Technol Kanpur, Ctr Environm Sci \& Engn, Kanpur 208016, Uttar Pradesh, India.
   Tiwari, Manoj Kumar, Indian Inst Technol Kanpur, Dept Civil Engn, Kanpur 208016, Uttar Pradesh, India.},
DOI = {10.1016/j.hazadv.2026.101111},
EarlyAccessDate = {MAR 2026},
Article-Number = {101111},
Keywords = {Non-optically observable parameters; Water quality; Remote sensing;
   Cloud masking; Gaussian mixture model; Machine learning},
Keywords-Plus = {AIR-TEMPERATURE; PHOSPHORUS; CLASSIFICATION},
Author-Email = {kunwar.iirs@kgpian.iitkgp.ac.in},
Number-of-Cited-References = {70},
