   chicas.daniel.santos.398@m.kyushu-u.ac.jp
   yscheng@csrsr.ncu.edu.tw
   mizoue.nobuya.277@m.kyushu-u.ac.jp
   s0243018@csrsr.ncu.edu.tw},
