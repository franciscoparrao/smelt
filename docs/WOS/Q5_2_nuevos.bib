   Andras, Peter, Matej Bel Univ Banska Bystrica, Fac Nat Sci, Banska Bystrica, Slovakia.},
DOI = {10.1080/27669645.2025.2490326},
Keywords = {Prediction; hazard zonation; geo hazards; Himalayas; machine learning},
