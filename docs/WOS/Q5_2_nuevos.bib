   Arafat, Ahmed A., Taif Univ, Coll Engn, Dept Civil Engn, POB 11099, Taif 21944, Saudi Arabia.},
DOI = {10.1038/s41598-026-37781-8},
Article-Number = {6549},
Keywords = {Land use change; Vegetation dynamics; Remote sensing; Normalized
   difference vegetation index (NDVI); Topographic wetness index (TWI);
   Semi-arid regions},
