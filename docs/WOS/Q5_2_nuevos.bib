DOI = {10.1038/s41598-026-39866-w},
Article-Number = {9383},
Keywords = {Grasslands; Rangelands; Machine learning; Satellite remote sensing;
   Biomass},
Author-Email = {sean.kearney@tbgpea.org},
Number-of-Cited-References = {39},
