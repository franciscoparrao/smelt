}

@article{ WOS:001587438000001,
Author = {Nxumalo, Nzuzo and Xulu, Sifiso and Nzimande, Ntombifuthi Precious},
Title = {Land use and land cover change dynamics and local perception in the
   Dolphin Coast, KwaZulu-Natal},
Journal = {COGENT SOCIAL SCIENCES},
Year = {2025},
Volume = {11},
Number = {1},
Month = {DEC 31},
Abstract = {The Earth's land cover is continuously modified by changes in land use
   driven by anthropogenic and biophysical factors. Anthropogenic
   activities play a dominant role in altering natural landscapes and
   resources, often leading to adverse environmental and socio-economic
   implications. Like many developing nations, South Africa has experienced
   rapid urbanisation, population, and economic growth, particularly in
   areas with high economic potential. Understanding Land Use and Land
   Cover (LULC) changes is crucial for assessing past land use patterns,
   identifying driving forces, and evaluating the broader implications of
   these changes. This study aims to assess LULC change patterns, identify
   their underlying drivers and evaluate their environmental and
   socio-economic implications in the Dolphin Coast, KwaZulu-Natal. The
   study employs RapidEye and PlanetScope images from 2009 to 2024,
   utilising Google Earth Engine and random forest algorithm for
   classification. Qualitative data was collected through semi-structured
   interviews with key informants and analysed using thematic analysis. The
   results showed major landscape changes from vegetation to built-up,
   barren to built-up, and vegetation to forests, with an overall accuracy
   between 88\% and 95\%. Respondents perceived a significant decline in
   agricultural land due to urban expansion, population growth, rural-urban
   migration, and inadequate land-use monitoring as primary drivers of LULC
   changes. Moreover, stakeholders highlighted critical implications,
   including biodiversity loss, and climate-related challenges such as
   flooding and pollution along the coastal region. These insights
   emphasise the need for proactive policies and sustainable urban planning
   to mitigate the impacts of LULC changes.},
Type = {Article},
Affiliation = {Nxumalo, N (Corresponding Author), Univ KwaZulu Natal, Dept Geog, Durban, South Africa.
   Nxumalo, Nzuzo; Xulu, Sifiso; Nzimande, Ntombifuthi Precious, Univ KwaZulu Natal, Dept Geog, Durban, South Africa.},
DOI = {10.1080/23311886.2025.2563785},
Article-Number = {2563785},
Keywords = {LULC changes; spatial-temporal analysis; local perceptions; random
   forest; Dolphin Coast; LULC changes; spatial-temporal analysis; local
   perceptions; random forest; Dolphin Coast},
Keywords-Plus = {RIVER},
Author-Email = {nzuzonxumalo06@gmail.com},
Number-of-Cited-References = {75},
Times-Cited = {2},
Unique-ID = {WOS:001587438000001},
}

@article{ WOS:001585126200001,
Author = {Li, Chen and Qiao, Weifeng and Tang, Juan and Qiu, Hua and Wu, Yan and
   Gao, Binpin},
Title = {Vegetation dynamics along an urban-rural gradient in the Yangtze River
   Delta: patterns, mechanisms, and scenario projections using a mixed-cell
   cellular automata (MCCA) framework},
Journal = {GISCIENCE \& REMOTE SENSING},
Year = {2025},
Volume = {62},
Number = {1},
Month = {DEC 31},
Abstract = {Understanding how the urban-rural gradient modulates vegetation dynamics
   under climate change and rapid urbanization is crucial for precise
   ecological management. However, existing research often uses coarse
   gradient classifications, while prevailing projection models are either
   limited by a lack of geospatial process simulation or constrained by the
   discrete-cell assumption, hindering their ability to capture the
   continuous nature of vegetation change. To address these challenges,
   this study adopts a six-zone urban-rural gradient classification
   (Natural-Agricultural-Rural-Suburban-Urban Expansion-Urban Core). Based
   on a systematic investigation of the spatiotemporal evolution and
   driving mechanisms of NDVI in the Yangtze River Delta, the mixed-cell
   cellular automata (MCCA) framework is migrated and extended from
   discrete land use simulation to continuous NDVI simulation. For this
   purpose, a development probability calculation strategy that couples
   historical trends with the natural background is employed to project
   future NDVI trends. The results indicate that: (1) From 2000 to 2022,
   the overall NDVI in the Yangtze River Delta increased but exhibited a
   complex ``U-shaped{''} spatial pattern along the urban-rural gradient,
   characterized by significant greening in the urban core and severe
   degradation in the urban expansion and suburban zones. Notably, the
   rural zone constituted the most extensive hotspot of vegetation
   degradation. (2) This pattern is shaped by a systematic shift in
   dominant drivers along the gradient and the dual role of socioeconomic
   factors, with the latter being closely linked to the planning
   orientations and land tenure systems in each gradient zone. (3) The
   adaptively modified MCCA model demonstrates its applicability,
   outperforming mainstream machine learning methods in both numerical
   accuracy and trend consistency, and is shown to be suitable for
   medium-to-short-term (approx. 10-12 years in this study) numerical
   projections and long-term trend analysis. (4) Future scenario
   projections for 2023-2035 show that, compared to the unstable SSP5-8.5
   pathway, the SSP2-4.5 pathway, despite higher localized degradation
   risks, promises more robust ecological recovery, better aligning with
   the region's sustainability goals. This study not only deepens the
   understanding of vegetation dynamics in complex urban-rural systems but
   also validates the feasibility of the MCCA framework as an effective
   tool for NDVI simulation, offering a new perspective for the predictive
   simulation of medium-to-short-term vegetation NDVI. The findings provide
   critical scientific support for formulating spatially differentiated and
   precise ecological governance strategies in rapidly urbanizing regions.},
Type = {Article},
Affiliation = {Qiao, WF (Corresponding Author), NanJing Normal Univ, Sch Geog, Nanjing, Peoples R China.
   Qiao, WF (Corresponding Author), Jiangsu Ctr Collaborat Innovat Geog Informat Resou, Nanjing, Peoples R China.
   Qiao, WF (Corresponding Author), Nanjing Normal Univ, Coll Rural Vitalizat, Nanjing, Peoples R China.
   Li, Chen; Qiao, Weifeng; Tang, Juan, NanJing Normal Univ, Sch Geog, Nanjing, Peoples R China.
