Title = {Research on the Impact of Agricultural Complexity Diagnosis on Crop
   Classification and Area Prediction Errors},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {3806-3818},
Abstract = {Cropland is essential for food provision, carbon fixation, soil
   protection, and water resource management. Remote sensing imagery plays
   a crucial role in cropland monitoring and food security. However, the
   accuracy of cropland classification varies significantly across
   different agricultural scenes, posing challenges for accurate mapping
   and area estimation. This study utilized multiple datasets with varying
   spatial resolutions (GaoFen-7: 0.65 m, 2.6 m; Gaofen-6: 8 m; Sentinel-2:
   10 m, 20 m; Landsat-9: 30 m) and employed diverse classifiers (random
   forest, decision trees, Gaussian Naive Bayes, K-nearest neighbors,
   parallel pipelines, support vector machines, deep neural network,
   recurrent neural network) to identify cropland. The mapping accuracy of
   different spatial resolutions and classifiers was compared across
   various agricultural scenes. In addition, a method for correcting the
   predicted arable land area has been proposed, which improved the
   accuracy of area predictions in the study area by 6\%, effectively
   enhancing the precision of remote sensing area statistics.},
