@article{ WOS:001583736600001,
Author = {Xie, Shuai and Zhang, Naijie and Liu, Liangyun and Sun, Lin},
Title = {Investigation of the spatio-temporal transferability of large-scale
   random forest crop classification models and potential influencing
   factors},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2025},
Volume = {18},
Number = {2},
Month = {DEC 31},
Abstract = {Training samples are crucial for remote-sensing-based crop
   classification; however, field surveys for data collection over large
   areas are costly and challenging. Model transfer offers a viable
   solution. This study evaluates the spatio-temporal transferability of
   machine learning models for large-scale crop classification and examines
   factors influencing classification performance across different training
   regions and years. A Random Forest model trained on Landsat/Sentinel-2
   time series and CDL crop labels from three U.S. states was applied to
   six European countries for crop mapping. Results showed that models
   trained in Kansas achieved high overall accuracy (88.1-96.8\%), with
   minimal accuracy variation (0.6-2.1\%) across training years,
   demonstrating strong adaptability. However, model performance varied
   significantly across training regions (up to 21.6\% accuracy
   difference), with Kansas outperforming Minnesota and South Dakota.
   Interestingly, models trained on merged regions or years performed worse
   than the best individual models, indicating that broader spatial or
   temporal training data cannot guarantee better transferability.
   Transferred models achieved accuracy comparable to locally trained
   models (<= 2.0\% difference). Temperature similarity between regions is
   a key factor, with greater annual temperature alignment leading to
   better transferability. This study offer a practical solution to
   large-area crop classification without local sample and guide the
   selection of optimal training areas.},
Type = {Article},
Affiliation = {Liu, LY (Corresponding Author), Chinese Acad Sci, Aerosp Informat Res Inst, Key Lab Digital Earth Sci, 9 Dengzhuang South Rd, Beijing 100094, Peoples R China.
   Xie, Shuai; Zhang, Naijie, Qingdao Univ Technol, Sch Informat \& Control Engn, Qingdao, Peoples R China.
   Liu, Liangyun, Chinese Acad Sci, Aerosp Informat Res Inst, Key Lab Digital Earth Sci, 9 Dengzhuang South Rd, Beijing 100094, Peoples R China.
   Sun, Lin, Shandong Univ Sci \& Technol, Coll Geodesy \& Geomatics, Qingdao, Peoples R China.},
DOI = {10.1080/17538947.2025.2563211},
Article-Number = {2563211},
Keywords = {Large-area; crop classification; spatio-temporal transferability; annual
   temperature pattern; google earth engine},
Keywords-Plus = {LAND-COVER CLASSIFICATION; PHENOLOGY},
Author-Email = {liuly@radi.ac.cn},
Number-of-Cited-References = {60},
Times-Cited = {0},
Unique-ID = {WOS:001583736600001},
}

@article{ WOS:001583749600001,
Author = {Aidoo, Kenneth and Tornyie, Ferdinand and Denton, Fatima and Gessner,
   Ursula and Owusu, Alex Barimah},
Title = {Assessment of multi-sensor approach to savanna landscape mapping in
   Ghana},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2025},
Volume = {40},
Number = {1},
Month = {DEC 31},
Abstract = {Land Use Land Cover (LULC) maps play an important role in land cover
   change assessment. In this study existing LULC maps of 2006 and 2015
   were used to develop a standardized LULC classification procedure for
   continuous mapping and land management. The same procedure was used to
   produce 2023 LULC map for the study area. Landsat 8, Sentinel-1, and
   Sentinel-2 were used in combination with a Random Forest algorithm to
   assess the potential of multi-sensor Earth observations in mapping
   savanna ecological zones in the Google Earth Engine (GEE). The
   classification results yielded an overall accuracy of 73.32\% and kappa
   coefficient of 0.6342 when integrating Landsat 8 and Sentinel-2 data. In
   addition, an overall accuracy of 80.21\% and kappa coefficient of 0.7225
   were obtained for the combined Landsat 8, Sentinel-2, and Sentinel-1
   data. The results demonstrated that using Sentinel-1 data in addition to
   multispectral data improved the classification accuracy by almost 7\%.},
Type = {Article},
Affiliation = {Aidoo, K (Corresponding Author), United Nations Univ, Inst Nat Resources Afr UNU INRA, Accra, Ghana.
   Aidoo, K (Corresponding Author), Univ Ghana, Dept Geog \& Resource Dev, Accra, Ghana.
   Aidoo, Kenneth; Tornyie, Ferdinand; Denton, Fatima, United Nations Univ, Inst Nat Resources Afr UNU INRA, Accra, Ghana.
   Aidoo, Kenneth; Owusu, Alex Barimah, Univ Ghana, Dept Geog \& Resource Dev, Accra, Ghana.
   Gessner, Ursula, German Aerosp Ctr DLR, German Remote Sensing Data Ctr DFD, Oberpfaffenhofen, Germany.},
DOI = {10.1080/10106049.2025.2555444},
Article-Number = {2555444},
Keywords = {Land use land cover; savanna ecological zone; multi-sensor; random
   forest; Google earth engine},
Keywords-Plus = {RANDOM FOREST; CLASSIFICATION; INDEX; FEATURES},
