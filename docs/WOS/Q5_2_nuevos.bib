@article{ WOS:001701898900001,
Author = {Li, Bingjie and Liu, Xiaoping and Zhuang, Haoming and Shi, Qian and
   Zeng, Li and Cai, Yiling and Zhang, Honghui and Cai, Yaotong and Wu,
   Changjiang and Xu, Xiaocong},
Title = {ALCC: Temporally Consistent Annual Land Cover Maps over China from 1985
   to 2022 Based on an Ensemble Change Detection Method},
Journal = {JOURNAL OF REMOTE SENSING},
Year = {2026},
Volume = {6},
Month = {FEB 27},
Abstract = {Long-term and consistent annual land cover products with high spatial
   resolution are essential for environment and climate modeling,
   biodiversity conservation, and sustainable development. However, current
   land cover products, typically produced independently each year, lack
   interannual consistency and do not adequately meet the requirements of
   many applications. Here, we developed temporally consistent annual land
   cover maps for China (ALCC) from 1985 to 2022. Specifically, we
   developed an ensemble change detection algorithm, which integrates the
   Continuous Change Detection and Classification, the Breaks for Additive
   Season and Trend monitor, and the Chow Test algorithms to identify
   changes in Landsat time-series data. Subsequently, the local-specific
   random forest classifier trained with stable training samples was
   adopted to update land cover information for changed areas. ALCC
   achieved a mean overall accuracy of 81.18\% +/- 0.79\% nationwide and
   exceeded 72.00\% across 7 geographical regions based on a multiperiod
   validation set, surpassing the performance of 4 existing annual land
   cover products (i.e., CLCD, GLC\_FCS30D, CLUD-A, and ESA-CCI LC).
   Furthermore, ALCC demonstrated superior performance compared to previous
   land cover products in areas with moderate (8.52\% to 34.24\%) and high
   (22.83\% to 29.10\%) inconsistency. Year-to-year change analysis
   revealed robust temporal consistency of ALCC, which identified more
   genuine change events than CLUD-A while exhibiting fewer spurious
   changes than CLCD and GLC\_FCS30D. A spatiotemporal pattern analysis
   based on ALCC highlighted several substantial land cover changes
   nationwide, including expansions of impervious surfaces (270.16\%),
   water (20.71\%), and forest (7.12\%), and losses of cropland (11.28\%)
   and grassland (4.44\%).},
Type = {Article},
