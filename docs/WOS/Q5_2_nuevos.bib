   Shi, Yue, Manchester Metropolitan Univ, Fac Sci \& Engn, Dept Comp \& Math, John Dalton Bldg,Chester St, Manchester M1 5GD, England.},
DOI = {10.1016/j.srs.2025.100344},
EarlyAccessDate = {DEC 2025},
Article-Number = {100344},
Keywords = {Crop yield prediction; High-resolution yield map; Earth observation;
   Machine learning; Tabular foundation models},
