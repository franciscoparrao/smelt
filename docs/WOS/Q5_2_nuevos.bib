}

@article{ WOS:001720196000001,
Author = {Gaur, Anmol and Deb, Chirag},
Title = {Machine learning methods and approaches for Urban Heat Island (UHI)
   assessment: A comprehensive review},
Journal = {RENEWABLE \& SUSTAINABLE ENERGY REVIEWS},
Year = {2026},
Volume = {234},
Month = {JUL},
Abstract = {The Urban Heat Island (UHI) effect is a phenomenon in which urban areas
   experience significantly higher temperatures than their surrounding
   regions due to human activities and the built environment. This poses
   challenges to urban systems, living conditions, and exacerbate air
   pollution in urban areas. Over the years, the use of Machine Learning
   (ML) to study the UHI effect has increased, driven by advances in
   computational power, high predictive accuracy, and the growing
   availability of large-scale, environmental datasets. This study aims to
   comprehensively review the application and role of ML in addressing the
   UHI effect. The key findings of this review show that the application of
   ML can be categorized into: land surface temperature (LST) retrieval and
   prediction, land use land cover (LULC) classification and change
   detection, UHI intensity and pattern modelling, and mitigation strategy
   assessment. The most common application is the derivation and prediction
   of LST in conjunction with physical and climatic variables such as
   building energy consumption, air temperature, human thermal comfort, and
   wind movement. Our findings further show that ML is effectively utilized
   in multi-temporal investigations and predictive modelling, assessing
   energy demand surges, and validating the efficacy of cooling
   interventions. We also outline the key challenges faced in implementing
   ML in this realm, including aerial data accessibility, data
   pre-processing complexities, modelling sophistication or UHI, and lack
   of ground truth data for validation. This review sets the stage for
   future use of ML, including emerging Artificial Intelligence (AI) -
   driven methods that could change how we understand and mitigate UHI
   effects.},
Type = {Article},
Affiliation = {Deb, C (Corresponding Author), Univ Sydney, Sch Architecture Design \& Planning, Sydney, Australia.
   Gaur, Anmol, Indian Inst Technol, Dept Energy Sci \& Engn, Mumbai 400076, India.
   Deb, Chirag, Univ Sydney, Sch Architecture Design \& Planning, Sydney, Australia.},
DOI = {10.1016/j.rser.2026.116903},
Article-Number = {116903},
Keywords = {Machine learning; Urban heat island (UHI); Land surface temperature
   (LST); Remote sensing; UHI mitigation; AI},
Keywords-Plus = {LAND-SURFACE TEMPERATURE; MITIGATION TECHNOLOGIES; ENERGY-CONSUMPTION;
   RANDOM FOREST; CLIMATE; VEGETATION; DEMAND; COVER; AREAS},
Author-Email = {chirag.deb@sydney.edu.au},
Number-of-Cited-References = {101},
Times-Cited = {0},
Unique-ID = {WOS:001720196000001},
}

@article{ WOS:001708055900001,
Author = {Li, Guoxu and Zhang, Yonglin and Sun, Tianle and Wang, Li and Huang, Bo
   and Song, Wanjuan and Bo, Yong and Wang, Ke and Xiong, Xiangyun and Xu,
   Shiguang and Yao, Lingyun and Zhang, Jianwen and Niu, Zheng},
Title = {Road network CO2 concentration prediction and driving factors
   analysis based on vehicle-cruising observations and machine learning in
   Shenzhen, China},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2026},
Volume = {19},
Number = {1},
Month = {JUL 1},
Abstract = {Enhanced urban CO2 monitoring and understanding its spatiotemporal
   patterns and driving factors are essential for emission management and
   climate change mitigation. This study developed a high-resolution
   framework for predicting and mapping CO2 concentrations within the road
   network of Shenzhen by integrating vehicle-cruising observations,
   street-view panoramas, and multisource remote sensing data. The proposed
   machine learning model demonstrated strong predictive performance (R \&
   sup2; = 0.92). Furthermore, the effects of urban function, urban
   development intensity, traffic conditions, and environmental factors on
   CO2 concentrations were systematically examined using explainable
   machine learning techniques. The results indicate that in urban centres,
   human activities exert a substantial influence on CO2 levels. Effective
   non-motorway planning, accessible public transport systems, and
   diversified urban functions are associated with lower CO2
   concentrations. Notably, areas with high vegetation cover were also
   found to exhibit elevated CO2 concentrations, and the influence of
   greenery on Shenzhen's CO2 levels was positive in November. By
   integrating multisource data from the perspectives of the urban
   landscape and street configuration, this study provides an interpretable
   approach for analysing the complex drivers of urban CO2 dynamics.
   Overall, the findings establish a cost-effective methodological
   framework for refined urban carbon monitoring and offer actionable
   insights to support low-carbon urban planning and evidence-based policy
   formulation.},
Type = {Article},
Affiliation = {Wang, L (Corresponding Author), 20A Datun Rd North, Beijing 100101, Peoples R China.
   Li, Guoxu; Zhang, Yonglin; Wang, Li; Song, Wanjuan; Bo, Yong; Wang, Ke; Xu, Shiguang; Yao, Lingyun; Niu, Zheng, Chinese Acad Sci, Aerosp Informat Res Inst, State Key Lab Remote Sensing \& Digital Earth, Beijing, Peoples R China.
   Li, Guoxu; Bo, Yong, Univ Chinese Acad Sci, Coll Resources \& Environm, Beijing, Peoples R China.
   Sun, Tianle; Xiong, Xiangyun, Shenzhen Environm Monitoring Ctr Guangdong Prov, Shenzhen, Peoples R China.
   Huang, Bo, Univ Hong Kong, Dept Geog, Hong Kong, Peoples R China.
   Zhang, Jianwen, China Univ Geosci Beijing, Sch Land Sci \& Technol, Beijing, Peoples R China.
   Niu, Zheng, Univ Chinese Acad Sci, Beijing, Peoples R China.},
DOI = {10.1080/17538947.2026.2639802},
Article-Number = {2639802},
Keywords = {Carbon dioxide prediction; explainable machine learning; street-view
   panoramas; multisource remote sensing data.},
Keywords-Plus = {CARBON-DIOXIDE; STREET CANYON; URBAN; ENVIRONMENTS; CITIES},
