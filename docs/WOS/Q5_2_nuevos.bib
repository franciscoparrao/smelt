   Bartlett, Nicole D., NOAA, Woods Hole, MA 02543 USA.
   Wiltsie, Daniel; Sullivan, Sully; Schaeffer, Blake A., US Environm Protect Agcy, Off Res \& Dev, Durham, NC 27701 USA.},
DOI = {10.1016/j.rsase.2026.101902},
EarlyAccessDate = {FEB 2026},
