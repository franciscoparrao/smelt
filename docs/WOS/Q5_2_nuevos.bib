@article{ WOS:001724036200001,
Author = {Odebiri, Omosalewa and Young, Mary},
Title = {Towards operational benthic habitat monitoring: Integrating Sentinel-2,
   bathymetry, and environmental drivers in Port Phillip Bay, Australia},
Journal = {JOURNAL OF ENVIRONMENTAL MANAGEMENT},
Year = {2026},
Volume = {404},
Month = {APR 15},
Abstract = {Coastal benthic habitats provide vital ecological and economic services
   but face accelerating degradation. Effective management requires
   accurate habitat maps and a mechanistic understanding of environmental
   drivers. However, current machine learning (ML) approaches often produce
   ``black-box{''} predictions with limited ecological interpretability and
   fail to integrate the full suite of multi-scale environmental drivers
   known to structure temperate benthic systems. This study addresses these
   gaps by developing an integrated remote sensing and explainable
   artificial intelligence (AI) framework to map temperate benthic habitats
   and quantify their environmental drivers in Port Phillip Bay, Australia.
   We combined Sentinel-2 imagery, bathymetry, and oceanographic variables
   within Google Earth Engine (GEE) to train a Random Forest (RF)
   classifier, achieving an overall accuracy of 0.78 for eight benthic
   habitat classes. Crucially, we applied SHapley Additive exPlanations
   (SHAP) to transform the model into an interpretable ecological tool,
   revealing non-linear responses and critical thresholds. Elevation (depth
   proxy) was the primary driver, followed by summer sea surface
   temperature (SST), wave exposure, and turbidity. We identified distinct
   thermal niches: macroalgae thrived in warmer waters (>18 degrees C),
   while seagrass preferred cooler conditions. Seagrass exhibited a
   unimodal response to turbidity, peaking at moderate turbidity (similar
   to 0.7), and wave exposure defined clear zonation between sheltered
   algal habitats and exposed reef communities. Notably, water-column
   correction did not improve accuracy, highlighting the value of
   integrating bathymetry and terrain derivatives in moderately shallow,
   well-mixed systems. Our framework delivers not only a contemporary
   habitat map but also a transparent, reproducible model of ecosystem
   structure. By bridging remote sensing and mechanistic ecology, this work
   provides a scalable approach for operational monitoring, vulnerability
   assessment, and evidence-based conservation in temperate coastal
   ecosystems.},
Type = {Article},
Affiliation = {Odebiri, O (Corresponding Author), Deakin Univ, Sch Life \& Environm Sci, Melbourne, Vic 3125, Australia.
   Odebiri, Omosalewa; Young, Mary, Deakin Univ, Sch Life \& Environm Sci, Melbourne, Vic 3125, Australia.},
DOI = {10.1016/j.jenvman.2026.129418},
Article-Number = {129418},
Keywords = {Benthic habitat mapping; Explainable AI; Remote sensing; Sentinel-2;
   Embayments; Environmental drivers; Seagrass; Macroalgae},
Keywords-Plus = {SEAGRASSES; DIVERSITY; SATELLITE; GROWTH; DEPTH},
Author-Email = {omosalewa.odebiri@deakin.edu.au},
Number-of-Cited-References = {93},
Times-Cited = {0},
Unique-ID = {WOS:001724036200001},
}

@article{ WOS:001722680900001,
Author = {Ben Miled, Achraf and Kouki, Fadoua and Alghamdi, Abdulaziz G. and
   Begum, S. Sabarunisha and Ghorashi, Sara Abdelwahab and Sorour, Shaymaa
   and Sikkandar, Mohamed Yacin and Sivakumar, Vivek},
Title = {Mapping coastal wetland biodiversity and ecosystem services using
   hyperspectral data and machine learning},
Journal = {REGIONAL STUDIES IN MARINE SCIENCE},
Year = {2026},
Volume = {96},
Month = {APR},
Abstract = {Coastal wetlands are vital ecosystems that support high biodiversity and
   multiple ecosystem services but are increasingly vulnerable to
   urbanization and climate change. This study focuses on mapping wetland
   biodiversity and ecosystem services along the Kochi Coast using
   high-resolution hyperspectral remote sensing data integrated with
   machine learning techniques. Support Vector Machine (SVM) and Random
   Forest (RF) classifiers were applied to classify land cover types
   including water, vegetation, wetlands, cropland, built-up areas,
   bareland, and rangelands for 2020-2021. Various combinations of spectral
   indices and derived variables were tested to optimize classification
   accuracy. Results revealed that RF performed better than SVM across all
   combinations, particularly in detecting wetlands, where RF achieved
   user's and producer's accuracies of 91.1\% and 89.7\%, respectively,
   compared to 87.6\% and 81.9\% for SVM. The highest overall accuracy
   (96.4\%) and Kappa coefficient (0.96) were recorded under RF combination
   D, indicating near-perfect classification. These findings underscore the
   effectiveness of hyperspectral imagery and RF models for precise coastal
   wetland mapping, contributing significantly to monitoring biodiversity
   loss and guiding sustainable coastal management strategies. The approach
   highlights the potential of combining advanced remote sensing and
   machine learning for enhancing ecological modelling and ecosystem
   service assessment in complex coastal environments, and provides a
   transferable framework for wetland monitoring in other rapidly
   urbanizing coastal regions.},
Type = {Article},
Affiliation = {Sikkandar, MY (Corresponding Author), Majmaah Univ, Coll Appl Med Sci, Dept Med Equipment Technol, Al Majmaah 11952, Saudi Arabia.
