DOI = {10.1080/17538947.2025.2553796},
Article-Number = {2553796},
Keywords = {Winter wheat; wheat mildew index; machine learning; automatic threshold
   segmentation algorithm; Gaofen-2},
Keywords-Plus = {MEANS CLUSTERING-ALGORITHM; IMAGE},
