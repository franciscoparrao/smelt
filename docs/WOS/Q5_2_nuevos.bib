@article{ WOS:001717553500023,
Author = {Meng, Qingji and Zang, Shuying and Zhu, Bingxue and Liu, Lushi and Song,
   Kaishan},
Title = {A Novel Spectral Index for Mapping Sunflowers Using Sentinel-2 Imagery},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {As a globally significant oilseed and economic crop, accurately mapping
   the spatial distribution of sunflowers is crucial for ensuring food
   security. However, existing sunflower classification models are often
   complex in design, and specialized vegetation indices (VIs) remain
   relatively scarce. Therefore, there is an urgent need to develop simple,
   efficient, and precise identification methods. This study introduces the
   sunflower identification index (SII), developed using the RE2 band,
   which is sensitive to chlorophyll variation, and the shortwave infrared
   2 (SWIR2) band, which reflects differences in canopy water content. The
   SII provides critical spectral information necessary for distinguishing
   sunflowers from other crops. The effectiveness of the SII was evaluated
   in three major sunflower-producing countries-China, Ukraine, and
   France-across three representative sunflower-growing regions, each
   characterized by distinct climatic conditions and farming systems. The
   results indicate that in the Hetao Irrigation District (S1) in 2023, the
   classification accuracy of SII (overall accuracy (OA) = 94.39\% and
   Kappa coefficient (Kappa) = 0.89) was significantly higher than that of
   the normalized difference vegetation index (NDVI) and the green NDVI
   (GNDVI). Furthermore, the SII continued to exhibit excellent performance
   when applied across different years and regions (the Ukrainian site (S2)
   and Toulouse (S3) in 2022, S1 in 2021, and S3 in 2020). Finally, the SII
   was employed in binary classification using both the random forest (RF)
   and support vector machine (SVM) algorithms, yielding satisfactory
   results (OA > 90\% and Kappa >= 0.81 ). These findings demonstrate that
   the SII possesses strong spatiotemporal transferability capabilities and
   robustness, allowing it to maintain high stability in complex and
   dynamic agricultural environments. In the future, integrating the SII
   with deep learning (DL) algorithms is expected to further enhance
   classification accuracy.},
Type = {Article},
Affiliation = {Zang, SY (Corresponding Author), Harbin Normal Univ, Heilongjiang Prov Key Lab Geog Environm Monitoring, Harbin 150025, Peoples R China.
