@article{ WOS:001687063800001,
Author = {Wang, Huaqing and Zhao, Xingchen and Gholami, Simin and McGinty,
   Christopher and Chamberlain, Brent and Qi, Xiaojun},
Title = {A hybrid deep learning and NDVI threshold approach for high-resolution
   urban greenspace classification},
Journal = {URBAN FORESTRY \& URBAN GREENING},
Year = {2026},
Volume = {118},
Month = {APR},
Abstract = {Accurate urban greenspace mapping is essential for effective
   environmental monitoring and urban planning. Traditional methods, such
   as the Normalized Difference Vegetation Index (NDVI) threshold, have
   been widely used for vegetation classification due to their proven
   accuracy. However, these approaches often rely on subjective threshold
   selection, which can be labor-intensive and prone to investigator bias.
   Deep learning techniques provide a promising alternative, enabling
   automated, high-resolution image classification that can capture more
   complex vegetation patterns. Nevertheless, deep learning models
   typically require large training datasets to achieve optimal accuracy
   and can struggle with classifying vegetation that deviates from typical
   green hues, such as those with yellow, purple, or red leaves. In this
   study, we present a novel hybrid approach to urban greenspace
   classification and segmentation that integrates deep learning with
   traditional NDVI threshold methods to improve classification accuracy
   for high-resolution satellite imagery from the National Agriculture
   Imagery Program. By utilizing a relatively small dataset of 122 training
   images, we developed a deep-learning-based NDVI threshold model, which
   was then applied to classify 2021 0.6-meter resolution NAIP imagery for
   the State of Utah, US. Our results demonstrate that this hybrid approach
   outperforms both standalone deep learning models and traditional NDVI
   threshold methods, providing a highly accurate classification of
   greenspace, including vegetation with non-green hues, with significantly
   smaller training data and no supervision. In our accuracy assessment,
   VegClassify achieved an overall accuracy of 88.02 \% and a Kappa
   coefficient of 72.74, significantly outperforming the widely used Random
   Forest classifier, which achieved an accuracy of 82.21 \% and a Kappa
   coefficient of 59.44. A Python package called ``VegClassify{''} of this
   model is offered on GitHub, and the classified 0.6-meter resolution
   greenspace land cover map for the State of Utah is offered via Zenodo
   repository, both of which are publicly accessible.},
Type = {Article},
Affiliation = {Wang, HQ (Corresponding Author), Utah State Univ, Dept Landscape Architecture \& Environm Planning, 4005 Old Main Hill, Logan, UT 84322 USA.
   Wang, Huaqing; Gholami, Simin; Chamberlain, Brent, Utah State Univ, Dept Landscape Architecture \& Environm Planning, 4005 Old Main Hill, Logan, UT 84322 USA.
   Zhao, Xingchen; Qi, Xiaojun, Utah State Univ, Dept Comp Sci, Logan, UT 84322 USA.
   McGinty, Christopher, Utah State Univ, Dept Wildland Resources, Logan, UT 84322 USA.},
DOI = {10.1016/j.ufug.2026.129332},
EarlyAccessDate = {FEB 2026},
Article-Number = {129332},
Keywords = {Land Cover; Remote Sensing; Urban Nature; Image Segmentation},
Keywords-Plus = {SPACES},
Author-Email = {huaqing.wang@usu.edu},
Number-of-Cited-References = {41},
