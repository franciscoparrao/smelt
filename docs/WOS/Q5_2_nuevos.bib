   Alghamdi, Abdulaziz G., King Saud Univ, Coll Food \& Agr Sci, Dept Soil Sci, Riyadh 11451, Saudi Arabia.
   Alsolai, Hadeel, Princess Nourah Bint Abdulrahman Univ, Coll Comp \& Informat Sci, Dept Informat Syst, Riyadh 11564, Saudi Arabia.},
DOI = {10.1007/s12601-026-00274-w},
Article-Number = {22},
Keywords = {Machine learning; Water quality monitoring; Chlorophyll-a; Turbidity;
   Dissolved oxygen; Bay of La Paz},
Keywords-Plus = {SATELLITE DATA; HONG-KONG; ALGORITHMS; ESTUARINE; POLLUTION; NETWORK;
