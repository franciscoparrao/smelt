}

@article{ WOS:001649062900004,
Author = {Nanda, Radhikesh Prasad and Yadav, Aditya Kumar and Kumar, Aman},
Title = {Landslide hazard mapping of Darjeeling using GIS and ensemble machine
   learning model},
Journal = {SADHANA-ACADEMY PROCEEDINGS IN ENGINEERING SCIENCES},
Year = {2025},
Volume = {51},
Number = {1},
Month = {DEC 27},
Abstract = {Landslides are among the most destructive natural hazards in mountainous
   regions, posing severe threats to life, infrastructure, and the
   environment. The Darjeeling district in the eastern Himalayas is highly
   prone to landslides due to its steep slopes, intense monsoonal rainfall,
   rapid urbanization, and deforestation. This study aims to assess
   landslide susceptibility in the Darjeeling region using a Geographic
   Information System (GIS)-based framework integrated with advanced
   machine learning (ML) techniques. A total of six ML classifiers-Support
   Vector Machine (SVM), Na \& iuml;ve Bayes (NB), Decision Tree Classifier
   (DTC), K-Nearest Neighbors (KNN), Logistic Regression (LRG), and Random
   Forest Classifier (RFC)-were implemented and evaluated using a dataset
   of eleven landslide conditioning factors, including elevation, slope,
   aspect, land use/land cover (LULC), rainfall, and proximity to drainage
   and roads. These models were trained and validated using a 70:30 split
   of the dataset, and their performances were assessed using accuracy,
   precision, recall, F1-score, and AUC metrics. To improve prediction
   robustness, an ensemble model was developed by combining the six
   individual models using a soft voting approach. The ensemble model
   achieved the highest predictive performance, with an overall accuracy of
   94\% and AUC of 0.94 during the training phase, and maintained strong
   validation performance across all evaluation metrics. This model was
   then applied to generate a landslide susceptibility map for the
   Darjeeling district, producing pixel-wise probabilistic outputs that
   were classified into five risk categories: Very Low, Low, Moderate,
   High, and Very High. The resulting map provides a spatially detailed
   representation of landslide-prone areas and can serve as a valuable tool
   for regional planning, disaster risk reduction, and policy development.
   The findings highlight the effectiveness of ensemble machine learning
   techniques for accurate and interpretable landslide susceptibility
   mapping in complex and data-sensitive terrain.},
Type = {Article},
Affiliation = {Nanda, RP (Corresponding Author), Natl Inst Technol, Dept Civil Engn, Durgapur, West Bengal, India.
   Nanda, Radhikesh Prasad; Yadav, Aditya Kumar; Kumar, Aman, Natl Inst Technol, Dept Civil Engn, Durgapur, West Bengal, India.},
DOI = {10.1007/s12046-025-03025-0},
Article-Number = {3},
Keywords = {Landslide; susceptibility map; machine learning; causative factors;
   slope; accuracy},
Keywords-Plus = {RAINFALL-INDUCED LANDSLIDES; HEURISTIC APPROACH; SUSCEPTIBILITY;
   VALIDATION; PREDICTION; DISTRICT; HIMALAYA; WEIGHT; ZONE; AREA},
Author-Email = {rpnanda.ce@nitdgp.ac.in
   yadavadityak2002@gmail.com
