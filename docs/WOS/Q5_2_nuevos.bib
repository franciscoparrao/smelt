DOI = {10.1016/j.rsase.2026.101915},
Article-Number = {101915},
Keywords = {Enhanced bloom index (EBI); Normalized difference vegetation index
   (NDVI); Sentinel-2; Time series peak analysis; Peak bloom in almond
   orchards},
Keywords-Plus = {HEAT REQUIREMENTS; PHENOLOGY; TEMPERATURE; CULTIVARS; CHILL; NDVI},
Author-Email = {tarin@bgu.ac.il},
