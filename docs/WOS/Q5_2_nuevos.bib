@article{ WOS:001687347500006,
Author = {Dong, Xuegang and Meng, Zhiguo and Zang, Shuying and Tang, Tianqi and
   Cai, Zhanchuan and Zhang, Xiaoping and Xu, Yi},
Title = {A New Framework for Mapping Lunar Mare Basalt Units Using Passive
   Microwave Data: A Case Study in Mare Imbrium},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Mare basalts are products of partial mantle melting, and their
   spatiotemporal distribution provides key constraints on the thermal
   evolution of the Moon. Conventional mapping from optical data is
   hindered by space weathering, ejecta contamination, and inconsistent
   criteria. To address these issues, this study introduces a new framework
   that integrates multichannel, multitemporal brightness temperature (TB)
   features derived from a 24-h complete TB dataset of the Chang'e-2 (CE-2)
   microwave radiometer (MRM) with the random forest (RF) algorithm.
   Applied to Mare Imbrium, the framework achieves high sample-level
   accuracy and, with hierarchical clustering, effectively reduces
   interunit patchiness. Compared with previous optical- and radar-based
   interpretations, the resulting geological map redefines basalt unit
   boundaries at the MRM pixel scale (0.125 degrees), refines stratigraphic
   relationships, and reveals regolith thermophysical variations linked to
   impact modification and volcanic resurfacing. These results highlight
   the potential of passive microwave remote sensing to bridge surface and
   subsurface observations and provide a reproducible and traceable
   framework for planetary geological mapping.},
Type = {Article},
Affiliation = {Zang, SY (Corresponding Author), Harbin Normal Univ, Coll Geog Sci, Harbin 150025, Peoples R China.
