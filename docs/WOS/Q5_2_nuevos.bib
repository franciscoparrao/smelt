Affiliation = {Shandu, ID (Corresponding Author), Univ KwaZulu Natal, Sch Agr \& Sci, Durban, South Africa.
   Shandu, Irvin D.; Xulu, Sifiso; Gebreslasie, Michael, Univ KwaZulu Natal, Sch Agr \& Sci, Durban, South Africa.
   Xulu, Sifiso, Univ South Africa, Dept Geog, Florida Campus, Johannesburg, South Africa.},
DOI = {10.3389/frsen.2025.1697897},
Article-Number = {1697897},
Keywords = {auxiliary features; land use and land cover classification; random
