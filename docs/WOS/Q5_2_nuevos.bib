@article{ WOS:001662945100033,
Author = {Meng, Qiaona and Leau, Yu-Beng and Shi, Jinmei and Zhou, Jinghe},
Title = {Multi-Source Remote Sensing Data Fusion for Aboveground Biomass
   Estimation in Tropical Forests: Recent Advances, Challenges, and Future
   Trends},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {4688-4732},
Abstract = {Accurate estimation of aboveground biomass (AGB) in tropical forests is
   critical for global carbon cycle research and climate policies such as
   REDD+, but single remote sensing sources face limitations: optical
   sensors suffer from saturation and cloud interference, SAR has
   saturation and terrain-induced distortions, and lidar (e.g., GEDI)
   provides high-precision vertical structures but sparse coverage.
   Multi-source data fusion - including data-level, feature-level,
   decision-level fusion, and spatio-temporal scaling - leverages the
   complementary strengths of optical, SAR, and LiDAR data to mitigate
   these issues, machine learning (e.g., RF, XGBoost) and deep learning
   (e.g., CNN, Transformer) to improve performance, and hybrid models to
   balance learning ability and robustness. Key challenges including data
   heterogeneity, geometric/radiometric inconsistencies, saturation in
   dense forests, cloud-induced optical data loss, and sparse GEDI
   footprints are addressed through validation frameworks (involving forest
   maps, NFI, airborne LiDAR) and uncertainty quantification methods (e.g.,
   spatial cross-validation, Monte Carlo simulations). Regional case
   studies (Amazon, Congo Basin, Southeast Asia) show optimal strategies
   for specific environments, while future directions focus on
   collaborative GEDI with P-band SAR, dynamic monitoring through temporal
   fusion, physical based deep learning, federated/transfer learning,
   interpretable AI, and standardized REDD+ protocols. Based on a
   systematic review of AGB estimation studies in tropical forests in the
   past five years, this paper summarizes the development progress of
   multi-source remote sensing data fusion and advanced algorithms,
   identifies the existing technical bottlenecks, and proposes a
   future-oriented comprehensive optimization framework to improve the
   accuracy and robustness of AGB estimation.},
Type = {Review},
Affiliation = {Leau, YB (Corresponding Author), Univ Malaysia Sabah UMS, Fac Comp \& Informat, Kota Kinabalu 88400, Sabah, Malaysia.
   Shi, JM (Corresponding Author), Hainan Vocat Univ Sci \& Technol, Coll Informat Engn, Haikou 571126, Hainan, Peoples R China.
   Meng, Qiaona; Leau, Yu-Beng, Univ Malaysia Sabah UMS, Fac Comp \& Informat, Kota Kinabalu 88400, Sabah, Malaysia.
   Shi, Jinmei; Zhou, Jinghe, Hainan Vocat Univ Sci \& Technol, Coll Informat Engn, Haikou 571126, Hainan, Peoples R China.},
DOI = {10.1109/ACCESS.2025.3649092},
Keywords = {Forests; Estimation; Biomass; Optical sensors; Synthetic aperture radar;
   Laser radar; Optical saturation; Biomedical optical imaging; Remote
   sensing; Carbon dioxide; Tropical forest; AGB estimation; multi-source
   remote sensing fusion; deep learning; machine learning; uncertainty
