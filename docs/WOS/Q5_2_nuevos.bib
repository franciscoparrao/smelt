@article{ WOS:001675064100001,
Author = {Gao, Xiao and Lu, Ping and Yi, Yonghong},
Title = {High-resolution daily surface soil moisture mapping over the
   Qinghai-Tibet Plateau via predictors fusion and machine learning},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {668},
Month = {APR},
Abstract = {High-accuracy and high-spatiotemporal-resolution soil moisture (SM)
   products are essential for understanding regional water-carbon-energy
   cycles and climate change, particularly over the Qinghai-Tibet Plateau
   (QTP). Although microwave remote sensing is highly sensitive to SM,
   current retrievals are limited by coarse spatial resolution, orbital
   coverage gaps, and freeze-thaw effects, leading to data discontinuities
   and accuracy fluctuations-issues that are especially pronounced on the
   QTP. To address these challenges, we developed a
   hyperparameter-optimized Random Forest (RF) downscaling framework that
   learns the nonlinear relationships between coarse-scale SMAP retrievals
   and regionally calibrated high-resolution predictors, producing the
   HRPSSM dataset: a seamless 500 m daily SM product spanning 2015-2023.
   Comparative validation with in-situ measurements and multiple benchmark
   datasets demonstrates that HRPSSM outperforms existing products in both
   accuracy and spatial consistency (mean R = 0.78, ubRMSE = 0.0369 m3/m3),
   effectively capturing seasonal dynamics and rainfall responses. Variable
   importance analysis indicates that EVI and soil organic carbon
   contribute most to downscaling performance, followed by soil texture and
   diurnal surface temperature difference, while meteorological factors
   such as near-surface humidity play greater roles during non-growing
   seasons and across subregions. HRPSSM thus fills a critical gap in
   high-resolution SM products over the QTP, providing a robust foundation
   for hydrological forecasting and climate-ecosystem interaction studies.},
Type = {Article},
Affiliation = {Lu, P (Corresponding Author), Tongji Univ, Coll Surveying \& Geoinformat, Shanghai 200092, Peoples R China.
   Gao, Xiao; Lu, Ping; Yi, Yonghong, Tongji Univ, Coll Surveying \& Geoinformat, Shanghai 200092, Peoples R China.},
DOI = {10.1016/j.jhydrol.2026.134982},
EarlyAccessDate = {JAN 2026},
Article-Number = {134982},
Keywords = {Surface soil moisture; Random Forest; Predictors; Qinghai-Tibet Plateau},
Keywords-Plus = {CLIMATE-CHANGE; IN-SITU; SMAP; DATASET; GAP},
Author-Email = {luping@tongji.edu.cn},
Number-of-Cited-References = {88},
Times-Cited = {0},
Unique-ID = {WOS:001675064100001},
}

@article{ WOS:001674929600001,
Author = {Haller, Vincent and Sanford, Luke and Gregoire, Timothy},
Title = {The importance of local calibration in biomass models for REDD+ - a case
   study in the Chiloe island, Chile},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {Market-based conservation schemes, such as REDD+ (Reducing Emissions
   from Deforestation and Forest Degradation), rely on the accurate
   quantification of carbon stocks. However, forest carbon modeling is
   still uncertain due to the challenging collection of field samples for
   calibrating remote sensing data. In this research, above-ground biomass
   (AGB) was measured in 120 inventory plots located on Chiloe Island in
   southern Chile. A forest carbon model was then calibrated using machine
   learning algorithms, with spectral, radar, and LiDAR-based canopy height
   data as predictors. Random Forest models showed the lowest errors, with
   root-mean-square error (RMSE) ranging from 91.0 to 93.7 tons AGB/ha. The
   presented methodology allows AGB mapping at the local scale, with no
   saturation below 350 tons AGB/ha. Significant prediction differences
   between our AGB maps and global AGB datasets confirm the importance of
   ground truthing for biomass mapping applications at the local scale.
   These cost-effective, localized methods could reduce the uncertainties
   of biomass mapping and further promote REDD+.},
Type = {Article},
Affiliation = {Haller, V (Corresponding Author), Yale Univ, Sch Environm, 195 Prospect St, New Haven, CT 06511 USA.
   Haller, Vincent; Sanford, Luke; Gregoire, Timothy, Yale Univ, Sch Environm, 195 Prospect St, New Haven, CT 06511 USA.
   Haller, Vincent, 54 Bay View Ave, Sydney, NSW 2250, Australia.},
DOI = {10.1016/j.rsase.2025.101851},
EarlyAccessDate = {JAN 2026},
Article-Number = {101851},
Keywords = {Above-ground biomass modelling; REDD+; Ground-truthing; Machine
   learning; Remote sensing; Allometry},
Keywords-Plus = {ALLOMETRIC EQUATIONS; TROPICAL FORESTS; PAYMENTS; LIDAR},
Author-Email = {vincent.haller@aya.yale.edu},
Number-of-Cited-References = {81},
