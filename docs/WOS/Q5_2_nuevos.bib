}

@article{ WOS:001649806000003,
Author = {Moorthi, Nivas Raj and Ramalingam, Kumaraperumal and Sellaperumal,
   Pazhanivelan and Dhanaraju, Muthumanickam and Sivasubramanian, K. and
   Kaliaperumal, Ragunath and Chidambaram, Prabu Padanillay},
Title = {Comparative assessment of spectral covariates from Sentinel 1 A,
   Sentinel 2 A, Landsat 8, and PRISMA for digital soil mapping of
   infiltration rate and textural classes},
Journal = {ENVIRONMENTAL MONITORING AND ASSESSMENT},
Year = {2025},
Volume = {198},
Number = {1},
Month = {DEC 26},
Abstract = {Prediction of soil properties at different depth levels and scales
   requires the use of multimodal datasets to represent the characteristics
   of the SCORPAN factors within the digital soil mapping (DSM) technique.
   With spectral variables representing the dynamic nature of soil property
   estimation, evaluating their efficiency can enhance the applicability of
   the models for further standardization. The current study aimed to
   compare the utility of different spectral modalities (i.e., Sentinel 1A,
   Sentinel 2A, Landsat 8, and PRISMA) for digital soil mapping of soil
   infiltration rates (cm h-1) and textural classes in the
   Thiruparankundram block of Madurai district. Further, the utility of the
   spectral subsets, both independently and in combination with other
   SCORPAN variables, was studied to perceive the efficiency of the
   framework and to determine the integration potential of spatial
   variables from multiple modalities. A total of 224 soil observations
   were derived from the legacy soil maps using a stratified random
   sampling procedure. The extracted soil and the covariate information
   were then subjected to the random forest algorithm for the mapping
   process. To mitigate the redundancy effect of the PRISMA spectral
   variables, supervised band selection techniques-viz., Recursive Feature
   Elimination (RFE), Boruta, Variable Selection Using Random Forest
   (VSURF), and Genetic Algorithm (GA)-were utilized to derive the optimal
   bands for the prediction process. The efficiency of the models trained
   for each subset was determined using data partitioning and repeated
   k-fold cross-validation techniques (10 folds; 10 repetitions) with
   several validation metrics opted for continuous and categorical
   variables. Among the spectral subsets utilized, the PRISMA bands
   selected through embedded selection methods (Boruta and VSURF) and the
   Landsat 8 spectral datasets under both validation strategies had the
   highest efficiency in predicting the soil infiltration and textural
   classes, respectively. Further, the variable importance measure
   determined for both continuous and categorical predictions through the
   permutation feature importance (PFI) indicated that Physiography,
   Geomorphology, Land Use and Land Cover, Multiresolution Ridge Top
   Flatness (MRRTF), and Multiresolution Valley Bottom Flatness (MRVB),
   among others, made the highest contribution towards the entire modelling
   process.},
Type = {Article},
Affiliation = {Ramalingam, K (Corresponding Author), Tamil Nadu Agr Univ, Dept Remote Sensing \& GIS, Coimbatore, Tamil Nadu, India.
   Moorthi, Nivas Raj; Ramalingam, Kumaraperumal; Dhanaraju, Muthumanickam, Tamil Nadu Agr Univ, Dept Remote Sensing \& GIS, Coimbatore, Tamil Nadu, India.
   Sellaperumal, Pazhanivelan; Kaliaperumal, Ragunath; Chidambaram, Prabu Padanillay, Tamil Nadu Agr Univ, Ctr Water \& Geospatial Studies, Coimbatore, Tamil Nadu, India.
   Sivasubramanian, K., Tamil Nadu Agr Univ, Dept Environm Sci, Coimbatore, Tamil Nadu, India.},
DOI = {10.1007/s10661-025-14921-7},
Article-Number = {69},
Keywords = {Digital soil mapping; Hyperspectral imagery; Infiltration rate; Texture;
   Random forest},
Keywords-Plus = {REFLECTANCE SPECTROSCOPY; FEATURE-SELECTION; CALCAREOUS SOILS; MACHINE;
   CLASSIFICATION; RESOLUTION},
Author-Email = {nivasrajmoorthi@gmail.com
