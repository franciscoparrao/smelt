@article{ WOS:001681063100016,
Author = {Resende, Hugo and Fazenda, Alvaro L. and de Oliveira, Amanda A. S. and
   Cappabianco, Fabio A. M. and Faria, Fabio A.},
Title = {Citizen Science in Action: Building Trust in Deforestation Data Through
   Continuous Reliability Enhancements},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {4980-4993},
Abstract = {The reliability of data produced by citizen science projects is crucial
   for applications that depend on precise annotations, such as training
   machine learning models. This reliability can be improved through
   careful visual design of campaigns and statistical analysis after data
   collection to address inconsistencies. Launched in 2019, the ForestEyes
   project combines citizen science, image analysis, and machine learning
   to detect deforestation in tropical rainforests. Continuous improvements
   remain necessary to ensure more reliable data. These enhancements may
   include using different remote sensing images (e.g., Landsat-8 and
   Sentinel-2), modifying the visual layout (e.g., grid mode and flip
   view), and adding viewing options such as zoom. This study presents four
   consecutive ForestEyes campaigns, each designed with targeted
   enhancements to improve volunteer classification quality. The first
   three campaigns followed a continuous improvement strategy, with each
   iteration addressing limitations identified previously. This process led
   to the use of higher resolution Sentinel-2 imagery in the third
   campaign, resulting in a notable accuracy increase compared to Landsat-8
   data. To further investigate the gains from this improvement, a fourth
   campaign tested a new ``transfer segmentation{''} approach, which
   applies segmentation to Sentinel-2 images and transfers the results to
   Landsat-8 imagery. Volunteer classification accuracy rose from 57.77\%
   in the first campaign (Landsat-8) to 93.33\% in the third campaign
   (Sentinel-2). These findings highlight the value of citizen science in
   detecting deforestation and underscore the importance of iterative
   campaign design and collaborative efforts to protect tropical forests.},
Type = {Article},
Affiliation = {Resende, H (Corresponding Author), Univ Fed Sao Paulo, Inst Sci \& Technol, BR-04021001 Sao Jose Dos Campos, Brazil.
   Resende, Hugo; Fazenda, Alvaro L.; Cappabianco, Fabio A. M., Univ Fed Sao Paulo, Inst Sci \& Technol, BR-04021001 Sao Jose Dos Campos, Brazil.
   de Oliveira, Amanda A. S., Univ Sao Paulo, Sch Arts Sci \& Humanities, BR-05508000 Sao Paulo, Brazil.
   Faria, Fabio A., Univ Lisbon, Inst Super Tecn, P-1600211 Lisbon, Portugal.},
DOI = {10.1109/JSTARS.2026.3655185},
Keywords = {Remote sensing; Deforestation; Earth; Image segmentation; Sentinel-2;
   Artificial satellites; Forests; Satellites; Reliability; Accuracy;
   Brazilian Legal Amazon (BLA); citizen science; deforestation detection;
   ForestEyes project; remote sensing},
