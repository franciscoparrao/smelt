   Tian, Yingze, Sichuan Forestry \& Grassland Survey \& Planning Ins, Chengdu, Peoples R China.
   Wu, Danzi, Beijing Forestry Univ, Sch Landscape Architecture, Beijing, Peoples R China.},
DOI = {10.3389/fpls.2026.1741992},
Article-Number = {1741992},
Keywords = {change detection; forest sub-compartment (FSC); machine learning; remote
   sensing image; texture feature},
Keywords-Plus = {TEXTURE FEATURE-EXTRACTION; INDEX; CLASSIFICATION; IMAGES},
Author-Email = {wudanzi@bjfu.edu.cn},
Number-of-Cited-References = {49},
