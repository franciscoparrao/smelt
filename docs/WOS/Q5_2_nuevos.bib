DOI = {10.1007/s11269-026-04508-3},
Article-Number = {191},
Keywords = {Remote sensing; Geographic information systems (GIS); Water loss
   management; Oil spillage detection and multi-sensor data fusion},
Keywords-Plus = {LEAK DETECTION; RISK-ASSESSMENT; SATELLITE; MODEL; POLLUTION; IMPACTS;
