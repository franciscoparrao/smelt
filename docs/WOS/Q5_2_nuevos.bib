}

@article{ WOS:001694537500012,
Author = {Gao, Ruonan and Balz, Timo and Yan, Yuyan and Zhuang, Qingwei and Shao,
   Zhenfeng and Chang, Boshen},
Title = {A Sample Spatiotemporal Expansion Method for Mapping Autumn-Harvested
   Crops in Cloudy and Rainy Areas},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {6152-6165},
Abstract = {Crop mapping is urgently required for crop monitoring to ensure food
   security. To address challenges of limited sample availability, as well
   as the inability of single-year field survey samples to support
   multiyear crop classification, we propose a spatiotemporal sample
   expansion method. Harmonic analysis of time series is employed to
   reconstruct 5-day vegetation index time series for both field survey and
   candidate expanded samples. Time-weighted dynamic time warping is then
   used to evaluate similarity between time series. Sample thinning
   enhances the representativeness of the expanded sample set and reduces
   redundancy for random forest classification. Results indicate that
   first-order harmonic simulation improves fitting of vegetation index
   time series; overall classification accuracy ranges from 0.79 to 0.81,
   enabling well-extracted rice and field boundary, albeit with slightly
   less satisfactory classification of maize. The conclusion suggests that
   the selection of Chinese calendar phenology or Gregorian calendar
   phenology may yield different spatiotemporal expansion samples, yet it
   exerts minimal impact on the final classification outcome; for
   large-area classification scenarios, augmenting the sample size may
   enhance classification accuracy. Compared with the cross-year reuse of
   historical samples method, the classification accuracy for rice and
   maize was improved by the proposed approach, leading to a 2\% increase
   in overall accuracy. This highlights its potential for autumn-harvest
   crop mapping in cloudy and rainy areas. With only a limited number of
   field survey samples from a single year, it is possible to achieve
   high-precision crop mapping across multiple years, showing potential for
   future extension to other land cover classifications pending further
   validation.},
Type = {Article},
Affiliation = {Balz, T (Corresponding Author), Wuhan Univ, State Key Lab Informat Engn Surveying Mapping \& R, Wuhan 430079, Peoples R China.
   Gao, Ruonan; Balz, Timo; Yan, Yuyan; Zhuang, Qingwei; Shao, Zhenfeng; Chang, Boshen, Wuhan Univ, State Key Lab Informat Engn Surveying Mapping \& R, Wuhan 430079, Peoples R China.},
DOI = {10.1109/JSTARS.2026.3656908},
Keywords = {Harmonic simulation; random forest; sample thinning; sample thinning;
   time series similarity; time series similarity; time series similarity},
Keywords-Plus = {NDVI TIME-SERIES; CLASSIFICATION; PHENOLOGY; IMAGERY; CORN},
