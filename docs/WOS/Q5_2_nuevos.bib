@article{ WOS:001698305800001,
Author = {Li, Xin and Yu, Hao and Yang, Yuan and Li, Jie Yu and Xie, Juan and Gao,
   Feifei and Zhang, Gucheng},
Title = {A comparative assessment of supervised models for landslide
   susceptibility mapping: a case study of Qiongzhong county, Hainan
   Island, China},
Journal = {GEOMATICS NATURAL HAZARDS \& RISK},
Year = {2026},
Volume = {17},
Number = {1},
Month = {DEC 31},
Abstract = {Landslides cause significant economic losses and human casualties.
   Landslide susceptibility assessment (LSA) is essential for land-use
   planning and risk management. This study aims to investigates hybrid
   models that fully leverages the advantages of individual supervised
   learning (ISL) models and ensemble learning (EL) models. We compared the
   performance of six supervised learning algorithms-logistic regression
   (LR), support vector machine (SVM), random forest (RF), adaptive
   boosting (AdaBoost), gradient boosting decision tree (GBDT), and extreme
   gradient boosting (XGBoost)-for LSA in Qiongzhong County, Hainan Island.
   Initially, twelve conditioning factors were quantified using certainty
   factors (CF) and filtered via independence tests. Subsequently, the
   landslide susceptibility maps (LSMs) were generated using the six
   models. Lastly, the model performance and LSMs were evaluated using
   statistical metrics. Results indicate that EL models, particularly
   XGBoost (AUC = 0.847) and RF (AUC = 0.843), outperformed ISL models. The
   normalized difference vegetation index (NDVI) was the most influential
   factor, followed by distance to roads. This study demonstrates the
   superiority of EL in enhancing prediction accuracy, addressing a
   research gap in LSA model comparison for tropical granite regions, and
   providing a reliable approach for disaster management.},
Type = {Article},
Affiliation = {Li, X (Corresponding Author), Hainan Prov Key Lab Marine Geol Resources \& Enviro, Haikou, Hainan, Peoples R China.
   Li, X (Corresponding Author), Hainan Geol Survey Inst, Dept Urban Geol, Haikou, Hainan, Peoples R China.
   Li, Xin; Xie, Juan; Zhang, Gucheng, Hainan Prov Key Lab Marine Geol Resources \& Enviro, Haikou, Hainan, Peoples R China.
   Li, Xin; Yu, Hao; Xie, Juan; Zhang, Gucheng, Hainan Geol Survey Inst, Dept Urban Geol, Haikou, Hainan, Peoples R China.
   Yang, Yuan, Hainan Expressway Co LTD, Dept Expressway Project, Haikou, Hainan, Peoples R China.
   Li, Jie Yu, Hainan Assoc Geol \& Geog, Comm Geol Disaster, Haikou, Hainan, Peoples R China.
