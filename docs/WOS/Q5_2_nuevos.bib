   Kafatos, Menas; Kim, Seung Hee, Chapman Univ, Inst Earth Comp Human \& Observing ECHO, Orange, CA 92866 USA.},
DOI = {10.3390/w18030353},
Article-Number = {353},
Keywords = {artificial intelligence (AI); empirical cumulative distribution function
   (ECDF); radar; GPM; LDAPS; high-resolution precipitation mapping; South
   Korea},
Keywords-Plus = {WEATHER RADAR; WATER-VAPOR; PRODUCTS; SNOWFALL; IMPACTS; TOPOGRAPHY;
