DOI = {10.1016/j.srs.2026.100406},
Article-Number = {100406},
Keywords = {Surface fuels; Active learning; Remote sensing; Extreme gradient
   boosting regression},
Keywords-Plus = {FIRE MANAGEMENT; CLASSIFICATION; REGRESSION; STRATEGIES; PARAMETERS;
   VEGETATION; MOISTURE; COVER},
Author-Email = {sunlong365@126.com},
