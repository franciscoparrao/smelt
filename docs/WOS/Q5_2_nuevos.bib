}

@article{ WOS:001707174800001,
Author = {Parent, Jason and Witharana, Chandi and Fahey, Robert and Wedagedara,
   Harshana and Cerrai, Diego},
Title = {Modeling tree-related risk to infrastructure using LiDAR: a case study
   for an electric distribution system},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {Utility databases provide unique opportunities to evaluate the ability
   of remote sensing data to predict tree failures, as indicated by
   tree-related power outages. Remote sensing-based models of tree risk to
   power lines and other infrastructure are needed to guide resilience
   efforts and help in real-time forecasting of damages for storm
   preparations. In this study, we developed and evaluated various
   predictors of power outages, based on remote sensing and utility asset
   data, and created simple explainable risk models. Light detection and
   ranging (LiDAR) data were used to map ``proximity pixels{''} (ProxPix)
   where vegetation was within striking distance of power lines. Various
   derivatives of ProxPix were created using LiDAR and GIS data to
   characterize forest conditions relating to tree failure. We evaluated
   metrics using a paired treatment-control approach that controlled for
   confounding factors (e.g. weather, powerline characteristics, etc.) and
   isolated the effects of individual predictors on outages. Significant
   predictors were used to create two risk models with GIS overlay
   techniques - one including LiDAR-based predictors, and the other
   including only line length and \% canopy cover.<br /> We found that
   power lines had more outages if associated with 1) more ProxPix, 2) a
   higher \% of ProxPix on hydric, shallow, and rocky soils; 3) a higher \%
   of ProxPix in areas of recent land cover change; 4) taller median
   ProxPix height with a higher \% of ProxPix > 15 m tall and >23 m tall;
   5) a lower \% of ProxPix with low exposure but a higher \% of ProxPix
   with high exposure; 6) greater canopy closure; 7) single-phase
   conductors; 8) no enhanced trimming; 9) no conductor covering; and 10)
   an east/west line orientation. Both the LiDAR and non-LiDAR risk models
   were highly effective at differentiating among low (0 outages), medium
   (1-2 outages), and high (>2 outages) classes of outages. The LiDAR-based
   model had the advantage of being applicable to fine-scale analyses,
   useful for precise targeting of resilience programs, and potential to
   identify forest conditions that may be improved by forest management.
   Compared to machine learning methods used in previous studies, our
   GIS-based models have the advantage of being explainable, easily
   scrutinized, and able to accommodate outage data which are highly
   imbalanced and lack information on true absences. Although evaluated
   using utility data, the LiDAR-based predictors are equally applicable to
   assessments of other infrastructure (roads, buildings, etc.) and for
   guiding forest management aimed at reducing storm damage.},
Type = {Article},
Affiliation = {Parent, J (Corresponding Author), Univ Rhode Isl, Dept Nat Resources Sci, South Kingstown, RI 02881 USA.
   Parent, Jason, Univ Rhode Isl, Dept Nat Resources Sci, South Kingstown, RI 02881 USA.
   Witharana, Chandi; Fahey, Robert; Wedagedara, Harshana, Univ Connecticut, Dept Nat Resources \& Environm, Storrs, CT USA.
   Cerrai, Diego, Univ Connecticut, Dept Civil \& Environm Engn, Storrs, CT USA.},
DOI = {10.1016/j.rsase.2026.101928},
Article-Number = {101928},
Keywords = {Outage; Tree; Risk assessment; Forest management; LiDAR; GIS},
Keywords-Plus = {FOREST; WIND; GROWTH},
Author-Email = {jason\_parent@uri.edu},
Number-of-Cited-References = {56},
Times-Cited = {0},
Unique-ID = {WOS:001707174800001},
}

@article{ WOS:001705920700010,
Author = {Fan, Weiru and Tang, Xiaobin and Xu, Xingqi and Hu, Huizhu and Yakovlev,
   Vladislav V. and Zhu, Shi-Yao and Wang, Da-Wei and Zhang, Delong},
Title = {Harnessing speckle images: efficient extraction of hidden information},
Journal = {ADVANCED PHOTONICS NEXUS},
Year = {2026},
Volume = {5},
Number = {1},
Month = {JAN 1},
Abstract = {Scattering obscures information carried by waves by producing speckle
   patterns, posing a fundamental challenge across diverse fields, from
   microscopy to astronomy. Although machine learning has recently shown
   promise in speckle analysis, existing approaches are hindered by their
   dependence on large, labeled datasets-a significant bottleneck in many
   real-world applications. Here, we introduce speckle unsupervised
   recognition and evaluation (SURE), a groundbreaking unsupervised
   learning strategy for speckle recognition that eliminates the need for
   labeled training data. SURE's distinctive feature lies in its ability to
   extract invariant features through advanced clustering algorithms to
   enable direct classification of high-level information from speckle
   patterns without prior knowledge. We demonstrate the transformative
   potential of this approach in two key applications: (1) a noninvasive
   glucose monitoring system that accurately tracks glucose concentrations
   over time without extensive calibration and (2) a high-throughput
   communication system using multimode fibers, achieving improved
   performance in dynamic environments. In addition, we showcase SURE's
   unprecedented capability to classify objects hidden behind obstacles
   using scattered light, further broadening its scope. This versatile
   approach opens new frontiers in biomedical diagnostics, quantum network
   decoupling, and remote sensing, unlocking a transformative new paradigm
   for extracting information from seemingly random optical patterns.},
Type = {Article},
Affiliation = {Fan, WR; Wang, DW; Zhang, DL (Corresponding Author), Zhejiang Univ, Sch Phys, State Key Lab Extreme Photon \& Instrumentat, Zhejiang Key Lab Micronano Quantum Chips \& Quantum, Hangzhou, Peoples R China.
