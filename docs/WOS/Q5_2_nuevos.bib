DOI = {10.1007/s11769-026-1596-8},
Keywords = {surface water mapping; machine learning; classification performance;
   Sentinel-2; Google Earth Engine (GEE); Songnen Plain, China},
Keywords-Plus = {RANDOM FOREST; ACCURACY; AREA},
