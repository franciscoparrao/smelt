@article{ WOS:001642432400001,
Author = {Wang, Zile and Osmond, Paul and Shi, Baiqian and Janmohammadi, Mehran
   and Zhang, Kefeng},
Title = {Next-generation water quality monitoring: sensor-based deep learning
   prediction and calibration optimization in urban rivers},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {666},
Month = {FEB},
Abstract = {Effective water quality management in urban river systems requires
   accurate, cost-efficient monitoring strategies, yet traditional methods
   are often limited by data scarcity and high costs. This study introduces
   a hybrid machine learning approach to predict key pollutants (e.g.,
   sediments, nutrients, heavy metals) in an urban river in Melbourne,
   Australia. The method integrates time-series sensor-based surrogates
   (e.g., DO, temperature, EC) and remote-sensing land-use classification
   data with periodic pollutant monitoring data from multiple sites (i.e.,
   more data collected for additional calibration) to enhance predictive
   accuracy. Four machine learning models-Random Forest (RF), XGBoost, Long
   Short-Term Memory (LSTM), and Self-Attention LSTM (SA-LSTM)- were
   compared to determine the most effective approach. Results show that
   SA-LSTM consistently outperforms LSTM models, achieving up to 10.2\%
   higher NSE and 11.8\% lower RMSE for nutrient predictions (e.g., TKN,
   TP, TN), due to its ability to prioritize key input features
   dynamically. Additionally, remote sensing-based land classification was
   found to be a valuable surrogate for parameters influenced by land-use
   variability. The study highlights the importance of calibration sites,
   with downstream locations proving most effective for heavy metal
   predictions and tributary sites near main streams improving phosphorus
   and nitrogen assessments. Adding calibration sites significantly
   improved model performance under data-scarce conditions, reducing the
   need for extensive historical data. However, predictive accuracy for
   pollutants such as E. coli, NO2--N, Cu, and Zn remained limited,
   emphasizing the need for advanced sensor parameters (e.g.,
   oxidation-reduction potential, UV absorbance, fluorescence, etc) to
   better capture pollutant dynamics. Overall, this study presents a
   scalable and data-efficient framework for urban water quality prediction
   by integrating machine learning, remote sensing, and calibration
   strategies. The findings support the development of adaptive and
   cost-effective monitoring strategies, addressing spatial variability and
   enabling sustainable management of urban water systems.},
Type = {Article},
Affiliation = {Wang, ZL; Zhang, KF (Corresponding Author), Univ New South Wales, UNSW Water Res Ctr, Sch Civil \& Environm Engn, Sydney, NSW 2052, Australia.
   Wang, Zile; Zhang, Kefeng, Univ New South Wales, UNSW Water Res Ctr, Sch Civil \& Environm Engn, Sydney, NSW 2052, Australia.
   Osmond, Paul, Univ New South Wales, Sch Built Environm, Sydney, NSW 2052, Australia.
   Shi, Baiqian, Monash Univ, Dept Civil Engn, BoSL Water Monitoring \& Control, Melbourne, Vic 3800, Australia.
   Shi, Baiqian; Janmohammadi, Mehran, Queensland Univ Technol, Sch Civil \& Environm Engn, Brisbane, Qld 4001, Australia.},
DOI = {10.1016/j.jhydrol.2025.134715},
EarlyAccessDate = {DEC 2025},
Article-Number = {134715},
Keywords = {Machine learning; Water quality prediction; Sensor-based surrogates;
   Self-Attention LSTM (SA-LSTM); Data-efficient monitoring},
Keywords-Plus = {SEDIMENT; NITRATE; LAND; SOIL},
Author-Email = {Zile.Wang@student.unsw.edu.au
   Kefeng.Zhang@unsw.edu.au},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001642432400001},
}

@article{ WOS:001649703300001,
Author = {Kang, Tae-An and An, Chi-Yong and Jeong, Hoejeong and Park, You-Jin and
   Park, Jinki and Ryu, Jongsoo and Bae, Hyungjin and Yoon, Youngnam and
   Lee, Hongseok},
Title = {Early detection of sesame leaf disease using hyperspectral imaging and
   machine learning: a patch-based spatial-spectral integration approach},
Journal = {FRONTIERS IN SUSTAINABLE FOOD SYSTEMS},
Year = {2025},
Volume = {9},
Month = {DEC 15},
Abstract = {Introduction Sesame (Sesamum indicum L.) is highly susceptible to leaf
   blight caused by Corynespora cassiicola and bacterial leaf spot caused
   by Pseudomonas syringae, both of which can cause substantial yield and
   quality losses. Conventional detection methods are limited to
   post-symptom diagnosis, limiting opportunities for timely intervention.
   Early asymptomatic detection is essential for stable production and
   economic sustainability.Methods We developed a hyperspectral imaging
   framework integrated with machine learning algorithms for early sesame
   leaf diseases detection by implementing a 3 x 3 patch-based approach to
   capture spatial-spectral disease patterns. Hyperspectral images (450-950
   nm) were acquired using dedicated hyperspectral imaging equipment. The 3
   x 3 patch extraction method captured spatial-spectral disease
   progression patterns, including infected areas and surrounding healthy
   tissues, to enable effective early disease detection. Three
   preprocessing methods {[}Raw reflectance spectra, Savitzky-Golay (SG)
   smoothing, and 1st derivative] were evaluated. Wavelength selection was
   performed using the Sequential Projection Algorithm (SPA), Genetic
   Algorithm (GA), and Competitive Adaptive Resampling (CARS). Feature
   extraction included three spectral features (mean, standard deviation,
   and range) and five vegetation indices {[}Normalized Difference
   Vegetation Index (NDVI), Red Chlorophyll Index (RCI), Photochemical
   Reflectance Index (PRI), Anthocyanin Reflectance Index (ARI), and Plant
   Senescence Reflectance Index (PSRI)]. Each preprocessing-effective
   wavelength combination was applied to Support Vector Machine (SVM),
   Partial Least Squares Discriminant Analysis (PLS-DA), Random Forest
   (RF), and Extreme Gradient Boosting (XGBoost) models.Results Comparative
   analysis revealed that the SG-SPA-SVM and Raw-GA-SVM models achieved the
   highest classification performance, each with 97.8\% accuracy on the
   test set. The proposed framework enabled early asymptomatic diagnosis as
   soon as 1 day post-inoculation, preceding visual symptom
   development.Discussion Integrating hyperspectral imaging with
   patch-based spatial-spectral analysis and machine learning enables
   accurate, early, and pathogen-specific detection of sesame leaf
   diseases. The reduced wavelength requirements of the GA-based approach
   improve feasibility for lightweight, cost-effective multispectral sensor
   development, thereby supporting sustainable sesame production and
   precision agriculture.},
Type = {Article},
Affiliation = {Lee, H (Corresponding Author), Natl Inst Crop Sci, Dept Upland Crop Res \& Dev, Rural Dev Adm, Miryang, Gyeongsangnam D, South Korea.
   Kang, Tae-An; An, Chi-Yong; Jeong, Hoejeong; Park, You-Jin; Park, Jinki; Ryu, Jongsoo; Bae, Hyungjin; Yoon, Youngnam; Lee, Hongseok, Natl Inst Crop Sci, Dept Upland Crop Res \& Dev, Rural Dev Adm, Miryang, Gyeongsangnam D, South Korea.
   Kang, Tae-An, Kyungpook Natl Univ, Dept Appl Biosci, Daegu 41566, South Korea.},
DOI = {10.3389/fsufs.2025.1716907},
Article-Number = {1716907},
Keywords = {bacterial contamination; fungal contamination; hyperspectral imaging;
   machine learning; sesame},
Keywords-Plus = {PSEUDOMONAS-SYRINGAE; SQUARES},
Author-Email = {ehg117@korea.kr},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001649703300001},
}

@article{ WOS:001648668100001,
Author = {Cowley, Dylan and Carrasco Rivera, David E. and Smart, Joanna N. and
   Hammerman, Nicholas M. and Golding, Kirsten M. and Diederiks, Faye F.
   and Roelfsema, Chris M.},
Title = {Insights into Seagrass Distribution, Persistence, and Resilience from
   Decades of Satellite Monitoring},
Journal = {REMOTE SENSING},
Year = {2025},
Volume = {17},
Number = {24},
Month = {DEC 15},
Abstract = {Persistence of seagrass meadows varies depending on community
   composition, substrate stability, environmental forcing, and water
   quality/clarity. Spatial trends in decadal scale persistence are
   difficult to assess at the meadow scale using in situ approaches and
   assessments using Earth Observation often lack temporal consistency.
   This study utilises a multi-decadal field monitoring dataset and
   high-resolution multispectral satellite imagery in a cloud-processing
   environment to assess species distribution, seagrass cover, and meadow
   persistence. In this work, we investigate long-term trends in overall
   meadow and species-specific persistence in the Eastern Banks, Moreton
   Bay, Australia, a shallow, semi-enclosed, subtropical embayment (similar
   to 200 km(2)). Here, we have identified an overall decline in seagrass
   cover (-15\% of the total study area), between 2011 and 2025, through
   contraction of meadow extent, with most losses in colonising species
   (Halophila spinulosa and Halophila ovalis) across the deeper sections of
   the study area. We have also quantified the spatial extent of a
   previously identified broad-scale ecosystem shift from meadows dominated
   by Zostera muelleri to a prevalence of Oceana serrulata, and reduction
   in the sparse cover species H. spinulosa and H. ovalis. We have
   presented a semi-automated cloud-processing based pipeline to combine in
   situ seagrass observations, derived from an expertly trained machine
   learning model, with high resolution multispectral data to assess
   seagrass cover and persistence. The variability in decadal-scale
   persistence between the six key species found in this region has been
   assessed, with dense cover species (e.g., O. serrulata and Z. muelleri)
   exhibiting moderate persistence (>0.32) and sparse cover species (H.
   ovalis and H. spinulosa) with low persistence (similar to 0.15).
   Colonising/opportunistic growth patterns characterise the species
   examined in this study, indicating quick response to disturbance but a
   lack temporal consistency in meadow form, which has critical
   implications for resilience.},
Type = {Article},
Affiliation = {Cowley, D (Corresponding Author), Univ Queensland, Sch Environm, St Lucia, Qld 4072, Australia.
   Cowley, Dylan; Carrasco Rivera, David E.; Smart, Joanna N.; Hammerman, Nicholas M.; Golding, Kirsten M.; Diederiks, Faye F.; Roelfsema, Chris M., Univ Queensland, Sch Environm, St Lucia, Qld 4072, Australia.},
DOI = {10.3390/rs17244033},
Article-Number = {4033},
Keywords = {seagrass mapping; species; random forest; object based; high spatial
   resolution; time series; persistence},
Keywords-Plus = {SOUTHERN MORETON BAY; MAPPING SEAGRASS; WATER-QUALITY; AUSTRALIA; COVER;
   QUEENSLAND; RECOVERY; SYSTEMS; IMPACTS; HABITAT},
Author-Email = {dylan.cowley@uq.edu.au
   d.carrascorivera@uq.edu.au
   n.hammerman@uq.edu.au
   f.diederiks@uq.edu.au
   c.roelfsema@uq.edu.au},
Number-of-Cited-References = {129},
Times-Cited = {0},
Unique-ID = {WOS:001648668100001},
}

@article{ WOS:001643267600002,
Author = {Syu, Chien-Hui and Valdez, Miguel Conrado and Chen, Chi-Farn and Chicas,
   Santos Daniel and Yen, Chun-Chien and Cheng, Youg-Sin and Mizoue, Nobuya
   and Yang, Jui-Han},
Title = {Geospatial and field-based digital mapping of soil organic carbon in
   Taiwan's agricultural and forest landscapes},
Journal = {ECOLOGICAL INFORMATICS},
Year = {2026},
Volume = {93},
Month = {FEB},
Abstract = {Soil carbon stocks are the second largest natural reservoir of carbon
   globally, after oceans. Soil carbon sequestration is a key process that
   supports both climate change mitigation and adaptation strategies. Thus,
   accurate mapping of soil organic carbon (SOC) stocks is essential for
   estimating their regional distribution and assessing soil functions.
   Regular ground sampling for estimating SOC is often expensive, prompting
   exploration of alternative, cost-effective techniques such as remote
   sensing. Many studies have applied remote sensing and machine learning
   to identify factors influencing SOC and predict its levels, but they
   often rely on limited data, such as single-year soil samples and small
   sample sizes, restricting their ability to capture SOC's variability and
   dynamics. This study aims to combine high sampling density (1.15
   samples/km(-2) in agricultural areas and 0.38/km(-2) for forest areas)
   and long-term SOC data (2010-2021) with remote sensing, topographic, and
   climatic data using random forest (RF) modeling to estimate SOC stocks
   in surface soils (0-30 cm) and identify key influencing factors across
   Taiwan's agricultural and forest lands. Initially, 22 variables were
   considered, and the least important ones were excluded. Two models were
   developed: one for agricultural land and one for forest land, with 14
   variables selected, in both models. The agricultural model emphasized
   elevation, climate, and green soil-adjusted vegetation index (GSAVI),
   while the forest model focused on vegetation indices and elevation. The
   models successfully predicted SOC stocks (in kg m(-2)), showing a strong
   correlation (R-2 > 0.75). Results revealed higher SOC in mountainous
   regions and lower SOC in suburban and low-lying agricultural areas, with
   SOC stocks ranging from 0.64 to 8.83 kg m(-2) in agriculture land and
   2.41 to 21.34 kg m(-2) in forest land. This research significantly
   contributes to SOC monitoring and informs carbon sequestration policy
   development in Taiwan. The findings from this study offer important
   insights for the long-term tracking of soil organic carbon stocks in
   Taiwan and provide a useful foundation for shaping future carbon
   sequestration policies.},
Type = {Article},
Affiliation = {Valdez, MC (Corresponding Author), Natl Cent Univ, Ctr Space \& Remote Sensing Res, Taoyuan City 32001, Taiwan.
   Valdez, Miguel Conrado; Chen, Chi-Farn; Cheng, Youg-Sin; Yang, Jui-Han, Natl Cent Univ, Ctr Space \& Remote Sensing Res, Taoyuan City 32001, Taiwan.
   Syu, Chien-Hui; Yen, Chun-Chien, Minist Agr, Taiwan Agr Res Inst, 189 Zhongzheng Rd, Taichung 413008, Taiwan.
   Chicas, Santos Daniel; Mizoue, Nobuya, Kyushu Univ, Fac Agr, Dept Agro Environm Sci, 744 Motooka, Nishi-ku, Fukuoka, Japan.},
DOI = {10.1016/j.ecoinf.2025.103557},
