@article{ WOS:001719051300001,
Author = {Haghighi, Hossein and Karimi, Danya and Rangzan, Kazem and Zareie, Sajad
   and Mousavi, Seyyed Sajeddin},
Title = {Hyperspectral assessment of road pavement condition using machine
   learning: a comparative study with EnMAP and PRISMA data},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2026},
Month = {2026 MAR 9},
Abstract = {This study explores how hyperspectral satellite data, specifically from
   EnMAP and PRISMA, can be combined with machine learning to assess the
   condition of urban roads. Field data were gathered in Ahvaz, Iran, using
   a smartphone-based tool called BumpRecorder. This system measured three
   pavement indicators: the International Roughness Index (IRI), the
   Japanese Roughness Index (JRI), and a Crack Index. To find meaningful
   patterns, the 20 spectral bands most closely correlated with each index
   were selected. These features then trained three types of machine
   learning models: Artificial Neural Networks (ANN), Support Vector
   Machines (SVM), and Random Forest (RF). Road conditions were grouped
   into `Good' or `Bad' using Jenks Natural Breaks. Among all setups, the
   RF model paired with EnMAP data delivered the strongest results,
   particularly for the JRI metric, with a Kappa score of 0.599 and a macro
   F1 score of 0.799. The findings indicate that Ahvaz primary roads
   maintain the best pavement conditions, with the lowest average JRI
   (27.12) and IRI (32.69) scores. In contrast, residential roads show the
   highest levels of roughness and deterioration, as reflected by their
   elevated JRI (40.69) and IRI (42.65) values. Secondary and tertiary
   roads lie between these extremes, supporting a broader pattern where
   pavement quality tends to decline progressively from major thoroughfares
   to local streets. To improve accessibility for users, a user-friendly
   graphical interface was created, allowing to load EnMAP or PRISMA
   imagery, choose the appropriate index for analysis, and run the
   classification model to assess road conditions.},
