@article{ WOS:001636812300001,
Author = {Zhang, Ling and Ma, Hui and Hu, Yingyi and Wang, Yixiao and Ma, Qimin
   and Zhao, Yanbo},
Title = {On the Use of Knowledge-Informed Machine Learning and Multisource Data
   for Spatially Explicit Estimation of Irrigation Water Withdrawal},
Journal = {EARTHS FUTURE},
Year = {2025},
Volume = {13},
Number = {12},
Month = {DEC 12},
Abstract = {Irrigation plays a crucial role in the earth system, yet our
   understanding of irrigation water withdrawal (IWW) remains limited due
   to the scarcity of spatially explicit data. While process-based models
   and remote sensing can bridge this data gap, their estimates often fail
   to capture real IWW and are associated with large uncertainties. Here,
   we present a knowledge-informed, explainable machine learning framework
   that combines random forest (RF) with Shapley additive explanations to
   generate spatially explicit IWW estimates across China. Our framework
   incorporates irrigation domain knowledge, state-of-the-art irrigated
   cropland maps, and various socioeconomic, hydroclimatic, and auxiliary
   factors. RF shows reasonable performance in spatial and temporal
   cross-validation, achieving a coefficient of determination exceeding
   0.85 and a root mean square error below 0.45 km3/year when evaluated
   against held-out prefecture-level data. The predictions of IWW depth are
   primarily driven by geographic and knowledge-based predictors, most of
   which exhibit nonlinear and non-monotonic impacts on model outputs. By
   integrating the RF model with a temporal downscaling approach, we
   develop a new gridded IWW product for China (named CIWW1km), which
   provides monthly IWW depth and volume at 1 km resolution from 2000 to
   2020. CIWW1km aligns closely with prefecture-level IWW reports and
   explains over 85\% of the variance in independent IWW observations
   (i.e., data excluded from training) across over 150 basins and counties.
   It highlights a rapid increase in IWW in China's arid zone, driven by
   irrigated area expansions. CIWW1km outperforms existing products and is
   well-suited for hydrological and climate studies, and water-food nexus
   analyses.},
Type = {Article},
Affiliation = {Zhang, L (Corresponding Author), Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, Key Lab Cryospher Sci \& Frozen Soil Engn, Heihe Remote Sensing Expt Res Stn, Lanzhou, Peoples R China.
   Zhang, Ling; Ma, Hui; Hu, Yingyi; Wang, Yixiao; Zhao, Yanbo, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, Key Lab Cryospher Sci \& Frozen Soil Engn, Heihe Remote Sensing Expt Res Stn, Lanzhou, Peoples R China.
   Ma, Hui, Univ Chinese Acad Sci, Beijing, Peoples R China.
   Wang, Yixiao, Northwest Normal Univ, Coll Geog \& Environm Sci, Lanzhou, Peoples R China.
   Ma, Qimin, Chengdu Univ Informat Technol, Coll Resources \& Environm, Chengdu, Peoples R China.},
DOI = {10.1029/2025EF006704},
Article-Number = {e2025EF006704},
Keywords = {irrigation withdrawal; knowledge-informed machine learning; explainable
   machine learning; remote sensing and reanalysis; feature selection;
   China},
Keywords-Plus = {COMBINING SATELLITE; SPACE; AREAS; TIME},
Author-Email = {zhanglingky@lzb.ac.cn},
Number-of-Cited-References = {93},
Times-Cited = {0},
Unique-ID = {WOS:001636812300001},
}

@article{ WOS:001636930800001,
Author = {Feng, Zhenqiang},
Title = {Mitigating Soil and Land Degradation: Socio-Ecological Perspectives on
   Ecosystem Service Trade-Offs},
Journal = {LAND DEGRADATION \& DEVELOPMENT},
Year = {2025},
Month = {2025 DEC 12},
Abstract = {Globally, mangrove forests offer a wide range of ecosystem services that
   are vulnerable due to land degradation and climate change. Mangrove
   protection and their restoration strategies have been getting more
   attention for restoring these significant ecosystem services. Land
   management practices play a crucial role in balancing ecosystem services
   with agricultural needs. The present study investigates the trade-offs
   and synergies among key ecosystem services in the Dongzhaigang Mangrove
   Nature Reserve, northeast Hainan province, China. This study analyzes
   the different indices (i.e., normalized difference vegetation index
   {[}NDVI], normalized difference water index {[}NDWI]), Random Forest
   algorithm for mangrove cover area and land use land cover (LULC)
   classification from 2017 to 2024. The study period found maximum NDVI
   mean values that is, 0.162 and 0.157, in the years 2021 and 2022. In
   contrast, NDWI showed a declining trend that is, 14.39\%, showing rising
   pressure on aquatic ecosystems. The results of mangrove cover area
   increased by 43.1\% during the study period from 2017 to 2024. The LULC
   classification highlights that the water surface decreased, while both
   the tree-covered area and built-up area increased in the studied region.
   In conclusion, overall findings reveal a clear trade-off: expansion of
   mangrove cover enhances regulating and supporting ecosystem services,
   while the loss of water bodies leads to challenges to provisioning
   services. These trends highlight the need for targeted, evidence-based
   interventions, including optimizing irrigation scheduling to reduce
   moisture stress and strengthening mangrove conservation zones to sustain
   coastal protection. This situation emphasizes the necessity for
   integrated land and water management to maintain a balanced ecosystem
   service for long-term sustainability.},
Type = {Article; Early Access},
Affiliation = {Feng, ZQ (Corresponding Author), Xuchang Univ, Sch Law, Xuchang, Henan, Peoples R China.
   Feng, Zhenqiang, Xuchang Univ, Sch Law, Xuchang, Henan, Peoples R China.},
DOI = {10.1002/ldr.70372},
EarlyAccessDate = {DEC 2025},
Keywords = {ecosystem services; land degradation; mangroves forest; remote sensing;
   trade-off},
Keywords-Plus = {MANGROVE FORESTS},
Author-Email = {littleqiang1225@163.com},
Number-of-Cited-References = {31},
Times-Cited = {0},
Unique-ID = {WOS:001636930800001},
}

@article{ WOS:001636901900001,
Author = {Janapati, Jayalakshmi and Seela, Balaji Kumar and Vadloori, Spandana and
   Lin, Pay-Liam and Tu, Chuan-Chi and Joseph, Everette},
Title = {Machine-learning approaches for characterizing the raindrop size
   distributions in Western Pacific tropical cyclones},
Journal = {QUARTERLY JOURNAL OF THE ROYAL METEOROLOGICAL SOCIETY},
Year = {2025},
Month = {2025 DEC 12},
Abstract = {Long-term observations of raindrop size distributions (RSDs) in the
   WPTCs are leveraged to enhance estimates of rainfall rate (R) and slope
   parameter. The radar reflectivity-rainfall (Z-R) relationship for the
   WPTCs exhibits a distinct dependence on the mass-weighted mean diameter
   (D m). Machine-learning techniques, including Random Forest (RF),
   XGBoost, and Decision Tree, were applied to estimate R, with RF
   demonstrating superior performance. Additionally, a hybrid moment-based
   approach was employed to elucidate the interrelationships among the
   gamma distribution parameters (slope, shape, and intercept), revealing
   strong predictability for the slope and intercept. These parameters
   showed a close association with liquid water content. Compared to linear
   regression, the RF method yielded more accurate estimates of the slope
   parameter. These results indicate that RF enhances both rainfall rate
   and slope parameter estimation, thereby improving precipitation
   forecasts and cloud modeling for the WPTCs.},
Type = {Article; Early Access},
Affiliation = {Lin, PL (Corresponding Author), Natl Cent Univ, Dept Atmospher Sci, Taoyuan, Taiwan.
   Janapati, Jayalakshmi; Seela, Balaji Kumar; Lin, Pay-Liam; Tu, Chuan-Chi, Natl Cent Univ, Inst Atmospher Phys, Dept Atmospher Sci, Taoyuan, Taiwan.
   Vadloori, Spandana, Natl Cent Univ, Earthquake Disaster Risk Evaluat \& Management Ctr, Taoyuan, Taiwan.
   Lin, Pay-Liam, Natl Cent Univ, Res Ctr Hazard Mitigat \& Prevent, Taoyuan, Taiwan.
   Lin, Pay-Liam, Acad Sinica, Inst Stat Sci, Taipei, Taiwan.
   Joseph, Everette, SUNY Albany, Atmospher Sci Res Ctr, Albany, NY USA.
