   Li, Chen; Qiao, Weifeng; Tang, Juan, Nanjing Normal Univ, Coll Rural Vitalizat, Nanjing, Peoples R China.
   Qiu, Hua, Qiannan Meteorol Bur, Qiannan Buyizu \& Miaozu Autonomous Prefecture, Duyun, Peoples R China.
   Wu, Yan, Chinese Acad Sci, Nanjing Inst Geog \& Limnol, Key Lab Watershed Geog Sci, Nanjing, Peoples R China.
   Gao, Binpin, Yunnan Acad Governance, Yunnan Comm CPC, Party Sch, Kunming, Peoples R China.},
DOI = {10.1080/15481603.2025.2562725},
Article-Number = {2562725},
Keywords = {Vegetation dynamics; urban-rural gradient; mixed-cell cellular automata;
   scenario projection; driving mechanisms},
