   Gao, Feifei, Minist Nat Resources, Key Lab Mine Ecol Effects \& Systemat Restorat, Beijing, Peoples R China.},
DOI = {10.1080/19475705.2026.2634968},
Article-Number = {2634968},
Keywords = {Ensemble learning; landslide susceptibility; certainty factor; machine
   learning; area under the curve},
