   Der Sarkissian, Rita, Univ Gustave Eiffel, Univ Paris Est Creteil, Ecole Ingenieurs Ville Paris EIVP, LAB URBA, F-77454 Marne la Vallee, France.},
DOI = {10.1007/s00267-025-02374-0},
Article-Number = {75},
Keywords = {Methane emissions; Agriculture; Temperature variation; Sentinel-5P;
   Machine learning; Loiret region},
Keywords-Plus = {MITIGATION},
