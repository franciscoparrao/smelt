   Varon-Ramirez, Viviana Marcela; Guevara, Mario, Univ Nacl Autonoma Mexico, Inst Geociencias, Campus Juriquilla, Queretaro, Mexico.
   Varon-Ramirez, Viviana Marcela, Ctr Invest Tibaitata, Corp Colombiana Invest Agr AGROSAVIA, Mosquera, Colombia.
   Daza-Torres, Martha Constanza, Univ Valle, Grp Invest Gest Integral Recurso Agua Desarrollo A, Cali, Colombia.},
DOI = {10.1071/SR25162},
