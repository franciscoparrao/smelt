   Han, Lijing, Shandong Univ Sci \& Technol, Coll Geodesy \& Geomat, Qingdao, Peoples R China.},
DOI = {10.1080/17538947.2025.2548378},
Article-Number = {2548378},
Keywords = {Soil salinity; UAV multispectral remote sensing; feature selection;
