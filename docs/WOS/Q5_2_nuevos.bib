}

@article{ WOS:001685681400001,
Author = {Lunday, John H. and Gani, Nahid D.},
Title = {Multi-sensor remote sensing and machine learning data fusion for
   high-resolution geologic mapping in vegetated karst terrain of Kentucky,
   United States},
Journal = {INTERNATIONAL JOURNAL OF IMAGE AND DATA FUSION},
Year = {2026},
Volume = {17},
Number = {1},
Month = {DEC 31},
Abstract = {This study presents a multi-sensor image and data fusion approach to
   refine 1:24,000-scale geological mapping in the 154.7 km2 karst-prone
   Olmstead area of southcentral Kentucky, USA. The region, underlain by
   Mississippian-age carbonates, is characterized by extensive sinkhole
   development and dense vegetation, which obscure lithologic boundaries
   and hinder traditional mapping. We integrated ASTER, Sentinel-2
   multispectral imagery, high-resolution LiDAR-derived DEMs with Random
   Forest classification, field validation and petrographic/SEM-EDS
   analyses to produce a new high-resolution geologic map. Spectral band
   ratios and fused datasets improved lithologic discrimination, while
   LiDAR analysis revealed sinkhole clustering and surface lineaments.
   Field and laboratory results confirmed stratigraphic boundaries and
   documented diagenetic features such as dolomitization, enabling clear
   separation of the previously grouped Paint Creek and Renault Limestones.
   Seasonal image stacks (summer vs. fall) demonstrated that vegetation
   significantly influences classification performance, with fall imagery
   yielding fewer unclassified pixels (0.0025\%) and greater clarity than
   summer data (0.43\%). Overall accuracy and kappa coefficients were
   higher for the summer imagery, indicating the robustness of the Random
   Forest model, despite the reduced visual. This study highlights the
   effectiveness and limitations of remote sensing - machine learning
   fusion in vegetated terrain and provides a reproducible framework for
   high-resolution geologic mapping and karst hazard assessment.},
Type = {Article},
Affiliation = {Gani, ND (Corresponding Author), Western Kentucky Univ, Dept Earth Environm \& Atmospher Sci, 1906 Coll Hts Blvd 31066, Bowling Green, KY 42101 USA.
   Lunday, John H.; Gani, Nahid D., Western Kentucky Univ, Dept Earth Environm \& Atmospher Sci, 1906 Coll Hts Blvd 31066, Bowling Green, KY 42101 USA.},
DOI = {10.1080/19479832.2026.2621068},
Article-Number = {2621068},
Keywords = {Geologic mapping; machine learning; remote sensing; LiDAR DEM;
   petrography; SEM},
Keywords-Plus = {EASTERN DESERT; ASTER; EGYPT; ROCKS; AREA},
Author-Email = {nahid.gani@wku.edu},
Number-of-Cited-References = {71},
Times-Cited = {0},
Unique-ID = {WOS:001685681400001},
}

@article{ WOS:001683420500001,
Author = {Afzali, Hamid and Rusnak, Milos and Opravil, Simon},
Title = {Riparian vegetation dynamics using satellite imagery and integrated
   spectral and spatial features: a case study of the Slovak Danube},
Journal = {EUROPEAN JOURNAL OF REMOTE SENSING},
Year = {2026},
Volume = {59},
Number = {1},
Month = {DEC 31},
Abstract = {Monitoring riparian vegetation with up-to-date technologies, such as
   remote sensing and machine learning, is emphasized by their extensive
   and dynamic nature. This study evaluates the spatiotemporal dynamics of
   vegetation in the Slovak Danube riparian zone from 2004 to 2022 using a
   multi-sensor approach (Landsat-5/8 and Sentinel-2). We integrated
   seasonal vegetation indices, textural, and morphological patterns to
   enhance Land Cover (LC) classification accuracy. Using Random Forest
   within a spectral-spatial framework, we achieved notable improvement in
   classification accuracy. We evaluated ecological processes, spatial
   errors, misclassification, and the spatial distribution of LC changes
   within the riparian zone. Our core-area analysis revealed that only 52\%
   of the riparian zone remains stable over time. Crucially, we quantified
   the impact of spatial misclassifications at class boundaries, finding
   that edge-related errors account for 0.24\% to 2.85\% of the detected
   change. The classification distinguished 1,076 ha of managed plantations
   and 1,236 ha of natural forest. Overall, the results demonstrated the
   effectiveness of various feature combinations for classifying different
   satellite datasets and assessing the temporal evolution of riparian
   zones in regulated river systems, while highlighting the critical
   importance of incorporating uncertainty analysis to ensure robust
   interpretation of detected LC changes.},
Type = {Article},
Affiliation = {Afzali, H (Corresponding Author), Slovak Acad Sci, Inst Geog, Stefanikova 49, Bratislava 81473, Slovakia.
   Afzali, Hamid; Rusnak, Milos; Opravil, Simon, Slovak Acad Sci, Inst Geog, Stefanikova 49, Bratislava 81473, Slovakia.
   Afzali, Hamid, Comenius Univ, Dept Phys Geog \& Geoecol, Bratislava, Slovakia.},
DOI = {10.1080/22797254.2026.2627046},
Article-Number = {2627046},
Keywords = {Riparian zone; vegetation dynamics; Random Forest; classification;
   Danube River; machine learning},
Keywords-Plus = {LAND-COVER CHANGES; RANDOM FOREST; RIVER-FLOODPLAIN; LANDSCAPE CHANGE;
   ECOSYSTEM; SENTINEL-2; DAM; CLASSIFICATIONS; PREDICTION; EVOLUTION},
Author-Email = {geogafza@savba.sk},
Number-of-Cited-References = {127},
Times-Cited = {0},
Unique-ID = {WOS:001683420500001},
}

@article{ WOS:001680678300001,
Author = {Yang, Yubo and Xu, Jixiang and Luan, Yingbo and Chen, Jianping and Wang,
   Shanshan and Ni, Jingbo and Cao, Mengmeng and Fu, Dequan},
Title = {Evaluation of spatial susceptibility to collapse based on random forest:
   a case study in the mountainous area of Changping District, Beijing},
Journal = {GEOMATICS NATURAL HAZARDS \& RISK},
Year = {2026},
Volume = {17},
Number = {1},
Month = {DEC 31},
Abstract = {Collapses represent a major geological threat in China's mountainous
   regions, which cover 65\% of its land area. Accurate susceptibility
   assessment is crucial, yet human engineering impacts in peri-urban
   mountains remains poorly quantified. This study develops an
   interpretable Random Forest model for collapse susceptibility in
   Changping District, Beijing. A spatial database included ten factors,
   including topography, geology, environment, and human activity. The
   model identified DTRO as the most critical factor, contributing 29.54\%
   of total importance. This underscores the dominant role of human
   engineering activities. NDVI (20.38\%), DTR (10.44\%), and ELV (8.65\%)
   were also key contributors. The top four factors contributed to 69.01\%
   of total predictive importance. The optimized model achieved outstanding
   performance, with an AUC of 0.981 and accuracy of 0.9315. Spatial
   validation confirmed reliability, as 98.01\% of collapses fall within
   the `high' and `very high' susceptibility zones, covering just 17.3\% of
   the study area. The susceptibility map reveals a distinct linear pattern
   of high-risk zones along roads and river valleys. This demonstrates that
   human factors can surpass natural factors in controlling collapse
   distribution in developed mountainous regions. This model provides an
   actionable tool for risk management and transferable framework for
   similar regions globally.},
Type = {Article},
Affiliation = {Chen, JP (Corresponding Author), China Univ Geosci Beijing, Sch Earth Sci \& Resources, Beijing, Peoples R China.
   Yang, Yubo; Chen, Jianping, China Univ Geosci Beijing, Sch Earth Sci \& Resources, Beijing, Peoples R China.
   Yang, Yubo; Ni, Jingbo; Cao, Mengmeng, Beijing Inst Geol Survey, Beijing, Peoples R China.
   Xu, Jixiang; Luan, Yingbo, Beijing Inst Geol, Beijing, Peoples R China.
   Wang, Shanshan; Fu, Dequan, Beijing Inst Geol Hazard Prevent, Beijing, Peoples R China.},
DOI = {10.1080/19475705.2026.2618471},
Article-Number = {2618471},
Keywords = {collapse; susceptibility; random forest; influencing factors;
   mountainous area of Changping District in Beijing},
Keywords-Plus = {LANDSLIDE SUSCEPTIBILITY; NETWORK; TERRAIN},
Author-Email = {3s@cugb.edu.cn},
Number-of-Cited-References = {52},
Times-Cited = {0},
Unique-ID = {WOS:001680678300001},
}

@article{ WOS:001678019000001,
Author = {He, Xu and Zhang, Rui and Shama, Age and Lv, Jichao and Hong, Ruikai and
   Yang, Yunjie and Jiang, Hang and Qin, Jiaoling and Liu, Guoxiang},
Title = {Dynamic monitoring of grassland land cover types of Inner Mongolia
   1990-2023 and testing the causal relationship between meteorological
   data and grassland area},
Journal = {GEOMATICS NATURAL HAZARDS \& RISK},
Year = {2026},
Volume = {17},
Number = {1},
Month = {DEC 31},
Abstract = {The area of global grassland ecosystems has been continuously declining
   over the past few decades. For this purpose, this study compared the
   classification performance of random forest (RF) and support vector
   machine (SVM) algorithms in large-scale land cover mapping using Landsat
   series of remotely sensed imagery since 1990 and selecting Inner
   Mongolia in China's continental cold and arid climate zone as a typical
   study area. We then applied the Shapley additive explanation (SHAP)
   method to analyze the sensitivity of remotely sensed features to
   grassland land types and accurately detected grassland disturbance
   dynamics using the LandTrendr algorithm. We explored the intrinsic
   relationship between major climate factors (temperature and
   precipitation) and grassland area changes using the convergent
   cross-mapping method. The results show that (1) the classification
   accuracy of RF model is better than SVM, and the average accuracy of
   grassland identification reaches 86.6\%; (2) the chlorophyll index
   green, BRE soil index, ratio vegetation index, SR\_B7 and altitude have
   a significant effect on the classification accuracy of grassland remote
   sensing; and (3) the average annual temperature of the grasslands around
   the meteorological station increases significantly by 2.13 degrees C.
   With the increase of annual mean temperature, the grassland area
   decreased significantly.},
Type = {Article},
Affiliation = {Zhang, R (Corresponding Author), Southwest Jiaotong Univ, Fac Geosci \& Engn, Chengdu, Peoples R China.
   He, Xu; Zhang, Rui; Shama, Age; Lv, Jichao; Hong, Ruikai; Yang, Yunjie; Jiang, Hang; Liu, Guoxiang, Southwest Jiaotong Univ, Fac Geosci \& Engn, Chengdu, Peoples R China.
   Qin, Jiaoling, Wuhan Univ, Sch Geodesy \& Geomat, Wuhan, Peoples R China.},
DOI = {10.1080/19475705.2026.2621845},
Article-Number = {2621845},
Keywords = {Grassland land cover classification; Landsat series of satellites;
   landTrendr algorithm; convergent cross mapping; Inner Mongolia},
Keywords-Plus = {TIME-SERIES; VEGETATION INDEXES; IMAGERY; CLASSIFICATION; DEGRADATION;
   DROUGHT; TRENDS; FOREST},
Author-Email = {zhangrui@swjtu.edu.cn},
Number-of-Cited-References = {69},
Times-Cited = {0},
Unique-ID = {WOS:001678019000001},
}

@article{ WOS:001677490000001,
Author = {Karami, Ayoob and Baghdadi, Nicolas and Bazzi, Henri and Nasrallah,
   Yasser and Zribi, Mehrez and Najem, Sami and Wigneron, Jean-Pierre},
Title = {Soil moisture estimation at 1-km resolution over croplands and
   grasslands using sentinel-1/2 and SMOS-IC data: algorithm and validation},
Journal = {EUROPEAN JOURNAL OF REMOTE SENSING},
Year = {2026},
Volume = {59},
Number = {1},
Month = {DEC 31},
Abstract = {This study presents a methodology to retrieve surface soil moisture (SM)
   at 1-km scale over croplands and grasslands using Sentinel-1 radar
   backscatter, harmonized Landsat/Sentinel-2 NDVI, and ancillary
   environmental variables. A Random Forest (RF) model was trained on the
   coarse (25-km) SMOS-IC product (2017-2024) to learn relationships
   between predictors and SM and then applied to generate fine-scale
   estimates. Only SMOS-IC pixels dominated by cropland and grassland
   selected to improve the reliability of the estimation. The RF achieved
   good performance at the training scale (R = 0.79, RMSE = 5.68 vol.\% and
   negligible bias). When transferred to 1-km grids, independent validation
   using International Soil Moisture Network observations (2015-2024)
   yielded an R value of 0.49, an RMSE of 11.2 vol.\%, an unbiased RMSE of
   9.55 vol.\%, and a global bias of 5.8 vol.\%. Spatial comparison with
   GLASS SM indicated generally strong correlations, especially in humid
   regions. However, limitations remain, including a systematic
   underestimation inherited from SMOS-IC and reduced performance over
   areas with fine-textured soils. Accuracy also decreases under very dense
   vegetation and following recent heavy rainfall events (>30 mm). Despite
   these challenges, the 1-km High-resolution SM dataset offers valuable
   spatial detail on soil moisture variability, supporting improved
   agricultural management and local-scale monitoring.},
Type = {Article},
Affiliation = {Karami, A (Corresponding Author), Univ Montpellier, CNRS, INRAE, CIRAD,TETIS, F-34093 Montpellier, France.
   Karami, Ayoob; Baghdadi, Nicolas; Bazzi, Henri; Nasrallah, Yasser; Najem, Sami, Univ Montpellier, CNRS, INRAE, CIRAD,TETIS, F-34093 Montpellier, France.
   Zribi, Mehrez, Univ Toulouse, CNRS, CNES, IRD,CESBIO, Toulouse, France.
   Wigneron, Jean-Pierre, INRAE, ISPA, UMR1391, Villenave Dornon, France.},
DOI = {10.1080/22797254.2026.2622132},
Article-Number = {2622132},
Keywords = {Random forest regression; soil moisture mapping; Sentinel-1 C-band SAR;
   SMOS-IC; NDVI; croplands and grasslands},
Keywords-Plus = {SURFACE; SMAP; RETRIEVAL; SATELLITE; NETWORK; MODEL; SAR; BACKSCATTER;
   PRODUCTS; SCIENCE},
Author-Email = {ayoobkarami@gmail.com},
Number-of-Cited-References = {96},
