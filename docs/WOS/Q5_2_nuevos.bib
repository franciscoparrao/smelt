@article{ WOS:001706413600016,
Author = {Huang, Jiapeng and Zhang, Yue and Mo, Fan},
Title = {Hierarchically Optimized Forest Coverage Modeling With Multisource
   Remote Sensing Data for High-Precision Understory Terrain Mapping},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {7583-7596},
Abstract = {The uncertainty in the accuracy of understory terrain severely restricts
   its applications in scientific research, while precise terrain
   information is crucial for studies such as vegetation biomass
   estimation. In this article, an innovative data fusion method is
   proposed, which integrates multisource remote sensing data and adopts a
   forest-coverage-based hierarchical optimization modeling strategy to
   construct a machine learning (ML) model for understory terrain
   estimation. Specifically, we utilize multimodal spaceborne LiDAR data
   (GEDI and ICESat-2), Sentinel data, high-precision digital elevation
   models, forest structural parameters, and topographic factors to build
   ML models following the forest cover hierarchical strategy. The
   experimental results show that among the evaluated ML algorithms, the
   random forest model achieves the optimal performance, improving the
   accuracy of understory terrain by 51\% at the regional scale compared
   with FABDEM (reducing root-mean-square error (RMSE) from 6.78 to 3.30
   m). In addition, the hierarchical modeling based on forest cover further
   enhances the accuracy by 13\% (to an RMSE of 2.85 m) in the Oregon study
   area. The study also reveals that the accuracy of understory terrain is
   affected by forest types and soil properties; particularly, forest types
   with dense canopies and complex structures, as well as loose-textured
   soils susceptible to vegetation interference, exert a significant impact
   on accuracy.},
Type = {Article},
Affiliation = {Huang, JP (Corresponding Author), Liaoning Tech Univ, Sch Geomat, Fuxin 123000, Peoples R China.
   Huang, Jiapeng; Zhang, Yue, Liaoning Tech Univ, Sch Geomat, Fuxin 123000, Peoples R China.
   Mo, Fan, Minist Nat Resources, Land Satellite Remote Sensing Applicat Ctr, Beijing 100048, Peoples R China.},
DOI = {10.1109/JSTARS.2026.3663861},
Keywords = {Forestry; Laser radar; Data models; Accuracy; Remote sensing; Vegetation
   mapping; Analytical models; Soft sensors; Sentinel-2; Photonics;
   Elevation; hierarchically optimized modeling; spaceborne LiDAR;
   understory terrain},
Keywords-Plus = {REFLECTANCE SPECTRA},
Author-Email = {huangjiapeng@lntu.edu.cn
   472320855@stu.lntu.edu.cn
   mof@lasac.cn},
Number-of-Cited-References = {57},
Times-Cited = {0},
Unique-ID = {WOS:001706413600016},
}

@article{ WOS:001706413600014,
Author = {Cao, Wanying and Duan, Hanchen and Huang, Beiying and Jia, Xiaopeng},
Title = {Multimodel Comparative Assessment and Optimal Geodetector-Driven
   Analysis of Aeolian Desertification in the Horqin Sandy Land},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {7644-7660},
Abstract = {The Horqin Sandy Land, a critical ecological barrier in northern China
   and the core area of the Three-North Shelterbelt Project, requires
   precise monitoring of aeolian desertification (AD) dynamics to maintain
   ecological stability in densely populated northern and northeastern
   China. This study innovatively integrated multisource remote sensing
   parameters via Google Earth Engine to systematically compare three
   feature space models (Albedo-NDVI, Albedo-MSAVI, and Albedo-KNDVI) and
   five machine learning algorithms for AD monitoring, while applying the
   Optimal Parameter Geographic Detector (OPGD) to quantify
   natural-anthropogenic driving mechanisms. High-resolution AD
   classification (5-year intervals, 2000-2020) revealed spatiotemporal
   dynamics, with machine learning models consistently outperforming
   feature space models. Random forest achieved the highest accuracy
   (97.7\%) and Kappa coefficient (0.967), effectively distinguishing
   nondesertified areas from extreme desertification. Temporal analysis
   showed a significant AD reversal: total desertified area declined to 30
   166.35 km(2) by 2020, driven by ecological policies and climate
   amelioration. OPGD analysis indicated soil texture as the strongest
   single driver (q > 0.48), but factor interactions (e.g., SD boolean AND
   \& gnE; LU) exerted greater explanatory power, highlighting compound
   effects of natural and anthropogenic factors. This study provides a
   robust framework for high-precision AD monitoring in semiarid
   agropastoral zones, supporting global efforts toward zero land
   degradation.},
Type = {Article},
Affiliation = {Duan, HC; Jia, XP (Corresponding Author), Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, Natl Key Lab Ecol Safety \& Sustainable Dev Arid La, Lanzhou 730000, Peoples R China.
   Cao, Wanying; Duan, Hanchen; Huang, Beiying; Jia, Xiaopeng, Chinese Acad Sci, Northwest Inst Ecoenvironm \& Resources, Natl Key Lab Ecol Safety \& Sustainable Dev Arid La, Lanzhou 730000, Peoples R China.
   Cao, Wanying, Univ Chinese Acad Sci, Beijing 100049, Peoples R China.},
DOI = {10.1109/JSTARS.2026.3660682},
Keywords = {Biological system modeling; Monitoring; Machine learning;
   Desertification; Remote sensing; Vegetation mapping; Sustainable
   development; Earth; Soil; Safety; Aeolian desertification (AD)
   monitoring; feature space model; Horqin Sandy Land (HSL); machine
   learning; optimal parameter geographic detector (OPGD)},
Author-Email = {caowanying23@mails.ucas.ac.cn
   hcduan@lzb.ac.cn
   huangby3928@163.com
   jiaxp@lzb.ac.cn},
