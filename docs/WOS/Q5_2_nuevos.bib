@article{ WOS:001700670600018,
Author = {Wang, Yishuo and Zhou, Muping and Meng, Qicheng and Zhou, Feng and Hu,
   Zhijun and Zhang, Chengqing and Zhao, Tianhao},
Title = {GBM: An Ocean Front Detection Framework},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Ocean fronts are fundamental dynamical interfaces in the ocean,
   regulating heat exchange, material transport, and ecosystem functioning.
   Despite extensive studies, existing front detection approaches-including
   histogram-based, entropy-based, Lyapunov exponent-based, gradient-based
   edge detection, and machine learning methods-often face challenges, such
   as fragmented detections, excessive false positives, sensitivity to
   fixed thresholds, and limited interpretability or reproducibility. To
   address these issues, this study proposes a physically informed and
   fully interpretable framework for ocean front detection, termed
   gradient-Bayesian-morphology (GBM). The framework integrates three
   complementary components: 1) a gradient-based thresholding strategy that
   introduces a physically meaningful prior emphasizing sharp field
   transitions; 2) a Bayesian inference scheme that combines gradient
   priors with local field descriptors to enable adaptive, data-driven
   classification of frontal zones without ad hoc threshold tuning; and 3)
   a suite of morphological and graph-based refinement procedures that
   enforce topological consistency by thinning frontal zones, merging
   fragmented segments, and systematically eliminating spurious ring
   structures. GBM is evaluated using daily sea surface temperature (SST)
   and salinity fields from 2022 to 2024 over the South China Sea (SCS) and
   the Kuroshio region, representing weak and strong frontal regimes,
   respectively. The results demonstrate that GBM effectively suppresses
   overdetection while producing fronts with enhanced spatial continuity.
   Statistical analyses further indicate stable frontal characteristics
   with minimal parameter sensitivity, highlighting the robustness and
   reproducibility of the proposed framework. Overall, GBM provides a
   transparent alternative to black-box approaches and offers a unified
   framework for multivariable ocean front analysis.},
