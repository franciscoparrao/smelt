}

@article{ WOS:001651857400001,
Author = {Attaullah Khan, Shehryar and Ahmed, Musharif and Farooq Khan, Naurin and
   Hanif, Muhammad},
Title = {Sugarcane varietal classification using remote sensing and AI: a
   comprehensive review and future roadmap},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2026},
Volume = {47},
Number = {4},
Pages = {1473-1513},
Month = {FEB 16},
Abstract = {Sugarcane varietal classification is critical for yield estimation,
   combating diseases, allocation of resources and estimating the footprint
   of sugarcane varieties, but research remains disjointed. Sugarcane
   variety identification is the core component of precision agriculture in
   management of sugarcane crop. This literature review gathered literature
   between 2000 and May 2025 and consolidated 15 primary studies and 2
   review papers. We examined datasets, statistical methods, computational
   algorithms, remote-sensing platforms and plant attributes/ variety
   specific spectral responses to get insights, based on our four research
   questions under protocol of SLR. Our study shows use of moderate-scale
   multispectral and hyperspectral imagery data and baseline
   machine-learning algorithms (SVM, RF, KNN) with statistical discriminant
   analysis tending to dominate. SVM proved to be the most reliable
   technique among machine learning and statistical methods. Deep neural
   network was applied in a single study in comparison with machine
   learning techniques, achieving second best accuracy after SVM. UAV
   imagery remained under-utilized but it achieved accuracy with
   flexibility in making multiple-flights in a single day and enabled to
   judge the influence of the time of the day on spectral bands and
   vegetation indices. In remote sensing, hyperspectral imagery has got the
   potential to find subtle spectral differences in sugarcane varieties. We
   have performed meta-analysis of RQ2 \& RQ3 to add quantitative value for
   researchers to grasp the significance of techniques and Remote Sensing
   platform accuracies. Significant gaps are observed for large-scale
   standardized datasets collection and utilization of non-image
   environmental covars and hybrid CNN-transformer model utilization.
   Moreover, the validation of classification results under different
   agro-climatic regions and production environments has not been covered
   in literature. High spectral and high spatial resolution multiplatform
   remote sensing and robust dataset standardization and hybrid
   deep-learning architectures in different agro-climatic conditions are
   advocated for future work for enhanced varietal classification in
   real-field conditions, specifically in Pakistan.},
Type = {Review},
Affiliation = {Khan, SA (Corresponding Author), Riphah Int Univ, Fac Comp, I-14 Campus,Sect I-14,Hajj Complex, Islamabad, Pakistan.
   Attaullah Khan, Shehryar; Ahmed, Musharif; Farooq Khan, Naurin, Riphah Int Univ, Dept Comp, Islamabad, Pakistan.
   Hanif, Muhammad, GIKI, Fac Comp Sci, Swabi, Pakistan.},
DOI = {10.1080/01431161.2025.2607761},
EarlyAccessDate = {JAN 2026},
Keywords = {Precision agriculture; remote sensing; sugarcane varieties;
   classification; statistical analysis methods; machine learning; deep
   learning; spectral bands; vegetation indices; plant traits; spectral
   response; time-series data},
Keywords-Plus = {DISCRIMINATION; IDENTIFICATION; IMAGES; UAV},
Author-Email = {shehryarniazai@gmail.com},
Number-of-Cited-References = {67},
