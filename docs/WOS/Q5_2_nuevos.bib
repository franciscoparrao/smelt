@article{ WOS:001666941400002,
Author = {Xu, Qing and Zhang, Ben and Yin, Xiaobin and Sun, Tong and Cheng,
   Yongcun and Li, Yan and Shang, Feifei and Ning, Jue and Yin, Yifan},
Title = {Deep Learning-Based Identification of Marine Mucilage in the Sea of
   Marmara from MODIS Images},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {3311-3320},
Abstract = {In 2021, the Sea of Marmara experienced the most severe marine mucilage
   (MM) event in history. The large-scale outbreak not only affected the
   marine ecosystem, but also caused serious damage to fisheries, shipping,
   and coastal economies. How to use satellite remote sensing technology
   for efficient and accurate monitoring of mucilage has become a hot
   topic. In this article, an MM identification model, MM-Net, was
   constructed using the U-Net deep learning framework based on multiband
   and multitype data from the moderate resolution imaging
   spectroradiometer (MODIS). By improving the commonly used binary cross
   entropy loss function in the basic U-Net and determining the optimal
   input parameters via comparative experiments, the sensitivity of MM-Net
   to small-sample mucilage identification was effectively enhanced, and
   its performance in mucilage detection efficiency boosted. The results
   show that MM-Net significantly outperforms random forest, and
   demonstrates substantial improvements compared with U-Net. The precision
   (83.0\%), recall (77.5\%), F1-score (80.2\%), and mean intersection over
   union (66.9\%) are 20.1\%, 23.6\%, 22.1\%, and 29.0\% higher than that
   of U-Net, respectively. This indicates that MM-Net has distinct
   advantages in reducing missed or false classifications while balancing
   its precision and recall in MM identification. Furthermore, the model
   performs well in identifying both diffused and aggregated types of MM.
   The research findings provide a scientific basis for marine ecological
   monitoring, environmental governance, and disaster early warning.},
