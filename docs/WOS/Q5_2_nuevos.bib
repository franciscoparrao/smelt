@article{ WOS:001663566700005,
Author = {Mythili, S. and Neela, K. L. and Selvi, T. Mahesh and Sikkandar, Mohamed
   Yacin},
Title = {Smart IoT-ML-RS framework for detecting emerging wastewater contaminants},
Journal = {DESALINATION AND WATER TREATMENT},
Year = {2026},
Volume = {325},
Month = {JAN},
Abstract = {Emerging pollutants, including pharmaceuticals, pesticides, and
   industrial residues, pose increasing risks to ecosystems and human
   health. This study develops and validates an integrated IoT-machine
   learning-remote sensing (IoT-ML-RS) framework to detect and map
   wastewater contamination in the Balasore District of Odisha, India.
   IoT-based water quality sensors enabled continuous monitoring of pH,
   turbidity, dissolved oxygen, chemical oxygen demand, and chlorophyll-a,
   while RS-derived indices such as NDVI, NDWI, NDBI, and topographic
   variables were extracted from Landsat-8 imagery and DEM data. These
   datasets were used to train the XGBoost model for spatial contamination
   risk assessment. The model outperformed conventional approaches and
   identified high pollution covering 30 \% (905.4 sq.km), moderate 25 \%
   (754.5 sq.km), low 20 \% (603.6 sq.km), and very low 15 \% (452.7 sq.km)
   of the district. Notably, 10 \% (301.95 sq.km) exhibited extremely high
   contamination, representing critical wastewater hotspots. The model
   achieved an R2 of 0.89, RMSE of 0.13, and overall accuracy of 85 \%.
   Spatial patterns revealed severe contamination in Balasore, Raibania,
   Kamarda, Sartha, Panapana, and Baliapal, while Soro, Dungura, and
   Balikhand showed moderate to low levels. The integrated IoT-ML-RS
   framework offers a scalable approach for wastewater risk evaluation and
   supports sustainable water management, early warning systems, and
   optimized treatment strategies in rapidly urbanizing coastal regions.},
Type = {Article},
Affiliation = {Mythili, S (Corresponding Author), United Inst Technol, Dept Comp Sci \& Engn, Coimbatore, Tamil Nadu, India.
   Mythili, S., United Inst Technol, Dept Comp Sci \& Engn, Coimbatore, Tamil Nadu, India.
