Keywords = {Convolutional neural networks; deep learning; 3D CNN; random forest;
   LULUCF; Sentinel-2; land cover classification},
Keywords-Plus = {BENCHMARK},
Author-Email = {stych@natur.cuni.cz},
Number-of-Cited-References = {50},
Times-Cited = {2},
Unique-ID = {WOS:001502969900001},
}

@article{ WOS:001502964500001,
Author = {He, Suling and Deng, Yuncheng and Wang, Jinliang and Luo, Mengjia},
Title = {Fine identification of vegetation types in open pit mining regions using
   combined UAV RGB imagery and LiDAR point cloud data},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2025},
Volume = {18},
Number = {1},
Month = {DEC 31},
Abstract = {Accurate vegetation type information is essential for the scientific
   assessment of ecological restoration in open pit mining areas. However,
   many existing mine-mapping studies tend to classify all vegetation into
   a single class, overlooking inter-species differentiation and thereby
   limiting the precision of ecological evaluations. To address this issue,
   this study proposed a multi-scale hierarchical classification (MSHC)
   method for fine-scale mapping of vegetation types in open phosphate
   mining areas by combining unmanned aerial vehicle (UAV) RGB remote
   sensing imagery and light detection and ranging (LiDAR) data with the
   support of object-oriented methods. The results showed that (1) The all
   features (AF) scheme achieved an overall accuracy (OA) of 97.04\% and a
   Kappa coefficient of 0.98. (2) The proposed MSHC method reached an OA of
   97.69\% and a Kappa of 0.97. (3) The vegetation in the study area was
   predominantly grassland (approximately 29.57\% of the total area), with
   Alnus nepalensis being the dominant tree species (16.07\% of the area).
   Overall, this study provides a detailed classification of vegetation
   types, offering a valuable dataset for ecological monitoring and
   assessment. The proposed method also presents a transferable and
   effective approach for the fine-scale vegetation mapping of other
   open-pit mining environments.},
Type = {Article},
Affiliation = {Wang, JL (Corresponding Author), Yunnan Normal Univ, Fac Geog, 768 Juxian St, Kunming 650500, Yunnan, Peoples R China.
   Wang, JL (Corresponding Author), Yunnan Normal Univ, Key Lab Resources \& Environm Remote Sensing Univ Y, Kunming, Peoples R China.
