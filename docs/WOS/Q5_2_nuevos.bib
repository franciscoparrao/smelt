@article{ WOS:001643036700001,
Author = {Blay, Jeffrey and Gebregziabher, Yared and Jha, Manoj K. and Beni, Leila
   Hashemi},
Title = {Inundation2Depth: A multi-source dataset for floodwater depth estimation
   in urban areas},
Journal = {DATA IN BRIEF},
Year = {2026},
Volume = {64},
Month = {FEB},
Abstract = {Floods impose severe risks in urban areas, yet operational mapping often
   stops at inundation extent rather than depth, which is critical for
   assessing and managing accessibility, and risk. Progress in deep
   learning offers a path forward but is constrained by the scarcity of
   large quantity, georeferenced depth datasets that are well labelled.
   Inundation2Depth dataset pairs inundation extent-depth labels derived
   from aerial imagery and LiDAR (Light Detection and Ranging)-based DTMs
   (Digital Terrain Models) under hydrostatic assumptions (water-surface
   elevation relative to terrain). The dataset encompass 12 flood affected
   areas across North and South Carolina in the Southeastern United States,
   covering 24,649.88 acres with diverse environmental characteristics.
   Data acquisition spans the period between 2016 and 2018, corresponding
   to two major hurricane flood events that significantly impacted the
   Carolinas. The sources include complementary layers from multi-sensor
   remote sensing imagery (thus, Optical and LiDAR point cloud data), which
   were preprocessed through standard correction, normalization, and
   georeferencing steps to ensure spatial consistency across scenes. Data
   are provided as scene-level raster and 256x256 tiles, available in both
   raw and normalized versions with consistent naming to support direct
   integration in machine/deep learning pipelines. It constitutes a total
   of 5925 overlapping tiles. This dataset's unique characteristics, such
   as spatial diversity and standardized format, make it valuable for
   developing and evaluating flood detection, segmentation, and damage
   assessment models. Inundation2Depth lowers the data barrier for GeoAI
   research on urban flood severity and promotes comparability across
   methods and study areas. The generated dataset was validated through a
   hydrodynamic modeling approach using HEC-RAS Rain-on-Grid tool.},
Type = {Article; Data Paper},
Affiliation = {Beni, LH (Corresponding Author), North Carolina A\&T State Univ, Dept Built Environm, 1601 Market St, Greensboro, NC 27401 USA.
   Blay, Jeffrey; Beni, Leila Hashemi, North Carolina A\&T State Univ, Dept Built Environm, 1601 Market St, Greensboro, NC 27401 USA.
   Gebregziabher, Yared, North Carolina A\&T State Univ, Dept Computat Data Sci \& Engn, 1601 Market St, Greensboro, NC 27401 USA.
   Jha, Manoj K., North Carolina A\&T State Univ, Dept Civil Architectural \& Environm Engn, 1601 Market St, Greensboro, NC 27401 USA.},
DOI = {10.1016/j.dib.2025.112347},
EarlyAccessDate = {DEC 2025},
Article-Number = {112347},
Keywords = {Remote sensing; Deep learning; Natural disasters; Risk modelling;
   Hydrodynamic modelling; Machine learning; Geospatial engineering},
