
@article{ WOS:001722666200001,
Author = {Li, Zhenglong and Xue, Yong and Ling, Xiaolu and Han, Liying and Zhang,
   Shan},
Title = {Combining machine learning and multi-criteria decision analysis for
   forest fire susceptibility assessment},
Journal = {EUROPEAN JOURNAL OF REMOTE SENSING},
Year = {2026},
Volume = {59},
Number = {1},
Month = {DEC 31},
Abstract = {Forest fires harm forests and endanger lives. Susceptibility assessment
   mapping using remote sensing and geographic information systems can help
   prevent forest fires and allocate fire-fighting resources rationally.
   This study combines machine learning (ML) and multi-criteria decision
   analysis to propose LOGEAHP - an integrated method based on logistic
   regression and the analytic hierarchy process (AHP). This method is used
   to calculate the relative weights of forest fire influencing factors and
   generate a forest fire susceptibility map for the Greater Khingan Range.
   The results show that nearly one-third of the Greater Khingan Range
   faced severe high forest fire risks between 2013-2024, with higher fire
   risks in the northern and southern regions than those in the central
   region. ``Distance from Road{''} is the most critical factor affecting
   forest fire risks in the Greater Khingan Range, with a feature value as
   high as 1.1287. The LOGEAHP exhibits excellent fire assessment
   performance and stability, with an average receiver operating
   characteristic (ROC) of 0.9311 and 95\% confidence interval for ROC
   ranging from 0.91 to 0.95. Bootstrap validation indicates that LOGEAHP
   achieves a statistically significant improvement over ML and AHP, with
   p-value significantly less than 0.01. This approach provides a robust
   basis for local fire prevention strategies.},
Type = {Article},
Affiliation = {Xue, Y (Corresponding Author), China Univ Min \& Technol, Sch Environm \& Spatial Informat, 1 Jinshan East Rd, Xuzhou 221008, Jiangsu, Peoples R China.
   Li, Zhenglong; Xue, Yong; Ling, Xiaolu; Han, Liying; Zhang, Shan, China Univ Min \& Technol, Sch Environm \& Spatial Informat, 1 Jinshan East Rd, Xuzhou 221008, Jiangsu, Peoples R China.},
DOI = {10.1080/22797254.2026.2646575},
Article-Number = {2646575},
Keywords = {Machine learning; multi-criteria decision analysis; remote sensing;
   forest fire; susceptibility assessment; fire prevention},
Keywords-Plus = {CLIMATE-CHANGE; WILDFIRE; TOPOGRAPHY; VEGETATION; MOUNTAINS; CHINA; RISK},
Author-Email = {yxue@cumt.edu.cn},
Number-of-Cited-References = {83},
Times-Cited = {0},
Unique-ID = {WOS:001722666200001},
}

@article{ WOS:001713399500001,
Author = {Yan, Yangyang and Zhao, Chuanpeng and Jia, Mingming and Zhang, Rong and
   Ren, Chunying and Wang, Zongming},
Title = {Fluctuating restoration of Suaeda species in Coastal China:
   remote sensing-based spatiotemporal patterns and underlying drivers},
Journal = {GISCIENCE \& REMOTE SENSING},
Year = {2026},
Volume = {63},
Number = {1},
Month = {DEC 31},
Abstract = {Suaeda species in coastal zones play a crucial ecological role in
   improving saline-alkali soils and supporting habitats for migratory
   waterbirds. However, these ecosystems have faced sustained degradation
   in recent decades, especially in developing countries such as China.
   Since the implementation of the Sustainable Development Goals (SDGs) and
   integrated coastal management, the ecological importance of Suaeda
   species has been increasingly emphasized in restoration efforts.
   However, the recovery trajectory and driving mechanisms remain unclear.
   To address this gap, we mapped Suaeda distributions for 2016, 2020, and
   2024, and analyzed the factors influencing its spatial distribution and
   changes. Overall accuracies for Suaeda species distribution exceeded
   87\%. From 2016 to 2024, the area covered by Suaeda species in coastal
   China increased from 64.83 km2 to 99.5 km2, demonstrating an overall
   upward trend with fluctuations, which reflects spatial heterogeneity and
   dynamic local colonization-disappearance processes. We found the spatial
   distribution was determined by relatively stable mean environmental
   factors, including soil electrical conductivity, annual mean
   temperature, sea surface salinity, and evapotranspiration during
   germination. We further discovered that temporal changes were driven by
   extreme environmental factors and human activities: negatively
   associated with Spartina alterniflora invasion, aquaculture expansion,
   and maximum sea surface salinity, but positively with minimum tidal
   levels. These findings underscore the role of S. alterniflora removal
   and aquaculture pond retreat strategies in facilitating Suaeda species
   restoration. As a case of global coastal governance, this study shows
   that pioneer community recovery is neither stable nor linear,
   highlighting the need to evaluate restoration beyond simple changes in
   community extent.},
Type = {Article},
Affiliation = {Zhao, CP (Corresponding Author), Chinese Acad Sci, Northeast Inst Geog \& Agroecol, State Key Lab Black Soils Conservat \& Utilizat, Changchun, Peoples R China.
   Yan, Yangyang; Zhao, Chuanpeng; Jia, Mingming; Zhang, Rong; Ren, Chunying; Wang, Zongming, Chinese Acad Sci, Northeast Inst Geog \& Agroecol, State Key Lab Black Soils Conservat \& Utilizat, Changchun, Peoples R China.
   Yan, Yangyang, Univ Chinese Acad Sci, Coll Resources \& Environm, Beijing, Peoples R China.},
DOI = {10.1080/15481603.2026.2643946},
Article-Number = {2643946},
Keywords = {<italic>Suaeda</italic> species; decision rules; spatiotemporal
   distribution; recovery trajectory; driving factors},
Keywords-Plus = {RANDOM FOREST; CLASSIFICATION; TEMPERATURE; DISTURBANCE; SENTINEL-2;
   IMPACTS; DATASET; MARSHES; NICHE},
Author-Email = {zhaochuanpeng@iga.ac.cn},
Number-of-Cited-References = {84},
Times-Cited = {0},
Unique-ID = {WOS:001713399500001},
}

@article{ WOS:001712261100001,
Author = {Mehmood, Kaleem and Anees, Shoaib Ahmad and Shahzad, Fahad and Gardazi,
   Syed Mubashar Hussain and Sardor, Sabirov and Atajanova, Saodat and
   Alkhuraiji, Wafa Saleh and Zhran, Mohamed},
Title = {Remote sensing and machine learning-based mapping of climatic stress
   impacts on vegetation and carbon sequestration},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2026},
Volume = {41},
Number = {1},
Month = {DEC 31},
Abstract = {This study develops a Vegetation Stress Index (VSI) to quantify
   spatiotemporal vegetation stress and its implications for carbon
   sequestration across the northern forests of Pakistan. The index
   integrates Solar-Induced Fluorescence (SIF), kernel NDVI (kNDVI), and
   hydroclimatic drivers, including soil moisture, precipitation, and
   temperature anomalies, for 2001-2023. VSI revealed strong spatial
   heterogeneity, with persistent stress hotspots covering about 10\% of
   forest area, while nearly three quarters of the region remained stable
   or improved. Time-series analysis identified 2006, 2007, and 2020 as
   major stress years. SHAP analysis showed that soil moisture was the
   dominant control on VSI (mean SHAP = 0.121), identifying water
   limitation as the main constraint on vegetation condition. Years with
   stronger soil-moisture limitation coincided with greater carbon uptake
   loss, especially in 2007 and 2020. These findings demonstrate the
   utility of VSI for diagnosing climatic stress and guiding forest
   resilience planning.},
Type = {Article},
Affiliation = {Zhran, M (Corresponding Author), Mansoura Univ, Fac Engn, Publ Works Engn Dept, Mansoura, Egypt.
   Mehmood, Kaleem; Shahzad, Fahad, Beijing Forestry Univ, Precis Forestry Key Lab Beijing, Beijing, Peoples R China.
   Mehmood, Kaleem, Univ Swat, Inst Forest Sci, Main Campus Charbagh, Swat, Pakistan.
   Anees, Shoaib Ahmad, Univ Agr, Dept Forestry, Dera Ismail Khan, Pakistan.
   Gardazi, Syed Mubashar Hussain, Women Univ Azad Jammu \& Kashmir, Dept Environm Sci, Bagh, Pakistan.
   Sardor, Sabirov, Mamun Univ, Dept Gen Profess Sci, Khiva City, Uzbekistan.
   Atajanova, Saodat, Urgench State Univ, Dept Transport Syst, Urgench, Uzbekistan.
   Alkhuraiji, Wafa Saleh, Princess Nourah bint Abdulrahman Univ, Coll Humanities \& Social Sci, Dept Geog \& Environm Sustainabil, Riyadh, Saudi Arabia.
   Zhran, Mohamed, Mansoura Univ, Fac Engn, Publ Works Engn Dept, Mansoura, Egypt.},
DOI = {10.1080/10106049.2026.2641408},
Article-Number = {2641408},
Keywords = {Vegetation stress index; solar-induced fluorescence; carbon uptake loss;
   remote sensing; forest ecosystem resilience},
Keywords-Plus = {SOIL-MOISTURE; DROUGHT},
Author-Email = {mohamedzhran@mans.edu.eg},
Number-of-Cited-References = {105},
