@article{ WOS:001695965200001,
Author = {Putra, Muhamad Iqbal Januadi and Phinn, Stuart},
Title = {Integrating artificial neural network-cellular automata and bayesian
   weight of evidence for spatiotemporal analysis of urban change in
   Brisbane City},
Journal = {COMPUTATIONAL URBAN SCIENCE},
Year = {2026},
Volume = {6},
Number = {1},
Month = {FEB 21},
Abstract = {Urbanisation is a global phenomenon, with major cities worldwide
   undergoing rapid transformation driven by economic and population
   growth. However, the urbanisation process in Brisbane City remains
   comparatively underexplored relative to other Australian metropolitan
   areas. This study presents a novel integrated framework that combines
   Google Earth Engine (GEE), Bayesian weight of evidence (WofE), and
   Artificial Neural Network-Cellular Automata (ANN-CA) to analyse and
   forecast spatiotemporal patterns of urban change. The research addresses
   three objectives: (i) monitoring urban settlements in Brisbane City from
   1990 to 2021, (ii) identifying the drivers of urban expansion between
   1990 and 2021, (iii) projecting future urban growth to 2030, and (iv)
   critically assessing the capability, strengths, and weaknesses of the
   ANN-CA model. Random forest classification using GEE achieved overall,
   producer, and user accuracies ranging from 0.97 to 1.00. The results
   revealed a period of stagnation and slight decline during 1990-2000,
   followed by accelerated expansion from 2000-2021, during which the urban
   area nearly doubled from 142.29 km2 to 307.41 km2. WofE analysis
   highlighted key determinants of urban growth, including distance to the
   central business district, proximity to waterways, roads, and points of
   interest, as well as topographic variables. ANN-CA simulations
   underscored the model's sensitivity to underfitting, overfitting, and
   imbalanced change rates. Adaptive-period recalibration improved
   performance, with validation on 2021 dataset yielding 93.69\% overall
   accuracy and Kappa coefficient of 0.67. Based on this corrective method,
   the model projects Brisbane's urban extent to reach 380.45 km2 by 2030.
   This integrated approach offers methodological advances and new insights
   into the mechanisms and trajectories of urban expansion.},
Type = {Article},
Affiliation = {Phinn, S (Corresponding Author), Univ Queensland, Sch Environm, Brisbane, Qld 4072, Australia.
   Putra, Muhamad Iqbal Januadi; Phinn, Stuart, Univ Queensland, Sch Environm, Brisbane, Qld 4072, Australia.
   Putra, Muhamad Iqbal Januadi, Univ Indonesia, Dept Geog, Depok, Indonesia.},
DOI = {10.1007/s43762-026-00248-7},
Article-Number = {13},
Keywords = {Artificial Neural Network-Cellular Automata (ANN-CA); Bayesian weight of
   evidence (WofE); GEE; GIS; Remote sensing; Spatiotemporal urban change},
Keywords-Plus = {GROWTH; MODEL; GIS},
Author-Email = {s.phinn@uq.edu.au},
Number-of-Cited-References = {57},
Times-Cited = {0},
Unique-ID = {WOS:001695965200001},
}

@article{ WOS:001695731000001,
Author = {Thapa, Bina and Darling, Lindsay and Choi, Dennis H. and Hardiman, Brady
   S. and Fei, Songlin},
Title = {Optimal spectra for deciduous tree species identification in urban
   areas: insights from hyperspectral remote sensing},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2026},
Month = {2026 FEB 21},
Abstract = {Tree species identification is fundamental for forest inventory, which
   can be achieved through hyperspectral remote sensing. However, the
   large-scale application of hyperspectral data is currently limited due
   to the cost of data acquisition and computational demand in data
   processing, which can be potentially resolved by identifying unique
   spectra associated with tree species. This study leveraged 49,000
   individual trees of 23 temperate deciduous species and multi-season
   (spring and summer) hyperspectral data (400-1000 nm, 178 bands, 1 m)
   from urban areas to identify optimal bands and bandwidths associated
   with species identification. We identified nine standard bands between
   spring and summer seasons that provided tree species identification
   accuracy (0.78 and 0.83) that is comparable to those based on 178 bands
   (0.83 and 0.86) and 21 bands (0.81 and 0.85), indicating that a few
   optimal bands are sufficient to classify deciduous tree species in urban
   settings. These optimal bands are from spectral regions of near-infrared
   (NIR), green, and red: four NIR bands centred at 761.60, 799.40, 857.80,
   and 943.40 nm; three green bands at 521.30, 538.40, and 558.90 nm; and
   two red bands at 658.30 and 696.20 nm. Reducing spectral resolution from
   narrow (3.40 nm) to broadband (range: 17.00 to 37.60 nm) retained
   similar classification accuracy (0.78 and 0.83 for spring and summer,
   respectively). These results demonstrate that nine unique spectral bands
   in the NIR, green, and red regions with bandwidth from 17.00 to 37.60 nm
   are adequate for identifying deciduous tree species. Furthermore, our
   study presents a robust approach for improving the efficiency of machine
   learning methods using these bands and suggests that integrating them
   into the design of affordable future multispectral sensors may enable
   unprecedented levels of tree species identification across scales.},
Type = {Article; Early Access},
Affiliation = {Fei, SL (Corresponding Author), Purdue Univ, Dept Forestry \& Nat Resources, 715 W State St, W Lafayette, IN 47906 USA.
   Thapa, Bina; Darling, Lindsay; Choi, Dennis H.; Hardiman, Brady S.; Fei, Songlin, Purdue Univ, Dept Forestry \& Nat Resources, 715 W State St, W Lafayette, IN 47906 USA.
   Darling, Lindsay, Morton Arboretum, Lisle, IL USA.
   Choi, Dennis H., Dankook Univ, Coll Bioconvergence, Sch Life Resources, Cheonan, South Korea.
   Hardiman, Brady S., Purdue Univ, Environm \& Ecol Engn, W Lafayette, IN USA.},
DOI = {10.1080/01431161.2026.2626094},
EarlyAccessDate = {FEB 2026},
Keywords = {Hyperspectral; optimal bands and bandwidths; species},
Keywords-Plus = {LEAF CHLOROPHYLL CONTENT; VEGETATION LIQUID WATER; NARROW-BAND; RED
   EDGE; REFLECTANCE; INDEXES; CLASSIFICATION; RETRIEVAL; LEAVES; COLUMN},
Author-Email = {sfei@purdue.edu},
