   Miranda, Marcelo D.; Meza, Francisco J., Pontificia Univ Catolica Chile, Ctr Interdisciplinario Cambio Global CCG, Santiago, Chile.
   Becerra, Pablo, Ctr Nacl Excelencia Ind Madera CENAMAD, Santiago, Chile.},
DOI = {10.1111/jvs.70105},
Article-Number = {e70105},
Keywords = {ecosystem functional types; Mediterranean-type ecosystems in Chile;
   MODIS vegetation indices; vegetation phenology},
Keywords-Plus = {ECOSYSTEM FUNCTIONAL TYPES; PRODUCTIVITY; FOREST; DIVERSITY; DROUGHT;
