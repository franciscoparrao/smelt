   Palmate, Santosh S., Texas A\&M Univ, Dept Biol \& Agr Engn, Scoates Hall,333 Spence St,2117 TAMU, College Stn, TX 77843 USA.},
DOI = {10.1016/j.compag.2025.111280},
EarlyAccessDate = {DEC 2025},
