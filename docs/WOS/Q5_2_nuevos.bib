   Turtiainen, Marjut, Arctic Flavours Assoc, Kauppakatu 20d, FI-89600 Suomussalmi, Finland.},
DOI = {10.3390/f17020253},
Article-Number = {253},
Keywords = {sample plot; bilberry; drone; segmentation; object detection; SAM; YOLO},
Keywords-Plus = {VACCINIUM-MYRTILLUS; NORTH KARELIA; VITIS-IDAEA; YIELDS},
