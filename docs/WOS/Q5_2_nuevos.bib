@article{ WOS:001719534900018,
Author = {Chen, Lingshan and Wan, Bo and Chen, Zongzhu and Cheng, Cheng and Wu,
   Minghui and Qiu, Penghua and Wang, Dezhi},
Title = {AEZGO: A Novel Approach for Mapping Mangrove Canopy Height Using UAV
   Lidar Data and Sentinel-2 Images},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {9226-9240},
Abstract = {Accurate mangrove canopy height mapping is essential for assessing blue
   carbon and protecting coastal communities. Yet, existing methods face
   dual challenges: 1) spectral saturation causing systematic bias
   (underestimation of tall trees and overestimation of short trees), and
   2) spatial heterogeneity of mangrove ecosystems impairing model
   generalizability across large areas. This study develops an automatic
   ecological zoning and geo-balanced optimization approach integrating
   Sentinel-2 imagery, UAV lidar data, and mangrove ecological knowledge to
   address the challenges. The approach involves: 1) automatic ecological
   zoning via an adaptive weighted partitioning algorithm based on four
   ecological knowledge types (environmental factors, spectral
   characteristics, canopy height-spectral correlations, and administrative
   boundaries) to reduce spatial heterogeneity, and 2) geo-balanced
   optimization integrates sample balancing, feature selection, and spatial
   covariates to resolve spectral saturation in spectral-height
   relationships. Applied to Hainan Island, China, the approach achieved
   significantly higher accuracy (R-2 = 0.74, RMSE = 1.12 m) compared to
   traditional random forest (R-2 = 0.59, RMSE = 1.34 m). Notably, it
   reduced balanced mean errors (aME) by 42\% for tall trees (>7 m, 2.57 to
   1.49 m) and 37\% for short trees (<3 m, -0.76 to -0.48 m). The resultant
   mangrove canopy height map revealed an average height of 3.77 m across
   Hainan's mangroves. Compared to the existing mangrove canopy height maps
   from other studies, our approach yielded the most accurate results for
   Hainan Island. The proposed approach shows potential for broader
   application, thereby supporting large-scale precision management of
   mangrove-related tasks such as carbon sink accounting and the evaluation
   of coastal protection services like windbreak and wave dissipation.},
Type = {Article},
Affiliation = {Wang, DZ (Corresponding Author), Hubei Univ, Fac Resources \& Environm Sci, Wuhan 430062, Peoples R China.
