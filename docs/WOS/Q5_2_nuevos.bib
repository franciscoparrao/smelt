@article{ WOS:001669876800001,
Author = {Hammad, Sherwan Yassin and Kovacs, Gergo Peter and Milics, Gabor},
Title = {Ambrosia artemisiifolia in Hungary: A Review of Challenges,
   Impacts, and Precision Agriculture Approaches for Sustainable
   Site-Specific Weed Management Using UAV Technologies},
Journal = {AGRIENGINEERING},
Year = {2026},
Volume = {8},
Number = {1},
Month = {JAN 15},
Abstract = {Weed management has become a critical agricultural practice, as weeds
   compete with crops for nutrients, host pests and diseases, and cause
   major economic losses. The invasive weed Ambrosia artemisiifolia (common
   ragweed) is particularly problematic in Hungary, endangering crop
   productivity and public health through its fast proliferation and
   allergenic pollen. This review examines the current challenges and
   impacts of A. artemisiifolia while exploring sustainable approaches to
   its management through precision agriculture. Recent advancements in
   unmanned aerial vehicles (UAVs) equipped with advanced imaging systems,
   remote sensing, and artificial intelligence, particularly deep learning
   models such as convolutional neural networks (CNNs) and Support Vector
   Machines (SVMs), enable accurate detection, mapping, and classification
   of weed infestations. These technologies facilitate site-specific weed
   management (SSWM) by optimizing herbicide application, reducing chemical
   inputs, and minimizing environmental impacts. The results of recent
   studies demonstrate the high potential of UAV-based monitoring for
   real-time, data-driven weed management. The review concludes that
   integrating UAV and AI technologies into weed management offers a
   sustainable, cost-effective, mitigate the socioeconomic impacts and
   environmentally responsible solution, emphasizing the need for
   collaboration between agricultural researchers and technology developers
   to enhance precision agriculture practices in Hungary.},
Type = {Review},
Affiliation = {Hammad, SY (Corresponding Author), Hungarian Univ Agr \& Life Sci, Doctoral Sch Agr \& Food Sci, Plant Sci Program, Szent Istvan Campus,Pater Karoly u 1, H-2100 Godollo, Hungary.
