}

@article{ WOS:001682673700005,
Author = {Zhang, Yue and Huang, Jiapeng and Liang, Lianhui and Mo, Fan},
Title = {A Hierarchical Optimization Model Based on Multisource Remote Sensing to
   Correct FABDEM},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {5267-5282},
Abstract = {As a global digital elevation model (DEM) corrected for vegetation and
   building influences, the Forest and Buildings Removed DEM (FABDEM)
   provides a closer approximation to bare-earth elevation compared to the
   original DEM. However, it still exhibits substantial elevation errors in
   forested regions. To enhance its accuracy for understory terrain
   extraction, this study integrates multisource remote sensing data to
   construct six machine learning models for high-precision correction of
   FABDEM in Puerto Rico and South Carolina. A comparative experiment was
   designed to assess the contribution of optical remote sensing features
   by contrasting models with and without optical data. Results indicate
   that the Random Forest model incorporating optical features performed
   best, achieving regional correction accuracies with RMSE of 4.96 and
   3.35 m in the two study areas, representing improvements of 38\% and
   34\% over the original FABDEM, respectively. Furthermore, a hierarchical
   optimization model based on forest canopy height further reduced the
   RMSE to 4.05 and 2.88 m, with maximum improvements approaching 50\%. The
   study also quantitatively evaluated the influence of vegetation and soil
   types on correction performance, revealing that areas with higher canopy
   transparency and more stable soil structures are more conducive to
   accurate understory terrain reconstruction. These findings provide a
   robust methodological framework and technical pathway for enhancing DEM
   accuracy in complex forested environments.},
Type = {Article},
Affiliation = {Liang, LH (Corresponding Author), Guangxi Univ, Sch Elect Engn, Nanning 530004, Peoples R China.
   Zhang, Yue; Huang, Jiapeng, Liaoning Tech Univ, Sch Geomat, Fuxin 123000, Peoples R China.
   Liang, Lianhui, Guangxi Univ, Sch Elect Engn, Nanning 530004, Peoples R China.
   Mo, Fan, Minist Nat Resources, Land Satellite Remote Sensing Applicat Ctr, Beijing 100048, Peoples R China.},
DOI = {10.1109/JSTARS.2026.3656929},
Keywords = {Forestry; Accuracy; Remote sensing; Laser radar; Optical sensors;
