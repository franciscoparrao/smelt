   Li, Wenjuan, Chinese Acad Agr Sci, Inst Agr Resources \& Reg Planning, State Key Lab Efficient Utilizat Arable Land China, Key Lab Agr Remote Sensing AGRIRS,Minist Agr \& Rur, Beijing 100081, Peoples R China.},
DOI = {10.1080/17538947.2025.2496403},
Article-Number = {2496403},
Keywords = {Google Earth Engine; remote sensing retrieval; look-up table (LUT);
