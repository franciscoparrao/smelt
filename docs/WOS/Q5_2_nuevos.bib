   Yakovlev, Vladislav V., Texas A\&M Univ, Dept Biomed Engn, College Stn, TX USA.
   Wang, Da-Wei, Hefei Natl Lab, Hefei, Peoples R China.},
DOI = {10.1117/1.APN.5.1.016016},
Article-Number = {016016},
Keywords = {scattering; unsupervised learning; speckle interpretation; pattern
   recognition; image sensing},
Keywords-Plus = {CONCENTRATION FLUCTUATIONS; SCATTERING},
