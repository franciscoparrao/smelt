@article{ WOS:001694521500023,
Author = {Thomas, Leena and Mary Synthuja Jain Preetha, M. and Vijula Grace, K. S.},
Title = {High-Precision Canopy Height Estimation Using Autoencoders With
   Multisource RGB Satellite Imagery and LiDAR Fusion},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {23894-23906},
Abstract = {Deforestation poses a significant threat to humanity. Accurate
   measurement of canopy height and land cover in protected areas is
   essential to understand the extent of deforestation. In this study, we
   introduce three novel methods for creating canopy height maps of the
   Western Ghats, a protected area in India, with an accuracy of 1 meter
   per pixel for the year 2024. We develop multiple Machine Learning models
   that integrate RGB images from Planet Labs, Sentinel data, and height
   information from the Global Ecosystem Dynamics Investigation to produce
   high quality canopy height maps of the Western Ghats. These three models
   draw inspiration from Convolutional Autoencoder architecture and are
   designed to enhance the accuracy of canopy height prediction across
   various tropical forest types in the Western Ghats region. The proposed
   models offer a significant improvement in the accuracy of canopy height
   estimation. Our study found that 51\% of the forest in the Western Ghats
   consists of tropical moist deciduous forests, with 17\% of the trees in
   these forests having heights between 20 and 24 meters. Tropical dry
   deciduous forest covers 41\% of the Western Ghats. Furthermore, only 2.
   8\% of the trees in these forests exceed a height of 40 meters. This
   expansion of tropical dry deciduous forests signifies a stage of natural
   succession, influenced by past land use practices or disturbances.},
Type = {Article},
Affiliation = {Thomas, L (Corresponding Author), Noorul Islam Ctr Higher Educ, Kumaracoil 629180, India.
   Thomas, Leena; Mary Synthuja Jain Preetha, M.; Vijula Grace, K. S., Noorul Islam Ctr Higher Educ, Kumaracoil 629180, India.},
DOI = {10.1109/ACCESS.2026.3660738},
Keywords = {Laser radar; Satellites; Satellite images; Neon; Accuracy; Spatial
   resolution; Biological system modeling; Surveys; Meters; Deforestation;
   Lidar; RGB satellite images; variational auto encoder; canopy height
   map; Sentinel-2 imagery; Planet Labs imagery},
Keywords-Plus = {WESTERN-GHATS},
Author-Email = {leenathomas@fisat.ac.in},
Number-of-Cited-References = {43},
Times-Cited = {0},
