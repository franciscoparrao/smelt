}

@article{ WOS:001690551100004,
Author = {De Clerck, Emma and Verrelst, Jochem},
Title = {A User-Friendly Google Earth Engine Web Application for Vegetation Trait
   Mapping and Time Series Analysis From Sentinel-2 and Sentinel-3 Imagery},
Journal = {IEEE GEOSCIENCE AND REMOTE SENSING LETTERS},
Year = {2026},
Volume = {23},
Abstract = {A Google Earth Engine (GEE) web application is introduced for automated
   mapping of a suite of quantitative vegetation traits (e.g., LAI, fAPAR,
   GPP, and chlorophyll/nitrogen/water content) from Sentinel-2 and
   Sentinel-3 imagery, covering both surface reflectance and
   top-of-atmosphere radiance. The system operationalizes validated
   Gaussian process regression (GPR) models based on radiative transfer
   simulations within a fully cloud-based workflow, enabling on-demand
   generation of vegetation trait maps at 20-300-m resolution without
   requiring coding expertise. Key innovations include: 1) dynamic model
   loading for 30 GPR models enabling estimation of 11 vegetation traits;
   2) automated masking/compositing for trait mapping; and 3)
   Savitzky-Golay smoothing for noise-reduced temporal analysis. The
   application demonstrates the potential of GEE to bridge advanced machine
   learning-based retrieval methods and practical, operational Earth
   observation use.},
Type = {Article},
Affiliation = {De Clerck, E (Corresponding Author), Univ Valencia, Image Proc Lab IPL, Valencia 46980, Spain.
   De Clerck, Emma; Verrelst, Jochem, Univ Valencia, Image Proc Lab IPL, Valencia 46980, Spain.},
DOI = {10.1109/LGRS.2026.3658233},
Article-Number = {5001105},
Keywords = {Biological system modeling; Vegetation mapping; Time series analysis;
   Computational modeling; Sensors; Load modeling; Earth; Cloud computing;
   Training; Remote sensing; Gaussian processes regression hybrid models;
   Google Earth Engine (GEE); remote sensing; Sentinel-2 surface
   reflectance and top-of-atmosphere; Sentinel-3 Ocean and Land Color
   Instrument; time series analysis; vegetation trait retrieval},
Keywords-Plus = {PLATFORM},
Author-Email = {emma.clerck@uv.es
   jochem.verrelst@uv.es},
