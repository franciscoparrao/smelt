   Zhao, Qunshan, Univ Glasgow, Urban Big Data Ctr, Sch Social \& Polit Sci, Glasgow, Scotland.
   Zheng, Zhi, Chinese Univ Hong Kong, Dept Geog \& Resource Management, Hong Kong, Peoples R China.},
DOI = {10.1016/j.jag.2026.105160},
EarlyAccessDate = {FEB 2026},
