   Liu, Ruihao; Chang, Cun; Zhong, Ruisen, Xinjiang Uygur Autonomous Reg, Key Lab GIS \& RS Applicat, Urumqi 830011, Peoples R China.},
DOI = {10.3390/rs17243945},
