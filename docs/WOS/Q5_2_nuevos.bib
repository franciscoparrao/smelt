@article{ WOS:001682535900003,
Author = {Bindajam, Ahmed Ali and Mallick, Javed and Alshayeb, Mohammed J. and
   Poddar, Sayanti},
Title = {Understanding urbanization and its expansion process in Bengaluru
   through geostatistical models for landscape management},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2026},
Volume = {77},
Number = {3},
Pages = {2855-2880},
Month = {FEB 1},
Abstract = {Urban sprawl in rapidly growing cities like Bengaluru has emerged as a
   critical planning challenge, often resulting in fragmented landscapes,
   ecological degradation, and pressure on infrastructure. This study
   evaluates the spatial-temporal dynamics of urbanization in Bengaluru
   from 1994 to 2024 using advanced geospatial modeling techniques. Landsat
   4/5 TM and Landsat 8/9 OLI datasets were classified with a Random Forest
   algorithm, achieving high classification accuracy (overall >90 \%, Kappa
   >0.85). Land Use and Land Cover (LULC) analysis reveals that built-up
   area increased from 162.35 km(2) in 1994 to 376.37 km(2) in 2024 (+31.9
   \%), while open land declined from 429.08 km(2) to 210.67 km(2) (-50.9
   \%); vegetation fluctuated from 106.86 km(2) in 1994 to 111.24 km(2) in
   2024, and water bodies decreased from 21.40 km(2) in 2004 to 11.24 km(2)
   in 2024. Change Vector Analysis showed a progressive rise in mean
   transformation magnitude from 5.4 (1994-2004) to 8.9 (1994-2024).
   Transition matrices indicate substantial conversions to built-up, with
   similar to 33 \% of vegetation and 30 \% of water bodies transformed.
   Spatial pattern indices confirm structural reorganization: the Urban
   Contiguity Index rose from 0.40 to 0.82, while the Urban Dispersion
   Index fell from 0.59 to 0.17, alongside an increase in Built-Up Density
   Index (0.134-0.311) and Edge Density (approximate to 2858-4932).
   Built-up density intensified (mean 1.21-2.80), with the high-density
   share expanding (approximate to 21.6-42.2 \%). Leapfrogging dominated
   early growth (LUI = 0.50, 1994-2004), whereas infill strengthened later
   (IR = 0.37, 2014-2024). These findings provide evidence of a transition
   from fragmented to more compact growth, underscoring the need for
   sustainable planning. The integrated framework offers a replicable
   diagnostic model for urban sprawl in rapidly urbanizing regions of the
   Global South. (c) 2025 COSPAR. Published by Elsevier B.V. All rights are
   reserved, including those for text and data mining, AI training, and
   similar technologies.},
Type = {Article},
Affiliation = {Mallick, J (Corresponding Author), King Khalid Univ, Coll Engn, Dept Civil Engn, Abha, Saudi Arabia.
   Bindajam, Ahmed Ali; Alshayeb, Mohammed J., King Khalid Univ, Coll Architecture \& Planning, Dept Architecture, Abha, Saudi Arabia.
   Mallick, Javed, King Khalid Univ, Coll Engn, Dept Civil Engn, Abha, Saudi Arabia.
   Poddar, Sayanti, Univ Calcutta, Asutosh Coll, Dept Geog, Kolkata 700026, W Bengal, India.},
DOI = {10.1016/j.asr.2025.11.018},
EarlyAccessDate = {JAN 2026},
Keywords = {Urban sprawl; Land use and land cover change; Random forest; Random
   forest classification; Change vector analysis; Built-up density mapping},
