@article{ WOS:001678579400001,
Author = {Tran, Thi Thu Trang and Trinh, Le Hung and Do, Thi Phuong Thao and Le,
   Van Phu},
Title = {Drought risk assessment in Quang Tri Province, Vietnam using Landsat
   multi-temporal remote sensing data and machine learning algorithm},
Journal = {BULLETIN OF GEOGRAPHY-PHYSICAL GEOGRAPHY SERIES},
Year = {2026},
Volume = {30},
Pages = {25-37},
Month = {JAN},
Abstract = {Drought is a major environmental challenge that significantly impacts
   agriculture, water resources and ecosystems, particularly in regions
   prone to arid conditions. This study aims to classify and monitor
   drought severity using multi-temporal remote sensing data, drought
   indices and machine learning techniques. Landsat satellite imageries
   from 2014 to 2024, collected at two-year intervals, are utilized to
   assess drought patterns in Quang Tri Province, Vietnam. Three key
   drought indices Normalized Difference Vegetation Index (NDVI),
   Normalized Difference Water Index (NDWI) and Land Surface Water Index
   (LSWI) are computed to evaluate vegetation health, surface water content
   and soil moisture levels. The Random Forest algorithm on Google Earth
   Engine (GEE) is applied to classify drought into different severity
   levels based on spectral features extracted from satellite images. The
   results indicate a clear spatial and temporal variation in drought
   severity, with coastal areas consistently undergoing extreme drought,
   whereas central regions show increasing drought expansion over time.
   Western and southern areas remain relatively stable due to higher
   vegetation cover and water retention capacity. The study highlights the
   effectiveness of combining remote sensing data and machine learning in
   improving drought classification accuracy. The findings contribute to
   early-warning systems, water resource management and climate adaptation
   strategies, providing valuable insights for policymakers and land
   managers.},
Type = {Article},
Affiliation = {Trinh, LH (Corresponding Author), Le Quy Don Tech Univ, 236 Hoang Quoc Viet St, Hanoi, Vietnam.
   Tran, Thi Thu Trang; Do, Thi Phuong Thao, Hanoi Univ Min \& Geol, Hanoi, Vietnam.
   Trinh, Le Hung; Le, Van Phu, Le Quy Don Tech Univ, 236 Hoang Quoc Viet St, Hanoi, Vietnam.},
DOI = {10.12775/bgeo-2026-0002},
Keywords = {Remote sensing; Landsat; drought index; Random Forest; Quang Tri
   Province; Vietnam},
Keywords-Plus = {WATER INDEX; CHALLENGES; LSWI; NDVI},
Author-Email = {trinhlehung@lqdtu.edu.vn},
Number-of-Cited-References = {37},
Times-Cited = {0},
Unique-ID = {WOS:001678579400001},
}

@article{ WOS:001676230100007,
Author = {Bhatta, Ramesh and Chaity, Manisha Das and Van Aardt, Jan},
Title = {A Novel Data-Driven Approach to Leaf Area Index Modeling Using
   High-Fidelity Simulation-Based Full-Waveform LiDAR Data},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {4693-4716},
Abstract = {Leaf area index (LAI), defined as the total one-sided leaf area per unit
   ground area, is a key parameter in forest eco-physiology and ecosystem
   modeling, linking leaf-level processes to canopy-scale gas exchange and
   energy fluxes. Conventional LAI estimation methods face various
   scalability and accuracy limitations, e.g., field-based approaches are
   constrained by labor-intensive data collection, while passive optical
   remote sensing suffers from documented spectral saturation in dense
   canopies. Full-waveform light detection and ranging (wLiDAR), which
   provides detailed vertical canopy structure, offers a scalable
   alternative to other sensing methods. This study presents a framework
   for LAI estimation using high-fidelity wLiDAR simulations that are
   representative of temperate forest canopy conditions, to evaluate two
   modeling paradigms: first, an interpretable empirical model in a limited
   data regime using waveform-derived metrics, and second, a data-driven
   convolutional neural network (CNN) in a larger data regime. The
   empirical model, based on Gini coefficient, waveform centroid, and total
   return energy, performed well in moderate canopy densities, with peak
   accuracy at intermediate footprint sizes (\$\textbackslash{}approx
   \textbackslash{}! 20 \textbackslash{}text\{ m\}\$). The CNN consistently
   outperformed both the empirical model and traditional off-the-shelf
   regressors-including support vector machines, extreme gradient boosting,
   random forest, gradient boosting, and ElasticNet-achieving an accuracy
   improvement of approximately
   \$5\textbackslash{}\%\textbackslash{}text\{--\}10\textbackslash{}\%\$
   while maintaining robust performance across multiple spatial scales.
   These gains, however, come with increased model complexity, reduced
   interpretability and domain transferability, underscoring the continued
   value of empirical models in ecologically complex scenarios
   characterized by heterogeneous canopy structure, mixed species
   composition, and variable leaf area distributions. Real-data validation
   using land, vegetation, and ice sensor (LVIS) waveforms further
   demonstrated that both the empirical (\$R<\^{}>\{2\}\$ = 0.75, MSE =
   0.05) and CNN (\$R<\^{}>\{2\}\$ = 0.50, MSE = 0.09) models generalize
   well to operational observations. Overall, this work validates both
   interpretable and deep learning approaches for LAI estimation from
   wLiDAR, highlights the influence of footprint size, and establishes a
   simulation-based framework applicable to airborne and spaceborne
   missions, such as LVIS and global ecosystem dynamics investigation
   platforms.},
Type = {Article},
Affiliation = {Bhatta, R (Corresponding Author), Rochester Inst Technol, Dept Chester Carlson Ctr Imaging Sci, New York, NY 14623 USA.
   Bhatta, Ramesh; Chaity, Manisha Das; Van Aardt, Jan, Rochester Inst Technol, Dept Chester Carlson Ctr Imaging Sci, New York, NY 14623 USA.},
DOI = {10.1109/JSTARS.2026.3652921},
Keywords = {Data models; Biological system modeling; Forestry; Laser radar;
   Estimation; Remote sensing; Atmospheric modeling; Vegetation mapping;
   Convolutional neural networks; Optical sensors; Convolutional neural
   network (CNN); empirical modeling; full-waveform LiDAR; leaf area index
   (LAI); LiDAR simulation},
Keywords-Plus = {NEURAL-NETWORKS; AIRBORNE LIDAR; CANOPY STRUCTURE; FOOTPRINT LIDAR;
   FOREST; LAI; VALIDATION; VEGETATION; RETRIEVAL; PRODUCTS},
Author-Email = {rb1005@rit.edu},
Number-of-Cited-References = {99},
Times-Cited = {0},
Unique-ID = {WOS:001676230100007},
}

@article{ WOS:001676230100004,
Author = {Huang, Jiapeng and Zhang, Yue and Yang, Xiaozhu and Mo, Fan},
Title = {A Deep Learning-Based Model for Forest Canopy Height Mapping Using
   Multisource Remote Sensing Data},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {4842-4857},
Abstract = {Forest canopy height is a critical structural parameter for accurately
   assessing forest carbon storage. This study integrates Global Ecosystem
   Dynamics Investigation (GEDI) LiDAR data with multisource remote sensing
   features to construct a multidimensional feature space comprising 13
   parameters. By employing high-dimensional feature vectors of ``spatial
   coordinates + environmental features,{''} the proposed deep
   learning-based neural network-guided interpolation (NNGI) model
   effectively harnesses the capacity of deep learning to model complex
   nonlinear relationships and adaptively extract local features. This
   method adopts a dual-network collaborative architecture to dynamically
   learn interpolation weights based on environmental similarity in the
   feature space, rather than relying on fixed parameters or merely
   considering spatial distance, thereby effectively fusing the complex
   nonlinear relationship modeling capability of deep learning with the
   concept of spatial interpolation. Experiments conducted across five
   representative regions in the United States demonstrate that the overall
   accuracy of the NNGI model significantly outperforms traditional machine
   learning methods, Pearson correlation coefffcient (r) = 0.79,
   root-mean-square error (RMSE) = 5.38 m, mean absolute error = 4.04 m,
   bias = -0.15 m. In areas with low (0\% -20\% ) and high (61\% -80\% )
   vegetation cover fractions, the RMSE decreased by 37.52\% and 5.37\%,
   respectively, while the r-value increased by 15.87\% and 35.90\%,
   respectively. Regarding different slope aspects, the RMSE for
   southeastern and western slopes decreased by 30.38\% and 18.70\%,
   respectively. This study provides a more reliable solution for the
   accurate estimation of forest structural parameters in complex
   environments.},
Type = {Article},
Affiliation = {Huang, JP (Corresponding Author), Liaoning Tech Univ, Sch Geomat, Fuxin 123000, Peoples R China.
   Huang, Jiapeng; Zhang, Yue; Yang, Xiaozhu, Liaoning Tech Univ, Sch Geomat, Fuxin 123000, Peoples R China.
   Mo, Fan, Minist Nat Resources, Land Satellite Remote Sensing Applicat Ctr, Beijing 100048, Peoples R China.},
DOI = {10.1109/JSTARS.2026.3653676},
Keywords = {Forestry; Remote sensing; Spatial resolution; Laser radar; Accuracy;
   Earth; Interpolation; Vegetation mapping; Soft sensors; MODIS; Deep
   learning model; forest canopy height; Global Ecosystem Dynamics
   Investigation (GEDI); multisource remote sensing; neural network-guided
   interpolation (NNGI)},
Author-Email = {huangjp@nefu.edu.cn
   mof@lasac.cn},
Number-of-Cited-References = {31},
Times-Cited = {0},
Unique-ID = {WOS:001676230100004},
}

@article{ WOS:001676230100011,
Author = {Huang, Wei and Li, JiaLu and Chen, Qiqiang and Yin, Junru and Niu,
   Jiqiang and Sun, Le},
Title = {SFCFNet: A Spatial-Frequency Cross-Attention Fusion Network for
   Hyperspectral Image Classification},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {4994-5008},
Abstract = {In recent years, the integration of convolutional neural networks and
   Transformers has significantly advanced hyperspectral image (HSI)
   classification by jointly capturing local and global features. However,
   most existing methods primarily focus on the fusion of spectral-spatial
   features while neglecting the complementary information contained in
   frequency-domain features. To address this issue, we propose a
   spatial-frequency cross-attention fusion network (SFCFNet) that jointly
   models spectral, spatial, and frequency-domain features for HSI
   classification. The framework consists of three core modules: first, the
   multiscale spectral-spatial feature learning module extracts joint
   spectral spatial features using multiscale 3-D and 2-D convolutions.
   Next, the triple-branch representation module employs three branches to
   capture global spatial features of large-scale structures, local spatial
   features of fine-grained textures, and multiscale frequency features
   based on Haar wavelet decomposition, providing complementary multidomain
   representations for subsequent deep fusion. Finally, the dual-domain
   feature cross-attention fusion module achieves effective fusion of
   spatial structures and frequency-domain textures, enhancing the model's
   ability to separate complex backgrounds from fine-grained targets and
   thereby improving classification performance. Compared with other
   methods, SFCFNet achieves higher overall accuracy on the Salinas,
   Houston2013, WHU-Hi-LongKou, and Xuzhou datasets, reaching 99.05\%,
   98.07\%, 98.76\%, and 98.18\%, respectively.},
Type = {Article},
Affiliation = {Huang, W (Corresponding Author), Zhengzhou Univ Light Ind, Sch Comp Sci \& Technol, Zhengzhou 450000, Peoples R China.
   Huang, Wei; Li, JiaLu; Chen, Qiqiang; Yin, Junru, Zhengzhou Univ Light Ind, Sch Comp Sci \& Technol, Zhengzhou 450000, Peoples R China.
