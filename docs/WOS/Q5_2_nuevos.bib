   Ganzorig, Ulgiichimeg, Inst Geog \& Geoecol, 5 Th Khoroo,Baruun Selbe 15-4, Ulaanbaatar, Mongolia.},
DOI = {10.1016/j.rse.2026.115302},
EarlyAccessDate = {FEB 2026},
