@article{ WOS:001703189900001,
Author = {Li, Wenqing and Li, Jin and Wu, Fengwen and Zhang, Zhiming and Chen,
   Jiahui},
Title = {From disagreement to consistency: Evaluating and fusing multi-source
   land cover products for reliable mapping in mountainous southwest China},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {Accurate land cover (LC) data are fundamental for ecosystem management
   and carbon neutrality assessments. Although the increasing availability
   of large-scale LC products, their reliability and transferability in
   complex mountainous regions remain insufficiently evaluated. Here, we
   systematically evaluated eight major global and national LC products in
   Southwest China, a mountainous biodiversity hotspot, to examine their
   spatial consistency, accuracy, and regional applicability. Results
   revealed substantial spatial inconsistencies among LC products from 2000
   to 2020, with overall agreement below 42\%. Agreement was particularly
   low for vegetation related classes, including forest (34.13\%-35.92\%),
   cropland (3.51\%-4.06\%), and shrub/grassland (0.04\%-1.65\%), showing
   strong classification uncertainty in heterogeneous landscapes. These
   discrepancies exhibited clear dependencies on elevation and climatic
   gradients, indicating that topographic complexity and environmental
   heterogeneity play a critical role in shaping interdataset disagreement.
   We further generated improved 30 m LC maps by applying a random forest
   based multi-source fusion strategy to existing LC products and
   multi-temporal Landsat imagery. The fused products consistently achieved
   higher accuracy across key LC types, with forest, cropland and water
   bodies reaching producer's and user's accuracy above 0.80. This study
   underscores the limitations of current large-scale LC products in
   mountainous regions and provides practical guidance for selecting and
   integrating LC products in highly heterogeneous environments.},
Type = {Article},
Affiliation = {Chen, JH (Corresponding Author), Chinese Acad Sci, Kunming Inst Bot, CAS Key Lab Plant Divers \& Biogeog East Asia, Kunming 650201, Peoples R China.
