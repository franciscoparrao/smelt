   Pan, Yaozhong, Qinghai Normal Univ, Acad Plateau Sci \& Sustainabil, Xining 810016, Peoples R China.
   Pan, Yaozhong, Beijing Normal Univ, Xining 810016, Peoples R China.},
DOI = {10.1080/17538947.2025.2540078},
Article-Number = {2540078},
Keywords = {Sentinel-2; red-edge information; spectral index; water anomaly;
   diagnostic framework},
Keywords-Plus = {HARMFUL ALGAL BLOOM; COASTAL; QUALITY; MODEL; LAKES; PEAK},
