   Minotti, P.; Kandus, P., Univ Nacl San Martin UNSAM, Escuela Habitat \& Sostenibil EHyS, Inst Invest \& Ingn Ambiental, 3iA,UNSAM, San Martin, Argentina.
   Minotti, P., Univ Nacl Cordoba UNC, Inst Gulich, Comis Nacl Act Espaciales CONAE, Cordoba, Argentina.},
DOI = {10.1080/01431161.2025.2607760},
EarlyAccessDate = {JAN 2026},
Keywords = {Wetland mapping; Landsat time series; Random Forest; Pampean wetlands;
   spectral indices; hydroperiod},
