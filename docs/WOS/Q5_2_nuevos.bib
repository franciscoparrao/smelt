@article{ WOS:001710658500001,
Author = {Zhu, Bingxue and Wu, Huizhu and Li, Sijia and Chen, Liwen and Song,
   Kaishan},
Title = {A concise real-time identification method of maize phenological period
   based on remote sensing time information and segmented machine learning
   algorithm},
Journal = {REMOTE SENSING OF ENVIRONMENT},
Year = {2026},
Volume = {338},
Month = {MAY 15},
Abstract = {Maize is one of the most important food crops worldwide, and precise
   management of its growth cycle is crucial for ensuring food security.
   The phenological stages of maize can be influenced by geographical
   location, climatic variations, and field management practices. Timely
   and accurate identification of maize phenological stages is vital for
   optimizing agricultural management, reducing fertilizer input, and
   improving yield prediction accuracy. However, current methods for maize
   phenological identification not only exhibit poor generalizability
   across spatiotemporal scales but also require intensive data inputs,
   further exacerbating prediction delays. In this study, we propose a new
   approach for the real-time mapping of maize phenological information by
   integrating time information obtained from remote sensing index and
   meteorological and spectral reflectance (Ref) data. We found the date
   when the Green-Red Vegetation Index (GRVI) equals zero (DOYGRVI=0)
   occurs near the jointing stage. At this stage, the cumulative
   meteorological and physical variables of maize growth are strongly
   associated with subsequent light and heat conditions. Based on this time
   information, we incorporated cumulative meteorological data
   precipitation, accumulated growing degree days, accumulated average
   radiative power density (AARPD), and data such as RED, GREEN, NIR, and
   SWIR Ref values corresponding to the DOYGRVI=0 as machine learning model
   inputs to predict the difference between the AARPD at the predicted
   phenological date and the AARPD corresponding to DOYGRVI=0 (Delta
   AARPD). The Delta AARPDprediction process involves separately conducting
   model training and prediction within distinct DOYGRVI=0 ranges.
   Subsequently, the prediction outputs are integrated with daily radiative
   power density data to enable real-time phenological stage forecasting.
   And this set of strategies demonstrated robust transferability: when
   trained on U.S. maize-growing regions, it achieved 83\% phenological
   identification accuracy (RMSE <2.5 days). Without recalibration, it
   remained directly applicable to Jilin, China-a key maize-producing
   area-exhibiting increased yet operationally acceptable errors (RMSE: 6.5
   days). Compared to existing phenological extraction methods that rely on
   full-season remote sensing time series, our framework requires satellite
   imagery only around the early growth stage, substantially reducing image
   input demands. Moreover, the model demonstrated robust cross-regional
   transferability: when trained on U.S. data and directly applied to
   Jilin, China, without recalibration, it maintained operationally
   acceptable accuracy (RMSE: 6.5 days). This enables cost-effective
   real-time monitoring and demonstrates significant deployment potential
   across global maize belts, particularly in data-scarce regions.},
