@article{ WOS:001641499700022,
Author = {Maia, Aluizio Brito and Renno, Camilo Daleles and Novo, Evlyn Marcia
   Leao de Moraes and de Mira, Italo Rafael Costa},
Title = {Flood Detection in Optical Systems: A Novel Approach to Overcome Cloud
   Cover With DEM Data},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {904-918},
Abstract = {Floods are complex hydrological phenomena influenced by precipitation
   patterns and basin morphology. Although optical remote sensing is widely
   used for flood mapping, its effectiveness is often limited by cloud
   cover, which leads to data gaps and misclassifications. This study
   presents a novel method for detecting flooded areas in
   cloud-contaminated optical imagery by integrating hydrological and
   morphometric attributes derived from digital elevation models (DEMs).
   The approach includes a customized cloud and shadow mask generated using
   the Rpart classifier, designed to reduce false positives while
   preserving surface water signals. The method employs a two-step random
   forest (RF) classification process. The first step (RF1) integrates
   optical imagery with DEM attributes to identify visible surface water.
   The second step (RF2) uses only DEM-derived features to replicate RF1
   and extend flood mapping beneath cloud-covered regions. The method was
   validated using synthetic cloud data, achieving an out-of-bag global
   accuracy (GA) of 94\% and a Jaccard Index of 0.94 for the RF2
   replication task. In independent validation, the model showed strong
   performance: for randomly sampled test data, GA reached 94.06\% with a
   Matthews correlation coefficient (MCC) of 72\% ; for stratified
   sampling, GA reached 88\%, with an MCC of 78\% . These results highlight
   the model's robustness across diverse conditions. The proposed
   cloud-aware flood detection method provides a fast and accurate tool for
   postdisaster mapping, supporting emergency response efforts and
   enhancing flood risk management by mitigating the limitations of
   optical-only approaches.},
Type = {Article},
Affiliation = {Maia, AB (Corresponding Author), Natl Inst Space Res, BR-12227010 Sao Jose Dos Campos, Brazil.
