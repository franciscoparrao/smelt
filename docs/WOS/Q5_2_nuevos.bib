}

@article{ WOS:001655417900001,
Author = {Wen, Zhuojian and Jiang, Desheng and Yin, He and Lu, Yongquan and Zhong,
   Yuqi and Liu, Guilin},
Title = {SDGSAT-1 glimmer imager data for improving the mapping of cropland with
   lighting facilities: An application in dragon fruit field mapping},
Journal = {COMPUTERS AND ELECTRONICS IN AGRICULTURE},
Year = {2026},
Volume = {243},
Month = {MAR 1},
Abstract = {Supplemental lighting facilities are critical for enabling year-round
   dragon fruit production, a practice that leads to higher crop yields and
   enhanced economic returns for local farmers. Tracking the spatial
   patterns of these lighted fields provides essential data for
   decision-makers to implement precise management strategies. However, the
   conventional nighttime light remote sensing datasets (DMSP/OLS,
   SNPP-VIIRS) are ineffective for mapping lighted dragon fruit fields, due
   to their coarse spatial resolution and spectral limitations. To address
   this challenge, this study presents the first assessment of SDGSAT-1
   Glimmer Imager (GLI) data by integrating mean shift segmentation (MSS)
   and random forest (RF) classification to generate a 10-meter resolution
   distribution map of dragon fruit fields across four study sites in China
   and Vietnam. The results showed that the single-date GLI red-green-blue
   (RGB) images alone provided sufficient multispectral information to
   identify dragon fruit fields, achieving the average user accuracy (UA)
   of 85 \%. The GLI RGB bands during the light-on season contributed the
   most significantly (>0.72) to RF-based dragon fruit field
   classification. Dual-temporal GLI RGB images covering the light-on and
   light-off periods yielded higher accuracies, improving the average UA by
   9 \%. Moreover, the SDGSAT-1 GLI panchromatic band combined with the MSS
   algorithm proved effective for delineating dragon fruit field boundaries
   with high precision, significantly outperforming DMSP/OLS and SNPP-VIIRS
   images. Our results demonstrate that SDGSAT-1 GLI data, by providing
   both high spatial resolution and multispectral information, effectively
   overcomes the limitations of previous sensors, enabling accurate
   parcel-scale mapping of dragon fruit fields with lighting facilities.},
Type = {Article},
Affiliation = {Liu, GL (Corresponding Author), South China Normal Univ, Sch Geog, Guangzhou 510631, Peoples R China.
   Wen, Zhuojian; Jiang, Desheng; Lu, Yongquan; Zhong, Yuqi; Liu, Guilin, South China Normal Univ, Sch Geog, Guangzhou 510631, Peoples R China.
   Yin, He, Kent State Univ, Dept Geog, 325 South Lincoln St, Kent, OH 44242 USA.},
DOI = {10.1016/j.compag.2025.111287},
EarlyAccessDate = {DEC 2025},
Article-Number = {111287},
Keywords = {Dragon fruit; Nighttime light; SDGSAT-1 GLI; Remote sensing},
Keywords-Plus = {NIGHTTIME LIGHTS; CHALLENGES; LANDSAT},
Author-Email = {liuguilin@m.scnu.edu.cn},
Number-of-Cited-References = {56},
Times-Cited = {0},
Unique-ID = {WOS:001655417900001},
}

@article{ WOS:001629383300003,
Author = {Brickner, Nechama Z. and Fine, Lior and Rozenstein, Offer and Paz-Kagan,
   Tarin},
Title = {Field crop mapping using machine learning and multi-sensor satellite
   fusion: toward dynamic agricultural monitoring},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Monitoring crop dynamics with precision is vital for food security and
   sustainable agricultural management. Yet, conventional monitoring
   approaches often lack sufficient spatial resolution, revisit frequency,
   and scalability, particularly in heterogeneous and fragmented
   agricultural landscapes. This study introduces a novel hierarchical
   remote sensing framework that integrates Sentinel-1 SAR and Sentinel-2
   multispectral data with machine learning to generate high-resolution,
   multi-season crop type maps across extensive agricultural regions.
   Focusing on the western Negev in Israel (2018-2024), we developed a
   three-tier Random Forest classification workflow specifically designed
   for field crop mapping. The workflow integrates multi-temporal spectral,
   phenological, and SAR-derived features in a stepwise approach: (1)
   agricultural land cover types (94\% overall accuracy), (2) wheat
   identification (95\% accuracy), and (3) classification of 13 field crop
   types (81\% accuracy), including key crops such as wheat, corn, and
   cotton. The hierarchical structure improved classification precision and
   enabled robust generalization across years, facilitating tracking of
   crop rotation, land-use intensity, and field-level management practices.
   Importantly, the model captured climate-driven phenological gradients in
   wheat, revealing spatial variability in crop development patterns that
   conventional methods often overlook. The novelty of this study lies in
   its scalable, multi-sensor classification framework that fuses radar,
   optical, and phenological information to support operational, dynamic
   crop monitoring. By coupling remote sensing outputs with national GIS
   infrastructure, this approach offers a cost-effective, transferable
   solution to advance precision agriculture, promote climate adaptation,
   and guide sustainable land-use planning at regional and national scales.},
Type = {Article},
Affiliation = {Paz-Kagan, T (Corresponding Author), Ben Gurion Univ Negev, Jacob Blaustein Inst Desert Res, French Associates Inst Agr \& Biotechnol Dryland, Sede Boqer Campus, IL-8499000 Beer Sheva, Israel.
   Brickner, Nechama Z.; Fine, Lior; Paz-Kagan, Tarin, Ben Gurion Univ Negev, Jacob Blaustein Inst Desert Res, French Associates Inst Agr \& Biotechnol Dryland, Sede Boqer Campus, IL-8499000 Beer Sheva, Israel.
   Fine, Lior; Rozenstein, Offer, Agr Res Org, Volcani Inst, Inst Soil Water \& Environm Sci, HaMaccabim Rd 68, IL-75359 Rishon Leziyyon, Israel.},
DOI = {10.1016/j.atech.2025.101650},
EarlyAccessDate = {DEC 2025},
Article-Number = {101650},
Keywords = {Hierarchical classification; Crop type mapping; Sentinel-1 and
   sentinel-2; Random forest; Phenology; Crop rotation},
Keywords-Plus = {LAND-COVER CLASSIFICATION; TIME-SERIES; PROGRAM; IMAGERY; WHEAT},
Author-Email = {tarin@bgu.ac.il},
Number-of-Cited-References = {66},
