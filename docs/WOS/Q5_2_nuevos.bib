@article{ WOS:001584762100001,
Author = {Zhang, Xiaomo and Ram, Billy and Vullaganti, Niharika and Aderholdt,
   William and Overby, Paul and Sun, Xin},
Title = {Soil moisture classification using hyperspectral imaging and deep
   learning models on ground robot vehicles},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Soil moisture monitoring is increasingly critical in precision
   agriculture due to growing concerns over food security and sustainable
   water use. While technologies like UAVs, satellite remote sensing, IoT,
   and wireless sensor networks have advanced single-depth soil moisture
   assessment, a major gap remains in leveraging on-the-go sensing systems,
   particularly unmanned ground vehicles (UGVs) with hyperspectral cameras.
   UGV-based hyperspectral systems offer real-time, high-resolution, and
   cost-effective monitoring potential across multiple soil depths.
   Although machine learning and deep learning (DL) models have shown
   strong performance in predicting soil properties like soil organic
   matter using hyperspectral imagery, their application to soil moisture
   classification remains limited. This study addresses that gap by
   developing one-dimensional convolutional neural network (1D-CNN) to
   classify real-time soil moisture at 6-24 inches (15.2-61.0 cm) depth
   using UGV-acquired hyperspectral data. Ground truth was determined using
   gravimetric water content, and hyperspectral data were captured at 6,
   12, 18, and 24 inches (15.2, 30.5, 45.7, and 61.0 cm). The best results
   were achieved using full spectral datasets enhanced with spectral
   augmentation methods, standard normal variation, and first/second
   derivative Savitzky-Golay filtering, along with balanced class
   weighting. The 1D-CNN models achieved testing accuracies up to 0.67 and
   AUC values of 0.85, outperforming models using only the top spectral
   bands selected by random forest and partial least squares regression.
   Green visible (500-565 nm) and near-infrared (750-1000 nm) regions were
   consistently critical for classification. This research demonstrates the
   potential of integrating hyperspectral imaging and DL for timely and
   accurate soil moisture classification, supporting precision irrigation
   and offering valuable tools for researchers and policymakers in
   agricultural water management.},
Type = {Article},
Affiliation = {Sun, X (Corresponding Author), North Dakota State Univ, Dept Agr \& Biosyst Engn, Fargo, ND 58108 USA.
   Zhang, Xiaomo; Ram, Billy; Vullaganti, Niharika; Sun, Xin, North Dakota State Univ, Dept Agr \& Biosyst Engn, Fargo, ND 58108 USA.
   Zhang, Xiaomo; Vullaganti, Niharika, North Dakota State Univ, Sch Nat Resource Sci, Nat Resources Management, Fargo, ND 58108 USA.
   Aderholdt, William, Grand Farm Innovat Campus, 3729 153rd Ave SE, Wheatland, ND 58079 USA.
   Overby, Paul, Lee Farms, Wolford, ND 58385 USA.},
DOI = {10.1016/j.atech.2025.101413},
EarlyAccessDate = {DEC 2025},
Article-Number = {101413},
Keywords = {Soil moisture; Unmanned ground vehicles; Hyperspectral imaging;
   Convolutional neural networks; Random forest; Partial least squares
   regression},
Author-Email = {xin.sun@ndsu.edu},
Number-of-Cited-References = {49},
Times-Cited = {2},
Unique-ID = {WOS:001584762100001},
}

@article{ WOS:001579334300001,
Author = {Shao, Zhanchao and Bryan, Karin R. and Vetrova, Varvara},
Title = {Toward improved spatially-resolved estimates of fine suspended sediment
   in shallow morphologically-complex estuaries},
Journal = {OCEAN MODELLING},
Year = {2025},
Volume = {198},
Month = {DEC},
Abstract = {As a dynamic component of the coastal ecosystem, suspended cohesive
   sediment in fringing regions influences geomorphological features,
   controls light availability, and serves as a transport medium for
   pollutants. Therefore, monitoring suspended sediment concentration (SSC)
   at scale is essential for understanding the resilience of wetlands and
   thus safeguarding the surrounding coastal ecosystem. In this study, a
   novel model was developed to enable continuous estimation of SSC in
   present and future estuarine environments, by combining intermittent
   satellite observations with numerical process-based modelling
   (Delft3D-Flow). Specifically, the correction model consisted of two
   steps: (1) comparing the Delft3D-derived SSC with corrected satellite
   data and using K-means classification to categorise the differences into
   classes; (2) developing a random forest regression model for each class
   to predict the satellite-derived SSC using Delft3D-derived SSC and other
   physical parameters as inputs. The correction model demonstrated
   enhanced accuracy in predicting remotely-sensed SSC testing data (R2 =
   0.71, MAE ranging between 5.45 and 6.05 mg \& sdot;L-1), and was an
   improvement on the SSC predictions derived solely from Delft3D
   simulations, assessed by comparing to a short-term deployment of in situ
   sensors, long-term monitoring data as well as satellite-based estimates.
   The newly developed correction model can enhance our ability to predict
   spatially-resolved SSC in complex intertidal estuaries where collecting
   adequate in situ validation data is challenging.},
Type = {Article},
Affiliation = {Shao, ZC (Corresponding Author), Univ Waikato, Sch Sci, Hamilton 3260, New Zealand.
   Shao, Zhanchao; Bryan, Karin R., Univ Waikato, Sch Sci, Hamilton 3260, New Zealand.
   Bryan, Karin R., Univ Auckland, Sch Environm, Auckland 1142, New Zealand.
   Vetrova, Varvara, Univ Canterbury, Sch Math \& Stat, Christchurch 8041, New Zealand.},
DOI = {10.1016/j.ocemod.2025.102618},
EarlyAccessDate = {DEC 2025},
Article-Number = {102618},
Keywords = {Sediment transport; Numerical modelling; Remote sensing; Machine
   learning; Sediment accretion},
Keywords-Plus = {MODELING SYSTEM ROMS; SEA-LEVEL; COASTAL WETLANDS; RIVER ESTUARY; MARSH
   GROWTH; TRANSPORT; SIMULATION; ACCRETION; SURFACE; FIELD},
Author-Email = {z.shao@waikato.ac.nz},
Number-of-Cited-References = {66},
Times-Cited = {0},
Unique-ID = {WOS:001579334300001},
}

@article{ WOS:001544971600001,
Author = {Le, Minh Tri and Tran, Khuong H. and Dao, Phuong D. and El-Askary,
   Hesham and Ha, V, Tuyen and Park, Taejin},
Title = {High spatial resolution crop type and land use land cover classification
   without labels: A framework using multi-temporal PlanetScope images and
   variational Bayesian Gaussian mixture model},
Journal = {SCIENCE OF REMOTE SENSING},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Previous studies often combined high spatial resolution data (e.g.,
   PlanetScope) with wider spectral range data (e.g., Sentinel-2) and
   relied on supervised classification methods to produce land use and land
   cover (LULC) maps. This study proposed a new unsupervised framework to
   generate crop type and LULC maps at high spatial resolution (<5 m) using
   available PlanetScope data solely without requiring ground truths. We
   used PlanetScope surface reflectance images and their derived spectral
   indices during growing seasons to create multi-temporal input features,
   which were fed into an unsupervised Variational Bayesian Gaussian
   Mixture Model (VBGMM). The VBGMM, unlike the traditional unsupervised
   classification methods, (1) first estimated optimal parameters that are
   most suitable based on the input features and then (2) assigned pixels
   to the cluster with maximum posteriori probability of a mixture of
   several Gaussian distributions. The crop type and LULC maps were then
   generated by labeling the derived clusters using the best possible
   assignment method, referring to the existing crop type or LULC products.
   We evaluated the produced PlanetScope-based crop type and LULC maps
   using true labels, corresponding reference maps, and other unsupervised
   classification methods. The results demonstrated the robustness and
   effectiveness of the proposed framework in mapping crop types and LULC
   at 3-5 m pixels across various ecosystems, climate zones, and
   human-managed landscapes. The spatial patterns of PlanetScopebased maps
   were (1) highly comparable with all the reference datasets at 10-30 m
   spatial resolution and (2) better than the traditional GMM and K-means
   clustering methods. The VBGMM produced classification maps with high
   confidence, yielding class probabilities above 0.9 for over 90 \% of all
   study areas. The area percentage for all crop type and LULC classes
   agreed well with their reference maps, with R2 of 0.95 and RMSE of 1.04
   \%. The confusion matrices using true labels indicated that
   PlanetScope-based maps achieved a higher overall accuracy of 84 \% than
   the supervised referenced maps of 81 \%. Besides, the entropy comparison
   showed that our framework-based maps were better at capturing fine-scale
   features such as developed areas within cities that commonly mix with
   open space and vegetation, deforestation and cropland conversion in
   South America, smallholder croplands in Africa and Asia, and generating
   homogeneous crop fields in North America. This study further highlighted
   the potential for future research to implement our proposed framework to
   generate timely and extensive annotated datasets, which can be used for
   operationally training machine learning models to map crop types and
   LULC, track deforestation, detect wildfires, and delineate flooded areas
   at larger scales using medium/coarse Earth observations.},
Type = {Article},
Affiliation = {Tran, KH (Corresponding Author), NASA Ames Res Ctr, Moffett Field, CA 94035 USA.
   Le, Minh Tri, George Mason Univ, Geog \& Geoinformat Sci Dept, Fairfax, VA 22030 USA.
