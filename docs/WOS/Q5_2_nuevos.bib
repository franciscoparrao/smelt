@article{ WOS:001632913100001,
Author = {Mamidisetti, Hanisha and Vijay, Ritesh},
Title = {A novel approach for assessment of coastal sewage pollution using remote
   sensing and machine learning models},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2025},
Month = {2025 DEC 8},
Abstract = {The study presents a satellite-based approach for monitoring coastal
   sewage pollution using Landsat OLI multispectral images combined with
   machine learning (ML) models. A dual classification approach was
   adopted, with one based on satellite-derived spectral responses and the
   other on field-measured water quality, to validate the association
   between them. ML models, Random Forest (RF), Multilayer Perceptron
   Artificial Neural Network (MLP-ANN), and 1D Convolutional Neural Network
   (CNN) were applied to classify coastal waters under different tidal
   conditions, i.e. high tide (HT) and low tide (LT). All models
   effectively identified sewage-impacted areas such as outfalls, creeks,
   and drains, with CNN providing the consistent performance across tidal
   conditions and sewage sources. A strong association (p < 0.001) was
   observed between the dual classifications. Application of reflectance-
   and water quality-based trained models to new satellite images confirmed
   their close association across flooding, ebbing, and slack tides. The
   Coastal Pollution Score Index (CSPI) revealed the presence of sewage in
   the study area, even beyond the outfalls. Further, the linear
   discriminant analysis identified blue-green during HT and red during LT
   as the most influential spectral bands in distinguishing pollution
   levels. Overall, this study demonstrates an integrated framework for
   coastal management using satellite multispectral data and ML, providing
   a cost-effective and data-driven decision-making tool.},
Type = {Article; Early Access},
Affiliation = {Vijay, R (Corresponding Author), Natl Environm Engn Res Inst NEERI, Wastewater Management Subvert, CSIR, Nehru Marg Nagpur, Nagpur 440020, Maharashtra, India.
   Mamidisetti, Hanisha; Vijay, Ritesh, Natl Environm Engn Res Inst NEERI, Wastewater Management Subvert, CSIR, Nehru Marg Nagpur, Nagpur 440020, Maharashtra, India.
   Mamidisetti, Hanisha; Vijay, Ritesh, Acad Sci \& Innovat Res ACSIR, Ghaziabad, India.},
DOI = {10.1080/01431161.2025.2593715},
EarlyAccessDate = {DEC 2025},
Keywords = {Coastal sewage pollution; coastal water quality; Landsat OLI; machine
   learning; pollution index; remote sensing; tides},
Keywords-Plus = {CLASSIFICATION; WATERS; MUMBAI; INDIA},
Author-Email = {r\_vijay@neeri.res.in},
Number-of-Cited-References = {63},
