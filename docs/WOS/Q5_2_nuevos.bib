DOI = {10.1080/17538947.2025.2594321},
Article-Number = {2594321},
Keywords = {Staple-food bamboo of the giant panda (SFB-GP); understory vegetation;
   space-air-ground integrated monitoring (SAGIM); random forest; giant
   panda national park (GPNP); remote sensing},
Keywords-Plus = {UNDERSTORY PLANT INVASION; SPECTRAL REFLECTANCE; SENTINEL-2; VEGETATION;
