DOI = {10.1080/15481603.2025.2609467},
Article-Number = {2609467},
Keywords = {Corn and soybean mapping; crop index-based classification method;
   Sentinel-2 image; pigment index},
Keywords-Plus = {TIME-SERIES; WATER-CONTENT; INDEX; SENTINEL-1; EXTENT; MAIZE},
Author-Email = {sunjing@caas.cn
