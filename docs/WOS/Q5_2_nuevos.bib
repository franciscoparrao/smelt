@article{ WOS:001707651900001,
Author = {Wu, Xiaocui and Zhou, Qu and Guan, Kaiyu and Wang, Sheng and Hipple,
   James and Peng, Bin and Chen, Zhangliang and Qin, Rongzhu},
Title = {A framework to detect tillage practices from space: A demonstration in
   the US Midwest},
Journal = {REMOTE SENSING OF ENVIRONMENT},
Year = {2026},
Volume = {337},
Month = {MAY 1},
Abstract = {Conservation tillage practices play critical roles in sustainable
   agriculture and have become more popular in the United States (US).
   Accurate spatial and temporal maps about tillage practices are essential
   to monitoring conservation tillage adoption and assessing its impacts on
   soil water and nutrient loss and greenhouse gas emissions. We built a
   dynamic feature threshold framework utilizing satellite data,
   environmental variables, and machine learning to map out tillage
   practices for corn and soybean fields in the Midwest from 2000 to 2022.
   The framework can effectively consider the confounding impact from local
   soil, vegetation, and environmental effects on crop residues. We
   compared tillage mapping accuracy using dynamic feature threshold or
   fixed feature threshold with either broadband angle index (BAI) or
   normalized difference tillage index (NDTI) as the key feature for
   tillage. The results showed that the dynamic feature threshold framework
   paired with BAI feature can accurately estimate tillage percentage for
   three categorical practices (no-till, reduced-till, and
   conventional-till), with R2 of 0.84, 0.62, and 0.76 for no-till,
   reduced-till, and conventional-till in corn fields, and corresponding R2
   of 0.84, 0.52, and 0.70 in soybean fields, respectively. The dynamic
   feature threshold framework achieved better performance with the
   BAI-based feature than the NDTI-based feature, with R2 increasing by
   0.03-0.12 for different corn tillage practices and by 0.05-0.10 for
   soybean. The temporally fixed feature threshold framework has a much
   lower performance than the dynamic feature threshold framework (R2
   reduced by 0.23-0.61 for the accuracy to map different categories of
   tillage for corn and soybean), mainly because it does not consider the
   confounding factors. Based on the results from the dynamics feature
   threshold framework with BAI, we found significant regional differences
   of tillage adoption in the US Midwest. We also found that the adoption
   of conservation tillage (no-till or reduced-till) increases slowly from
   2000 to 2022 across the U.S. Midwest. Northern counties in Dakotas,
   southern Minnesota, eastern Nebraska, and Iowa showed an increase trend
   in no-till percentage, which largely were converted from reduced-till
   percentage. Some counties in Indiana and Ohio showed an increase trend
   in reduced-till percentage, mainly converted from conventional- and
   no-till practices. The proposed framework based on remote sensing leads
   to much improved tillage information in space and time as demonstrated
   in the US Midwest, and provides a highly applicable and cost-effective
   way for regional tillage practice mapping.},
Type = {Article},
Affiliation = {Wu, XC; Guan, KY; Wang, S (Corresponding Author), Univ Illinois, Inst Sustainabil Energy \& Environm, Agroecosyst Sustainabil Ctr, Urbana, IL 61820 USA.
   Wu, Xiaocui; Zhou, Qu; Guan, Kaiyu; Wang, Sheng; Chen, Zhangliang; Qin, Rongzhu, Univ Illinois, Inst Sustainabil Energy \& Environm, Agroecosyst Sustainabil Ctr, Urbana, IL 61820 USA.
   Wu, Xiaocui; Zhou, Qu; Guan, Kaiyu; Wang, Sheng; Chen, Zhangliang; Qin, Rongzhu, Univ Illinois, Coll Agr Consumer \& Environm Sci, Dept Nat Resources \& Environm Sci, Urbana, IL USA.
   Guan, Kaiyu, Univ Illinois, Natl Ctr Supercomp Applicat, Urbana, IL USA.
   Hipple, James, US Dept Agr, Risk Management Agcy, Washington, DC USA.
   Peng, Bin, Univ Illinois, Dept Crop Sci, Urbana, IL USA.},
DOI = {10.1016/j.rse.2026.115323},
Article-Number = {115323},
Keywords = {Tillage practices; Dynamic feature threshold framework; Broadband
   angular index; Sustainable agriculture},
Keywords-Plus = {CROP RESIDUE COVER; NO-TILL; SOIL; SYSTEMS; YIELD},
Author-Email = {xiaocuiw@illinois.edu
   kaiyug@illinois.edu
   swan@agro.au.dk},
Number-of-Cited-References = {46},
