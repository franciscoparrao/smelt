   Roslim, Muhammad Huzaifah Mohd, Univ Putra Malaysia, Fac Agr Sci \& Forestry, Dept Crop Sci, Bintulu, Sarawak, Malaysia.},
DOI = {10.3389/fpls.2025.1662972},
Article-Number = {1662972},
Keywords = {hyperspectral; remote sensing; machine learning; rice crop; weed},
Keywords-Plus = {SPHENOCLEA-ZEYLANICA; LIMNOCHARIS-FLAVA; PATTERNS},
