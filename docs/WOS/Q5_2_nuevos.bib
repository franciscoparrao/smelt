@article{ WOS:001696179900001,
Author = {Do, Anh Ngoc Thi and Do, Tuyet Anh Thi},
Title = {Disruption and vulnerability of forest ecosystems and green spaces under
   the impact of typhoons Yagi and Wipha: A case study in Nghe An province,
   Vietnam},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2026},
Volume = {77},
Number = {5},
Pages = {5837-5861},
Month = {MAR 1},
Abstract = {Climate change has exacerbated the frequency and severity of tropical
   storms, exerting considerable stress on forest ecosystems and green
   areas in Central Vietnam. This research introduces an innovative
   evaluation of cumulative vulnerability levels resulting from the two
   consecutive storms, Yagi (2024) and Wipha (2025), in Nghe An province.
   This research diverges from prior investigations that concentrated on
   singular storms or fixed area loss by quantifying the cumulative effects
   of sequential events on landscape configuration and the hastening of
   fragmentation. Employing Sentinel-2 satellite imagery, we conducted land
   use and land cover (LULC) mapping utilizing Convolutional Neural Network
   (CNN) methodologies to monitor alterations from March 2024 to July 2025.
   The findings reveal a substantial net loss of 28,646.91 ha of forest and
   green spaces over a period of 16 months, while the area of water bodies
   expanded from 2.47\% to 5.64\% as a result of extended flooding. The
   Genetic Algorithm-Dwarf Mongoose Optimization Algorithm (GA-DMOA) model
   was employed to evaluate the vulnerability of forest ecosystems and
   green spaces, achieving notable efficacy with R2 values exceeding 0.85.
   The findings from the GA-DMOA model revealed that variables such as
   rainfall, hydrological factors (including hydrology and hydrology
   density), slope, and fragmentation indices (Disjunct Core Area Density
   (DCAD), Aggregation Index (AI)) were pivotal in determining
   vulnerability, with building density identified as a significant
   anthropogenic variable exacerbating risk in suburban locales. The
   percentage of areas classified as highly vulnerable escalated
   dramatically from 8.51\% during the Yagi storm to 29.95\% during the
   Wipha storm, creating contiguous corridors of vulnerability extending
   from Con Cuong and Tuong Duong to Anh Son and Tan Ky, even reaching
   coastal zones. These results documented a cycle of
   disturbance-reconfiguration-vulnerability; whereby the structural damage
   inflicted by Typhoon Yagi molded the landscape, and subsequent
   hydrological responses, in conjunction with urban pressures from Typhoon
   Wipha, significantly heightened fragmentation and sensitivity. The
   implications of this study establish a novel, comprehensive framework
   for simultaneously assessing the impacts of multiple storms, thereby
   providing a vital scientific foundation for targeted landscape
   restoration and sustainable climate adaptation strategies in storm-prone
   coastal regions. (c) 2025 COSPAR. Published by Elsevier B.V. All rights
   are reserved, including those for text and data mining, AI training, and
   similar technologies.},
Type = {Article},
Affiliation = {Do, ANT (Corresponding Author), Van Lang Univ, Sci \& Technol Adv Inst, Lab Ecol \& Environm Management, Ho Chi Minh City, Vietnam.
   Do, Anh Ngoc Thi, Van Lang Univ, Sci \& Technol Adv Inst, Lab Ecol \& Environm Management, Ho Chi Minh City, Vietnam.
   Do, Anh Ngoc Thi, Van Lang Univ, Fac Appl Technol, Lang Sch Technol, Ho Chi Minh City, Vietnam.
   Do, Tuyet Anh Thi, Hanoi Univ Nat Resources \& Environm, Hanoi, Vietnam.},
