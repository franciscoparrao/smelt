   Duan, Hongtao, Chinese Acad Sci, Nanjing Inst Geog \& Limnol, State Key Lab Lake \& Watershed Sci Water Secur, Nanjing 211135, Peoples R China.},
DOI = {10.1007/s11769-025-1588-0},
Keywords = {cotton cultivation mapping; long-term series; Landsat; Moderate
   Resolution Imaging Spectroradiometer (MODIS); remote sensing; Xinjiang,
   China},
Keywords-Plus = {TIME-SERIES},
