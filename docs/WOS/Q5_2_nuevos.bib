@article{ WOS:001671277100010,
Author = {Sulla-Torres, Jose and Barrios-Lipa, Luis and Toribio-Obando, Bryan and
   Zuniga-Portilla, Enrique and Zuniga-Carnero, Manuel and Rosas-Paredes,
   Karina and Peyre, Gwendolyn},
Title = {Mapping Continental Water Bodies in the Peruvian Andes Using Machine
   Learning and Sentinel-2 Imagery},
Journal = {JOURNAL OF ADVANCES IN INFORMATION TECHNOLOGY},
Year = {2026},
Volume = {17},
Number = {1},
Pages = {122-132},
Abstract = {and characterizing inland water bodies is essential for water resource
   management and ecological monitoring, especially in dry and
   drought-prone areas. In this study, we applied land cover classification
   through remote sensing imagery in the southern Andean region of
   Arequipa, Peru. Machine learning algorithms were employed to identify
   inland water bodies within a heterogeneous landscape, facilitating their
   monitoring, conservation, and sustainable management. The study used the
   Cross-Industry Standard Process for Data Mining (CRISP-DM) methodology,
   which comprises six phases: business modeling, evaluation, and
   deployment. Sentinel-2 multispectral satellite imagery was processed.
   Three supervised machine learning algorithms (Random Forest (RF),
   Support Vector Machine (SVM), and K-Nearest Neighbor (KNN)) were trained
   and tested to classify landscape features into distinct categories and
   map inland water bodies. Cross-validation and random sampling validation
   points were used to evaluate model performance. Among the tested models,
   KNN showed the best performance in detecting lakes and lagoons, with an
   F1-Score of 0.741, an Overall Accuracy (OA) of 0.409, and a Kappa
   coefficient (kappa) of 0.248, outperforming RF and SVM for this specific
   task. The results demonstrate the feasibility of using high-accuracy
   machine learning techniques to classify and map inland water bodies,
   supporting informed decision-making for the conservation and sustainable
   management of aquatic ecosystems in the Arequipa region.},
Type = {Article},
Affiliation = {Sulla-Torres, J (Corresponding Author), Catholic Univ Santa Maria, Profess Sch Syst Engn, Arequipa, Peru.
   Sulla-Torres, Jose; Barrios-Lipa, Luis; Toribio-Obando, Bryan; Zuniga-Carnero, Manuel; Rosas-Paredes, Karina, Catholic Univ Santa Maria, Profess Sch Syst Engn, Arequipa, Peru.
