@article{ WOS:001683478800001,
Author = {Singh, Pooja and Yadav, Basant},
Title = {Ensemble-based mapping and trophic characterization of lentic water
   bodies in the Middle Ganga Basin under climate and land use change},
Journal = {JOURNAL OF ENVIRONMENTAL MANAGEMENT},
Year = {2026},
Volume = {400},
Month = {FEB 15},
Abstract = {Lentic small water bodies (LSWBs), such as ponds and small lakes, play
   an important role in freshwater ecosystems by supporting biodiversity,
   groundwater recharge, and rural subsistence. However, their size and
   ecological integrity are being impacted by changing climates and
   land-use change, and they are still under-represented in large-scale
   water assessments. This study examines the decadal dynamics (2013-2024)
   of LSWBs in the Haridwar watershed of the Middle Gangetic Basin,
   determining how their extent and trophic status have changed as a result
   of environmental and land-use changes. The watershed, located in the
   middle Ganga Basin, was chosen for its extensive pond network that is
   greatly impacted by urbanisation, agriculture, and monsoonal
   variability. To overcome the constraints of single-sensor techniques,
   multi-sensor satellite datasets (Landsat-7/8, Sentinel-1/2) and
   important spectral indices were combined in an ensemble machine-learning
   algorithm to accurately map yearly LSWBs (training = 96.89 \%, testing =
   87.27 \%). Compared to conventional classifiers, the ensemble technique
   improved accuracy, stability, and cloud resilience, enabling continuous
   long-term monitoring. Trophic State Index (TSI) mapping, confirmed with
   field data (accuracy = 78.57 \%, kappa coefficient = 0.74), showed that
   eutrophic and hypereutrophic LSWBs dominated the region (>70 \%),
   indicating chronic nutrient enrichment. Low rainfall and elevated
   temperatures were associated with increasing trophic levels, while
   agricultural expansion and urbanization contributed to land degradation
   and declining water quality. These findings show that climate and
   land-use change have a synergistic effect on LSWBs, and the suggested
   ensemble multi-sensor algorithm provides a scalable, cost-effective tool
   for continuous monitoring and management of small freshwater ecosystems
   in data-scarce regions.},
Type = {Article},
Affiliation = {Yadav, B (Corresponding Author), Indian Inst Technol Roorkee, Dept Water Resources Dev \& Management, Roorkee 247667, India.
   Singh, Pooja; Yadav, Basant, Indian Inst Technol Roorkee, Dept Water Resources Dev \& Management, Roorkee 247667, India.},
DOI = {10.1016/j.jenvman.2026.128754},
EarlyAccessDate = {JAN 2026},
Article-Number = {128754},
Keywords = {Lentic small water bodies; Haridwar waterbody mapping; Ensemble machine
   learning; Trophic state index; Remote sensing},
Keywords-Plus = {ECOSYSTEM SERVICES; LEARNING-MODELS; REMOTE; CLASSIFICATION},
Author-Email = {basant.yadav@wr.iitr.ac.in},
Number-of-Cited-References = {82},
Times-Cited = {0},
Unique-ID = {WOS:001683478800001},
}

@article{ WOS:001681981800001,
Author = {Karadeniz, Enes and Er, Selman and Aydogdu, Mujde and Sunbul, Fatih},
Title = {Bridging expert knowledge and machine intelligence: a hybrid spatial
   indicator framework for ecotourism suitability},
Journal = {ECOLOGICAL INDICATORS},
Year = {2026},
Volume = {183},
Month = {FEB},
Abstract = {Ecotourism suitability assessments increasingly rely on ecological
   indicators that capture spatial heterogeneity, ecosystem sensitivity,
   and biodiversity value. This study develops a hybrid indicator-based
   framework that combines fuzzy expert knowledge with ensemble machine
   learning to quantify ecotourism suitability in Malatya Province, T \&
   uuml;rkiye. Fifteen ecological and socio-environmental predictors,
   including elevation, slope, climate variables, river proximity,
   biodiversity richness, endemic species distributions, and land-cover
   patterns, were incorporated into a GIS-based analytical environment.
   Expert-derived fuzzy weights were computed using the Fuzzy Logarithmic
   Methodology of Additive Weights (F-LMAW) to generate an Ecological
   Suitability Indicator (ESI). Complementarily, K-Means clustering was
   used to derive data-driven suitability classes, which were modeled using
   Random Forest and XGBoost with spatial-block cross-validation. XGBoost
   demonstrated superior classification performance (accuracy = 66.8\%;
   kappa = 0.585). Across all models, biodiversity richness, endemic
   species presence, slope gradients, and river corridors consistently
   emerged as key ecological determinants. While the ESI produced
   conservative suitability zones, ensemble learning identified broader
   high-quality ecological landscapes, including the Levent Valley
   corridor, Nemrut foothills, and river-based habitats. The convergence
   between expert- and data-driven indicators demonstrates the reliability
   of hybrid ecological assessment. The proposed framework offers a
   transparent and transferable approach for constructing ecological
   suitability indicators in data-scarce, biodiversity-rich regions.},
Type = {Article},
Affiliation = {Er, S (Corresponding Author), Inonu Univ, Fac Arts \& Sci, Dept Geog, Malatya, Turkiye.
   Karadeniz, Enes; Er, Selman; Aydogdu, Mujde, Inonu Univ, Fac Arts \& Sci, Dept Geog, Malatya, Turkiye.
   Sunbul, Fatih, Bakircay Univ, Fac Humanities \& Social Sci, Dept Geog, Izmir, Turkiye.},
DOI = {10.1016/j.ecolind.2026.114678},
EarlyAccessDate = {JAN 2026},
Article-Number = {114678},
Keywords = {Ecological suitability indicators; Fuzzy LMAW; Ensemble machine
   learning; Biodiversity hotspots; Spatial ecological modeling; K -means
   clustering; GIS-based assessment},
Keywords-Plus = {TOURISM DEVELOPMENT; GIS; SITES; FUZZY; MODEL},
Author-Email = {selman.er@inonu.edu.tr},
Number-of-Cited-References = {66},
