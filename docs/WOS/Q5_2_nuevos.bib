}

@article{ WOS:001542048500001,
Author = {Rodriguez-Dorna, Andres and Alonso, Laura and Costas, Fernando and
   Picos, Juan and Armesto, Julia},
Title = {Very high resolution Worldview-3 images for land cover mapping on a
   large scale: strengths and remaining challenges},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2025},
Volume = {40},
Number = {1},
Month = {DEC 31},
Abstract = {Land cover (LC) maps are essential for landscape planning and resource
   management on a large scale. Very high-resolution (VHR) images, like
   WorldView-3 (WV3) images, are particularly advantageous for this task in
   fragmented or heterogeneous landscapes due to their high spatial and
   spectral resolutions. However, most studies that emphasize its potential
   cover areas smaller than 100 km2. This study evaluates the potential and
   challenges of using WV3 images for large-scale LC classification,
   developing a forest-oriented LC map of Galicia, Spain (29,578 km2). A
   pre-processing workflow was defined, and three classification algorithms
   were tested: random forest, artificial neural networks, and 2D
   convolutional neural networks, with the latter achieving the highest
   accuracy (67\%, improving to 77\% after applying post-classification
   filtering). Challenges included varying acquisition dates, observation
   geometries, and multiple shadowy areas. WV3 images show promise for
   large-scale LC mapping in heterogeneous landscapes, but consistent
   datasets with uniform acquisition parameters would enhance their
   potential.},
Type = {Article},
Affiliation = {Alonso, L (Corresponding Author), Univ Vigo, Escola Enxenaria Forestal, Pontevedra, Spain.
   Alonso, L (Corresponding Author), Univ Vigo, Grp Xest Segura \& Sostible Recursos Minerais XESSM, CINTECX, Vigo, Spain.
   Rodriguez-Dorna, Andres; Alonso, Laura; Costas, Fernando; Picos, Juan; Armesto, Julia, Univ Vigo, Escola Enxenaria Forestal, Pontevedra, Spain.
   Rodriguez-Dorna, Andres; Alonso, Laura; Armesto, Julia, Univ Vigo, Grp Xest Segura \& Sostible Recursos Minerais XESSM, CINTECX, Vigo, Spain.},
DOI = {10.1080/10106049.2025.2538802},
Article-Number = {2538802},
Keywords = {Worldview-3; large-scale; land cover; convolutional networks; forest},
Keywords-Plus = {REMOTE-SENSING IMAGES; SHADOW DETECTION; TIME-SERIES; CLASSIFICATION;
   SENTINEL-2; ACCURACY; AREAS},
Author-Email = {laura.alonso.martinez@uvigo.es},
Number-of-Cited-References = {103},
Times-Cited = {0},
Unique-ID = {WOS:001542048500001},
}

@article{ WOS:001537606100001,
Author = {Kosanova, Svetlana and Halabuk, Andrej and Kenderessy, Pavol and Rusnak,
   Tomas},
Title = {Assessment of yield stability patterns using sentinel-2 over a 7-year
   period},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2025},
Volume = {40},
Number = {1},
Month = {DEC 31},
Abstract = {This study employed Sentinel-2 satellite data spanning 2018-2024 to
   conduct a subfield-level yield stability assessment within the Danubian
   lowland, Slovakia. A robust spatiotemporal multi-crop framework was
   implemented based on Normalized Difference Vegetation Index (NDVI)
   classification, followed by multiyear stability analysis. This resulted
   in the identification of stable high, medium, low, and unstable yield
   productivity zones. Stable high yielding zones accounted for only 6.5\%
   of the cropland, whereas unstable yield zones comprised almost 47\%. The
   resulting map revealed scattered fine-scale variations in yield
   stability at the parcel level, while also identifying some general
   spatial trends related to climatic and elevation gradients. The key
   factors for distinguishing the two contrasting classes (stable high
   versus low yield zones) were analysed. Gradient boosting classification
   models (XGBoost) were implemented to distinguish these classes,
   achieving a good performance with a Receiver Operating Characteristic
   Area Under the Curve (AUC) of 0.86. Shapley additive explanation
   analysis (SHAP) was applied to enhance model interpretation. Notably,
   elevation, topsoil spectral reflectance (from a Sentinel-2-based bare
   soil mosaic), topography and field size have been identified as key
   predictive features for the classification model.},
Type = {Article},
Affiliation = {Halabuk, A (Corresponding Author), Slovak Acad Sci, Inst Landscape Ecol, Nitra, Slovakia.
   Kosanova, Svetlana, Constantine Philosopher Univ Nitra, Fac Nat Sci \& Informat, Nitra, Slovakia.
   Halabuk, Andrej; Kenderessy, Pavol; Rusnak, Tomas, Slovak Acad Sci, Inst Landscape Ecol, Nitra, Slovakia.},
DOI = {10.1080/10106049.2025.2532529},
Article-Number = {2532529},
Keywords = {Yield productivity zones; remote sensing; precision agriculture; bare
   soil mosaic},
Keywords-Plus = {SOIL ORGANIC-CARBON; MANAGEMENT; AGRICULTURE},
Author-Email = {andrej.halabuk@savba.sk},
Number-of-Cited-References = {59},
Times-Cited = {1},
Unique-ID = {WOS:001537606100001},
}

@article{ WOS:001537597800001,
Author = {Zhang, Wenqi and Luo, Chong and Wang, Zongming and Mao, Dehua},
Title = {Temporal variability in remote sensing accuracy for wetland mapping: a
   case study from Sentinel-1 and Sentinel-2 in Northeast China},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2025},
Volume = {18},
Number = {1},
Month = {DEC 31},
Abstract = {Wetlands are vital ecosystems that support regional ecological balance
   and require efficient, accurate, and cost-effective monitoring
   approaches. This study enhances wetland mapping in the Sanjiang Plain
   using multi-source (Sentinel-1 SAR and Sentinel-2 optical) and
   multi-temporal (2018-2021) satellite data on the Google Earth Engine
   platform. A Random Forest classifier was applied with training samples
   from high-resolution imagery and field surveys. Input features included
   spectral bands, vegetation indices, and radar backscatter coefficients.
   Preprocessing involved cloud masking for Sentinel-2 and speckle
   filtering for Sentinel-1. Classification accuracy was evaluated using
   independent validation samples, overall accuracy, and Kappa coefficient.
   Results indicate October images provide the highest single-year mapping
   accuracy, with Sentinel-1 and Sentinel-2 data from October 2021
   achieving 85.4\% accuracy and a Kappa of 0.669. Multi-temporal data
   improved accuracy to 88.9\% (Kappa = 0.749). Sentinel-1 showed greater
   annual variation in wetland distribution compared to the stable
   Sentinel-2. Precipitation impacted accuracy, reducing Sentinel-2
   performance while variably affecting Sentinel-1. Combining radar and
   optical data with multi-temporal analysis enhances wetland monitoring,
   offering guidance for data acquisition in large-scale conservation.
   Challenges include misclassifications like water-shadow confusion in
   optical imagery and backscatter interference from vegetation in radar
   data, requiring further research.},
Type = {Article},
Affiliation = {Wang, ZM (Corresponding Author), Chinese Acad Sci, Northeast Inst Geog \& Agroecol, State Key Lab Black Soils Conservat \& Utilizat, Changchun, Peoples R China.
   Zhang, Wenqi; Luo, Chong; Wang, Zongming; Mao, Dehua, Chinese Acad Sci, Northeast Inst Geog \& Agroecol, State Key Lab Black Soils Conservat \& Utilizat, Changchun, Peoples R China.
   Zhang, Wenqi, Jilin Agr Univ, Sch Econ \& Management, Changchun, Peoples R China.},
DOI = {10.1080/17538947.2025.2538210},
Article-Number = {2538210},
Keywords = {Wetland mapping; Sentinel image; multi-temporal; multi-source; Northeast
   China},
Keywords-Plus = {WATER INDEX NDWI},
Author-Email = {zongmingwang@iga.ac.cn},
Number-of-Cited-References = {37},
Times-Cited = {0},
Unique-ID = {WOS:001537597800001},
}

@article{ WOS:001534771300001,
Author = {Markovic, Miljana and Lugonja, Predrag and Brdar, Sanja and
   Athanasiadis, Ioannis and Radulovic, Mirjana and Pejak, Branislav and
   Mesaros, Minucer and Crnojevic, Vladimir},
Title = {Double cropping detection in the moderate continental climate region of
   Serbia using machine learning and Sentinel-2 data},
Journal = {EUROPEAN JOURNAL OF REMOTE SENSING},
Year = {2025},
Volume = {58},
Number = {1},
Month = {DEC 31},
Abstract = {Global food security is challenged by population growth and limited
   agricultural land. Intensifying existing cropland use is crucial for
   increasing agricultural production. Mapping cropping intensity, defined
   by annual crop cycles and commonly classified as single, double, or
   triple cropping, is vital for food production modeling. While most
   studies focus on regions with higher cropping intenisity, this study
   targets Vojvodina in northern Serbia, where double cropping is less
   prevalent. We investigated the impact of different vegetation indices
   (VIs) on detecting double cropping using machine learning (ML) and
   Sentinel-2 imagery with collected ground truth data over two years with
   contrasting weather conditions: one dry and one with above-average
   rainfall. Our approach improves existing methods by integrating VIs not
   previously examined in related studies. Alongside NDVI, indices such as
   CVI, VARI, and ExG significantly improved model performance. In the dry
   year (2022), overall accuracy reached 95.80\%, with an F1-score of
   91.19\% for classifying double cropping, while in the wet year (2023),
   the accuracy was 93.56\% and the F1-score 84.96\%. This approach
   simplifies data requirements while maintaining high accuracy, making it
   applicable to regions with similar geographical characteristics.
   Additionally, this study fills a key knowledge gap on the extent and
   distribution of this practice in Serbia.},
Type = {Article},
Affiliation = {Markovic, M (Corresponding Author), Univ Novi Sad, BioSense Inst, Dr Zorana Djindjica 1, Novi Sad 21000, Serbia.
   Markovic, Miljana; Lugonja, Predrag; Brdar, Sanja; Radulovic, Mirjana; Pejak, Branislav; Crnojevic, Vladimir, Univ Novi Sad, BioSense Inst, Dr Zorana Djindjica 1, Novi Sad 21000, Serbia.
   Athanasiadis, Ioannis, Wageningen Univ \& Res, Wageningen, Netherlands.
   Mesaros, Minucer, Univ Novi Sad, Fac Sci, Novi Sad, Serbia.},
DOI = {10.1080/22797254.2025.2533462},
Article-Number = {2533462},
Keywords = {Double cropping; cropping intensity; Sentinel-2; machine learning;
   vegetation indices},
Keywords-Plus = {TIME-SERIES; VEGETATION INDEX; LAND-COVER; AGRICULTURAL INTENSITY;
   ESTIMATING AREA; COLOR INDEXES; RANDOM FOREST; FOOD-DEMAND; MODIS-EVI;
   CHINA},
Author-Email = {miljana.markovic@biosense.rs},
Number-of-Cited-References = {111},
Times-Cited = {0},
Unique-ID = {WOS:001534771300001},
}

@article{ WOS:001522214100001,
Author = {Zhang, Xiaotong and Jia, Mingming and Yan, Fengqin and Zhang, Yongbin
   and Man, Weidong and Li, Fuping and Liu, Mingyue and Wu, Fenghua and
   Yin, Xuan and Duan, Jihang},
Title = {Advancing coastal wetland management: a combined UAV-satellite approach
   for Spartina alterniflora aboveground biomass estimation using
   interpretable machine learning},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2025},
Volume = {18},
Number = {1},
Month = {DEC 31},
Abstract = {Aboveground biomass (AGB) is a key indicator for carbon storage and
   ecological health in wetland ecosystems. Spartina alterniflora
   (S.alterniflora), an invasive species in coastal wetlands, threatens
   biodiversity and blue carbon stocks. This process impacts blue carbon
   stocks in coastal marshes, making their assessment and management during
   ecological restoration crucial. While satellite remote sensing is useful
   for large-scale AGB monitoring, its coarse resolution limits accuracy.
   UAV technology provides high-resolution plot-scale data, complementing
   satellite imagery for more precise estimates. This study proposes a
   combined UAV and satellite remote sensing framework for AGB estimation
   in coastal wetlands. An AGB inversion map for S.alterniflora was
   developed at the plot scale using UAV imagery and a Random Forest (RF)
   model, achieving an R-2 of 0.64 and an RMSE of 0.321 kg/m(2). This map
   was then scaled up to the landscape level by integrating satellite
   imagery, with an R-2 of 0.68 and an RMSE of 0.300 kg/m(2). SHAP analysis
   was conducted to interpret the model, and the statistical analysis of
   AGB under different invasion stages was performed using long-term
   classification data and space-for-time substitution. This approach
   highlights the potential of combining UAV and satellite data for
   large-scale, accurate AGB estimation to inform wetland conservation and
   management efforts.},
Type = {Article},
Affiliation = {Liu, MY (Corresponding Author), North China Univ Sci \& Technol, Coll Min Engn, Tangshan 063210, Peoples R China.
   Zhang, Xiaotong; Zhang, Yongbin; Man, Weidong; Li, Fuping; Liu, Mingyue; Wu, Fenghua; Yin, Xuan; Duan, Jihang, North China Univ Sci \& Technol, Coll Min Engn, Tangshan 063210, Peoples R China.
   Jia, Mingming, Chinese Acad Sci, Northeast Inst Geog \& Agroecol, Key Lab Wetland Ecol \& Environm, Changchun, Peoples R China.
   Yan, Fengqin, Chinese Acad Sci, Inst Geog Sci \& Nat Resources Res, State Key Lab Resources \& Environm Informat Syst, Beijing, Peoples R China.
   Man, Weidong; Li, Fuping, Hebei Ind Technol Inst Mine Ecol Remediat, Tangshan, Peoples R China.
   Liu, Mingyue, Collaborat Innovat Ctr Green Dev \& Ecol Restorat M, Tangshan, Peoples R China.},
DOI = {10.1080/17538947.2025.2525383},
Article-Number = {2525383},
Keywords = {Salt marsh vegetation; random forest; Shapley additive interpretations;
   space-for-time substitution; upscaling},
Keywords-Plus = {CHLOROPHYLL; INVERSION; VARIABLES; FORESTS; MODEL; LEAF},
Author-Email = {liumy917@ncst.edu.cn},
