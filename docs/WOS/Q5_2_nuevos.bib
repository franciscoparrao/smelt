Affiliation = {Akturk, E (Corresponding Author), Kastamonu Univ, Fac Forestry, Dept Forest Engn, Kastamonu, Turkiye.
   Akturk, Emre; Guney, Kerim, Kastamonu Univ, Fac Forestry, Dept Forest Engn, Kastamonu, Turkiye.},
DOI = {10.1080/19479832.2025.2473715},
Article-Number = {2473715},
Keywords = {Land cover; forest/non-forest map; change monitoring; hybrid image
   classification; machine learning; phytogeographic regions},
Keywords-Plus = {MAXIMUM-LIKELIHOOD CLASSIFICATION; LAND-COVER; URBAN EXPANSION;
   IMAGE-ANALYSIS; DECISION TREE; IMPACTS; CHINA},
Author-Email = {eakturk@kastamonu.edu.tr},
