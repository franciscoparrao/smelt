   Papadhopulli, Ina; Sheme, Enida; Mece, Elinda, Polytech Univ Tirana, Fac Informat Technol, Dept Comp Engn, Tirana, Albania.},
DOI = {10.1016/j.dib.2026.112463},
EarlyAccessDate = {JAN 2026},
Article-Number = {112463},
Keywords = {Industrial hemp; Cannabis sativa L.; UAV remote sensing; Multisensor
