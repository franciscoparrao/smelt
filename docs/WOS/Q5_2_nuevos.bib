Article-Number = {2646394},
Keywords = {Urban wetlands; object-based hierarchical wetland classification;
   wetland gain and loss; Google Earth Engine; International Wetland Cities},
Keywords-Plus = {RANDOM FOREST; FINE CLASSIFICATION; SURFACE-WATER; CHINA; DYNAMICS;
   PRODUCT; IMAGERY},
