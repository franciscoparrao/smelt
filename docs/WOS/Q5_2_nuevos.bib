DOI = {10.3390/geomatics6010013},
Article-Number = {13},
Keywords = {wildfire ignition; anthropogenic drivers; machine learning; remote
   sensing; Mediterranean Basin},
Keywords-Plus = {FIRE IGNITION; AREA},
Author-Email = {nicolaaimane.dimarco@etu.uae.ac.ma},
Number-of-Cited-References = {49},
