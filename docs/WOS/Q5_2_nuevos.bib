   de Figueiredo, Felipe Augusto Pereira, Inst Nacl Telecomunicacoes INATEL, Ave Joao Camargo 510, Santa Ritado Do Sapucai, MG, Brazil.},
DOI = {10.1016/j.dib.2026.112472},
