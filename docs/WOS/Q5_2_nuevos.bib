   Dey, Biprateep, Univ Toronto, Dept Stat Sci, Toronto, ON, Canada.
   Dey, Biprateep, Univ Toronto, Canadian Inst Theoret Astrophys CITA, Toronto, ON, Canada.
   Dey, Biprateep, Univ Toronto, Dunlap Inst Astron \& Astrophys, Toronto, ON, Canada.
   Dey, Biprateep, Vector Inst, Toronto, ON, Canada.
   Zhao, David; Lee, Ann B., Carnegie Mellon Univ, Dept Stat \& Data Sci, Pittsburgh, PA 15213 USA.
   Izbicki, Rafael, Fed Univ Sao Carlos UFSCar, Dept Stat, Sao Carlos, Brazil.},
DOI = {10.1088/2632-2153/ae1f05},
Article-Number = {045058},
Keywords = {conditional density estimation; local coverage diagnostics; calibrated
   distributions; reliable uncertainty quantification; posterior
   approximations},
