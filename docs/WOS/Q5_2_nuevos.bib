@article{ WOS:001687152500001,
Author = {Dong, Hesong and Wang, Haoran and Shao, Guofan and Tang, Lina},
Title = {Gains and gaps of large-scale canopy height products for urban tree
   carbon stock inversion: A multi-scale assessment},
Journal = {URBAN FORESTRY \& URBAN GREENING},
Year = {2026},
Volume = {118},
Month = {APR},
Abstract = {While regional and global canopy height models (CHMs) are widely
   available, their practical utility for estimating ecosystem services
   (e.g., carbon stocks) in complex urban settings remains insufficiently
   scrutinized. Existing assessments predominantly focus on statistical
   accuracy, leaving a critical gap in understanding their predictive
   contribution to ecological modeling. This study evaluates the gains and
   limitations of four large-scale CHMs (Potapov, Lang, Tolan, and Malambo)
   for city-level urban tree carbon density (UTCD) inversion. Using
   Washington, D.C., as a testbed, we constructed multiple Random Forest
   models across 10 m, 20 m, and 30 m resolutions, integrating each CHM
   into a robust multi-source baseline derived from Sentinel-1/2 imagery
   and topography. Airborne LiDAR data served as the ground-truth
   benchmark. Results revealed a fundamental disconnect between global
   mapping capabilities and urban precision requirements. First, the
   predictive gain of large-scale CHMs was minimal. While the airborne
   LiDAR benchmark decisively improved performance, largescale CHMs offered
   no substantial gains, confirming their inability to resolve fine-scale
   urban heterogeneity. Second, we observed a distinct scale-dependent
   paradox: while spatial aggregation from 10 m to 30 m increased the
   relative feature importance of CHMs by smoothing high-frequency noise,
   this did not translate into meaningful predictive gains. This
   discrepancy indicates that the structural signals emerging at coarser
   scales transition from being noisy disruptors to becoming
   informationally redundant surrogates, which remain constrained by
   systematic saturation biases. We conclude that current large-scale
   modeled CHMs are better suited for approximate characterization of urban
   vertical structure than as effective enhancement features for advanced
   inversion modeling. Future research should prioritize urban-specific
   CHMs capable of capturing sub-tree vertical heterogeneity.},
Type = {Article},
Affiliation = {Tang, LN (Corresponding Author), Chinese Acad Sci, Inst Urban Environm, 1799 Jimei Ave, Xiamen 361021, Fujian Province, Peoples R China.
   Dong, Hesong; Tang, Lina, Chinese Acad Sci, Inst Urban Environm, State Key Lab Reg \& Urban Ecol, Xiamen 361021, Peoples R China.
   Dong, Hesong; Wang, Haoran, Univ Chinese Acad Sci, Beijing 100049, Peoples R China.
   Wang, Haoran, Chinese Acad Sci, Aerosp Informat Res Inst, State Key Lab Remote Sensing \& Digital Earth, Beijing 100101, Peoples R China.
   Shao, Guofan, Purdue Univ, Dept Forestry \& Nat Resources, W Lafayette, IN 47907 USA.},
DOI = {10.1016/j.ufug.2026.129333},
EarlyAccessDate = {FEB 2026},
Article-Number = {129333},
Keywords = {Urban forestry; Aboveground biomass; Canopy height model; Carbon stock
   mapping; Multi-source remote sensing; Scale effect},
Keywords-Plus = {FOREST},
Author-Email = {lntang@iue.ac.cn},
Number-of-Cited-References = {35},
Times-Cited = {0},
