@article{ WOS:001622235600001,
Author = {Sanchez-Guevara, Johana Andrea and Figueroa-Casas, Apolinar and
   Pencue-Fierro, Edgar Leonairo and Solano-Correa, Yady Tatiana},
Title = {Multitemporal analysis of inland water bodies in the Colombian Andes for
   water security},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2025},
Volume = {40},
Number = {1},
Month = {DEC 31},
Abstract = {Inland water bodies in the Colombian Andes face growing threats from
   human activity and climate variability, intensifying concerns over
   regional water security (WS). This issue is critical in the Upper Cauca
   River Basin, where pollution, hydrological changes, and limited in situ
   data hinder effective water management. Challenges are amplified in low-
   and middle-income countries with restricted access to high-performance
   computing and field monitoring, especially in remote or insecure areas.
   This study addresses these gaps through a remote sensing-based framework
   for multitemporal water monitoring using freely available satellite
   imagery. The methodology integrates four automatic segmentation
   techniques; applies the C2RCC processor to estimate chlorophyll-a
   (Chl-a), total suspended matter (TSM) and coloured dissolved organic
   matter (CDOM); and extracts time series data on surface area, NDWI, and
   water quality. Data from Landsat-8 (2014-2021), Sentinel-2 (2020-2021),
   and PlanetScope (2016-2021) support consistent monitoring. The approach
   provides a cost-effective, scalable solution to support water quality
   assessment and decision-making in data-scarce, high-risk Andean regions.},
Type = {Article},
Affiliation = {Solano-Correa, YT (Corresponding Author), Pontificia Univ Javeriana, Cali, Colombia.
   Sanchez-Guevara, Johana Andrea; Figueroa-Casas, Apolinar; Pencue-Fierro, Edgar Leonairo, Univ Cauca, Popayan, Colombia.
   Solano-Correa, Yady Tatiana, Pontificia Univ Javeriana, Cali, Colombia.},
DOI = {10.1080/10106049.2025.2583331},
Article-Number = {2583331},
Keywords = {Remote sensing; multitemporal analysis; segmentation; C2RCC; Colombian
   Andes},
Keywords-Plus = {SURFACE-WATER; RANDOM FOREST; FEATURE-EXTRACTION; CHLOROPHYLL-A;
