@article{ WOS:001639153100001,
Author = {Budharapu, Vighnesh and Bhuvad, Shubham and Garje, Tushar and Turkar,
   Varsha and Agarwadkar, Mugdha and Agarwadkar, Yogesh},
Title = {Automated UAV-based tool for urban forest tree monitoring using machine
   learning and image processing},
Journal = {TREES FORESTS AND PEOPLE},
Year = {2026},
Volume = {23},
Month = {JAN},
Abstract = {Urban forest management requires accurate and scalable methods for
   monitoring tree structure and health. Traditional inventory approaches
   are labor-intensive and limited in spatial coverage, while existing
   remote sensing methods often lack the resolution and adaptability needed
   for diverse urban environments. This study presents an automated
   UAV-based framework that integrates machine learning, image processing,
   and topographical analysis for individual tree detection and
   characterization. The framework employs YOLOv8 object detection for
   initial tree identification, followed by slope-based region-growing
   segmentation that refines canopy boundaries using Digital Elevation
   Model (DEM) and Digital Terrain Model (DTM) data. A two-stage Otsu's
   thresholding approach addresses small tree exclusion in mixed height
   canopies. Tree structural attributes including height and canopy girth,
   are derived from DEM/DTM analysis, while vegetation health is assessed
   using the Modified Green-Red Vegetation Index (MGRVI). The methodology
   was validated on UAV datasets from Maharashtra and Telangana, achieving
   95\% detection accuracy in sparse canopy regions and 85\% in dense
   areas. An interactive WebGIS interface enables spatial visualization of
   tree attributes and health metrics to support data-driven urban forestry
   decisions. The framework demonstrates adaptability across diverse tree
   species and canopy densities, offering a scalable solution for automated
   urban forest monitoring and management.},
Type = {Article},
Affiliation = {Budharapu, V (Corresponding Author), Vidyalankar Inst Technol, Mumbai 400037, India.
   Budharapu, Vighnesh; Bhuvad, Shubham; Garje, Tushar, Vidyalankar Inst Technol, Mumbai 400037, India.
   Turkar, Varsha; Agarwadkar, Yogesh, InfiCorridor Solut Pvt Ltd, Mumbai 400012, India.
   Agarwadkar, Mugdha, AP Shah Inst Technol, Thana 400615, India.},
DOI = {10.1016/j.tfp.2025.101104},
EarlyAccessDate = {DEC 2025},
Article-Number = {101104},
Keywords = {Urban forestry; Tree detection; YOLOv8; Remote sensing; WebGIS; MaCHINE
   LEArning},
Keywords-Plus = {UNMANNED AERIAL VEHICLES; CLASSIFICATION; MANAGEMENT},
Author-Email = {vighnesh.budharapu@vit.edu.in},
Number-of-Cited-References = {32},
