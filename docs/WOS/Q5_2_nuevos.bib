@article{ WOS:001642294300001,
Author = {Kazeminezhad, Mohammad Hossein},
Title = {Neural network-enhanced calibration of ERA5 wind speeds in the
   northwestern Indian Ocean using 32 years of satellite observations},
Journal = {REMOTE SENSING APPLICATIONS-SOCIETY AND ENVIRONMENT},
Year = {2026},
Volume = {41},
Month = {JAN},
Abstract = {Accurate wind speed estimation is essential for applications in ocean
   engineering, renewable energy, and climate modeling. Although the ERA5
   reanalysis dataset provides high-resolution global wind data, its
   accuracy varies across different regions and wind regimes. This study
   presents a comprehensive assessment and calibration of ERA5 wind speed
   data in the Northwestern Indian Ocean, using satellite observations from
   multiple scatterometers and altimeters over a 32-year period
   (1992-2023). The evaluation reveals systematic biases in ERA5, including
   a general underestimation of high wind speeds and localized
   discrepancies near coastlines, particularly in the Persian Gulf, Gulf of
   Oman, and equatorial regions. To enhance the accuracy of wind data,
   three calibration techniques including Linear Regression (LR), Quantile
   Mapping (QM), and Artificial Neural Networks (ANN), were applied and
   compared. The results demonstrate that while LR reduces the normalized
   mean bias, it offers only limited improvements in the Scatter Index
   (SI), decreasing it from 20.24 \% to 19.07 \%. QM improves the alignment
   of high wind percentiles and reduces the SI for the 99th percentile from
   28.69 \% to 26.47 \%, but it does not significantly enhance the overall
   dataset. ANN, on the other hand, offers the most effective correction,
   reducing the overall SI to 17.93 \% and the SI at the 99th percentile to
   24.76 \%. A dedicated assessment under tropical cyclone (TC) conditions
   further confirms the robustness of the ANN calibration, showing
   substantial improvements in the representation of extreme wind speed
   (with the SI reduced from 36.53 \% to 28.77 \% at the 99th percentile).
   Despite persistent residual biases at the highest wind speeds, the ANN
   approach significantly enhances agreement with satellite observations,
   outperforming raw ERA5 in all evaluated metrics. These findings
   highlight the potential of machine learning techniques to improve
   reanalysis datasets in regions where accurate wind representation is
   critical for climate resilience, offshore safety, and renewable energy
   planning.},
Type = {Article},
Affiliation = {Kazeminezhad, MH (Corresponding Author), Iranian Natl Inst Oceanog \& Atmospher Sci, Etemad Zadeh St,Fatemi Ave, Tehran 1411813389, Iran.
   Kazeminezhad, Mohammad Hossein, Iranian Natl Inst Oceanog \& Atmospher Sci, Etemad Zadeh St,Fatemi Ave, Tehran 1411813389, Iran.},
DOI = {10.1016/j.rsase.2025.101826},
EarlyAccessDate = {DEC 2025},
Article-Number = {101826},
Keywords = {Scatterometer; Altimeter; Feedforward neural network; Renewable energy;
   Remote sensing; Tropical cyclone},
Keywords-Plus = {MODEL},
Author-Email = {mkazeminezhad@inio.ac.ir},
Number-of-Cited-References = {52},
Times-Cited = {0},
Unique-ID = {WOS:001642294300001},
}

@article{ WOS:001641475400001,
Author = {Cai, Xudong and Zhao, Ziyang and Zhang, Wei and Shao, Yang and Chen, Hao
   and Luo, Min},
Title = {Spatial prediction of emergency supply demand under urban flood disaster
   events: A case study of the ``23.7{''} rainstorm in Beijing},
Journal = {URBAN CLIMATE},
Year = {2026},
Volume = {65},
Month = {FEB},
Abstract = {Urban floods, intensified by climate change, disrupt lifeline services,
   including transportation, power, and communications, making the timely
   distribution of emergency supplies a central operational challenge.
   However, most forecasting overlooks spatial heterogeneity of need and
   relies on static aggregates. To address this gap, this study establishes
   a scientific and efficient methodology for forecasting regional demand
   for emergency supplies. Using Beijing's July 2023 ({''}23.7{''}) storm
   as a case, a geographical model for flood risk was created using the
   AdaBoost machine learning method, integrating meteorological and
   topographic variables with historical waterlogging data as input
   samples. A geographical emergency spatial coefficient was developed by
   combining socioeconomic indicators, obtained via spatial principal
   component analysis, with disaster risk levels. This coefficient was
   further integrated with Beijing's regional population data to forecast
   emergency supply demand. The results show that (1) DEM (Digital
   Elevation Model), rainfall from the ``23.7{''} event, average
   precipitation, and NDVI (Normalized Difference Vegetation Index) are the
   four most critical factors, jointly contributing 65.2 \% of the total
   normalized feature importance. (2) Zones classified as high and very
   high flood risk are primarily located in Mentougou and Fangshan
   Districts. (3) The maximum predicted number of affected individuals
   within a single 1-km2 grid cell is 30,843, necessitating 77,107.5 L of
   water, 49,348.8 kg of food, 30,843 items of clothing, and 51,199.38
   doses of antibiotics during the ``23.7{''} rainstorm event. The proposed
   model can support local and disaster management authorities in
   prioritizing high-demand areas and planning flood management and relief
   strategies.},
Type = {Article},
Affiliation = {Zhao, ZY (Corresponding Author), Xian Univ Posts \& Telecommun, Sch Modern Post, Xian 710061, Shaanxi, Peoples R China.
   Cai, Xudong; Zhao, Ziyang; Zhang, Wei; Shao, Yang, Xian Univ Posts \& Telecommun, Sch Modern Post, Xian 710061, Shaanxi, Peoples R China.
   Chen, Hao, Beijing Normal Univ, Fac Geog Sci, Beijing 100875, Peoples R China.
   Luo, Min, Weinan Postal Safety Supervis Ctr, Weinan 714000, Shaanxi, Peoples R China.},
DOI = {10.1016/j.uclim.2025.102740},
EarlyAccessDate = {DEC 2025},
Article-Number = {102740},
Keywords = {Urban flooding; Disaster relief prediction; Emergency logistics; Machine
   learning model; Risk assessment},
Keywords-Plus = {SENSITIVITY-ANALYSIS; MAPS},
Author-Email = {zyzhao@xupt.edu.cn
