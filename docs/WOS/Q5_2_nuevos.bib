@article{ WOS:001662954800001,
Author = {Haq, Bushra and Jamshed, Muhammad Ali and Kasi, Bakhtiar and Kasi,
   Mumraiz Khan},
Title = {Predicting Wildfires With Advanced Deep Learning Models on Wireless
   Sensor Data},
Journal = {IEEE SENSORS JOURNAL},
Year = {2026},
Volume = {26},
Number = {2},
Pages = {2797-2804},
Month = {JAN 15},
Abstract = {Wildfires are a critical environmental concern, requiring accurate and
   timely predictive strategies to minimize their adverse impacts.
   Traditional geographic information system (GIS) data often faces delays,
   making real-time prediction challenging. To address this, wireless
   sensor networks (WSNs) offer a promising solution. However, due to the
   limited availability of extensive WSN data, this research leverages
   meteorological datasets to train predictive models that can be
   implemented on wireless sensor nodes for real-time wildfire prediction.
   The study applies machine learning (ML) and deep learning (DL)
   techniques to enhance wildfire forecasting capabilities. Among
   conventional ML models, random forest (RF) emerged as the most effective
   classifier when working with limited wildfire data, enabling the
   integration of extensive meteorological information to augment the
   dataset. Advanced DL models, including artificial neural networks
   (ANNs), long short-term memory (LSTM), convolutional neural networks
   (CNNs), and recurrent neural networks (RNNs), as well as a hybrid model,
   were evaluated on the enriched dataset. The hybrid model achieved
   superior classification performance. For time series forecasting, LSTM
   outperformed SARIMAX by capturing complex and nonlinear temporal
   patterns. This research demonstrates the effectiveness of combining
   meteorological data and multiple predictive methodologies to advance
   wildfire prediction capabilities, particularly for real-time
   applications using WSNs, offering valuable insights for disaster
   management and environmental forecasting. Notably, the experimental
   findings reveal that the our hybrid model improves classification
   accuracy, and the LSTM forecasting strategy reduces prediction errors
   compared to existing state-of-the-art techniques.},
