   Abdou Amadou, Sanoussi; Lawali, Dambo, Abdou Moumouni Univ, Fac Letters \& Human Sci, Dept Geog, Niamey 418, Niger.},
DOI = {10.3390/rs18050750},
Article-Number = {750},
Keywords = {stratified random sampling; Google Earth Engine (GEE); random forest
   regression; Collect Earth Online (CEO); Niger},
Keywords-Plus = {CLASSIFICATION ACCURACY; SAMPLE-SIZE; PREDICTION; VEGETATION; REGIONS},
