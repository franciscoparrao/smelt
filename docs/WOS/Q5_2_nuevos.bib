@article{ WOS:001712227700008,
Author = {Liu, Mingliang and Wang, Shuai and Yang, Zhiqiang and Liu, Tingting and
   Qiao, Zhenmin},
Title = {New Paradigm of Water Body Identification in Remote Sensing Image Under
   the Background of Multimodal Large Models},
Journal = {LASER \& OPTOELECTRONICS PROGRESS},
Year = {2026},
Volume = {63},
Number = {4},
Month = {FEB},
Abstract = {Objective Accurate and efficient identification of surface water bodies
   from remote sensing images plays a pivotal role in environmental
   monitoring, hydrological modeling, urban planning, disaster response,
   and sustainable resource management. Traditional water extraction
   methods-ranging from simple thresholding techniques based on spectral
   indices like the normalized difference water index (I-NDWI) to more
   complex machine learning classifiers such as support vector machines
   (SVM) and random forests (RF) -have long been constrained by challenges
   including spectral variability, environmental complexity (e.g., shadows,
   adjacent buildings, vegetation cover), and the need for manual feature
   engineering. While deep learning models, particularly convolutional
   neural networks (CNNs) like U-Net and generative adversarial networks
   (GAN), have significantly advanced segmentation accuracy, they are
   inherently limited by their dependence on large volumes of pixel-level
   annotated training data, high computational costs, lengthy training
   cycles, and poor generalization across diverse spatial resolutions and
   sensor types. These limitations hinder their practical deployment,
   especially in rapidly changing or data-scarce environments. In response
   to these pressing challenges, this study introduces a groundbreaking
   paradigm for water body identification in remote sensing by harnessing
   the emergent capabilities of multimodal large models (MLMs). This new
   approach aims to transcend the limitations of conventional and deep
   learning methods by leveraging the cross-modal reasoning, zero-shot
   learning potential, and linguistic understanding of MLMs, thereby
   enabling accurate, efficient, and scalable water detection with minimal
   human annotation and computational overhead. Methods The proposed
   paradigm integrates visual perception and natural language reasoning
   through a carefully designed three-stage hierarchical workflow: water
   existence determination, water boundary discrimination, and precise
   water body identification. In the first stage, a binary classification
   task is performed by inputting the raw remote sensing image along with a
   natural language Prompt (e.g., ``Does this image contain any water
   bodies?{''}) into a multimodal large model. The model outputs a yes/no
   decision and generates a coarse segmentation mask, allowing for rapid
   filtering of scenes containing water and significantly reducing
   downstream computational load. In the second stage, candidate regions
   are generated using the segment anything model (SAM), which proposes
   potential object masks. These region proposals are then combined with a
   discriminative Prompt (e.g., ``Identify and precisely segment all water
   bodies within the highlighted areas{''}) and processed by the MLM to
   refine the spatial boundaries of water bodies. This fusion of vision
   foundation models with language-guided reasoning enables fine-grained
   discrimination even in complex urban or vegetated landscapes. In the
   third and final stage, another semantic Prompt (e.g., ``Classify the
   segmented water bodies into categories such as natural lake, river,
   reservoir, swimming pool, or coastal water{''}) is used to classify the
   identified water patches into specific types, enhancing the semantic
   richness of the output. To evaluate the robustness and generalization of
   this framework, experiments were conducted across six diverse and
   publicly available remote sensing datasets: Zurich Summer (urban aerial
   imagery), DroneDeploy (high-resolution drone imagery), LandCover.
   ai (Inria), LoveDA (urban-rural satellite imagery), DeepGlobe (global
   land cover), and MSLCC (multi-sensor data). The performance of five
   state-of-the-art multimodal models-Qwen2.5-VL, DeepSeek-VL2,
   InternVL2\_5, LLaMA-3.2V, and Phi-3.5-was systematically compared.
   Evaluation metrics included precision (P), recall (R), accuracy (A), and
   F1 score (F), providing a comprehensive assessment of model performance
   across different scenarios. Results and Discussions Extensive
   experimental results validate the effectiveness and superiority of the
   proposed paradigm. In the water existence determination task,
   DeepSeek-VL2-small emerged as the top performer, achieving F1 scores of
   84.99 \% on DeepGlobe, 90.73 \% on LandCover. ai, 83.45 \% on LoveDA,
   and an impressive 93.83 \% on MSLCC (Fig. 4). Its recall reached 98.48
   \% on MSLCC, indicating an exceptional ability to detect water bodies
   with minimal omission errors. In the water boundary discrimination task,
   DeepSeek-VL2-small again demonstrated leading performance, with F1
   scores of 92.51 \% (LandCover.ai), 87.13 \% (LoveDA), 87.25 \%
   (DeepGlobe), 73.16 \% (Zurich Summer), and 98.05 \% (MSLCC) (Fig. 5),
   showcasing strong robustness across varying resolutions and imaging
   conditions. Notably, other models exhibited strengths in specific
   contexts: InternVL2\_5 performed best on DroneDeploy, while Qwen2.5-VL
   showed balanced performance across datasets. In the final water
   identification stage, the complete pipeline successfully distinguished
   between various water types-including lakes, rivers, reservoirs,
   swimming pools, and coastal zones-across diverse geographical and
   environmental settings (Fig. 6). The method proved highly effective in
   handling complex scenes with mixed land covers, shadows, and small or
   fragmented water bodies, demonstrating superior generalization and
   resilience compared to traditional deep learning models. Crucially, the
   entire framework operates with minimal or no fine-tuning, leveraging the
   inherent knowledge of pretrained MLMs, thus eliminating the need for
   large annotated datasets and reducing training time and computational
   cost to near zero. Conclusions This study presents a transformative
   approach to remote sensing water body identification by integrating
   multimodal large models into a structured, Prompt-driven, three-stage
   framework. The results demonstrate that this new paradigm achieves high
   accuracy, strong generalization across sensor types and resolutions, and
   excellent robustness in complex environments-without relying on
   extensive labeled data or intensive model training. By combining the
   visual understanding of foundation models with the semantic reasoning of
   language models, the proposed method enables intelligent, interpretable,
   and adaptable water detection and classification. The consistent top
   performance of DeepSeek-VL2-small highlights its suitability for remote
   sensing applications. This work marks a significant shift from
   data-intensive deep learning toward knowledge-driven, zero-shot
   intelligent analysis in earth observation, offering a scalable and
   efficient solution for large-scale water monitoring and paving the way
   for future applications in dynamic environmental change detection and
   automated geospatial intelligence.},
Type = {Article},
Affiliation = {Liu, ML (Corresponding Author), Beijing Sensetime Technol Dev Co Ltd, Beijing 100080, Peoples R China.
   Liu, Mingliang; Wang, Shuai; Yang, Zhiqiang; Liu, Tingting; Qiao, Zhenmin, Beijing Sensetime Technol Dev Co Ltd, Beijing 100080, Peoples R China.},
DOI = {10.3788/LOP251300},
Article-Number = {0401001},
Keywords = {multimodal large model; water body identification; remote sensing image;
   deep learning; neural network},
Keywords-Plus = {INDEX NDWI; EARTH; LAND},
Author-Email = {liumingliang1@sensetime.com},
Number-of-Cited-References = {19},
Times-Cited = {0},
Unique-ID = {WOS:001712227700008},
}

