@article{ WOS:001687347500013,
Author = {Liu, Jingtong and Ding, Kaiyan and Yue, Linwei and Saranathan, Arun M.
   and Yuan, Qiangqiang and Shen, Huanfeng},
Title = {Simultaneous Retrieval of Chlorophyll-a, Total Suspended Solids, and
   Colored Dissolved Organic Matter in Inland Waters Based on Multitask
   Learning Constrained by Probability Density Distributions},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2026},
Volume = {64},
Abstract = {Accurately estimating optically active water quality indicators (WQIs)
   from remote sensing reflectance ( Rrs ) in inland waters remains
   challenging due to their complex optical properties. The multispectral
   signals are influenced by overlapping absorption and scattering effects
   from multiple dissolved and suspended constituents, making it difficult
   to isolate individual WQI contributions. To this end, we propose a novel
   hierarchical machine learning framework for the simultaneous retrieval
   of chlorophyll-a (Chla), total suspended solid (TSS), and colored
   dissolved organic matter (CDOM) in inland waters. The core idea of the
   proposed method is a conditional probability-constrained multitask
   learning framework that models the joint distribution of WQIs.
   Specifically, the model employs a mixture density network (MDN) to learn
   the initial probability distributions of multiple WQIs and obtains the
   target output via a multitask learning module. The proposed model is
   trained and tested with Sentinel-2 images and the GLObal Reflectance
   community dataset for Imaging and optical sensing of Aquatic
   environments (GLORIA) dataset over the globe. Two mechanism-informed
   strategies were designed for robust global modeling: 1) optical water
   type (OWT) classification via R-rs curve clustering, and 2) missing
   value construction using the multiple imputation by chained equations
   (MICEs) algorithm based on the synergistic distribution of WQIs for
   different OWTs. The improved overall accuracies (i.e., RMSEChla=9.86
   mg/m(3),RMSETSS=14.75g/m(3) , and RMSEaCDOM(440)=0.41m(-1 )) verify that
   the proposed multitask MDN (MT-MDN) model achieves reliable estimation
   results. This suggests that the accuracy has improved from 29.37\% to
   50.75\% compared to representative machine learning methods {[}e.g.,
   MDN, random forest (RF), extreme gradient boosting (XGBoost), and
   categorical boosting (CB)], and has seen an improvement of up to 56.51\%
   compared to traditional semi-empirical methods.},
Type = {Article},
Affiliation = {Yue, LW (Corresponding Author), China Univ Geosci, Sch Geog \& Informat Engn, Wuhan 430074, Peoples R China.
   Liu, Jingtong; Ding, Kaiyan; Yue, Linwei, China Univ Geosci, Sch Geog \& Informat Engn, Wuhan 430074, Peoples R China.
   Saranathan, Arun M., Sci Syst \& Applicat Inc, Lanham, MD 20706 USA.
   Saranathan, Arun M., NASA, Goddard Spaceflight Ctr, Greenbelt, MD 20771 USA.
   Yuan, Qiangqiang, Wuhan Univ, Sch Geodesy \& Geomatics, Wuhan 430079, Peoples R China.
   Shen, Huanfeng, Wuhan Univ, Sch Resource \& Environm Sci, Wuhan 430079, Peoples R China.},
DOI = {10.1109/TGRS.2026.3656588},
Article-Number = {5401118},
Keywords = {Optical sensors; Optical reflection; Optical imaging; Optical
   scattering; Mathematical models; Water; Reflectivity; Multitasking;
   Accuracy; Water quality; Chlorophyll-a (Chla); colored dissolved organic
   matter (CDOM); machine learning; simultaneous retrieval; total suspended
   solid (TSS)},
Keywords-Plus = {REMOTE ESTIMATION; COASTAL; LANDSAT; CLASSIFICATION; VARIABILITY; RED},
Author-Email = {liujt@cug.edu.cn
   kyding@cug.edu.cn
   yuelw@cug.edu.cn
   fnu.arunmuralidharansaranathan@nasa.gov
   qqyuan@sgg.whu.edu.cn
   shenhf@whu.edu.cn},
