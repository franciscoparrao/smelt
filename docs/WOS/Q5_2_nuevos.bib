@article{ WOS:001641499700009,
Author = {Jing, Bo and Huang, Yabo and Shi, Xiaorui and Zhao, Jianhui and Wu, Lin
   and Li, Ning and Wang, Haipeng},
Title = {Estimation of Fractional Vegetation Cover From Fully Polarimetric SAR
   Data via Multidimensional Feature Selection and Model Optimization},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {945-965},
Abstract = {Fractional vegetation cover (FVC) is a crucial parameter in ecological
   and environmental monitoring. Most existing FVC estimation studies rely
   on optical remote sensing data, which are susceptible to weather
   conditions. Synthetic aperture radar (SAR) data are emerging as a novel
   and multitemporal data source for FVC estimation due to their
   all-weather capability. However, current studies based on fully
   polarimetric SAR often fail to effectively mine high-dimensional
   polarimetric features, and the estimation accuracy of existing models
   remains limited. This study proposes a modeling framework for FVC
   estimation based on Radarsat-2 full-polarimetric SAR data, which
   incorporates the designed global feature selection method ET-GA, and
   utilizes the black-winged kite algorithm (BKA) for hyperparameter tuning
   to improve FVC estimation accuracy. First, a total of 32 polarimetric
   features were extracted using multiple polarimetric decomposition
   methods. Based on this, the ET-GA was designed for feature selection,
   while recursive feature elimination (RFE) was employed as the
   comparative algorithm, and the maximal information coefficient (MIC) was
   used for analysis. Subsequently, in order to reduce the impact of
   manually setting parameters on the accuracy of model estimation, the BKA
   was employed across six regression models, encompassing both traditional
   machine learning and deep learning algorithms, to automate
   hyperparameter optimization. The MIC and FVC estimation results both
   indicate that ET-GA is better than RFE in dimensionality reduction and
   key information retention. In the six regression models, the
   BKA-optimized 1DResNet achieved the highest accuracy (R-2 = 0.9512),
   benefiting from both its strong deep feature representation and the
   effective hyperparameter tuning provided by the BKA. This study
   effectively improves the accuracy of FVC estimation with fully
   polarimetric SAR data and provides a solution for FVC estimation under
   cloudy and rainy conditions.},
