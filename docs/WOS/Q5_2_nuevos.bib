Keywords = {Gully erosion; The global scale; Google earth imagery; Random forests;
   Land use/cover},
Keywords-Plus = {TOPOGRAPHIC THRESHOLD; SEDIMENT YIELD; SOIL-EROSION; SUSCEPTIBILITY;
   DEGRADATION; UNCERTAINTY; IMPACTS; DENSITY; CLIMATE; SCALES},
Author-Email = {matthias.vanmaercke@kuleuven.be},
Number-of-Cited-References = {110},
