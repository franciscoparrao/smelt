@article{ WOS:001690341000001,
Author = {Wu, Qingxia and Zhu, Zhongli and Ma, Julong and Liu, Shaomin and Chai,
   Linna and Xu, Ziwei},
Title = {High-resolution soil moisture retrieval in heterogeneous terrain: A
   comparison of ensemble learning approaches using landsat 8/9},
Journal = {JOURNAL OF HYDROLOGY-REGIONAL STUDIES},
Year = {2026},
Volume = {64},
Month = {APR},
Abstract = {Study region: The study area is located in Tianjun County, eastern
   Qinghai Province, China, near Qinghai Lake on the northwestern
   Qinghai-Tibet Plateau, covering approximately 40 \& times; 36 km. Study
   focus: Using more than 20 soil moisture-related indices derived from
   Landsat data together with elevation information, this study develops a
   30 m resolution soil moisture retrieval framework. Four ensemble
   learning models, Random Forest (RF), Extremely Randomized Trees (ERT),
   Extreme Gradient Boosting (XGBoost), and Categorical Boosting
   (CatBoost), were trained and evaluated using QLB-NET in situ soil
   moisture observations to assess their spatial and temporal predictive
   performance. New hydrological insights: All models showed relatively
   stable performance, with CatBoost and XGBoost significantly
   outperforming ERT and RF. CatBoost achieved the best test performance,
   with average values of R2 = 0.79, RMSE = 0.060 m3 /m3 , Bias = -0.0009,
   and MAE = 0.0457 across multiple runs. The resulting high-resolution
   soil moisture maps reveal pronounced spatial heterogeneity and clear
   month-to-month variability. SHAP analysis indicates that elevation is
   the most influential predictor of soil moisture, and soil moisture
   variance increases markedly with terrain complexity at a spatial scale
   of 3 km. These results highlight the value of integrating highresolution
   remote sensing data with ensemble learning methods for soil moisture
   estimation in complex mountainous regions.},
Type = {Article},
Affiliation = {Zhu, ZL (Corresponding Author), Beijing Normal Univ, Fac Geog Sci, State Key Lab Earth Surface Proc \& Hazards Risk Go, Beijing 100875, Peoples R China.
   Wu, Qingxia; Zhu, Zhongli; Ma, Julong; Liu, Shaomin; Chai, Linna; Xu, Ziwei, Beijing Normal Univ, Fac Geog Sci, State Key Lab Earth Surface Proc \& Hazards Risk Go, Beijing 100875, Peoples R China.},
DOI = {10.1016/j.ejrh.2026.103236},
EarlyAccessDate = {FEB 2026},
Article-Number = {103236},
Keywords = {Soil moisture; Machine learning; High heterogeneity; Landsat 8/9},
Keywords-Plus = {DROUGHT INDEX; AREA; VARIABILITY; NETWORK; MODIS},
Author-Email = {zhuzl@bnu.edu.cn},
Number-of-Cited-References = {76},
Times-Cited = {0},
