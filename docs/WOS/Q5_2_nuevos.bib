   Yao, Zhaosheng; Zha, Hainie; Zhu, Shaolong; Wang, Yuanzhi, Anqing Normal Univ, Anqing 246133, Anhui, Peoples R China.
   Yao, Zhaosheng; Zha, Hainie; Zhu, Shaolong; Wang, Yuanzhi, Univ Key Lab Intelligent Percept \& Comp Anhui Prov, Anqing 246133, Anhui, Peoples R China.
   Han, Dongwei; Shao, Ruimin; Wang, Jianliang; Liu, Tao; Sun, Chengming, Yangzhou Univ, Cultivat \& Construct Site Natl Key Lab Crop Gen, Yangzhou 225009, Peoples R China.
   Zain, Muhammad, North China Univ Water Resources \& Elect Power, Coll Water Conservancy, Zhengzhou 450046, Peoples R China.
   Wu, Fei, Tech Univ Munich, TUM Sch Life Sci, Precis Agr Lab, D-85354 Freising Weihenstephan, Germany.},
DOI = {10.1007/s11119-025-10307-4},
Article-Number = {24},
Keywords = {Above-ground biomass (AGB); Remote sensing phenotyping; Canopy volume;
   Gaussian process regression (GPR); Color indices (CIs)},
Keywords-Plus = {ABOVEGROUND BIOMASS; TEXTURES},
Author-Email = {wyz@aqnu.edu.cn
   cmsun@yzu.edu.cn},
Number-of-Cited-References = {33},
