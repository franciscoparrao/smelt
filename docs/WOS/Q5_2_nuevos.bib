@article{ WOS:001686395700001,
Author = {Lin, Zijian and Zhou, Mingxing and Zhou, Yan and Wang, Liyin and Wu,
   Zuohang and Li, Dengqiu},
Title = {Linking historical vegetation changes to bamboo monodominance via
   multi-source remote sensing},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2026},
Month = {2026 FEB 11},
Abstract = {Bamboo expansion and monodominance threaten subtropical forest
   biodiversity, yet large-scale spatiotemporal patterns remain poorly
   quantified. Here, we integrate high-resolution mapping (2-m based on
   Gaofen-6 and Sentinel-2), Landsat time-series analysis (2000-2020) and
   Extreme Gradient Boosting (XGBoost)-SHapley Additive exPlanations (SHAP)
   machine learning to unravel bamboo dynamics in Wuyishan National Park,
   China. Our results reveal a bimodal distribution of bamboo coverage
   fraction (BCF) with either high-dominance (>75\% cover) or low-dominance
   (<15\%). Spatially, low-coverage bamboo formed transition zones around
   high-density cores (up to 16 km(2)), exhibiting clustered, and linear
   expansion patterns. Temporal analysis showed predominant greening trends
   (64\% positive normalized difference vegetation index (NDVI) changes),
   with abrupt changes peaking in 2000-2014 (73\% positive). Elevation
   (400-1200 m) emerged as the most influential predictor of monodominance,
   while SHAP analysis revealed threshold-dependent effects: (1) negative
   impacts at Mean Value (MV) of NDVI less than 0.6 or larger than 0.8 and
   Initial Vegetation State (IVS) larger than 0.75; (2) edge-mediated
   dynamics, with positive responses dominant >10 m from bamboo forest
   boundaries. This study provides the first multi-sensor framework for
   monitoring bamboo monodominance, offering critical insights for managing
   invasive bamboo ecosystems under climate change.},
Type = {Article; Early Access},
Affiliation = {Li, DQ (Corresponding Author), Fujian Normal Univ, Fujian Prov Key Lab Subtrop Resources \& Environm, Fuzhou 350117, Peoples R China.
   Lin, Zijian; Zhou, Mingxing; Li, Dengqiu, Fujian Normal Univ, Fujian Prov Key Lab Subtrop Resources \& Environm, Fuzhou 350117, Peoples R China.
   Lin, Zijian; Zhou, Mingxing; Li, Dengqiu, Fujian Normal Univ, Inst Geog, Fuzhou, Peoples R China.
   Zhou, Yan; Wang, Liyin, Wuyishan Natl Pk Fujian Sci Res \& Monitoring Ctr, Nanping, Peoples R China.
   Zhou, Yan; Wang, Liyin, Natl Observat \& Res Stn Fujian Wuyishan Forest Eco, Nanping, Peoples R China.
   Wu, Zuohang, Fujian Inst Meteorol Sci, Fuzhou, Peoples R China.},
DOI = {10.1080/01431161.2026.2628284},
EarlyAccessDate = {FEB 2026},
Keywords = {Bamboo monodominance; remote sensing; XGBoost-SHAP; historical change;
   edge effects; Wuyishan National Park},
Keywords-Plus = {LANDSAT TIME-SERIES; BROAD-LEAVED FOREST; SUCCESSION; PATTERN},
Author-Email = {lidengqiu@fjnu.edu.cn},
