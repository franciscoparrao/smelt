Keywords = {Lithology mapping; Three-dimensional spatial positioning; Automatic
   sample generation; Google Earth Engine; Stacking ensemble learning},
Keywords-Plus = {ROCKS},
Author-Email = {zhangtao@stu.ynu.edu.cn
   zzf\_1002@126.com
   zengmin@ynu.edu.cn
   yanghy527@ynu.edu.cn},
Number-of-Cited-References = {45},
