}

@article{ WOS:001654582800001,
Author = {Liu, Ruifeng and Lv, Lansong and Cui, Yurong and Pan, Wenxin and Zhang,
   Xiulong and Fu, Juan},
Title = {Spatial and temporal evolution of wetland ecological quality in the
   Yellow River Delta: a comprehensive analysis based on multi-temporal
   remote sensing and improved ecological indices},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2026},
Volume = {77},
Number = {2},
Pages = {1664-1678},
Month = {JAN 15},
Abstract = {As a designated national wetland nature reserve, the Yellow River Delta
   requires continuous ecosystem monitoring to assess ecological conditions
   and support restoration initiatives. This study systematically evaluated
   land use changes and spatiotemporal dynamics of ecological quality in
   the Yellow River Estuary using multi-temporal Landsat imagery (2004,
   2014, and 2024) and an improved Nonlinear Remote Sensing Ecological
   Index (NRSEI) for 2014 and 2024. Land use classification was performed
   using a random forest algorithm, and the NRSEI was enhanced by
   integrating the Temperature Vegetation Dryness Index (TVDI) with Kernel
   Principal Component Analysis (KPCA) to improve sensitivity to wetland
   ecological changes. Key results include: (1) Total wetland area
   increased significantly, with artificial wetlands expanding from 114.91
   km2 to 158.18 km2, while natural wetlands slightly decreased from 490.89
   km2 to 477.06 km2. Wetland areas consistently surpassed non-wetland
   areas, showing an inverse trend between these categories. Overall
   ecological quality improved, with notable recovery in specific regions;
   (2) The optimized NRSEI model strengthened the ecological evaluation
   framework, especially in capturing nonlinear relationships among
   ecological parameters; (3) By 2024, 88.4 \% of the study area reached
   `good' ecological status, with high-quality habitats increasing by 36.1
   \%. This study validates the effectiveness of recent ecological
   restoration efforts and provides a scientific foundation for the
   sustainable management of coastal wetlands, highlighting the value of
   dynamic monitoring and precise assessment in wetland ecosystem
   conservation. (c) 2025 COSPAR. Published by Elsevier B.V. All rights are
   reserved, including those for text and data mining, AI training, and
   similar technologies.},
Type = {Article},
Affiliation = {Fu, J (Corresponding Author), Shandong Prov Terr Spatial Ecol Restorat Ctr, Jinan 250014, Peoples R China.
   Liu, Ruifeng; Lv, Lansong; Fu, Juan, Shandong Prov Terr Spatial Ecol Restorat Ctr, Jinan 250014, Peoples R China.
   Cui, Yurong; Pan, Wenxin, Shandong Normal Univ, Coll Geog \& Environm, Jinan 250358, Peoples R China.
   Zhang, Xiulong, China Met Geol Bur, Geol Explorat Inst Shandong Zhengyuan, Jinan 250014, Peoples R China.},
DOI = {10.1016/j.asr.2025.10.079},
EarlyAccessDate = {DEC 2025},
Keywords = {Yellow River Delta wetland; Ecological quality; Nonlinear remote sensing
   ecological index; Land use change; Random forest classification},
Keywords-Plus = {CLASSIFICATION; TRANSFORMATION},
Author-Email = {fujuan@shandong.cn},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001654582800001},
}

@article{ WOS:001651219500003,
Author = {Afshar, Mehdi H. and Hassani, Amirhossein and Aminzadeh, Milad and
   Borrelli, Pasquale and Panagos, Panos and Robinson, David A. and Or,
   Dani and Shokri, Nima},
Title = {Spatial and temporal assessment of soil degradation risk in Europe},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {15},
Number = {1},
Month = {DEC 24},
Abstract = {Soil degradation threatens agricultural productivity and ecosystem
   resilience across Europe, yet spatially consistent assessments of its
   intensity and drivers remain limited. In this study, we used Soil
   Degradation Proxy (SDP), that integrates four key indicators of soil
   degradation, including erosion rate, soil pH, electrical conductivity,
   and organic carbon content, to quantify soil degradation risk. Using
   over 38,000 LUCAS topsoil observations and a machine learning model
   trained on climate, land cover, topographic, soil parent material
   properties, and spectral variables, we map annual SDP values between
   years 2000 to 2022 across Europe. Results show soil degradation risk is
   highest in southern Europe, especially in intensively managed and
   sparsely vegetated landscapes. Over the past two decades, approximately
   7.1\% of land area across the EU and the UK has experienced increasing
   degradation risk (most notably across Eastern Europe), with rainfed
   croplands emerging as the most affected land cover type. Land cover is
   the most influential driver, modulating effects of climatic variables
   such as precipitation and temperature on SDP. This data-driven framework
   provides a consistent and scalable approach for monitoring soil
   degradation risk and offers actionable insights to support targeted
   conservation and EU-wide policy implementation.},
