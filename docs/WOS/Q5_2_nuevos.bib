   Perez, Jose Manuel Alcantara, ARCGISA, Cadiz 11379, Los Barrios, Spain.},
DOI = {10.1093/jigpal/jzaf032},
Article-Number = {jzaf032},
Keywords = {oil spills; hyperspectral; machine learning; autoencoder;<middle
   dot>ANNs; HSI<middle dot> remote sensing},
Keywords-Plus = {CLASSIFICATION},
