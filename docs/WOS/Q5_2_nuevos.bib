@article{ WOS:001635908500001,
Author = {Do, Anh Ngoc Thi and Do, Tuyet Anh Thi and Tran, Hau Duc},
Title = {Application of machine learning model to evaluate how urbanization has
   affected the green space pattern in Hanoi city between 1995 and 2023},
Journal = {TROPICAL ECOLOGY},
Year = {2025},
Volume = {66},
Number = {4},
Pages = {645-665},
Month = {DEC},
Abstract = {The process of urbanization has a profound impact on the composition,
   functionality, and dynamics of ecosystems, which includes the alteration
   of land cover land use (LCLU) from natural landscapes to artificial
   ones. Our findings indicated a significant reduction in urban green
   space (UGS), amounting to a decline of 6944.29 ha from 2005 to 2023,
   which translates to an annual decrease of 385.79 ha. The assessment of
   classification accuracy through the use of independent datasets has
   indicated that the classification results are reliable, with an accuracy
   rate of over 85\%, and a Kappa coefficient exceeding 0.8. The findings
   of this current study have illustrated the progression of urbanization
   and the decline of green spaces within Hanoi city over a span of 28
   years. The analysis highlights considerable landscape fragmentation,
   evidenced by a 52.81\% reduction in the Largest Patch Index (LPI), a
   14.19\% decline in Disjunct Core Area Density (DCAD), and a 5.17\% drop
   in the Total Edge Contrast Index (TECI). Conversely, the Perimeter-area
   fractal dimension (PAFRAC), Landscape Shape Index (LSI) and Shannon
   Diversity Index (SHDI) have experienced increases of 0.46\%; 42.73\% and
   27.56\%, respectively, over the 28 year period. The dispersed and
   unequal patterns of LCLU have resulted in significant spatial and
   temporal fluctuations in landscape fragmentation at a large scale. The
   variety of landscapes and the intricate of green space structures have
   experienced a notable increase overall. The findings of the study
   highlight the importance of landscape metrics in providing crucial
   information for the management and conservation of ecosystems.},
Type = {Article},
Affiliation = {Do, ANT (Corresponding Author), Van Lang Univ, Sci \& Technol Adv Inst, Lab Ecol \& Environm Management, Ho Chi Minh City, Vietnam.
   Do, ANT (Corresponding Author), Van Lang Univ, Fac Appl Technol, Van Lang Sch Technol, Ho Chi Minh City, Vietnam.
   Do, Anh Ngoc Thi, Van Lang Univ, Sci \& Technol Adv Inst, Lab Ecol \& Environm Management, Ho Chi Minh City, Vietnam.
   Do, Anh Ngoc Thi, Van Lang Univ, Fac Appl Technol, Van Lang Sch Technol, Ho Chi Minh City, Vietnam.
   Do, Tuyet Anh Thi, Hanoi Univ Nat Resources \& Environm, Hanoi, Vietnam.
   Tran, Hau Duc, Hanoi Natl Univ Educ, 136 Xuan Thuy, Hanoi, Vietnam.
   Tran, Hau Duc, Hanoi Natl Univ Educ, Inst Nat Sci INS, 136 Xuan Thuy, Hanoi, Vietnam.},
DOI = {10.1007/s42965-025-00410-y},
EarlyAccessDate = {DEC 2025},
Keywords = {Fragmentation; Urbanization; SPOT satellite; Urban green space},
Keywords-Plus = {URBAN HEAT ISLANDS; FOREST FRAGMENTATION; TEMPERATURE; ENVIRONMENT;
   DIVERSITY; IMPACTS; BIOMASS},
