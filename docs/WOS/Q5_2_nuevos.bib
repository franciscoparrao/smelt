@article{ WOS:001723806000001,
Author = {Hussainzad, Emal Ahmad and Gou, Zhonghua},
Title = {Mapping diurnal urban heat dynamics in data-scarce global south cities:
   A machine learning-enabled diagnostic framework applied to Kabul},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2026},
Volume = {142},
Month = {MAY 15},
Abstract = {Urbanization in the Global South is accelerating at an unprecedented
   pace, heightening vulnerability to the surface urban heat island (SUHI)
   effect amid limited in-situ monitoring and fragmented long-term urban
   datasets at neighborhood-scale resolution. This study addresses these
   challenges by applying a replicable machine learning-enabled diagnostic
   framework to analyze long-term SUHI dynamics, using Kabul-a
   high-altitude, semiarid city with rapid, uneven, and informal
   urbanization-as a representative case. By integrating multi-satellite
   datasets and geospatial analytics on Google Earth Engine, we generate
   spatially consistent diurnal land surface temperature (LST) maps at 30 m
   resolution for 2000-2020, providing a detailed characterization of
   diurnal surface temperature patterns across settlement types in similar
   contexts. The application of Gradient Boosting Regression (GBR),
   Quantile Regression (QR), and spatial autocorrelation analysis revealed
   trends and typological differences in LST between formal and informal
   areas. The average difference between the temperatures of day and night
   decreased from around 25 degrees C in 2000 to about 17 degrees C in
   2020, indicating reduced daytime extremes alongside persistent nocturnal
   warmth. Spatial clustering weakened over time, becoming more fragmented,
   signifying a shift from a purely central to a polycentric SUHI pattern.
   Informal settlements generally recorded higher daytime LST values,
   particularly in the upper quantile tau = 0.9, while formal areas
   exhibited stronger nocturnal heat retention. The study demonstrates how
   a settlement-integrated remote sensing workflow can reveal diurnal
   thermal disparities and long-term spatial reorganization of surface heat
   in cities with limited ground observations. These insights support
   context-sensitive heat adaptation strategies for rapidly urbanizing,
   semi-arid cities facing uneven heat impacts across socio-spatial
   landscapes.},
Type = {Article},
Affiliation = {Gou, ZH (Corresponding Author), Wuhan Univ, Sch Urban Design, Wuhan, Peoples R China.
   Hussainzad, Emal Ahmad; Gou, Zhonghua, Wuhan Univ, Sch Urban Design, Wuhan, Peoples R China.},
DOI = {10.1016/j.scs.2026.107312},
Article-Number = {107312},
Keywords = {Surface urban heat island; Global south cities; Kabul urbanization;
   Settlement typology; Diurnal LST dynamics; Informal settlements},
Keywords-Plus = {ISLAND},
Author-Email = {zh.gou@whu.edu.cn},
Number-of-Cited-References = {76},
Times-Cited = {0},
Unique-ID = {WOS:001723806000001},
}

@article{ WOS:001721198900001,
Author = {Zhao, Yongquan and Liu, Desheng and Zhu, Xiaolin and Luo, Ming and
   Huang, Bo and Song, Chunqiao and Duan, Xuejun},
Title = {RASSFM 2.0: An enhanced M2Msharpening model for PlanetScope-Sentinel-2
   image fusion across broad landscapes with improved land cover
   classification},
Journal = {REMOTE SENSING OF ENVIRONMENT},
Year = {2026},
Volume = {338},
Month = {MAY 15},
Abstract = {Very-High-spatial-Resolution (VHR, <= 5 m) remote sensing products
   (e.g., land cover maps) are critical for providing detailed and scalable
   information to support broad applications (e.g., urban, agriculture,
   ecology, and forestry). However, accurate VHR products require imagery
   that is both spatially detailed and spectrally rich, which is rarely met
   by a single sensor. Globally available PlanetScope (eight 3-m bands) and
   Sentinel-2 (thirteen 10/20/60-m bands) are complementary in this regard,
   making them ideal for synergistic use. Conventional spatial-spectral
   fusion approaches, such as pansharpening and hypersharpening, however,
   are tailored to specific sensor modalities and thus ill-suited for
   blending multispectral images from these two constellations. To bridge
   this gap, we advance the concept of Multispectral-to-Multispectral
   sharpening (M2Msharpening) and propose RASSFM 2.0, an enhanced
   M2Msharpening model over the original Robust and Adaptive
   Spatial-Spectral image Fusion Model (RASSFM 1.0; Zhao and Liu, 2022) for
   fusing PlanetScope and Sentinel-2 imagery. RASSFM 2.0 incorporates three
   key improvements: (1) radiometric harmonization to align PlanetScope
   spectra with Sentinel-2, (2) inter-band sharpening to downscale 20-m
   Sentinel-2 bands to 10-m, and (3) all-band fusion to improve accuracy
   and efficiency. Quantitative and visual assessments across five global
   fusion sites with representative landscapes confirmed the superior
   performance of RASSFM 2.0 regarding spatial clarity, spectral fidelity,
   and processing time. Its practical utility was further validated through
   land cover classification at three larger classification sites with
   complex land covers, where a random forest classifier based on the
   RASSFM 2.0-fused image achieved the highest area-adjusted overall
   accuracy (90.97 +/- 0.08\%), outperforming PlanetScope-only (85.04 +/-
   0.10\%), Sentinel-2-only (85.65 +/- 0.10\%), PlanetScope-Sentinel-2
   stacked (87.06 +/- 0.09\%), and RASSFM 1.0-fused (88.98 +/- 0.08\%)
   results. Notably, RASSFM 2.0 significantly reduces confusion between
   spectrally similar classes (e.g., sparse herbaceous and bare land) and
   improves the delineation of spatially complex surface structures (e.g.,
   fragmented and small-sized objects). Furthermore, the contribution of
   RASSFM 2.0 to land cover classification is concrete in both pure and
   mixed pixels, particularly for mixed pixels. These findings demonstrate
   the effectiveness of RASSFM 2.0 in generating synthetic VHR imagery with
   rich spectra, greatly enhancing land cover classification across broad
   landscapes. As a transparent and physics-based model, RASSFM 2.0 serves
   as a robust standalone tool and can provide valuable physical priors to
   inform or constrain learning-based fusion methods. This work advances
   both upstream M2Msharpening methodology and its value in downstream
   applications.},
Type = {Article},
Affiliation = {Song, CQ; Duan, XJ (Corresponding Author), Chinese Acad Sci, Nanjing Inst Geog \& Limnol, State Key Lab Lake \& Watershed Sci Water Secur, Nanjing 211135, Peoples R China.
   Zhao, Yongquan; Song, Chunqiao; Duan, Xuejun, Chinese Acad Sci, Nanjing Inst Geog \& Limnol, State Key Lab Lake \& Watershed Sci Water Secur, Nanjing 211135, Peoples R China.
   Zhao, Yongquan; Song, Chunqiao; Duan, Xuejun, Univ Chinese Acad Sci, Beijing 100049, Peoples R China.
   Liu, Desheng, Ohio State Univ, Dept Geog, Columbus, OH 43210 USA.
   Zhu, Xiaolin, Hong Kong Polytech Univ, Dept Land Surveying \& Geoinformat, Hong Kong, Peoples R China.
   Luo, Ming, Sun Yat Sen Univ, Sch Geog \& Planning, Guangzhou, Peoples R China.
   Huang, Bo, Univ Hong Kong, Dept Geog, Hong Kong, Peoples R China.},
DOI = {10.1016/j.rse.2026.115371},
Article-Number = {115371},
Keywords = {Spatial-spectral fusion; Multispectral-to-multispectral sharpening
   (M2Msharpening); Land cover classification; Physics-based fusion;
   PlanetScope; Sentinel-2},
Keywords-Plus = {GENERATIVE ADVERSARIAL NETWORK; WATER INDEX NDWI; SATELLITE IMAGES;
   SPECTRAL FUSION; QUALITY; ACCURACY; AREA},
