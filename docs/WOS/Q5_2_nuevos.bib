   Wallerman, Jorgen, Swedish Univ Agr Sci, Dept Forest Resource Management, Skogsmarksgrand 17, S-90183 Umea, Sweden.},
DOI = {10.1016/j.srs.2026.100395},
EarlyAccessDate = {FEB 2026},
