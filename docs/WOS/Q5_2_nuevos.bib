@article{ WOS:001671646600001,
Author = {Chetty, Evania and Mahomed, Maqsooda and Gokool, Shaeden},
Title = {A Comparative Analysis of Multi-Spectral and RGB-Acquired UAV Data for
   Cropland Mapping in Smallholder Farms},
Journal = {DRONES},
Year = {2026},
Volume = {10},
Number = {1},
Month = {JAN 21},
Abstract = {Highlights What are the main findings? RGB spectral bands extracted from
   multi-spectral sensors produce classification results comparable to full
   multi-spectral data for cropland mapping. Full multi-spectral data
   yields marginally superior accuracy, though RGB spectral information
   proves adequate for cropland classification, indicating trade-offs
   between spectral dimensionality and classification performance. What is
   the implication of the main finding? The comparable performance of RGB
   spectral information suggests potential cost efficiencies for UAV-based
   precision agriculture, though this study establishes a spectral baseline
   rather than a direct sensor cost comparison. Future research should
   evaluate dedicated RGB sensors with enhanced spatial resolution across
   diverse cropping systems to validate cost-benefit implications and
   accessibility for resource-constrained farmers.Highlights What are the
   main findings? RGB spectral bands extracted from multi-spectral sensors
   produce classification results comparable to full multi-spectral data
   for cropland mapping. Full multi-spectral data yields marginally
   superior accuracy, though RGB spectral information proves adequate for
   cropland classification, indicating trade-offs between spectral
   dimensionality and classification performance. What is the implication
   of the main finding? The comparable performance of RGB spectral
   information suggests potential cost efficiencies for UAV-based precision
   agriculture, though this study establishes a spectral baseline rather
   than a direct sensor cost comparison. Future research should evaluate
   dedicated RGB sensors with enhanced spatial resolution across diverse
   cropping systems to validate cost-benefit implications and accessibility
   for resource-constrained farmers.Abstract Accurate cropland
   classification within smallholder farming systems is essential for
   effective land management, efficient resource allocation, and informed
   agricultural decision-making. This study evaluates cropland
   classification performance using Red, Green, Blue (RGB) and
   multi-spectral (blue, green, red, red-edge, near-infrared) unmanned
   aerial vehicle (UAV) imagery. Both datasets were derived from imagery
   acquired using a MicaSense Altum sensor mounted on a DJI Matrice 300
   UAV. Cropland classification was performed using machine learning
   algorithms implemented within the Google Earth Engine (GEE) platform,
   applying both a non-binary classification of five land cover classes and
   a binary classification within a probabilistic framework to
   distinguishing cropland from non-cropland areas. The results indicate
   that multi-spectral imagery achieved higher classification accuracy than
   RGB imagery for non-binary classification, with overall accuracies of
   75\% and 68\%, respectively. For binary cropland classification, RGB
   imagery achieved an area under the receiver operating characteristic
   curve (AUC-ROC) of 0.75, compared to 0.77 for multi-spectral imagery.
   These findings suggest that, while multi-spectral data provides improved
   classification performance, RGB imagery can achieve comparable accuracy
   for fundamental cropland delineation. This study contributes baseline
   evidence on the relative performance of RGB and multi-spectral UAV
   imagery for cropland mapping in heterogeneous smallholder farming
   landscapes and supports further investigation of RGB-based approaches in
   resource-constrained agricultural contexts.},
Type = {Article},
Affiliation = {Gokool, S (Corresponding Author), Univ KwaZulu Natal, Ctr Water Resources Res, Sch Agr \& Sci, ZA-3209 Pietermaritzburg, South Africa.
   Gokool, S (Corresponding Author), South African Environm Observat Network, Grasslands Forests Wetlands Node, ZA-3201 Pietermaritzburg, South Africa.
   Chetty, Evania; Mahomed, Maqsooda; Gokool, Shaeden, Univ KwaZulu Natal, Ctr Water Resources Res, Sch Agr \& Sci, ZA-3209 Pietermaritzburg, South Africa.
   Gokool, Shaeden, South African Environm Observat Network, Grasslands Forests Wetlands Node, ZA-3201 Pietermaritzburg, South Africa.},
