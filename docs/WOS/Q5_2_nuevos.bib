@article{ WOS:001568497300001,
Author = {Idris, Ismail Abdalla and Adam, Elhadi and Abutaleb, Khaled Abubakr Ali
   and Abaker, Abdelgalal O. I.},
Title = {Analysing four decades of urban growth in Greater Khartoum, Sudan, using
   Earth observation data and Google Earth Engine},
Journal = {COGENT SOCIAL SCIENCES},
Year = {2025},
Volume = {11},
Number = {1},
Month = {DEC 31},
Abstract = {Rapid urbanisation associated with population growth and economic
   development is a key driver of changes in local and global land use and
   land cover (LULC). Monitoring and modelling changes that occur in LULC
   are crucial for promoting sustainable urban development and advancing
   humankind. Remote sensing has been applied worldwide to map and monitor
   LULC changes, although mapping of the urbanisation of Khartoum (Sudan)
   has not yet been done. This study detects and analyses urban growth in
   Greater Khartoum in five-year intervals from 1982 to 2022 using nine
   temporal Landsat images. The images were classified using the random
   forest classification algorithm. Overall accuracy and the standard kappa
   coefficient were applied for accuracy assessment of the classification.
   The overall accuracies were 81.4-91.0\% and the kappa coefficient ranged
   from 0.70 to 0.88. The built-up area expanded from 21,621 ha in 1982 to
   121,741 ha in 2022. Bare land decreased from 497,730 ha in 1982 to
   379,896 ha in 2022. Agricultural areas and water body varied, but the
   study area underwent rapid expansion during the same period. We believe
   this is the first detailed study offering insight into the growth of
   this city. These findings contribute to strengthening the planning and
   management of Sudan's largest city.},
Type = {Article},
Affiliation = {Idris, IA (Corresponding Author), Univ Witwatersrand, Sch Geog Archaeol \& Environm Studies, ZA-2050 Johannesburg, South Africa.
   Idris, Ismail Abdalla; Adam, Elhadi; Abutaleb, Khaled Abubakr Ali, Univ Witwatersrand, Sch Geog Archaeol \& Environm Studies, Johannesburg, South Africa.
   Abutaleb, Khaled Abubakr Ali, Agr Res Council Nat Resource \& Engn ARC NRF, Geoinformat Div, Pretoria, South Africa.
   Abaker, Abdelgalal O. I., King Khalid Univ, Appl Coll, Khamis Mushait, Saudi Arabia.},
DOI = {10.1080/23311886.2025.2555384},
Article-Number = {2555384},
Keywords = {Urban expansion; change detection; random forest; Khartoum; Landsat;
   Earth Sciences; GIS, Remote Sensing, and Cartography; Environmental
   Studies; Urban Studies},
Keywords-Plus = {LAND-COVER CHANGE; DARFUR; AREA},
Author-Email = {2416230@students.wits.ac.za},
Number-of-Cited-References = {58},
Times-Cited = {0},
Unique-ID = {WOS:001568497300001},
}

@article{ WOS:001563797800001,
Author = {Chen, Ang and Zhang, Min and Xu, Cong and Xing, Xiaoyu and Yang, Dong
   and Xu, Bin and Yang, Xiuchun},
Title = {Remote sensing assessment of shrub encroachment and its driving
   mechanisms in semi-arid grasslands},
Journal = {GISCIENCE \& REMOTE SENSING},
Year = {2025},
Volume = {62},
Number = {1},
Month = {DEC 31},
Abstract = {Influenced by climate change and human activities, shrub encroachment in
   global arid and semi-arid grasslands profoundly affects ecosystem
   functions and livestock farming. Remote sensing technology is crucial
   for evaluating shrub encroachment across spatial and temporal scales,
   providing a broader perspective for understanding its driving
   mechanisms. The shrub encroachment dominated by Caragana vegetation in
   the Inner Mongolia grasslands is typical both in China and globally.
   However, the lack of remote sensing studies hinders a deeper
   understanding of the current status and causes of shrub encroachment in
   this region. This study focuses on the semi-arid grasslands in central
   Inner Mongolia, estimating shrub coverage based on vegetation indices,
   SAR backscatter coefficients, phenological metrics, and the extreme
   gradient boosting algorithm. A new Remote Sensing-based Shrub
   Encroachment Index (RSSEI) was established to assess the stage of shrub
   encroachment. The complex driving mechanisms of shrub encroachment were
   innovatively elucidated through the integrated application of
   Geographical Detector (GD) and Geographical Convergent Cross Mapping
   (GCCM). The results show that the shrub coverage estimation model
   achieved high accuracy (R2 = 0.70, RMSE = 4.0\%, MAE = 2.7\%), with the
   SHapley Additive exPlanations (SHAP) value indicating the significant
   role of phenological metrics in estimating shrub coverage. The RSSEI was
   found to grade shrub encroachment stages more accurately, with overall
   accuracy reaching 74.6\%. Moderate to severe encroached grasslands
   dominate the study area, exhibiting an east-high and west-low spatial
   distribution. GD and GCCM indicated that moisture-related factors,
   including precipitation, soil water content, and vapor pressure deficit,
   were the main driving forces of shrub encroachment. And shrub
   encroachment has a significant causal influence on 2 m-height air
   temperature. This study provides an improving technical reference for
   remote sensing observation of shrub encroachment in semi-arid grasslands
   and is also valuable for understanding the formation causes and feedback
   effects of shrub encroachment in these areas.},
Type = {Article},
Affiliation = {Yang, XC (Corresponding Author), Beijing Forestry Univ, Sch Grassland Sci, Beijing, Peoples R China.
   Chen, Ang; Zhang, Min; Xing, Xiaoyu; Yang, Dong; Yang, Xiuchun, Beijing Forestry Univ, Sch Grassland Sci, Beijing, Peoples R China.
   Chen, Ang, Peking Univ, Inst Remote Sensing \& Geog Informat Syst, Sch Earth \& Space Sci, Beijing, Peoples R China.
   Xu, Cong, Univ Canterbury, New Zealand Sch Forestry, Christchurch, New Zealand.
   Xu, Bin, Chinese Acad Agr Sci, Inst Agr Resources \& Reg Planning, Key Lab Agriinformat, Minist Agr, Beijing, Peoples R China.},
DOI = {10.1080/15481603.2025.2555073},
Article-Number = {2555073},
Keywords = {Shrub encroachment; driving mechanism; phenology metrics; geostatistical
   model; geographic causal model},
Keywords-Plus = {WOODY PLANT ENCROACHMENT; VEGETATION; ECOSYSTEM; CONSEQUENCES; IMPACTS;
   CHLOROPHYLL; TEMPERATURE; SENTINEL-1; PHENOLOGY; BIOMASS},
Author-Email = {yangxiuchun@bjfu.edu.cn},
Number-of-Cited-References = {83},
Times-Cited = {0},
Unique-ID = {WOS:001563797800001},
}

@article{ WOS:001561240600001,
Author = {Ma, Gelilan and Zhao, Chuanwu and Wu, Hanyi and Gao, Yuan and Ren,
   Shoujia and Pan, Yaozhong},
Title = {A novel red-edge-based anomalous water detection index and diagnostic
   framework},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2025},
Volume = {18},
Number = {2},
Month = {DEC 31},
Abstract = {Frequent water anomalies pose serious threats to human habitats. Owing
   to the complexity of aquatic environments and the diversity of anomaly
   types, satellite remote sensing still faces challenges. In this study,
   the anomalous water index (AWI) and the advanced water turbidity index
   (AWTI), were developed using Sentinel-2's red edge band. Based on these
   parameters, we constructed a two-step decision-tree-based diagnostic
   framework (ADF) consisting of detection and classification components.
   The proposed indices and framework were compared with existing spectral
   indices and supervised learning algorithms in eight global study areas.
   The results showed that AWI effectively identified various water
   anomalies, whereas the AWTI distinguished turbid water from algal water.
   Both indices yielded F1 and kappa values exceeding 0.89, outperforming
   the existing indices. ADF achieved comparable performance to both the
   random forest and support vector machine algorithms, with F1 scores of
   approximately 0.9. The ADF exhibited strong time series monitoring
   performance across four cases, with kappa values of 0.87-0.94,
   indicating high accuracy and few false positives. In conclusion, this
   study provides a solid theoretical basis for detecting and classifying
   water anomalies without prior knowledge. Future work will extend the
   method to more anomaly types and regions, enhancing threshold
   generalization for global monitoring.},
Type = {Letter},
Affiliation = {Pan, YZ (Corresponding Author), Beijing Normal Univ, Fac Geog Sci, State Key Lab Remote Sensing, Beijing 100875, Peoples R China.
   Pan, YZ (Corresponding Author), Beijing Normal Univ, Key Lab Environm Change \& Nat Disasters Chinese, Minist Educ, Beijing 100875, Peoples R China.
   Pan, YZ (Corresponding Author), Qinghai Normal Univ, Acad Plateau Sci \& Sustainabil, Xining 810016, Peoples R China.
