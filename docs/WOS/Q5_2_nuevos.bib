   Wu, Qinglong, Fuxianhu Stn Plateau Deep Lake Field Observat \& Re, Chengjiang 653200, Yunnan, Peoples R China.},
DOI = {10.1016/j.ecoser.2026.101818},
EarlyAccessDate = {JAN 2026},
