   Gerlein-Safdi, Cynthia, Univ Calif Berkeley, Lawrence Berkeley Natl Lab, Berkeley, CA 94720 USA.},
DOI = {10.1109/TGRS.2026.3671457},
Article-Number = {4204414},
Keywords = {Floods; Urban areas; Irrigation; Sentinel-2; Remote sensing; Synthetic
   aperture radar; Optical sensors; Optical imaging; Training; Normalized
   difference water index; Canal cities; custom street flood index (CSFI);
   flood detection; machine learning (ML); multispectral remote sensing;
   street level; urban flooding},
