   Bormudoi, Arnob, Assam downtown Univ, Fac Engn, Gauhati 781026, India.},
DOI = {10.3390/land15010174},
Article-Number = {174},
Keywords = {crop vulnerability; NDVI-anomaly; deep learning; random forest;
