@article{ WOS:001650420700008,
Author = {Behera, Indrakant and Jain, Nirmala and Martha, Tapas R. and Bose,
   Mahalingam},
Title = {Optimising sampling strategies for AI-based landslide susceptibility
   mapping: a case study of Idukki, Kerala},
Journal = {NATURAL HAZARDS},
Year = {2025},
Volume = {122},
Number = {1},
Month = {DEC 26},
Abstract = {Landslide inventory is a primary requirement for Artificial
   Intelligence-based landslide susceptibility mapping using terrain
   predictors. Idukki of the Western Ghats has always been the hotspot for
   Landslide activity. Accurately and precisely, susceptibility zonation is
   required to facilitate effective hazard mitigation strategies. This
   study utilised conditioning factors such as Slope, Aspect, Curvature,
   Stream Power Index, Topographic Ruggedness Index, Distance from
   Lineaments, Geomorphology, Lithology, Soil, and Land Use/Land Cover
   (LULC), employing conventional and spatial sampling strategies. Advanced
   models such as Random Forest (RF), Support Vector Machine (SVM), XGBoost
   (XGB), K Nearest Neighbour (KNN), Artificial Neural Network (ANN),
   One-Dimensional Convolution Neural Network (1D CNN), and Deep Neural
   Network (DNN) were used to predict landslide susceptibility. The
   accuracy of prediction was evaluated by the Receiver Operating
   Characteristic-Area Under Curve (ROC-AUC). Mainly, two data sampling
   strategies have been performed due to the irregular geographical
   distribution of the inventory. Spatial sampling outperformed
   conventional sampling, with the ANN model achieving the highest ROC-AUC
   scores (0.878 spatial, 0.831 conventional). Landslide occurrences were
   often preceded by above-average daily and antecedent cumulative
   rainfall, leading to soil moisture build-up and slope instability. The
   analysis revealed a strong correlation between intense rainfall and
   landslide events, underscoring precipitation as a key triggering factor.
   Overall, this study highlights the significance of integrating diverse
   sampling strategies with machine learning (ML) and deep learning (DL)
   models to enhance landslide susceptibility assessment and support hazard
   mitigation in vulnerable regions.},
Type = {Article},
Affiliation = {Behera, I (Corresponding Author), Indian Inst Technol, Mehta Family Sch Data Sci \& Artificial Intelligenc, Roorkee 247667, Uttarakhand, India.
   Behera, Indrakant, Indian Inst Technol, Mehta Family Sch Data Sci \& Artificial Intelligenc, Roorkee 247667, Uttarakhand, India.
   Jain, Nirmala; Martha, Tapas R., Govt India, Indian Space Res Org, Natl Remote Sensing Ctr, Dept Space, Hyderabad 500037, Telangana, India.
   Bose, Mahalingam, Cent Univ Karnataka, Dept Geog, Kalaburagi 585311, Karnataka, India.},
DOI = {10.1007/s11069-025-07842-8},
Article-Number = {18},
Keywords = {Landslides; Machine learning; Deep learning; Spatial sampling;
   Conventional sampling; ROC-AUC curve; Triggering factors; Idukki},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; YOUDEN INDEX; MACHINE; GIS; BIVARIATE;
   DISTRICT; MODELS; REGION; COUNTY},
