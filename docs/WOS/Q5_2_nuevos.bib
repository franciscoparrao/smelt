@article{ WOS:001645261600001,
Author = {Elkholy, Eman and Anandhi, Aavudai},
Title = {Biological and geological carbon sequestration monitoring techniques: a
   review},
Journal = {CARBON MANAGEMENT},
Year = {2026},
Volume = {17},
Number = {1},
Month = {DEC 31},
Abstract = {Carbon sequestration captures, stores, and reduces CO2 emissions across
   environmental ecosystems. It encompasses two primary pathways:
   biological processes in terrestrial ecosystems and geological storage in
   underground formations. Researchers and policymakers have focused on
   carbon sequestration monitoring to confirm storage effectiveness and
   maintain long-term retention. Some of the main reasons behind monitoring
   importance are regulatory compliance, carbon credit verification, and
   leakage detection. Despite its importance, critical gaps include limited
   definitional clarity for carbon sequestration monitoring, insufficient
   validation reporting in 57\% of studies, and geographical research
   differences concentrated in North America. To provide a comprehensive
   understanding of carbon sequestration monitoring, a systematic
   literature review was conducted using the PRISMA framework, evaluating
   56 scientific publications to assess monitoring techniques across both
   pathways. The review analyzed definitions of carbon sequestration and
   carbon sequestration monitoring from the literature, identifying key
   components for each, and developed a simple and broad definition. It
   also identified monitoring techniques and established a hierarchical
   classification system, identifying four primary categories for
   biological sequestration and six for geological sequestration. The
   review revealed distinct advantages and disadvantages across different
   monitoring categories. Remote sensing offers an advantage in spatial
   coverage but faces classification challenges; field measurements provide
   high accuracy but remain labor-intensive; machine learning shows
   promising capabilities despite accuracy limitations; and integrated
   techniques offer a comprehensive assessment despite increased
   complexity.},
Type = {Review},
Affiliation = {Anandhi, A (Corresponding Author), Florida A\&M Univ, Coll Agr \& Food Sci, Biol Syst Engn, Benjamin Bannekar Tech C, Tallahassee, FL 32307 USA.
   Elkholy, Eman, Florida A\&M Univ, FSH Sci Res Ctr, Sch Environm, Tallahassee, FL USA.
   Anandhi, Aavudai, Florida A\&M Univ, Coll Agr \& Food Sci, Biol Syst Engn, Benjamin Bannekar Tech C, Tallahassee, FL 32307 USA.},
DOI = {10.1080/17583004.2025.2590609},
Article-Number = {2590609},
Keywords = {Carbon sequestration; monitoring techniques; biological sequestration;
   geological sequestration; integrated monitoring},
Keywords-Plus = {STOCK ASSESSMENT; SHALLOW SUBSURFACE; FOREST; TRANSPORT; FIELD},
Author-Email = {anandhi.swamy@famu.edu},
Number-of-Cited-References = {51},
Times-Cited = {0},
Unique-ID = {WOS:001645261600001},
}

@article{ WOS:001645863700001,
Author = {Jiang, Linlin and Hou, Wan and Shi, Kaifang},
Title = {A novel multimodal fusion deep network for identifying hillside urban
   expansion},
Journal = {GISCIENCE \& REMOTE SENSING},
Year = {2026},
Volume = {63},
Number = {1},
Month = {DEC 31},
Abstract = {Hillside urban expansion (HUE) threatens fragile and sensitive
   mountainous and hilly ecosystems, increasing geological and ecological
   risks that adversely affect human well-being. Accurate HUE
   identification is therefore essential for understanding land-use
   conflicts and optimizing urban spatial planning in hilly regions.
   However, the fragmented and small-scale nature of HUE patches, coupled
   with severe land-cover confusion, makes spatial identification highly
   challenging. To address this issue, we proposed a multimodal fusion deep
   network (HUENet) that integrates spatial- and frequency-domain features
   for improved HUE identification in complex terrains. First, a
   prior-based masking strategy was used to construct training and
   validation datasets. Then, a multi-scale frequency-domain spatial and
   channel attention (MFSCA) module was introduced to enhance feature
   representation and fusion. Experimental results show that HUENet
   significantly outperforms mainstream machine learning and deep learning
   models, with mIoU improvements of 3.28\%-14.67\% and notable gains in
   efficiency. HUENet exhibits high spatial accuracy, achieving an overall
   accuracy exceeding 80\% across related datasets. In addition, HUENet
   exhibits strong transferability across various topographic conditions
   and potential for long-term monitoring of HUE dynamics. Our study offers
   a novel methodological approach for precise HUE identification and
   provides scientific insights to support sustainable urban development in
   mountainous and hilly regions.},
Type = {Article},
