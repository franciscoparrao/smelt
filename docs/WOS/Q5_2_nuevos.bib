   Ellenbroek, Anton, Food \& Agr Org United Nations FAO, Rome, Italy.},
DOI = {10.1080/17538947.2026.2617004},
Article-Number = {2617004},
Keywords = {Remote sensing; artificial intelligence; fisheries; navigation radar
   detector},
Keywords-Plus = {MARITIME SURVEILLANCE; FOOD SECURITY; TIME-SERIES; MANAGEMENT;
   IDENTIFICATION; ILLEGAL; CLASSIFICATION; TECHNOLOGY; OCEAN; CATCH},
Author-Email = {gianpaolo.coro@isti.cnr.it},
