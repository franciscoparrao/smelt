   Alghamdi, Tami A.; Budiarto, Rahmat, Al Baha Univ, Coll Comp \& Informat, Al Aqiq 657797738, Saudi Arabia.},
DOI = {10.32604/cmc.2025.069377},
Article-Number = {069377},
Keywords = {Audio classification; convolutional neural network (CNN); environmental
   science; forest fire detection; machine learning; spectrogram analysis;
   IoT},
