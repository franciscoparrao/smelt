DOI = {10.1007/s12518-026-00710-5},
Article-Number = {60},
Keywords = {Protected agriculture; Spatiotemporal distribution; Berry water
   consumption; Random forest; Sentinel-2},
Keywords-Plus = {RANDOM FORESTS; LAND-COVER; REMOTE; VEGETATION; MICHOACAN; NETWORKS;
   ZAMORA; INDEX; GREEN; AREA},
Author-Email = {cvillasenor@ciga.unam.mx
   jsolorzano@ciga.unam.mx},
Number-of-Cited-References = {83},
