   Lee, Han Soo, Hiroshima Univ, Grad Sch Innovat \& Practice Smart Soc, Smart Energy, Higashihiroshima, Japan.},
DOI = {10.1016/j.jhydrol.2026.135073},
EarlyAccessDate = {FEB 2026},
Article-Number = {135073},
Keywords = {Hydrological model; Water resources management; WRF-Hydro; Crop type
   mapping; Waterscarcity; Irrigation; Amu River Basin},
