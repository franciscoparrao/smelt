   Cheng, Bo, Hainan Aerosp Informat Res Inst, Key Lab Earth Observat Hainan Prov, Wenchang 571399, Peoples R China.},
DOI = {10.1016/j.jag.2026.105123},
EarlyAccessDate = {JAN 2026},
