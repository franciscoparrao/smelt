}

@article{ WOS:001645143900001,
Author = {Elrasheed, Abdelmajeed A. and Abdelrahman, Samia and Szabo, Szilard},
Title = {Mapping volcanogenic massive sulphide-associated gossans in hyper-arid
   terrains using PRISMA hyperspectral imaging and random forest models: A
   case study from Ariab, NE Sudan},
Journal = {KUWAIT JOURNAL OF SCIENCE},
Year = {2026},
Volume = {53},
Number = {1},
Month = {JAN},
Abstract = {The global demand for key metals (Ni, Cu, and Co), coupled with the
   depletion of easily discoverable resources, necessitates advanced
   exploration methodologies for volcanogenic massive sulphide (VMS)
   deposits. Gossans, key surface indicators of VMS and associated gold
   mineralization, are particularly challenging to identify in regions with
   complex geological settings, deep weathering, and rugged topography,
   such as the Ariab mining district of the Arabian Nubian Shield (ANS).
   This study investigated the novel application of the space borne
   hyperspectral PRISMA (PRecursore IperSpettrale della Missione
   Applicativa) sensor, leveraging its high spectral resolution for gossan
   detection. An integrated approach was employed, incorporating color
   composites, band ratios, density slicing, and a hyperparameter-optimized
   Random Forest classifier. The model achieved an overall accuracy
   exceeding 80 \%, demonstrating its efficacy for scalable gossan mapping.
   The results were validated through spectral analysis, confirming
   diagnostic jarosite signatures and extensive fieldwork. This research
   establishes PRISMA as a powerful, exploration-ready tool for early-stage
   targeting of auriferous VMS deposits in the ANS and similar arid shield
   terrains globally.},
Type = {Article},
Affiliation = {Elrasheed, AA (Corresponding Author), Univ Debrecen, Dept Phys Geog \& Geoinforamt, Egyet Ter 1, H-4032 Debrecen, Hungary.
   Elrasheed, Abdelmajeed A.; Szabo, Szilard, Univ Debrecen, Dept Hydrobiol, Egyet Ter 1, H-4032 Debrecen, Hungary.
   Elrasheed, Abdelmajeed A.; Abdelrahman, Samia, Univ Khartoum, Dept Geol, Khartoum 1115, Sudan.},
DOI = {10.1016/j.kjs.2025.100526},
EarlyAccessDate = {DEC 2025},
Article-Number = {100526},
Keywords = {Gossan; VMS; PRISMA; Remote sensing; Hyperspectral; Arabian nubian
   shield; Random forest},
Keywords-Plus = {RED-SEA HILLS; ARABIAN-NUBIAN SHIELD; ALLAQI-HEIANI SUTURE; MINERAL
   EXPLORATION; GOLD MINERALIZATION; SPECTRAL-ANALYSIS; SHEAR-ZONE;
   DEPOSITS; EVOLUTION; REGIONS},
Author-Email = {ali.abdelmajeed.adam.elrasheed@science.unideb.hu},
Number-of-Cited-References = {113},
Times-Cited = {0},
