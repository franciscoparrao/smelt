@article{ WOS:001608183600007,
Author = {Krishnachaithanya, N. and Sivakumar, P. Bagavathi and Deepika, T.},
Title = {Probabilistic flood risk mapping for Indian megacities using a scalable
   machine learning framework in Google Earth engine},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {Intensifying climate change and rapid urbanization pose a severe flood
   risk to India's major cities. Conventional flood assessment methods,
   however, are often geographically limited and fail to quantify critical
   uncertainties, hindering effective disaster management. To address this
   gap, we introduce the ALERT (Advanced Learning for Enhanced Flood Risk
   Prediction) framework, a scalable and integrated solution for flood
   analysis across the chosen Indian mega cities implemented entirely
   within Google Earth Engine (GEE). The framework leverages multi-source
   remote sensing data-including Sentinel-1 SAR and Sentinel-2 optical
   imagery-to perform robust Land Use/Land Cover (LULC) classification
   using a Random Forest algorithm. Its core innovation is a Bayesian
   probabilistic model that integrates SAR-derived floodwater evidence with
   topographic wetness index (TWI) and precipitation (ERA5) data to
   generate per-pixel flood probability maps, explicitly quantifying
   prediction uncertainty. Across five diverse megacities (Chennai, Mumbai,
   Bengaluru, Kolkata, Gurugram), the Random Forest classifier achieved
   LULC accuracies exceeding similar to 90\%. Critically, integrating this
   LULC context reduced flood detection false positives by similar to
   10-15\% compared to traditional SAR-only methods. The Bayesian
   probabilistic approach further improved flood mapping accuracy by
   similar to 3-5\% over deterministic thresholding, providing a more
   reliable assessment of inundation risk. The validated ALERT framework
   delivers a replicable and scalable solution for dynamic flood
   monitoring, offering critical insights for risk-informed urban planning
   and enhancing climate resilience in vulnerable urban regions globally,
   with demonstrated applicability across strategically selected Indian
   megacities.},
Type = {Article},
Affiliation = {Deepika, T (Corresponding Author), Amrita Vishwa Vidyapeetham, Dept Comp Sci \& Engn, Amrita Sch Comp, Coimbatore, India.
   Krishnachaithanya, N.; Sivakumar, P. Bagavathi; Deepika, T., Amrita Vishwa Vidyapeetham, Dept Comp Sci \& Engn, Amrita Sch Comp, Coimbatore, India.},
DOI = {10.1016/j.rineng.2025.107872},
EarlyAccessDate = {DEC 2025},
Article-Number = {107872},
Keywords = {Google Earth engine; Spatial data processing; Geospatial analysis;
   Indian floods; Vector data; Scalable model},
Author-Email = {n\_krishnachaithanya@cb.students.amrita.edu
   pbsk@cb.amrita.edu
   t\_deepika@cb.amrita.edu},
Number-of-Cited-References = {51},
Times-Cited = {1},
Unique-ID = {WOS:001608183600007},
}

@article{ WOS:001597720400001,
Author = {Han, Muyan and Chai, Ji},
Title = {An efficient and transferable remote sensing spectral index for regional
   corn mapping},
Journal = {SCIENCE OF REMOTE SENSING},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Accurate and timely corn mapping at regional scales supports effective
   agricultural management and policy development. However, traditional
   data-driven approaches rely heavily on extensive ground-truth samples
   and have limited applicability in data-scarce areas. And there is still
   a lack of simple and practical approaches that require few or no field
   observations for corn mapping. Therefore, this study presents a novel
   framework that integrates an improved Dual-peak Canopy Nitrogen Index
   (DCNI) with Green Chromatic Coordinate (GCC) analysis. The refined DCNI
   captures nitrogen-related spectral dynamics to distinguish corn from
   spectrally similar crops such as soybean and sorghum during peak growth
   stages. The GCC analysis identifies the optimal mapping window,
   mitigating the effects of cloud cover and temporal data gaps for
   regional corn mapping. We applied this improved index to three selected
   but representative corn growing regions: Nenjiang in China, Pocahontas
   in the United States, and Mayenne in France. Using the optimized DCNI
   thresholds, binary classification was performed to reduce both
   commission and omission errors. In the pixel-level validation for 2021,
   our DCNI index achieved better overall accuracy and F1 scores compared
   to the classical random forest model and its variants. Interannual tests
   from 2020 to 2022 also showed stable performance and strong agreement
   with official statistics, with all coefficients of determination R2
   above 0.96. We also investigate uncertainties arising from data
   interpolation, limited field samples, and mixed cropping patterns, and
   propose the integration of higherfrequency satellite observations and
   multisource data fusion to improve early season monitoring and broaden
   large-scale applicability. The proposed framework requires minimal crop
   samples and computational resources, providing a simple, practical
   alternative for regional corn mapping with robust transferability.},
Type = {Article},
Affiliation = {Chai, J (Corresponding Author), China Univ Geosci, Sch Publ Adm, Dept Land Resource Management, 388 Lumo Rd, Wuhan 430074, Peoples R China.
   Han, Muyan, Univ Manchester, Sch Environm Educ \& Dev, Dept Geog, Oxford Rd, Manchester M13 9PL, England.
   Chai, Ji, China Univ Geosci, Sch Publ Adm, Dept Land Resource Management, 388 Lumo Rd, Wuhan 430074, Peoples R China.},
