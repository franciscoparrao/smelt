@article{ WOS:001643435900005,
Author = {Ju, Bowen and Li, Rongrong and Xu, Yong and Huang, Bo},
Title = {Contrasting Daytime and Nighttime Characteristics and Driving Mechanisms
   of Surface Urban Heat Islands Across Local Climate ZonesBeijing as a
   Case Study},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {1567-1582},
Abstract = {The urban heat island (UHI) effect poses critical challenges to urban
   sustainability, yet the driving mechanisms of the daytime and nighttime
   surface urban heat island intensity (SUHII) remain insufficiently
   understood. This study employs an integrated approach combining remote
   sensing and GIS to produce a high-accuracy local climate zone (LCZ)
   classification in Beijing, and utilizes satellite-derived land surface
   temperature data to analyze the spatial distribution of SUHII across
   different LCZ types. The XGBoost model, combined with SHAP values, is
   used to quantify the contributions of nine urban morphological
   parameters to SUHII and to assess the spatiotemporal differences in
   these impacts. The results reveal substantial variations in daytime and
   nighttime SUHII across different LCZs. The highest daytime SUHII occurs
   in LCZ 8 with an average of 8.48 degrees C, while the highest nighttime
   SUHII occurs in LCZ 1 and LCZ G, with averages of 3.68 degrees C and
   3.64 degrees C, respectively. Crucially, different parameters dominate
   SUHII at different times: building surface fraction and average building
   volume are key drivers of daytime SUHII, whereas sky view factor and
   distance to water play dominant roles at night. Moreover, some
   parameters, such as average building height and its standard deviation,
   exhibit contrasting effects between day and night, highlighting the
   necessity of separate assessments for daytime and nighttime conditions.
   These findings emphasize the spatiotemporal heterogeneity of SUHII
   driving mechanisms, underscore the value of LCZ-based classification in
   disentangling UHI complexity, and demonstrate the importance of
   quantifying daytime-nighttime differences for designing targeted urban
   heat mitigation strategies.},
Type = {Article},
Affiliation = {Huang, B (Corresponding Author), Univ Hong Kong, Dept Geog, Hong Kong, Peoples R China.
   Ju, Bowen; Li, Rongrong, Chinese Univ Hong Kong, Inst Space \& Earth Informat Sci, Hong Kong, Peoples R China.
   Ju, Bowen; Huang, Bo, Shenzhen Univ, Res Inst Smart Cities, Sch Architecture \& Urban Planning, Shenzhen, Peoples R China.
   Xu, Yong, Guangzhou Univ, Sch Geog \& Remote Sensing, Guangzhou 510006, Peoples R China.
   Huang, Bo, Univ Hong Kong, Dept Geog, Hong Kong, Peoples R China.},
DOI = {10.1109/JSTARS.2025.3637559},
Keywords = {Surface morphology; Land surface; Buildings; Thermal pollution; Remote
   sensing; Morphology; Spatial resolution; Landsat; Heating systems; Land
   surface temperature; Day-night differences; local climate zone (LCZ);
   remote sensing (RS); surface urban heat island (SUHI); urban morphology},
Keywords-Plus = {BUILDING HEIGHT; ZONES; AREAS; CHINA},
Author-Email = {bowenju@link.cuhk.edu.hk
   rongrongli@cuhk.edu.hk
   xu1129@gzhu.edu.cn
   bohuang@hku.hk},
