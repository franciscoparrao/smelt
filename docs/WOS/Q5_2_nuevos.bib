   Dube, Timothy, Univ Western Cape, Inst Water Studies, Bellville, South Africa.
   Salem, Salem Ibrahim, Plymouth Marine Lab, Prospect Pl, Plymouth, England.
   Okumura, Tadanobu, Wildlife Management Off Inc, Tokyo, Japan.
   Maki, Masayasu, Fukushima Univ, Fukushima, Japan.},
DOI = {10.1080/10106049.2025.2575477},
Article-Number = {2575477},
Keywords = {Diverse-landscape; cross-seasonal; dual-sentinel; ecosystem
