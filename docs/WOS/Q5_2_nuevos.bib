   Guan, Qingchun; Tang, Xiaoxue; Chen, Junwen, China Univ Petr East China, Coll Oceanog \& Space Informat, Qingdao 266580, Peoples R China.},
DOI = {10.1007/s00343-025-5246-2},
EarlyAccessDate = {MAR 2026},
Keywords = {coastal eutrophication; water quality retrieval; transformer network;
   support vector regression (SVR)},
