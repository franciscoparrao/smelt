   Zhang, Yanliang, Heilongjiang Acad Agr Machinery Engn Sci, Harbin 150081, Peoples R China.},
DOI = {10.1016/j.still.2026.107091},
EarlyAccessDate = {JAN 2026},
Article-Number = {107091},
Keywords = {Soil available phosphorus; Interpretable machine learning; Sentinel-2
   satellite imagery; Topographic variables; Digital soil mapping},
Keywords-Plus = {ORGANIC-MATTER; VEGETATION; INDEX},
Author-Email = {zhang66wei@126.com
   zyl19770518@163.com},
Number-of-Cited-References = {95},
