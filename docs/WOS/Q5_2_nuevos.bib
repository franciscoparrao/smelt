Unique-ID = {WOS:001651857400001},
}

@article{ WOS:001719534900005,
Author = {Li, Jian and Lin, Xinglei and Lu, Yilin and Lu, Jian and Fu, Hongkun and
   Qi, Ji and Kang, Junrui and Liu, Baoqi and Zhao, Jiawei and Guan, Hengxu
   and Dong, Chunxiang},
Title = {An Improved 3D U-Net Hybrid Network for High-Precision Soybean Mapping
   From Multitemporal Sentinel-2 Imagery},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {9032-9052},
Abstract = {High-precision mapping of soybeans, a globally significant oil and
   protein crop, has long been constrained by the limitations of
   traditional remote sensing methods, particularly regarding their
   inefficiency in fusing spatio-temporal information and suboptimal
   classification accuracy. Consequently, the rigorous demands of modern
   precision agriculture for crop monitoring have often not been adequately
   addressed. To address these challenges, a novel hybrid model was
   developed in this study for soybean identification using multitemporal
   remote sensing imagery. This model is built upon an improved
   three-dimensional (3D) U-Net architecture, which synergistically
   integrates bidirectional long short-term memory (BiLSTM) networks and
   random forest (RF) algorithms. This integration enables the effective
   extraction of multilevel features and subsequent integrated
   classification. A notable innovation of this research involves the
   incorporation of the greenness and water content composite index (GWCCI)
   into the feature set. GWCCI quantifies canopy greenness and water
   status, improving discrimination of soybean phenology. Experimental
   validation was conducted within the primary soybean production region of
   Hailun City, Heilongjiang Province. The results demonstrated that the
   proposed model significantly outperformed 10 baseline methods (including
   standard 3D U-Net, CNN, and RF) across four key metrics: overall
   accuracy (OA), user accuracy (UA), F1-score, and Kappa coefficient.
   Specifically, when benchmarked against a standard 3D U-Net, the
   developed model exhibited a 3.2\% increase in OA, a 9.3\% increase in
   UA, a 2.6\% increase in F1-score, and a 6.4\% increase in the Kappa
   coefficient. These quantitative improvements highlight its enhanced
   capability in distinguishing soybeans from background crops. Ultimately,
   this research not only provides a novel methodological framework for
   precise crop classification but also contributes a viable
   multi-dimensional feature fusion strategy directly applicable to crop
   monitoring and intelligent agricultural management.},
