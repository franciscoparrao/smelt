Keywords = {Geospatial artificial intelligence; Remote sensing; Spatiotemporal
   modeling; Multimodal data fusion; Semantic segmentation},
Keywords-Plus = {GRAPH NEURAL-NETWORK; ATTENTION; FUSION; IMAGES; CLASSIFICATION;
