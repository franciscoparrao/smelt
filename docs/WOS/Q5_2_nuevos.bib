   Figueira, Rui, Univ Lisbon, CIBIO,Ctr Invest Biodiversidade \& Recursos Genet, InBIO Lab Associado, Inst Super Agron, P-1349017 Lisbon, Portugal.
   Figueira, Rui, Univ Porto, Ctr Invest Biodiversidade \& Recursos Genet, InBIO Lab Associado, CIBIO, Campus Vairao, P-4485661 Vairao, Portugal.},
DOI = {10.3390/rs17243979},
Article-Number = {3979},
Keywords = {land use; Alqueva; permanent crops; EU Crop Map; machine learning;
   Sentinel-1; Sentinel-2},
