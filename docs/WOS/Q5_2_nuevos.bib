   photovoltaic damage; economic loss assessment},
Keywords-Plus = {RANDOM FOREST; RISK-ASSESSMENT; CHINA; LANDSAT; DISASTER; SOLAR},
Author-Email = {wujidong@bnu.edu.cn},
