   Setia, Raj, Punjab Remote Sensing Ctr, Ludhiana 141004, Punjab, India.},
DOI = {10.1007/s10661-026-15160-0},
Article-Number = {315},
Keywords = {Fluoride contamination; Hydrogeochemical analysis; Spatial analysis;
   Deep learning; Groundwater quality},
Keywords-Plus = {MAJOR ION CHEMISTRY; WEATHERING PROCESSES; QUALITY; CHHATTISGARH;
   IMPACT; PUNJAB; MODEL; CITY},
