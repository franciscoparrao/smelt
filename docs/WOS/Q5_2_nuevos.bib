@article{ WOS:001602170900002,
Author = {Bensefia, Sofiane and Kouider, Djouheina Boukehlifi and Athmani, Houria},
Title = {ASSESSMENT OF SAND ENCROACHMENT IN ARID REGIONS: A CASE STUDY OF EL
   HAJEB MUNICIPALITY, BISKRA PROVINCE, SOUTHEASTERN SAHARA, ALGERIA},
Journal = {CARPATHIAN JOURNAL OF EARTH AND ENVIRONMENTAL SCIENCES},
Year = {2026},
Volume = {21},
Number = {1},
Pages = {35-48},
Month = {FEB},
Abstract = {This study examines sand encroachment in El Hajeb, Algeria, from 2000 to
   2023-a region highly vulnerable to desertification. A multi-source
   remote sensing framework was used, combining optical and radar satellite
   data (Landsat, MODIS, Sentinel-1 SAR) with spectral indices (NDVI,
   MSAVI, BSI, NDESI) to monitor dune dynamics, vegetation health, and sand
   distribution. Pre-processing steps included atmospheric correction,
   cloud masking, and normalization. Advanced geospatial analysis and
   supervised classification were conducted using machine-learning
   algorithms-Random Forest (RF) and Support Vector Machine (SVM)-, which
   improved classification accuracy and land, cover discrimination. Results
   show an 11.90\% reduction in stabilized dunes and a 6.05\% increase in
   sparse sand areas. These shifts are linked to vegetation exploitation,
   soil moisture status, and intensified aeolian activity driven by
   prolonged droughts and prevailing winds. Sentinel-1 SAR data contributed
   to understanding surface roughness and moisture variability, reinforcing
   the analysis. Spatial maps revealed high-risk zones along the periphery
   of vegetated areas. To combat land degradation, the study recommends
   windbreaks, sand fences, and afforestation efforts. Overall, the
   research highlights the value of integrating remote sensing and machine
   learning for environmental monitoring and supports the development of
   adaptive land management strategies to enhance resilience in arid
   landscapes.},
Type = {Article},
Affiliation = {Bensefia, S (Corresponding Author), Mohmed El Bachir El Ibrahimi Univ, Fac Life \& Nat Sci \& Earth \& Universe Sci, Dept Agr Sci, Hlth \& Environm Lab, El Anasser, Algeria.
   Bensefia, Sofiane, Mohmed El Bachir El Ibrahimi Univ, Fac Life \& Nat Sci \& Earth \& Universe Sci, Dept Agr Sci, Hlth \& Environm Lab, El Anasser, Algeria.
   Kouider, Djouheina Boukehlifi; Athmani, Houria, Univ Mohamed Khider, LARYSS Lab, Biskra, Algeria.},
DOI = {10.26471/cjees/2026/021/350},
Keywords = {sand encroachment; desertification; remote sensing; machine learning;
   sustainability and management; Elhajdeb region},
Keywords-Plus = {CLIMATE-CHANGE; SOIL},
Author-Email = {Sofiane.bensefia@univ-bba.dz
   bk.jouhina@univ-biskra.dz},
Number-of-Cited-References = {44},
Times-Cited = {1},
