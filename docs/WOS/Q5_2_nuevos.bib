@article{ WOS:001695655300001,
Author = {Lee, Siwoo and Kang, Yoojin and Sung, Taejun and Hwang, Soomin and Yang,
   Seyoung and Im, Jungho},
Title = {Mapping nationwide 1 Km hourly human mobility (2022-2024) across South
   Korea using multi-source data},
Journal = {GISCIENCE \& REMOTE SENSING},
Year = {2026},
Volume = {63},
Number = {1},
Month = {DEC 31},
Abstract = {Population mobility is a fundamental driver of urban development and
   socioeconomic processes, providing a critical foundation for scientific
   analysis and evidence-based decision-making. Despite its importance,
   most existing studies and applications continue to rely on static
   resident (de jure) population data, which fail to represent the
   spatiotemporal dynamics of human activity. In this study, we develop a
   comprehensive framework to map nationwide hourly floating (de facto)
   population across South Korea at 1 km spatial resolution for the period
   2022-2024 by integrating mobile phone-based records with a
   machine-learning approach. The proposed framework incorporates a diverse
   set of spatial and temporal predictors, including building
   characteristics, land cover, accessibility indicators, temporal
   variables, and meteorological conditions, enabling the model to capture
   spatial heterogeneity and short-term temporal variability that are often
   neglected in prior population mapping studies. Quantitative evaluation
   demonstrates strong model performance, with leave-one-year-out
   cross-validation yielding high temporal generalization (Pearson
   correlation coefficients r = 0.981-0.993) and spatial cross-validation
   across unseen metropolitan regions indicating robust transferability (r
   = 0.847-0.941). Qualitative analyses reveal interpretable and realistic
   mobility patterns, including elevated nighttime populations in
   residential areas and pronounced daytime peaks in commercial and
   industrial zones, particularly around midday (13:00). The model also
   successfully captures city-specific mobility responses, holiday-related
   population redistribution, and weather-dependent behavioral changes,
   such as increased residential presence on rainy days. These results
   represent a substantial improvement over conventional static population
   datasets and existing floating population products. By resolving hourly
   variations in human presence at high spatial resolution, the resulting
   dataset provides a valuable resource for a wide range of applications,
   including urban management (e.g. traffic modeling and infrastructure
   planning) and environmental risk assessment (e.g. disaster preparedness
   and wildfire prevention). Overall, this work offers new insights into
   human mobility dynamics and supports more informed analyses of
   environmental sustainability and urban resilience.},
Type = {Article},
Affiliation = {Im, J (Corresponding Author), Ulsan Natl Inst Sci \& Technol UNIST, Dept Civil Urban \& Earth \& Environm Engn, Ulsan, South Korea.
   Im, J (Corresponding Author), UNIST, Grad Sch Artificial Intelligence, Ulsan, South Korea.
   Im, J (Corresponding Author), UNIST, Grad Sch Carbon Neutral, Ulsan, South Korea.
   Lee, Siwoo; Sung, Taejun; Hwang, Soomin; Yang, Seyoung; Im, Jungho, Ulsan Natl Inst Sci \& Technol UNIST, Dept Civil Urban \& Earth \& Environm Engn, Ulsan, South Korea.
   Kang, Yoojin, Kookmin Univ, Dept Forestry Environm \& Syst, Seoul, South Korea.
   Im, Jungho, UNIST, Grad Sch Artificial Intelligence, Ulsan, South Korea.
   Im, Jungho, UNIST, Grad Sch Carbon Neutral, Ulsan, South Korea.},
DOI = {10.1080/15481603.2026.2633052},
Article-Number = {2633052},
Keywords = {Human mobility; mobile phone data; machine learning; floating population},
Keywords-Plus = {POPULATION},
Author-Email = {ersgis@unist.ac.kr},
Number-of-Cited-References = {92},
Times-Cited = {0},
Unique-ID = {WOS:001695655300001},
}

@article{ WOS:001691609200001,
Author = {Medina, Angel J. and Lopez, Rolando Salas and Zabaleta-Santisteban, Jhon
   A. and Tuesta-Trauco, Katerin M. and Rivera-Fernandez, Abner S. and
   Sanchez-Vega, Jose A. and Silva-Melendez, Teodoro B. and Silva-Lopez,
   Jhonsy O. and Briceno, Nilton B. Rojas and Alberca, Marlen A. Grandez
   and Diaz, Cecibel Portocarrero and Veneros, Jaris and Cruz, Manuel Oliva
   and Barboza, Elgar},
Title = {Integration of sentinel optical and radar data in Google Earth Engine
   for mapping small complex agroforests of shade-grown coffee in northern
   Peru},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2026},
Volume = {41},
Number = {1},
Month = {DEC 31},
Abstract = {Coffee is a key global export product; however, there is still limited
   information on the location and dynamics of its growing areas,
   especially in light of the implementation of new regulations such as the
   EUDR. This study used optical and radar data from the Sentinel
   satellite, processed on the Google Earth Engine (GEE) platform, to map
   vegetation cover and land use, including coffee farming systems in the
   province of Rodr \& iacute;guez de Mendoza. The Random Forest algorithm
   was applied, trained with 531 verification points collected in the
   field. As a result, six classified maps were generated, showing
   sustained growth in the area under coffee cultivation, from 7,111.071 ha
   to 9,443.050 ha over a six-year period. The cartographic products
   achieved high levels of accuracy, with Overall Accuracy (OA) values
   above 94\% and a Kappa index (KI) above 88.9\%. These results
   demonstrate the potential of GEE for multi-year monitoring of permanent.},
