}

@article{ WOS:001676953700001,
Author = {Lyu, Lili and Jacinthe, Pierre-Andre and Lin, Nan and Lyu, Dongmei and
   Liu, Ge and Li, Sijia and Fang, Chong and Tao, Hui and Yu, Hao and Li,
   Zuchuan and Song, Kaishan},
Title = {Global inland waters trophic status from space observation: scientific
   advances and future challenges},
Journal = {WATER RESEARCH},
Year = {2026},
Volume = {293},
Month = {APR 1},
Abstract = {Inland waters represent a significant share of the global freshwater
   resources and can have a profound impact on global climate and human
   well-being. By 2050, the world's population is expected to reach 9.7
   billion, and one in four people is expected to suffer from water
   shortages. The United Nations has identified clean drinking water
   management as a Sustainable Development Goal (SDG 6) to address this
   major challenge. Eutrophication is a serious threat to inland water
   resources worldwide. The vigorous development of eutrophication research
   could greatly contribute to the achievement of SDG 6. To understand the
   trophic status in inland waters around the world, catchment and larger
   scale observations are necessary. In recent decades, advances in
   satellite remote sensing technology have improved our ability to assess
   the extent of the problem and understand underlying mechanisms of the
   eutrophication process. This review covers the basic concepts, key
   studies, and methodological frameworks for monitoring the trophic status
   of inland waters using satellite remote sensing across diverse spatial
   and temporal scales. Based on the pressure, status, response of
   eutrophication, we propose a conceptual framework that integrates index
   harmonization, a multi-model workflow, and guidance for index selection
   to enhance the effectiveness of remote sensing monitoring of trophic
   status in inland waters. The review (i) linked optical responses and
   biochemical processes of eutrophication, (ii) explained how to monitor
   trophic status using a multi-strategy approach with satellite retrieval
   algorithms, and (iii) discussed the significant importance of trophic
   status mapping for the healthy development of inland waters worldwide.
   Driven by remote sensing and various models, global multi-temporal and
   multi-spatial optical big data has played a significant role in the
   monitoring of inland water trophic status. Future research will focus on
   harnessing hyperspectral missions, developing high-quality atmospheric
   correction and addressing adjacency effects, advancing physics-guided
   machine learning, and integrating these approaches with process-based
   hydrological and biogeochemical models. These researches will continue
   to contribute to the assessment of risks in inland waters, the
   sustainable utilization and protection of water resources, and the
   active response to climate change and human pressures.},
Type = {Article},
Affiliation = {Song, KS (Corresponding Author), Chinese Acad Sci, Northeast Inst Geog \& Agroecol, Changchun 130102, Peoples R China.
   Lyu, Lili; Lin, Nan; Lyu, Dongmei; Yu, Hao, Jilin Jianzhu Univ, Coll Modern Ind, Changchun 130118, Peoples R China.
   Lyu, Lili; Liu, Ge; Li, Sijia; Fang, Chong; Tao, Hui; Song, Kaishan, Chinese Acad Sci, Northeast Inst Geog \& Agroecol, Changchun 130102, Peoples R China.
   Jacinthe, Pierre-Andre, Purdue Univ Indianapolis, Indiana Univ, Dept Earth Sci, Indianapolis, IN USA.
