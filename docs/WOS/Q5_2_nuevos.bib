Times-Cited = {0},
Unique-ID = {WOS:001715288800001},
}

@article{ WOS:001711098900008,
Author = {Yin, Zhiqiang and Liu, Mingxue and Chen, Mengyao and Wang, Jiao and Guo,
   Dianfan and Zang, Shuying},
Title = {A Season-Adaptive Machine Learning Framework for Estimating Ground
   Surface Temperature in Northeast China},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {8193-8207},
Abstract = {Ground surface temperature (GST) is a pivotal parameter in land surface
   energy and water balance, rendering it a critical input for
   hydrological, climatic, and ecological models. However, acquiring GST
   data with high spatio-temporal continuity and accuracy over large scales
   remains challenging due to the limitations of both in-situ measurements
   and remote sensing technologies. To overcome this limitation, this
   article develops robust machine learning models to simulate GST dynamics
   during the growing seasons (April-September) and snowing (October-March)
   seasons in Northeast China. We examined the spatio-temporal evolution of
   the simulated GST and identified its main influencing factors. Our
   results reveal significant seasonal variations in model performance,
   with substantially higher accuracy achieved during the growing season.
   The multiple linear regression model exhibited the poorest performance
   in both seasons. By comparison, the support vector regression model
   performed best for the growing season, whereas the random forest (RF)
   model achieved the highest precision for the snowing season. Spatially,
   the simulated GST exhibits a distinct latitudinal gradient, decreasing
   from south to north. A significant warming trend was temporally observed
   over the study period. Factor analysis revealed that air temperature
   (TEM) and snow cover are the primary factors driving variations in GST.
   Furthermore, the interactive effects among all factors were stronger
   than their individual contributions, with the interaction between TEM
   and precipitation being the most significant. This article proposes a
   novel GST prediction framework that explicitly accounts for snow cover
   in Northeast China, offering a novel approach for simulating GST under
   complex cryospheric conditions.},
Type = {Article},
Affiliation = {Guo, DF; Zang, SY (Corresponding Author), Harbin Normal Univ, Spatial Informat Serv Cold Reg, Heilongjiang Prov Key Lab Geog Environm Monitoring, Harbin 150025, Peoples R China.
