   Liu, Xiuyu, Beijing Normal Univ, State Key Lab Remote Sensing Sci, Beijing 100875, Peoples R China.},
DOI = {10.1016/j.agrcom.2026.100121},
EarlyAccessDate = {JAN 2026},
Article-Number = {100121},
Keywords = {Settlements; SAM; Random forest; Spatial analysis; GEE; Rural
