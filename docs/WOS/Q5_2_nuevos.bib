   Valencia Ortiz, Joaquin Andres, Univ Salamanca, Fac Sci, Dept Geol, Plaza Caidos S-N, Salamanca 37008, Spain.},
DOI = {10.3390/geomatics6010016},
Article-Number = {16},
Keywords = {fairy circles; Landsat 8; automatic classification; convolutional neural
