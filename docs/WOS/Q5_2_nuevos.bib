DOI = {10.1007/s11442-026-2469-x},
Keywords = {machine learning; intermittent rivers and ephemeral streams; remote
   sensing framework; algorithm selection},
Keywords-Plus = {NATURAL FLOW REGIMES; WATER INDEX NDWI; CLIMATE-CHANGE; CLASSIFICATION;
   CHALLENGES; PREDICTION; STREAMFLOW; FRAMEWORK; SELECTION; QUANTIFY},
Author-Email = {xiechaoshuai20@mails.ucas.ac.cn
   lvaf@igsnrr.ac.cn},
