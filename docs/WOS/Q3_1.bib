@article{ WOS:001577579000001,
Author = {Cheng, Shixuan and Zhang, Kai and Li, Yihao and Chen, Zhangxin},
Title = {Real-time prediction and inverse design of multiphase CO2
   trapping in deep saline aquifers using machine learning enhanced by SHAP
   analysis},
Journal = {GAS SCIENCE AND ENGINEERING},
Year = {2026},
Volume = {145},
Month = {JAN},
Abstract = {Accurate forecasting of multiphase CO2 behavior is critical for safe
   large-scale deployment of carbon capture and storage projects. A total
   of 9835 high fidelity CMG GEM simulations, covering geological and
   operational uncertainties in deep saline aquifers, were generated and
   subsequently used to benchmark thirteen c algorithms for the concurrent
   prediction of CO2 trapping mechanisms. Attention based tabular networks
   TabTransformerLite and SAINTLite together with the decision ensemble
   NODELite outperformed linear, support vector, tree ensemble, and fully
   connected neural network baselines. TabTransformerLite secured the best
   performance with nRMSE of 0.033, R2 of 0.92, and minimal fold to fold
   variability. Shapley value analysis placed depth and permeability as
   primary controls on dissolved, residual, and mineral precipitated CO2
   compared to the injection rate and porosity. An inverse design workflow
   used the trained model to identify operating windows that lift mineral
   trapping above the ninetieth percentile, indicating optimal depth near
   2.25 km, permeability above 1.6 Darcy, and injection rates between 7.5
   and 14.7 x 103 m3/day. The resulting framework connects model
   predictions to geographic information systems for site screening and to
   real time digital twin optimization, providing a scalable millisecond
   speed alternative to physics-based simulation for CO2 storage planning
   and monitoring.},
Type = {Article},
Affiliation = {Chen, ZX (Corresponding Author), Eastern Inst Technol, Ningbo Inst Digital Twin, Ningbo, Peoples R China.
   Cheng, Shixuan; Chen, Zhangxin, Univ Calgary, Dept Chem \& Petr Engn, Calgary, AB T2N 1N4, Canada.
   Zhang, Kai, China Univ Geosci, Hubei Key Lab Oil \& Gas Explorat \& Dev Theory \& Te, Wuhan 430074, Peoples R China.
   Zhang, Kai, China Univ Geosci, Key Lab Tecton \& Petr Resources, Minist Educ, Wuhan 430074, Peoples R China.
   Zhang, Kai, China Univ Geosci Wuhan, Sch Earth Resources, Wuhan, Peoples R China.
   Li, Yihao, Columbia Univ, Fu Fdn Sch Engn \& Appl Sci, Data Sci Inst, New York, NY 10027 USA.
   Chen, Zhangxin, Eastern Inst Technol, Ningbo Inst Digital Twin, Ningbo, Peoples R China.},
DOI = {10.1016/j.jgsce.2025.205782},
EarlyAccessDate = {SEP 2025},
Article-Number = {205782},
Keywords = {Carbon capture and storage (CCS); Deep saline aquifers;
   TabTransformerLite; SHAP analysis; Inverse design; Multiphase CO2
   trapping},
Keywords-Plus = {CARBON-DIOXIDE; STORAGE; SELECTION; CAPTURE},
