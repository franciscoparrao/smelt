   Shao, Yiqin, Zhejiang Sci Tech Univ, Coll Text Sci \& Engn Int Inst Silk, Hangzhou 310018, Peoples R China.},
DOI = {10.1016/j.engappai.2026.114305},
Article-Number = {114305},
Keywords = {Consteel electric arc furnace; Deep stacking network; Tabular data;
   Interpretable prediction; Feature selection},
Keywords-Plus = {MODEL},
