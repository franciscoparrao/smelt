@incollection{ WOS:001447231000024,
Author = {Pensa, Ruggero G. and Crombach, Anton and Peignier, Sergio and Rigotti,
   Christophe},
Editor = {Pedreschi, D and Monreale, A and Guidotti, R and Pellungrini, R and Naretto, F},
Title = {Combining SHAP-Driven Co-clustering and Shallow Decision Trees to
   Explain XGBoost},
Booktitle = {DISCOVERY SCIENCE, DS 2024, PT I},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15243},
Pages = {369-384},
Abstract = {Transparency is a non-functional requirement of machine learning that
   promotes interpretable or easily explainable outcomes. Unfortunately,
   interpretable classification models, such as linear, rule-based, and
   decision tree models, are superseded by more accurate but complex
   learning paradigms, such as deep neural networks and ensemble methods.
   For tabular data classification, more specifically, models based on
   gradient-boosted tree ensembles, such as XGBoost, are still competitive
   compared to deep learning ones, so they are often preferred to the
   latter. However, they share the same interpretability issues, due to the
   complexity of the learnt model and, consequently, of the predictions.
   While the problem of computing local explanations is largely addressed,
   the problem of extracting global explanations is scarcely investigated.
   Existing solutions consist of computing some feature importance score,
   or extracting approximate surrogate trees from the learnt forest, or
   even using a black-box explainability method. However, those methods
   either have poor fidelity or their comprehensibility is questionable. In
   this paper, we propose to fill this gap by leveraging the strong
   theoretical basis of the SHAP framework in the context of co-clustering
   and feature selection. As a result, we are able to extract shallow
   decision trees that explain XGBoost with competitive fidelity and higher
   comprehensibility compared to two recent state-of-the-art competitors.},
Type = {Proceedings Paper},
Affiliation = {Pensa, RG (Corresponding Author), Univ Turin, Turin, Italy.
   Pensa, Ruggero G., Univ Turin, Turin, Italy.
   Crombach, Anton; Rigotti, Christophe, Inria Ctr Lyon, Villeurbanne, France.
   Crombach, Anton; Rigotti, Christophe, Univ Claude Bernard Lyon 1, INSA Lyon, CNRS, LIRIS,UMR5205, F-69621 Villeurbanne, France.
   Peignier, Sergio, INSA Lyon, INRAE, BF2I, UMR0203, F-69621 Villeurbanne, France.},
DOI = {10.1007/978-3-031-78977-9\_24},
Keywords = {Explainable AI; SHAP values; Co-clustering},
Author-Email = {ruggero.pensa@unito.it
   anton.crombach@inria.fr
   sergio.peignier@insa-lyon.fr
   christophe.rigotti@insa-lyon.fr},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001447231000024},
}

@article{ WOS:001648557300015,
Author = {Ramesh, Jayroop and Sabu Thomas, Stalin and Khamis, Amar Hassan and
   Sagahyroon, Assim and Aloul, Fadi and Rushood, Adel},
Title = {Interpretable Machine Learning Models for Vitamin A Deficiency Screening
   in School-Aged Children},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {212999-213015},
Abstract = {Vitamin A deficiency (VAD) is one of the leading causes of visual
   impairment globally. While blood tests are common approaches in
   developed countries, socioeconomic and public perspectives render this a
   challenge in developing countries. In Africa and Southeast Asia, the
   alarming rise of preventable childhood blindness and delayed growth
   rates has been classified as an ``epidemic{''}. With the proliferation
   of machine learning in clinical support systems and the relative
   availability of electronic health records, there is a potential promise
   of early detection to curb ocular complication progression. In this
   work, the aim is to observe the feasibility of detecting Vitamin A
   deficiency in children by utilizing existing records using machine
   learning techniques instead of requiring retinol serum tests. For this
   purpose, a heterogeneous tabular dataset consisting of 18,423 unique
   patient records across 25 features belonging to the non-invasive ocular
   symptomatology and ophthalmological diagnoses was acquired from a
   children's hospital in Maradi, Nigeria. Extensive empirical comparisons
   between traditional machine learning and deep learning methods are
   provided with their corresponding interpretability through attributions
   and shapley values. The achieved results indicate that in the case of
   sparse datasets, after rectification for class imbalances using
   SMOTE-NC, Random Forest, Light Gradient Boosting Model achieved the
   highest balanced scores of accuracy: 86.0\%, sensitivity: 81.8\%,
   specificity: 86.4\% and F1-score: 72.7\% respectively. To the best of
   the authors' knowledge, this is one of the first studies exploring the
   utility of routine eye examination records to screen for Vitamin A
   deficient individuals in a school-aged population. We conclude that
   machine learning can aid in identifying possible candidates for
   prioritized testing, dietary supplementation and treatment.},
Type = {Article},
Affiliation = {Ramesh, J (Corresponding Author), Amer Univ Sharjah, Dept Comp Sci \& Engn, Sharjah, U Arab Emirates.
   Ramesh, Jayroop; Sabu Thomas, Stalin; Sagahyroon, Assim; Aloul, Fadi, Amer Univ Sharjah, Dept Comp Sci \& Engn, Sharjah, U Arab Emirates.
   Khamis, Amar Hassan, Mohammed Bin Rashid Univ Med \& Hlth Sci, Hamdan Bin Mohammed Coll Dent Med, Dubai, U Arab Emirates.
   Rushood, Adel, Al Basar Int Fdn, Kahhal Med Ctr, Dammam 32421, Saudi Arabia.},
DOI = {10.1109/ACCESS.2025.3644236},
Keywords = {Machine learning; Pediatrics; Visualization; Electronic medical records;
   Developing countries; Accuracy; Random forests; Ophthalmology;
   Correlation; Blood; Electronic health records; ophthalmology; machine
   learning; vitamin a deficiency; deep learning},
Keywords-Plus = {VISUAL-ACUITY; PREVALENCE; SUPPLEMENTATION; CATARACT; RISK},
Author-Email = {b00057412@aus.edu},
Number-of-Cited-References = {69},
Times-Cited = {0},
Unique-ID = {WOS:001648557300015},
}

@incollection{ WOS:001705119700002,
Author = {Rathod, Sharmila and Panchal, Aryan and Ramle, Krish and Padvi, Ashlesha
   and Panchal, Jash},
Editor = {Yang, XS and Sherratt, S and Dey, N and Joshi, A},
Title = {Survey on Non-Invasive Glucose Monitoring and Glycemia Detection Using
   Machine Learning and Signal Analysis Techniques},
Booktitle = {PROCEEDINGS OF TENTH INTERNATIONAL CONGRESS ON INFORMATION AND
   COMMUNICATION TECHNOLOGY, ICICT 2025, VOL 6},
Series = {Lecture Notes in Networks and Systems},
Year = {2025},
Volume = {1412},
Pages = {9-17},
Abstract = {Diabetes or Hyperglycemia, a condition where an individual is
   characterized by significantly elevated blood sugar levels, may pose a
   significant threat to the effective lifespan as well as may pose a
   significant risk for various cardiovascular diseases. Reliable and
   non-invasive monitoring of hyperglycemia and also hypoglycemia is
   important for timely intervention and prognosis. The paper presents an
   extensive and structured survey dealing with the non-invasive glucose
   monitoring and diabetes detection using machine learning and signal
   analysis techniques. The paper focuses on a comparative analysis
   approach which showcases the literature in tabular and diagrammatic
   form. Examination of 10 papers that deal with Photoplethysmography (PPG)
   and Electrocardiography (ECG) signals to detect glucose variations using
   machine learning techniques has been carried out. The review highlights
   the respective proposed system, unique findings, improvements,
   techniques, methods, future prospects, comparison with previous studies,
   feature importance, and model evaluation as well as stated accuracy.
   This comprehensive analysis aims to provide insights into the
   methodologies in non-invasive glycemic conditions thereby contributing
   to the development of improved disease analysis.},
Type = {Proceedings Paper},
Affiliation = {Panchal, A (Corresponding Author), Rajiv Gandhi Inst Technol, Dept Comp Engn, Mumbai, Maharashtra, India.
   Rathod, Sharmila; Panchal, Aryan; Ramle, Krish; Padvi, Ashlesha; Panchal, Jash, Rajiv Gandhi Inst Technol, Dept Comp Engn, Mumbai, Maharashtra, India.},
DOI = {10.1007/978-981-96-6429-0\_2},
Keywords = {Hyperglycemia; Electrocardiography; Machine learning},
Author-Email = {sharmila.rathod@mctrgit.ac.in
   aryan.panchal1204@gmail.com},
Number-of-Cited-References = {9},
Times-Cited = {0},
Unique-ID = {WOS:001705119700002},
}

@article{ WOS:001537533000002,
Author = {Tomes, Andrew and Gholami, Shahrzad and Alia, Didier and Hennessy, Conor
   and Xu, Dafeng and Bitz, Cecilia and Dodhia, Rahul and Ferres, Juan
   Lavista and Anderson, C. Leigh},
Title = {Assessing the utility of machine learning for predicting food
   sufficiency: a case study in Malawi},
Journal = {DATA \& POLICY},
Year = {2025},
Volume = {7},
Abstract = {This study explores the potential of applying machine learning (ML)
   methods to identify and predict areas at risk of food insufficiency
   using a parsimonious set of publicly available data sources. We combine
   household survey data that captures monthly reported food insufficiency
   with remotely sensed measures of factors influencing crop production and
   maize price observations at the census enumeration area (EA) in Malawi.
   We consider three machine-learning models of different levels of
   complexity suitable for tabular data (TabNet, random forests, and LASSO)
   and classical logistic regression and examine their performance against
   the historical occurrence of food insufficiency. We find that the models
   achieve similar accuracy levels with differential performance in terms
   of precision and recall. The Shapley additive explanation decomposition
   applied to the models reveals that price information is the leading
   contributor to model fits. A possible explanation for the accuracy of
   simple predictors is the high spatiotemporal path dependency in our
   dataset, as the same areas of the country are repeatedly affected by
   food crises. Recurrent events suggest that immediate and longer-term
   responses to food crises, rather than predicting them, may be the bigger
   challenge, particularly in low-resource settings. Nonetheless, ML
   methods could be useful in filling important data gaps in food crises
   prediction, if followed by measures to strengthen food systems affected
   by climate change. Hence, we discuss the tradeoffs in training these
   models and their use by policymakers and practitioners.},
Type = {Article},
Affiliation = {Tomes, A (Corresponding Author), Univ Washington, Evans Sch Publ Policy \& Governance, Seattle, WA 98195 USA.
   Tomes, Andrew; Alia, Didier; Hennessy, Conor; Xu, Dafeng; Anderson, C. Leigh, Univ Washington, Evans Sch Publ Policy \& Governance, Seattle, WA 98195 USA.
   Gholami, Shahrzad; Dodhia, Rahul; Ferres, Juan Lavista, Microsoft AI Good Lab, Seattle, WA USA.
   Bitz, Cecilia, Univ Washington, Atmospher Sci Dept, Seattle, WA USA.},
DOI = {10.1017/dap.2025.10013},
Article-Number = {e52},
Keywords = {crop prices; food insufficiency; machine learning; Malawi; remote
   sensing},
Keywords-Plus = {INSECURITY; HOUSEHOLD; SECURITY; CRISIS},
Author-Email = {altomes@uw.edu},
Number-of-Cited-References = {50},
Times-Cited = {0},
Unique-ID = {WOS:001537533000002},
}

@incollection{ WOS:001562603200210,
Author = {Vidhya, K. and Surya, S. K. and Geetha, S. K. and Thiyagu, T. M. and
   Catherine, Joy R. and Archpaul, Jenefa},
Book-Group-Author = {IEEE},
Title = {TabNet Fusion Framework for Explainable Multi-Omics Alzheimer's Disease
   Classification},
Booktitle = {2025 3RD INTERNATIONAL CONFERENCE ON INVENTIVE COMPUTING AND
   INFORMATICS, ICICI},
Year = {2025},
Pages = {1364-1369},
Abstract = {Alzheimer's Disease (AD) predominantly impacts cognitive functions such
   as memory and reasoning, especially in the aging population. Early
   detection is crucial for timely intervention and improved patient
   outcomes. Traditional diagnostic techniques often rely on neuroimaging
   and cerebrospinal fluid (CSF) analysis, which are invasive, expensive,
   and not feasible for large-scale screening. Moreover, certain approaches
   lack interpretability and may not be applicable in resource- constrained
   healthcare environments. While machine learning algorithms have been
   employed for AD classification, they often depend on manual feature
   selection and struggle to handle high- dimensional omics datasets
   effectively. To address these limitations, this study introduces a
   hybrid framework that integrates SHAP and LIME explainability methods
   with advanced deep tabular learning architectures such as TabNet,
   FT-Transformer, and DeepMPL. The classification task leverages a dataset
   of 600 samples incorporating 140 lipidomic features and four CSF
   biomarkers Amyloid-beta, Tau, p-Tau, and Neurogranin sourced from ADNI
   and institutional studies. Missing data were handled using CSF
   Amyloid-based thresholds, and the features were scaled using the
   RobustScaler technique. Experimental analy- sis reveals that the
   FT-Transformer model achieved the best performance, attaining a
   classification accuracy of 94\% and an AUC of 0.98, surpassing
   conventional methods such as Random Forest and XGBoost. The proposed
   model not only captures intricate patterns among biomarkers but also
   offers interpretable outputs, making it a promising tool for early,
   non-invasive AD detection. Future directions include integrating
   multi-omics data and validating the approach in clinical settings.},
Type = {Proceedings Paper},
Affiliation = {Archpaul, J (Corresponding Author), Karunya Inst Tech \& Sci, Sch CST, Coimbatore, Tamil Nadu, India.
   Vidhya, K.; Surya, S. K.; Archpaul, Jenefa, Karunya Inst Tech \& Sci, Sch CST, Coimbatore, Tamil Nadu, India.
   Geetha, S. K., KPR Inst Engn \& Technol, Dept CSE, Coimbatore, Tamil Nadu, India.
   Thiyagu, T. M., Vel Tech Rangarajan Dr Sagunthala RD Inst Sci \& T, Dept CSE, Coimbatore, Tamil Nadu, India.
   Catherine, Joy R., Karunya Inst Tech \& Sci, Div ECE, Coimbatore, Tamil Nadu, India.},
DOI = {10.1109/ICICI65870.2025.11069639},
Keywords = {Alzheimer's Disease; TabNet; FT-Transformer; Lipidomics; CSF Biomarkers;
   Explainable AI; SHAP; LIME; Multi-omics Fusion},
Author-Email = {vidhyak@karunya.edu
   sksurya@karunya.edu.in
   geetha.sk@kpriet.ac.in
   t.m.thiyagu@gmail.com
   catherinejoy@karunya.edu
   jenefaa@karunya.edu},
Number-of-Cited-References = {20},
