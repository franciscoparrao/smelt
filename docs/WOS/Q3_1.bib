   Wang, Chao, Minist Nat Resources Peoples Republ China, Key Lab Geohazard Forecast \& Geoecol Restorat Plat, Kunming 650093, Peoples R China.
   Wang, Chao, Yunnan Key Lab Geohazard Forecast \& Geol Restorat, Kunming 650093, Peoples R China.},
DOI = {10.1038/s41598-025-32687-3},
Article-Number = {3080},
Keywords = {Rock shear strength parameters; Stacking ensemble algorithm;
   Chaos-improved sparrow search algorithm; SHAP interpretability analysis;
   Intelligent prediction},
Author-Email = {wangchao@kust.edu.cn},
Number-of-Cited-References = {51},
