   Ma, Enlin, Xihua Univ, Sch Architecture \& Civil Engn, Chengdu 610039, Sichuan, Peoples R China.},
DOI = {10.1016/j.compstruc.2024.107276},
EarlyAccessDate = {JAN 2024},
Article-Number = {107276},
Keywords = {Tunnel deformation prediction; Temporal factors; Static factors; Hybrid
   model; Bi-LSTM; Light GBM},
Keywords-Plus = {BACK ANALYSIS; CONVERGENCE; CLOSURE; BEHAVIOR},
Author-Email = {maenlin@chd.edu.cn
   laijinxing@chd.edu.cn},
Number-of-Cited-References = {64},
Times-Cited = {33},
Unique-ID = {WOS:001156167800001},
}

@article{ WOS:000890677400006,
Author = {Dandolo, David and Masiero, Chiara and Carletti, Mattia and Pezze,
   Davide Dalle and Susto, Gian Antonio},
Title = {AcME-Accelerated model-agnostic explanations: Fast whitening of the
   machine-learning black box},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2023},
Volume = {214},
Month = {MAR 15},
Abstract = {In the context of human-in-the-loop Machine Learning applications, like
   Decision Support Systems, inter-pretability approaches should provide
   actionable insights without making the users wait. In this paper, we
   propose Accelerated Model-agnostic Explanations (AcME), an
   interpretability approach that quickly provides feature importance
   scores both at the global and the local level. AcME can be applied a
   posteriori to each regression or classification model based on tabular
   data. Not only AcME computes feature ranking, but it also provides a
   what-if analysis tool to assess how changes in features values would
   affect model predictions. We evaluated the proposed approach on
   synthetic and real-world datasets, also in comparison with SHapley
   Additive exPlanations (SHAP), the approach we drew inspiration from,
   which is currently one of the state-of-the-art model-agnostic
   interpretability approaches. We achieved comparable results in terms of
   quality of produced explanations while reducing dramatically the
   computational time and providing consistent visualization for global and
   local interpretations. To foster research in this field, and for the
   sake of reproducibility, we also provide a repository with the code used
   for the experiments.},
Type = {Article},
Affiliation = {Susto, GA (Corresponding Author), Univ Padua, Padua, Italy.
   Dandolo, David; Masiero, Chiara, Statwolf Data Sci, Padua, Italy.
   Carletti, Mattia; Pezze, Davide Dalle; Susto, Gian Antonio, Univ Padua, Padua, Italy.},
DOI = {10.1016/j.eswa.2022.119115},
EarlyAccessDate = {NOV 2022},
Article-Number = {119115},
Keywords = {Machine learning; Machine learning interpretability; Explainable
   artificial intelligence; Decision Support Systems},
Keywords-Plus = {EXPLAINABLE ARTIFICIAL-INTELLIGENCE},
Author-Email = {david.dandolo@statwolf.com
   chiara.masiero@statwolf.com
   mattia.carletti@unipd.it
   davide.dallepezze@phd.unipd.it
   gianantonio.susto@unipd.it},
Number-of-Cited-References = {37},
