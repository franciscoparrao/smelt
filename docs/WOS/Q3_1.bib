DOI = {10.3389/fimmu.2026.1774359},
Article-Number = {1774359},
Keywords = {feature selection; machine learning; multidimensional; recurrent
   spontaneous abortion; screening model; TabPFN},
Keywords-Plus = {PREGNANCY LOSS; LIVE BIRTH; MISCARRIAGE; ANTIBODIES},
Author-Email = {xingmingzh@126.com},
Number-of-Cited-References = {33},
