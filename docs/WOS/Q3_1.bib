DOI = {10.3390/app151910779},
Article-Number = {10779},
Keywords = {Marshall stability; flow prediction; machine learning; SHAP},
Keywords-Plus = {MARSHALL STABILITY; MIX; WASTE; FLOW; CONCRETE; STEEL; CREEP},
Author-Email = {kemalerten@isparta.edu.tr
