Unique-ID = {WOS:001307490900001},
}

@article{ WOS:001205306900001,
Author = {Meiseles, Amiel and Rokach, Lior},
Title = {Iterative Feature eXclusion (IFX): Mitigating feature starvation in
   gradientboosted decision trees},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2024},
Volume = {289},
Month = {APR 8},
Abstract = {Gradient boosting models like XGBoost are among the most popular models
   for tabular classification problems.Unfortunately, the greediness of
   gradient boosting algorithms can cause them to rely too heavily on
   somefeatures, thereby starving the other features. We propose Iterative
   Feature eXclusion (IFX) to alleviate thisproblem by iteratively removing
   the most influential feature from the training data and continuing
   training.By forcing the model to learn from weaker features, we increase
   the diversity of the gradient boosting modeland improve the predictive
   performance. Our experiments show that in most cases, IFX improves
   XGBoostpredictive performance, sometimes by a large margin. All of the
   code and results from our experiments arefreely available online.
   Iterative Feature eXclusion can be used as a drag-and-drop replacement
   for XGBoost,thereby easing the adoption of our work by machine learning
   researchers and practitioners},
Type = {Article},
Affiliation = {Meiseles, A (Corresponding Author), Ben Gurion Univ Negev, Dept Software \& Informat Syst Engn, POB 653, IL-8410501 Beer Sheva, Israel.
   Meiseles, Amiel; Rokach, Lior, Ben Gurion Univ Negev, Dept Software \& Informat Syst Engn, POB 653, IL-8410501 Beer Sheva, Israel.},
DOI = {10.1016/j.knosys.2024.111546},
EarlyAccessDate = {FEB 2024},
Article-Number = {111546},
Keywords = {Feature selection; Gradient boosting machine; Decision trees; Shapley
   values; Tabular classification},
Keywords-Plus = {FEATURE-SELECTION; CLASSIFIERS; FOREST},
Author-Email = {amielm@post.bgu.ac.il},
