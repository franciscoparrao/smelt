   Murugappan, M., Kuwait Coll Sci \& Technol, Dept Elect \& Commun Engn, Intelligent Signal Proc ISP Res Lab, Block 4, Doha 13133, Kuwait.
   Murugappan, M., Vels Inst Sci Technol \& Adv Studies, Dept Elect \& Commun Engn, Chennai, Tamil Nadu, India.},
DOI = {10.1007/s13755-025-00361-7},
