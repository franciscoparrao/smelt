@incollection{ WOS:001669335800014,
Author = {Baer, Gregor and Grau, Isel and Zhang, Chao and Van Gorp, Pieter},
Editor = {Guidotti, R and Schmid, U and Longo, L},
Title = {Class-Dependent Perturbation Effects in Evaluating Time Series
   Attributions},
Booktitle = {EXPLAINABLE ARTIFICIAL INTELLIGENCE, XAI 2025, PT IV},
Series = {Communications in Computer and Information Science},
Year = {2026},
Volume = {2579},
Pages = {292-314},
Abstract = {As machine learning models become increasingly prevalent in time series
   applications, Explainable Artificial Intelligence (XAI) methods are
   essential for understanding their predictions. Within XAI, feature
   attribution methods aim to identify which input features contribute the
   most to a models prediction, with their evaluation typically relying on
   perturbation-based metrics. Through systematic empirical analysis across
   multiple datasets, model architectures, and perturbation strategies, we
   reveal previously overlooked class-dependent effects in these metrics:
   they show varying effectiveness across classes, achieving strong results
   for some while remaining less sensitive to others. In particular, we
   find that the most effective perturbation strategies often demonstrate
   the most pronounced class differences. Our analysis suggests that these
   effects arise from the learned biases of classifiers, indicating that
   perturbation-based evaluation may reflect specific model behaviors
   rather than intrinsic attribution quality. We propose an evaluation
   framework with a class-aware penalty term to help assess and account for
   these effects in evaluating feature attributions, offering particular
   value for class-imbalanced datasets. Although our analysis focuses on
   time series classification, these class-dependent effects likely extend
   to other structured data domains where perturbation-based evaluation is
   common (Code and results are available at
   https://github.com/gregorbaer/class-perturbation-effects.).},
Type = {Proceedings Paper},
Affiliation = {Baer, G (Corresponding Author), Eindhoven Univ Technol, Informat Syst, Eindhoven, Netherlands.
   Baer, G (Corresponding Author), Eindhoven Univ Technol, Eindhoven Artificial Intelligence Syst Inst, Eindhoven, Netherlands.
   Baer, Gregor; Grau, Isel; Van Gorp, Pieter, Eindhoven Univ Technol, Informat Syst, Eindhoven, Netherlands.
   Baer, Gregor; Grau, Isel; Zhang, Chao; Van Gorp, Pieter, Eindhoven Univ Technol, Eindhoven Artificial Intelligence Syst Inst, Eindhoven, Netherlands.
   Zhang, Chao, Eindhoven Univ Technol, Human Technol Interact, Eindhoven, Netherlands.},
DOI = {10.1007/978-3-032-08330-2\_14},
Keywords = {Feature attribution; Perturbation analysis; XAI evaluation; Time series
   classification},
Author-Email = {g.baer@tue.n1},
Number-of-Cited-References = {24},
Times-Cited = {1},
Unique-ID = {WOS:001669335800014},
}

@article{ WOS:001641202200004,
Author = {Admasu, Muluken Bogale and Admassu, Addisu Mengistu and Biresaw, Tariku
   Habtamu},
Title = {Physics-informed data augmentation for explainable ML-based
   multi-objective optimization in flexural design of CFRP-strengthened
   CFST beams},
Journal = {STRUCTURES},
Year = {2026},
Volume = {83},
Month = {JAN},
Abstract = {The flexural strengthening of concrete-filled steel tube (CFST) members
   using carbon fiber-reinforced polymer (CFRP) is widely adopted to
   enhance structural performance; however, reliably predicting flexural
   strength and systematically optimizing CFRP configurations remain
   challenging. These difficulties arise from the nonlinear interactions
   among geometric, material, and strengthening parameters, which are
   further compounded by the scarcity of comprehensive experimental
   datasets. This study aims to develop a physics-informed, data-driven
   framework capable of producing accurate, interpretable, and
   design-oriented predictions of flexural strength for CFRP-strengthened
   CFST members, while supporting systematic optimization. A
   physics-informed Tabular Variational Autoencoder is employed to generate
   high-fidelity synthetic data constrained by material strength limits,
   geometric proportions, and slenderness criteria. The augmented dataset
   is validated using statistical similarity metrics and nonlinear
   fiber-element moment-curvature simulations, and subsequently used to
   train an ensemble machine learning model. The framework integrates
   multi-objective optimization to balance flexural strength, CFRP usage,
   and constructability, alongside Monte Carlo-based uncertainty
   quantification to assess predictive robustness. The ensemble
   demonstrates excellent predictive accuracy, with the Stacking regressor
   and XGBoost achieving testing R2 values of 0.9863 and 0.9855,
   respectively, while SHAP analysis identifies steel yield strength, tube
   dimensions, and CFRP wrapping area as the most influential parameters.
   Implemented as a user-friendly Streamlit web application, the framework
   provides a physics-consistent, reliable, and transparent tool to support
   optimized and uncertainty-aware flexural design of CFRP-strengthened
   CFST beams.},
Type = {Article},
Affiliation = {Admasu, MB (Corresponding Author), Arba Minch Univ, Arba Minch Inst Technol, Fac Civil Engn, POB 21, Arba Minch, Ethiopia.
   Admasu, Muluken Bogale; Biresaw, Tariku Habtamu, Arba Minch Univ, Arba Minch Inst Technol, Fac Civil Engn, POB 21, Arba Minch, Ethiopia.
