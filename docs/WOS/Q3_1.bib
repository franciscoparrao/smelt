}

@article{ WOS:001674724600021,
Author = {Chung, Heeseung and Kim, Cheong},
Title = {Stock Crash Risk Prediction With Implied Volatility Index: A Comparison
   of Tree-Based and Transformer-Based Models},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {12447-12460},
Abstract = {Stock price crash prediction is important for both risk management and
   investment decisions. We build machine learning models that predict
   whether individual stocks will experience a maximum drawdown over 40\%
   within 60 trading days. The dataset covers 2,812 Korean listed stocks
   from 2015 to 2024. We test nine models: four tree-based ensembles
   (CatBoost, XGBoost, LGBM, Random Forest) and four deep learning models
   (CNN, LSTM, GRU, Transformer), plus logistic regression. In 10-fold
   walk-forward validation, CatBoost shows the best performance (AUC 0.841,
   KS 0.559, PR-AUC 0.320), while deep learning models lag behind. SHAP
   analysis indicates that the implied volatility index (VKOSPI) has the
   strongest predictive power, followed by wavelet features extracted from
   price data. The main findings are: tree-based models outperform deep
   learning on this tabular financial dataset; options market volatility
   helps predict individual stock tail risk; and wavelet transform provides
   a useful way to combine daily price patterns with quarterly financial
   data.},
Type = {Article},
Affiliation = {Kim, C (Corresponding Author), aSSIST Univ, Seoul 03767, South Korea.
   Kim, C (Corresponding Author), Dong A Univ, Busan 49236, South Korea.
   Chung, Heeseung; Kim, Cheong, aSSIST Univ, Seoul 03767, South Korea.
   Kim, Cheong, Dong A Univ, Busan 49236, South Korea.},
DOI = {10.1109/ACCESS.2026.3656717},
