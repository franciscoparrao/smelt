   Gomes, Eduardo; Esteves, Augusto; Pereira, Lucas, ITI LARSyS Interact Technol Inst, P-1900319 Lisbon, Portugal.},
DOI = {10.3390/en18051282},
Article-Number = {1282},
Keywords = {explainable artificial intelligence; feature selection; machine
   learning; photovoltaic seasonality},
Keywords-Plus = {POWER-GENERATION},
Author-Email = {eduardo.c.gomes@tecnico.ulisboa.pt
