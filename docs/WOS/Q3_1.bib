   Jiang, Longteng; Jin, Xin, Beijing Elect Sci \& Technol Inst, Beijing, Peoples R China.},
DOI = {10.1016/j.heares.2025.109353},
EarlyAccessDate = {SEP 2025},
Article-Number = {109353},
Keywords = {Noise-induced hearing loss; Risk factor; Variable type; Machine
   learning; Prediction model},
