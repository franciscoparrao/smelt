   Tiang, Jun-Jiat, Multimedia Univ, Fac Artificial Intelligence \& Engn, Ctr Wireless Technol, CoE Intelligent Network, Cyberjaya, Selangor, Malaysia.},
DOI = {10.3389/fdgth.2025.1727559},
