   Qian, Junyan; Du, Xiaofu; Pan, Ruishi; Ling, Ming; Ding, Hao, Guangxi Normal Univ, Guangxi Key Lab Multisource Informat Min \& Secur, Guilin, Guangxi, Peoples R China.},
DOI = {10.1177/30504554251325141},
EarlyAccessDate = {MAR 2025},
Keywords = {explainable artificial intelligence; machine learning; interpretability;
   model-agnostic interpretation; black-box models},
Author-Email = {dhguet@gmail.com},
Number-of-Cited-References = {32},
Times-Cited = {1},
Unique-ID = {WOS:001451966600001},
}

@article{ WOS:001443289000005,
Author = {Zuehlke, Monty-Maximilian and Kudenko, Daniel},
Title = {TCR: topologically consistent reweighting for XGBoost in regression
   tasks},
Journal = {MACHINE LEARNING},
Year = {2025},
Volume = {114},
Number = {4},
Month = {FEB 24},
Abstract = {Gradient boosted tree ensembles (GBTEs) such as XGBoost continue to
   outperform other machine learning models on tabular data. However, the
   plethora of adjustable hyperparameters can exacerbate optimisation,
   especially in regression tasks with no intuitive performance measures
   such as accuracy and confidence. Automated machine learning frameworks
   alleviate the hyperparameter search for users, but if the optimisation
   procedure ends prematurely due to resource constraints, it is
   questionable whether users receive good models. To tackle this problem,
   we introduce a cost-efficient method to retrofit previously optimised
   XGBoost models by retraining them with a new weight distribution over
   the training instances. We base our approach on topological results,
   which allows us to infer model-agnostic weights for specific regions of
   the data distribution where the targets are more susceptible to input
   perturbations. By linking our theory to the training procedure of
   XGBoost regressors, we then establish a topologically consistent
   reweighting scheme, which is independent of the specific model instance.
   Empirically, we verify that our approach improves prediction
   performance, outperforms other reweighting methods and is much faster
   than a hyperparameter search. To enable users to find the optimal
   weights for their data, we provide guides based on our findings on 20
   datasets. Our code is available at:
   https://github.com/montymaxzuehlke/tcr.},
Type = {Article},
Affiliation = {Zühlke, MM (Corresponding Author), L3S Res Ctr, Appelstr 9a, D-30167 Hannover, Lower Saxony, Germany.
   Zuehlke, Monty-Maximilian; Kudenko, Daniel, L3S Res Ctr, Appelstr 9a, D-30167 Hannover, Lower Saxony, Germany.},
DOI = {10.1007/s10994-024-06704-x},
Article-Number = {108},
Keywords = {Feature importance; Representation learning; Tree-based methods;
   Topology},
Author-Email = {zuehlke@l3s.de
   kudenko@l3s.de},
Number-of-Cited-References = {44},
Times-Cited = {1},
Unique-ID = {WOS:001443289000005},
}

@article{ WOS:001405708700001,
Author = {Liu, Yaosheng and Li, Ang and Liu, Yipeng and Leng, Zhendong and Xie,
   Yongli},
Title = {A theory-data-integrated intelligent framework for prediction of
   blasting-induced rock fragment size},
Journal = {POWDER TECHNOLOGY},
Year = {2025},
Volume = {453},
Month = {MAR 15},
Abstract = {Blasting is the primary method used in mining operations to acquire the
   desired fragment sizes. In this study, an automated machine learning
   (AutoML)-based model driven jointly by theory and data is developed for
   predicting the mean size of rock fragments. First, the Conditional
   Tabular Generative Adversarial Network is guided by practical mining
   blasting experiences, seeking to synthesize data coinciding with
   different geological conditions. Second, the synthesized data is
   validated via statistical methods. A specific objective function is
   formulated to optimize AutoML runtime using the Tunicate Swarm
   Algorithm. Subsequently, AutoML tools are employed to verify the
   validity of the synthesized data. By comparing the regression
   performance of actual data, synthesized data, and their hybrid, the
   results reveal that the overall percentage improvement in prediction
   accuracy when combining synthesized and actual data was 12.3 \% and 48
   \%, respectively. Finally, the importance of input features on fragment
   size behaviors is investigated, with geological parameters identified as
   the most important influencing factors, with importance percentages of
   51.7 \% and 65 \%, respectively. These findings indicate that our work
   can effectively handle limited real-world data and provide more
   effective blasting fragment predictions.},
Type = {Article},
Affiliation = {Li, A (Corresponding Author), Changan Univ, Sch Highway, Xian 710064, Peoples R China.
   Liu, Yaosheng; Li, Ang; Xie, Yongli, Changan Univ, Sch Highway, Xian 710064, Peoples R China.
