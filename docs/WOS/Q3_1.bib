@article{ WOS:001605612900006,
Author = {Asare, Ebenezer Aquisman and Abdul-Wahab, Dickson and Kaufmann, Elsie
   Effah and Wahi, Rafeah and Ngaini, Zainab},
Title = {Interpretable multi-objective machine learning with calibrated
   uncertainty for deployment-oriented prediction of defects and properties
   in polymer FFF},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {258},
Number = {D},
Month = {JAN 30},
Abstract = {Fused filament fabrication (FFF) parts exhibit variability in defects
   (porosity, interlayer weakness, and warpage) and scatter in mechanical
   properties due to interacting process parameters and environment. Many
   predictive tools are black-box and lack calibrated uncertainty, limiting
   deployment. An interpretable, deployment-oriented framework is
   introduced that integrates physics-informed analytical synthesis,
   empirical anchoring, calibrated uncertainty quantification (UQ), and
   multi-objective optimization across four polymer archetypes: polylactic
   acid (PLA), acrylonitrile-butadiene-styrene (ABS), poly(ethylene
   terephthalate)-glycol (PETG), and thermoplastic polyurethane (TPU). A
   hybrid dataset combines synthetic samples (n = 400 per material) with
   literature-validated experimental records (n = 20 per material).
   Ensemble surrogates, gradient boosting, random forests, support-vector
   regression, and shallow neural networks were used to predict tensile
   strength, elastic modulus, and dimensional error; SHapley Additive
   exPlanations (SHAP) provide mechanism-consistent attributions; isotonic
   regression calibrates prediction intervals. Gradient boosting attains
   strong tabular performance (R-2 approximate to 0.98 for strength; R-2
   approximate to 0.99 for dimensional error). Post-hoc calibration lifts
   empirical coverage from similar to 60-70 \% to similar to 85-90 \%,
   enabling accept/reprint gating. The Non-dominated Sorting Genetic
   Algorithm II (NSGA-II) traces Pareto fronts, and a knee-point selector
   returns actionable trade-offs between strength, dimensional accuracy,
   and process time. Key contributions are: (i) a physics-informed
   synthesis regime with explicit failure-mode injection that broadens
   exposure to defect-prone states; (ii) calibrated UQ that converts
   ensemble variance into reliable error bounds; (iii) interpretable
   attributions revealing dominant, material-specific drivers (e.g.,
   printer model, layer height, cooling); and (iv) knee solutions for each
   polymer. Although enclosed FFF platforms can be repeatable, residual
   uncertainty persists (lot variation, geometry-dependent thermal
   histories, cross-printer effects). The workflow is transparent and
   reproducible, and pre-registers criteria for future extension to direct
   energy deposition (DED) and related processes.},
Type = {Article},
Affiliation = {Asare, EA (Corresponding Author), Northeastern Univ, Coll Engn, Dept Mech \& Ind Engn, Boston, MA 02135 USA.
   Asare, EA (Corresponding Author), Ghana Atom Energy Commiss GAEC, Natl Nucl Res Inst NNRI, Organ Res Lab, Nucl Chem \& Environm Res Ctr, Box LG 80, Accra, Ghana.
   Asare, Ebenezer Aquisman, Northeastern Univ, Coll Engn, Dept Mech \& Ind Engn, Boston, MA 02135 USA.
   Asare, Ebenezer Aquisman, Ghana Atom Energy Commiss GAEC, Natl Nucl Res Inst NNRI, Organ Res Lab, Nucl Chem \& Environm Res Ctr, Box LG 80, Accra, Ghana.
   Abdul-Wahab, Dickson, Univ Ghana, Grad Sch Nucl \& Allied Sci, Dept Nucl Sci \& Applicat, Accra, Ghana.
   Kaufmann, Elsie Effah, Univ Ghana, Dept Biomed Engn, Accra, Ghana.
   Wahi, Rafeah; Ngaini, Zainab, Univ Malaysia Sarawak, Fac Resource Sci \& Technol, Dept Chem, Kota Samarahan Sarawak, Malaysia.},
DOI = {10.1016/j.measurement.2025.119350},
EarlyAccessDate = {OCT 2025},
Article-Number = {119350},
Keywords = {Additive manufacturing; Machine learning; Uncertainty quantification;
   Multi-objective optimization; Real-time monitoring},
Keywords-Plus = {ABSOLUTE ERROR MAE; RMSE},
Author-Email = {aquisman1989@gmail.com},
Number-of-Cited-References = {109},
Times-Cited = {1},
Unique-ID = {WOS:001605612900006},
}

@article{ WOS:001600399300012,
Author = {Chen, Bowen and Xiong, Zhuo and Zhao, Yongchun and Zhang, Junying},
Title = {Multi-view machine learning model of ash chemical composition-minerals:
   Improving ash fusibility prediction and interpretability of high-alkali
   coal},
Journal = {FUEL},
Year = {2026},
Volume = {406},
Number = {D},
Month = {FEB 15},
Abstract = {Alkaline metals have always been a significant factor restricting the
   development of high-alkali coal. Three mainstream machine learning (ML)
   models, including extreme gradient boosting (XGBoost), deep neural
   network (DNN), and tabular prior-data fitted network (TabPFN), were used
   to study the ash fusion temperature (AFT). To improve the prediction
   performance, a multi-view coupling prediction model of ash chemical
   composition and minerals is established, namely, multi-view XGBoost
   (M-XGB), multi-view DNN (M-DNN), and multi-view TabPFN (M-TabPFN). The
   multi-view model takes ash chemical composition and potential minerals
   as input features. The mineral view establishes the mineral composition
   in ash based on a Mathematical Programming Language (AMPL) global
   optimization, coupled with multi-view learning and a multi-head
   attention mechanism. The multi-view model considers the effect of ash
   chemical composition on ash fusion temperature (AFT) and fully accounts
   for the complex interactions between ash components and the formation of
   minerals on AFT. M-DNN achieves optimal prediction performance, with R2
   metrics above 0.94, attributed to the flexibility of accepting multiple
   inputs, the support of sharing the underlying feature extraction, the
   combination of branching outputs in any structure, and the ease of
   end-to-end training of various modules. Feature importance analysis and
   interaction effects were performed using SHapley Additive exPlanations
   (SHAP). Na2O, SO3, CaO, nepheline, albite, and anhydrite were the most
   critical factors affecting the AFT. Beyond improving predictive
   accuracy, A novel oxide-mineral-AFT pathway analysis has been
   introduced, which reveals the mechanistic chain from ash chemistry to
   fusion behavior, and enhances model interpretability and practical
   relevance for high-alkali coal utilization.},
Type = {Article},
Affiliation = {Zhang, JY (Corresponding Author), Huazhong Univ Sci \& Technol, Sch Energy \& Power Engn, State Key Lab Coal Combust, Wuhan 430074, Peoples R China.
   Chen, Bowen; Xiong, Zhuo; Zhao, Yongchun; Zhang, Junying, Huazhong Univ Sci \& Technol, Sch Energy \& Power Engn, State Key Lab Coal Combust, Wuhan 430074, Peoples R China.},
DOI = {10.1016/j.fuel.2025.137115},
EarlyAccessDate = {OCT 2025},
Article-Number = {137115},
Keywords = {Machine learning; High alkali coal; Ash fusibility; Multi-view learning;
   Feature analysis},
Keywords-Plus = {FORMATION MECHANISMS; FUSION; TEMPERATURE; BEHAVIOR; BIOMASS; SODIUM},
Author-Email = {jyzhang@hust.edu.cn},
Number-of-Cited-References = {54},
Times-Cited = {1},
Unique-ID = {WOS:001600399300012},
}

@article{ WOS:001590686800006,
Author = {Rajeev, Devi and Remya, S. and Nayyar, Anand},
Title = {TransplantPredictor: A deep learning framework for liver transplant
   matching and survival prediction},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {Liver transplant outcome prediction presents a complex multi-modal data
   fusion engineering challenge involving heterogeneous clinical data,
   temporal dependencies, and interpretability constraints. This paper
   presents TransplantPredictor, a novel ensemble deep learning framework
   that systematically addresses these challenges through innovative
   architectural design and algorithmic optimization. Unlike previous
   single-model approaches in transplant prediction literature, our
   framework systematically integrates multiple complementary deep learning
   architectures with progressive transfer learning to overcome the
   fundamental limitations of single-paradigm methodologies. We propose a
   three-component ensemble architecture integrating LSTM networks for
   temporal sequence modeling, RNN for clinical progression patterns, and
   Gradient Boosting for non-linear tabular relationships. The ensemble
   employs advanced stacking with engineered meta-features and implements
   progressive transfer learning to overcome limited medical data
   constraints. The framework incorporates unified explainability using
   SHAP and LIME with consistency validation, while systematic
   preprocessing handles missing data through MICE and class imbalance via
   SMOTE. Extensive evaluation on 250 liver transplantation cases
   demonstrates superior performance of the proposed framework. The final
   TransplantPredictor with transfer learning achieves AUC-ROC of 0.941,
   F1-score of 87.9\%, and accuracy of 91.2\%, significantly outperforming
   the traditional MELD scoring system (84.9\% accuracy) by 6.3\%.
   Individual component analysis shows the ensemble approach provides
   substantial improvements over single models: LSTM (84.2\%), RNN
   (82.5\%), and Gradient Boosting (85.1\%). The progressive transfer
   learning strategy contributes an additional 5.2\% F1-score improvement
   compared to existing models. Ablation studies confirm the effectiveness
   of each component and the benefits of combining multiple models with
   transfer learning. The framework provides a practical solution for
   medical AI applications requiring accurate and interpretable
   predictions.},
Type = {Article},
Affiliation = {Remya, S (Corresponding Author), Amrita Vishwa Vidyapeetham, Amrita Sch Comp, Dept CSE, Amritapuri, India.
   Rajeev, Devi; Remya, S., Amrita Vishwa Vidyapeetham, Amrita Sch Comp, Dept CSE, Amritapuri, India.
   Nayyar, Anand, Duy Tan Univ, Sch Comp Sci, Da Nang, Vietnam.},
DOI = {10.1016/j.rineng.2025.107351},
EarlyAccessDate = {SEP 2025},
Article-Number = {107351},
Keywords = {Ensemble learning; Multi-modal data fusion; Transfer learning;
   Explainable AI; Medical informatics; Deep learning optimization},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; PATIENT SELECTION; ALGORITHMS},
Author-Email = {devir@am.amrita.edu
   remyas@am.amrita.edu
   anandnayyar@duytan.edu.vn},
Number-of-Cited-References = {55},
