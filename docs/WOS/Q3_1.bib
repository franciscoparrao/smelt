@article{ WOS:001611101100006,
Author = {Chen, Yun and Fu, Qianwang and Zheng, Wenbo},
Title = {Prediction of chloride resistance of seawater sea sand concrete based on
   generative adversarial network and stacking ensemble learning model},
Journal = {CONSTRUCTION AND BUILDING MATERIALS},
Year = {2025},
Volume = {501},
Month = {NOV 28},
Abstract = {Seawater sea sand concrete (SWSSC) serves as an eco-friendly building
   material that significantly decreases dependency on conventional
   freshwater sources and natural sand extraction for construction
   projects. Nonetheless, the naturally high intrinsic chloride ion content
   within SWSSC renders conventional techniques for determining its
   chloride ion diffusion coefficient (D) particularly susceptible to
   inaccuracies. This study proposes a novel framework that integrates a
   conditional tabular generative adversarial networks (CTGAN) with
   stacking ensemble learning models to address data limitations when
   predicting the D of SWSSC. We compiled a dataset comprising 80
   experimental and 320 synthetic instances, complemented by 11 input
   features. The CTGAN algorithm was subsequently employed to generate the
   synthetic data. Following this, five machine learning (ML) methods and
   four stacking ensemble learning models were utilized to predict the D of
   SWSSC. Hyperparameters for these ML models were optimized using ten-fold
   cross-validation and the beluga whale optimization (BWO) algorithm.
   Results show that the synthetic dataset offers credibility enabling the
   development of ML models with higher prediction accuracy in estimating
   the D of SWSSC. Within the collection of ML architectures developed
   through synthetic data training, Ensemble ML-1 exhibited optimal
   forecasting precision, registering validation R2 and RMSE statistics of
   0.8800 and 1.3347 x 10-1 2 m2/s correspondingly for D of SWSSC
   prediction. SHAP feature importance analysis identified water, coarse
   aggregate, fly ash, and W/B as the highest influential parameters
   affecting the D of SWSSC. Integrating stacking ensemble learning, data
   augmentation, and model interpretation, the proposed method can be
   applied to predict other durability performance indicators in low-carbon
   concrete.},
Type = {Article},
Affiliation = {Fu, QW (Corresponding Author), Hainan Univ, Sch Civil Engn \& Architecture, Haikou 570228, Hainan, Peoples R China.
   Chen, Yun; Fu, Qianwang; Zheng, Wenbo, Hainan Univ, Sch Civil Engn \& Architecture, Haikou 570228, Hainan, Peoples R China.
   Chen, Yun, Hainan Univ, Collaborat Innovat Ctr Ecol Civilizat, Haikou 570228, Peoples R China.},
DOI = {10.1016/j.conbuildmat.2025.144328},
EarlyAccessDate = {NOV 2025},
