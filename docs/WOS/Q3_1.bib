Keywords = {Domain knowledge; Machine learning; Low-alloy steel; Performance
   prediction},
Keywords-Plus = {MECHANICAL-PROPERTIES; NEURAL-NETWORK; MICROSTRUCTURE; ELEMENTS; MODEL},
Author-Email = {lshao@ustb.edu.cn},
Number-of-Cited-References = {42},
