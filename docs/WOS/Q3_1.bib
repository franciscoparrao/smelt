@article{ WOS:001706437400001,
Author = {Zhu, Hualiang and Zhang, Xianwei and Wei, Gang and Wang, Qingzhi and
   Liu, Xinyu and Yan, Lei and Wang, Gang},
Title = {A method for better mapping of susceptibility to thaw hazards in
   data-scarce cold regions},
Journal = {REMOTE SENSING OF ENVIRONMENT},
Year = {2026},
Volume = {337},
Month = {MAY 1},
Abstract = {Rapid climate warming is increasing thaw hazards in permafrost regions,
   threatening infrastructure and ecosystems, but accurate assessment of
   the susceptibility to thaw hazards in data-scarce high-altitude zones
   such as the Qinghai-Tibet Plateau remains challenging. Reported here is
   the development of an inventory of 534 thawhazard sites in Qinghai
   Province using an integrated framework of multi-source data (satellite
   remote sensing, unmanned aerial vehicle imagery, field surveys). Four
   machine learning models-random forest, support vector machine,
   multilayer perceptron, and the novel tabular prior-data fitted network
   (TabPFN)-are compared for thaw-hazard susceptibility mapping under
   small-sample constraints, evaluating accuracy, interpretability, and
   uncertainty. TabPFN significantly outperforms the conventional models,
   achieving an accuracy of 0.938, an area under the receiver operating
   characteristic curve of 0.979, and the lowest coefficient of variation,
   indicating robust predictions with limited data. Unlike conventional
   models favoring precipitation and permafrost type, Shapley additive
   explanations analysis shows that TabPFN prioritizes vegetation and
   temperature change rate. The four susceptibility maps consistently align
   predicted high-risk zones with observed thaw hazards, particularly in
   areas near the Qinghai-Tibet Railway. Uncertainty mapping highlights
   sparse-data areas for targeted field validation. This study demonstrates
   TabPFN's value as a robust, interpretable tool for thaw-hazard modeling
   in data-scarce permafrost regions, aiding risk mitigation and land-use
   planning.},
