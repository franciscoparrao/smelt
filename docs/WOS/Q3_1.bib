   Leng, Zhendong, China Gezhouba Grp Explos Co Ltd, Chongqing 401121, Peoples R China.},
DOI = {10.1016/j.powtec.2025.120638},
EarlyAccessDate = {JAN 2025},
Article-Number = {120638},
Keywords = {Blasting fragment; Theory-guided; CTGAN; AutoML; Feature importance},
Keywords-Plus = {NEURAL-NETWORK},
