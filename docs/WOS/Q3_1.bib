   Moulaei, Reza, Univ Tehran Med Sci, Sch Med, Tehran, Iran.
   Sabet, Babak, Shahid Beheshti Univ Med Sci, Fac Med, Dept Surg, Tehran, Iran.
   Mousavi, Seyed Mohammad, Kerman Univ Med Sci, Inst Futures Studies Hlth, Med Informat Res Ctr, Kerman, Iran.
   Afrash, Mohammad Reza, Smart Univ Med Sci, Dept Artificial Intelligence Med Sci Res Ctr, Tehran, Iran.},
DOI = {10.1038/s41598-024-82931-5},
Article-Number = {31392},
Keywords = {deep learning; machine learning; predicting; stroke},
Keywords-Plus = {RANDOM FOREST; TABULAR DATA},
Author-Email = {M.afrash@sbmu.ac.ir},
