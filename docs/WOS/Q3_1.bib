   Wolf, Maximilian, Coburg Univ Appl Sci, Coburg, Germany.},
DOI = {10.1007/978-3-031-63787-2\_12},
Keywords = {Feature Relevance; XAI; SHAP; Diffusion; Perturbation},
Author-Email = {tritscher@informatikuni-wuerzburg.de
