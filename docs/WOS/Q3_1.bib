@article{ WOS:001407092500001,
Author = {Yuan, Cunyu and Zhang, Xia and Tang, Luliang and Xiong, Yan},
Title = {CBEES: A fine-grained commercial built environment perception and
   evaluation based on social media},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2025},
Volume = {119},
Month = {FEB},
Abstract = {The perception and evaluation of commercial Built Environment (BE)
   significantly impact urban vitality and economic benefits. Existing
   evaluation methods, primarily relying on top-down static structured
   data, struggle to comprehensively capture dynamic public perceptions and
   evaluations of commercial BE elements. Social media big data offers a
   novel perspective for evaluating commercial space, providing rich time
   series and semantic information. However, this potential remains
   underutilized in current research. This study proposes a finegrained
   method for Commercial Built Environment perception and Evaluation based
   on Social media (CBEES), integrating Natural Language Processing (NLP)
   techniques with deep learning models to extract detailed semantic
   information from unstructured text, enabling a comprehensive
   quantitative evaluation of commercial BE. Initially, CBEES employs NLP
   techniques to identify BE element feature variables, utilizing a
   Cross-Attention Mechanism to calculate element weights. Then, CBEES
   applies a sentiment classification algorithm based on a fine-tuned BERT
   model to assess public sentiment polarity. Finally, CBEES conducts
   dynamic and static evaluations of commercial BE using time series
   analysis and Random Forest classification models. Experiments using
   social media text data from 12 commercial projects in Wuhan identified
   48 commercial BE elements. The results revealed significant temporal
   differences in BE element evaluations, with notable changes in negative
   sentiment during the initial COVID-19 reopening phase. Static
   evaluations identified Food street (8.4 \%), Crowd (7.9 \%), and
   Stair/Elevator (5.6 \%) as key elements influencing public perception.
   SHapley Additive exPlanations uncovered non-linear relationships between
   certain BE elements and perception evaluations. CBEES provides a novel
   methodological framework for fine-grained monitoring of commercial BE
   and responding to changes in public demands, enhancing the
   sustainability of urban commercial space planning, design, and
   operational management.},
Type = {Article},
Affiliation = {Zhang, X (Corresponding Author), Wuhan Univ, Sch Urban Design, Wuhan, Peoples R China.
   Tang, LL (Corresponding Author), Wuhan Univ, State Key Lab Informat Engn Surveying Mapping \& Re, Wuhan, Peoples R China.
   Yuan, Cunyu; Zhang, Xia; Xiong, Yan, Wuhan Univ, Sch Urban Design, Wuhan, Peoples R China.
   Tang, Luliang, Wuhan Univ, State Key Lab Informat Engn Surveying Mapping \& Re, Wuhan, Peoples R China.},
DOI = {10.1016/j.scs.2024.106120},
EarlyAccessDate = {JAN 2025},
Article-Number = {106120},
Keywords = {Commercial space; Built environment; Public perception evaluation;
   Social media data; Natural language processing},
Keywords-Plus = {SPACE},
Author-Email = {xiazhang@whu.edu.cn
   tll@whu.edu.cn},
Number-of-Cited-References = {69},
