DOI = {10.1007/s10706-025-03325-6},
Article-Number = {358},
Keywords = {Ballast; Machine learning; Crushing strength; Freeze-thaw cycle},
Keywords-Plus = {NEURAL-NETWORKS},
Author-Email = {598005684@qq.com},
Number-of-Cited-References = {31},
Times-Cited = {0},
Unique-ID = {WOS:001559625500007},
}

@article{ WOS:001544702500004,
Author = {Golgoon, Ashkan and Franks, Ryan and Filom, Khashayar and Kannan, Arjun
   Ravi},
Title = {MbExplainer: Multilevel bandit-based explanations for downstream models
   with augmented graph embeddings},
Journal = {MACHINE LEARNING},
Year = {2025},
Volume = {114},
Number = {9},
Month = {AUG 5},
Abstract = {Graph Neural Networks (GNNs) are a highly useful tool for performing
   various machine learning prediction tasks on graph-structured data. In
   many industrial applications, it is common that the graph embeddings
   generated from training GNNs are used in an ensemble model where the
   embeddings are combined with other tabular features, e.g., original node
   or edge features, in a downstream machine learning task. The tabular
   features may even arise naturally if, e.g., one tries to build a graph
   such that some of the node or edge features are stored in a tabular
   format. In this paper we address the problem of explaining the output of
   such ensemble models for which the input features consist of learned
   neural graph embeddings combined with additional tabular features.
   Therefore, we propose MbExplainer, a model-agnostic explanation approach
   for downstream models with augmented graph embeddings. MbExplainer
   returns a human-comprehensible triple as an explanation for an instance
   prediction of the whole pipeline consisting of three components: a
   subgraph with the highest importance, the topmost important node
   features, and the topmost important augmented downstream features. A
   game-theoretic formulation is used to take the contributions of each
   component and their interactions into account by assigning three Shapley
   values corresponding to their own specific games. Finding the
   explanation requires an efficient search through the local search spaces
   corresponding to each component. MbExplainer applies a novel multilevel
   search algorithm that enables simultaneous pruning of local search
   spaces in a computationally tractable way. In particular, three
   interweaved Monte Carlo Tree Searches are utilized to iteratively prune
   the local search spaces. MbExplainer also includes a global search
   algorithm that uses contextual bandits to efficiently allocate pruning
   budget among the local search spaces. We demonstrate the effectiveness
   of MbExplainer by presenting a set of comprehensive numerical examples
   on multiple public graph datasets for node classification, graph
   classification, and graph regression tasks.},
Type = {Article},
Affiliation = {Golgoon, A (Corresponding Author), Discover Financial Serv Inc, Emerging Capabil Res Grp, Riverwoods, IL 60015 USA.
   Golgoon, Ashkan; Franks, Ryan; Filom, Khashayar; Kannan, Arjun Ravi, Discover Financial Serv Inc, Emerging Capabil Res Grp, Riverwoods, IL 60015 USA.},
DOI = {10.1007/s10994-025-06830-0},
Article-Number = {201},
Keywords = {Explainable AI; Graph explainability; ML explainability; GNNs; Shapley
   values},
Keywords-Plus = {PREDICTION; GAME},
Author-Email = {ashkangolgoon@gmail.com
   ryanfranks1996@gmail.com
   khashayar.1367@gmail.com
   arjun.kannan@gmail.com},
Number-of-Cited-References = {86},
Times-Cited = {0},
Unique-ID = {WOS:001544702500004},
}

@article{ WOS:001515236000001,
Author = {Namjoo, Ehsan and O'Connor, Alison N. and Buckley, Jim and Ryan, Conor},
Title = {GlassBoost: A Lightweight and Explainable Classification Framework for
   Tabular Datasets},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2025},
Volume = {15},
Number = {12},
Month = {JUN 19},
Abstract = {Explainable artificial intelligence (XAI) is essential for fostering
   trust, transparency, and accountability in machine learning systems,
   particularly when applied in high-stakes domains. This paper introduces
   a novel XAI system designed for classification tasks on tabular data,
   which offers a balance between performance and interpretability. The
   proposed method, GlassBoost, first trains an XGBoost model on a given
   dataset and then computes gain scores, quantifying the average
   improvement in the model's loss function contributed by each feature
   during tree splits. Based on these scores, a subset of significant
   features is selected. A shallow decision tree is then trained using the
   top d features with the highest gain scores, where d is significantly
   smaller than the total number of original features. This model
   compression yields a transparent, IF-THEN rule-based decision process
   that remains faithful to the original high-performing model. To evaluate
   the system, we apply it to an anomaly detection task in the context of
   intrusion detection systems (IDSs), using a dataset containing traffic
   features from both malicious and normal activities. Results show that
   our method achieves high accuracy, precision, and recall while providing
   a clear and interpretable explanation of its decision-making. We further
   validate its explainability using SHAP, a well-established approach in
   the field of XAI. Comparative analysis demonstrates that GlassBoost
   outperforms SHAP in terms of precision, recall, and accuracy, with more
   balanced performance across the three metrics. Likewise, our review of
   literature findings indicate that Glassboost outperforms many other XAI
   models while retaining computational efficiency. In one of our
   configurations, GlassBoost achieved accuracy of 0.9868, recall of
   0.9792, and precision of 0.9843 using only eight features within a tree
   structure of a maximum depth of four.},
Type = {Article},
Affiliation = {Ryan, C (Corresponding Author), Univ Limerick, Dept Comp Sci \& Informat Syst, Limerick V94T9PX, Ireland.
   Namjoo, Ehsan; O'Connor, Alison N.; Buckley, Jim; Ryan, Conor, Univ Limerick, Dept Comp Sci \& Informat Syst, Limerick V94T9PX, Ireland.},
DOI = {10.3390/app15126931},
Article-Number = {6931},
Keywords = {anomaly detection; cybersecurity; explainability; feature importance
   score; gradient-boosting machine (GBM); model compression},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE},
Author-Email = {ehsan.namjoo@ul.ie
   alison.oconnor@ul.ie
   jim.buckley@lero.ie
   conor.ryan@ul.ie},
Number-of-Cited-References = {38},
Times-Cited = {0},
Unique-ID = {WOS:001515236000001},
}

@article{ WOS:001505919900001,
Author = {Ozkara, Burak Berksu and Bamshad, David and Gowda, Ramita and Karabacak,
   Mert and Bishay, Vivian and Garcia-Reyes, Kirema and Rastinehad,
   Ardeshir R. and Shilo, Dan and Fischman, Aaron},
Title = {Predicting Early Outcomes of Prostatic Artery Embolization Using
   n-Butyl Cyanoacrylate Liquid Embolic Agent: A Machine Learning
   Study},
Journal = {DIAGNOSTICS},
Year = {2025},
Volume = {15},
Number = {11},
Month = {MAY 28},
Abstract = {Background/Objectives: Prostatic artery embolization (PAE) has been
   increasingly recognized, especially with recent progress in embolization
   techniques for the management of lower urinary tract symptoms due to
   benign prostatic hyperplasia. Nevertheless, a proportion of patients
   undergoing PAE fail to demonstrate clinical improvement. Machine
   learning models have the potential to provide valuable prognostic
   insights for patients undergoing PAE. Methods: A retrospective cohort
   study was performed utilizing a modified prior-data fitted network
   architecture to predict short-term (7 weeks) favorable outcomes, defined
   as a reduction greater than 9 points in the International Prostate
   Symptom Score (IPSS), in patients who underwent PAE with nBCA glue.
   Patients were stratified into two groups based on the median IPSS
   reduction value, and a binary classification model was developed to
   predict the outcome of interest. The model was developed using clinical
   tabular data, including both pre-procedural and intra-procedural
   variables. SHapley Additive ExPlanations (SHAP) were used to uncover the
   relative importance of features. Results: The final cohort included 109
   patients. The model achieved an accuracy of 0.676, an MCC of 0.363, a
   precision of 0.666, a recall of 0.856, an F1-score of 0.731, and a Brier
   score of 0.203, with an AUPRC of 0.851 and an AUROC of 0.821. SHAP
   analysis identified pre-PAE IPSS, prior therapy, right embolization
   volume, preoperative quality of life, and age as the top five most
   influential features. Conclusions: Our model showed promising
   discrimination and calibration in predicting early outcomes of PAE with
   nBCA glue, highlighting the potential of precision medicine to deliver
   interpretable, individualized risk assessments.},
Type = {Article},
Affiliation = {Fischman, A (Corresponding Author), Icahn Sch Med Mt Sinai, Dept Diag Mol \& Intervent Radiol, New York, NY 10029 USA.
   Ozkara, Burak Berksu; Bamshad, David; Bishay, Vivian; Garcia-Reyes, Kirema; Shilo, Dan; Fischman, Aaron, Icahn Sch Med Mt Sinai, Dept Diag Mol \& Intervent Radiol, New York, NY 10029 USA.
   Gowda, Ramita, St Georges Univ, Sch Med, True Blue, Grenada.
   Karabacak, Mert, Mt Sinai Hlth Syst, Dept Neurosurg, New York, NY 10029 USA.
   Rastinehad, Ardeshir R., Lenox Hill Hosp, Dept Urol, New York, NY 10075 USA.},
DOI = {10.3390/diagnostics15111351},
Article-Number = {1351},
Keywords = {prostate artery embolization; machine learning; IPSS; artificial
   intelligence},
Author-Email = {aaron.fischman@mountsinai.org},
Number-of-Cited-References = {26},
Times-Cited = {0},
Unique-ID = {WOS:001505919900001},
}

@article{ WOS:001498643100001,
Author = {Wang, Songbo and Ban, Sifan and Duan, Zhuo and Yang, Siyuan and Li, Yang},
Title = {Augmenting nonlinear shear creep evaluation of adhesive joints with
   conditional tabular GAN},
Journal = {INTERNATIONAL JOURNAL OF ADHESION AND ADHESIVES},
Year = {2025},
Volume = {141},
Month = {AUG},
Abstract = {Fibre-reinforced polymers with adhesive bonding have emerged as a
   significant advancement in the strengthening of existing structures.
   However, at warm service temperatures (20-50 degrees C), these adhesive
   joints demonstrate viscoelastic behaviour, leading to nonlinear creep
   that is difficult to evaluate. This study introduces a novel approach
   that leverages Ensemble Machine Learning (EML) models, enhanced by
   Conditional Tabular Generative Adversarial Network (CTGAN), to assess
   the creep response of the joints. The initial dataset, comprising
   results from 25 butt shear creep tests conducted in a thermal chamber,
   facilitated the generation of a synthetic dataset by CTGAN, which was
   then used to train the EML models. Employing the
   ``Train-Synthetic-Test-Real{''} strategy allowed for the comparison of
   the constructed EML models, with the CTGAN-Random Forest (RF) model
   demonstrating superior performance. This model further forms the basis
   of a graphical user interface tool, enabling accurate predictions of the
   shear creep in the joints under different conditions and the production
   of additional synthetic data for future analyses. Moreover, the SHapley
   Additive exPlanations explorations were conducted to demystify the
   CTGAN-RF model, offering insights into the impact of different features
   on the output results.},
Type = {Article},
Affiliation = {Wang, SB; Li, Y (Corresponding Author), Hubei Univ Technol, Sch Civil Engn Architecture \& Condit, Wuhan 430068, Peoples R China.
   Wang, Songbo; Ban, Sifan; Duan, Zhuo; Yang, Siyuan; Li, Yang, Hubei Univ Technol, Sch Civil Engn Architecture \& Condit, Wuhan 430068, Peoples R China.
   Wang, Songbo; Li, Yang, Innovat Demonstrat Base Ecol Condit Geotech \& Ecol, Wuhan 430068, Peoples R China.},
DOI = {10.1016/j.ijadhadh.2025.104066},
EarlyAccessDate = {MAY 2025},
Article-Number = {104066},
Keywords = {Nonlinear shear creep; Adhesive joints; Thermal chamber testing;
   Conditional tabular GAN; Ensemble machine learning},
Keywords-Plus = {BEHAVIOR; CFRP},
Author-Email = {wangsongbo@hbut.edu.cn},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001498643100001},
}

@article{ WOS:001655409400001,
Author = {Tian, Yuping and Wu, Zechuan and Liu, Kai and Li, Mingze},
Title = {Dynamic assessment of ecological quality in China from 2000 to 2024
   based on artificial intelligence},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {666},
Month = {FEB},
Abstract = {The assessment of spatial disparities in ecological quality and the
   factors influencing them plays a vital role in shaping effective
   ecological protection and land-use strategies. However,
   nationwide-scale, unified, and data-driven approaches remain limited,
   particularly in integrating advanced artificial intelligence models into
   impact assessment. This study developed a long-term RSEI dataset using
   Google Earth Engine to evaluate spatiotemporal patterns of ecological
   quality across China's seven geographic regions from 2000 to 2024. We
   employed trend and spatial autocorrelation analyses to assess regional
   evolution and clustering dynamics. This study is the first in the field
   to apply the tabular foundation model TabPFN, integrating it with SHAP
   analysis to assess the impacts of both natural and human-induced
   factors. The results indicated a general improvement in ecological
   quality, accompanied by notable spatial aggregation and distinct
   regional variation. TabPFN outperformed traditional models (Random
   Forest, XGBoost, TabNet), with R2 values ranging from 0.7215 to 0.8969
   and accuracy improvements of 6.3 \%-14.7 \%. Key drivers included net
   primary productivity, vegetation coverage, precipitation, temperature,
   and land cover, with GDP typically exerting negative impacts. The
   findings offer new insights into ecological quality dynamics and
   highlight the effectiveness of TabPFN-SHAP in transparent impact
   assessment. Beyond the China context, the proposed framework is
   adaptable for regional and urban planning worldwide, contributing a
   scalable and innovative methodology to the toolbox of environmental
   impact assessment and management.},
Type = {Article},
Affiliation = {Li, MZ (Corresponding Author), Northeast Forestry Univ, Coll Forestry, Key Lab Sustainable Forest Ecosyst Management, Minist Educ, Harbin 150040, Peoples R China.
   Tian, Yuping; Wu, Zechuan; Li, Mingze, Northeast Forestry Univ, Coll Forestry, Key Lab Sustainable Forest Ecosyst Management, Minist Educ, Harbin 150040, Peoples R China.
   Liu, Kai, Heilongjiang Acad Forestry, Harbin 150081, Peoples R China.},
DOI = {10.1016/j.jhydrol.2025.134849},
EarlyAccessDate = {FEB 2025},
Article-Number = {134849},
Keywords = {Ecological quality; Artificial intelligence; Tabular foundation model;
   Spatiotemporal heterogeneity},
Keywords-Plus = {FOREST},
Author-Email = {mingzelee@nefu.edu.cn},
Number-of-Cited-References = {71},
Times-Cited = {0},
Unique-ID = {WOS:001655409400001},
}

@article{ WOS:001427944500002,
Author = {Mendoza, Antonio and Tume, Sebastian and Puri, Kriti and Acosta,
   Sebastian and Cavallaro, Joseph R.},
Title = {Clinical Features and Physiological Signals Fusion Network for
   Mechanical Circulatory Support Need Prediction in Pediatric Cardiac
   Intensive Care Unit},
Journal = {IEEE JOURNAL OF BIOMEDICAL AND HEALTH INFORMATICS},
Year = {2025},
Volume = {29},
Number = {2},
Pages = {783-791},
Month = {FEB},
Abstract = {We link the hemodynamic response to inotropic agents with outcomes
   related to Mechanical Circulatory Support (MCS) by analyzing
   physiological time series and clinical features using a Machine
   Learning/Deep Learning ensemble approach for multi-modal waveforms in
   the pediatric cardiac intensive care setting of a quaternary-care
   hospital. Unlike existing studies that typically process a single
   feature type or focus on short-term diagnoses from physiological
   signals, our novel system processes minute-by-minute multi-sensor data
   to identify the need for MCS in patients admitted with acute
   decompensated heart failure. The data used includes tabular clinical
   features, time series from hemodynamic monitors, and raw waveforms from
   electrocardiogram and arterial blood pressure signals. Our predictions
   support an early identification of high-risk patients after just two
   days of Intensive Care Unit (ICU) admission, with classification and
   feature importance results confirming the predictive ability of the
   early hemodynamic response to inotropic agent administration, achieving
   an AUC of 0.88 in the prediction classification task. This is
   particularly significant in cases where clinical decisions are not
   straightforward, such as those in the cohort for this study.},
Type = {Article},
Affiliation = {Mendoza, A (Corresponding Author), Rice Univ, Houston, TX 77005 USA.
   Mendoza, Antonio; Cavallaro, Joseph R., Rice Univ, Houston, TX 77005 USA.
   Tume, Sebastian; Puri, Kriti, Baylor Coll Med, Texas Childrens Hosp, Houston, TX 77005 USA.
   Acosta, Sebastian, Baylor Coll Med, Houston, TX 77030 USA.},
DOI = {10.1109/JBHI.2024.3510217},
Keywords = {Blood pressure; convolutional neural networks; deep learning; ensemble
   learning; hemodynamics; heart failure; Time series analysis; intensive
   care unit; convolutional neural networks; deep learning; ensemble
   learning; hemodynamics; heart failure; time series analysis; intensive
   care unit},
Author-Email = {antonio@rice.edu
   cavallar@rice.edu},
