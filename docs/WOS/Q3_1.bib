   Fu, Dongmei; Shao, Lizhen, Univ Sci \& Technol Beijing, Shunde Grad Sch, Foshan 528399, Peoples R China.},
DOI = {10.1016/j.commatsci.2024.113602},
EarlyAccessDate = {DEC 2024},
