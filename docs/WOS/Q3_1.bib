@article{ WOS:001671225900001,
Author = {Wang, Yichuan and Liu, Shuhan and Zhang, Hepeng and Chen, Shuai and Xia,
   Chaoqun and Yang, Tai},
Title = {Breaking small sample data barriers: Machine learning prediction of
   hydrogen storage capacity in Mg-based alloys via data augmentation},
Journal = {ENERGY},
Year = {2026},
Volume = {344},
Month = {FEB 1},
Abstract = {Machine learning significantly accelerates novel materials development
   compared to traditional trial-and-error methods, substantially reducing
   research periods and costs. However, the application of machine learning
   in Mg-based hydrogen storage alloys, regarded as one of the most
   promising materials for hydrogen storage, remains limited. Furthermore,
   the problem of small sample datasets persists in current prediction
   models for Mg-based alloys and even extends to prediction models for
   other hydrogen storage materials, significantly reducing the
   generalization ability of models. Herein, a novel approach was
   introduced: structured data augmentation. Beginning with only 268
   experimental data, four augmentation methods were applied, yielding
   expanded datasets of 2143 and 4286 samples. Machine learning models
   trained on augmented data demonstrated unprecedented accuracy and
   generalization ability. The RF model trained on augmented data-1
   achieved an R-2 value of 0.963 and an average relative error of 1.76 \%
   when predicting unknown materials, significantly outperforming prior
   works and models trained on the original dataset. Furthermore, through
   the SHAP method, Ab\_T, Ni content, Mg content, and Ab\_P were
   identified as the most critical variables, with key thresholds that
   enhance the alloy's capacity revealed (Ni content <18.7 wt\%, Ab\_T >
   195.5 degrees C, Ab\_P > 1.96 MPa, Mg content >48.85 wt\%). This study
   pioneers the strategy of data augmentation to overcome the limitations
   of small sample datasets in machine learning-driven discovery of
   hydrogen storage materials, advancing the application of machine
   learning in hydrogen storage materials, while providing design guidance
   for Mg-based hydrogen storage alloys.},
Type = {Article},
Affiliation = {Yang, T (Corresponding Author), Hebei Univ Technol, Sch Mat Sci \& Engn, Tianjin 300130, Peoples R China.
   Wang, Yichuan; Zhang, Hepeng; Chen, Shuai; Xia, Chaoqun; Yang, Tai, Hebei Univ Technol, Sch Mat Sci \& Engn, Tianjin 300130, Peoples R China.
   Liu, Shuhan, Nankai Univ, Sch Stat \& Data Sci, Tianjin 300072, Peoples R China.
   Xia, Chaoqun; Yang, Tai, Hebei Univ Technol, Tianjin Key Lab Laminating Fabricat \& Interface Co, Tianjin 300130, Peoples R China.},
DOI = {10.1016/j.energy.2026.139914},
EarlyAccessDate = {JAN 2026},
Article-Number = {139914},
