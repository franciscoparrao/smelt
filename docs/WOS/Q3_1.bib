   Bertsimas, Dimitris, MIT, Sloan Sch Management, 77 Massachusetts Ave, Cambridge, MA 02139 USA.},
DOI = {10.1038/s41746-022-00689-4},
Article-Number = {149},
Keywords-Plus = {MORTALITY PREDICTION; FEATURES; MODELS},
