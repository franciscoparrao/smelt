@article{ WOS:001434343800001,
Author = {Tran, Vinh Quang and Byeon, Haewon},
Title = {Explainable hybrid tabular Variational Autoencoder and feature Tokenizer
   Transformer for depression prediction},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2025},
Volume = {265},
Month = {MAR 15},
Abstract = {Recent advancements in machine learning and deep learning have
   significantly improved the diagnosis, detection, prediction, and
   prognosis of depressive disorders. However, these methodologies have
   issues related to generalizability, transparency, data scarcity, privacy
   concerns, and class imbalance. This study develops a robust and
   interpretable model for predicting depression in South Korea, addressing
   these limitations. We employed a hybrid deep learning approach that
   integrates the Feature Tokenizer Transformer model, specifically
   designed for tabular data, to effectively tokenize and process
   categorical and numerical features, alongside synthetic data generated
   by the tabular variational autoencoder (TVAE). TVAE is an adaptation of
   variational autoencoders that uses a specialized loss function for
   tabular data. generated high-quality synthetic data from the Korea
   National Health and Nutrition Examination Survey (KNHANES) dataset. The
   efficacy of the TVAE-generated data was validated using non-parametric
   statistical tests, achieving 86.30\% on the Kolmogorov-Smirnov test and
   76.65\% on the Chi-squared test. Performance evaluation metrics, such as
   accuracy, recall, F1-score, and AUC, demonstrated our model's
   effectiveness, yielding an accuracy 0.7783, a recall score of 0.5310, an
   F1-score of 0.4657, and an AUC of 0.6822, outperforming state-of-the-art
   models. Additionally, SHapley Additive exPlanations analysis was
   incorporated to explain feature importance, offering valuable insights
   for healthcare professionals. This research highlights the potential of
   deep learning and synthetic data generation techniques to enhance
   depression prediction, addressing critical challenges such as
   generalizability, class imbalance, data privacy, and interpretability
   over existing models.},
Type = {Article},
Affiliation = {Byeon, H (Corresponding Author), Inje Univ, Dept Digital Antiaging Healthcare BK21, Gimhae 50834, South Korea.
   Tran, Vinh Quang; Byeon, Haewon, Inje Univ, Dept Digital Antiaging Healthcare BK21, Gimhae 50834, South Korea.},
DOI = {10.1016/j.eswa.2024.126084},
EarlyAccessDate = {DEC 2025},
Article-Number = {126084},
Keywords = {Variational autoencoder; Feature tokenizer; Transformer; Depression;
   Explainable},
Keywords-Plus = {NUTRITION EXAMINATION SURVEY; KOREA NATIONAL-HEALTH},
Author-Email = {trnvinh5799@oasis.inje.ac.kr
   byeon@inje.ac.kr},
Number-of-Cited-References = {63},
Times-Cited = {6},
Unique-ID = {WOS:001434343800001},
}

@article{ WOS:001556054700001,
Author = {La, Hung and Nguyen, Tan},
Title = {Interpretable and optimized TabNet-TPE for predicting bond strength in
   corroded reinforced concrete using a global database},
Journal = {STRUCTURES},
Year = {2025},
Volume = {80},
Month = {OCT},
Abstract = {Accurate prediction of bond strength in corroded reinforced concrete
   structures is crucial for durability assessment and material
   optimization. This study develops an advanced Attentive Interpretable
   Tabular Learning (TabNet) model optimized with the Tree-Structured
   Parzen Estimator to enhance predictive accuracy and interpretability,
   offering a data-driven alternative to empirical formulations. The model
   is benchmarked against Deep Neural Networks (DNN-TPE) and Deep Kernel
   Learning (DKL-TPE) using an extensive experimental dataset, and further
   compared with TPE-optimized boosting algorithms, where TabNet
   consistently outperforms in both accuracy and robustness. Bayesian
   hyperparameter tuning refines decision layer width (n(d)) and attention
   embedding width (n(a)), improving generalization capability. Feature
   importance analysis using SHAP values, Permutation Importance, and
   TabNet's intrinsic selection identifies corrosion level (eta) as the
   most influential predictor. Accumulated Local Effects (ALE) reveal that
   eta > 20 \% leads to an approximately 80 \% reduction in bond strength
   (tau(u)), highlighting severe cross-section loss, cracking-induced
   confinement failure, and stress redistribution. Interestingly, at low
   corrosion levels (eta < 2 \%), ALE exhibits a slight positive effect,
   likely due to surface roughening that enhances mechanical interlock, but
   this benefit dissipates as corrosion progresses beyond eta approximate
   to 5-10 \%. Additionally, 3D Partial Dependence Plots (PDPs) illustrate
   complex nonlinear interactions, revealing threshold effects and
   parameter dependencies in bond strength deterioration. Monte Carlo and
   Individual Conditional Expectation (ICE) analyses validate the model's
   robustness under severe corrosion (eta > 20 \%), with tau u predictions
   consistently ranging from 2-10 MPa (+/- 4 MPa), and reveal
   sample-specific degradation patterns. Attention masking further
   identifies l/d, d, and eta as the most critical predictors. The
   TabNet-TPE model achieves the highest predictive accuracy (R-2 = 0.9606,
   RMSE = 1.5479 MPa, MAE = 1.1653 MPa, and a20-index=0.8182), surpassing
   conventional machine learning models. By integrating explainable AI
   techniques, this study bridges data-driven modeling with engineering
   practice, providing a scalable and interpretable framework for corrosion
   mitigation and infrastructure resilience strategies.},
Type = {Article},
Affiliation = {Nguyen, T (Corresponding Author), Ton Duc Thang Univ, Fac Civil Engn, Smart Comp Civil Engn Res Grp, Ho Chi Minh City, Vietnam.
   La, Hung, Ton Duc Thang Univ, Fac Civil Engn, Ho Chi Minh City, Vietnam.
   Nguyen, Tan, Ton Duc Thang Univ, Fac Civil Engn, Smart Comp Civil Engn Res Grp, Ho Chi Minh City, Vietnam.},
DOI = {10.1016/j.istruc.2025.109707},
EarlyAccessDate = {JUL 2025},
Article-Number = {109707},
Keywords = {Bond strength prediction; TabNet; Tree-structured parzen estimator;
   Feature importance analysis; Interpretable deep learning; Accumulated
   local effects},
Keywords-Plus = {NEURAL-NETWORKS; STEEL BARS; CORROSION; BEHAVIOR; DEGRADATION; REBAR},
Author-Email = {241804402@student.tdtu.edu.vn
   nguyentan@tdtu.edu.vn},
Number-of-Cited-References = {76},
Times-Cited = {6},
Unique-ID = {WOS:001556054700001},
}

@article{ WOS:001544213500001,
Author = {Kim, Jeong-Kyun and Mun, Sujeong and Lee, Siwoo},
Title = {Detection and Analysis of Circadian Biomarkers for Metabolic Syndrome
   Using Wearable Data: Cross-Sectional Study},
Journal = {JMIR MEDICAL INFORMATICS},
Year = {2025},
Volume = {13},
Abstract = {Background: Wearable devices are increasingly used for monitoring health
   and detecting digital biomarkers related to chronic diseases such as
   metabolic syndrome (MetS). Although circadian rhythm disturbances are
   known to contribute to MetS, few studies have explored wearable-derived
   circadian biomarkers for MetS identification. Objective: This study
   aimed to detect and analyze sleep and circadian rhythm biomarkers
   associated with MetS using step count and heart rate data from wearable
   devices and to identify the key biomarkers using explainable artificial
   intelligence (XAI). Methods: Data were analyzed from 272 participants in
   the Korean Medicine Daejeon Citizen Cohort, collected between 2020 and
   2023, including 88 participants with MetS and 184 without any MetS
   diagnostic criteria. Participants wore Fitbit Versa or Inspire 2 devices
   for at least 5 weekdays, providing minute-level heart rate, step count,
   and sleep data. A total of 26 indicators were derived, including sleep
   markers (midsleep time and total sleep time) and circadian rhythm
   markers (midline estimating statistic of rhythm, amplitude, interdaily
   stability, and relative amplitude). In addition, a novel circadian
   rhythm marker, continuous wavelet circadian rhythm energy (CCE), was
   proposed using continuous wavelet transform of heart rate signals.
   Statistical tests (t test and the Wilcoxon rank sum test) and machine
   learning models-Shapley Additive Explanations, explainable boosting
   machine, and tabular neural network-were applied to evaluate marker
   significance and importance. Results: Circadian rhythm markers,
   especially heart rate-based indicators, showed stronger associations
   with MetS than sleep markers. The newly proposed CCE demonstrated the
   highest importance for MetS identification across all XAI models, with
   significantly lower values observed in the MetS group (P<.001). Other
   heart rate-based markers, including relative amplitude and low activity
   period, were also identified as important contributors. Although sleep
   markers did not reach statistical significance, some were recognized as
   secondary predictors in XAI-based analyses. The CCE marker maintained a
   high predictive value even when adjusting for age, sex, and BMI.
   Conclusions: This study identified CCE and relative amplitude of heart
   rate as key circadian rhythm biomarkers for MetS monitoring,
   demonstrating their high importance across multiple XAI models. In
   contrast, traditional sleep markers showed limited significance,
   suggesting that circadian rhythm analysis may offer additional insights
   into MetS beyond sleep-related indicators. These findings highlight the
   potential of wearable-based circadian biomarkers for improving MetS
   assessment and management.},
Type = {Article},
Affiliation = {Lee, S (Corresponding Author), Korea Inst Oriental Med, KM Data Div, 1672 Yuseong Daero, Daejeon 34054, South Korea.
   Kim, Jeong-Kyun; Mun, Sujeong; Lee, Siwoo, Korea Inst Oriental Med, KM Data Div, 1672 Yuseong Daero, Daejeon 34054, South Korea.},
DOI = {10.2196/69328},
Article-Number = {e69328},
Keywords = {metabolic syndrome; wearable device; digital biomarker; circadian
   rhythm; explainable artificial intelligence},
Author-Email = {bfree@kiom.re.kr},
Number-of-Cited-References = {34},
Times-Cited = {6},
Unique-ID = {WOS:001544213500001},
}

@article{ WOS:001307490900001,
Author = {Karamanou, Areti and Brimos, Petros and Kalampokis, Evangelos and
   Tarabanis, Konstantinos},
Title = {Explainable Graph Neural Networks: An Application to Open Statistics
   Knowledge Graphs for Estimating House Prices},
Journal = {TECHNOLOGIES},
Year = {2024},
Volume = {12},
Number = {8},
Month = {AUG},
Abstract = {In the rapidly evolving field of real estate economics, the prediction
   of house prices continues to be a complex challenge, intricately tied to
   a multitude of socio-economic factors. Traditional predictive models
   often overlook spatial interdependencies that significantly influence
   housing prices. The objective of this study is to leverage Graph Neural
   Networks (GNNs) on open statistics knowledge graphs to model these
   spatial dependencies and predict house prices across Scotland's 2011
   data zones. The methodology involves retrieving integrated statistical
   indicators from the official Scottish Open Government Data portal and
   applying three representative GNN algorithms: ChebNet, GCN, and
   GraphSAGE. These GNNs are compared against traditional models, including
   the tabular-based XGBoost and a simple Multi-Layer Perceptron (MLP),
   demonstrating superior prediction accuracy. Innovative contributions of
   this study include the use of GNNs to model spatial dependencies in real
   estate economics and the application of local and global explainability
   techniques to enhance transparency and trust in the predictions. The
   global feature importance is determined by a logistic regression
   surrogate model while the local, region-level understanding of the GNN
   predictions is achieved through the use of GNNExplainer. Explainability
   results are compared with those from a previous work that applied the
   XGBoost machine learning algorithm and the SHapley Additive exPlanations
   (SHAP) explainability framework on the same dataset. Interestingly, both
   the global surrogate model and the SHAP approach underscored the
   comparative illness factor, a health indicator, and the ratio of
   detached dwellings as the most crucial features in the global
   explainability. In the case of local explanations, while both methods
   showed similar results, the GNN approach provided a richer, more
   comprehensive understanding of the predictions for two specific data
   zones.},
Type = {Article},
Affiliation = {Kalampokis, E (Corresponding Author), Univ Macedonia, Dept Business Adm, Informat Syst Lab, Thessaloniki 54636, Greece.
   Karamanou, Areti; Brimos, Petros; Kalampokis, Evangelos; Tarabanis, Konstantinos, Univ Macedonia, Dept Business Adm, Informat Syst Lab, Thessaloniki 54636, Greece.},
DOI = {10.3390/technologies12080128},
Article-Number = {128},
Keywords = {linked statistical data; knowledge graphs; graph neural networks;
   explainable artificial intelligence; house price prediction; explainable
   graph neural networks},
Keywords-Plus = {MACHINE-LEARNING ALGORITHMS; SPATIAL DEPENDENCE; DATA WAREHOUSES; MODEL;
   DETERMINANTS; EXPLANATIONS; REGRESSION},
Author-Email = {akarm@uom.edu.gr
   petrosbrimos@uom.edu.gr
   ekal@uom.edu.gr
   kat@uom.edu.gr},
Number-of-Cited-References = {133},
