   Yan, Xiaodong, Xi An Jiao Tong Univ, Sch Math \& Stat, 28 Xianning West Rd, Xian 710049, Shaanxi, Peoples R China.},
DOI = {10.1007/s11222-025-10722-7},
Article-Number = {199},
Keywords = {Conformal prediction; Missing response; Covariate shift; Propensity
   score},
Keywords-Plus = {QUANTILE REGRESSION; INFERENCE; MODELS},
