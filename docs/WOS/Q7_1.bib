@article{ WOS:000652593000452,
Author = {Zhu, Jia-Jie and Muandet, Krikamol and Diehl, Moritz and Schoelkopf,
   Bernhard},
Title = {A New Distribution-Free Concept for Representing, Comparing, and
   Propagating Uncertainty in Dynamical Systems with Kernel Probabilistic
   Programming},
Journal = {IFAC PAPERSONLINE},
Year = {2020},
Volume = {53},
Number = {2},
Pages = {7240-7247},
Abstract = {This work presents the concept of kernel mean embedding and kernel
   probabilistic programming in the context of stochastic systems. We
   propose formulations to represent, compare, and propagate uncertainties
   for fairly general stochastic dynamics in a distribution-free manner.
   The new tools enjoy sound theory rooted in functional analysis and wide
   applicability as demonstrated in distinct numerical examples. The
   implication of this new concept is a new mode of thinking about the
   statistical nature of uncertainty in dynamical systems. Copyright (C)
   2020 The Authors.},
Type = {Proceedings Paper},
Affiliation = {Zhu, JJ (Corresponding Author), Max Planck Inst Intelligent Syst, Empir Inference Dept, Tubingen, Germany.
