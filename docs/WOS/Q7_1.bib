   Fontana, Matteo, Joint Res Ctr European Commiss, Ispra, VA, Italy.},
DOI = {10.1016/j.jmva.2021.104879},
EarlyAccessDate = {FEB 2022},
Article-Number = {104879},
Keywords = {Conformal Prediction; Distribution-free prediction set; Exact prediction
