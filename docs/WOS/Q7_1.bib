DOI = {10.1016/j.compag.2025.110559},
EarlyAccessDate = {JUN 2025},
Article-Number = {110559},
Keywords = {Digital agriculture; Crop production; Deep learning; Uncertainty
   quantification; Conformal prediction},
Author-Email = {mibrahi2@uni-bonn.de
