   Jensen, Vilde, Kongsberg Satellite Serv, N-9011 Tromso, Norway.
   Bianchi, Filippo Maria, UiT Arctic Univ Norway, Dept Math \& Stat, N-9019 Tromso, Norway.
   Bianchi, Filippo Maria, UiT Arctic Univ Norway, NORCE Norwegian Res, N-9019 Tromso, Norway.
   Anfinsen, Stian Normann, UiT Arctic Univ Norway, NORCE Norwegian Res Ctr, Tromso, Norway.},
DOI = {10.1109/TNNLS.2022.3217694},
EarlyAccessDate = {NOV 2022},
Keywords = {Time series analysis; Probabilistic logic; Predictive models;
   Forecasting; Ensemble learning; Uncertainty; Medical services; Conformal
   prediction (CP); deep neural networks (NNs); ensemble learning;
   heteroscedasticity; Probabilistic forecasting; quantile regression (QR);
