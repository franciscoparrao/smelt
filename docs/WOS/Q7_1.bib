Keywords = {Copula model; Function-on-scalar regression; Image analysis; Optimal
   rate of convergence; Statistical inference},
Keywords-Plus = {VARYING COEFFICIENT MODEL; PREDICTION; INFERENCE},
Author-Email = {lkong@ualberta.ca},
Number-of-Cited-References = {41},
