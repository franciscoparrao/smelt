   Sherehiy, Andriy; Popa, Dan O., Univ Louisville, Automat \& Robot Res Inst, Louisville, KY 40208 USA.},
DOI = {10.1115/1.4070041},
Article-Number = {011005},
Keywords = {data augmentation; generative adversarial network (GAN); Gaussian
   process (GP); intense pulsed light sintering; aerosol jet printing;
   data-driven engineering; machine learning for engineering applications;
   process modeling for engineering applications},
