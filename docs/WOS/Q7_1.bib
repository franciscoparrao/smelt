Booktitle = {2025 IEEE CONFERENCE ON NETWORK FUNCTION VIRTUALIZATION AND
   SOFTWARE-DEFINED NETWORKING, NFV-SDN},
Series = {IEEE Conference on Network Function Virtualization and Software Defined
   Networks},
Year = {2025},
Pages = {466-471},
Abstract = {The advanced capability of the 6th generation (6G) of mobile networks to
   accommodate requests from a vast number of users with intensive
   requirements will be natively fortified by intelligent and autonomous
   network management. This potential will be primarily enabled by the
   integration of Artificial Intelligence (AI) in critical networking
   operations such as resource management and orchestration, security and
   service assurance. However, even though AI methods are highly efficient
   at dealing with intricate tasks, their predictions usually are over- or
   under-confident, introducing significant levels of uncertainty in the
   networking operation consistency. To address this issue, we introduce an
   Uncertainty Quantification (UQ) methodology to enhance the confidence of
   the predictions related to classification tasks. Our methodology is
   employed in the context of tabular data classification, and we also
   leverage a UQ metric to assess the improvement in the predictions
   conducted via our method. It is demonstrated that the proposed framework
   highly enhances the confidence of the predictions conducing consistent
   and reliable AI methods.},
