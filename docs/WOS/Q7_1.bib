@article{ WOS:000743760600008,
Author = {Kelly, Ryan and Chen, Kehui},
Title = {Distribution free prediction intervals for multiple functional
   regression},
Journal = {STATISTICS AND ITS INTERFACE},
Year = {2022},
Volume = {15},
Number = {2},
Pages = {161-170},
Abstract = {This paper applies conformal prediction techniques to the problem of
   constructing prediction intervals in a multiple functional regression
   setting. After a short introduction to the Signature expansion and its
   favorable properties, a method utilizing this feature set is developed
   with great modeling flexibility. With minimal assumptions, the resulting
   algorithm produces a closed form solution for a prediction set with
   guaranteed coverage. The good performance of the proposed method is
   illustrated using simulations and data examples.},
Type = {Article},
Affiliation = {Chen, KH (Corresponding Author), Univ Pittsburgh, Dept Stat, Pittsburgh, PA 15261 USA.
