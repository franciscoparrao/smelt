@article{ WOS:001372514600001,
Author = {Moya, Christian and Mollaali, Amirhossein and Zhang, Zecheng and Lu, Lu
   and Lin, Guang},
Title = {Conformalized-DeepONet: A distribution-free framework for uncertainty
   quantification in deep operator networks},
Journal = {PHYSICA D-NONLINEAR PHENOMENA},
Year = {2025},
Volume = {471},
Month = {JAN},
Abstract = {In this paper, we adopt conformal prediction, a distribution-free
   uncertainty quantification (UQ) framework, to obtain prediction
   intervals with coverage guarantees for Deep Operator Network (DeepONet)
   regression. Initially, we enhance the uncertainty quantification
   frameworks (B-DeepONet and Prob-DeepONet) previously proposed by the
   authors by using split conformal prediction. By combining conformal
   prediction with our Prob- and B-DeepONets, we effectively quantify
   uncertainty by generating rigorous prediction intervals for DeepONet
   prediction. Additionally, we design a novel Quantile-DeepONet that
   allows for a more natural use of split conformal prediction. We refer to
   this distribution-free effective uncertainty quantification framework as
   split conformal Quantile-DeepONet regression. Finally, we demonstrate
   the effectiveness of the proposed methods using various ordinary,
   partial differential equation numerical examples, and multi-fidelity
   learning.},
Type = {Article},
Affiliation = {Zhang, ZC (Corresponding Author), Florida State Univ, Dept Math, Tallahassee, FL 32304 USA.
   Zhang, Zecheng, Florida State Univ, Dept Math, Tallahassee, FL 32304 USA.
   Lu, Lu, Yale Univ, Dept Stat \& Data Sci, New Haven, CT 06511 USA.
   Moya, Christian; Lin, Guang, Purdue Univ, Dept Math, W Lafayette, IN 47907 USA.
   Mollaali, Amirhossein, Purdue Univ, Sch Mech Engn, W Lafayette, IN 47907 USA.},
DOI = {10.1016/j.physd.2024.134418},
EarlyAccessDate = {DEC 2024},
Article-Number = {134418},
Keywords = {Operator learning; Uncertainty quantification; Conformal prediction;
   Quantile prediction; Dynamical systems; Time-dependent PDE},
