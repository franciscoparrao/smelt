@article{ WOS:001678334900001,
Author = {Rasul, Mohamed J. M. A. and Abbas, Asad and Baek, Jongbok and Kim,
   Jonghoon},
Title = {A hybrid ensemble learning framework with uncertainty quantification for
   state-of-health estimation in lithium-ion batteries},
Journal = {MEASUREMENT},
Year = {2026},
Volume = {266},
Month = {MAR 24},
Abstract = {Accurate state-of-health (SOH) estimation is essential to ensure the
   safety, reliability, and longevity of lithium-ion batteries. While
   data-driven methods have shown promise, most provide only deterministic
   point estimates without quantifying predictive uncertainty-limiting
   their deployment in safety-critical applications. This study introduces
   a hybrid ensemble learning framework enhanced with distribution-free
   uncertainty quantification for precise, interpretable, and reliable SOH
   estimation. The proposed method integrates Random Forest (RF) and
   Gradient Boosting (GB) within a stacked ensemble guided by a linear
   regression meta-learner, capturing complex nonlinear degradation
   dynamics while improving generalization. To address the uncertainty gap,
   conformal prediction is incorporated to generate statistically valid
   prediction intervals without requiring probabilistic model assumptions.
   Additionally, mutual information gain (MIG) automatically selects the
   most informative voltage and charging features, reducing redundancy and
   enhancing model transparency. The framework is rigorously validated
   across three public benchmark datasets-NASA, Oxford, and
   XJTU-demonstrating superior accuracy (RMSE < 0.001, R-2 > 0.99) and
   well-calibrated uncertainty with coverage probabilities consistently
   near 95 \%. Robustness tests under simulated real-world data
   imperfections further confirm the model's practical reliability. By
   unifying ensemble learning with model-agnostic uncertainty
   quantification, this work provides a risk-aware, uncertainty-informed
   approach to battery health estimation, advancing the development of
   safer and more dependable battery management and predictive maintenance
   systems.},
Type = {Article},
Affiliation = {Kim, J (Corresponding Author), Chungnam Natl Univ, Dept Elect Engn, Energy Storage Convers Lab, Daejeon 34134, South Korea.
   Baek, J (Corresponding Author), Korea Inst Energy Res, Energy ICT Convergence Res Dept, Energy Efficiency Res Div, Daejeon 16105, South Korea.
