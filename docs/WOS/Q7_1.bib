}

@incollection{ WOS:001596385600012,
Author = {Sangalli, Sara and Sarwin, Gary and Erdil, Ertunc and Serra, Carlo and
   Carretta, Alessandro and Staartjes, Victor and Konukoglu, Ender},
Editor = {Gee, JC and Alexander, DC and Hong, J and Iglesias, JE and Sudre, CH and Venkataraman, A and Golland, P and Kim, JH and Park, J},
Title = {Conformal Forecasting for Surgical Instrument Trajectory},
Booktitle = {MEDICAL IMAGE COMPUTING AND COMPUTER ASSISTED INTERVENTION - MICCAI
   2025, PT IX},
Series = {Lecture Notes in Computer Science},
Year = {2026},
Volume = {15968},
Pages = {117-127},
Abstract = {Forecasting surgical instrument trajectories and predicting the next
   surgical action recently started to attract attention from the research
   community. Both these tasks are crucial for automation and assistance in
   endoscopy surgery. Given the safety-critical nature of these tasks,
   reliable uncertainty quantification is essential. Conformal prediction
   is a fast-growing and widely recognized framework for uncertainty
   estimation in machine learning and computer vision, offering
   distribution-free, theoretically valid prediction intervals. In this
   work, we explore the application of standard conformal prediction and
   conformalized quantile regression to estimate uncertainty in forecasting
   surgical instrument motion, i.e., predicting direction and magnitude of
   surgical instruments' future motion. We analyze and compare their
   coverage and interval sizes, assessing the impact of multiple hypothesis
   testing and correction methods. Additionally, we show how these
   techniques can be employed to produce useful uncertainty heatmaps. To
   the best of our knowledge, this is the first study applying conformal
   prediction to surgical guidance, marking an initial step toward
   constructing principled prediction intervals with formal coverage
   guarantees in this domain (The code is available at this link).},
Type = {Proceedings Paper},
Affiliation = {Sangalli, S (Corresponding Author), Swiss Fed Inst Technol, Comp Vis Lab, Zurich, Switzerland.
   Sangalli, Sara; Sarwin, Gary; Erdil, Ertunc; Konukoglu, Ender, Swiss Fed Inst Technol, Comp Vis Lab, Zurich, Switzerland.
