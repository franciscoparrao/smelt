@article{ WOS:001654269200001,
Author = {Han, Jiale and Dai, Xiaowu},
Title = {Online Auction Design Using Distribution-Free Uncertainty Quantification
   with Applications to E-Commerce},
Journal = {JOURNAL OF THE AMERICAN STATISTICAL ASSOCIATION},
Year = {2025},
Month = {2025 DEC 23},
Abstract = {Online auction is a cornerstone of e-commerce, and a key challenge is
   designing incentive-compatible mechanisms that maximize expected
   revenue. Existing approaches often assume known bidder value
   distributions and fixed sets of bidders and items, but these assumptions
   rarely hold in real-world settings where bidder values are unknown, and
   the number of future participants is uncertain. In this article, we
   introduce the Conformal Online Auction Design (COAD), a novel mechanism
   that maximizes revenue by quantifying uncertainty in bidder values
   without relying on known distributions. COAD incorporates both bidder
   and item features, using historical data to design an
   incentive-compatible mechanism for online auctions. Unlike traditional
   methods, COAD leverages distribution-free uncertainty quantification
   techniques and integrates machine learning methods, such as random
   forests, kernel methods, and deep neural networks, to predict bidder
   values while ensuring revenue guarantees. Moreover, COAD introduces
   bidder-specific reserve prices, based on the lower confidence bounds of
   bidder valuations, contrasting with the single reserve price commonly
   used in the literature. We demonstrate the practical effectiveness of
   COAD through an application to real-world eBay auction data. Theoretical
   results and extensive simulation studies further validate the properties
   of our approach. Supplementary materials for this article are available
   online, including a standardized description of the materials available
   for reproducing the work.},
Type = {Article; Early Access},
Affiliation = {Dai, XW (Corresponding Author), Univ Calif Los Angeles, Dept Stat \& Data Sci, 8125 Math Sci Bldg 951554, Los Angeles, CA 90095 USA.
   Han, Jiale; Dai, Xiaowu, Univ Calif Los Angeles, Dept Stat \& Data Sci, 8125 Math Sci Bldg 951554, Los Angeles, CA 90095 USA.
   Dai, Xiaowu, Univ Calif Los Angeles, Dept Biostat, Los Angeles, CA 90095 USA.},
DOI = {10.1080/01621459.2025.2576180},
EarlyAccessDate = {DEC 2025},
Keywords = {Conformal prediction; Online auction; Revenue maximization; Uncertainty
   quantification},
Author-Email = {daix@ucla.edu},
Number-of-Cited-References = {48},
Times-Cited = {0},
Unique-ID = {WOS:001654269200001},
}

@article{ WOS:001647963900001,
Author = {Soon, Kian Lun and Soon, Lam Tatt},
Title = {Enhancing reliability in electrified transportation: A conformalized
   quantile regression framework for battery state-of-charge uncertainty
   quantification},
Journal = {JOURNAL OF POWER SOURCES},
Year = {2026},
Volume = {666},
Month = {FEB 28},
Abstract = {The reliability of electrified transportation is critically undermined
   by untrustworthy uncertainty bounds for battery State-of-Charge (SOC)
   estimation, as conventional methods rely on unrealistic distributional
   assumptions. To address this issue, this paper presents a novel
   framework in which a high-accuracy predictive model is first trained,
   followed by post-hoc uncertainty calibration to produce guaranteed,
   distribution-free SOC bounds, thereby overcoming the limitations of
   conventional estimators (assuming Gaussian noise) and standard quantile
   models (lacking coverage guarantees). The framework's two main
   contributions are as follows. First, FeatureFormer models complex,
   non-linear interactions among instantaneous battery features by
   processing them as a feature-based pseudo-sequence, unlike a standard
   Patch transformer, which processes aggregated temporal patches to model
   long-range dependencies. Second, the predictive backbone is coupled with
   Conformalized Quantile Regression (CQR), which calibrates the model's
   quantile outputs to produce mathematically guaranteed, distribution-free
   prediction intervals that do not assume a specific error structure. The
   FeatureFormer-CQR framework demonstrates superior performance by
   achieving minimal Mean Calibration Error (MCE) of 0.0194, Winkler Score
   of 13.636, Normalized Mean Prediction Interval Width (NMPIW) of 0.1452,
   with a Prediction Interval Coverage Probability (PICP) close to 95 \%,
   thereby providing guaranteed SOC bounds essential for enhancing the
   operational reliability and safety of electrified transportation
   systems.},
Type = {Article},
Affiliation = {Soon, KL (Corresponding Author), Taylors Univ, Sch Engn, Subang Jaya, Selangor, Malaysia.
   Soon, LT (Corresponding Author), Taylors Univ, Sch Architecture Bldg \& Design, 1 Jalan Taylors, Subang Jaya 47500, Selangor, Malaysia.
   Soon, Kian Lun, Taylors Univ, Sch Engn, Subang Jaya, Selangor, Malaysia.
   Soon, Lam Tatt, Taylors Univ, Sch Architecture Bldg \& Design, 1 Jalan Taylors, Subang Jaya 47500, Selangor, Malaysia.},
DOI = {10.1016/j.jpowsour.2025.239123},
EarlyAccessDate = {DEC 2025},
Article-Number = {239123},
Keywords = {Uncertainty quantification; Conformalized quantile regression; Electric
   vehicle; State of charge},
Author-Email = {KianLun.Soon@taylors.edu.my
   lamtatt.soon@taylors.edu.my},
Number-of-Cited-References = {26},
Times-Cited = {0},
Unique-ID = {WOS:001647963900001},
}

@article{ WOS:001643735100004,
Author = {Meehinkong, Panisara and Ponnoprat, Donlapark},
Title = {coverforest: Conformal predictions with random forest in python},
Journal = {NEUROCOMPUTING},
Year = {2026},
Volume = {668},
Month = {MAR 1},
Abstract = {Conformal prediction provides a framework for uncertainty
   quantification, specifically in the forms of predic tion intervals and
   sets with distribution-free guaranteed coverage. While recent
   cross-conformal techniques such as CV+ and Jackknife+-after-bootstrap
   achieve better data efficiency than traditional split conformal meth
   ods, they incur substantial computational costs due to required pairwise
   comparisons between training and test samples' out-of-bag scores.
   Observing that these methods naturally extend from ensemble models,
   particularly random forests, we leverage existing optimized random
   forest implementations to enable efficient cross-conformal predictions.
   We present coverforest, a Python package that implements efficient
   conformal prediction methods specif ically optimized for random forests.
   Our package leverages parallel computing and Cython optimizations to
   accelerate out-of-bag calculations, making it 2-10 times faster than
   existing implementations while maintaining theoretical coverage
   guarantees. coverforest supports both regression and classification
   tasks through various conformal prediction methods, including split
   conformal, CV+, and Jackknife+-after-bootstrap, as well as adap tive
   prediction sets for classification. Built upon scikit-learn's random
   forest implementation, coverforest provides a practical solution for
   reliable uncertainty quantification. We demonstrate the package's
   performance through empirical evaluations on several benchmark datasets.
   The source code for the coverforest is hosted on GitHub at
   https://github.com/donlap/coverforest.},
Type = {Article},
Affiliation = {Ponnoprat, D (Corresponding Author), Chiang Mai Univ, Dept Stat, Chiang Mai 50200, Thailand.
   Meehinkong, Panisara; Ponnoprat, Donlapark, Chiang Mai Univ, Dept Stat, Chiang Mai 50200, Thailand.},
DOI = {10.1016/j.neucom.2025.132362},
EarlyAccessDate = {DEC 2025},
Article-Number = {132362},
Keywords = {Conformal prediction; Cross-validation; Jackknife; Bootstrap; Prediction
   sets},
Author-Email = {donlapark.p@cmu.ac.th},
Number-of-Cited-References = {44},
Times-Cited = {1},
Unique-ID = {WOS:001643735100004},
}

@article{ WOS:001646854100001,
Author = {Bridge-Nduwimana, Charlene Beatrice and El Harrauss, Salah Eddine and El
   Ouaazizi, Aziza and Benyakhlef, Majid},
Title = {A Tabular Data Imputation Technique Using Transformer and Convolutional
   Neural Networks},
Journal = {BIG DATA AND COGNITIVE COMPUTING},
Year = {2025},
Volume = {9},
Number = {12},
Month = {DEC 13},
Abstract = {Upstream processes strongly influence downstream analysis in sequential
   data-processing workflows, particularly in machine learning, where data
   quality directly affects model performance. Conventional statistical
   imputations often fail to capture nonlinear dependencies, while deep
   learning approaches typically lack uncertainty quantification. We
   introduce a hybrid imputation model that integrates a deep learning
   autoencoder with Convolutional Neural Network (CNN) layers and a
   Transformer-based contextual modeling architecture to address systematic
   variation across heterogeneous data sources. Performing multiple
   imputations in the autoencoder-transformer latent space and averaging
   representations provides implicit batch correction that suppresses
   context-specific remains without explicit batch identifiers. We
   performed experiments on datasets in which 10\% of missing data was
   artificially introduced by completely random missing data (MCAR) and
   non-random missing data (MNAR) mechanisms. They demonstrated practical
   performance, jointly ranking first among the imputation methods
   evaluated. This imputation technique reduced the root mean square error
   (RMSE) by 50\% compared to denoising autoencoders (DAE) and by 46\%
   compared to iterative imputation (MICE). Performance was comparable for
   adversarial models (GAIN) and attention-based models (MIDA), and both
   provided interpretable uncertainty estimates (CV = 0.08-0.15).
   Validation on datasets from multiple sources confirmed the robustness of
   the technique: notably, on a forensic dataset from multiple
   laboratories, our imputation technique achieved a practical improvement
   over GAIN (0.146 vs. 0.189 RMSE), highlighting its effectiveness in
   mitigating batch effects.},
Type = {Article},
Affiliation = {Bridge-Nduwimana, CB; El Harrauss, SE (Corresponding Author), Sidi Mohamed Ben Abdellah Univ, High Sch Technol EST, Innovat Technol \& Comp Sci Lab LT2I, Fes 30000, Morocco.
