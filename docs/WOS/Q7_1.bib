@incollection{ WOS:001701718700044,
Author = {Kapogiannis, Konstantinos and Lakoumentas, John and Keramidi, Irene and
   Ramantas, Kostas and Verikoukis, Christos},
Book-Group-Author = {IEEE},
Title = {Classification of Tabular Data for 6G Operations under an Uncertainty
