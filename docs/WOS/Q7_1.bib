   Baek, Jongbok, Korea Inst Energy Res, Energy ICT Convergence Res Dept, Energy Efficiency Res Div, Daejeon 16105, South Korea.},
DOI = {10.1016/j.measurement.2026.120528},
EarlyAccessDate = {JAN 2026},
Article-Number = {120528},
Keywords = {State-of health (SOH) estimation; Uncertainty quantification; Conformal
   prediction; Ensemble learning; Mutual information gain; Battery
   diagnostics},
