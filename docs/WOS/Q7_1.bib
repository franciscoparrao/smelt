@article{ WOS:001259733900001,
Author = {Matias, Alan L. S. and Gomes, Joao Paulo P. and Mattos, Cesar Lincoln C.
   and Rocha Neto, Ajalmar R. and Mesquita, Diego},
Title = {Bayesian ART for incomplete datasets},
Journal = {APPLIED SOFT COMPUTING},
Year = {2024},
Volume = {163},
Month = {SEP},
Abstract = {Adaptive Resonance Theory (ART) models allow for categorizing data in a
   fast and incremental manner. In particular, the Bayesian ART leverages
   Bayesian methodology to capture complex relationships between
   categories. While Bayesian methods are well-known for handling
   uncertainty, Bayesian ART models are at the mercy of a recurring foe:
   missing data. When data is missing, practitioners must rely on off -the
   -shelf solutions to impute the data before using Bayesian ART,
   effectively truncating the uncertainty quantification. To overcome such
   limitation, we (I) estimate the distribution of missing data entries
   using a Gaussian mixture model and (II) modify the three steps of
   Bayesian ART (category choice, matching, and update) to propagate the
   uncertainty around the missing entries. Experiments in a variety of
   tabular datasets show that, in general, our novel methodology leads to
   better results than using off -the -shelf imputation solutions. The
   performance gap becomes especially noticeable as the number of missing
   data entries increases.},
Type = {Article},
Affiliation = {Matias, ALS (Corresponding Author), Univ Fed Ceara, Fortaleza, CE, Brazil.
   Matias, Alan L. S.; Gomes, Joao Paulo P.; Mattos, Cesar Lincoln C., Univ Fed Ceara, Fortaleza, CE, Brazil.
   Rocha Neto, Ajalmar R., Fed Inst Ceara, Fortaleza, CE, Brazil.
   Mesquita, Diego, Getulio Vargas Fdn, Rio De Janeiro, RJ, Brazil.},
DOI = {10.1016/j.asoc.2024.111865},
EarlyAccessDate = {JUN 2024},
Article-Number = {111865},
Keywords = {Adaptive Resonance Theory; Bayesian ART; Missing values},
Keywords-Plus = {FUZZY ARTMAP; NEURAL-NETWORK; DISTANCE ESTIMATION; MISSING DATA;
