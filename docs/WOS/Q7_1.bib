@article{ WOS:000789652700005,
Author = {Solari, Aldo and Djordjilovic, Vera},
Title = {Multi split conformal prediction},
Journal = {STATISTICS \& PROBABILITY LETTERS},
Year = {2022},
Volume = {184},
Month = {MAY},
Abstract = {Split conformal prediction is a computationally efficient method for
   performing distribution-free predictive inference in regression. It
   involves, however, a one-time random split of the data, and the result
   can strongly depend on the particular split. To address this problem, we
   propose multi split conformal prediction, a simple method based on
   Markov's inequality to aggregate split conformal prediction intervals
   across multiple splits. (c) 2022 Elsevier B.V. All rights reserved.},
Type = {Article},
