@article{ WOS:001722973800001,
Author = {Heddoub, Amine and Homri, Lazhar and Siadat, Ali},
Title = {Class-conditional conformal prediction with discriminant-analysis
   backbones for reliable open-set fault diagnosis in safety-critical
   industrial systems},
Journal = {JOURNAL OF PROCESS CONTROL},
Year = {2026},
Volume = {161},
Month = {MAY},
Abstract = {Industrial fault diagnosis in safety-critical systems demands
   uncertainty quantification mechanisms and the ability to detect unknown
   faults. While uncertainty quantification for fault diagnosis has been
   studied, most approaches do not provide a mathematical coverage
   guarantee and do not explicitly model rejection of samples outside the
   known fault set under open-set conditions. Our framework produces
   prediction sets rather than single label classifications, naturally
   quantifying uncertainty and enabling transparent decision making. We
   combine Mondrian conformal prediction (MCP) with lightweight
   discriminant-analysis (DA) classifiers to obtain coverage guarantees for
   each fault type, even under severe class imbalance or overlapping fault
   signatures. In this paper, we focus on DA backbones to match
   safety-critical deployment constraints and to isolate the contribution
   of class-conditional conformal calibration. We validate this DA-based
   implementation of the framework on two industrial benchmarks: the
   DAMADICS valve-actuator dataset and the Tennessee Eastman Process (TEP).
   Empirical results show that coverage targets are met across all fault
   classes, including minority classes and similar faults. Confident
   predictions achieve near-perfect coverage, and the method identifies
   unknown faults with high detection rates at low false-alarm rates.
   Overall, combining conformal prediction with discriminant-analysis
   backbones suits safety-critical fault diagnosis. This approach provides
   distribution-free guarantees, transparent uncertainty quantification,
   and open-set robustness.},
Type = {Article},
Affiliation = {Homri, L (Corresponding Author), Univ Lorraine, Arts \& Metiers Inst Technol, LCFC, F-57070 Metz, France.
   Heddoub, Amine; Homri, Lazhar; Siadat, Ali, Univ Lorraine, Arts \& Metiers Inst Technol, LCFC, F-57070 Metz, France.
   Siadat, Ali, Res Ctr S3I, Arts \& Metiers Campus Rabat, Rabat, Morocco.},
DOI = {10.1016/j.jprocont.2026.103701},
Article-Number = {103701},
Keywords = {Conformal prediction; Fault diagnosis; Discriminant analysis;
   Uncertainty quantification; Open-set recognition},
Keywords-Plus = {QUANTITATIVE MODEL; KNOWLEDGE; DRIVEN},
Author-Email = {lazhar.homri@ensam.eu},
Number-of-Cited-References = {52},
Times-Cited = {0},
Unique-ID = {WOS:001722973800001},
}

@article{ WOS:001705944900001,
Author = {Dong, Shijian and Hu, Wenyue and Kong, Shuang and Jiang, Xiaoqing and
   Shao, Yiqin},
Title = {Interpretable stacking network for predicting endpoint temperature of
   Consteel electric arc furnace using tabular data},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {171},
Month = {MAY 1},
Abstract = {Prediction and control of the endpoint temperature in the Consteel
   electric arc furnace can enhance the mechanical properties,
   microstructure and energy utilization efficiency. An interpretable
   stacking model is first developed to predict the endpoint temperature in
   the Consteel electric arc furnace. The Random Forest technique is used
   to preprocess raw data and extract key features. The synergistic
   application of the correlation heat map and cumulative contribution rate
   of SHapley Additive exPlanations values determines base learners, which
   improves the methodological soundness of the stacking model
   construction. The stacking model effectively enhances robustness by
   integrating the advantages of heterogeneous learners, including tabular
   deep network, eXtreme Gradient Boosting, Multilayer Perceptron, and
   Support Vector Regression. The Bayesian Ridge Regression with dual
   evaluation properties is designed as the meta-learner. The domain
   knowledge of different variables on the endpoint temperature is also
   analyzed to enhance the interpretability of the prediction model. The
   importance of each feature is visualized using the SHapley Additive
   exPlanations framework. Compared with the existing methods, the
   effectiveness and adaptability of the proposed algorithm are verified
   using the sampled data from an actual Consteel electric arc furnace
   process. The prediction interval coverage probability and the normalized
   average width are also presented and analyzed. Experimental results show
   that the proposed model achieves Hit Rates of 85.85 \% within +15
   degrees C and 92.92 \% within +20 degrees C.},
Type = {Article},
Affiliation = {Shao, YQ (Corresponding Author), Zhejiang Sci Tech Univ, Coll Text Sci \& Engn Int Inst Silk, Hangzhou 310018, Peoples R China.
   Dong, Shijian, Northeastern Univ, Sch Met, Shenyang 110819, Liaoning, Peoples R China.
   Hu, Wenyue; Kong, Shuang; Jiang, Xiaoqing, Northeastern Univ, Coll Informat Sci \& Engn, Shenyang 110819, Liaoning, Peoples R China.
   Shao, Yiqin, Zhejiang Sci Tech Univ, Coll Text Sci \& Engn Int Inst Silk, Hangzhou 310018, Peoples R China.},
DOI = {10.1016/j.engappai.2026.114305},
Article-Number = {114305},
Keywords = {Consteel electric arc furnace; Deep stacking network; Tabular data;
   Interpretable prediction; Feature selection},
Keywords-Plus = {MODEL},
