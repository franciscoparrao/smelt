   Majlatow, Maxim; Shakil, Fahim Ahmed; Emrich, Andreas; Mehdiyev, Nijat, Saarland Univ, Inst Informat Syst IWi, D-66123 Saarbrucken, Germany.},
DOI = {10.3390/app15147925},
Article-Number = {7925},
Keywords = {conformal prediction; explainable artificial intelligence; probability
   calibration; predictive process monitoring},
Author-Email = {maxim.majlatow@dfki.de
   ahim\_ahmed.shakil@dfki.de
   andreas.emrich@dfki.de
   nijat.mehdiyev@dfki.de},
Number-of-Cited-References = {61},
