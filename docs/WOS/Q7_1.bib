}

@article{ WOS:001721810700001,
Author = {Sulthana, Huma and Jays, Judy and Prakash Kumar, B.},
Title = {The convergence of statistical design and computational intelligence: a
   systematic review of DOE-driven AI/ML in analytical method development
   and validation},
Journal = {ACCREDITATION AND QUALITY ASSURANCE},
Year = {2026},
Month = {2026 MAR 24},
Abstract = {This systematic review evaluates the integration of Design of
   Experiments (DoE) with Artificial Intelligence (AI) and Machine Learning
   (ML) for developing and validating analytical methods in pharmaceutical
   and chemical sciences. The literature search (2010-2025) across
   scientific databases identified peer-reviewed studies combining DoE for
   data generation with AI/ML for modeling and optimization. The synergy
   between DoE and ML enhances experimental efficiency, with DoE providing
   structured data for robust ML models and ML enabling predictive modeling
   and active learning. Comparative analysis reveals Artificial Neural
   Networks (ANNs) and Support Vector Machines (SVMs) excel in nonlinear
   systems, Multiple Linear Regression (MLR) offers interpretable
   baselines, Adaptive Neuro-Fuzzy Inference Systems (ANFIS) balance
   accuracy and transparency, Random Forest and XGBoost provide robust
   ensemble predictions, and Gaussian Process Regression supports
   uncertainty quantification. Applications include optimizing
   chromatographic methods, robustness testing, and predictive validation
   within Analytical Quality by Design (QbD). Challenges involve the
   ``black-box{''} nature of models, data governance, and Good
   Manufacturing Practice (GMP) validation. AI (XAI) is emerging to improve
   transparency. This integration transforms analytical method development,
   accelerating timelines and supporting autonomous laboratories, with
   addressing interpretability and regulatory hurdles critical for broader
   adoption.},
Type = {Review; Early Access},
Affiliation = {Jays, J (Corresponding Author), MS Ramaiah Univ Appl Sci, Fac Pharm, Dept Pharmaceut Chem, Bengaluru 560054, Karnataka, India.
   Sulthana, Huma; Jays, Judy, MS Ramaiah Univ Appl Sci, Fac Pharm, Dept Pharmaceut Chem, Bengaluru 560054, Karnataka, India.
   Prakash Kumar, B., Sri Adichunchanagiri Coll Pharm, Fac Pharm, B G Nagar 571448, Karnataka, India.},
DOI = {10.1007/s00769-026-01701-0},
EarlyAccessDate = {MAR 2026},
Keywords = {Design of experiments (DoE); Artificial intelligence (AI); Machine
   learning (ML); Analytical method development; Predictive modeling;
   Explainable AI (XAI)},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; OPTIMIZATION; PREDICTION; ANFIS},
Author-Email = {judyjays.py.ph@msruas.ac.in},
Number-of-Cited-References = {79},
Times-Cited = {0},
Unique-ID = {WOS:001721810700001},
}

@article{ WOS:001716451400001,
Author = {Lansiaux, Edouard and Azzouz, Ramy and Chazard, Emmanuel and Vromant,
   Amelie and Wiel, Eric},
Title = {Artificial Intelligence Models for Predicting Triage in Emergency
   Departments: Seven-Month Retrospective Comparative Study of Natural
   Language Processing, Large Language Model, and Joint Embedding
   Predictive Architectures},
Journal = {JMIR MEDICAL INFORMATICS},
Year = {2026},
Volume = {14},
Month = {MAR 16},
Abstract = {Background: Triage errors in emergency departments (EDs), including
   undertriage and overtriage, pose significant risks to patient safety and
   resource allocation. With increasing patient volumes and staffing
   challenges, artificial intelligence (AI) integration into triage
   protocols has gained attention as a potential solution.
   Objective: This study aims to develop and compare 3 AI models-natural
   language processing (NLP), large language model (LLM), and Joint
   Embedding Predictive Architecture (JEPA)-for predicting triage outcomes
   according to the French Emergency Nurses Classification in Hospital
   (FRENCH) scale and to assess their performance relative to nurse triage
   and clinical expert consensus.
   Methods: We conducted a retrospective analysis of prospectively
   collected data from adult patients triaged at Roger Salengro Hospital ED
   (Lille, France) over 7 months (June-December 2024). Three AI models were
   developed: TRIAGEMASTER (NLP with Doc2Vec + MLP), URGENTIAPARSE (LLM
   with FlauBERT + Extreme Gradient Boosting {[}XGBoost]), and EMERGINET
   (JEPA with variance-invariance-covariance regularization). Of 73,236 ED
   visits, 657 (0.90\%) had complete audio recordings and structured data.
   Data were split 80:20 into training and validation sets with
   stratification. Gold-standard labels were established by senior
   clinician consensus (minimum 5 years of ED experience). The primary
   outcome was concordance with the gold-standard FRENCH triage level,
   assessed using weighted., Spearman correlation, F1-score, area under the
   receiver operating characteristic (AUC-ROC) curve, mean absolute error
   (MAE), and root mean square error (RMSE). Secondary analyses evaluated
   Groupes d'Etude Multicentrique des Services d'Accueil (GEMSA) prediction
   and performance by input data type.
   Results: URGENTIAPARSE demonstrated superior performance, with a
   composite z score of 2.514 compared with EMERGINET (0.438), TRIAGEMASTER
   (-3.511), and nurse triage (-4.343). URGENTIAPARSE achieved an F1-score
   of 0.900 (95\% CI 0.876-0.924), an AUC-ROC of 0.879 (95\% CI
   0.851-0.907), a weighted. of 0.800 (P<.001), a Spearman correlation of
   0.802 (P<.001), an MAE of 0.228, and an RMSE of 0.790. Exact agreement
   was 90.0\%, with near-agreement (+1 or -1 level) of 92.8\%. However,
   training showed perfect accuracy (1.0) with poor validation performance
   (similar to 0.5), indicating overfitting. EMERGINET achieved moderate
   performance (F1-score=0.731, AUC 0.686), while TRIAGEMASTER and nurse
   triage performed poorly (F1-score=0.618 and 0.303, respectively). For
   GEMSA prediction, URGENTIAPARSE maintained superiority (kappa=0.863,
   Spearman=0.864, P<.001). Class 1 (highest acuity) was underrepresented
   (4/657, 0.61\%), limiting undertriage risk assessment.
   Conclusions: The LLM-based architecture (URGENTIAPARSE) demonstrated the
   highest accuracy for ED triage prediction among the tested models,
   outperforming traditional NLP, JEPA, and current nurse triage practices.
   However, severe overfitting, extreme selection bias (657/73,236, 0.90\%,
   inclusion), a monocentric design, and sparse high-acuity representation
   limit clinical applicability. Before deployment, the model requires
   regularization, external validation across diverse EDs, prospective
   testing, and comprehensive safety evaluation, particularly for
   undertriage detection. Integration of AI triage support systems shows
   promise but demands rigorous validation, bias mitigation, and
   transparent uncertainty quantification to ensure patient safety.},
Type = {Article},
Affiliation = {Lansiaux, E (Corresponding Author), Lille Univ Hosp, Emergency Dept, 2 Ave Oscar Lambret, Lille F-59800, France.
   Lansiaux, Edouard; Wiel, Eric, Lille Univ Hosp, Emergency Dept, 2 Ave Oscar Lambret, Lille F-59800, France.
   Azzouz, Ramy, Lille Univ Hosp, Ctr Antipoison, Lille, France.
   Azzouz, Ramy; Chazard, Emmanuel; Wiel, Eric, Lille Univ, ULR 2694, METRICS, Lille, France.
   Chazard, Emmanuel, Lille Univ, Dept Publ Hlth, EA 2694, Lille, France.
   Vromant, Amelie, Hop La Pitie Salpetriere, Assistance Publ Hop Paris, Emergency Dept, Paris, France.},
DOI = {10.2196/83318},
Article-Number = {e83318},
Keywords = {triage; emergency department; artificial intelligence; natural language
   processing; large language model; Joint Embedding Predictive
   Architecture; clinical decisionsupport; FRENCH scale},
Keywords-Plus = {NURSES CLASSIFICATION; CHALLENGES},
Author-Email = {edouard.lansiaux@orange.fr},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001716451400001},
}

@article{ WOS:001714589600010,
Author = {Haas, Stefan and Hullermeier, Eyke},
Title = {Aleatoric and Epistemic Uncertainty Measures for Ordinal Classification
   Through Binary Reduction},
Journal = {MACHINE LEARNING},
Year = {2026},
Volume = {115},
Number = {3},
Month = {MAR 6},
Abstract = {Ordinal classification problems, where labels exhibit a natural order,
   are prevalent in high-stakes fields such as medicine and finance.
   Accurate uncertainty quantification, including the decomposition into
   aleatoric (inherent variability) and epistemic (lack of knowledge)
   components, is crucial for reliable decision-making. However, existing
   research has primarily focused on nominal classification and regression.
   In this paper, we introduce a novel class of measures of aleatoric and
   epistemic uncertainty in ordinal classification, which is based on a
   suitable reduction to (entropy- and variance-based) measures for the
   binary case. These measures effectively capture the trade-off in ordinal
   classification between exact hit-rate and minimal error distances. We
   demonstrate the effectiveness of our approach on various tabular ordinal
   benchmark datasets using ensembles of gradient-boosted trees and
   multi-layer perceptrons for approximate Bayesian inference. Our method
   significantly outperforms standard and label-wise entropy and
   variance-based measures in error detection, as indicated by
   misclassification rates and mean absolute error. Additionally, the
   ordinal measures show competitive performance in out-of-distribution
   (OOD) detection. Our findings highlight the importance of considering
   the ordinal nature of classification problems when assessing
   uncertainty.},
Type = {Article},
Affiliation = {Haas, S (Corresponding Author), LMU Munchen, Inst Informat, Munich, Germany.
   Haas, S (Corresponding Author), BMW Grp, Munich, Germany.
   Haas, Stefan; Hullermeier, Eyke, LMU Munchen, Inst Informat, Munich, Germany.
   Haas, Stefan, BMW Grp, Munich, Germany.
   Hullermeier, Eyke, Munich Ctr Machine Learning MCML, Munich, Germany.
   Hullermeier, Eyke, German Res Ctr Artificial Intelligence DFKI, DSA, Kaiserslautern, Germany.},
DOI = {10.1007/s10994-025-06960-5},
Article-Number = {63},
Keywords = {Ordinal classification; Ordinal regression; Uncertainty quantification;
   Aleatoric uncertainty; Epistemic uncertainty; Binary reduction},
Keywords-Plus = {WEIGHTED KAPPA; REGRESSION; PREDICTION; MULTICLASS},
Author-Email = {stefan.haas@campus.lmu.de
   eyke@lmu.de},
Number-of-Cited-References = {73},
Times-Cited = {0},
Unique-ID = {WOS:001714589600010},
}

@article{ WOS:001691142300001,
Author = {Ghosh, Dhrubajyoti and Boettcher, William and Johnston, Rob and Lahiri,
   Soumendra},
Title = {Machine Learning Based Bot Detection on X With Temporal and Semantic
   Feature Integration},
Journal = {IEEE TRANSACTIONS ON COMPUTATIONAL SOCIAL SYSTEMS},
Year = {2026},
Month = {2026 FEB 12},
Abstract = {Escalating proliferation of inorganic accounts, commonly known as bots,
   within the digital ecosystem represents an ongoing and multifaceted
   challenge to online security, trustworthiness, and user experience.
   These bots, often employed for the dissemination of malicious propaganda
   and manipulation of public opinion, wield significant influence in
   social media spheres with far-reaching implications for electoral
   processes, political campaigns, and international conflicts. Swift and
   accurate identification of inorganic accounts is of paramount importance
   in mitigating their detrimental effects. This research article focuses
   on the identification of such accounts and explores various effective
   methods for their detection through machine learning techniques. In
   response to the pervasive presence of bots in the contemporary digital
   landscape, this study extracts temporal and semantic features from tweet
   behaviors and proposes a bot detection framework using fundamental
   machine learning approaches, including support vector machines (SVMs)
   and k-means clustering. Furthermore, the research ranks the importance
   of these extracted features for each detection technique and also
   provides uncertainty quantification using a distribution-free method,
   called the conformal prediction, thereby contributing to the development
   of effective strategies for combating the prevalence of inorganic
   accounts in social media platforms.},
Type = {Article; Early Access},
Affiliation = {Ghosh, D (Corresponding Author), Kennesaw State Univ, Dept Data Sci \& Analyt, Marietta, GA 30060 USA.
   Ghosh, Dhrubajyoti, Kennesaw State Univ, Dept Data Sci \& Analyt, Marietta, GA 30060 USA.
   Boettcher, William, North Carolina State Univ, Humanities \& Social Sci, Raleigh, NC 27606 USA.
   Johnston, Rob, North Carolina State Univ, Sch Publ \& Int Affairs, Raleigh, NC 27606 USA.
   Lahiri, Soumendra, Washington Univ, Dept Stat \& Data Sci, St Louis, MO 63130 USA.},
DOI = {10.1109/TCSS.2026.3659065},
EarlyAccessDate = {FEB 2026},
Keywords = {Chatbots; Feature extraction; Social networking (online); Semantics;
   Machine learning; Blogs; Uncertainty; History; Support vector machines;
   Robustness; Bots; conformal prediction; inorganic accounts; organic
   accounts; social media},
Author-Email = {dghosh3@kennesaw.edu
   william\_boettcher@ncsu.edu
   bejohnst@ncsu.edu
   s.lahiri@wustl.edu},
Number-of-Cited-References = {42},
