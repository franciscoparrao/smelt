   Meyer-Lindenberg, Andreas, Zent Inst Seel Gesundheit, D-6800 Mannheim, Germany.
   Barra, Vincent, Univ Blaise Pascal, CNRS, LIMOS, UMR 6158, Aubiere, France.},
DOI = {10.1002/hbm.20599},
