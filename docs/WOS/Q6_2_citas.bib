   Huber, Marco F., Fraunhofer Inst Mfg Engn \& Automat IPA, Nobelstr 12, Stuttgart, Germany.},
Keywords-Plus = {FEATURE-SELECTION; DENSITY-FUNCTION; RANDOM SEARCH; GRID SEARCH;
   CLASSIFICATION; ALGORITHM; OPTIMIZATION; PARAMETERS},
Author-Email = {MARC.ZOELLER@USU.COM
   MARCO.HUBER@IEEE.ORG},
