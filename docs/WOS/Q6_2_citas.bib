@article{ WOS:000076031300020,
Author = {Schindler, R and Vonach, R and Lendl, B and Kellner, R},
Title = {A rapid automated method for wine analysis based upon sequential
   injection (SI)-FTIR spectrometry},
Journal = {FRESENIUS JOURNAL OF ANALYTICAL CHEMISTRY},
Year = {1998},
Volume = {362},
Number = {1},
Pages = {130-136},
Month = {SEP},
Abstract = {A new process control methodology for the simultaneous determination of
   sugars, alcohols and organic acids in wine based on multivariate
   evaluation of mid-IR transmission spectra of wine samples is presented.
   In addition to ethanol several lower level wine components (glucose,
   fructose, glycerol, citric-, tartaric-, malic-, lactic- and acetic acid)
   were determined. To establish a multivariate calibration model a set of
   72 calibration solutions was prepared and measured, using a novel, fully
   automated sequential injection (SI) system with Fourier transform
   infrared (FTIR) detection. The resulting spectra were evaluated using a
   partial least square (PLS) model. The developed PLS model was then
   applied to the analysis of real wine samples containing 79-91 g L-1
   ethanol, 5.9-8.1 g L-1 glycerol, 0.4-6.9 g L-1 glucose, 1.5-7.5 g L-1
   fructose, 0.3-1.6 g L-1 citric acid, 1.0-1.7 g L-1 tartaric acid,
   0.02-3.2 g L-1 malic acid, 0.4-2.8 g L-1 lactic acid and 0.15-0.60 g L-1
   acetic acid, yielding results which were in good agreement with those
   obtained by an external reference method (HPLC-IR). The short analysis
   time (less than 3 min) together with high reproducibility makes the
   newly developed method applicable to process control and screening
   purposes (average of the standard deviations calculated from four
   repetitive measurements of six different real samples: ethanol: 0.55 g
   L-1, glycerol: 0.037 g L-1, glucose: 0.056 g L-1, fructose: 0.036 g L-1,
   citric acid: 0.020 g L-1, tartaric acid: 0.010 g L-1, malic acid: 0.052
   g L-1, lactic acid: 0.012 g L-1 and acetic acid: 0.026 g L-1).},
Type = {Article},
Affiliation = {Lendl, B (Corresponding Author), Vienna Tech Univ, Inst Analyt Chem, Getreidemarkt 9-151, A-1060 Vienna, Austria.
   Vienna Tech Univ, Inst Analyt Chem, A-1060 Vienna, Austria.},
DOI = {10.1007/s002160051045},
Keywords-Plus = {TRANSFORM INFRARED SPECTROMETRY; QUANTITATIVE-ANALYSIS; FLOW-INJECTION;
   MULTIVARIATE CALIBRATION},
Number-of-Cited-References = {17},
Times-Cited = {47},
Unique-ID = {WOS:000076031300020},
}

@article{ WOS:A1991FD46300007,
Author = {UHE, AM and COLLIER, GR and MCLENNAN, EA and TUCKER, DJ and ODEA, K},
Title = {QUANTITATION OF TRYPTOPHAN AND OTHER PLASMA AMINO-ACIDS BY AUTOMATED
   PRECOLUMN ORTHO-PHTHALDIALDEHYDE DERIVATIZATION HIGH-PERFORMANCE
   LIQUID-CHROMATOGRAPHY - IMPROVED SAMPLE PREPARATION},
Journal = {JOURNAL OF CHROMATOGRAPHY-BIOMEDICAL APPLICATIONS},
Year = {1991},
Volume = {564},
Number = {1},
Pages = {81-91},
Month = {MAR 8},
Abstract = {Pre-column derivatization with omicron-phthaldialdehyde is a rapid and
   sensitive method for the quantitation of amino acids in biological
   fluids.  This method uses acetonitrile as a deproteinizing reagent which
   gives improved recovery of tryptophan compared with 5-sulfosalicylic
   acid and permits the measurement of aspartic acid which coelutes with
   5-sulfosalicylic acid.  The method is automated to increase
   reproducibility and convenience.  Mean coefficients of variation for
   peak areas relative to internal standard were 3.2 and 5.2\% for amino
   acid standards and plasma samples, respectively.  The presence of
   nitrilotriacetic acid stabilized the omicron-phthaldialdehyde reagent
   which is important in an automated system.  The method is suitable for
   the analysis of large numbers of plasma samples where total tryptophan
   and aspartic acid are of interest.},
Type = {Article},
Affiliation = {UHE, AM (Corresponding Author), DEAKIN UNIV,DEPT HUMAN NUTR,GEELONG,VIC 3217,AUSTRALIA.
   DEAKIN UNIV,DEPT CHEM \& ANALYT SCI,GEELONG,VIC 3217,AUSTRALIA.},
