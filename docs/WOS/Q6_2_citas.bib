   Sobottke, R., Med Zentrum StadteReg Aachen, Dept Orthopaed, Ctr Orthopaed \& Trauma Surg, D-52146 Wurselen, Germany.
   Franklin, J., Univ Cologne, Inst Med Stat Informat \& Epidemiol, D-50931 Cologne, Germany.
   Eysel, P., Univ Cologne, Dept Orthopaed \& Trauma Surg, D-50931 Cologne, Germany.},
DOI = {10.1007/s00586-013-2693-9},
Keywords = {Cobb angle; Idiopathic scoliosis; Systematic review; Reproducibility;
   Measuring methods; Computer-assisted measuring},
Keywords-Plus = {RELIABILITY; INTRAOBSERVER; RADIOGRAPHS; AGREEMENT; IMAGES},
Author-Email = {sina.langensiepen@uk-koeln.de},
Number-of-Cited-References = {28},
