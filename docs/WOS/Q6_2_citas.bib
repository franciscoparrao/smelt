   CSIRO, Marine Res, Hobart, Tas 7001, Australia.},
DOI = {10.1016/S0039-9140(02)00428-9},
Article-Number = {PII S0039-9140(02)00428-9},
Keywords = {reagent injection; reverse FIA; seawater; phosphorus; photometric
   detection; tangential flow filtration},
Keywords-Plus = {PHOSPHORUS},
Number-of-Cited-References = {30},
Times-Cited = {62},
