   Warren, Robin, Univ Stellenbosch, MRC Ctr Mol \& Cellular Biol, DST NRF Ctr Excellence Biomed TB Res, ZA-7600 Stellenbosch, South Africa.
   Dheda, Keertan, Univ Cape Town, Inst Infect Dis \& Mol Med, ZA-7925 Cape Town, South Africa.
   Dheda, Keertan, UCL, Sch Med, Dept Infect, London W1N 8AA, England.},
DOI = {10.1371/journal.pone.0028815},
Article-Number = {e28815},
Keywords-Plus = {PULMONARY TUBERCULOSIS; RIFAMPIN RESISTANCE; LIQUID CULTURE; TIME; PCR;
   INFECTION; IMMUNITY; GROWTH; AGENTS; ASSAY},
Author-Email = {keertan.dheda@uct.ac.za},
Number-of-Cited-References = {27},
