   Hunter, R.; Jones, D.; Boubertakh, R.; Petersen, S. E.; Schilling, R., Univ London, William Harvey Res Inst, Barts \& London NIHR Cardiovasc Biomed Res Unit, London WC1E 7HU, England.},
DOI = {10.1016/j.hrthm.2013.04.030},
Keywords = {Atrial fibrillation; Delayed-enhancement magnetic resonance imaging;
