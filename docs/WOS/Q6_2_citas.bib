DOI = {10.1109/TMI.2008.2004401},
Keywords = {Active contours; active shape models (ASMs); computer aided diagnosis
   (CAD); radiology; rheumatoid arthritis (RA)},
Keywords-Plus = {COMPUTERIZED IMAGE-ANALYSIS; HAND RADIOGRAPHS; METHOTREXATE; WIDTH;
