Journal = {PROTEIN SCIENCE},
Year = {1992},
Volume = {1},
Number = {9},
Pages = {1215-1224},
Month = {SEP},
Abstract = {Greatly reduced automated protein sequencing degradation times of less
   than 25 min with concurrent on-line phenylthiohydantoin (PTH) derivative
   analysis times of less than 16 min have been achieved by using a
   miniaturized reaction cartridge with optimized chemical and analytical
   cycles. Using this method a wide range of standard and novel peptides
   and proteins have been sequenced with reproducibly high initial and
   repetitive cycle yields. In these accelerated analyses the recovery of
   the more labile PTH derivatives was markedly improved by using elevated
   pressure during cleavage steps and temperature programming throughout
   the Edman cycle.},
