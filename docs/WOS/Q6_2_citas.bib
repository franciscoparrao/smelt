   Peng, Haiyun; Satapathy, Ranjan; Cambria, Erik, Nanyang Technol Univ, Sch Comp Sci \& Engn, 50 Nanyang Ave, Singapore, Singapore.},
Keywords = {Multilingual Sentiment Analysis; Commonsense Knowledge},
