   Russo, P.; Ross, M. M.; Liotta, L.; Petricoin, E., George Mason Univ, Fairfax, VA 22030 USA.
   Zhang, H.; Tian, Y.; Chan, D. W., Johns Hopkins Univ, Baltimore, MD USA.
   Kulasingam, V.; Drabovich, A. P.; Smith, C.; Batruch, I.; Diamandis, E. P., Univ Toronto, Mt Sinai Hosp, Toronto, ON M5G 1X5, Canada.},
DOI = {10.1021/pr100821m},
Keywords = {SRM; MRM; mass spectrometry; proteomics},
Keywords-Plus = {PROSTATE-SPECIFIC ANTIGEN; MULTIPLEXED ASSAYS; PROTEINS; PLASMA;
