   Carland, Tristan M., J Craig Venter Inst, Dept Human Biol, La Jolla, CA 92037 USA.},
DOI = {10.1093/bioinformatics/btv061},
Keywords-Plus = {DIFFERENTIAL EXPRESSION ANALYSIS; BIOCONDUCTOR PACKAGE; GENE; TOOL},
Author-Email = {kfisch@ucsd.edu
   asu@scripps.edu},
