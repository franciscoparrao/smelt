}

@article{ WOS:A1994NH28100007,
Author = {PICHON, V and HENNION, MC},
Title = {DETERMINATION OF PESTICIDES IN ENVIRONMENTAL WATERS BY AUTOMATED ONLINE
   TRACE-ENRICHMENT AND LIQUID-CHROMATOGRAPHY},
Journal = {JOURNAL OF CHROMATOGRAPHY A},
Year = {1994},
Volume = {665},
Number = {2},
Pages = {269-281},
Month = {APR 15},
Abstract = {Automated on-line trace-enrichment, liquid chromatographic analysis and
   UV diode-array detection (DAD) were investigated for the determination
   of pesticides at the 0.1 mu g/l level in drinking and surface waters.
   The selection of the preconcentration parameters (sorbent, sample
   volume, reproducibility) is discussed. Conditions are specified for
   quantification methods such as using calibration graphs constructed with
   spiked samples, standard addition methods and a calculation method
   included in the DAD software depending on the sample nature. Detection
   limits of 0.1 mu g/l were obtained using 150 ml of river waters without
   any clean-up.},
Type = {Article; Proceedings Paper},
Affiliation = {ECOLE SUPER PHYS \& CHIM IND VILLE PARIS,CHIM ANALYT LAB,CNRS,URA 437,F-75231 PARIS 05,FRANCE.},
