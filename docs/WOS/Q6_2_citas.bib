   Lindegaard, Jacob Christian, Aarhus Univ Hosp, Dept Oncol, DK-8000 Aarhus C, Denmark.},
DOI = {10.1118/1.3063006},
Keywords = {alumina; biomedical equipment; brachytherapy; cancer; carbon;
