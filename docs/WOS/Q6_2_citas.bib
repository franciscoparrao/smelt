@article{ WOS:000406558700004,
Author = {Wegner, Kyle A. and Keikhosravi, Adib and Eliceiri, Kevin W. and Vezina,
   Chad M.},
Title = {Fluorescence of Picrosirius Red Multiplexed With Immunohistochemistry
   for the Quantitative Assessment of Collagen in Tissue Sections},
Journal = {JOURNAL OF HISTOCHEMISTRY \& CYTOCHEMISTRY},
Year = {2017},
Volume = {65},
Number = {8},
Pages = {479-490},
Month = {AUG},
Abstract = {The low cost and simplicity of picrosirius red (PSR) staining have
   driven its popularity for collagen detection in tissue sections. We
   extended the versatility of this method by using fluorescent imaging to
   detect the PSR signal and applying automated quantification tools. We
   also developed the first PSR protocol that is fully compatible with
   multiplex immunostaining, making it possible to test whether collagen
   structure differs across immunohistochemically labeled regions of the
   tissue landscape. We compared our imaging method with two gold standards
   in collagen imaging, linear polarized light microscopy and second
   harmonic generation imaging, and found that it is at least as sensitive
   and robust to changes in sample orientation. As proof of principle, we
   used a genetic approach to overexpress beta catenin in a patchy subset
   of mouse prostate epithelial cells distinguished only by immunolabeling.
   We showed that collagen fiber length is significantly greater near beta
   catenin overexpressing cells than near control cells. Our fluorescent
   PSR imaging method is sensitive, reproducible, and offers a new way to
   guide region of interest selection for quantifying collagen in tissue
   sections.},
Type = {Article},
Affiliation = {Vezina, CM (Corresponding Author), Univ Wisconsin, Dept Comparat Biosci, Hanson Labs, 1656 Linden Dr, Madison, WI 53706 USA.
   Wegner, Kyle A., Univ Wisconsin, Mol \& Environm Toxicol Ctr, Madison, WI 53706 USA.
   Keikhosravi, Adib; Eliceiri, Kevin W., Morgridge Inst Res, Dept Biomed Engn, Madison, WI USA.
   Keikhosravi, Adib; Eliceiri, Kevin W., Morgridge Inst Res, Lab Opt \& Computat Instrumentat, Madison, WI USA.
