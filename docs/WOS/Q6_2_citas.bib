   Farhadi, Jian, St Thomas Hosp, Dept Plast Surg, London, England.
   Bula, Sylvain, Biosafe Grp SA, Eysins, Switzerland.},
DOI = {10.1089/ten.tec.2011.0617},
Keywords-Plus = {MESENCHYMAL STEM-CELLS; STROMAL CELLS; BONE-MARROW; PROGENITORS; SYSTEM;
   THERAPIES; CAPACITY; CULTURE; GRAFTS},
