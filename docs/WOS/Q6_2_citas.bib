DOI = {10.1148/radiol.2513081313},
Keywords-Plus = {POSITRON-EMISSION-TOMOGRAPHY; COMPUTED-TOMOGRAPHY; VARIABILITY;
   REPRODUCIBILITY; PERFORMANCE; ACCURACY; PHANTOM; LESIONS; BENIGN},
Author-Email = {alfonso.marchiano@istitutotumori.mi.it},
