   UNIV CALIF LOS ANGELES,SCH MED,DEPT RADIOL SCI,LOS ANGELES,CA 90024.
   UNIV CALIF LOS ANGELES,SCH MED,DEPT MED,LOS ANGELES,CA 90024.},
DOI = {10.1023/A:1005815206195},
Keywords = {gated myocardial perfusion SPECT; automatic quantification; regional
   wall motion and thickening},
Keywords-Plus = {CORONARY-ARTERY DISEASE; EMISSION COMPUTED-TOMOGRAPHY; LEFT-VENTRICULAR
   FUNCTION; TRANSIENT ISCHEMIC DILATION; LUNG UPTAKE;
   TECHNETIUM-99M-SESTAMIBI SPECT; TL-201 SCINTIGRAPHY; EJECTION FRACTION;
   TC-99M SESTAMIBI; STRESS},
