   Pernot, Petra; McSweeney, Sean, ESRF, F-38000 Grenoble, France.},
DOI = {10.1107/S1399004714026959},
Keywords = {small-angle X-ray scattering; BioSAXS Sample Changer; high-throughput;
   automation},
