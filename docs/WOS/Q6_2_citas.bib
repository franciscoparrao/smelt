Keywords-Plus = {CARDIOVASCULAR MAGNETIC-RESONANCE; VEIN ANTRUM ISOLATION; CATHETER
   ABLATION; PULMONARY VEIN; FIBRILLATION; SCAR; MRI; EXTENT},
Author-Email = {n.peters@imperial.ac.uk},
Number-of-Cited-References = {27},
Times-Cited = {122},
