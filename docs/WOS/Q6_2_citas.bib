@article{ WOS:000368688600002,
Author = {Jansen, Jesper and Schreurs, Ruud and Dubois, Leander and Maal, Thomas
   J. J. and Gooris, Peter J. J. and Becking, Alfred G.},
Title = {Orbital volume analysis: validation of a semi-automatic software
   segmentation method},
Journal = {INTERNATIONAL JOURNAL OF COMPUTER ASSISTED RADIOLOGY AND SURGERY},
Year = {2016},
Volume = {11},
Number = {1},
Pages = {11-18},
Month = {JAN},
Abstract = {The purpose of this study was to validate a quick, accurate and
   reproducible (semi-) automatic software segmentation method to measure
   orbital volume in the unaffected bony orbit. Precise volume measurement
   of the orbital cavity is a useful addition to pre-operative planning and
   intraoperative navigation in orbital reconstruction.
   In 21 CT scans, one unaffected orbit was selected to compare manual
   segmentation (gold standard) with three segmentation methods using iPlan
   software (version 3.0.5; Brainlab, Feldkirchen, Germany): automatic
   (method A), automatic minus bone/air masks (method SA) and automatic
   minus masks followed by manual adjustments (method SAA). First,
   validation of the manual segmentation and a newly described method for
   the anterior boundary was performed. Subsequently the accuracy,
   reproducibility and time efficiency of the methods were examined.
   Measurements were performed by two observers.
   The intraclass correlation for the interobserver agreement of the
   anterior boundary was 0.992, and the intraobserver and interobserver
   agreement for the manual segmentation were 0.997 and 0.994,
   respectively. Method A had an average volumetric difference of 0.49 cc
   (SD 0.74) in comparison with the gold standard; this was 0.24 cc (SD
   0.27) for method SA and 0.86 cc (SD 0.27) for method SAA. The average
   time for each method was 38 (SD 5.4), 146 (SD 16.0) and 327 (SD 36.2)
   seconds per orbit.
   The built-in automatic method A is quick, but suboptimal for clinical
   use. The newly developed method SA appears to be accurate, reproducible,
   quick and easy to use. Manual adjustments in method SAA are more
   time-consuming and do not improve volume accuracy. The largest volume
   discrepancy is located near the inferior orbital fissure.},
Type = {Article},
Affiliation = {Jansen, J (Corresponding Author), Univ Amsterdam, Acad Med Ctr, Dept Oral \& Maxillofacial Surg, Orbital Unit, Meibergdreef 9, NL-1105 AZ Amsterdam, Netherlands.
   Jansen, Jesper; Schreurs, Ruud; Dubois, Leander; Maal, Thomas J. J.; Gooris, Peter J. J.; Becking, Alfred G., Univ Amsterdam, Acad Med Ctr, Dept Oral \& Maxillofacial Surg, Orbital Unit, Meibergdreef 9, NL-1105 AZ Amsterdam, Netherlands.
   Schreurs, Ruud; Maal, Thomas J. J., Radboud Univ Nijmegen, Med Ctr, Dept Oral \& Maxillofacial Surg, NL-6525 ED Nijmegen, Netherlands.},
DOI = {10.1007/s11548-015-1254-6},
Keywords = {Orbital volume measurement; Pre-operative planning; Orbital fractures;
   Orbital reconstruction; Validation; Segmentation},
Keywords-Plus = {LATE ENOPHTHALMOS; RECONSTRUCTION; CT; PREDICTION},
Author-Email = {j.jansen@amc.uva.nl},
Number-of-Cited-References = {27},
