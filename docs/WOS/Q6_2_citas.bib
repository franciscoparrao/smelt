   Yu, Guodong; Hautier, Geoffroy, Catholic Univ Louvain, Inst Condensed Matter \& Nanosci IMCN, B-1348 Louvain La Neuve, Belgium.},
DOI = {10.1016/j.cpc.2018.01.004},
