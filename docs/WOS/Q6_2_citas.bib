@article{ WOS:000457396100035,
Author = {Joskowicz, Leo and Cohen, D. and Caplan, N. and Sosna, J.},
Title = {Inter-observer variability of manual contour delineation of structures
   in CT},
Journal = {EUROPEAN RADIOLOGY},
Year = {2019},
Volume = {29},
Number = {3},
Pages = {1391-1399},
Month = {MAR},
Abstract = {PurposeTo quantify the inter-observer variability of manual delineation
   of lesions and organ contours in CT to establish a reference standard
   for volumetric measurements for clinical decision making and for the
   evaluation of automatic segmentation algorithms.Materials and
   methodsEleven radiologists manually delineated 3193 contours of liver
   tumours (896), lung tumours (1085), kidney contours (434) and brain
   hematomas (497) on 490 slices of clinical CT scans. A comparative
   analysis of the delineations was then performed to quantify the
   inter-observer delineation variability with standard volume metrics and
   with new group-wise metrics for delineations produced by groups of
   observers.ResultsThe mean volume overlap variability values and ranges
   (in \%) between the delineations of two observers were: liver tumours
   17.8 {[}-5.8,+7.2]\%, lung tumours 20.8 {[}-8.8,+10.2]\%, kidney
   contours 8.8 {[}-0.8,+1.2]\% and brain hematomas 18 {[}-6.0,+6.0] \%.
   For any two randomly selected observers, the mean delineation volume
   overlap variability was 5-57\%. The mean variability captured by groups
   of two, three and five observers was 37\%, 53\% and 72\%; eight
   observers accounted for 75-94\% of the total variability. For all cases,
   38.5\% of the delineation non-agreement was due to parts of the
   delineation of a single observer disagreeing with the others. No
   statistical difference was found for the delineation variability between
   the observers based on their expertise.ConclusionThe variability in
   manual delineations for different structures and observers is large and
   spans a wide range across a variety of structures and pathologies. Two
   and even three observers may not be sufficient to establish the full
   range of inter-observer variability.Key Points center dot This study
   quantifies the inter-observer variability of manual delineation of
   lesions and organ contours in CT.center dot The variability of manual
   delineations between two observers can be significant. Two and even
   three observers capture only a fraction of the full range of
   inter-observer variability observed in common practice.center dot
   Inter-observer manual delineation variability is necessary to establish
   a reference standard for radiologist training and evaluation and for the
   evaluation of automatic segmentation algorithms.},
Type = {Article},
Affiliation = {Joskowicz, L (Corresponding Author), Hebrew Univ Jerusalem, Rachel \& Selim Benin Sch Comp Sci \& Engn, Edmond J Safra Campus, IL-9190401 Jerusalem, Israel.
   Joskowicz, Leo; Cohen, D., Hebrew Univ Jerusalem, Rachel \& Selim Benin Sch Comp Sci \& Engn, Edmond J Safra Campus, IL-9190401 Jerusalem, Israel.
   Caplan, N.; Sosna, J., Hadassah Hebrew Univ Med Ctr, Dept Radiol, Jerusalem, Israel.},
DOI = {10.1007/s00330-018-5695-5},
Keywords = {Humans; Observer variation; Reproducibility of results},
Keywords-Plus = {PERFORMANCE; VOLUMETRY},
Author-Email = {josko@cs.huji.ac.il},
Number-of-Cited-References = {16},
Times-Cited = {202},
Unique-ID = {WOS:000457396100035},
}

@article{ WOS:000249488500012,
Author = {Engel, Bernard and Storm, Dan and White, Mike and Arnold, Jeff and
   Arabi, Mazdak},
Title = {A hydrologic/water quality model application protocol},
Journal = {JOURNAL OF THE AMERICAN WATER RESOURCES ASSOCIATION},
Year = {2007},
Volume = {43},
Number = {5},
Pages = {1223-1236},
Month = {OCT},
Abstract = {This paper presents a procedure for standard application of hydrologic /
   water quality models. To date, most hydrologic / water quality modeling
   projects and studies have not utilized formal protocols, but rather have
   employed ad hoc approaches. The procedure proposed is an adaptation and
   extension of steps identified from relevant literature including
   guidance provided by the U. S. Environmental Protection Agency. This
   protocol provides guidance for establishing written plans prior to
   conducting modeling efforts. Eleven issues that should be addressed in
   model application plans were identified and discussed in the context of
   hydrologic / water quality studies. A graded approach for selection of
   the level of documentation for each item was suggested. The creation and
   use of environmental modeling plans is increasingly important as the
   results of modeling projects are used in decision- making processes that
   have significant implications. Standard modeling application protocols
   similar to the proposed procedure herein provide modelers with a roadmap
   to be followed, reduces modelers' bias, enhances the reproducibility of
   model application studies, and eventually improves acceptance of
   modeling outcomes.},
Type = {Article},
Affiliation = {Engel, B (Corresponding Author), Purdue Univ, 225 S Univ St, W Lafayette, IN 47907 USA.
   Purdue Univ, W Lafayette, IN 47907 USA.
   Oklahoma State Univ, Stillwater, OK 74078 USA.
   USDA ARS, Temple, TX 76502 USA.},
DOI = {10.1111/j.1752-1688.2007.00105.x},
Keywords = {simulation; quality assurance/quality control; runoff; nonpoint source
   pollution},
Keywords-Plus = {AUTOMATIC CALIBRATION; RIVER-BASIN; SWAT; UNCERTAINTY; VARIABILITY;
   VALIDATION; WATERSHEDS; IMPACTS; POINT},
Author-Email = {engelb@purdue.edu},
