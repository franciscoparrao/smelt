Title = {Progress on Software Verification: SV-COMP 2022},
Booktitle = {TOOLS AND ALGORITHMS FOR THE CONSTRUCTION AND ANALYSIS OF SYSTEMS, TACAS
   2022, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2022},
Volume = {13244},
Pages = {375-402},
Abstract = {The 11th edition of the Competition on Software Verification (SV-COMP
   2022) provides the largest ever overview of tools for software
   verification. The competition is an annual comparative evaluation of
   fully automatic software verifiers for C and Java programs. The
   objective is to provide an overview of the state of the art in terms of
   effectiveness and efficiency of software verification, establish
   standards, provide a platform for exchange to developers of such tools,
   educate PhD students on reproducibility approaches and benchmarking, and
   provide computing resources to developers that do not have access to
   compute clusters. The competition consisted of 15 648 verification tasks
   for C programs and 586 verification tasks for Java programs. Each
   verification task consisted of a program and a property (reachability,
   memory safety, overflows, termination). The new category on data-race
   detection was introduced as demonstration category. SV-COMP 2022 had 47
   participating verification systems from 33 teams from 11 countries.},
Type = {Proceedings Paper},
Affiliation = {Beyer, D (Corresponding Author), Ludwig Maximilians Univ Munchen, Munich, Germany.
