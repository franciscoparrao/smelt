}

@article{ WOS:000180382100009,
Author = {Wada, M and Kuroiwa, J and Nara, S},
Title = {Completely reproducible description of digital sound data with cellular
   automata},
Journal = {PHYSICS LETTERS A},
Year = {2002},
Volume = {306},
Number = {2-3},
Pages = {110-115},
Month = {DEC 30},
Abstract = {A novel method of compressive and completely reproducible description of
   digital sound data by means of rule dynamics of CA (cellular automata)
   is proposed. The digital data of spoken words and music recorded with
   the standard format of a compact disk are reproduced completely by this
   method with use of only two rules in a one-dimensional CA without loss
