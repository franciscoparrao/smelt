@article{ WOS:A1985ABR6300033,
Author = {BAYFIELD, RF and ROMALIS, LF},
Title = {PH CONTROL IN THE FLUOROMETRIC ASSAY FOR SELENIUM WITH
   2,3-DIAMINONAPHTHALENE},
Journal = {ANALYTICAL BIOCHEMISTRY},
Year = {1985},
Volume = {144},
Number = {2},
Pages = {569-576},
Abstract = {Inconsistencies in reproducibility and duplication in the fluorometric
   assay of Se in biological materials with 2,3-diaminonaphthalene (DAN)
   were investigated. These were attributed to inadequate pH control in the
   reaction mixture following acid digestion of samples and preceding
   formation of the piazselenol complex. The problems were overcome by
   using methyl orange as an internal indicator to establish an initial pH
   of .apprx. 3 and, after addition of the DAN reagent in 0.1 N HCl, a
   final pH of  1.8. Formation of the DAN-selenol complex at this pH gave
   maximum fluorescence response measured in cyclohexane extracts of the
   reaction mixture. Use of a single tube for the digestion and extraction
   procedures, followed by automatic sampling of the cyclohexane extract
   and printout of fluorescence intensities, provided a simple method of
   analysis capable of handling 150 tubes simultaneously. Analyzed by the
   method described, Se standards gave consistently acceptable results (r =
   0.9995, P < 0.001, CV 2.3-3.3); Standard Reference Liver gave values of
   1159 .+-. 34.7 ng/g, which compared favorably with the published value
   of 1100 .+-. 100 ng/g; and recoveries of Se from animal blood and liver
   varied from 96-104\%.},
Type = {Article},
Affiliation = {NEW S WALES DEPT AGR, CENT VET LAB, GLENFIELD, NSW 2167, AUSTRALIA.},
DOI = {10.1016/0003-2697(85)90155-1},
Number-of-Cited-References = {30},
Times-Cited = {47},
Unique-ID = {WOS:A1985ABR6300033},
}

@article{ WOS:001164830900015,
Author = {Lerner, Raissa and Baker, Dhanwin and Schwitter, Claudia and Neuhaus,
   Sarah and Hauptmann, Tony and Post, Julia M. and Kramer, Stefan and
   Bindila, Laura},
Title = {Four-dimensional trapped ion mobility spectrometry lipidomics for high
   throughput clinical profiling of human blood samples},
Journal = {NATURE COMMUNICATIONS},
Year = {2023},
Volume = {14},
Number = {1},
Month = {DEC 7},
Abstract = {Lipidomics encompassing automated lipid extraction, a four-dimensional
   (4D) feature selection strategy for confident lipid annotation aswell as
   reproducible and cross-validated quantification can expedite clinical
   profiling. Here, we determine 4D descriptors (mass to charge, retention
   time, collision cross section, and fragmentation spectra) of 200 lipid
   standards and 493 lipids from reference plasma via trapped ion mobility
   mass spectrometry to enable the implementation of stringent criteria for
   lipid annotation. We use 4D lipidomics to confidently annotate 370
   lipids in reference plasma samples and 364 lipids in serum samples, and
   reproducibly quantify 359 lipids using level-3 internal standards. We
   show the utility of our 4D lipidomics workflow for highthroughput
   applications by reliable profiling of intra-individual lipidome
   phenotypes in plasma, serum, whole blood, venous and finger-prick dried
   blood spots.},
Type = {Article},
Affiliation = {Bindila, L (Corresponding Author), Univ Med Ctr, Inst Physiol Chem, Clin Lipid Unit, Duesbergweg 6, D-55128 Mainz, Germany.
   Lerner, Raissa; Baker, Dhanwin; Schwitter, Claudia; Neuhaus, Sarah; Post, Julia M.; Bindila, Laura, Univ Med Ctr, Inst Physiol Chem, Clin Lipid Unit, Duesbergweg 6, D-55128 Mainz, Germany.
   Hauptmann, Tony; Kramer, Stefan, Johannes Gutenberg Univ Mainz, Inst Comp Sci, Data Min, Staudingerweg 9, D-55128 Staudingerweg, Germany.},
DOI = {10.1038/s41467-023-36520-1},
Article-Number = {937},
Keywords-Plus = {CORONARY-ARTERY-DISEASE; MASS-SPECTROMETRY; QUANTIFICATION; LIPIDS},
