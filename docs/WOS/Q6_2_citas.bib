@article{ WOS:000239973800007,
Author = {Rusjan, Pablo and Mamo, David and Ginovart, Nathalie and Hussey, Douglas
   and Vitcu, Irina and Yasuno, Fumihiko and Tetsuya, Suhara and Houle,
   Sylvain and Kapur, Shitij},
Title = {An automated method for the extraction of regional data from PET images},
Journal = {PSYCHIATRY RESEARCH-NEUROIMAGING},
Year = {2006},
Volume = {147},
Number = {1},
Pages = {79-89},
Month = {JUN 30},
Abstract = {Manual drawing of regions of interest (ROIs) on brain positron emission
   tomography (PET) images is labour intensive and subject to intra- and
   inter-individual variations. To standardize analysis and improve the
   reproducibility of PET measures, we have developed image analysis
   software for automated quantification of PET data. The method is based
   on the individualization of a set of standard ROIs using a magnetic
   resonance (MR) image co-registered with the PET image. To evaluate the
   performance of this automated method, the software-based quantification
   has been compared with conventional manual quantification of PET images
   obtained using three different PET radiotracers: {[}C-11]-WAY 100635,
   {[}C-11]-raclopride and {[}C-11]-DASB. Our results show that binding
   potential estimates obtained using the automated method correlate highly
   with those obtained by trained raters using manual delineation of ROIs
   for frontal and temporal cortex, thalamus, and striatum (global
   intraclass correlation coefficient > 0.8). For the three radioligands,
   the software yields time-activity data that are similar (within 8\%) to
   those obtained by manual quantification, eliminates
   investigator-dependent variability, considerably shortens the time
   required for analysis and thus provides an alternative method for
   accurate quantification of PET data. (c) 2006 Elsevier Ireland Ltd. All
   rights reserved.},
Type = {Article},
Affiliation = {Rusjan, P (Corresponding Author), PET Ctr, Ctr Addict \& Mental Hlth, 250 Coll St, Toronto, ON M5T 1R8, Canada.
   PET Ctr, Ctr Addict \& Mental Hlth, Toronto, ON M5T 1R8, Canada.
   Univ Toronto, Dept Psychiat, Toronto, ON, Canada.
   Natl Inst Radiol Sci, Brain Imaging Project, Chiba 260, Japan.},
DOI = {10.1016/j.pscychresns.2006.01.011},
Keywords = {PET; time-activity curves; brain template; region of interest; automated
   method; binding potential},
Keywords-Plus = {HUMAN BRAIN; INTRACLASS CORRELATIONS; MULTIPLE VOLUMES; ATLAS;
   REGISTRATION; TEMPLATE; MODEL},
