   Stasi, Michele, IRCCS, Candiolo Canc Inst FPO, Dept Med Phys, I-10060 Candiolo, Italy.},
DOI = {10.1016/j.compmedimag.2015.09.001},
Keywords = {Prostate cancer; Multiparametric MRI; Computer aided detection; Image
   analysis; SVM classifier},
Keywords-Plus = {CONTRAST; DIFFUSION; MRI},
Author-Email = {valentina.giannini@ircc.it},
Number-of-Cited-References = {40},
