@article{ WOS:000400719700040,
Author = {Salazar-Beltran, Daniel and Hinojosa-Reyes, Laura and Ruiz-Ruiz, Edgar
   and Hernandez-Ramirez, Aracely and Luis Guzman-Mar, Jorge},
Title = {Determination of phthalates in bottled water by automated on-line solid
   phase extraction coupled to liquid chromatography with uv detection},
Journal = {TALANTA},
Year = {2017},
Volume = {168},
Pages = {291-297},
Month = {JUN 1},
Abstract = {An on-line solid phase extraction coupled to liquid chromatography with
   UV detection (SPE/LC-UV) method was automated by the multisyringe
   flow-injection analysis (MSFIA) system for the determination of three
   phthalic acid esters (PAEs). The PAEs determined in drinking water
   stored in polyethylene terephthalate (PET) bottles of ten commercial
   brands were dimethyl phthalate (DMP), diethyl phthalate (DEP) and
   dibutyl phthalate (DBP). C18-bonded silica membrane was used for
   isolation and enrichment of the PAEs in water samples. The calibration
   range of the SPE/LC-UV method was 2.5-100 mu g L-1 for DMP and DEP and
   10-100 mu g L-1 for DBP with correlation coefficients (r) ranging from
   0.9970 to 0.9975. Limits of detection (LODs) were between 0.7 and 2.4 mu
   g L-1. Inter-day reproducibility performed at two concentration levels
   (10 and 100 mu g L-1) expressed as relative standard deviation (\%RSD)
   were found in the range of 0.9-4.0\%. The solvent volume was reduced to
   18 mL with a total analysis time of 48 min per sample. The major species
   detected in bottled water samples was DBP reaching concentrations
   between 20.5 and 82.8 mu g L-1. The recovery percentages for the three
   analytes in drinking water were 80-115\%. The migration test showed a
   great variation in the sum of migrated PAEs level (10.2-50.6 mu g L-1)
   among the PET bottle brands analyzed indicating that the presence of
   these contaminants in the plastic containers may depend on raw materials
   and the conditions used during their production process.},
Type = {Article},
Affiliation = {Guzmán-Mar, JL (Corresponding Author), UANL, Fac Ciencias Quim, Cd Univ, San Nicolas De Los Garza 66455, Nuevo Leon, Mexico.
   Salazar-Beltran, Daniel; Hinojosa-Reyes, Laura; Ruiz-Ruiz, Edgar; Hernandez-Ramirez, Aracely; Luis Guzman-Mar, Jorge, UANL, Fac Ciencias Quim, Cd Univ, San Nicolas De Los Garza 66455, Nuevo Leon, Mexico.},
DOI = {10.1016/j.talanta.2017.03.060},
Keywords = {Bottled water; Phthalates; On-line solid-phase extraction; MSPIA
   automation; LC-UV detection; Migration; PET containers},
Keywords-Plus = {ENVIRONMENTAL WATER; HPLC-UV; GC-MS; ESTERS; SAMPLES; MICROEXTRACTION;
   METABOLITES; URINE; MILK},
Author-Email = {jorge.guzmanmr@uanl.edu.mx},
Number-of-Cited-References = {35},
Times-Cited = {62},
Unique-ID = {WOS:000400719700040},
}

@article{ WOS:000372974300018,
Author = {Glaab, Enrico},
Title = {Building a virtual ligand screening pipeline using free software: a
   survey},
Journal = {BRIEFINGS IN BIOINFORMATICS},
Year = {2016},
Volume = {17},
Number = {2},
Pages = {352-366},
Month = {MAR},
Abstract = {Virtual screening, the search for bioactive compounds via computational
   methods, provides a wide range of opportunities to speed up drug
   development and reduce the associated risks and costs. While virtual
   screening is already a standard practice in pharmaceutical companies,
   its applications in preclinical academic research still remain
   under-exploited, in spite of an increasing availability of dedicated
   free databases and software tools. In this survey, an overview of recent
   developments in this field is presented, focusing on free software and
   data repositories for screening as alternatives to their commercial
   counterparts, and outlining how available resources can be interlinked
   into a comprehensive virtual screening pipeline using typical academic
   computing facilities. Finally, to facilitate the set-up of corresponding
   pipelines, a downloadable software system is provided, using platform
   virtualization to integrate pre-installed screening tools and scripts
   for reproducible application across different operating systems.},
Type = {Article},
Affiliation = {Glaab, E (Corresponding Author), Univ Luxembourg, Luxembourg Ctr Syst Biomed, 7 Ave Hauts Fourneaux, L-4362 Esch Sur Alzette, Luxembourg.
   Glaab, Enrico, Luxembourg Ctr Syst Biomed, Bioinformat, Luxembourg, Luxembourg.},
DOI = {10.1093/bib/bbv037},
Keywords = {virtual screening; docking; protein-ligand binding; ADMETox; off-target
   effects; workflow management},
Keywords-Plus = {EMPIRICAL SCORING FUNCTIONS; SMALL MOLECULE DOCKING; IN-SILICO
   PREDICTION; ULTRA EXPERT-SYSTEM; WEB SERVER; DRUG DESIGN; GENETIC
   ALGORITHM; BINDING-AFFINITY; CONFORMATIONAL SELECTION; RODENT
   CARCINOGENICITY},
