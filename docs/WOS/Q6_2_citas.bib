   Ostwald, Dirk, Free Univ Berlin, Ctr Cognit Neurosci Berlin, Berlin, Germany.
   Ostwald, Dirk, Max Planck Inst Human Dev, Ctr Adapt Rat, Berlin, Germany.},
DOI = {10.1371/journal.pbio.2006022},
