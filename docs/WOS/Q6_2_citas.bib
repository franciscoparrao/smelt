   Bozec, Erwan; Boutouyrie, Pierre; Laurent, Stephane, Georges Pompidou European Hosp, Paris, France.
   Giannarelli, Chiara; Ghiadoni, Lorenzo, Univ Pisa, Dept Internal Med, Pisa, Italy.},
DOI = {10.7863/jum.2010.29.8.1169},
Keywords = {B-mode; carotid stiffness; intima-media thickness; radio frequency echo
