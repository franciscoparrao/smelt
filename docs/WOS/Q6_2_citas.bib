   Tolone, Salvatore, 2nd Univ Napoli, Dept Surg, Gen \& Bariatr Surg Unit, Naples, Italy.
   Savarino, Vincenzo, Univ Genoa, Dept Internal Med, Gastroenterol Unit, Genoa, Italy.
   Savarino, Edoardo, Univ Padua, Dept Surg Oncol \& Gastroenterol, Gastroenterol Unit, Padua, Italy.},
DOI = {10.1007/s10620-017-4625-8},
Keywords = {GERD; NERD; PPI; Impedance-pH monitoring; Esophageal chemical clearance;
   PSPW index; Esophageal baseline impedance},
