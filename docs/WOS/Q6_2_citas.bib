   Univ Messina, Dipartimento MO BI FI PA, I-98168 Messina, Italy.
   Univ Messina, Dipartimento Chim Organ \& Biol, I-98166 Messina, Italy.},
DOI = {10.1002/ffj.1529},
Keywords = {goat cheese; cheese volatiles; headspace SPME; SPME method optimization;
   GC-MS},
Keywords-Plus = {SOLID-PHASE MICROEXTRACTION; VOLATILE COMPOUNDS; QUANTITATIVE-ANALYSIS;
   AROMA; MILK},
Author-Email = {lmondello@pharma.unime.it},
