@article{ WOS:000220618400025,
Author = {Sjödin, A and Jones, RS and Lapeza, CR and Focant, JF and McGahee, EE
   and Patterson, DG},
Title = {Semiautomated high-throughput extraction and cleanup method for the
   measurement of polybrominated diphenyl ethers, polybrominated biphenyls,
   and polychlorinated biphenyls in human serum},
Journal = {ANALYTICAL CHEMISTRY},
Year = {2004},
Volume = {76},
Number = {7},
Pages = {1921-1927},
Month = {APR 1},
Abstract = {A semiautomated extraction and cleanup method has been developed for the
   measurement of eight polybrominated diphenyl ethers (PBDEs),
   2,2',4,4',5,5'-hexabromobiphenyl (BB-153) and
   2,2',4,4',5,5'-hexachlorobiphenyl (CB-153). The method employs automated
   addition of internal standards (C-13-labeled), addition of formic acid
   (denaturation agent), and dilution with water prior to automated
   overnight extraction using a modular solid-phase extraction (SPE)
   system. Removal of coextracted biogenic materials was performed on a
   two-layered 3-mL disposable cartridge containing activated silica gel
   and a mixture of silica gel and sulfuric acid. Sample cleanup was
   automated using the same modular SPE system. Reproducibility and
   precision of the liquid handler used for internal standard additions
   were shown to be 2 and 4\%, respectively. Overall reproducibility during
   processing of eight batches of samples (N = 30/batch, including methods
   blanks) was below 10\% for most analytes. Mean recoveries of the
   C-13-labeled internal standards ranged from 69 to 95\% for the seven
   monitored PBDEs; 76 and 98\% were recovered for BB-153 and CB-153,
   respectively.},
Type = {Article},
Affiliation = {Sjödin, A (Corresponding Author), Ctr Dis Control \& Prevent, Natl Ctr Environm Hlth, Div Sci Lab, 4770 Buford Highway,NE Mail Stop F-17, Atlanta, GA 30341 USA.
   Ctr Dis Control \& Prevent, Natl Ctr Environm Hlth, Div Sci Lab, Atlanta, GA 30341 USA.},
