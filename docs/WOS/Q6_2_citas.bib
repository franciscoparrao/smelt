   Lund Univ, Dept Elect Measurements, S-22100 Lund, Sweden.
   Sahlgrens Univ Hosp, Dept Psychiat \& Neurochem, Inst Clin Neurosci, S-43180 Molndal, Sweden.
   AB Draco, Bioanalyt Chem, Preclin Res \& Dev, S-22100 Lund, Sweden.},
Keywords-Plus = {DESORPTION IONIZATION; FAST-EVAPORATION; PROTEINS; SENSITIVITY;
   RESOLUTION},
Number-of-Cited-References = {18},
