   de Pina, Maria de Fatima, Univ Porto, Dept Epidemiol Clin Med Predit \& Saude Publ, Fac Med, P-4100 Oporto, Portugal.},
DOI = {10.1371/journal.pone.0025045},
Article-Number = {e25045},
Keywords-Plus = {LATE GADOLINIUM ENHANCEMENT; STEM-CELLS; MYOCARDIAL-INFARCTION; GENE
   DELIVERY; MICE; MULTIPOTENT; RAT},
Author-Email = {perpetua@ineb.up.pt},
