}

@article{ WOS:000430366700001,
Author = {Kinjo, Sonoko and Monma, Norikazu and Misu, Sadahiko and Kitamura,
   Norikazu and Imoto, Junichi and Yoshitake, Kazutoshi and Gojobori,
   Takashi and Ikeo, Kazuho},
Title = {Maser: one-stop platform for NGS big data from analysis to visualization},
Journal = {DATABASE-THE JOURNAL OF BIOLOGICAL DATABASES AND CURATION},
Year = {2018},
Month = {APR 13},
Abstract = {A major challenge in analyzing the data from high-throughput
   next-generation sequencing < NGS > is how to handle the huge amounts of
   data and variety of NGS tools and visualize the resultant outputs. To
   address these issues, we developed a cloud-based data analysis platform,
   Maser < Management and Analysis System for Enormous Reads >, and an
   original genome browser, Genome Explorer < GE >. Maser enables users to
   manage up to 2 terabytes of data to conduct analyses with easy graphical
   user interface operations and offers analysis pipelines in which several
   individual tools are combined as a single pipeline for very common and
   standard analyses. GE automatically visualizes genome assembly and
   mapping results output from Maser pipelines, without requiring
   additional data upload. With this function, the Maser pipelines can
   graphically display the results output from all the embedded tools and
   mapping results in a web browser. Therefore Maser realized a more
   user-friendly analysis platform especially for beginners by improving
   graphical display and providing the selected standard pipelines that
   work with built-in genome browser. In addition, all the analyses
   executed on Maser are recorded in the analysis history, helping users to
   trace and repeat the analyses. The entire process of analysis and its
   histories can be shared with collaborators or opened to the public. In
   conclusion, our system is useful for managing, analyzing, and
   visualizing NGS data and achieves traceability, reproducibility, and
   transparency of NGS analysis.},
Type = {Article},
Affiliation = {Ikeo, K (Corresponding Author), Natl Inst Genet, Ctr Informat Biol, 1111 Yata, Mishima, Shizuoka 4118540, Japan.
   Ikeo, K (Corresponding Author), SOKENDAI, Dept Genet, Mishima, Shizuoka, Japan.
   Kinjo, Sonoko; Kitamura, Norikazu; Imoto, Junichi; Ikeo, Kazuho, Natl Inst Genet, Ctr Informat Biol, 1111 Yata, Mishima, Shizuoka 4118540, Japan.
   Monma, Norikazu, Hitachi Ltd, Tokyo, Japan.
   Misu, Sadahiko, BITS Co Ltd, Tokyo, Japan.
