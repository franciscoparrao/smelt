DOI = {10.1016/j.jcrs.2012.06.049},
Keywords-Plus = {OPTICAL COHERENCE TOMOGRAPHY; LENS POWER CALCULATION; CORNEAL
   TOPOGRAPHY; NORMAL EYES; AUTOMATIC MEASUREMENTS; CLINICAL-EVALUATION;
   REFRACTIVE SURGERY; REPEATABILITY; PENTACAM; ABERRATIONS},
