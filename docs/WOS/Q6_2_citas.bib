   Desai, Shaun, Washington Univ, Sch Med, Dept Otolaryngol, St Louis, MO 63110 USA.
   Hoch, Benjamin, Univ Washington, Dept Pathol, Seattle, WA 98195 USA.},
DOI = {10.1158/1078-0432.CCR-10-3110},
Keywords-Plus = {SQUAMOUS-CELL CARCINOMA; POLYMERASE CHAIN-REACTION; SENTINEL NODE;
   MOLECULAR-DETECTION; SELECTIVE NECK; MESSENGER-RNA; TUMOR-CELLS; ORAL
   CAVITY; BIOPSY; DISSECTION},
