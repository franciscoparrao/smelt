   Maeki, Masatoshi; Ishida, Akihiko; Tani, Hirofumi; Tokeshi, Manabu, Hokkaido Univ, Div Appl Chem, Fac Engn, Sapporo, Hokkaido 0608628, Japan.
   Tokeshi, Manabu, Nagoya Univ, Innovat Res Ctr Prevent Med Engn, Nagoya, Aichi 4648601, Japan.
   Tokeshi, Manabu, Nagoya Univ, Inst Innovat Future Soc, Nagoya, Aichi 4648601, Japan.
   Komatsu, Takeshi, Hokkaido Univ, Grad Sch Chem Sci \& Engn, Sapporo, Hokkaido 0608628, Japan.},
DOI = {10.1021/acssensors.9b02218},
Keywords = {paper-based device; lithium ion; whole blood analysis; point-of-care
   testing; colorimetry},
