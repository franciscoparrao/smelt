   Ikram, M. Arfan; Vernooij, Meike W.; van der Lugt, Aad, Erasmus MC, Dept Radiol, Rotterdam, Netherlands.
   Niessen, Wiro J., Delft Univ Technol, Fac Sci Appl, Delft, Netherlands.},
DOI = {10.1016/j.neuroimage.2010.03.012},
Keywords = {MRI; Brain tissue segmentation; Reproducibility; Reliability; Accuracy;
   Sample size estimates},
Keywords-Plus = {WHITE-MATTER LESIONS; DISCRIMINANT-ANALYSIS; ROTTERDAM SCAN; IMAGES;
   CLASSIFICATION; VOLUME; POPULATION; EXTRACTION; DISEASE; MODEL},
