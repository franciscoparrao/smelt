@article{ WOS:000081433800017,
Author = {Lemieux, L and Hagemann, G and Krakow, K and Woermann, FG},
Title = {Fast, accurate, and reproducible automatic segmentation of the brain
   inT1-weighted volume MRI data},
Journal = {MAGNETIC RESONANCE IN MEDICINE},
Year = {1999},
Volume = {42},
Number = {1},
Pages = {127-135},
Month = {JUL},
Abstract = {A new fast automated algorithm has been developed to segment the brain
   from T(1)-weighted volume MR images, The algorithm uses automated
   thresholding and morphological operations. It is fully three-dimensional
   and therefore independent of scan orientation. The validity and the
   performance of the algorithm were evaluated by comparing the
   automatically calculated brain volume with semi-automated measurements
   in 10 subjects, by calculating the brain volume from repeated scans in
   another 10 subjects, and by visual inspection. The mean and standard
   deviation of the difference between semi-automated and auto mated
   measurements were 0.56\% and 2.8\% of the mean brain volume,
   respectively, which is within inter-observer variability of the
   semi-automated method. The mean and standard deviation of the difference
   between the total volumes calculated from repeated scans were 0.40\% and
   1.2\% of the mean brain volume, respectively. Good results were also
   obtained from a scan of abnormal brains. Magn Reson Med 42:127-135,
   1999. (C) 1999 Wiley-Liss, Inc.},
Type = {Article},
Affiliation = {Lemieux, L (Corresponding Author), Natl Soc Epilepsy, MRI Unit, Gerrards Cross SL9 0RJ, Bucks, England.
   Natl Soc Epilepsy, MRI Unit, Gerrards Cross SL9 0RJ, Bucks, England.
   UCL, Inst Neurol, Dept Clin Neurol, Epilepsy Res Grp, London, England.
   Univ Dusseldorf, Dept Neurol, D-4000 Dusseldorf, Germany.},
Keywords = {MRI; brain; segmentation; volume; validation},
Keywords-Plus = {GRAY-MATTER; EPILEPSY; REGISTRATION; IMAGES; ATLAS},
Author-Email = {llemieux@ion.ucl.ac.uk},
Number-of-Cited-References = {23},
