   Elola, Andoni, Univ Basque Country, Dept Commun Engn, Leioa, Spain.
   Clifford, Gari D., Georgia Inst Technol, Dept Biomed Engn, Atlanta, GA 30332 USA.
   Clifford, Gari D., Emory Univ, Atlanta, GA 30322 USA.},
DOI = {10.1088/1361-6579/abc960},
