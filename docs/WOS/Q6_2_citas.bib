   Demichev, Vadim, Charite Univ Med Berlin, Dept Biochem, Berlin, Germany.
   Demichev, Vadim, Univ Cambridge, Dept Biochem, Cambridge, England.},
DOI = {10.1038/s41467-023-39869-5},
Keywords-Plus = {DATA-INDEPENDENT ACQUISITION; MASS-SPECTROMETRY; PEPTIDE IDENTIFICATION;
   STATISTICAL-MODEL; SOFTWARE TOOLS; QUANTIFICATION; TANDEM; MS/MS;
