   Fan, Chunhai, Shanghai Jiao Tong Univ, Frontiers Sci Ctr Transformat Mol, Sch Chem \& Chem Engn, Shanghai 200240, Peoples R China.},
DOI = {10.1021/acsnano.2c11241},
EarlyAccessDate = {FEB 2023},
Keywords = {metal \&minus; organic frameworks; microfluidics; encapsulation;
