   Wheeler-Kingshott, Claudia A. M. Gandini, C Mondino Natl Neurol Inst, Brain MRI Ctr 3T, Pavia, Italy.
   Wheeler-Kingshott, Claudia A. M. Gandini, Univ Pavia, Dept Brain \& Behav Sci, Via Palestro 3, I-27100 Pavia, Italy.},
DOI = {10.1371/journal.pone.0155557},
Article-Number = {e0155557},
Keywords-Plus = {HUMAN OPTIC-NERVE; OF-THE-ART; MULTIPLE-SCLEROSIS; MATTER DEMYELINATION;
   MRI; MOTION; FIELD; RESOLUTION; REDUCTION; ARTIFACTS},
