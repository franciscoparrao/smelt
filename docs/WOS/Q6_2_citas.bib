   Univ Washington, Dept Genet, Seattle, WA 98195 USA.
   Univ Washington, Dept Med, Div Gastroenterol, Seattle, WA 98195 USA.},
Keywords-Plus = {MULTIPLE MICROSATELLITE LOCI; BARRETTS-ESOPHAGUS; NEOPLASTIC
   PROGRESSION; ALLELIC LOSSES; SHADOW BANDS; CANCER; BREAST; GENE; P53;
   ADENOCARCINOMAS},
