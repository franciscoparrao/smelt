   Raftery, Adrian E., Univ Washington, Dept Stat, Seattle, WA 98195 USA.
   Raftery, Adrian E., Univ Washington, Dept Sociol, Seattle, WA 98195 USA.},
DOI = {10.1146/annurev-statistics-033121-115326},
Keywords = {clustering; mixture models; expectation-maximization algorithm; Bayesian
   inference; software},
