   Huggett, Jim F., Univ Surrey, Sch Biosci \& Med, Fac Hlth \& Med Sci, Guildford, Surrey, England.},
DOI = {10.1373/clinchem.2016.262824},
Keywords-Plus = {GUIDELINES MINIMUM INFORMATION; TYROSINE KINASE INHIBITORS;
