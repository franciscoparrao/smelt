   Markov, Gabriel V., Sorbonne Univ, CNRS, Stn Biol Roscoff, UMR 8227,Integrat Biol Marine Models, Roscoff, France.},
DOI = {10.1371/journal.pcbi.1006146},
Article-Number = {e1006146},
