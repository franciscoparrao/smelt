   Chen, Bailiang, Univ Lorraine, IADI, INSERM, U947, Nancy, France.
   Chen, Bailiang, CHU Nancy, Nancy, France.
   Guo, Qingshan; Shen, Yue, Third Mil Med Univ, Inst Surg Res, State Key Lab Trauma Burns \& Combined Injury, Trauma Ctr,Daping Hosp, Chongqing 400042, Peoples R China.},
DOI = {10.1007/s11548-012-0775-5},
Keywords = {Augmented reality; Implant templating; Pelvis; Acetabulum; Fracture
   reduction and fixation},
Keywords-Plus = {3-DIMENSIONAL RECONSTRUCTION; MAXILLOFACIAL SURGERY; ARTHROPLASTY;
   MANAGEMENT; TEMPLATE; ACCURACY; MODELS; SYSTEM; TRIAL},
Author-Email = {shenfy@vrlab.buaa.edu.cn
