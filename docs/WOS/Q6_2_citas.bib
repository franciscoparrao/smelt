   Leng, Geng, Univ Elect Sci \& Technol China, Sch Resources \& Environm, Chengdu 611731, Peoples R China.},
DOI = {10.1016/j.chroma.2017.03.002},
Keywords = {Automation; Dispersive liquid-liquid microextraction; High performance
   liquid chromatography; Cold vapour atomic fluorescence; spectroscopy;
   Mercury; Speciation analysis},
Keywords-Plus = {POLYCYCLIC AROMATIC-HYDROCARBONS; SPECIATION ANALYSIS;
