   Puliafito, Carmen A., Univ So Calif, Keck Sch Med, Los Angeles, CA 90089 USA.},
DOI = {10.1117/1.3268773},
Article-Number = {064023},
Keywords = {optical coherence tomography; segmentation; reproducibility; image
   analysis; computer-aided diagnosis; repeatability; retina; image
   processing},
Keywords-Plus = {THICKNESS MEASUREMENTS; REPEATABILITY},
Author-Email = {dcabrera2@med.miami.edu},
Number-of-Cited-References = {24},
