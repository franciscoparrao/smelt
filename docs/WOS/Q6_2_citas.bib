   Hendrickson, Ryan; Benardini, James; Venkateswaran, Kasthuri, CALTECH, Jet Prop Lab, 4800 Oak Grove Dr, Pasadena, CA USA.
   Vetter, Russ; Hyde, John, NOAA, Southwest Fisheries Sci Ctr, La Jolla, CA USA.
   Doty, Megan M.; Stillwell, Kristina; Kim, Jae H., Univ Calif San Diego, Div Neonatol, La Jolla, CA 92093 USA.
   Knight, Rob, Univ Calif San Diego, Jacobs Sch Engn, Ctr Microbiome Innovat, La Jolla, CA 92093 USA.
   Allen, Eric E.; Knight, Rob, Univ Calif San Diego, Dept Comp Sci \& Engn, La Jolla, CA 92093 USA.},
DOI = {10.1128/mSystems.00218-17},
