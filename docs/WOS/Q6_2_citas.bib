Unique-ID = {WOS:000468255200002},
}

@article{ WOS:000430897600005,
Author = {Viswanathan, Meera and Patnode, Carrie D. and Berkman, Nancy D. and
   Bass, Eric B. and Chang, Stephanie and Hartling, Lisa and Murad, M.
   Hassan and Treadwell, Jonathan R. and Kane, Robert L.},
Title = {Recommendations for assessing the risk of bias in systematic reviews of
   health-care interventions},
Journal = {JOURNAL OF CLINICAL EPIDEMIOLOGY},
Year = {2018},
Volume = {97},
Pages = {26-34},
Month = {MAY},
Abstract = {Objectives: Risk-of-bias assessment is a central component of systematic
   reviews, but little conclusive empirical evidence exists on the validity
   of such assessments. In the context of such uncertainty, we present
   pragmatic recommendations that promote transparency and reproducibility
   in processes, address methodological advances in the risk-of-bias
   assessment, and can be applied consistently across review topics.
   Study Design and Setting: Epidemiological study design principles;
   available empirical evidence, risk-of-bias tools, and guidance; and
   workgroup consensus.
   Results: We developed recommendations for assessing the risk of bias of
   studies of health-care interventions specific to framing the focus and
   scope of risk-of-bias assessment; selecting the risk-of-bias categories;
   choosing assessment instruments; and conducting, analyzing, and
   presenting results of risk-of-bias assessments. Key recommendations
   include transparency and reproducibility of judgments, separating risk
   of bias from other constructs such as applicability and precision, and
   evaluating the risk of bias per outcome. We recommend against certain
   past practices, such as focusing on reporting quality, relying solely on
   study design or numerical quality scores, and automatically downgrading
   for industry sponsorship.
   Conclusion: Risk-of-bias assessment remains a challenging but essential
   step in systematic reviews. We presented standards to promote
   transparency of judgments. (C) 2017 Elsevier Inc. All rights reserved.},
Type = {Review},
Affiliation = {Viswanathan, M (Corresponding Author), RTI Int, RTI Int Univ North Carolina Chapel Hill Eviden Ba, Res Triangle Pk, NC 27709 USA.
   Viswanathan, Meera; Berkman, Nancy D., RTI Int, RTI Int Univ North Carolina Chapel Hill Eviden Ba, Res Triangle Pk, NC 27709 USA.
   Patnode, Carrie D., Kaiser Permanente, Kaiser Permanente Res Affiliates Evidence Based P, Ctr Hlth Res, Portland, OR USA.
   Bass, Eric B., Johns Hopkins Univ, Evidence Based Practice Ctr, Baltimore, MD USA.
   Chang, Stephanie, Agcy Healthcare Res \& Qual, Ctr Evidence \& Practice Improvement, Rockville, MD USA.
   Hartling, Lisa, Univ Alberta, Evidence Based Practice Ctr, Edmonton, AB, Canada.
   Murad, M. Hassan, Mayo Clin, Evidence Based Practice Ctr, Rochester, MN USA.
   Treadwell, Jonathan R., ECRI Inst, Evidence Based Practice Ctr, Plymouth Meeting, PA USA.
   Kane, Robert L., Univ Minnesota, Evidence Based Practice Ctr, Minneapolis, MN USA.},
DOI = {10.1016/j.jclinepi.2017.12.004},
Keywords = {Risk-of-bias guidance; Critical appraisal; Systematic reviews;
   Meta-analyses; Health-care interventions; Evidence-based practice},
Keywords-Plus = {RANDOMIZED CONTROLLED-TRIALS; CRITICAL-APPRAISAL; QUALITY; TOOL;
   METAANALYSES; AMSTAR; CREDIBILITY; STRENGTH},
