Keywords = {Semi-automated segmentation; Breast cancer; Unsupervised fuzzy
   clustering; Spatial information; Computer-assisted lesion detection;
   Magnetic Resonance Imaging},
Keywords-Plus = {CANCER; CLASSIFICATION; LESIONS; INFORMATION; PERFORMANCE; RADIOMICS;
   IMAGES},
Author-Email = {carmelo.militello@ibfm.cnr.it},
