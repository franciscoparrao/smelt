   Free Univ Berlin, Inst Comp Sci Algorithms Bioinformat, D-14195 Berlin, Germany.
   Commiss European Communities, Joint Res Ctr, I-21020 Ispra, Italy.},
DOI = {10.1021/pr050344u},
Keywords = {absolute quantitation; serum; myoglobin; high-performance liquid
   chromatography; electrospray ionization mass spectrometry;
   two-dimensional HPLC; standard addition; monoliths; computational
   proteomics; algorithms},
Keywords-Plus = {PROTEIN IDENTIFICATION TECHNOLOGY; ACUTE MYOCARDIAL-INFARCTION; CODED
   AFFINITY TAGS; PROTEOMIC ANALYSIS; PEPTIDE STANDARDS; QUANTIFICATION;
