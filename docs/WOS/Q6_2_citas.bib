   Gonzalez Ballester, Miguel A., ICREA, Barcelona, Spain.
   Lopez-Linares, Karen; Ceresa, Mario; Gonzalez Ballester, Miguel A., Univ Pompeu Fabra, Barcelona, Spain.},
DOI = {10.1016/j.media.2018.03.010},
Keywords = {AAA; EVAR; Segmentation; DCNN; Deep learning; Thrombus; Post-operative;
   detection},
