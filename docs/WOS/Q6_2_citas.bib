   van Griethuysen, Joost J. M.; Beets-Tan, Regina G. H., Maastricht Univ, Med Ctr, GROW Sch Oncol \& Dev Biol, Maastricht, Netherlands.
   Fedorov, Andriy; Aucoin, Nicole; Aerts, Hugo J. W. L., Harvard Med Sch, Brigham \& Womens Hosp, Dept Radiol, Boston, MA 02115 USA.
   Fillion-Robin, Jean-Christophe, Kitware, Clifton Pk, NY USA.
   Pieper, Steve, Isomics, Cambridge, MA USA.},
DOI = {10.1158/0008-5472.CAN-17-0339},
