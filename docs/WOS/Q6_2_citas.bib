   Shamikh, Alia, Karolinska Inst, Dept Oncol Pathol, Stockholm, Sweden.
   Shamikh, Alia, Karolinska Univ Hosp, Dept Clin Pathol \& Cytol, Stockholm, Sweden.
   Jurek, Aleksandra, 10x Genom, Stockholm, Sweden.
   Schultz, Niklas; Nister, Monica, Karolinska Inst, Karolinska Univ Hosp, Dept Oncol Pathol, BioClin, Stockholm, Sweden.},
DOI = {10.1038/s41467-023-36071-5},
