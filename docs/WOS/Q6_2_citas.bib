   Javaloy, Jaime; Alio, Jorge L., Univ Miguel Hernandez, Div Ophthalmol, Alicante, Spain.},
DOI = {10.1016/j.jcrs.2011.12.029},
Keywords-Plus = {OPTICAL COHERENCE TOMOGRAPHY; ANTERIOR SEGMENT BIOMETRY; AUTOMATIC
   MEASUREMENTS; THICKNESS MEASUREMENT; SCANNING-SLIT; REPRODUCIBILITY;
   TOPOGRAPHY; PENTACAM; CURVATURE; AGREEMENT},
Author-Email = {david.pinyero@ua.es},
Number-of-Cited-References = {26},
