   van Marle, Margreet, Deltares, Delft, Netherlands.
   van den Berg, Maarten, PBL Netherlands Environm Assessment Agcy, The Hague, Netherlands.
   van der Werf, Guido R., Vrije Univ Amsterdam, Fac Sci, Amsterdam, Netherlands.},
DOI = {10.5194/gmd-13-461-2020},
Keywords-Plus = {BIOMASS BURNING EMISSIONS; ANTHROPOGENIC EMISSIONS; REACTIVE GASES;
