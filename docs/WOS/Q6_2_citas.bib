   Hsu, Bailing, Univ Missouri, Nucl Sci \& Engn Inst, Columbia, MO USA.},
DOI = {10.1007/s12350-014-9971-8},
Keywords = {Myocardial flow reserve; image quantification; dynamic SPECT; operator
   variability; Tc-99m-sestamibi},
Keywords-Plus = {POSITRON-EMISSION-TOMOGRAPHY; NONINVASIVE QUANTIFICATION; EXPECTATION
