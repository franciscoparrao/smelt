   Abbas, Batool; Fishbaugh, James; Gerig, Guido, NYU, Tandon Sch Engn, VIDA, Brooklyn, NY USA.},
DOI = {10.1002/jmri.26615},
Keywords = {radial MRI; quantitative MRI; hip; articular cartilage; T1 mapping; T2
   mapping},
Keywords-Plus = {REPRODUCIBILITY; ARTHROGRAPHY; VOLUME; MRI},
Author-Email = {riccardo.lattanzi@nyumc.org},
Number-of-Cited-References = {24},
Times-Cited = {51},
Unique-ID = {WOS:000480583900014},
