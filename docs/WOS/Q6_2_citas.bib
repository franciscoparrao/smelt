@article{ WOS:000264976600060,
Author = {Trevino, J. and Calle, A. and Rodriguez-Frade, J. M. and Mellado, M. and
   Lechuga, L. M.},
Title = {Determination of human growth hormone in human serum samples by surface
   plasmon resonance immunoassay},
Journal = {TALANTA},
Year = {2009},
Volume = {78},
Number = {3},
Pages = {1011-1016},
Month = {MAY 15},
Abstract = {A surface plasmon resonance immunoassay has been developed to determine
   human growth hormone (hGH) directly and without pre-treatment in human
   serum samples. A binding inhibition immunoassay was employed. Antibody
   concentration, assay buffer and regeneration solution have been
   optimized in order to reach the best performance and the lower
   non-specific binding of the matrix components to the sensor Surface. The
   lowest detection limit was 6 ng/mL, with a working range covering the
   physiological range. Reproducibility of the assay was excellent with
   both intra-assay and inter-assay relative standard deviations < 5\%,
   while a variation of 2.19\% was obtained employing different sensor
   chips. Reutilization of the sensor surface allows its continuous use
   over 50 measurements with a signal drop < 20\%. The SPR immunoassay
   results were validated using enzyme-linked immunosorbent assay (ELISA)
   showing an excellent correlation (R-2 = 0.985). A portable and fully
   automated system (Sensia SL) was employed in this work. This is the
   first SPR biosensor assay capable of detecting relevant concentrations
   of a clinical analyte in serum. This study shows the potentials of this
   device as a diagnostic tool for the detection of multiple clinical
   analytes. (c) 2009 Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Treviño, J (Corresponding Author), CSIC ICN, CIN2, ETSE, Grp Nanoblosensores \& Biofis Mol, Edificio Q ETSE,3 Planta,Campus UAB, Barcelona 08193, Spain.
