   Dillner, Joakim, Karolinska Inst, Dept Lab Med Med Epidemiol \& Biostat, Stockholm, Sweden.
   Arbyn, Marc, Sci Inst Publ Hlth, Canc Epidemiol Unit, Brussels, Belgium.},
DOI = {10.1016/j.vaccine.2012.04.105},
