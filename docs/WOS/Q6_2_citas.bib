@article{ WOS:000308268800072,
Author = {Magalhaes, Luis M. and Barreiros, Luisa and Maia, Miguel A. and Reis,
   Salette and Segundo, Marcela A.},
Title = {Rapid assessment of endpoint antioxidant capacity of red wines through
   microchemical methods using a kinetic matching approach},
Journal = {TALANTA},
Year = {2012},
Volume = {97},
Pages = {473-483},
Month = {AUG 15},
Abstract = {Antioxidant capacity of food samples is usually assessed by different
   analytical methods, however the results attained even for the same
   method are strongly dependent on the selected reaction time and also on
   the standard compound used. To tackle this problem, we propose here a
   kinetic matching approach, associated to the conversion of results into
   equivalents of a common standard compound, as a universal way for
   expression of results. The methodology proposed was applied to methods
   based on different chemistries (Folin-Ciocalteu (F-C), CUPRAC, DPPH
   center dot and ABTS(center dot+) assays) and red wines (n=40) were
   chosen as a model of complex food sample. For implementation of the
   kinetic matching approach, the standard phenolic mixture (caffeic acid,
   (+)-catechin, hesperetin, morin and (-)-epigallocatechin gallate) was
   chosen for calibration in F-C, CUPRAC and DPPH center dot assays, while
   tannic acid was suitable for ABTS(center dot+) assay. Results showed
   that, for all methods, there was no statistical difference between
   results attained by the kinetic matching approach (after < 10 min of
   reaction) and that at endpoint conditions (after 60 to 300 min). The
   repeatability and the reproducibility of the kinetic matching approach
   was < 4.5\%, for all antioxidant assays. The sample throughput increases
   from < 18 (endpoint measurements) to > 108 h(-1) using the proposed
   kinetic approach. Moreover, we have established here a way of converting
   results to equivalents of a common standard, providing values
   independent of its kinetic profile, by using the ratio between
   calibration sensitivities performed at endpoint conditions. (C) 2012
   Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Magalhaes, LM (Corresponding Author), Univ Porto, Fac Farm, Dept Ciencias Quim, REQUIMTE, Rua Jorge Viterbo Ferreira 228, P-4050313 Oporto, Portugal.
   Magalhaes, Luis M.; Barreiros, Luisa; Maia, Miguel A.; Reis, Salette; Segundo, Marcela A., Univ Porto, Fac Farm, Dept Ciencias Quim, REQUIMTE, P-4050313 Oporto, Portugal.},
DOI = {10.1016/j.talanta.2012.05.002},
Keywords = {Antioxidant capacity; Kinetic profile; Folin-Ciocalteu; CUPRAC; ABTS;
   DPPH; Red wines},
Keywords-Plus = {CIOCALTEU REDUCING CAPACITY; PHENOLIC-COMPOUNDS; AUTOMATIC METHOD; FOOD;
   ASSAYS; INDEX},
Author-Email = {luismagalhaes@ff.up.pt
   msegundo@ff.up.pt},
Number-of-Cited-References = {24},
Times-Cited = {68},
Unique-ID = {WOS:000308268800072},
}

@article{ WOS:000268362700036,
Author = {Marchiano, Alfonso and Calabro, Elisa and Civelli, Enrico and Di Tolla,
   Giuseppe and Frigerio, Laura Francesca and Morosi, Carlo and Tafaro,
   Francesco and Ferri, Elena and Sverzellati, Nicola and Camerini, Tiziana
   and Mariani, Luigi and Lo Vullo, Salvatore and Pastorino, Ugo},
Title = {Pulmonary Nodules: Volume Repeatability at Multidetector CT Lung Cancer
   Screening},
Journal = {RADIOLOGY},
Year = {2009},
Volume = {251},
Number = {3},
Pages = {919-925},
Month = {JUN},
Abstract = {Purpose: To assess in vivo volumetric repeatability of an automated
   software algorithm in pulmonary nodules detected during a lung cancer
   screening trial.
   Materials and Methods: This study was approved by an institutional
   review board. Written informed consent was obtained from all
   participants. Data were collected from the Multicentric Italian Lung
   Detection project, a randomized controlled lung cancer screening trial.
   The first 1236 consecutive baseline computed tomographic (CT) studies
   performed at the Istituto Nazionale Tumori of Milan were evaluated.
   Among the enrolled participants, those who underwent repeat low-dose CT
   after 3 months and had at least one indeterminate nodule with a volume
   of more than 60 mm(3) (diameter of 4.8 mm or greater) were considered.
   Nonsolid, part-solid, and pleural-based nodules were excluded from this
   study. A descriptive analysis was performed by calculating means and
   standard deviations of nodule volumes at three assessment times (at
   baseline and 3 and 12 months later). The volume measurement
   repeatability was determined by using the approach described by Bland
   and Altman.
   Results: One hundred one subjects (70 men, 31 women; mean age, 58 years)
   with 233 eligible nodules (mean volume, 98.3 mm(3); range, 5-869 mm(3))
   were identified. The 95\% confidence interval for difference in measured
   volumes was in the range of +/- 27\%. About 70\% of measurements had a
   relative difference in nodule volume of less than 10\%. No malignant
   lesions were registered during the follow-up of these subjects.
   Conclusion: Semiautomatic volumetry is sufficiently accurate and
   repeatable and may be useful in assisting with lung nodule management in
   a lung cancer screening program. (C) RSNA, 2009},
Type = {Article},
Affiliation = {Marchianò, A (Corresponding Author), Fdn IRCCS, Ist Nazl Tumori, Dept Diagnost Imaging \& Radiotherapy, Via Venezian 1, I-20133 Milan, Italy.
