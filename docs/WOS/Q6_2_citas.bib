@article{ WOS:000315363600003,
Author = {Keawkim, Kannika and Chuanuwatanakul, Suchada and Chailapakul, Orawon
   and Motomizu, Shoji},
Title = {Determination of lead and cadmium in rice samples by sequential
   injection/anodic stripping voltammetry using a bismuth film/crown
   ether/Nafion modified screen-printed carbon electrode},
Journal = {FOOD CONTROL},
Year = {2013},
Volume = {31},
Number = {1},
Pages = {14-21},
Month = {MAY},
Abstract = {A highly sensitive automated method for the determination of Pb2+ and
   Cd2+ by sequential injection/anodic stripping voltammetry using a crown
   ether/Nafion modified screen-printed carbon electrode coated with a
   bismuth film was developed. The bismuth film was prepared by in situ
   depositing of Bi3+ simultaneously with the analyte metal ions on the
   modified electrode at -1.2 V vs. Ag/AgCl reference electrode for 180 s,
   using hydrochloric acid as a supporting electrolyte. Under the optimal
   conditions, estimated from sequential univariate analysis of each of the
   parameters, a linear detection range of 0.5-60 mu g dm(-3) for both
   metal ions was found, with a LOD (3S(b)/S) of 0.11 mu g dm(-3) for Pb2+
   and 0.27 mu g dm(-3) for Cd2+. This method shows good reproducibility
   and stability and was successfully applied to measure Pb2+ and Cd2+
   levels in rice and rice product samples, with good agreement with those
   obtained by the standard ICP-OES method. (c) 2012 Elsevier Ltd. All
   rights reserved.},
Type = {Article},
Affiliation = {Chuanuwatanakul, S (Corresponding Author), Chulalongkorn Univ, Electrochem \& Opt Spect Res Unit, Dept Chem, Fac Sci, 254 Phayathai Rd, Bangkok 10330, Thailand.
   Keawkim, Kannika; Chuanuwatanakul, Suchada; Chailapakul, Orawon, Chulalongkorn Univ, Electrochem \& Opt Spect Res Unit, Dept Chem, Fac Sci, Bangkok 10330, Thailand.
