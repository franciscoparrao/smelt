@incollection{ WOS:000273617500084,
Author = {Ross, James C. and Jose Estepar, Raul San and Diaz, Alejandro and
   Westin, Carl-Fredrik and Kikinis, Ron and Silverman, Edwin K. and
   Washko, George R.},
Editor = {Yang, GZ and Hawkes, D and Rueckert, D and Nobel, A and Taylor, C},
Title = {Lung Extraction, Lobe Segmentation and Hierarchical Region Assessment
   for Quantitative Analysis on High Resolution Computed Tomography Images},
Booktitle = {MEDICAL IMAGE COMPUTING AND COMPUTER-ASSISTED INTERVENTION - MICCAI
   2009, PT II, PROCEEDINGS},
Series = {Lecture Notes in Computer Science},
Year = {2009},
Volume = {5762},
Pages = {690+},
Abstract = {Regional assessment of lung disease (such as chronic obstructive
   pulmonary disease) is a critical component to accurate patient
   diagnosis. Software tools than enable such analysis are also important
   for clinical research studies. In this work, we present an image
   segmentation and data representation framework that enables quantitative
   analysis specific to different lung regions on high resolution computed
   tomography (HRCT) datasets. We present an offline, fully automatic image
   processing chain that generates airway, vessel, and lung mask
   segmentations in which the left and right lung are delineated. We
   describe a novel lung lobe segmentation tool that produces reproducible
   results with minimal user interaction. A usability study performed
   across twenty datasets (inspiratory and expiratory exams including a
   range of disease states) demonstrates the tool's ability to generate
   results within five to seven minutes on average. We also describe a data
   representation scheme that involves compact encoding of label maps such
   that both ``regions{''} (such as lung lobes) and ``types{''} (Such as
   emphysematous parenchyma) can be simultaneously represented at a given
   location in the HRCT.},
Type = {Proceedings Paper},
Affiliation = {Ross, JC (Corresponding Author), Brigham \& Womens Hosp, Channing Lab, 75 Francis St, Boston, MA 02115 USA.
   Ross, James C.; Silverman, Edwin K., Brigham \& Womens Hosp, Channing Lab, 75 Francis St, Boston, MA 02115 USA.
   Ross, James C.; Jose Estepar, Raul San; Westin, Carl-Fredrik, Brigham \& Womens Hosp, Harvard Med Sch, Lab Math Imaging, Boston, MA 02115 USA.
   Ross, James C.; Jose Estepar, Raul San; Westin, Carl-Fredrik; Kikinis, Ron, Brigham \& Womens Hosp, Surg Planning Lab, Boston, MA 02115 USA.
   Diaz, Alejandro, Pontificia Univ Catolica Chile, Santiago, Chile.
   Silverman, Edwin K.; Washko, George R., Brigham \& Womens Hosp, Pulmonary \& Critical Care Div, Boston, MA 02115 USA.},
