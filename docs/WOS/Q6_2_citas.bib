   Anwar, Saira, Texas A\&M Univ, 101 Bizzell St,Emerging Technol Bldg 1041D, College Stn, TX 77840 USA.
   Hipwell, M. Cynthia, Texas A\&M Univ, 180 Spence St, Mech Engn Off Bldg 409, College Stn, TX 77840 USA.
   Srinivasa, Arun R., Texas A\&M Univ, 180 Spence St,Mech Engn Off Bldg 505, College Stn, TX 77840 USA.},
DOI = {10.1016/j.caeai.2024.100206},
Article-Number = {100206},
Keywords = {Automatic assessment; Artificial intelligence; Natural language
   processing; Text-based responses; Post-secondary education},
Keywords-Plus = {FORMATIVE ASSESSMENT; FRAMEWORK; FEEDBACK},
