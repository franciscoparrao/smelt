}

@article{ WOS:000232141200008,
Author = {Anbeek, P and Vincken, KL and van Bochove, GS and van Osch, MJP and van
   der Grond, J},
Title = {Probabilistic segmentation of brain tissue in MR imaging},
Journal = {NEUROIMAGE},
Year = {2005},
Volume = {27},
Number = {4},
Pages = {795-804},
Month = {OCT 1},
Abstract = {A new method has been developed for probabilistic segmentation of five
   different types of brain structures: white matter, gray matter,
   cerebro-spinal fluid without ventricles, ventricles and white matter
   lesion in cranial MR imaging. The algorithm is based on information from
   T1-weighted (T1-w), inversion recovery (IR), proton density-weighted
   (PD), T2-weighted (T2-w) and fluid attenuation inversion recovery
   (FLAIR) scans. it uses the K-Nearest Neighbor classification technique
   that builds a feature space from spatial information and voxel
   intensities. The technique generates for each tissue type an image
   representing the probability per voxel being part of it. By application
   of thresholds on these probability maps, binary segmentations can be
   obtained. A similarity index (SI) and a probabilistic SI (PSI) were
   calculated for quantitative evaluation of the results. The influence of
   each image type on the performance was investigated by alternately
   leaving out one of the five scan types. This procedure showed that the
   incorporation of the T1-w, PD or T2-w did not significantly improve the
   segmentation results. Further investigation indicated that the
   combination of IR and FLAIR was optimal for segmentation of the five
   brain tissue types. Evaluation with respect to the gold standard showed
   that the SI-values for all tissues exceeded 0.8 and all PSI-values
   exceeded 0.7, implying an excellent agreement. (C) 2005 Elsevier Inc.
   All rights reserved.},
Type = {Article},
Affiliation = {Anbeek, P (Corresponding Author), Univ Med Ctr Utrecht, Image Sci Inst, Dept Radiol, Heidelberglaan 100,Rm E01-335, NL-3584 CX Utrecht, Netherlands.
   Univ Med Ctr Utrecht, Image Sci Inst, Dept Radiol, NL-3584 CX Utrecht, Netherlands.},
DOI = {10.1016/j.neuroimage.2005.05.046},
Keywords = {brain; K-Nearest Neighbor classification; MR imaging; segmentation},
Keywords-Plus = {MULTIPLE-SCLEROSIS LESIONS; MAGNETIC-RESONANCE IMAGES; WHITE-MATTER
   LESIONS; AUTOMATIC SEGMENTATION; VOLUME; CLASSIFICATION; MODEL;
   REPRODUCIBILITY; INFORMATION; VALIDATION},
Author-Email = {nelly@isi.uu.nl},
Number-of-Cited-References = {40},
Times-Cited = {185},
Unique-ID = {WOS:000232141200008},
}

@article{ WOS:000595589600001,
Author = {Buccino, Alessio P. and Hurwitz, Cole L. and Garcia, Samuel and Magland,
   Jeremy and Siegle, Joshua H. and Hurwitz, Roger and Hennig, Matthias H.},
Title = {SpikeInterface, a unified framework for spike sorting},
Journal = {ELIFE},
Year = {2020},
Volume = {9},
Month = {NOV 10},
Abstract = {Much development has been directed toward improving the performance and
   automation of spike sorting. This continuous development, while
   essential, has contributed to an over-saturation of new, incompatible
   tools that hinders rigorous benchmarking and complicates reproducible
   analysis. To address these limitations, we developed SpikeInterface, a
   Python framework designed to unify preexisting spike sorting
   technologies into a single codebase and to facilitate straightforward
   comparison and adoption of different approaches. With a few lines of
   code, researchers can reproducibly run, compare, and benchmark most
   modern spike sorting algorithms; pre-process, post-process, and
   visualize extracellular datasets; validate, curate, and export sorting
   outputs; and more. In this paper, we provide an overview of
   SpikeInterface and, with applications to real and simulated datasets,
   demonstrate how it can be utilized to reduce the burden of manual
   curation and to more comprehensively benchmark automated spike sorters.},
Type = {Article},
Affiliation = {Buccino, AP (Corresponding Author), Swiss Fed Inst Technol, Dept Biosyst Sci \& Engn, Zurich, Switzerland.
   Buccino, AP (Corresponding Author), Univ Oslo, Ctr Integrat Neuroplast CINPLA, Oslo, Norway.
   Buccino, Alessio P., Swiss Fed Inst Technol, Dept Biosyst Sci \& Engn, Zurich, Switzerland.
   Buccino, Alessio P., Univ Oslo, Ctr Integrat Neuroplast CINPLA, Oslo, Norway.
   Hurwitz, Cole L.; Hennig, Matthias H., Univ Edinburgh, Sch Informat, Edinburgh, Midlothian, Scotland.
   Garcia, Samuel, CNRS, Ctr Rech Neurosci Lyon, Lyon, France.
   Magland, Jeremy, Flatiron Inst, New York, NY USA.
   Siegle, Joshua H., Allen Inst Brain Sci, Seattle, WA USA.},
DOI = {10.7554/eLife.61834},
