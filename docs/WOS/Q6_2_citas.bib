   Motomizu, Shoji, Okayama Univ, Fac Sci, Dept Chem, Okayama 7008530, Japan.},
DOI = {10.1016/j.foodcont.2012.09.025},
Keywords = {Lead and cadmium; Rice; Sequential injection analysis; Anodic stripping
   voltammetry; Modified screen-printed carbon electrode; Automated method},
