@incollection{ WOS:000391578700013,
Author = {Fereidooni, Hossein and Conti, Mauro and Yao, Danfeng and Sperduti,
   Alessandro},
Editor = {Badra, M and Pau, G and Vassiliou, V},
Title = {ANASTASIA: ANdroid mAlware detection using STAtic analySIs of
   Applications},
Booktitle = {2016 8TH IFIP INTERNATIONAL CONFERENCE ON NEW TECHNOLOGIES, MOBILITY AND
   SECURITY (NTMS)},
Year = {2016},
Abstract = {The number of malware applications targeting the Android operating
   system has significantly increased in recent years and malicious
   applications pose a significant threat to Android platform security. We
   propose ANASTASIA, a system to detect malicious Android applications
   through statically analyzing applications' behaviors. ANASTASIA provides
   a more complete coverage of security behaviors when compared to
   state-of-the-art solutions. We utilize a large number of statically
   extracted features from various security behavioral characteristics of
   an application. We built a Machine Learning-based detection framework
   with high performance detection and acceptable false positive rate. The
   significance of our work is to develop a lightweight malware detection
   system for Android-powered smartphones that leverages robust, effective,
   and efficient features. Besides, in order to assess our solution, we
   used a reliable, large-scale, and updated malware data-set in terms of
   diversity and number of malware applications. We evaluated the
   performance of our proposal on large-scale malware data-set (including
   18,677 malware and 11,187 benign apps). Our experimental results show a
   true positive rate of 97.3\% and a false negative rate of 2.7\%. These
   results are better than what are reported by state-of-the-art Android
   malware detection methods.},
Type = {Proceedings Paper},
Affiliation = {Fereidooni, H (Corresponding Author), Univ Padua, I-35100 Padua, Italy.
   Fereidooni, Hossein; Conti, Mauro; Sperduti, Alessandro, Univ Padua, I-35100 Padua, Italy.
   Yao, Danfeng, Virginia Tech, Dept Comp Sci, Blacksburg, VA USA.},
Keywords = {Android static analysis; Malware detection; Machine Learning},
