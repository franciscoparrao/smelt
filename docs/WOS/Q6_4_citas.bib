Keywords = {deep learning; arctic; ice-wedge polygons; Mask-RCNN; VHSR imagery},
Keywords-Plus = {GROUND-ICE; VEGETATION COMPOSITION; THAW SUBSIDENCE; PERMAFROST;
   DEGRADATION; COAST; THERMOKARST; DYNAMICS; PATTERNS; TERRAIN},
