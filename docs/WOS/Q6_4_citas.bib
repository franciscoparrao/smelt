   Li, Ao; Wu, Zhiqiang, Wright State Univ, Dept Elect Engn, Dayton, OH 45435 USA.
   Wu, Zhiqiang, Univ Tibet, Dept Elect \& Informat Engn, Lhasa 850000, Peoples R China.
   Lu, Huaiyin, Sun Yat Sen Univ, Sch Elect \& Informat Technol, Guangzhou 510275, Guangdong, Peoples R China.},
DOI = {10.1109/ACCESS.2018.2862159},
Keywords = {Linear regression; multi-task learning; image classification; nonlinear
   feature; numerical optimization},
Keywords-Plus = {FACE RECOGNITION; SPARSE GRAPH; LOW-RANK; REPRESENTATION; DICTIONARY;
