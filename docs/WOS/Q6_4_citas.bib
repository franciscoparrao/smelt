DOI = {10.1016/j.mattod.2025.06.031},
EarlyAccessDate = {AUG 2025},
Keywords = {Machine learning; Alloy design; Additive manufacturing; Versatile alloy;
   Multi-objective optimisation},
Keywords-Plus = {MECHANICAL-PROPERTIES; MARAGING-STEEL; LASER; MICROSTRUCTURE; EVOLUTION;
