@article{ WOS:000785793200002,
Author = {Wang, Xiaying and Geiger, Fabian and Niculescu, Vlad and Magno, Michele
   and Benini, Luca},
Title = {Leveraging Tactile Sensors for Low Latency Embedded Smart Hands for
   Prosthetic and Robotic Applications},
Journal = {IEEE TRANSACTIONS ON INSTRUMENTATION AND MEASUREMENT},
Year = {2022},
Volume = {71},
Abstract = {Tactile sensing is a crucial perception mode for robots and human
   amputees in need of controlling a prosthetic device. Today, robotic and
   prosthetic systems are still missing the important feature of accurate
   tactile sensing. This lack is mainly due to the fact that the existing
   tactile technologies have limited spatial and temporal resolution and
   are either expensive or not scalable. In this article, we present the
   design and implementation of a hardware-software embedded system called
   SmartHand. It is specifically designed to enable the acquisition and
   real-time processing of high-resolution tactile information from a
   hand-shaped multisensor array for prosthetic and robotic applications.
   During data collection, our system can deliver a high throughput of 100
   frames per second, which is 13.7x higher than previous related work.
   This has allowed the collection of a new tactile dataset consisting of
   340000 frames while interacting with 16 objects from everyday life
   during five different sessions. Together with the empty hand, the
   dataset presents a total of 17 classes. We propose a compact yet
   accurate convolutional neural network that requires one order of
   magnitude less memory and 15.6x fewer computations compared with related
   work without degrading classification accuracy. The top-1 and top-3
   cross-validation accuracies on the collected dataset are, respectively,
   98.86\% and 99.83\%. We further analyze the intercession variability and
   obtain the best top-3 leave-one-out-validation accuracy of 77.84\%. We
   deploy the trained model on a high-performance ARM Cortex-M7
   microcontroller achieving an inference time of only 100 ms minimizing
   the response latency. The overall measured power consumption is 505 mW.
   Finally, we fabricate a new control sensor and perform additional
   experiments to provide analyses on sensor degradation and slip
   detection. This work is a step forward in giving robotic and prosthetic
   devices a sense of touch by demonstrating the practicality of a smart
   embedded system that uses a scalable tactile sensor with embedded tiny
   machine learning.},
Type = {Article},
Affiliation = {Wang, XY (Corresponding Author), Swiss Fed Inst Technol, Dept Informat Technol \& Elect Engn, CH-8092 Zurich, Switzerland.
   Wang, Xiaying; Geiger, Fabian; Niculescu, Vlad; Magno, Michele; Benini, Luca, Swiss Fed Inst Technol, Dept Informat Technol \& Elect Engn, CH-8092 Zurich, Switzerland.},
DOI = {10.1109/TIM.2022.3165828},
Article-Number = {4004314},
Keywords = {Biomedical applications; convolutional neural networks (CNNs); edge
   computing; embedded systems; prosthetic hand; tactile sensors},
Keywords-Plus = {NEURAL-NETWORK; ELECTRONIC SKIN; CLASSIFICATION},
Author-Email = {xiaywang@iis.ee.ethz.ch},
Number-of-Cited-References = {43},
Times-Cited = {16},
Unique-ID = {WOS:000785793200002},
}

@article{ WOS:000712291200001,
Author = {Lemkus, Trent and Gotwalt, Christopher and Ramsey, Philip and Weese,
   Maria L.},
Title = {Self-validated ensemble models for design of experiments},
Journal = {CHEMOMETRICS AND INTELLIGENT LABORATORY SYSTEMS},
Year = {2021},
Volume = {219},
Month = {DEC 15},
Abstract = {One of the possible objectives when designing experiments is to build or
   formulate a model for predicting future observations. When the primary
   objective is prediction, some typical approaches in the planning phase
   are to use well-established small-sample experimental designs in the
   design phase (e.g., Definitive Screening Designs) and to construct
   predictive models using widely used model selection algorithms such as
   LASSO. These design and analytic strategies, however, do not guarantee
   high prediction performance, partly due to the small sample sizes that
   prevent partitioning the data into training and validation sets, a
   strategy that is commonly used in machine learning models to improve
   out-of-sample prediction. In this work, we propose a novel framework for
   building high-performance predictive models from experimental data that
   capitalizes on the advantage of having both training and validation
   sets. However, instead of partitioning the data into two mutually
   exclusive subsets, we propose a weighting scheme based on the fractional
   random weight bootstrap that emulates data partitioning by assigning
   anti-correlated training and validation weights to each observation. The
   proposed methodology, called Self-Validated Ensemble Modeling (SVEM),
   proceeds in the spirit of bagging so that it iterates through bootstraps
   of anti-correlated weights and fitted models, with the final SVEM model
   being the average of the bootstrapped models. We investigate the
   performance of the SVEM algorithm with several model-building approaches
   such as stepwise regression, Lasso, and the Dantzig selector. Finally,
   through simulation and case studies, we show that SVEM generally
   generates models with better prediction performance in comparison to
   one-shot model selection approaches.},
Type = {Article},
Affiliation = {Weese, ML (Corresponding Author), Miami Univ, Dept Informat Syst \& Analyt, Oxford, OH 45056 USA.
   Lemkus, Trent; Ramsey, Philip, Univ New Hampshire, Dept Math \& Stat, Durham, NH 03824 USA.
   Gotwalt, Christopher, SAS, Cary, NC 27513 USA.
   Weese, Maria L., Miami Univ, Dept Informat Syst \& Analyt, Oxford, OH 45056 USA.},
DOI = {10.1016/j.chemolab.2021.104439},
EarlyAccessDate = {OCT 2021},
Article-Number = {104439},
Keywords = {Box-Behnken designs; Definitive screening designs; Forward selection;
   Fractional weighted bootstrap; Lasso},
Keywords-Plus = {SELECTION},
Author-Email = {weeseml@miamioh.edu},
Number-of-Cited-References = {29},
Times-Cited = {16},
Unique-ID = {WOS:000712291200001},
}

@article{ WOS:000705650800007,
Author = {Hu, Liangyuan and Lin (joyce), Jung-Yi and Sigel, Keith and Kale, Minal},
Title = {Estimating heterogeneous survival treatment effects of lung cancer
   screening approaches: A causal machine learning analysis},
Journal = {ANNALS OF EPIDEMIOLOGY},
Year = {2021},
Volume = {62},
Pages = {36-42},
Month = {OCT},
Abstract = {The National Lung Screening Trial (NLST) found that low-dose computed
   tomography (LDCT) screening provided lung cancer (LC) mortality benefit
   compared to chest radiography (CXR). Considerable research concerns
   identifying the differential treatment effects that may exist in certain
   subpopulations. We shed light on several important issues in existing
   research and highlight the need for further investigation of the
   heterogeneous comparative effect of LDCT versus CXR, using more flexible
   and rigorous statistical approaches. We used a high-performance Bayesian
   machine learning approach designed for censored survival data,
   accelerated failure time Bayesian additive regression trees model
   (AFT-BART), to flexibly capture the relationships between the failure
   time and predictors. We then used the counterfactual framework to draw
   Markov chain Monte Carlo samples of the individual treatment effect for
   each participant. Using these posterior samples, we explored the
   possible treatment effect heterogeneity via a stepwise binary tree
   approach. When re-analyzed with AFT-BART, LDCT did not have a
   statistically significant LC or overall mortality benefit compared to
   CXR. The Asian and Black (particularly those with pack-year >= 37 years
   and without emphysema) NLST population were shown to have enhanced
   overall mortality benefit from LDCT than the population average.
   Although inconclusive for LC mortality benefit, Asians, Blacks and
   Whites with history of chronic obstructive pulmonary disease showed a
   small trend towards benefit from LDCT. Causal inference with flexible
   machine learning modeling can provide valuable knowledge for informing
   treatment decision and planning targeted clinical trials emphasizing
   personalized medicine approaches. (c) 2021 Elsevier Inc. All rights
   reserved.},
Type = {Article},
Affiliation = {Hu, LY (Corresponding Author), Rutgers State Univ, Dept Biostat \& Epidemiol, 683 Hoes Lane West, Piscataway, NJ 08854 USA.
   Hu, Liangyuan; Lin (joyce), Jung-Yi, Icahn Sch Med Mt Sinai, Dept Populat Hlth Sci \& Policy, New York, NY 10029 USA.
   Hu, Liangyuan, Rutgers State Univ, Dept Biostat \& Epidemiol, 683 Hoes Lane West, Piscataway, NJ 08854 USA.
   Lin (joyce), Jung-Yi, Icahn Sch Med Mt Sinai, Inst Hlth Care Delivery Sci, New York, NY 10029 USA.
   Sigel, Keith; Kale, Minal, Icahn Sch Med Mt Sinai, Dept Med, New York, NY 10029 USA.},
DOI = {10.1016/j.annepidem.2021.06.008},
EarlyAccessDate = {JUL 2021},
Keywords = {Lung cancer prevention; Bayesian machine learning; Causal inference;
   Individualized screening},
Keywords-Plus = {CARDIOVASCULAR EVENTS; PRIMARY PREVENTION; TRIAL; MORTALITY; RISK},
Author-Email = {liangyuan.hu@rutgers.edu},
Number-of-Cited-References = {46},
