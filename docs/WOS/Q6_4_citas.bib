   Zhao, Yan, Kunming Univ Sci \& Technol, Natl Engn Res Ctr Solid Waste Resource Recovery, Kunming 650093, Peoples R China.},
DOI = {10.1021/acsanm.3c00256},
EarlyAccessDate = {MAR 2023},
Keywords = {machine learning; material design; two-dimensional materials; seawater
   desalination; self-cleaning properties},
