}

@article{ WOS:000623649900002,
Author = {Sangare, Mamoudou and Gupta, Sharut and Bouzefrane, Samia and Banerjee,
   Soumya and Muhlethaler, Paul},
Title = {Exploring the forecasting approach for road accidents: Analytical
   measures with hybrid machine learning},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2021},
Volume = {167},
Month = {APR 1},
Abstract = {Urban traffic forecasting models generally follow either a Gaussian
   Mixture Model (GMM) or a Support Vector Classifier (SVC) to estimate the
   features of potential road accidents. Although SVC can provide good
   performances with less data than GMM, it incurs a higher computational
   cost. This paper proposes a novel framework that combines the
   descriptive strength of the Gaussian Mixture Model with the
   high-performance classification capabilities of the Support Vector
   Classifier. A new approach is presented that uses the mean vectors
   obtained from the GMM model as input to the SVC. Experimental results
   show that the approach compares very favorably with baseline statistical
   methods.},
