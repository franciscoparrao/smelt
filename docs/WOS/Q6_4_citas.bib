DOI = {10.3390/nano12010159},
Article-Number = {159},
Keywords = {metal-organic frameworks; water harvesting; molecular simulation;
   algorithm; absorption},
Keywords-Plus = {STRUCTURE-PROPERTY RELATIONSHIP; DRIVEN HEAT-PUMPS; METHANE STORAGE;
   ADSORPTION PERFORMANCE; HYDROGEN STORAGE; CO2; PREDICTION; SEPARATION;
   CAPACITY; AMMONIA},
Author-Email = {lilifeng@e.gzhu.edu.cn
