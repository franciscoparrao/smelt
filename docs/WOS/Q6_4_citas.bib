   Kosonen, Risto, Nanjing Tech Univ, Coll Urban Construct, Nanjing 211800, Peoples R China.},
DOI = {10.3390/en15062078},
Article-Number = {2078},
Keywords = {transfer learning; occupancy prediction; indoor climate; IoT; model
   robustness; space efficiency; energy efficiency},
