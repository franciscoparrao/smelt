   Parambath, J. B. M., Univ Sharjah, Ctr Adv Mat Res, Res Inst Sci \& Engn, POB 27272, Sharjah, U Arab Emirates.
   Olabi, A. G., Aston Univ, Sch Engn \& Appl Sci, Mech Engn \& Design, Aston Triangle, Birmingham B4 7ET, England.},
DOI = {10.1016/j.energy.2024.131127},
