   Li, Zhen, Dalian Univ Technol, Sch Mech Engn, Dalian 116024, Liaoning, Peoples R China.
   Li, Wenjie; Sun, Dan, Nucl Power Inst China, Sci \& Technol Reactor Syst Design Technol Lab, Chengdu 610213, Sichuan, Peoples R China.},
DOI = {10.20517/jmi.2024.15},
