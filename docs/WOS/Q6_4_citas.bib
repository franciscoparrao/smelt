   Hu, Xueqin, Shanghai Univ Chinese Med, Coll Basic Med Sci, Shanghai 201203, Peoples R China.},
DOI = {10.1016/j.compbiomed.2009.02.002},
Keywords = {Chronic gastritis; Transductive confidence machine; Random forest;
   Proximity measure; Hedged prediction},
Keywords-Plus = {KNOWLEDGE; MEDICINE},
Author-Email = {cdlin@xmu.edu.cn},
Number-of-Cited-References = {32},
Times-Cited = {14},
