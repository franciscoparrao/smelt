@article{ WOS:001429642900001,
Author = {Alzamer, Haneen and Jaafreh, Russlan and Kim, Jung-Gu and Hamad, Kotiba},
Title = {Artificial Intelligence and Li Ion Batteries: Basics and Breakthroughs
