   Kaimakis, Paris, Univ Cent Lancashire Cyprus, Univ Ave 12-14, CY-7080 Pyla, Cyprus.},
DOI = {10.1016/j.apenergy.2020.115023},
Article-Number = {115023},
Keywords = {Artificial neural networks; Clustering; Forecasting; Machine learning;
   Photovoltaic; Performance},
Keywords-Plus = {NUMERICAL WEATHER PREDICTION; SOLAR},
Author-Email = {theocharidis.spyros@ucy.ac.cy},
Number-of-Cited-References = {62},
Times-Cited = {150},
