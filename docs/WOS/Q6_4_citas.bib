@article{ WOS:000364422200003,
Author = {Mishina, Yohei and Murata, Ryuei and Yamauchi, Yuji and Yamashita,
   Takayoshi and Fujiyoshi, Hironobu},
Title = {Boosted Random Forest},
Journal = {IEICE TRANSACTIONS ON INFORMATION AND SYSTEMS},
Year = {2015},
Volume = {E98D},
Number = {9},
Pages = {1630-1636},
Month = {SEP},
Abstract = {Machine learning is used in various fields and demand for
   implementations is increasing. Within machine learning, a Random Forest
   is a multi-class classifier with high-performance classification,
   achieved using bagging and feature selection, and is capable of
   high-speed training and classification. However, as a type of ensemble
   learning, Random Forest determines classifications using the majority of
   multiple trees; so many decision trees must be built. Performance
   increases with the number of decision trees, requiring memory, and
   decreases if the number of decision trees is decreased. Because of this,
   the algorithm is not well suited to implementation on small-scale
   hardware as an embedded system. As such, we have proposed Boosted Random
   Forest, which introduces a boosting algorithm into the Random Forest
   learning method to produce high-performance decision trees that are
   smaller. When evaluated using databases from the UCI Machine learning
   Repository, Boosted Random Forest achieved performance as good or better
   than ordinary Random Forest, while able to reduce memory use by 47\%.
   Thus, it is suitable for implementing Random Forests on embedded
   hardware with limited memory.},
Type = {Article},
Affiliation = {Mishina, Y (Corresponding Author), Chubu Univ, Dept Comp Sci, Kasugai, Aichi 4878501, Japan.
   Mishina, Yohei; Murata, Ryuei; Yamauchi, Yuji; Yamashita, Takayoshi; Fujiyoshi, Hironobu, Chubu Univ, Dept Comp Sci, Kasugai, Aichi 4878501, Japan.},
DOI = {10.1587/transinf.2014OPP0004},
Keywords = {Boosting; Random Forest; machine learning; pattern recognition},
Keywords-Plus = {RECOGNITION},
Author-Email = {mishi@vision.cs.chubu.ac.jp
