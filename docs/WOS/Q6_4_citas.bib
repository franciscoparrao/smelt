   Yang, Tiansheng, Univ South Wales, Pontypridd, Newport, England.
   Rathore, Rajkumar Singh, Cardiff Metropolitan Univ, Cardiff Sch Technol, Cardiff, Wales.},
DOI = {10.1038/s41598-025-94500-5},
Article-Number = {9684},
Keywords = {IoT security; Deep learning; Hybrid LSTM-CNN; Intrusion detection;
   Cybersecurity; Threat detection; Machine learning},
Keywords-Plus = {ANOMALY DETECTION; ATTACK},
