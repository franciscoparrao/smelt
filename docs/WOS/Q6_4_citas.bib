   Chauhan, Vedang, Western New England Univ, Dept Mech Engn, Springfield, MA USA.
   Brahmbhatt, Niku, JG Coll Comp Applicat, ASIA Campus, Ahmadabad, Gujarat, India.},
DOI = {10.1002/er.7202},
EarlyAccessDate = {AUG 2021},
Keywords = {battery modeling; lithium-ion battery; machine learning; multivariate
   multioutput regression; scikit-learn; thermal modeling},
Keywords-Plus = {MANAGEMENT-SYSTEMS; VEHICLES; PROGRESS; ISSUES},
Author-Email = {kmtran@uwaterloo.ca},
Number-of-Cited-References = {36},
