Keywords-Plus = {ENERGY-CONVERSION EFFICIENCY; SURFACE FUNCTIONALIZATION; MECHANICAL
   ENERGY; HARVESTING ENERGY; FRICTION LAYER; OUTPUT POWER; ELECTRODE;
