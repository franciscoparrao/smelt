   Lee, Chan-Woo, KIER, Energy AI \& Comp Sci Lab, Daejeon 34129, South Korea.
   Lee, Kang Taek, KAIST Grad Sch Green Growth \& Sustainabil, Daejeon 34141, South Korea.},
DOI = {10.1002/aenm.202402342},
EarlyAccessDate = {AUG 2024},
Keywords = {electrocatalysts; first-principles calculation; machine learning;
   materials discovery; spinel oxides},
