@article{ WOS:000657202500030,
Author = {Lee, Sangwon and Kim, Baekjun and Cho, Hyun and Lee, Hooseung and Lee,
   Sarah Yunmi and Cho, Eun Seon and Kim, Jihan},
Title = {Computational Screening of Trillions of Metal-Organic Frameworks for
   High-Performance Methane Storage},
Journal = {ACS APPLIED MATERIALS \& INTERFACES},
Year = {2021},
Volume = {13},
Number = {20},
Pages = {23647-23654},
Month = {MAY 26},
Abstract = {In the past decade, there has been an increasing number of computational
   screening works to facilitate finding optimal materials for a variety of
   different applications. Unfortunately, most of these screening studies
   are limited to their initial set of materials and result in a
   brute-force type of screening approach. In this work, we present a
   systematic strategy that can find metal-organic frameworks (MOFs) with
   the desired properties from an extremely diverse and large set of over
   100 trillion possible MOFs using machine learning and evolutionary
   algorithm. It is demonstrated that our algorithm can discover 964 MOFs
   with methane working capacity over 200 cm(3) cm(-3) and 96 MOFs with
   methane working capacity over the current world record of 208 cm(3)
   cm(-3). We believe that this methodology can take advantage of the
   modular nature of MOFs and can readily be extended to other important
   applications as well.},
Type = {Article},
Affiliation = {Kim, J (Corresponding Author), Korea Adv Inst Sci \& Technol, Dept Chem \& Biomol Engn, Daejeon 34141, South Korea.
   Lee, Sangwon; Kim, Baekjun; Cho, Hyun; Cho, Eun Seon; Kim, Jihan, Korea Adv Inst Sci \& Technol, Dept Chem \& Biomol Engn, Daejeon 34141, South Korea.
   Lee, Hooseung; Lee, Sarah Yunmi, Yonsei Univ, Dept Chem, Seoul 03722, South Korea.},
DOI = {10.1021/acsami.1c02471},
EarlyAccessDate = {MAY 2021},
Keywords = {metal-organic framework; methane storage; machine learning; genetic
