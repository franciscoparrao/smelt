DOI = {10.1109/TTE.2024.3368920},
Keywords = {Cyberattack; Electric vehicle charging; Detectors; Ecosystems; Costs;
   Behavioral sciences; Transportation; Cyber-attack; electric vehicles
   (EVs); extreme fast chargers (XFCs); false data injection attack (FDIA);
   machine learning (ML) algorithm},
Keywords-Plus = {DATA INJECTION ATTACKS; SECURITY; VEHICLES; SYSTEMS},
Author-Email = {amirhosseinakbaryan@gmail.com
   mahdibahrami17@yahoo.com
   m.ahmadi7407@gmail.com
   vakilian@sharif.edu
   matti.lehtonen@aalto.fi},
Number-of-Cited-References = {32},
