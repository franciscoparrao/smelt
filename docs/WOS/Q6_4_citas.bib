Keywords = {thyroid cancer; cytopathology; histopathology; machine learning; deep
   learning; artificial intelligence},
Keywords-Plus = {FINE-NEEDLE-ASPIRATION; ARTIFICIAL NEURAL-NETWORK; EVALUATING
   CANCER-RISK; FOLLICULAR LESIONS; NUCLEAR FEATURES; INTEROBSERVER
   VARIABILITY; AUTOMATIC CLASSIFICATION; ASSOCIATION GUIDELINES;
