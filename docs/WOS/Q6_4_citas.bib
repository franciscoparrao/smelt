DOI = {10.3762/bjnano.15.119},
Keywords = {artificial intelligence; high-performance computing; HPC; machine;
   learning; materials modelling; multiscale modelling; nanomaterials;
   semantic data management},
Keywords-Plus = {MATERIALS SCIENCE; CLOUD; HPC; CHALLENGES; TOOL},
