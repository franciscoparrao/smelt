   Meng, Fan; Chen, Zhensong, Univ Chinese Acad Sci, Sch Econ \& Management, Beijing 100049, Peoples R China.},
DOI = {10.1109/TITS.2016.2552248},
Keywords = {Road crack detection; structured learning; machine learning; random
   structured forests; crack descriptor; crack characterization},
Author-Email = {yshi@ucas.ac.cn
