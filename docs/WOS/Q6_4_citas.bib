   Al-Dulaimi, Khamael, Queensland Univ Technol, Sch Elect Engn \& Robot, Brisbane, Qld 4059, Australia.
   Rehman, Amjad; Abunadi, Ibrahim, Prince Sultan Univ, Artificial Intelligence \& Data Analyt Lab, CCIS, Riyadh 11586, Saudi Arabia.
   Bahaj, Saeed Ali, Prince Sattam bin Abdulaziz Univ, Coll Business Adm, MIS Dept, Al Kharj 11942, Saudi Arabia.
   Bahaj, Saeed Ali, Hadhramout Univ, Coll Engn \& Petr, Dept Comp Engn, Mukalla 50511, Yemen.},
DOI = {10.1109/ACCESS.2022.3200603},
Keywords = {Feature extraction; Convolutional neural networks; Lighting;
   Computational modeling; Crops; Chemicals; Visualization; Economics;
   Agriculture; Classification algorithms; CNN networks; ensemble models;
   real-world data; weed classification; economic growth},
Keywords-Plus = {WEED DETECTION; PRECISION AGRICULTURE; NEURAL-NETWORKS; MACHINE VISION;
