   Nascimento, Francisco Assis de Oliveira, Inst Leonidas \& Maria Deane Fiocruz Amazonia, Manaus, AM, Brazil.},
DOI = {10.1016/j.ecoinf.2023.102430},
EarlyAccessDate = {DEC 2023},
