   Rajakannu, Amuthakkannan, Natl Univ Sci \& Technol, Coll Engn, Dept Mech \& Ind Engn, Muscat, Oman.},
DOI = {10.1007/s11468-025-03042-z},
EarlyAccessDate = {MAY 2025},
Keywords = {Plasmonic resonance; Dual-mode sensing; Point-of-care diagnostics;
   Machine learning optimization; Global health technology},
