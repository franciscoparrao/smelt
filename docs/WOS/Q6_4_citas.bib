@article{ WOS:000599703200004,
Author = {Wu, Re-Bing and Cao, Xi and Xie, Pinchen and Liu, Yu-xi},
Title = {End-To-End Quantum Machine Learning Implemented with Controlled Quantum
   Dynamics},
Journal = {PHYSICAL REVIEW APPLIED},
Year = {2020},
Volume = {14},
Number = {6},
Month = {DEC 7},
Abstract = {To achieve quantum machine learning on imperfect noisy
   intermediate-scale quantum (NISQ) processors, the entire physical
   implementation should include as few as possible hand-designed modules
   with only a few ad hoc parameters to be determined. This work presents
   such a hardware-friendly end-to-end quantum-machine-learning scheme that
   can be implemented with imperfect NISQ processors. The proposal
   transforms the machine-learning task to the optimization of controlled
   quantum dynamics, in which the learning model is parameterized by
   experimentally tunable control variables. Our design also enables
   automated feature selection by encoding the raw input to quantum states
   through agent control variables. Comparing with the gate-based
   parameterized quantum circuits, the proposed end-to-end quantum-learning
   model is easy to implement as there are only a few ad hoc parameters to
   be determined. Numerical simulations on the benchmarking MNIST (Mixed
   National Institute of Standards and Technology) dataset of handwritten
   digits demonstrate that the model can achieve high performance using
   only 3-5 qubits without downsizing the dataset, which shows great
   potential for accomplishing large-scale real-world learning tasks on
   NISQ processors.},
Type = {Article},
Affiliation = {Wu, RB (Corresponding Author), Tsinghua Univ, Dept Automat, Beijing 100084, Peoples R China.
   Wu, RB (Corresponding Author), Beijing Natl Res Ctr Informat Sci \& Technol, Beijing 100084, Peoples R China.
   Wu, Re-Bing; Cao, Xi, Tsinghua Univ, Dept Automat, Beijing 100084, Peoples R China.
   Wu, Re-Bing, Beijing Natl Res Ctr Informat Sci \& Technol, Beijing 100084, Peoples R China.
   Xie, Pinchen, Princeton Univ, Program Appl \& Computat Math, Princeton, NJ 08544 USA.
   Liu, Yu-xi, Tsinghua Univ, Inst Microelect, Beijing 100084, Peoples R China.},
DOI = {10.1103/PhysRevApplied.14.064020},
Article-Number = {064020},
Author-Email = {rbwu@tsinghua.edu.cn},
Number-of-Cited-References = {40},
Times-Cited = {22},
