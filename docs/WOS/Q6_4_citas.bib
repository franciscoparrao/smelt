   Yoo, Hyeonsuk; Lee, Yongjin, Inha Univ, Educ \& Res Ctr Smart Energy \& Mat, Dept Chem \& Chem Engn, Incheon 22212, South Korea.},
DOI = {10.1016/j.seppur.2021.119117},
EarlyAccessDate = {JUN 2021},
