@article{ WOS:000908068300002,
Author = {Willman, Jonathan T. and Nguyen-Cong, Kien and Williams, Ashley S. and
   Belonoshko, Anatoly B. and Moore, Stan G. and Thompson, Aidan P. and
   Wood, Mitchell A. and Oleynik, Ivan I.},
Title = {Machine learning interatomic potential for simulations of carbon at
   extreme conditions},
Journal = {PHYSICAL REVIEW B},
Year = {2022},
Volume = {106},
Number = {18},
Month = {NOV 30},
Abstract = {A spectral neighbor analysis (SNAP) machine learning interatomic
   potential (MLIP) has been developed for simulations of carbon at extreme
   pressures (up to 5 TPa) and temperatures (up to 20 000 K). This was
   achieved using a large database of experimentally relevant quantum
   molecular dynamics (QMD) data, training the SNAP potential using a
   robust machine learning methodology, and performing extensive validation
   against QMD and experimental data. The resultant carbon MLIP
   demonstrates unprecedented accuracy and transferability in predicting
   the carbon phase diagram, melting curves of crystalline phases, and the
   shock Hugoniot, all within 3\% of QMD. By achieving quantum accuracy and
   efficient implementation on leadership-class high-performance computing
   systems, SNAP advances frontiers of classical MD simulations by enabling
   atomic-scale insights at experimental time and length scales.},
Type = {Article},
Affiliation = {Oleynik, II (Corresponding Author), Univ S Florida, Dept Phys, Tampa, FL 33620 USA.
   Willman, Jonathan T.; Nguyen-Cong, Kien; Williams, Ashley S.; Oleynik, Ivan I., Univ S Florida, Dept Phys, Tampa, FL 33620 USA.
   Belonoshko, Anatoly B., Univ Royal Inst Technol, Dept Phys, Stockholm, Sweden.
   Moore, Stan G.; Thompson, Aidan P.; Wood, Mitchell A., Sandia Natl Labs, Albuquerque, NM 87185 USA.},
DOI = {10.1103/PhysRevB.106.L180101},
Article-Number = {L180101},
Keywords-Plus = {HIGH-PRESSURES; SHOCK COMPRESSION; DIAMOND; HYDROCARBONS; PHASE;
   DISSOCIATION; GENERATION},
Author-Email = {oleynik@usf.edu},
Number-of-Cited-References = {64},
Times-Cited = {47},
Unique-ID = {WOS:000908068300002},
