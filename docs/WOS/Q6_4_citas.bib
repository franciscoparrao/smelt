   Eslami, Saeid, Univ Amsterdam, Dept Med Informat, Amsterdam UMC, Amsterdam, Netherlands.},
DOI = {10.1016/j.ijpharm.2023.123414},
EarlyAccessDate = {SEP 2023},
Article-Number = {123414},
