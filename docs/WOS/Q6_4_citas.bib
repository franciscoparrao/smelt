@article{ WOS:001136371500064,
Author = {Li, Biaoshun and Lin, Mujie and Chen, Tiegen and Wang, Ling},
Title = {FG-BERT: a generalized and self-supervised functional group-based
   molecular representation learning framework for properties prediction},
Journal = {BRIEFINGS IN BIOINFORMATICS},
Year = {2023},
Volume = {24},
Number = {6},
Month = {SEP 22},
Abstract = {Artificial intelligence-based molecular property prediction plays a key
   role in molecular design such as bioactive molecules and functional
   materials. In this study, we propose a self-supervised pretraining deep
   learning (DL) framework, called functional group bidirectional encoder
   representations from transformers (FG-BERT), pertained based on similar
   to 1.45 million unlabeled drug-like molecules, to learn meaningful
   representation of molecules from function groups. The pretrained FG-BERT
   framework can be fine-tuned to predict molecular properties. Compared to
   state-of-the-art (SOTA) machine learning and DL methods, we demonstrate
   the high performance of FG-BERT in evaluating molecular properties in
   tasks involving physical chemistry, biophysics and physiology across 44
   benchmark datasets. In addition, FG-BERT utilizes attention mechanisms
   to focus on FG features that are critical to the target properties,
   thereby providing excellent interpretability for downstream training
   tasks. Collectively, FG-BERT does not require any artificially crafted
   features as input and has excellent interpretability, providing an
   out-of-the-box framework for developing SOTA models for a variety of
   molecule (especially for drug) discovery tasks.},
Type = {Article},
Affiliation = {Wang, L (Corresponding Author), South China Univ Technol, Sch Biol \& Biol Engn,Minist Educ, Guangdong Prov Engn \& Technol Res Ctr Biopharmace, Guangdong Prov Key Lab Fermentat \& Enzyme Engn,Jo, Guangzhou 510006, Peoples R China.
