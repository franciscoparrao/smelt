   Zhou, Zhi-Li, Nanjing Univ Informat Sci \& Technol, Sch Comp \& Software, Nanjing 210044, Jiangsu, Peoples R China.},
DOI = {10.1016/j.neucom.2017.09.055},
Keywords = {l(2,1)-norm; Elastic Net; Sparse minimization; Multi-class; Feature
   selection},
Keywords-Plus = {MOLECULAR CLASSIFICATION; GENE SELECTION; REGRESSION; CANCER; FACE;
