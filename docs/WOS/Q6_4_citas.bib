   Pouget, Stephane, Univ Calif Los Angeles, 404 Westwood Plaza,Engn 6, Los Angeles, CA 90095 USA.
   Cohen, Albert, Google, 8 Rue Londres, F-75009 Paris, France.
   Sadayappan, P., Univ Utah, Sch Comp, Salt Lake City, UT 84112 USA.},
DOI = {10.1145/3570641},
Article-Number = {20},
Keywords = {Code generation; optimisation space; microkernel; convolution},
Keywords-Plus = {AFFINE SCHEDULING PROBLEM; EFFICIENT SOLUTIONS; COMPILER},
