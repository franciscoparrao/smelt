   Eldar, Yonina C., Weizmann Inst Sci, Dept Math \& Comp Sci, IL-7610001 Rehovot, Israel.},
DOI = {10.1109/MSP.2022.3198805},
Keywords = {Electromagnetics; Physics; Electric potential; Inverse problems;
