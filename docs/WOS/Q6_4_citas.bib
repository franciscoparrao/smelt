   Alhammadi, Abdulraqeb, Univ Teknol Malaysia UTM, Malaysia Japan Int Inst Technol, Commun Syst \& Networks Res Lab, Kuala Lumpur 54100, Malaysia.},
DOI = {10.1016/j.aej.2022.08.017},
EarlyAccessDate = {DEC 2022},
Keywords = {6G; Autonomous vehicle; Visible light communication; Intelligence
