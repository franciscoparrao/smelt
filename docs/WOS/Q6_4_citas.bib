@article{ WOS:001048367600001,
Author = {Oyebisi, Solomon and Owamah, Hilary and Omeje, Maxwell},
Title = {Application of machine learning algorithm in the internal and external
   hazards from industrial byproducts},
Journal = {CLEANER ENGINEERING AND TECHNOLOGY},
Year = {2023},
Volume = {13},
Month = {APR},
Abstract = {Natural radioactive substances that are produced because of industrial
   processes pose a risk to both the envi-ronment and people. An extensive
   analysis of the radiological properties of industrial byproducts was
   undertaken in this work, and the risks for both indoor and outdoor
   environments were assessed based on activity concen-trations. The
   machine learning technique of artificial neural networks was used with
   various training algorithms to predict the internal and external hazards
   from these industrial byproducts. The findings demonstrated that, with
   the exception of incinerated sewage sludge ash, metakaolin, marble
   powder, nickel slag, pyrite ash, silica fume, steel slag, and glass
   waste powder, every industrial byproduct examined poses potential indoor
   and out-door dangers. All backpropagation training algorithms that were
   used showed high prediction, according to the neural networks. However,
   when compared to the Bayesian Regularization and Scaled Conjugate
   Gradient backpropagation training algorithms, the Levenberg-Marquardt
   backpropagation technique had the best per-formance indicators for
   training, validation, and testing. The results can provide reference
   information for developing a framework for monitoring hazards and their
   accompanying precise management.},
Type = {Article},
Affiliation = {Oyebisi, S (Corresponding Author), Covenant Univ, Dept Civil Engn, PMB 1023,Km 10,Idiroko Rd, Ota, Nigeria.
   Oyebisi, Solomon, Covenant Univ, Dept Civil Engn, PMB 1023,Km 10,Idiroko Rd, Ota, Nigeria.
