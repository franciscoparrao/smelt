   Berladir, Khrystyna; Ivanov, Vitalii; Mitalova, Zuzana, Tech Univ Kosice, Fac Mfg Technol, Dept Automobile \& Mfg Technol, Bayerova 1, Presov 08001, Slovakia.
   Antosz, Katarzyna, Rzeszow Univ Technol, Fac Mech Engn \& Aeronaut, PL-35959 Rzeszow, Poland.
   Ivanov, Vitalii, Sumy State Univ, Fac Tech Syst \& Energy Efficient Technol, Dept Mfg Engn Machines \& Tools, 116 Kharkivska St, UA-40007 Sumy, Ukraine.},
DOI = {10.3390/polym17050694},
