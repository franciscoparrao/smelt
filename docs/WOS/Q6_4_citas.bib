@article{ WOS:001472145300001,
Author = {Khan, Arslan Qayyum and Muhammad, Syed Ghulam and Raza, Ali and
   Chaimahawan, Preeda and Pimanmas, Amorn},
Title = {Advanced machine learning techniques for predicting compressive strength
   of ultra-high performance concrete},
Journal = {FRONTIERS OF STRUCTURAL AND CIVIL ENGINEERING},
Year = {2025},
Volume = {19},
Number = {4},
Pages = {503-523},
Month = {APR},
Abstract = {This study presents a robust framework for predicting the compressive
   strength of ultra-high performance concrete (UHPC) using machine
   learning models, based on a comprehensive data set of 761 data points
   derived from various UHPC mix designs. Six models, including K-Nearest
   Neighbors (KNN), Gradient Boosting Regression (GBR), Random Forest
   Regression (RFR), Support Vector Regression (SVR), Stacking and eXtreme
   Gradient Boosting (XGBoost), were evaluated. Among them, XGBoost
   demonstrated the best prediction accuracy, achieving a coefficient of
   determination (R2) of 0.969 and a root mean square error (RMSE) of 4.626
   MPa, outperforming the other models. The Stacking model also performed
   well with an R2 of 0.960, though it slightly overestimated at higher
   compressive strength levels. SHapley Additive exPlanations (SHAP)
   analysis revealed that curing time, silica fume, and aggregate content
   were the most significant factors influencing compressive strength.
   Curing time emerged as the dominant factor, significantly surpassing
   other variables such as silica fume and aggregate content in its impact
   on compressive strength. This dominance is attributed to its critical
   role in hydration and compressive strength development, while silica
   fume and aggregates primarily contributed by enhancing matrix
   densification and structural integrity. SHAP feature dependency analysis
   further highlighted complex interactions, particularly between water
   content and superplasticizer dosage, affecting workability and
   compressive strength.},
Type = {Article},
Affiliation = {Pimanmas, A (Corresponding Author), Kasetsart Univ, Dept Civil Engn, Bangkok 10900, Thailand.
   Khan, Arslan Qayyum, Univ Illinois, Dept Civil \& Environm Engn, Urbana, OH 61801 USA.
   Muhammad, Syed Ghulam; Raza, Ali, Univ Lahore, Dept Civil Engn, Lahore 54000, Pakistan.
   Chaimahawan, Preeda, Univ Phayao, Sch Engn, Pahyao 56000, Thailand.
   Pimanmas, Amorn, Kasetsart Univ, Dept Civil Engn, Bangkok 10900, Thailand.},
DOI = {10.1007/s11709-025-1169-4},
EarlyAccessDate = {APR 2025},
Keywords = {ultra-high performance concrete; compressive strength; machine learning;
   SHAP; prediction},
Keywords-Plus = {STEEL; ALGORITHM},
Author-Email = {amorn.pi@ku.th},
Number-of-Cited-References = {65},
Times-Cited = {15},
Unique-ID = {WOS:001472145300001},
}

@article{ WOS:001402234900001,
Author = {Yang, Bolong and Liu, Weiqian and Gu, Tao and Wu, Zhansheng},
Title = {Material design and catalyst-membrane electrode interface engineering
   for high-performance rechargeable zinc-air batteries},
Journal = {ENERGY STORAGE MATERIALS},
Year = {2025},
Volume = {74},
Month = {JAN},
Abstract = {Rechargeable zinc-air batteries (ZABs) are one of the new energy
   technologies with great development potential. However, their air
   electrodes still demand precious metal-based catalytic materials to
   accelerate the chemical reactions during the charging and discharging
   processes, thus increasing the overall battery cost. Developing
   efficient non-precious metal-based catalyst and constructing
   catalyst-membrane electrodes interface with hierarchical porous
   structures are currently the key and challenge for the development of
   ZABs. This review first introduces the configuration and working
   mechanisms of ZABs. Then the design concepts of oxygen electrocatalysts
   were discussed in detail, including metal-free, atomically dispersed
   metal site, and transition metal compound electrocatalysts. Meanwhile,
   the construction strategies of self-supporting electrodes, mainly
   including solvothermal, wet chemistry, electrochemical deposition and
   electrospinning technology, were reviewed from the level of
   catalyst-membrane electrode interface engineering. It deeply explores
   enhancing the catalytic activity and stability of electrocatalysts via
   rational structural design and examines the impact of diverse synthesis
   strategies on electrocatalyst performance. Moreover, the current
   approaches to understand the mechanism of air electrode were summarized
   through theoretical calculation, data-driven machine learning, atomic
   scale characterization, and In-situ operation and characterization.
   Finally, the development prospects and challenges of ZABs were discussed
   in depth, aiming to provide valuable insights for future commercial
   applications of ZABs.},
Type = {Article},
Affiliation = {Yang, BL; Wu, ZS (Corresponding Author), Xian Polytech Univ, Sch Environm \& Chem Engn, Xian Key Lab Text Chem Engn Auxiliaries, Xian 710048, Peoples R China.
   Yang, Bolong; Liu, Weiqian; Gu, Tao; Wu, Zhansheng, Xian Polytech Univ, Sch Environm \& Chem Engn, Xian Key Lab Text Chem Engn Auxiliaries, Xian 710048, Peoples R China.},
DOI = {10.1016/j.ensm.2024.103985},
EarlyAccessDate = {DEC 2024},
Article-Number = {103985},
Keywords = {Oxygen electrocatalysts; Self-supporting electrodes; Mechanistic
   understanding; Zinc-air batteries},
Keywords-Plus = {BIFUNCTIONAL OXYGEN ELECTROCATALYST; METAL-ORGANIC FRAMEWORK; DOPED
   CARBON; EFFICIENT ELECTROCATALYSTS; COORDINATION-ENVIRONMENT; HYDROGEN
   EVOLUTION; ACTIVE-SITES; REDUCTION; NITROGEN; IDENTIFICATION},
