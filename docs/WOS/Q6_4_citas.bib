   Kepner, Jeremy; Gadepally, Vijay; Jones, Michael; Samsi, Sid, MIT Lincoln Lab, Supercomp Ctr, Lexington, MA 02421 USA.
   Kepner, Jeremy; Alford, Simon; Gadepally, Vijay, MIT Comp Sci \& AI Lab, Cambridge, MA 02139 USA.
   Kepner, Jeremy; Robinett, Ryan, MIT Math Dept, Cambridge, MA 02142 USA.
   Milechin, Lauren, MIT Dept Earth Atmospher \& Planetary Sci, Cambridge, MA USA.},
DOI = {10.1109/hpec.2019.8916336},
Number-of-Cited-References = {57},
Times-Cited = {33},
