   Mi, Yongtao, Harbin Engn Univ, Coll Aerosp \& Civil Engn, Harbin 150001, Peoples R China.},
DOI = {10.1038/s41598-024-79502-z},
Article-Number = {28346},
Keywords = {Machine learning; Proportional features; Random search; Compressive
   strength prediction; SHapley Additive exPlanations},
Keywords-Plus = {METASTABLE GRAIN-BOUNDARIES; RATIO},
Author-Email = {renwangjun123@126.com
   cyc-lgdx@foxmail.com},
Number-of-Cited-References = {66},
Times-Cited = {23},
Unique-ID = {WOS:001356316700047},
}

@article{ WOS:001229783900001,
Author = {Anagnostopoulos, Argyrios and Xenitopoulos, Theofilos and Ding, Yulong
   and Seferlis, Panos},
Title = {An integrated machine learning and metaheuristic approach for advanced
   packed bed latent heat storage system design and optimization},
Journal = {ENERGY},
Year = {2024},
Volume = {297},
Month = {JUN 15},
Abstract = {To tackle the challenge of waste heat recovery in the industrial sector,
   this research presents a novel design and optimization framework for
   Packed Bed Latent Heat Storage Systems (PBLHS). This features a Deep
   Learning (DL) model, integrated with metaheuristic algorithms. The DL
   model was developed to predict PBLHS performance, trained using data
   generated from a validated Computational Fluid Dynamics (CFD) model. The
   model exhibited a high performance with an R(2 )value of 0.975 and a low
   Mean Absolute Percentage Error (<9.14\%). To enhance the ML model's
   efficiency and optimized performance, various metaheuristic algorithms
   were explored. The Harmony Search algorithm emerged as the most
   effective through an early screening and underwent further refinement.
   The optimized algorithm demonstrated its capability by rapidly producing
   designs that showcased an improvement in total efficiency of up to 85\%
   over available optimized experimental PBLHS designs. This research
   underscores the potential of ML-integrated approaches in laying the
   groundwork for generalized design frameworks for TES systems, offering
   efficient and effective solutions for waste heat recovery.},
Type = {Article},
Affiliation = {Anagnostopoulos, A (Corresponding Author), Aristotle Univ Thessaloniki, Dept Mech Engn, POB 454, Thessaloniki 54124, Greece.
   Anagnostopoulos, Argyrios; Xenitopoulos, Theofilos; Seferlis, Panos, Aristotle Univ Thessaloniki, Dept Mech Engn, POB 454, Thessaloniki 54124, Greece.
   Anagnostopoulos, Argyrios, Univ Silesia, Inst Chem, PL-40006 Katowice, Poland.
   Ding, Yulong, Univ Birmingham, Birmingham Ctr Energy Storage, Birmingham B15 2TT, England.
   Ding, Yulong, Univ Birmingham, Sch Chem Engn, Birmingham B15 2TT, England.},
DOI = {10.1016/j.energy.2024.131149},
EarlyAccessDate = {APR 2024},
Article-Number = {131149},
Keywords = {Packed bed latent heat storage; Deep learning optimization;
   Metaheuristic algorithms; Thermal energy storage design; Phase change
   materials},
Keywords-Plus = {THERMAL-ENERGY STORAGE; WASTE HEAT; RECOVERY; INDUSTRY; TES; EU},
Author-Email = {argyanag@meng.auth.gr},
