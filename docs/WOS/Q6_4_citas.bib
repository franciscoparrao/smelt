DOI = {10.1016/j.jksuci.2024.102069},
EarlyAccessDate = {JUN 2024},
Article-Number = {102069},
Keywords = {Software-Defined Networking (SDN); Industrial Internet of Things (IIoT);
   SDN-IIoT architecture; Software-Defined Industrial Network (SDIN); SDN
   solutions},
Keywords-Plus = {SOFTWARE-DEFINED NETWORKING; EDGE-CLOUD; DISTRIBUTED BLOCKCHAIN;
