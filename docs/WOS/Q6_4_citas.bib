   Abueidda, Diab W.; Sobh, Nahil A., Univ Illinois, Beckman Inst Sci \& Technol, Champaign, IL 61820 USA.},
DOI = {10.1016/j.compstruc.2020.106283},
Article-Number = {106283},
Keywords = {Adjoint sensitivity; Finite element analysis (FEA); Machine learning;
   Neo-Hookean materials; Stress constraint},
Keywords-Plus = {NEURAL-NETWORK; DESIGN; SIMULATION; MITIGATION; FRAMEWORK; ALGORITHM;
   STIFFNESS},
Author-Email = {sobh@illinois.edu},
