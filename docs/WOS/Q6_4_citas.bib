   Situ, Yizhen, Beijing Univ Chem Technol, State Key Lab Organ Inorgan Composites, Beijing 100029, Peoples R China.},
DOI = {10.1016/j.jcis.2024.02.098},
EarlyAccessDate = {FEB 2024},
Keywords = {Deep learning; Metal -organic frameworks; Adsorption separation; Open
   metal sites; Breakthrough curves},
Keywords-Plus = {FLUE-GAS DESULFURIZATION; SULFUR-DIOXIDE; FORCE-FIELD; ADSORPTION; CO2;
   SO2; SEPARATION; REMOVAL; DESIGN; ENERGY},
