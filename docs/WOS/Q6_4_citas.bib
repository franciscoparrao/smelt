Keywords = {Machine learning; materials design; domain knowledge; applications of
   machine learning},
Keywords-Plus = {HIGH-ENTROPY ALLOYS; BETA-TI ALLOYS; AUSTENITE FORMATION; PREDICTION;
   DISCOVERY; NETWORKS; FORMULAS; MODEL; LIFE},
