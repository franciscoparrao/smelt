   Carminati, M., Ist Nazl Fis Nucl, I-20133 Milan, Italy.
   Scandurra, G., Univ Messina, Dipartimento Ingn, I-98166 Messina, Italy.},
DOI = {10.1063/5.0050999},
Article-Number = {091501},
Keywords-Plus = {IMPEDANCE SPECTROSCOPY; FAULT-DIAGNOSIS; FPGA; SYSTEM; DESIGN; SENSOR;
   IMPLEMENTATION; CONTROLLER; VIBRATION; FEEDBACK},
Author-Email = {marco1.carminati@polimi.it},
Number-of-Cited-References = {105},
Times-Cited = {23},
