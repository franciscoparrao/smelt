   Gao, Robert X., Case Western Reserve Univ, Dept Mech \& Aerosp Engn, Cleveland, OH 44106 USA.
   Kurfess, Thomas, Georgia Inst Technol, GW Woodruff Sch Mech Engn, Atlanta, GA 30332 USA.},
DOI = {10.1016/j.jmsy.2017.02.011},
Keywords = {Fog computing; Machine learning; Industrial internet of things;
