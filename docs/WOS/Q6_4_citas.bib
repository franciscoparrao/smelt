   Lavin, Alexander, Pasteur Labs \& ISI, Brooklyn, NY 11205 USA.
   Wainwright, Haruko, MIT, Dept Nucl Sci \& Engn, Dept Civil \& Environm Engn, Cambridge, MA 02139 USA.},
DOI = {10.1016/j.cageo.2023.105508},
EarlyAccessDate = {DEC 2023},
Article-Number = {105508},
Keywords = {Soil and groundwater contamination; Physics-informed machine learning;
