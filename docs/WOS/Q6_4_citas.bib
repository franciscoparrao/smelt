@article{ WOS:000375594800010,
Author = {Chang, Tsung-Hui and Liao, Wei-Cheng and Hong, Mingyi and Wang,
   Xiangfeng},
Title = {Asynchronous Distributed ADMM for Large-Scale Optimization-Part II:
   Linear Convergence Analysis and Numerical Performance},
Journal = {IEEE TRANSACTIONS ON SIGNAL PROCESSING},
Year = {2016},
Volume = {64},
Number = {12},
Pages = {3131-3144},
Month = {JUN 15},
Abstract = {The alternating direction method of multipliers (ADMM) has been
   recognized as a versatile approach for solving modern large-scale
   machine learning and signal processing problems efficiently. When the
   data size and/or the problem dimension is large, a distributed version
   of ADMM can be used, which is capable of distributing the computation
   load and the data set to a network of computing nodes. Unfortunately, a
   direct synchronous implementation of such algorithm does not scale well
   with the problem size, as the algorithm speed is limited by the slowest
   computing nodes. To address this issue, in a companion paper, we have
   proposed an asynchronous distributed ADMM (AD-ADMM) and studied its
   worst-case convergence conditions. In this paper, we further the study
   by characterizing the conditions under which the AD-ADMM achieves linear
   convergence. Our conditions as well as the resulting linear rates reveal
   the impact that various algorithm parameters, network delay, and network
   size have on the algorithm performance. To demonstrate the superior time
   efficiency of the proposed AD-ADMM, we test the AD-ADMM on a
   high-performance computer cluster by solving a large-scale logistic
   regression problem.},
Type = {Article},
Affiliation = {Chang, TH (Corresponding Author), Chinese Univ Hong Kong, Sch Sci \& Engn, Shenzhen 518172, Peoples R China.
   Chang, Tsung-Hui, Chinese Univ Hong Kong, Sch Sci \& Engn, Shenzhen 518172, Peoples R China.
   Liao, Wei-Cheng, Univ Minnesota, Dept Elect \& Comp Engn, Minneapolis, MN 55455 USA.
   Hong, Mingyi, Iowa State Univ, Dept Ind \& Mfg Syst Engn, Ames, IA 50011 USA.
   Wang, Xiangfeng, E China Normal Univ, Shanghai Key Lab Trustworthy Comp, Sch Comp Sci \& Software Engn, Shanghai 200062, Peoples R China.},
DOI = {10.1109/TSP.2016.2537261},
Keywords = {Distributed optimization; ADMM; asynchronous; consensus optimization},
Keywords-Plus = {SHRINKAGE},
Author-Email = {tsunghui.chang@ieee.org
   liaox146@umn.edu
   mingyi@iastate.edu
   xfwang@sei.ecnu.edu.cn},
