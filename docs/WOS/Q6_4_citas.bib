   Yoo, Doo-Yeol, Yonsei Univ, Dept Architecture \& Architectural Engn, 50 Yonsei Ro, Seoul 03722, South Korea.},
DOI = {10.1016/j.engappai.2024.109053},
EarlyAccessDate = {AUG 2024},
