@article{ WOS:000387086200003,
Author = {Zhang, Qian and Feng, Ting and Xu, Lei and Sun, Huiyong and Pan, Peichen
   and Li, Youyong and Li, Dan and Hou, Tingjun},
Title = {Recent Advances in Protein-Protein Docking},
Journal = {CURRENT DRUG TARGETS},
Year = {2016},
Volume = {17},
Number = {14},
Pages = {1586-1594},
Abstract = {Protein-protein interactions (PPIs) play important roles in a variety of
   biological processes, and many PPIs have been regarded as biologically
   compelling targets for drug discovery. Extensive efforts have been made
   to develop feasible protein-protein docking approaches to study PPIs in
   silico. Most of these approaches are composed of two stages: sampling
   and scoring. Sampling is used to generate a number of plausible
   protein-protein binding conformations and scoring can rank all those
   conformations. Due to large and flexible binding interface of PPI,
   determination of the near native structures is computationally
   expensive, and therefore computational efficiency is the most
   challenging issue in protein-protein docking. Here, we have reviewed the
   basic concepts and implementations of the sampling, scoring and
   acceleration algorithms in some established docking programs, and the
   limitations of these algorithms have been discussed. Then, some
   suggestions to the future directions for sampling, scoring and
   acceleration algorithms have been proposed. This review is expected to
   provide a better understanding of protein-protein docking and give some
   clues for the optimization and improvement of available approaches.},
Type = {Review},
Affiliation = {Li, D; Hou, TJ (Corresponding Author), Zhejiang Univ, Coll Pharmaceut Sci, Hangzhou 310058, Zhejiang, Peoples R China.
   Zhang, Qian; Feng, Ting; Xu, Lei; Sun, Huiyong; Pan, Peichen; Li, Dan; Hou, Tingjun, Zhejiang Univ, Coll Pharmaceut Sci, Hangzhou 310058, Zhejiang, Peoples R China.
   Li, Youyong, Soochow Univ, Inst Funct Nano \& Soft Mat FUNSOM, Suzhou 215123, Jiangsu, Peoples R China.},
DOI = {10.2174/1389450117666160112112640},
Keywords = {Acceleration; GPU; machine learning; protein-protein docking; ranking;
   scoring function},
Keywords-Plus = {MOLECULAR-DYNAMICS SIMULATIONS; SHAPE COMPLEMENTARITY; AUTOMATED
   DOCKING; GENETIC ALGORITHM; HIGH-PERFORMANCE; ELECTROSTATICS;
   REFINEMENT; CAPRI; GPU; IMPLEMENTATION},
Author-Email = {lidancps@zju.edu.cn
   tingjunhou@zju.edu.cn},
Number-of-Cited-References = {75},
