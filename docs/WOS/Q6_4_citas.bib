@article{ WOS:001313096500001,
Author = {Zhou, Yinjie and Ji, Sibei and He, Songyang and Fan, Wei and Zan, Liang
   and Zhou, Li and Ji, Xu and He, Ge},
Title = {Machine Learning-Assisted High-Throughput Screening of Metal-Organic
   Frameworks for CO2 Separation from CO2-Rich
   Natural Gas},
Journal = {INDUSTRIAL \& ENGINEERING CHEMISTRY RESEARCH},
Year = {2024},
Volume = {63},
Number = {38},
Pages = {16497-16508},
Month = {SEP 13},
Abstract = {Under the appeal of carbon peaking and carbon neutrality goals, it is
   highly advisable to develop green chemical technologies. Based on this,
   it is even more attractive to synthesize methanol with the H-2 generated
   from water electrolysis by offshore wind power and the CO2 separated
   from offshore CO2-rich natural gas. Therefore, the separation and
   adsorption of CO2-rich natural gas in this context is of great
   socioeconomic significance. However, the conventional high-throughput
   screening methods for metal-organic frameworks (MOFs) in separating
   natural gas components and CO2 suffer from great challenges such as high
   model complexity and long computation time. To address the
   aforementioned problems, a machine learning-assisted modeling and
   screening strategy is proposed herein for the rapid and efficient
   separation of CO2 from the actual natural gas of six components (N-2,
   CO2, CH4, C2H6, C3H8, and H2S). First, structural analysis is used to
   eliminate the MOFs that cannot adsorb CO2 from the Computation-Ready
   Experimental Metal-Organic Frameworks (CoRE-MOFs) database. Six
   structural and 17 chemical descriptors of the remaining MOFs were
   calculated. Grand Canonical Monte Carlo (GCMC) simulations were applied
   to evaluate the separation performance metrics of the randomly selected
   training and testing MOF samples. By combining 23 descriptors and
   separation performance metrics, a Random Forest (RF) regression model
   was obtained with R-2 exceeding 0.92 on the test samples, which was
   employed to predict the separation performance of the remaining MOFs. As
   a result, 10 MOF candidates with the best CO2 separation performance
   were obtained. Furthermore, a structure-property relationship of MOFs
   with satisfactory regenerability was conducted. Three design strategies
   were proposed to guide the development of high-performance novel MOFs
   for CO2 separation. This study offers a high-throughput screening
   framework for MOFs to facilitate the separation of CO2 from a CO2-rich
   natural gas.},
Type = {Article},
Affiliation = {He, G (Corresponding Author), Sichuan Univ, Sch Chem Engn, Chengdu 610065, Peoples R China.
   Zhou, Yinjie; Ji, Sibei; He, Songyang; Fan, Wei; Zan, Liang; Zhou, Li; Ji, Xu; He, Ge, Sichuan Univ, Sch Chem Engn, Chengdu 610065, Peoples R China.},
DOI = {10.1021/acs.iecr.4c02357},
EarlyAccessDate = {SEP 2024},
Keywords-Plus = {FORCE-FIELD; IN-SILICO; ADSORPTION; HYDROGENATION; CATALYSTS; N-2; CH4;
   NI},
Author-Email = {hege@scu.edu.cn},
Number-of-Cited-References = {51},
Times-Cited = {11},
Unique-ID = {WOS:001313096500001},
}

@article{ WOS:001311778400001,
Author = {Zhang, Bo and Li, Xueqing and Xu, Xinxin and Cao, Jingguo and Zeng, Ming
   and Zhang, Wu},
Title = {Multi-property prediction and high-throughput screening of polyimides:
   An application case for interpretable machine learning},
Journal = {POLYMER},
Year = {2024},
Volume = {312},
Month = {OCT 24},
Abstract = {Polyimide (PI), as a high-performance polymer widely used in aerospace,
   optoelectronics, microelectronics, etc., the properties it focused on in
   different areas of application were diverse. However, most of the past
   machine learning studies in polyimide property prediction were focused
   only on the prediction of a single property. This study focused on four
   major categories of properties of polyimide, including thermal (Tg,
   T-d5, T-d10, and CTE), mechanical (Ts and TM), dielectric (epsilon), and
   optical (lambda(cutoff), T400, n(av), and Delta n), totaling eleven
   properties. PI data synthesized from previous studies were collected.
   MorGan fingerprints, improved MorGan fingerprints, RDkit and Mordred
   descriptors were selected as feature representations. Four ML models
   such as DNN, RF, XGBoost and BT were also built. Collectively, 176
   machine learning models were trained for 11 predictions of properties.
   The performance and generalization ability of the models were confirmed
   by experimental validation, external validation and leave-one-out
   cross-validation. SHAP analysis was used to explain the optimal model
   for each property prediction from a physicochemical point of view and
   structural aspects, and three PIs with different structures were
   designed accordingly. Finally, a high-throughput virtual screening of
   nearly 7.6 million polyimides was performed based on the trained model.
   SA\_scores was used to evaluate the ease of synthesis of each PI, and
   finally high-performance PIs with potential and easy to synthesize were
   selected for each field. This study could be expected to provide a
   guideline and a design framework for the application of PIs in various
   fields in the future.},
Type = {Article},
Affiliation = {Zeng, M (Corresponding Author), Tianjin Univ Sci \& Technol, Coll Marine \& Environm Sci, Tianjin 300457, Peoples R China.
   Cao, JG (Corresponding Author), Tianjin Univ Sci \& Technol, Coll Chem Engn \& Mat Sci, Tianjin 300457, Peoples R China.
   Zhang, Bo; Zeng, Ming; Zhang, Wu, Tianjin Univ Sci \& Technol, Coll Marine \& Environm Sci, Tianjin 300457, Peoples R China.
   Xu, Xinxin, Zhejiang Univ, Coll Environm \& Resource Sci, Dept Environm Engn, Hangzhou 310058, Peoples R China.
   Li, Xueqing; Cao, Jingguo, Tianjin Univ Sci \& Technol, Coll Chem Engn \& Mat Sci, Tianjin 300457, Peoples R China.},
DOI = {10.1016/j.polymer.2024.127603},
EarlyAccessDate = {SEP 2024},
Article-Number = {127603},
Keywords = {Polyimide; Machine learning; Heat resistance; Mechanical properties;
   Dielectricity; Optical properties},
Author-Email = {cjg@tust.edu.cn
   ming.zeng@tust.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {11},
Unique-ID = {WOS:001311778400001},
}

@article{ WOS:001276180800001,
Author = {Gnekpe, Christian and Tchuente, Dieudonne and Nyawa, Serge and Dey,
   Prasanta Kumar},
Title = {Energy Performance of Building Refurbishments: Predictive and
   Prescriptive AI-based Machine Learning Approaches},
Journal = {JOURNAL OF BUSINESS RESEARCH},
Year = {2024},
Volume = {183},
Month = {OCT},
Abstract = {The energy performance (EP) of buildings is critical for European
   governments to meet their decarbonization targets by 2050. In the
   context of European Union (EU) policies, which subsidize citizen-led
   building renovations, it is imperative to ascertain the efficacy of
   these renovations in significantly enhancing EP. This study relies on
   six AI-based machine learning (ML) algorithms to identify key predictors
   and prescribe measures for enhancing post-renovation EP in building
   refurbishments. The gradient boosting model outperforms the other ML
   models with an accuracy rate of 84.34 \% as the most effective
   predictive model. Moreover, an analysis of numerous predictors in the
   experiment showed that implementing modern energy-efficient heating
   systems, optimizing dwelling characteristics, regular maintenance,
   investing in high-performance insulation materials, and understanding
   the dynamics of the occupants were relevant prescriptions for efficient
   energy-saving strategies. The results should enable market actors to
   make optimal decisions regarding EP refurbishments.},
Type = {Article},
Affiliation = {Dey, PK (Corresponding Author), Aston Univ, Aston Business Sch, Birmingham B4 7ET, England.
   Gnekpe, Christian; Tchuente, Dieudonne; Nyawa, Serge, TBS Business Sch, 1 Pl Alphonse Jourdain,CS 66810, F-31068 Toulouse 7, France.
   Dey, Prasanta Kumar, Aston Univ, Aston Business Sch, Birmingham B4 7ET, England.},
DOI = {10.1016/j.jbusres.2024.114821},
EarlyAccessDate = {JUL 2024},
Article-Number = {114821},
Keywords = {Energy efficiency; Machine learning; Artificial intelligence; Predictor
   importance open data; France},
Keywords-Plus = {NATURAL-GAS CONSUMPTION; EFFICIENCY MEASURES; INDOOR CLIMATE;
   RENOVATION; RETROFIT; SAVINGS; MODELS; INSULATION; FRAMEWORK; IMPACT},
