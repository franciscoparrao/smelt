   Ho, Laishan, Univ Queensland, Queensland, Australia.
   Liu, Wenxuan; Wang, Lukun, Shandong Univ Sci \& Technol, Qingdao, Peoples R China.},
DOI = {10.1109/MCOMSTD.0005.2200044},
Keywords = {6G mobile communication; Training; Privacy; Data privacy; Federated
   learning; Voting; Reinforcement learning},
Number-of-Cited-References = {13},
Times-Cited = {50},
