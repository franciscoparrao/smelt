   Cheng, Min, BYD Co Ltd, Shenzhen 518122, Guangdong, Peoples R China.
   Dai, Zhongde, Sichuan Univ, Sch Carbon Neutral Future Technol, Chengdu 610065, Peoples R China.},
DOI = {10.1021/acs.iecr.4c00855},
EarlyAccessDate = {APR 2024},
Keywords-Plus = {COVALENT-ORGANIC FRAMEWORKS; MIXED MATRIX MEMBRANES; TRANSFERABLE
   POTENTIALS; METHANE ADSORPTION; PHASE-EQUILIBRIA; CARBON-DIOXIDE;
   FORCE-FIELD; MIXTURES; MODELS},
