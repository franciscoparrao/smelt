   Tosic, Nikola; de la Fuente, Albert, Univ Politecn Cataluna, Civil \& Environm Engn Dept, Jordi Girona 1-3, Barcelona 08034, Spain.},
DOI = {10.1016/j.conbuildmat.2022.129019},
EarlyAccessDate = {SEP 2022},
Article-Number = {129019},
Keywords = {Supplementary cementitious materials; Blended cement concrete; Strength
   prediction; Durability prediction; Regression model},
Keywords-Plus = {SELF-COMPACTING CONCRETE; BLAST-FURNACE SLAG; LIFE-CYCLE ASSESSMENT;
