   Abellan, Jose L., Univ Catolica San Antonio Murcia, Murcia, Spain.
   Ukidave, Yash, AMD, Santa Clara, CA USA.},
DOI = {10.1109/ISPASS51385.2021.00013},
Keywords = {graphs; benchmarks; GNN training; GPUs},
Author-Email = {tbaruah@ece.neu.edu
   kaustubhcs@ece.neu.edu
