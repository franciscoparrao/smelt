EarlyAccessDate = {NOV 2024},
Article-Number = {235753},
Keywords = {PEMFC; Flow field; Machine learning},
Keywords-Plus = {GEOMETRY OPTIMIZATION; BIPOLAR PLATES; CHANNEL; SIMULATION},
