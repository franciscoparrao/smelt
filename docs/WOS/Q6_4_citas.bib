   Rodriguez, Julio C., SOAN Labs, Bogota, Colombia.},
DOI = {10.3390/polym14112262},
Article-Number = {2262},
Keywords = {viscoelasticity; machine learning; response surface methodology; natural
   rubber; reverse engineering; formulation; optimization; modeling},
Keywords-Plus = {DYNAMIC-MECHANICAL PROPERTIES; CROSS-LINK DENSITY; VISCOELASTIC
   PROPERTIES; MORPHOLOGY; BEHAVIOR; LATEX},
Author-Email = {ajroman@wisc.edu
