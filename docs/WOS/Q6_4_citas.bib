DOI = {10.1186/s13321-016-0179-6},
Article-Number = {67},
Keywords = {Predictive modelling; Machine learning; Workflows; Drug discovery;
   Flow-based programming},
Keywords-Plus = {QSAR; LIBRARY; GALAXY},
