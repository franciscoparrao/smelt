   Univ Calif Santa Cruz, Ctr Biomol Sci \& Engn, Baskin Engn, Santa Cruz, CA 95064 USA.},
DOI = {10.1109/TPDS.2005.12},
Keywords = {parallel processing; SIMD; systolic array; biological sequence analysis;
   DNA; computational chemistry; image processing; VLSI system design;
   computer architecture; high performance computing},
