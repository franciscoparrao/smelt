DOI = {10.3390/electronics9040577},
Article-Number = {577},
Keywords = {intrusion-detection system; NSGAII; ANN; feature selection},
Keywords-Plus = {INTRUSION DETECTION SYSTEM; NETWORK ANOMALY DETECTION;
