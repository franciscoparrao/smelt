Keywords = {Blockchains; Indexes; Vehicle dynamics; Stability criteria; Mobile
   nodes; Scalability; Consensus protocol; Blockchain; AI; ANNs; consensus
   node selection algorithm; machine learning; mobile consensus nodes},
