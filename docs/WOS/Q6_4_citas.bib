DOI = {10.1021/acs.jcim.5b00175},
Keywords-Plus = {MODELS; EXTRACTION},
Author-Email = {bajorath@bit.uni-bonn.de},
Number-of-Cited-References = {40},
Times-Cited = {42},
Unique-ID = {WOS:000356903200007},
}

@article{ WOS:001562202900001,
Author = {Peng, Ligang and Miao, Xu and Zhu, Ji-Xiang and Zhang, Ming-Qi and
   Zheng, Xiao-Qing and Li, Heng-Yang and Wang, Yuzhou and Jiang, Xi and
   Huang, Bo-Tao},
Title = {Hybrid machine learning and multi-objective optimization for intelligent
   design of green and low-carbon concrete},
Journal = {SUSTAINABLE MATERIALS AND TECHNOLOGIES},
Year = {2025},
Volume = {45},
Month = {OCT},
Abstract = {The increasing utilization of recycled aggregates and supplementary
   cementitious materials in green and lowcarbon concrete production
   demands advanced methods to predict and optimize the performance, yet
   challenges remain in performance, sustainability, and cost trade-offs.
   In this study, a comprehensive database for recycled aggregate concrete
   using supplementary cementitious materials was established, and a hybrid
   framework integrating machine learning and multi-objective optimization
   was proposed. Results demonstrated that Sparrow Search Algorithm
   optimized models significantly outperformed base models, with Sparrow
   Search Algorithm-Extreme Gradient Boosting achieving superior accuracy
   with R2 values of 0.9403 for slump, 0.9428 for compressive strength,
   0.9017 for total charge passed. Shapley additive explanation analysis
   quantified feature contributions, revealing fly ash/superplasticizer
   dosage, effective water-binder ratio, and cement dosage as dominant
   factors for slump, compressive strength, and total charge passed,
   respectively. Furthermore, the advanced third-generation non-dominated
   sorting genetic algorithm and the technique for order of preference by
   similarity to ideal solution were integrated to optimize mix designs,
   balancing compressive strength, carbon emissions, and material costs.
   Sensitivity analysis highlighted the impacts of recycled aggregates and
   supplementary cementitious material replacement ratios, and
   transportation distances on performance, sustainability, and
   cost-effectiveness. This study is the establishment of this robust
   framework, which provides a systematic, data-driven roadmap for
   designing high-performance, low-carbon, and cost-effective concrete,
   thereby offering a viable pathway toward sustainable infrastructure.},
