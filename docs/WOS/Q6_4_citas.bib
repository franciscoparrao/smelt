   Li, Tao, Univ Florida, Dept Elect \& Comp Engn, Gainesville, FL 32611 USA.},
DOI = {10.1109/TPDS.2020.2990429},
Keywords = {Parallel; partition; sparse tensor data structure; sparse tensor-vector
