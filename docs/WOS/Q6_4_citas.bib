@article{ WOS:000746826800001,
Author = {Sakano, Kosuke and Igarashi, Yasuhiko and Imai, Hiroaki and Miyakawa,
   Shuntaro and Saito, Takaya and Takayanagi, Yoshiki and Nishiyama, Koji
   and Oaki, Yuya},
Title = {Performance Predictors for Organic Cathodes of Lithium-Ion Battery},
Journal = {ACS APPLIED ENERGY MATERIALS},
Year = {2022},
Volume = {5},
Number = {2},
Pages = {2074-2082},
Month = {FEB 28},
Abstract = {Organic cathodes for lithium-ion batteries are one of the most promising
   and significant materials toward a sustainable society. The molecular
   design is a key to achieve superior performances beyond inorganic
   cathodes. The present work shows predictors of the reaction potential,
   specific capacity, and ideal energy density for organic cathodes.
   Straightforward prediction models of the performance were constructed by
   a combination of machine learning and chemical insight, namely, sparse
   modeling for small data (SpM-S), on a small data set as training data
   found in the literature. The prediction accuracy was validated using
