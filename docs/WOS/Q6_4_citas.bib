   oerling@fb.com
   mbasmanova@fb.com
   kevinwilfong@fb.com
   lsakka@fb.com
   kpai@fb.com
   weihe@fb.com
   biswapesh@fb.com},
Number-of-Cited-References = {20},
Times-Cited = {28},
Unique-ID = {WOS:000992393000009},
}

@article{ WOS:000667254000001,
Author = {Qiao, Zhiwei and Li, Lifeng and Li, Shuhua and Liang, Hong and Zhou,
   Jian and Snurr, Randall Q.},
Title = {Molecular fingerprint and machine learning to accelerate design of
   high-performance homochiral metal-organic frameworks},
Journal = {AICHE JOURNAL},
Year = {2021},
Volume = {67},
Number = {10},
Month = {OCT},
Abstract = {Computational screening was employed to calculate the enantioseparation
   capabilities of 45 functionalized homochiral metal-organic frameworks
   (FHMOFs), and machine learning (ML) and molecular fingerprint (MF)
   techniques were used to find new FHMOFs with high performance. With
   increasing temperature, the enantioselectivities for
   (R,S)-1,3-dimethyl-1,2-propadiene are improved. The ``glove effect{''}
   in the chiral pockets was proposed to explain the correlations between
   the steric effect of functional groups and performance of FHMOFs.
   Moreover, the neighborhood component analysis and RDKit/MACCS MFs show
   the highest predictive effect on enantioselectivities among the four ML
   classification algorithms with nine MFs that were tested. Based on the
   importance of MF, 85 new FHMOFs were designed, and a newly designed
   FHMOF, NO2-NHOH-FHMOF, with high similarity to the optimal MFs achieved
   improved chiral separation performance, with enantioselectivities of
   85\%. The design principles and new chiral pockets obtained by ML and
   MFs could facilitate the development of new materials for chiral
   separation.},
