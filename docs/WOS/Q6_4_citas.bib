DOI = {10.1021/acs.jpcc.3c01749},
EarlyAccessDate = {JUN 2023},
Keywords-Plus = {HYDROGEN STORAGE; SELECTIVE ADSORPTION; CATALYTIC-OXIDATION; COMPOUNDS
