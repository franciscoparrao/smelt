Keywords = {compositional influence; design strategies; high-entropy alloys;
   solid-state hydrogen storage; structural characteristics},
Keywords-Plus = {PRINCIPAL ELEMENT ALLOYS; MECHANICAL-PROPERTIES; PHASE-STABILITY;
   ATOMIC-SIZE; MICROSTRUCTURE; KINETICS; DESIGN; ENERGY; NANOCRYSTALLINE;
   CAPACITY},
Author-Email = {zhaoding@cqu.edu.cn
   yzhou@wtu.edu.cn
   chenyuan@cqu.edu.cn},
Number-of-Cited-References = {175},
