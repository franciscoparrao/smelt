@article{ WOS:001550648400001,
Author = {Wang, Shuoyang and Song, Xiangyu and Duan, Jicheng and Li, Shuo and Gao,
   Dangdang and Liu, Jia and Meng, Fanjing and Yang, Wen and Yu, Shixin and
   Wang, Fangshu and Xu, Jie and Luo, Siyi and Zhao, Fangchao and Chen,
   Dong},
Title = {Automated Machine Learning-Based Prediction of the Effects of
   Physicochemical Properties and External Experimental Conditions on
   Cadmium Adsorption by Biochar},
Journal = {WATER},
Year = {2025},
Volume = {17},
Number = {15},
Month = {JUL 30},
Abstract = {Biochar serves as an effective adsorbent for the heavy metal cadmium,
   with its performance significantly influenced by its physicochemical
   properties and various environmental features. Traditional machine
   learning models, though adept at managing complex multi-feature
   relationships, rely heavily on expertise in feature engineering and
   hyperparameter optimization. To address these issues, this study employs
   an automated machine learning (AutoML) approach, automating feature
   selection and model optimization, coupled with an intuitive online
   graphical user interface, enhancing accessibility and generalizability.
   Comparative analysis of four AutoML frameworks (TPOT, FLAML, AutoGluon,
   H2O AutoML) demonstrated that H2O AutoML achieved the highest prediction
   accuracy (R-2 = 0.918). Key features influencing adsorption performance
   were identified as initial cadmium concentration (23\%), stirring rate
   (14.7\%), and the biochar H/C ratio (9.7\%). Additionally, the maximum
   adsorption capacity of the biochar was determined to be 105 mg/g.
   Optimal production conditions for biochar were determined to be a
   pyrolysis temperature of 570-800 degrees C, a residence time of >= 2 h,
   and a heating rate of 3-10 degrees C/min to achieve an H/C ratio of
   <0.2. An online graphical user interface was developed to facilitate
   user interaction with the model. This study not only provides practical
   guidelines for optimizing biochar but also introduces a novel approach
   to modeling using AutoML.},
Type = {Article},
Affiliation = {Chen, D (Corresponding Author), Qingdao Univ Technol, Sch Environm \& Municipal Engn, Qingdao 266520, Peoples R China.
   Wang, Shuoyang; Song, Xiangyu; Li, Shuo; Gao, Dangdang; Liu, Jia; Yang, Wen; Yu, Shixin; Wang, Fangshu; Xu, Jie; Luo, Siyi; Zhao, Fangchao; Chen, Dong, Qingdao Univ Technol, Sch Environm \& Municipal Engn, Qingdao 266520, Peoples R China.
