Affiliation = {Dascalu, M (Corresponding Author), Univ Politehn Bucuresti, Comp Sci \& Engn Dept, Bucharest, Romania.
   Dascalu, M (Corresponding Author), Acad Romanian Scientists, Bucharest, Romania.
