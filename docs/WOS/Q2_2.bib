   Shah, Alka, Nirma Univ, Inst Technol, Dept Civil Engn, Ahmadabad 382481, Gujarat, India.
   Shukla, Vipin, Pandit Deendayal Energy Univ, Sch Energy Technol, Dept Elect Engn, Gandhinagar 382426, Gujarat, India.},
DOI = {10.1016/j.conbuildmat.2024.137678},
EarlyAccessDate = {AUG 2024},
