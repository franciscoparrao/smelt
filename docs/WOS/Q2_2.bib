   Liu, Gaoyang, Shaoxing Univ, Sch Civil Engn, Shaoxing, Peoples R China.
   Zhou, Biao, China Univ Min \& Technol, Sch Emergency Management \& Safety Engn, Beijing, Peoples R China.},
DOI = {10.1016/j.cscm.2023.e02405},
EarlyAccessDate = {AUG 2023},
