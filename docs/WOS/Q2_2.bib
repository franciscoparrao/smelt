@article{ WOS:001165390900001,
Author = {Liu, Chenjing and Chen, Xiangru and Lin, Jie and Hu, Peng and Wang,
   Junfeng and Geng, Xue},
Title = {Evolving masked low-rank transformer for long text understanding},
Journal = {APPLIED SOFT COMPUTING},
Year = {2024},
Volume = {152},
Month = {FEB},
Abstract = {Long sequence text processing is time-consuming owing to the
   ultra-large-scale self-attention computing. Recent advances demonstrate
   the attention in transformer can be accelerated by redundancy removal,
   and there are various sparse variants for attention in large sequences
   are proposed, which leads to state-of-the-art performance on language
   and vision task. Low-rank method achieve outstanding success in the
   field of efficient transformer. The dynamic token sparsification is
   efficiently time-saving and cost-saving, which can be easily extended to
   prune redundant spans and to yield semantic features. Evolutionary
   algorithm is attractive for selecting hyperparameter which is of
   significant importance in effectiveness. Motivated by these works, we
   propose an efficient transformers model, termed EMLT, to alleviate time
   and cost without sacrificing the accuracy. EMLT effectively combines
   strengths of Low-rank transformers, dynamic token sparsification and
   evolutionary algorithm to ulteriorly cut redundant token and meanwhile
   maintains the original precision, which can achieve a linear memory and
   time complexity. We compress transformer in three stages. Firstly,
   sliding window is validated as local attention to capture fine-grained
   dependency semantics. After that, low -rank approximation of attention
   matrix is applied as global attention to store long-range dependency
   semantics, and aggregated with local attention. On this basis, we
   consistently prune redundant token in accordance with importance score
   to further sparse the attention operation. Finally, Evolutionary
   algorithm is utilized to optimize the hyper-parameters of every layer.
   The results of comprehensive experiments and analysis show that our
   method can rival others on accuracy, and outperforms others on
   efficiency by a large margin in terms of the computational complexity.},
Type = {Article},
Affiliation = {Wang, JF (Corresponding Author), Sichuan Univ, Coll Comp Sci, Chengdu 610065, Peoples R China.
   Geng, X (Corresponding Author), Agcy Sci Technol \& Res, Inst Infocomm Res, Singapore 138632, Singapore.
   Liu, Chenjing; Chen, Xiangru; Hu, Peng; Wang, Junfeng, Sichuan Univ, Coll Comp Sci, Chengdu 610065, Peoples R China.
   Liu, Chenjing; Chen, Xiangru; Lin, Jie; Hu, Peng; Geng, Xue, Agcy Sci Technol \& Res, Inst Infocomm Res, Singapore 138632, Singapore.},
DOI = {10.1016/j.asoc.2023.111207},
EarlyAccessDate = {JAN 2024},
Article-Number = {111207},
Keywords = {Evolutionary computing; Efficient transformer; Genetic algorithm;
   Natural language processing; Neural architecture search},
Author-Email = {cjliu1996@gmail.com
   cxrasdfg@gmail.com
   jie.dellinger@gmail.com
   penghu.ml@gmail.com
   wangjf@scu.edu.cn
   geng\_xue@i2r.a-star.edu.sg},
Number-of-Cited-References = {69},
