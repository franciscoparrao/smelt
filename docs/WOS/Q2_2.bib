@article{ WOS:001686208900001,
Author = {Tang, YanBang},
Title = {Machine learning-driven prediction of gamma-ray shielding performance
   in TeO2- Bi2O3- ZnO- BaF2 glasses},
Journal = {RADIATION PHYSICS AND CHEMISTRY},
Year = {2026},
Volume = {243},
Month = {JUN},
Abstract = {The development of non-toxic, high-performance radiation shielding
   materials is critical for applications in nuclear energy and medical
   physics. This study focuses on the 65TeO2 - 15Bi2O3 - (20 -x)ZnO - xBaF2
   (where x = 0 to 20) glass system, a promising lead-free candidate. A
   comprehensive dataset comprising 3066 data points for the mass
   attenuation coefficient (mu/rho) across a wide energy spectrum (0.001
   MeV-100,000 MeV) was systematically generated using the established XCOM
   photon cross-section database. To develop a predictive model for this
   complex, non-linear relationship, we constructed and evaluated a
   comprehensive suite of over 40 distinct machine learning (ML) regression
   algorithms. Subsequently, an advanced Automated Machine Learning
   (AutoML) framework, AutoGluon, was employed to perform automated model
   selection, hyperparameter optimization, and ensembling. The results
   demonstrate that tree-based ensemble models exhibit superior predictive
   capabilities. The final optimized AutoML model achieved better
   performance on an unseen test set, with a coefficient of determination
   (R2) of 0.9999, a root mean square error (RMSE) of 27.8791 cm2/g, and a
   mean absolute error (MAE) of 9.7983 cm2/g. This high-fidelity model
   serves as a digital twin for the glass system, enabling rapid,
   cost-effective prediction of shielding properties and accelerating the
   design and discovery of novel radiation shielding materials.},
Type = {Article},
Affiliation = {Tang, YB (Corresponding Author), Univ Chinese Acad Sci, Beijing, Peoples R China.
   Tang, YanBang, Univ Chinese Acad Sci, Beijing, Peoples R China.
   Tang, YanBang, European Org Nucl Res CERN, Geneva, Switzerland.},
DOI = {10.1016/j.radphyschem.2025.113586},
EarlyAccessDate = {FEB 2026},
Article-Number = {113586},
Keywords = {Radiation shielding; Tellurite glass; Mass attenuation coefficient;
   Automated machine learning},
Keywords-Plus = {MASS ATTENUATION COEFFICIENT},
Author-Email = {tangyanbang23@mails.ucas.ac.cn},
Number-of-Cited-References = {62},
Times-Cited = {1},
Unique-ID = {WOS:001686208900001},
}

@article{ WOS:001679157300003,
Author = {Campos, Deivid and Galvao, Viviane and de Rezende, Matheus Lopes and
