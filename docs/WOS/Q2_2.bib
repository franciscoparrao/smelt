   Shotwell, Matthew S.; Matheny, Michael E., Vanderbilt Univ, Med Ctr, Dept Biostat, 221 Kirkland Hall, Nashville, TN 37235 USA.
   Matheny, Michael E., Vanderbilt Univ, Med Ctr, Div Gen Internal Med \& Publ Hlth, 221 Kirkland Hall, Nashville, TN 37235 USA.},
DOI = {10.1093/jamia/ocy110},
Keywords = {machine learning; Logical Observation Identifiers Names and Codes;
