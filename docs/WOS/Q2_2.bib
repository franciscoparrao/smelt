   Figueiredo, Karla, State Univ Rio De Janeiro UERJ, Inst Math \& Stat, Rio De Janeiro, Brazil.},
DOI = {10.1016/j.neucom.2023.126317},
EarlyAccessDate = {MAY 2023},
