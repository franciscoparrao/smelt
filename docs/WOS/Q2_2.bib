}

@article{ WOS:001524642600001,
Author = {Philipp, Micha C. J. and Kuhn, Yannick and Latz, Arnulf and Horstmann,
   Birger},
Title = {Physics-Based Inverse Modeling of Battery Degradation with Bayesian
   Methods},
Journal = {CHEMSUSCHEM},
Year = {2025},
Volume = {18},
Number = {15},
Month = {JUL 27},
Abstract = {To further improve lithium-ion batteries, a profound understanding of
   complex battery processes is crucial. Physical models offer
   understanding but are difficult to validate and parameterize. Therefore,
   automated machine-learning methods are necessary to evaluate models with
   experimental data. Bayesian methods, e.g., Expectation Propagation +
   Bayesian Optimization for Likelihood-Free Inference (EP-BOLFI), stand
   out as they capture uncertainties in models and data while granting
   meaningful parameterization. An important topic is prolonging battery
   lifetime, which is limited by degradation, such as the solid-electrolyte
   interphase (SEI) growth. As a case study, EP-BOLFI is applied to
   parametrize SEI growth models with synthetic and real degradation data.
   EP-BOLFI allows for incorporating human expertise in the form of
   suitable feature selection, which improves the parametrization. It is
   shown that even under impeded conditions, correct parameterization is
   achieved with reasonable uncertainty quantification, needing less
   computational effort than standard Markov Chain Monte Carlo methods.
   Additionally, the physically reliable summary statistics show if
   parameters are strongly correlated and not unambiguously identifiable.
   Further, Bayesian Alternately Subsampled Quadrature (BASQ) is
   investigated, which calculates model probabilities, to confirm electron
   diffusion as the best theoretical model to describe SEI growth during
   battery storage.},
Type = {Article},
Affiliation = {Horstmann, B (Corresponding Author), German Aerosp Ctr DLR, Inst Engn Thermodynam, Wilhelm Runge Str 10, D-89081 Ulm, Germany.
   Horstmann, B (Corresponding Author), Helmholtz Inst Ulm HIU, Theory Electrochem Mat, Helmholtzstr 11, D-89081 Ulm, Germany.
   Horstmann, B (Corresponding Author), Ulm Univ, Fac Nat Sci, Albert Einstein Allee 11, D-89081 Ulm, Germany.
   Philipp, Micha C. J.; Kuhn, Yannick; Latz, Arnulf; Horstmann, Birger, German Aerosp Ctr DLR, Inst Engn Thermodynam, Wilhelm Runge Str 10, D-89081 Ulm, Germany.
   Philipp, Micha C. J.; Kuhn, Yannick; Latz, Arnulf; Horstmann, Birger, Helmholtz Inst Ulm HIU, Theory Electrochem Mat, Helmholtzstr 11, D-89081 Ulm, Germany.
   Latz, Arnulf; Horstmann, Birger, Ulm Univ, Fac Nat Sci, Albert Einstein Allee 11, D-89081 Ulm, Germany.},
DOI = {10.1002/cssc.202402336},
EarlyAccessDate = {JUL 2025},
Keywords = {Bayesian methods; inverse modeling; lithium-ion batteries; machine
   learning; model selection; parameterizations; uncertainty
   quantifications},
