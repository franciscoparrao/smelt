Year = {2020},
Pages = {2097-2100},
Abstract = {Automatic machine learning (AutoML) aims to automate the different
   aspects of the data science process and, by extension, allow non-experts
   to utilize ``off the shelf{''} machine learning solution. One of the
   more popular AutoML methods is the Tree-based Pipeline Optimization Tool
   (TPOT), which uses genetic programming (GP) to efficiently explore the
   vast space of ML pipelines and produce a working ML solution. However,
   TPOT's GP process comes with substantial time and computational costs.
   In this study, we explore TPOT's GP process and propose MetaTPOT, an
   enhanced variant that uses a meta learning-based approach to predict the
   performance of TPOT's pipeline candidates. MetaTPOT leverages domain
   knowledge in the form of pipelines pre-ranking to improve TPOT's speed
   and performance. Evaluation on 65 classification datasets shows that our
   approach often improves the outcome of the genetic process while
   simultaneously substantially reduce its running time and computational
   cost.},
Type = {Proceedings Paper},
Affiliation = {Laadan, D (Corresponding Author), Ben Gurion Univ Negev, Beer Sheva, Israel.
   Laadan, Doron; Vainshtein, Roman; Curiel, Yarden; Katz, Gilad; Rokach, Lior, Ben Gurion Univ Negev, Beer Sheva, Israel.},
DOI = {10.1145/3340531.3412147},
Keywords = {AutoML; Meta-Learning; Genetic Programming(GP); TPOT},
