   Gong, Ke; Peng, Yi, Univ Elect Sci \& Technol China, Sch Management \& Econ, Chengdu, Sichuan, Peoples R China.},
DOI = {10.1007/s10660-017-9283-6},
Keywords = {Time series; E-commerce; Empirical mode decomposition (EMD);
