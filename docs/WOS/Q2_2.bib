@article{ WOS:001662811100001,
Author = {Bilolikar, Divya K. and More, Aishwarya and Gong, Aella and Janssen,
   Joseph},
Title = {How to out-perform default random forest regression: choosing
   hyperparameters for applications in large-sample hydrology},
Journal = {HYDROLOGY RESEARCH},
Year = {2026},
Volume = {57},
Number = {1},
Pages = {61-77},
Month = {JAN},
Abstract = {Predictions are a central part of water resources research. Despite
   their strong theoretical basis, the effective application of physically
   based models to catchment-scale processes remains an ongoing challenge
   and there are some important prediction problems that are not easily
   amenable to a first-principles representation. As such, machine learning
   (ML) models have been seen as a valid alternative in recent years. In
   spite of their availability, well-optimized state-of-the-art ML
   strategies are not widely used in water resources research. Further,
   some analyses require many model trainings, so sometimes computational
   time prevents properly optimized hyperparameters. To leverage data and
   use it effectively to drive scientific advances in the field, it is
   essential to make ML models accessible to users that may lack a deep
   understanding of ML by improving automated machine learning resources.
   ML models such as XGBoost have been recently shown to outperform random
   forest (RF) models which are traditionally used in water resources
   research. In this study, based on over 150 water-related datasets, we
   extensively compare XGBoost and RF. This study provides water scientists
   with access to quick user-friendly RF and XGBoost model
   optimization.HIGHLIGHTSIn large-sample hydrology datasets, if one wants
   to optimize KGE, XGBoost may be the best possible model. Random forests,
   especially when hyperparameters are tuned, perform well on large-sample
   hydrology datasets in terms of NSE. The default hyperparameters provided
   in most software packages for random forests and XGBoost perform poorly
   in hydrology, but better defaults exist.},
Type = {Article},
Affiliation = {Janssen, J (Corresponding Author), Univ British Columbia, Dept Earth Ocean \& Atmospher Sci, Vancouver, BC, Canada.
   Janssen, J (Corresponding Author), Stanford Univ, Dept Geophys, Palo Alto, CA 94305 USA.
   Bilolikar, Divya K., Univ British Columbia, Dept Math, Vancouver, BC, Canada.
   More, Aishwarya, Univ British Columbia, Dept Stat, Vancouver, BC, Canada.
   Janssen, Joseph, Univ British Columbia, Dept Earth Ocean \& Atmospher Sci, Vancouver, BC, Canada.
   Janssen, Joseph, Stanford Univ, Dept Geophys, Palo Alto, CA 94305 USA.},
DOI = {10.2166/nh.2025.075},
EarlyAccessDate = {DEC 2025},
