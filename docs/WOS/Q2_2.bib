   Weng, Tzu-Ching, Feng Chia Univ, Coll Business, Dept Business, Taichung, Taiwan.
   Huu Manh Nguyen, Nha Trang Univ, Dept Accounting \& Finance, Nha Trang, Vietnam.
   Xuan Vinh Vo, Univ Econ Ho Chi Minh City, Inst Business Res, Ho Chi Minh City, Vietnam.},
DOI = {10.1080/10971475.2022.2058180},
EarlyAccessDate = {MAR 2022},
Keywords = {Stock market volatility; market leverages; bank debts; trade credit;
   panel data; quantile regression (QR)},
