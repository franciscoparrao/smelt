   Yu, Joonsang, NAVER, CLOVA AI Lab, CLOVA ImageVis, Seongnam Si, Gyeonggi Provin, South Korea.},
DOI = {10.23919/DATE56975.2023.10137044},
Keywords = {Distributed Training; Knowledge Distillation; Neural Architecture
