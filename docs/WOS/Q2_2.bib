Year = {2023},
Volume = {7},
Number = {5},
Month = {MAY},
Abstract = {This letter presents a neural architecture search to optimize tactile
   elaboration systems taking into account the computational cost of the
   whole pipeline consisting of data preprocessing and a convolutional
   neural network (CNN) model to extract information. The strategy is
   exploited to train standard 1-D CNNs and binary CNNs on a three-class
   touch modality classification dataset. The experimental results show
   that systems based on standard CNNs outperform state-of-the-art
   techniques in terms of accuracy and computational cost, while the ones
   based on binary CNNs further reduce the computational cost with a small
   accuracy drop.},
