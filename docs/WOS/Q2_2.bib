   Clausen, Benjamin L., Geosci Res Inst, 11060 Campus St, Loma Linda, CA 92350 USA.
   Ardila, Ana Maria Martinez, Loma Linda Univ, Dept Earth \& Biol Sci, Griggs Hall,11065 Campus St, Loma Linda, CA 92350 USA.},
DOI = {10.1007/s12145-022-00821-8},
EarlyAccessDate = {JUN 2022},
Keywords = {Automated machine learning; Geochemistry; Machine learning; Methodology;
   Southern California; Web application},
Keywords-Plus = {PENINSULAR RANGES BATHOLITH; DISCRIMINATION},
Author-Email = {harveya@southern.edu
   1170541@alumno.um.edu.mx
   bclausen@llu.edu
   anmartinez@llu.edu},
Number-of-Cited-References = {32},
