Unique-ID = {WOS:001525761400001},
}

@article{ WOS:001542931700001,
Author = {Ottaviani, Filippo Maria and Ballesteros-Perez, Pablo and Narbaev, Timur},
Title = {Automated machine learning pipeline for robust project cost and duration
   forecasting},
Journal = {AUTOMATION IN CONSTRUCTION},
Year = {2025},
Volume = {178},
Month = {OCT},
Abstract = {Projects often face issues that trigger project controls, where
   Estimates at Completion (EACs) play a crucial role in determining the
   scope of corrective actions. Recent studies have applied supervised
   Machine Learning (ML) regression techniques to develop EAC models,
   utilizing features derived from Earned Value Management (EVM) and Earned
   Schedule Management (ESM) methodologies. However, these studies overlook
   several underfitting and overfitting issues that could compromise model
   robustness, leading to biased results. This paper introduces an ML
   pipeline designed to address these issues through automated procedures
   for data balancing and augmentation, feature engineering, and model
   training and evaluation. The pipeline was tested with 30 ML techniques
   on a dataset of 50 real-world construction projects. Results show that
   the EAC models developed through the pipeline achieve superior accuracy,
   precision, and timeliness to EVM and ESM ones. These findings validate
   the pipeline and offer practitioners an automated framework for
   developing robust, ML-based EAC models.},
Type = {Article},
Affiliation = {Ottaviani, FM (Corresponding Author), Politecn Torino, Dept Management \& Prod Engn, Corso Duca Abruzzi 24, I-10129 Turin, Italy.
   Ottaviani, Filippo Maria; Narbaev, Timur, Politecn Torino, Dept Management \& Prod Engn, Corso Duca Abruzzi 24, I-10129 Turin, Italy.
   Ballesteros-Perez, Pablo, Univ Politecn Valencia, Escuela Tecn Super Ingn Ind, Camino Vera S-N, Valencia 46022, Spain.},
DOI = {10.1016/j.autcon.2025.106426},
EarlyAccessDate = {JUL 2025},
Article-Number = {106426},
Keywords = {Project management; Machine Learning; Regression; Monitoring and
   control; Earned Value Management; Estimate at completion},
Keywords-Plus = {MANAGEMENT; REGRESSION; INFERENCE; ACCURACY; MODEL},
Author-Email = {filippo.ottaviani@polito.it
