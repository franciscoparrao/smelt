   Canabarro, Askery, Univ Fed Alagoas, Grp Fis Mat Condensada, Nucleo Ciencias Exatas NCEx, Campus Arapiraca, Arapiraca, AL, Brazil.},
DOI = {10.1016/j.sna.2023.114666},
EarlyAccessDate = {SEP 2023},
Article-Number = {114666},
Keywords = {Luminescence thermometry; Machine learning; Deep learning},
Keywords-Plus = {UP-CONVERSION},
