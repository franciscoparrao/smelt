@article{ WOS:001126283500001,
Author = {Demetgul, Mustafa and Wang, Wei and Fleischer, Juergen and Tansel,
   Ibrahim Nur},
Title = {AI-based inspection of the axes of machine tools},
Journal = {INTERNATIONAL JOURNAL OF ADVANCED MANUFACTURING TECHNOLOGY},
Year = {2024},
Volume = {130},
Number = {5-6},
Pages = {2023-2064},
Month = {JAN},
Abstract = {Artificial intelligence (AI) encompasses versatile computational tools
   easily adaptable to various applications. This study delves into
   diagnosing linear stages, crucial components in machinery such as
   machine tools and additive manufacturing equipment, essential for
   precise linear motion. Adding sensors to these stages for precision
   monitoring proves costly and inconvenient in industrial applications.For
   sensorless diagnostics of linear stages, this paper introduces an
   innovative automated machine learning (AutoML) approach. AutoML employs
   diverse methods to interpret electric motor current signals, estimating
   the extent of misalignment issues. Support vector machine (SVM),
   gradient boosting (GB), and auto-multilayer perceptron (AutoMLP) methods
   classify the data. To boost performance, ensemble learning (EL) combines
   estimations from each method for a final decision.Motor signals, saved
   in the user interface's database, drive the table horizontally and
   vertically. AutoML learns proper classification through the user
   interface, using data and user interpretations for training and
   subsequent classifications. Hyperparameter optimization improves
   classification performance, with experimental studies demonstrating the
   superior fault detection capability of the ensemble method in motor
   current signal analysis. The findings suggest that monitoring motor
   current signals and leveraging AI tools for evaluation of the
   performance of manufacturing operation and machine diagnostics will be
   essential in the near future. Machine tool and additive manufacturing
   system manufacturers should include AI tools to their controllers.},
Type = {Article},
Affiliation = {Tansel, IN (Corresponding Author), Florida Int Univ, Mech \& Mat Engn Dept, West Flagler St, Miami, FL 10555 USA.
   Demetgul, Mustafa; Wang, Wei; Fleischer, Juergen, Karlsruhe Inst Technol, Inst Prod Sci, Rinheimer Querallee 2, Karlsruhe, Germany.
   Tansel, Ibrahim Nur, Florida Int Univ, Mech \& Mat Engn Dept, West Flagler St, Miami, FL 10555 USA.},
DOI = {10.1007/s00170-023-12830-y},
EarlyAccessDate = {DEC 2023},
Keywords = {AI; Sensorless monitoring; Linear stage diagnosis; AutoML; AutoMLP;
   Ensemble learning},
Keywords-Plus = {FAULT-DIAGNOSIS; MISALIGNMENT},
Author-Email = {tanseli@fiu.edu},
Number-of-Cited-References = {47},
Times-Cited = {6},
Unique-ID = {WOS:001126283500001},
}

