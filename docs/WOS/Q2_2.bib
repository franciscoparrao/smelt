@incollection{ WOS:001202335502031,
Author = {Awad, Noor and Mallik, Neeratyoy and Hutter, Frank},
Editor = {Zhou, ZH},
Title = {DEHB: Evolutionary Hyberband for Scalable, Robust and Efficient
   Hyperparameter Optimization},
Booktitle = {PROCEEDINGS OF THE THIRTIETH INTERNATIONAL JOINT CONFERENCE ON
   ARTIFICIAL INTELLIGENCE, IJCAI 2021},
Year = {2021},
Pages = {2147-2153},
Abstract = {Modern machine learning algorithms crucially rely on several design
   decisions to achieve strong performance, making the problem of
   Hyperparameter Optimization (HPO) more important than ever. Here, we
   combine the advantages of the popular bandit-based HPO method Hyperband
   (HB) and the evolutionary search approach of Differential Evolution (DE)
   to yield a new HPO method which we call DEHB. Comprehensive results on a
   very broad range of HPO problems, as well as a wide range of tabular
   benchmarks from neural architecture search, previous HPO methods we are
   aware of, especially for high-dimensional problems with discrete input
   dimensions. For example, DEHB is up to 1000x faster than random search.
   It is also efficient in computational time, conceptually simple and easy
   to implement, positioning it well to become a new default HPO method.},
Type = {Proceedings Paper},
Affiliation = {Awad, N (Corresponding Author), Univ Freiburg, Dept Comp Sci, Freiburg, Germany.
