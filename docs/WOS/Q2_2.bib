   Lee, Byung Suk; Rizzo, Donna M.; Perdrial, Julia N., Univ Vermont, GUND Inst Environm, Burlington, VT 05405 USA.},
DOI = {10.1016/j.mlwa.2024.100543},
EarlyAccessDate = {MAR 2024},
