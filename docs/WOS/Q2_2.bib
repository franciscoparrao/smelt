   Lainez, J. M.; Puigjaner, L., Univ Politecn Cataluna, Dept Chem Engn, E-08028 Barcelona, Spain.},
DOI = {10.1016/j.compchemeng.2009.06.025},
Keywords = {Supply chain management; Product portfolio management; Supplier-customer
