DOI = {10.1016/j.mtcomm.2025.113870},
EarlyAccessDate = {SEP 2025},
Article-Number = {113870},
Keywords = {Hydrogen storage alloys; Machine learning; Whale optimization algorithm;
   First principle calculation},
Keywords-Plus = {TOTAL-ENERGY CALCULATIONS; LAVES PHASE; ZR; BCC; NI; TI},
Author-Email = {liushuai364@163.com},
