@article{ WOS:001650302400001,
Author = {Tang, Yanbang},
Title = {A systematic framework for predicting irradiation-induced swelling in
   austenitic stainless steels using automated machine learning},
Journal = {NUCLEAR INSTRUMENTS \& METHODS IN PHYSICS RESEARCH SECTION B-BEAM
   INTERACTIONS WITH MATERIALS AND ATOMS},
Year = {2026},
Volume = {572},
Month = {MAR},
Abstract = {The prediction of irradiation-induced swelling is critical for ensuring
   the structural integrity and extending the operational lifetime of
   components in nuclear reactors. While machine learning (ML) has shown
   promise in modeling this complex, multi-factorial phenomenon, developing
   robust models requires a systematic and unbiased evaluation methodology.
   This study proposes a comprehensive, data-driven framework to develop a
   highperformance predictive model for the swelling of austenitic
   stainless steels. The framework, applied to a dataset of 333
   experimental points, consists of: (I) data exploration and feature
   importance ranking using the bestperforming model; and (II) rigorous
   model development and evaluation using a 10-fold cross-validation
   scheme. An Automated Machine Learning (AutoML) approach was employed and
   extensively benchmarked against 41 traditional ML models. The optimized
   AutoML model demonstrated superior performance, achieving a mean
   coefficient of determination (R2) of 0.967 +/- 0.022 and a mean Root
   Mean Squared Error (RMSE) of 0.664 +/- 0.381 \% across the
   cross-validation folds. This performance surpassed that of all other
   standalone models, highlighting the effectiveness of automated
   ensembling techniques. A feature importance analysis confirmed that the
   model correctly identified irradiation conditions (fluence, temperature)
   and key microstructural and compositional factors (dislocation density,
   Si, C) as the primary drivers of swelling. The proposed systematic
   framework not only yields an accurate predictive tool but also provides
   a robust and transferable methodology for tackling complex materials
   science problems where model selection and unbiased performance
