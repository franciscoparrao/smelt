   Ryu, Kyung Hwan, Sunchon Natl Univ, Dept Chem Engn, Sunchon 57922, South Korea.},
DOI = {10.14478/ace.2023.1033},
Keywords = {Livestock Manure; Gasification; Fuel gas production; Economic analysis;
