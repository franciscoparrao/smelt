@article{ WOS:001592191700008,
Author = {Huang, Yansong and Sun, Kebin and Ma, Yuxin and Cheng, Ran},
Title = {Exploring Neural Architecture Search Spaces via Visual Analytics},
Journal = {IEEE COMPUTATIONAL INTELLIGENCE MAGAZINE},
Year = {2025},
Volume = {20},
Number = {4},
Pages = {99-112},
Month = {NOV},
Abstract = {Deep neural networks represent a significant driving force behind the
   accelerated advancement of artificial intelligence (AI). However,
   traditional approaches based on manual model architecture design appear
   inadequate for satisfying various modern applications due to their
   inherent inefficiency and scalability limitations. The advent of neural
   architecture search (NAS) methodologies in recent years has rendered the
   automated search for optimal model architectures a novel possibility.
   The emergence of NAS benchmarks has also provided an effective solution
   to the problem of costly evaluation in the NAS process. However, a
   significant challenge persists that most existing NAS methods cannot
   provide explanations for the exceptional model architectures identified
   in the benchmark search space. In light of the vast deployment of visual
   analytics methods in the domain of explainable AI, this paper introduces
   a visual analytics framework to facilitate interactive exploration of
   the search space illustrated in NAS benchmarks. The framework is
   designed to enable the extraction of potential relationships between
   model architectures and performance metrics. Furthermore, this paper
   introduces an analytical pipeline that integrates a range of data
   processing techniques to efficiently map model architectures across
   diverse types of large-scale search spaces into a low-dimensional space,
   which is then adapted for analysis in our visual analytics framework.
   The effectiveness of the proposed framework is demonstrated through case
   studies and a user study.},
Type = {Article},
Affiliation = {Ma, YX (Corresponding Author), Southern Univ Sci \& Technol, Shenzhen 518055, Peoples R China.
   Huang, Yansong; Sun, Kebin; Ma, Yuxin, Southern Univ Sci \& Technol, Shenzhen 518055, Peoples R China.
   Cheng, Ran, Hong Kong Polytech Univ, Hong Kong, Peoples R China.
   Cheng, Ran, Hong Kong Polytech Univ, Shenzhen Res Inst, Shenzhen 518053, Peoples R China.},
DOI = {10.1109/MCI.2025.3598240},
Keywords = {Adaptation models; Visual analytics; Scalability; Pipelines; Force;
   Computer architecture; Manuals; Benchmark testing; Performance metrics;
   Neural architecture search},
Author-Email = {mayx@sustech.edu.cn},
Number-of-Cited-References = {79},
Times-Cited = {0},
Unique-ID = {WOS:001592191700008},
}

@article{ WOS:001615065500003,
Author = {Kang, Yibo and Zu, Jianhua},
Title = {Gamma-ray buildup factor calculation via an automated machine learning
   framework with integrated analysis},
Journal = {ANNALS OF NUCLEAR ENERGY},
Year = {2026},
Volume = {227},
Number = {A},
Month = {FEB},
Abstract = {The point-kernel-method is widely used in gamma-radiation shielding
   calculation. The buildup factor, a critical parameter in this method,
   quantifies the contribution of scattered radiation in shielding
   materials and determines the calculation accuracy. Various methods have
   been developed to calculate buildup factors, including classical fitting
   formulas and machine-learning-based prediction models. Many machine
   learning algorithms, such as support vector regression, neural network
   regression, and tree regression, have been used to predict buildup
   factors. However, researchers face challenges in mastering different
   algorithms and hyperparameter tuning techniques. Exactly replicating
   other researchers' ML models can be particularly difficult.
   Additionally, even when fully functional, ML surrogate models often lack
   explanations in physical relevance. This study explores the use of
   automated machine learning (AutoML) to create surrogate models for
   predicting buildup factors. We analyzed the top-performing models using
   Shapley additive explanation (SHAP) techniques for physical
   understanding. SHAP analyses, in turn, provide supporting evidence for
   the physical consistency of the trained models. AutoML can automatically
   select algorithms and optimize hyperparameters based on the performance
   metrics of the dataset. AutoML significantly lowers technical barriers
   while providing a variety of model options. Models trained with AutoML
   demonstrate good predictive performance on the ANS standard database and
   generalize well to estimate buildup factors for materials not included
   before. The method can potentially replace the GP fitting formula and
   utilize the advantages of existing machine learning techniques for
   predicting buildup factors.},
Type = {Article},
Affiliation = {Kang, YB (Corresponding Author), Shanghai Jiao Tong Univ, Sch Nucl Sci \& Engn, Shanghai 200240, Peoples R China.
   Kang, Yibo; Zu, Jianhua, Shanghai Jiao Tong Univ, Sch Nucl Sci \& Engn, Shanghai 200240, Peoples R China.},
DOI = {10.1016/j.anucene.2025.111971},
EarlyAccessDate = {OCT 2025},
Article-Number = {111971},
Keywords = {Automated machine learning; Gamma-rays; Exposure buildup factor; Shapley
   additive explanation; Radiation protection; Regression algorithm},
Keywords-Plus = {PENETRATION},
Author-Email = {z1pper@sjtu.edu.cn
   zujianhua@sjtu.edu.cn},
Number-of-Cited-References = {59},
Times-Cited = {0},
Unique-ID = {WOS:001615065500003},
}

@article{ WOS:001617942200001,
Author = {Thanjaivadivel, M. and Jayaprakasam, Bhagath Singh and Gupta, Manish and
   Mythrayee, D. and Abbas, Qaisar and Muniyandy, Elangovan},
Title = {Dynamic Observability for Automated ML Pipelines in Predictive
   Maintenance for Industrial IoT},
Journal = {JOURNAL OF CIRCUITS SYSTEMS AND COMPUTERS},
Year = {2025},
Month = {2025 OCT 29},
Abstract = {The widespread uptake of Industrial Internet of Things (IIoT)
   technologies has revolutionized predictive maintenance through real-time
   monitoring and fault prediction. Increasing complexity in automated
   machine learning (ML) pipelines, however, requires greater transparency,
   traceability and resilience. This work presents a new framework for
   dynamic observability of predictive maintenance pipelines for IIoT
   systems. The solution of choice combines modern observability features
   like Grafana, Prometheus, and mltrace with deep neural networks like
   LSTM and transformers for real-time monitoring, tracing and optimizing
   all pipeline elements. Employing the NASA C-MAPSS data set, the system
   efficiently eliminates noise and performs dynamic feature extraction
   using moving averages and time derivatives. The main innovations are
   approximation-based metric assessments, streaming data ingest through
   reservoir sampling and count-min sketch, and end-to-end metric
   consolidation through ML metrics fused with operational KPIs. The
   observability framework facilitates anomaly detection, diagnosis of
   performance degradations and recovery on auto-pilot, improving model
   accuracy, lessening feature staleness and pipeline latency as well as
   throughput. Case studies illustrate its power in the identification of
   data drifts, fix of feature corruption, and optimization of model output
   towards business objectives. Empirical findings indicate an 8.2\%
   increase in accuracy, 11.5\% precision and 25\% reduction in latency in
   preprocessing, confirming the performance of the framework. Feature
   staleness and corruption scores also decreased significantly, confirming
   improved data integrity. Visual analyses also confirm classifier
   stability and feature freshness improvements. In general, the dynamic
   observability framework provides a scalable and adaptive platform for
   predictive maintenance in IIoT, enhancing operational efficiency,
   reliability and self-healing capabilities.},
Type = {Article; Early Access},
Affiliation = {Thanjaivadivel, M (Corresponding Author), Nandha Engn Coll, Erode 638052, Tamil Nadu, India.
   Thanjaivadivel, M., Nandha Engn Coll, Erode 638052, Tamil Nadu, India.
