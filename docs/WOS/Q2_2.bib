@incollection{ WOS:000982339100244,
Author = {Montes, Charles and Morehouse, Todd and Kasilingam, Dayalan and Zhou,
   Ruolin},
Book-Group-Author = {IEEE},
Title = {Optimized CNN Auto-Generator using GA with Stopping Criterion: Design
   and a Use Case},
Booktitle = {2023 IEEE 20TH CONSUMER COMMUNICATIONS \& NETWORKING CONFERENCE, CCNC},
Series = {IEEE Consumer Communications and Networking Conference},
Year = {2023},
Abstract = {The goal of this paper is to use the genetic algorithm with adapted
   stopping criterion to reduce the computational cost of optimizing
   hyperparameters and network architecture in convolutional neural
   networks (CNNs) and to apply it on baseband modulation classification.
   Hyperparameter optimization is the maximization of a neural network's
   performance using a set of input network parameters and network
   architecture. With much research going into neural networks (e.g.,
   CNNs), most research uses manually chosen hyperparameters instead of
   choosing optimal hyperparameters. Much work has gone into optimizing
   hyperparameters as they greatly effect the accuracy of CNNs and enable
   automated machine learning. Choosing the optimal hyperparameters can be
   done by applying the genetic algorithm to search for them. Each search
   operation requires a full training using a set of hyperparameters which
   is computationally expensive. Research has shown advantages to applying
   a stopping criterion to improve the neural network accuracy while
   reducing the computational cost. A stopping criterion is a training
   constraint to stop learning after a certain goal is achieved. Using the
   genetic algorithm with adapted stopping criterion, a fast CNN
   auto-generator has been designed, which can simultaneously generate a
   network of layers and their parameters from a pool of many potential
   networks that might not have been considered. Such an optimized CNN
   auto-generator has been applied on automatic modulation classification
   (AMC) through exploring the dataset DeepSig RADIOML 2016.10A. Compared
   to the literature, our design can achieve greater accuracy and lower run
   time. It also provides human designed CNN levels of accuracy on the
   RADIOML dataset while starting from no network but generating an
   entirely custom network for the dataset using a small subset in the CNN
   generation process.},
Type = {Proceedings Paper},
Affiliation = {Montes, C (Corresponding Author), Univ Massachusetts, Dept Elect \& Comp Engn, Dartmouth, MA 02747 USA.
   Montes, Charles; Morehouse, Todd; Kasilingam, Dayalan; Zhou, Ruolin, Univ Massachusetts, Dept Elect \& Comp Engn, Dartmouth, MA 02747 USA.},
DOI = {10.1109/CCNC51644.2023.10060860},
Keywords = {optimization; CNN; automatic modulation recognition; AMR; AMC;
   hyperparameter; neural architecture search; genetic algorithm},
Keywords-Plus = {CLASSIFICATION; RECOGNITION},
Number-of-Cited-References = {24},
Times-Cited = {2},
Unique-ID = {WOS:000982339100244},
}

@incollection{ WOS:001157348200010,
