   Zhao, Dezong, Univ Glasgow, James Watt Sch Engn, Glasgow City G12 8QQ, England.
   Panesar, Arjun, DDM Hlth Ltd, Coventry CV4 7EZ, England.
   Wu, Philip Fei, Royal Holloway Univ London, Sch Business \& Management, Egham TW20 0EX, Surrey, England.
   Gao, Rong, Hubei Univ Technol, Sch Comp Sci, Wuhan 430068, Peoples R China.},
DOI = {10.1016/j.knosys.2025.113223},
