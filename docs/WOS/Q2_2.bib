@article{ WOS:000824023600001,
Author = {Jurado, Israel Campero and Fedjajevs, Andrejs and Vanschoren, Joaquin
   and Brombacher, Aarnout},
Title = {Interpretable Assessment of ST-Segment Deviation in ECG Time Series},
Journal = {SENSORS},
Year = {2022},
Volume = {22},
Number = {13},
Month = {JUL},
Abstract = {Nowadays, even with all the tremendous advances in medicine and health
   protocols, cardiovascular diseases (CVD) continue to be one of the major
   causes of death. In the present work, we focus on a specific
   abnormality: ST-segment deviation, which occurs regularly in
   high-performance athletes and elderly people, serving as a myocardial
   infarction (MI) indicator. It is usually diagnosed manually by experts,
   through visual interpretation of the printed electrocardiography (ECG)
   signal. We propose a methodology to detect ST-segment deviation and
   quantify its scale up to 1 mV by extracting statistical, point-to-point
   beat characteristics and signal quality indexes (SQIs) from single-lead
   ECG. We do so by applying automated machine learning methods to find the
   best hyperparameter configuration for classification and regression
   models. For validation of our method, we use the ST-T database from
   Physionet; the results show that our method obtains 98.30\% accuracy in
   the case of a multiclass problem and 99.87\% accuracy in the case of
   binarization.},
