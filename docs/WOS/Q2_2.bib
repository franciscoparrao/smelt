@article{ WOS:001329507200001,
Author = {Zhang, Xiaoyuan and Liu, Mengnan and Liu, Yingying},
Title = {Battery state of health estimation using an AutoGluon-tabular model
   incorporating uncertainty quantification},
Journal = {JOURNAL OF ENERGY STORAGE},
Year = {2024},
Volume = {101},
Number = {B},
Month = {NOV 10},
Abstract = {The estimation of the state of health (SOH) for lithium-ion batteries
   (LIBs) is of great significance for battery usage, management,
   maintenance, and economic evaluations. However, prevailing SOH
   estimation methods for LIBs typically necessitate personalized manual
   feature engineering, tedious hyper-parameters tuning, and often overlook
   the uncertainty inherent in the SOH degradation process. In light of
   these challenges, this study proposes an automatic machine learning
   (AutoML) based SOH estimation method considering uncertainty
   quantification. In the proposed method, AutoGluon-tabular (AGT) is used
   to automatically learn highly sensitive latent SOH-related features from
   raw charging data even with some missing values. In parallel, the
   bootstrap sampling (BS) method is combined with AGT (AGT-BS) to achieve
   uncertainty quantification in the process of SOH degradation of LIBs.
   Notably, the proposed method allows for the training and testing
   datasets to stem from distinct individual batteries of the same type.
   This facilitates the offline training of computationally timeconsuming
   AutoML models, followed by online deployment for evaluating the SOH of
   batteries of identical types, aligning well with practical scenarios of
   onboard SOH estimation. To the best of our knowledge, this work is the
   first attempt to employ an AutoML approach for online SOH estimation of
   LIBs. The feasibility and effectiveness of the proposed AGT-BS model are
   verified by multiple sets of comparison experiments in three public
   battery datasets.},
Type = {Article},
Affiliation = {Zhang, XY (Corresponding Author), Henan Univ Technol, Coll Elect Engn, Zhengzhou 450001, Peoples R China.
   Zhang, Xiaoyuan; Liu, Mengnan; Liu, Yingying, Henan Univ Technol, Coll Elect Engn, Zhengzhou 450001, Peoples R China.},
DOI = {10.1016/j.est.2024.113920},
EarlyAccessDate = {SEP 2024},
Article-Number = {113920},
Keywords = {Automatic machine learning; AutoGluon-tabular; Uncertainty
   quantification; Lithium-ion batteries; State of health estimation},
Author-Email = {freedon@haut.edu.cn},
Number-of-Cited-References = {54},
Times-Cited = {6},
Unique-ID = {WOS:001329507200001},
}

@article{ WOS:001226309400021,
Author = {Mehrabian, Amir and Sabbaghian, Maryam and Yanikomeroglu, Halim},
Title = {RL-Based Hyperparameter Selection for Spectrum Sensing With CNNs},
Journal = {IEEE TRANSACTIONS ON COMMUNICATIONS},
Year = {2024},
Volume = {72},
Number = {5},
Pages = {2806-2819},
Month = {MAY},
Abstract = {Selection of hyperparameters in deep neural networks is a challenging
   problem due to the wide search space and emergence of various layers
   with specific hyperparameters. There exists an absence of consideration
   for the neural architecture selection of convolutional neural networks
   (CNNs) for spectrum sensing. Here, we develop a method using
   reinforcement learning and Q-learning to systematically search and
   evaluate various architectures for generated datasets including
   different signals and channels in the spectrum sensing problem. We show
   by extensive simulations that CNN-based detectors proposed by our
   developed method outperform several detectors in the literature. For the
   most complex dataset, the proposed approach provides 9\% enhancement in
   accuracy at the cost of higher computational complexity. Furthermore, a
   novel method using multi-armed bandit model for selection of the sensing
   time is proposed to achieve higher throughput and accuracy while
   minimizing the consumed energy. The method dynamically adjusts the
   sensing time under the time-varying condition of the channel without
   prior information. We demonstrate through a simulated scenario that the
   proposed method improves the achieved reward by about 20\% compared to
   the conventional policies. Consequently, this study effectively manages
   the selection of important hyperparameters for CNN-based detectors
   offering superior performance of cognitive radio network.},
Type = {Article},
Affiliation = {Sabbaghian, M (Corresponding Author), Univ Tehran, Sch Elect \& Comp Engn, Tehran 1439957131, Iran.
   Mehrabian, Amir; Sabbaghian, Maryam, Univ Tehran, Sch Elect \& Comp Engn, Tehran 1439957131, Iran.
   Yanikomeroglu, Halim, Carleton Univ, Dept Syst \& Comp Engn, Ottawa, ON K1S 5B6, Canada.},
DOI = {10.1109/TCOMM.2024.3354204},
Keywords = {Sensors; Detectors; Computer architecture; Search problems; OFDM;
   Throughput; Wireless sensor networks; Cognitive radio; spectrum sensing;
   neural architecture search; hyperparameters; deep learning;
   convolutional neural network},
Keywords-Plus = {COGNITIVE RADIO; ROBUST; PERFORMANCE; SIGNAL; TIME},
Author-Email = {amir.mehrabian@ut.ac.ir
