@incollection{ WOS:000724517700013,
Author = {Kim, Grace E. and Steller, Moritz and Olson, Sarah},
Book-Group-Author = {ACM},
Title = {Modeling watershed nutrient concentrations with AutoML},
Booktitle = {PROCEEDINGS OF 2020 10TH INTERNATIONAL CONFERENCE ON CLIMATE INFORMATICS
   (CI2020)},
Year = {2020},
Pages = {86-97},
Abstract = {Water quality impairments in coastal and estuarine waters around the
   world have been linked to human activities on land. Excess nitrogen
   inputs from rivers result in low dissolved oxygen bottom waters, or
   hypoxia, which has negative ecological and economic impacts.
   Additionally, warming surface water temperatures increase
   stratification, further preventing oxygenation of bottom waters. Land
   use management policies have been implemented to improve water quality,
   but the solution must be regionally appropriate, accounting for the
   uniqueness and complexity of each watershed. In this study, we implement
   an AutoML pipeline to find the best model and associated parameters for
   predicting total nitrogen concentrations in the Chesapeake Bay, USA
   watershed from geographic and climate predictors. The highest performing
   model was a stacked ensemble model, H2O AutoML Regression GLM, with an
   R-2 of 0.91 and RMSE of 0.48 on the test data. This model outperformed
   deep learning models, which were included in the 60+ models evaluated in
   the AutoML pipeline. Since feature importance cannot be deciphered from
   ensemble models, we looked to the best performing non-ensemble model for
   the most important predictors. The three most important features in the
   H2O AutoML XGBoost model (R-2 = 0.84, RMSE = 0.69) were geographic
   indicators (i.e. longitude, latitude and watershed code) while climate
   variables were poor predictors. Our results point to the importance of
   location and land use within a subwatershed for modeling watershed
   nitrogen concentrations. While these findings provide insight into
   watershed dynamics for our region of study, we hypothesize that the best
   performing model, model performance and/or feature importance may be
   different for other geographies.},
