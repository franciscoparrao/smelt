@incollection{ WOS:000324655500043,
Author = {Li, Guang (George)},
Book-Group-Author = {ASME},
Title = {ARCTIC FPSO: TECHNICAL FEASIBILITIES AND CHALLENGES},
Booktitle = {PROCEEDINGS OF THE ASME 31ST INTERNATIONAL CONFERENCE ON OCEAN, OFFSHORE
   AND ARCTIC ENGINEERING, 2012, VOL 6},
Year = {2012},
Pages = {379-385},
Abstract = {FPSO (Floating Production Storage Offloading) vessels are ideally suited
   for development of remote-region projects because tankers and onsite
   storage are needed to transport crude oil to markets. Even for the
   basins where pipelines are eventually built, an FPSO can still serve as
   an early production system to reduce project risk and improve project
   cash flow. Therefore, an FPSO offers an attractive solution to deepwater
   fields in the Arctic where fixed platforms are not feasible from either
   technical or commercial perspectives.
   The technical feasibility of an arctic FPSO depends on ice and iceberg
   conditions. In iceberg infested water, the arctic FPSO needs to be
   disconnectable to avoid collisions with incoming icebergs. Even without
   the presence of icebergs, an Arctic FPSO may need to be disconnectable
   due to the limits of stationkeeping capacity of its mooring system.
   Design of a disconnectable mooring system becomes significantly more
   challenging than a permanent one because of the additional requirement
   of load transfer, disconnected subsea system, disconnections and
   reconnections. These requirements often conflict with the ones of flow
   assurance, topside layout, ventilation and fire protection. These
   conflicting requirements are discussed and technology gaps are
   identified in this paper.},
Type = {Proceedings Paper},
Affiliation = {Li, G (Corresponding Author), SBM Atlantia, Houston, TX USA.
   SBM Atlantia, Houston, TX USA.},
Number-of-Cited-References = {9},
Times-Cited = {1},
Unique-ID = {WOS:000324655500043},
}

@incollection{ WOS:000281910700084,
Author = {King, Carey W. and Guelen, Guercan and Essandoh-Yeddu, Joseph and
   Hovorka, Susan},
Book-Group-Author = {ASME},
Title = {ECONOMIC ANALYSIS OF AN INTEGRATED ANTHROPOGENIC CARBON DIOXIDE NETWORK
   FOR CAPTURE AND ENHANCED OIL RECOVERY ALONG THE TEXAS GULF COAST},
Booktitle = {ES2009: PROCEEDINGS OF THE ASME 3RD INTERNATIONAL CONFERENCE ON ENERGY
   SUSTAINABILITY, VOL 1},
Year = {2009},
Pages = {679-688},
Abstract = {This paper explains the system economics of an example integrated
   network that uses anthropogenic CO2 from Texas Gulf Coast fossil power
   plants for enhanced oil recovery (EOR). These CO2 sources and sinks are
   connected via a pipeline network. A discounted cash flow model indicates
   that for all candidate oil fields that require less than an estimated
   \$10/BBL in EOR capital expenditure, all three entities (CO2 capture,
   pipelines, and EOR operators) can have 20\% internal rate of return at
   \$55 per tonne of CO2 and \$56 per barrel of oil. These results include
   no existing or future tax incentives, and there are some costs not yet
   included. However, a Monte Carlo analysis shows insight by indicating
   that the total system rate of return is most sensitive to oil production
   parameters. Oil price and estimated amount of recoverable oil are the
   most positively influential factors while the EOR capital cost is the
   most negatively sensitive factor. The capital costs of capture and CO2
   price are less sensitive, both negatively affecting rate of return.},
Type = {Proceedings Paper},
Affiliation = {King, CW (Corresponding Author), Univ Texas Austin, Ctr Int Energy \& Environm Policy, Austin, TX 78713 USA.
   King, Carey W., Univ Texas Austin, Ctr Int Energy \& Environm Policy, Austin, TX 78713 USA.},
Keywords = {carbon dioxide; capture; sequestration; enhanced oil recovery; economics},
Author-Email = {careyking@mail.utexas.edu
   gurcan.gulen@beg.utexas.edu
   jeyeddu@hotmail.com
   susan.hovorka@beg.utexas.edu},
Number-of-Cited-References = {13},
Times-Cited = {1},
Unique-ID = {WOS:000281910700084},
}

@article{ WOS:001643225700001,
Author = {Wilson, Andrew J.},
Title = {Chicago's Irish Nationalists: From Civil Rights to Bloody Sunday,
   1968-1972},
Journal = {JOURNAL OF AMERICAN ETHNIC HISTORY},
Year = {2026},
Volume = {45},
Number = {2},
Pages = {5-33},
Month = {WIN},
Abstract = {From the mid-1800s onward, Chicago's Irish immigrants played an
   important role in supporting both physical force and constitutional
   nationalist organizations in their ancestral homeland. This tradition of
   assistance declined significantly after the partition of Ireland in
   1921. Most of Chicago's Irish community saw the Irish Free State's
   dominion status as a significant step toward eventual freedom. In
   addition, the 1924 Immigration Act and onset of the Great Depression cut
   the city's nationalist groups off from the steady stream of new arrivals
   from Ireland that had been a source of regeneration for nearly a
   century. Chicago'spost-1945 suburbanization further compounded these
   trends, breaking the sense of ethnic solidarity that had traditionally
   driven concern for events in Ireland. This article argues, however, that
   in the late 1960s, despite all the challenges, Chicago's remaining Irish
   nationalists were rejuvenated by the outbreak of violence in Northern
   Ireland. Enraged by what they saw as British oppression, particularly
   the use of internment without trial and the murder of civil rights
   demonstrators on Bloody Sunday, they channeled their activism through
   the Irish Northern Aid Committee (Noraid). In its first two years,
   Chicago Noraid sent significant amounts of cash to the republican
   movement in Ireland, helped generate publicity for their cause, and
   attracted support from a handful of the city's political leaders. Others
   set up weapons pipelines that provided the Provisional IRA with the
   military hardware it needed to wage an ``armed struggle{''} that helped
   bring down the Unionist government in Belfast.},
Type = {Article},
Number-of-Cited-References = {106},
Times-Cited = {0},
Unique-ID = {WOS:001643225700001},
}

@article{ WOS:001703015000001,
Author = {Chu, Yangyang and Fang, Yun and Sun, Liangzhi and Zhang, Yang and Wang,
   Liujian and Han, Xiaomeng and Lv, Mou and Liu, Haixing and Xin, Kunlun
   and Wang, Weigang and Zhu, Yanping and Shu, Shihu},
Title = {AutoML democratizes water quality forecasting: Lowering expertise
   barriers},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2026},
Volume = {85},
Month = {APR},
Abstract = {Harmful algal blooms present a persistent threat to global water
   security. While advanced forecasting tools could help mitigate this
   risk, their widespread adoption is hindered by the extensive machine
   learning expertise required for their development and tuning. This study
   introduces the first application of Fast and Lightweight Automated
   Machine Learning (FLAML) framework to water quality forecasting and
   harmful algal bloom (HAB) early warning, specifically targeting
   blue-green algae and chlorophyll-a (Chl-a) concentrations. Our automated
   approach effectively democratizes predictive modeling by substantially
   reducing the need for manual architecture design and hyperparameter
   optimization. The FLAML framework achieves superior predictive accuracy,
   with blue-green algae forecasting attaining R2 = 0.982, RMSE = 1.71
   cells/mL, and MAPE = 1.72\%, while Chl-a prediction reached R2 = 0.991,
   RMSE = 0.013 mu g/L and MAPE = 0.5\%. These results substantially
   outperform the best deep learning baseline (CNN-LSTM: R2 = 0.874 for
   blue-green algae, R2 = 0.930 for Chl-a), as well as LSTM and Transformer
   architectures. Remarkably, this high performance is attained with a
   computational budget of only 600 s, drastically reducing the time and
   expertise barriers associated with traditional methods. The model also
   demonstrates robust performance across varying input time windows (6,
   12, 24, 36, and 48 h) and feature sets. This study establishes FLAML as
   a practical, efficient, and highly accessible solution for enabling
   real-time algal bloom forecasting in eutrophic drinking water
   reservoirs. The demonstrated performance suggests potential
   applicability for water utilities operating similar systems to implement
   advanced AI-driven management strategies with limited machine learning
   background. Validation across diverse climatic, hydrological, and
   trophic conditions is recommended before broader generalization.},
Type = {Article},
Affiliation = {Shu, SH (Corresponding Author), Donghua Univ, Coll Environm Sci \& Engn, Shanghai 201620, Peoples R China.
   Chu, Yangyang; Fang, Yun; Sun, Liangzhi; Zhang, Yang; Wang, Liujian; Han, Xiaomeng; Wang, Weigang; Zhu, Yanping; Shu, Shihu, Donghua Univ, Coll Environm Sci \& Engn, Shanghai 201620, Peoples R China.
   Han, Xiaomeng; Shu, Shihu, Shanghai Inst Pollut Control \& Ecol Safety, Shanghai 200092, Peoples R China.
   Lv, Mou, Qingdao Univ Technol, Sch Environm \& Municipal Engn, Qingdao 2666520, Peoples R China.
   Liu, Haixing, Dalian Univ Technol, Dept Hydraul Engn, Dalian 116024, Liaoning, Peoples R China.
   Xin, Kunlun, Tongji Univ, Coll Environm Sci \& Engn, Shanghai Inst Pollut Control \& Ecol Secur, Siping Rd, Shanghai 200092, Peoples R China.},
DOI = {10.1016/j.jwpe.2026.109675},
EarlyAccessDate = {APR 2026},
Article-Number = {109675},
Keywords = {Automated machine learning; Water quality forecasting; FLAML; Time
   series prediction; Democratization of AI},
Author-Email = {shushihu@dhu.edu.cn},
Number-of-Cited-References = {48},
Times-Cited = {0},
Unique-ID = {WOS:001703015000001},
}

@article{ WOS:001692937400003,
Author = {Zarrin, Mohamad and Cavaleri, Liborio and Rezaei, Amirhossein and Safa,
   Nima Dindar},
Title = {A 1D-CNN deep learning framework for seismic collapse prediction of
   jacket offshore platforms with Bayesian neural architecture search},
Journal = {OCEAN ENGINEERING},
Year = {2026},
Volume = {352},
Number = {2},
Month = {APR 15},
Abstract = {This paper aims to develop and evaluate the one dimensional
   convolutional neural network (1D-CNN) deep learning (DL) model for
   earthquake accelerogram time series classification, with the ultimate
   goal of predicting seismic limit state exceedance in Jacket Type
   Offshore Platforms (JTOP). The application of earthquake time series as
   the DL model input feature is not common in the fast seismic performance
   evaluation of structures. Additionally, in practical scenarios, the
   predictive performance of 1D-CNN is heavily reliant on the selection of
   appropriate model architecture and hyperparameters. Therefore, this
   study proposes a framework for systematically searching the neural
   architecture and hyperparameters of deep learning models, particularly
   1D-CNN, through Bayesian optimization. Since manual search for model
   components can be a difficult task that may require numerous
   trial-and-error attempts or parametric studies, the aim of this
   framework is to streamline and organize the typical workflow of
   developing DL models to ensure optimal performance. Moreover, the
   comprehensive nested cross-validation method has been utilized to
   achieve an unbiased evaluation. The focus of this study is on the
   seismic collapse prediction of Jacket Type Offshore Platforms with
   1D-CNN, and to fulfill this objective, a stochastic optimization
   algorithm is proposed to perform the stratified K-fold cross validation,
   specifically developed for the dataset preparation based on the
   incremental dynamic analysis (IDA). For comparison purposes, the
   presented framework is also applied for the hyperparameter tuning of
   Multilayer Perceptron (MLP) and Support Vector Machine (SVM) techniques.
   The effectiveness of the presented framework is evaluated for a case
   study JTOP structure subjected to an ensemble of earthquake records. The
   results demonstrate the capability of 1D-CNN model, developed using the
   proposed framework, for computing the collapse fragility curves of
   JTOPs.},
