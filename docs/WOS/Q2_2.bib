@incollection{ WOS:001451321805006,
Author = {Elahi, Ali and Taghvaei, Fatemeh},
Editor = {Ding, W and Lu, CT and Wang, F and Di, L and Wu, K and Huan, J and Nambiar, R and Li, J and Ilievski, F and Baeza-Yates, R and Hu, X},
Title = {Combining Financial Data and News Articles for Stock Price Movement
   Prediction Using Large Language Models},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON BIG DATA, BIGDATA},
Series = {IEEE International Conference on Big Data},
Year = {2024},
Pages = {4875-4883},
Abstract = {Predicting financial markets and stock price movements requires
   analyzing a company's performance, historic price movements,
   industry-specific events alongside the influence of human factors such
   as social media and press coverage. We assume that financial reports
   (such as income statements, balance sheets, and cash flow statements),
   historical price data, and recent news articles can collectively
   represent aforementioned factors.
   We combine financial data in tabular format with textual news articles
   and employ pre-trained Large Language Models (LLMs) to predict market
   movements. Recent research in LLMs has demonstrated that they are able
   to perform both tabular and text classification tasks, making them our
   primary model to classify the multi-modal data. We utilize retrieval
   augmentation techniques to retrieve and attach relevant chunks of news
   articles to financial metrics related to a company and prompt the LLMs
   in zero, two, and four-shot settings. Our dataset contains news articles
   collected from different sources, historic stock price, and financial
   report data for 20 companies with the highest trading volume across
   different industries in the stock market. We utilized recently released
   language models for our LLM-based classifier, including GPT-3 and 4, and
   LLaMA-2 and 3 models.
   We introduce an LLM-based classifier capable of performing
   classification tasks using combination of tabular (structured) and
   textual (unstructured) data. By using this model, we predicted the
   movement of a given stock's price in our dataset with a weighted
   F1-score of 58.5\% and 59.1\% and Matthews Correlation Coefficient of
   0.175 for both 3-month and 6-month periods. The dataset and codes for
   this paper can be found on Github. https://github.com/aliielahi/FinedFMP
   (1)},
Type = {Proceedings Paper},
Affiliation = {Elahi, A (Corresponding Author), Univ Illinois, Dept Comp Sci, Chicago, IL 60680 USA.
   Elahi, Ali, Univ Illinois, Dept Comp Sci, Chicago, IL 60680 USA.
   Taghvaei, Fatemeh, Univ Illinois, Dept Elect \& Comp Engn, Chicago, IL 60680 USA.},
DOI = {10.1109/BigData62323.2024.10825449},
Keywords = {Financial Stock Price Movement Prediction; Large Language Models;
   Information Retrieval; Retrieval Augmented Generation},
Author-Email = {aelahi6@uic.edu
   ftaghv2@uic.edu},
Number-of-Cited-References = {24},
Times-Cited = {1},
Unique-ID = {WOS:001451321805006},
}

@incollection{ WOS:001275761100020,
Author = {Francia, Matteo and Giovanelli, Joseph and Golfarelli, Matteo},
Editor = {Yang, DN and Xie, X and Tseng, VS and Pei, J and Huang, JW and Lin, JCW},
Title = {AutoClues: Exploring Clustering Pipelines via AutoML and Diversification},
Booktitle = {ADVANCES IN KNOWLEDGE DISCOVERY AND DATA MINING, PT I, PAKDD 2024},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2024},
Volume = {14645},
Pages = {246-258},
Abstract = {AutoML has witnessed effective applications in the field of supervised
   learning - mainly in classification tasks - where the goal is to find
   the best machine-learning pipeline when a ground truth is available.
   This is not the case for unsupervised tasks that are by nature
   exploratory and they are performed to unveil hidden insights. Since
   there is no right result, analyzing different configurations is more
   important than returning the best-performing one. When it comes to
   exploratory unsupervised tasks - such as cluster analysis - different
   facets of the datasets could be interesting for the data scientist; for
   instance, data items can be effectively grouped together in different
   subspaces of features. In this paper, AutoClues explores and returns a
   dashboard of both relevant and diverse clusterings via AutoML and
   diversification. AutoML ensures that the explored pipelines for cluster
   analysis (including pre-processing steps) compute good clusterings.
   Then, diversification selects, out of the explored clusterings, the ones
   conveying different clues to the data scientists.},
Type = {Proceedings Paper},
Affiliation = {Giovanelli, J (Corresponding Author), Univ Bologna, Cesena, Italy.
   Francia, Matteo; Giovanelli, Joseph; Golfarelli, Matteo, Univ Bologna, Cesena, Italy.},
DOI = {10.1007/978-981-97-2242-6\_20},
Keywords = {AutoML; Clustering; Diversification},
Keywords-Plus = {SIMULTANEOUS FEATURE-SELECTION; K-MEANS},
Author-Email = {m.francia@unibo.it
   j.giovanelli@unibo.it
   matteo.golfarelli@unibo.it},
Number-of-Cited-References = {32},
Times-Cited = {1},
Unique-ID = {WOS:001275761100020},
}

@incollection{ WOS:001445799800166,
Author = {Franco, Bruno Lovison and Miquel, Jonathan and Romdhane, Aymen and
   Prenat, Guillaume and Anghel, Lorena and Novo, David and Benoit, Pascal},
Book-Group-Author = {IEEE},
Title = {Trade-offs in Neural Network Compression: Quantized and Binary Models
   for Keyword Spotting},
Booktitle = {2024 31ST IEEE INTERNATIONAL CONFERENCE ON ELECTRONICS, CIRCUITS AND
   SYSTEMS, ICECS},
Series = {IEEE International Conference on Electronics Circuits and Systems},
Year = {2024},
Abstract = {Enabling smart and independent IoT devices often requires to run complex
   Machine Learning (ML) workloads at the edge. Such systems usually
   operate with memories in the order of tens of kilobytes and low
   processing power. To fit within these constraints, model designers
   typically rely on low-precision integer representation of operations
   down to 1-bit, i.e., Binary Neural Networks (BNN). In this paper, we
   investigate the tradeoffs available to model designers between memory
   footprint and accuracy and the challenges to overcome for effective use
   of BNN. We show that designing BNN architectures is not a
   straightforward process. To overcome this, we propose a methodology
   based on design guidelines and Neural Architecture Search (NAS) to adapt
   traditional model architectures into BNN variants. As a case study, we
   apply this methodology to a ResNet-based model for a keyword spotting
   (KWS) application. Our results demonstrate that, contrary to 8-bit
   quantization, direct binarization significantly impacts accuracy.
   However, careful architecture redesign and hyperparameter tuning helps
   bringing BNNs performances on par with their quantized counterparts.},
Type = {Proceedings Paper},
Affiliation = {Franco, BL (Corresponding Author), Univ Montpellier, CNRS, LIRMM, Montpellier, France.
   Franco, Bruno Lovison; Miquel, Jonathan; Romdhane, Aymen; Novo, David; Benoit, Pascal, Univ Montpellier, CNRS, LIRMM, Montpellier, France.
   Prenat, Guillaume; Anghel, Lorena, UGA, CNRS, CEA, SPINTEC Grenoble, Grenoble, France.},
DOI = {10.1109/ICECS61496.2024.10849192},
Keywords = {Edge Computing; Exploration; TinyML; Binary Neural Networks;
