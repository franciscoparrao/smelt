@article{ WOS:001120621200001,
Author = {Neutatz, Felix and Lindauer, Marius and Abedjan, Ziawasch},
Title = {AutoML in heavily constrained applications},
Journal = {VLDB JOURNAL},
Year = {2024},
Volume = {33},
Number = {4, SI},
Pages = {957-979},
Month = {JUL},
Abstract = {Optimizing a machine learning pipeline for a task at hand requires
   careful configuration of various hyperparameters, typically supported by
   an AutoML system that optimizes the hyperparameters for the given
   training dataset. Yet, depending on the AutoML system's own second-order
   meta-configuration, the performance of the AutoML process can vary
   significantly. Current AutoML systems cannot automatically adapt their
   own configuration to a specific use case. Further, they cannot compile
   user-defined application constraints on the effectiveness and efficiency
   of the pipeline and its generation. In this paper, we propose Caml,
   which uses meta-learning to automatically adapt its own AutoML
   parameters, such as the search strategy, the validation strategy, and
   the search space, for a task at hand. The dynamic AutoML strategy of
   Caml takes user-defined constraints into account and obtains
   constraint-satisfying pipelines with high predictive performance.},
Type = {Article},
Affiliation = {Neutatz, F (Corresponding Author), TU Berlin, Berlin, Germany.
   Neutatz, Felix, TU Berlin, Berlin, Germany.
   Lindauer, Marius; Abedjan, Ziawasch, Leibniz Univ Hannover, Hannover, Germany.},
DOI = {10.1007/s00778-023-00820-1},
EarlyAccessDate = {NOV 2023},
Keywords = {AutoML; Constraints; Meta-Learning},
Author-Email = {f.neutatz@tu-berlin.de
   m.lindauer@ai.uni-hannover.de
   abedjan@dbs.uni-hannover.de},
Number-of-Cited-References = {63},
