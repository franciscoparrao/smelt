@article{ WOS:001719526900002,
Author = {Kalagotla, Srinivas Goud and Wang, Fang and Datla, Kirti and Ferguson,
   Bradley J. and Beversdorf, David Q.},
Title = {Toward a Smartwatch-Based System for Automated Social Interaction
   Monitoring in Autism},
Journal = {IEEE ACCESS},
Year = {2026},
Volume = {14},
Pages = {41141-41154},
Abstract = {Autism Spectrum Disorder (ASD) is a complex neurodevelopmental condition
   that affects social interactions and communication. Traditional
   assessment methods are often manual, subjective - lack ecological
   validity and scalability. This study presents a fully automated, machine
   learning-based system for continuous monitoring of social interactions
   in individuals with ASD using voice and physiological data collected in
   naturalistic environments. The system leverages speaker diarization to
   quantify the duration the ASD individual speaks during real-life
   conversations. An enhanced deep learning-based diarization method built
   on pyannote-audio is used to identify the target speaker, with each
   recording beginning with a short voice sample from the participant for
   identification purposes. Audio and heart rate data are simultaneously
   collected via a standalone smartwatch app, requiring no phone or network
   connectivity during data capture. Data are then processed through a
   cloud-based pipeline. The system was validated in both controlled and
   real-world settings, including testing with ASD individuals. Results
   show that the system can accurately and effectively capture speaking
   time, identify speaker turns, and track physiological signals during
   social interactions. This approach provides an objective, scalable
   framework for social behavior assessment in ASD, with strong potential
   for clinical application and long-term, real-world monitoring.},
