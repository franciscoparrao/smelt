   Kisskalt, Dominik; Mayr, Andreas; Lutz, Benjamin; Roegele, Annelie; Franke, Joerg, Friedrich Alexander Univ Erlangen Nurnberg FAU, Inst Factory Automat \& Prod Syst FAPS, Egerlandstr 7-9, D-91058 Erlangen, Germany.},
DOI = {10.1016/j.procir.2020.04.009},
