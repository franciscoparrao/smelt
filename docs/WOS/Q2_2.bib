   Zahedi, Leila; Amini, M. Hadi, FIU Miami, Sustainabil Optimizat \& Learning InterDependent N, Miami, FL 33199 USA.
   Mohammadi, Farid Ghareh, Univ Georgia, Dept Comp Sci, Athens, GA 30602 USA.},
DOI = {10.1109/ICMLA52953.2021.00186},
Keywords = {Automated Machine Learning; Automated Hyper-Parameter Tuning; Artificial
   Bee Colony Algorithm; Evolutionary Optimization},
Keywords-Plus = {ARTIFICIAL BEE COLONY; OPTIMIZATION},
Author-Email = {moamini@fiu.edu},
