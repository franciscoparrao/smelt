   Laman, Haluk, Univ Cent Florida, Dept Civil Environm \& Construct Engn, Orlando, FL 32816 USA.},
DOI = {10.3390/modelling2040026},
Keywords = {machine learning; passenger vehicle traffic; traffic volume; predictive
   modeling; regression analysis},
