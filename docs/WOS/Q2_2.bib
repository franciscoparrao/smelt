Keywords-Plus = {EMPIRICAL MODE DECOMPOSITION; CRUDE-OIL PRICE; CLICKSTREAM; BEHAVIOR;
   FREQUENCY; CHOICE; SALES},
Author-Email = {gks\_cn@163.com},
Number-of-Cited-References = {38},
Times-Cited = {8},
