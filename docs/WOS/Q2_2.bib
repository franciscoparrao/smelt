   Tavares, Gabriel Marques, Munich Ctr Machine Learning MCML, D-80539 Munich, Germany.
   Ceravolo, Paolo, Univ Milano Statale, Dipartimento Informat, I-20135 Milan, Italy.},
DOI = {10.3390/info15040241},
Article-Number = {241},
Keywords = {AutoML; trace clustering; pipeline synthesis; process mining},
Keywords-Plus = {MODELS},
