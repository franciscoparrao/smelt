   Kadir, Rabiah Abdul, Univ Kebangsaan Malaysia, Inst IR4 0, Bangi 43600, Selangor, Malaysia.},
DOI = {10.1109/ACCESS.2022.3198662},
Keywords = {Encoding; Data preprocessing; Machine learning; Feature extraction; Data
