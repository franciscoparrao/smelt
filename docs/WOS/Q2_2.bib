DOI = {10.3390/info14040232},
Article-Number = {232},
Keywords = {AutoML; MLOps; structure learning; hyperparameter optimization; Bayesian
   optimization; multilayer perceptron},
Keywords-Plus = {CONTINUOUS INTEGRATION; EFFICIENT},
Author-Email = {gtsek@ct.aegean.gr},
Number-of-Cited-References = {66},
Times-Cited = {16},
