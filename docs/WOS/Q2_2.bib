@article{ WOS:001377582600001,
Author = {Silivery, Arun Kumar and Rao, Kovvur Ram Mohan and Solleti, Ramana},
Title = {Dual-path feature extraction based hybrid intrusion detection in IoT
   networks},
Journal = {COMPUTERS \& ELECTRICAL ENGINEERING},
Year = {2025},
Volume = {122},
Month = {MAR},
Abstract = {A significant concern in the current computing industry is safeguarding
   Internet of Things (IoT) networks due to the rapid rise in cyberattacks
   and security lapses. Previously, numerous machinelearning techniques
   have been suggested to safeguard these networks; however, they require
   specialized knowledge for feature extraction and are unable to manage
   massive datasets effectively. Thus, a deep learning-based intrusion
   detection framework is implemented in this work for IoT-based intrusion
   detection. A Dual Path Feature Extraction Network is implemented to
   perform optimal feature extraction and fusion processes. Then, the fused
   features are forwarded to the Neural Architecture Search Network for
   attack detection and classification. In addition, the data imbalance
   issue is resolved using the Conditional Tabular Generative Adversarial
   Network. The proposed framework is evaluated to verify its effectiveness
   using three datasets: BoT-IoT, ToNIoT, and IoT-23. The experiment
   findings show that the proposed system outperforms competitors and is
   appropriate for IoT environments.},
