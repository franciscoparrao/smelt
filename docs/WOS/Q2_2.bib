}

@incollection{ WOS:000869718800006,
Author = {Schuh, Guenther and Stroh, Max-Ferdinand and Benning, Justus},
Editor = {Kim, DY and VonCieminski, G and Romero, D},
Title = {Case-Study-Based Requirements Analysis of Manufacturing Companies for
   Auto-ML Solutions},
Booktitle = {ADVANCES IN PRODUCTION MANAGEMENT SYSTEMS: SMART MANUFACTURING AND
   LOGISTICS SYSTEMS: TURNING IDEAS INTO ACTION, APMS 2022, PT I},
Series = {IFIP Advances in Information and Communication Technology},
Year = {2022},
Volume = {663},
Pages = {43-50},
Abstract = {Methods of machine learning (ML) are difficult for manufacturing
   companies to employ productively. Data science is not their core skill,
   and acquiring talent is expensive. Automated machine learning (Auto-ML)
   aims to alleviate this, democratizing machine learning by introducing
   elements such as low-code or no-code functionalities into its model
   creation process. Due to the dynamic vendor market of Auto-ML, it is
   difficult for manufacturing companies to successfully implement this
   technology. Different solutions as well as constantly changing
   requirements and functional scopes make a correct software selection
   difficult. This paper aims to alleviate said challenge by providing a
   longlist of requirements that companies should pay attention to when
   selecting a solution for their use case. The paper is part of a larger
   research effort, in which a structured selection process for Auto-ML
   solutions in manufacturing companies is designed. The longlist itself is
   the result of six case studies of different manufacturing companies,
   following the method of case study research by Eisenhardt. A total of 75
   distinct requirements were identified, spanning the entire machine
   learning and modeling pipeline.},
Type = {Proceedings Paper},
Affiliation = {Benning, J (Corresponding Author), Rhein Westfal TH Aachen, FIR, Inst Ind Management, Campus Blvd 55, D-52074 Aachen, Germany.
   Schuh, Guenther; Stroh, Max-Ferdinand; Benning, Justus, Rhein Westfal TH Aachen, FIR, Inst Ind Management, Campus Blvd 55, D-52074 Aachen, Germany.},
DOI = {10.1007/978-3-031-16407-1\_6},
Keywords = {Machine learning; Auto-ML; Requirements; Manufacturing},
Author-Email = {justus.benning@fir.rwth-aachen.de},
Number-of-Cited-References = {15},
Times-Cited = {3},
Unique-ID = {WOS:000869718800006},
}

@incollection{ WOS:000922928402074,
Author = {Baudart, Guillaume and Hirzel, Martin and Kate, Kiran and Ram, Parikshit
   and Shinnar, Avraham and Tsay, Jason},
Editor = {Ranzato, M and Beygelzimer, A and Dauphin, Y and Liang, PS and Vaughan, JW},
Title = {Pipeline Combinators for Gradual AutoML},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 34 (NEURIPS 2021)},
Series = {Advances in Neural Information Processing Systems},
Year = {2021},
Volume = {34},
Abstract = {Automated machine learning (AutoML) can make data scientists more
   productive. But if machine learning is totally automated, that leaves no
   room for data scientists to apply their intuition. Hence, data
   scientists often prefer not total but gradual automation, where they
   control certain choices and AutoML explores the rest. Unfortunately,
   gradual AutoML is cumbersome with state-of-the-art tools, requiring
   large non-compositional code changes. More concise compositional code
   can be achieved with combinators, a powerful concept from functional
   programming. This paper introduces a small set of orthogonal combinators
   for composing machine-learning operators into pipelines. It describes a
   translation scheme from pipelines and associated hyperparameter schemas
   to search spaces for AutoML optimizers. On that foundation, this paper
   presents Lale, an open-source sklearn-compatible AutoML library, and
   evaluates it with a user study.},
Type = {Proceedings Paper},
Affiliation = {Baudart, G (Corresponding Author), ENS PSL Univ, INRIA, Paris, France.
   Baudart, Guillaume, ENS PSL Univ, INRIA, Paris, France.
   Hirzel, Martin; Kate, Kiran; Ram, Parikshit; Shinnar, Avraham; Tsay, Jason, IBM Res, Armonk, NY USA.},
