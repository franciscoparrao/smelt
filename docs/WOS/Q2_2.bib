DOI = {10.1007/s10994-021-05992-x},
EarlyAccessDate = {JUN 2021},
Keywords = {Adaptive machine learning; Streaming data; Non-stationary data; Concept
   drift; Automated machine learning},
Keywords-Plus = {WEIGHTED MAJORITY; NEURAL NETWORKS; TIME; MODELS; ALGORITHMS; SELECTION;
