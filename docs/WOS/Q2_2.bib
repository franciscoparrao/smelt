@incollection{ WOS:001196800600085,
Author = {Conrad, Felix and Maelzer, Mauritz and Lange, Felix and Wiemer, Hajo and
   Ihlenfeldt, Steffen},
Editor = {Longo, F and Shen, W and Padovano, A},
Title = {AutoML Applied to Time Series Analysis Tasks in Production Engineering},
Booktitle = {5TH INTERNATIONAL CONFERENCE ON INDUSTRY 4.0 AND SMART MANUFACTURING,
   ISM 2023},
Series = {Procedia Computer Science},
Year = {2024},
Volume = {232},
Pages = {849-860},
Abstract = {This paper demonstrates the application of a fully automated machine
   learning (ML) pipeline on time series data from the domain of production
   engineering. The workflow aims to streamline the machine learning (ML)
   process and reduce manual effort by incorporating automated machine
   learning (AutoML) and automated featurization techniques. A comparative
   study is created to evaluate the proposed workflow against existing
   state-of-the-art methods using six datasets from production engineering,
   five widely used ones and a newly presented one. The study compares the
   performance of the automated workflow with the manual data mining
   process described in the literature. The results lead to two main
   conclusions: first, an automated featurization process cannot match the
   performance of manual feature generation, but still delivers good
   results without requiring manual work. Second, if the manually generated
   features are used, AutoML can outperform the manual process in solving
   the combined problem of algorithm selection and hyperparameter
   optimization, leading to better prediction results. The presented
   approach serves as a useful reference for other methods, showing the
   practicality of baseline workflow without human bias. Overall, the
   proposed data processing pipeline demonstrates the potential of AutoML
   in production engineering and provides valuable insights for
   practitioners in this domain. (C) 2024 The Authors. Published by
   Elsevier B.V.},
Type = {Proceedings Paper},
Affiliation = {Conrad, F (Corresponding Author), TUD Dresden Univ Technol, D-01062 Dresden, Germany.
   Conrad, Felix; Maelzer, Mauritz; Wiemer, Hajo; Ihlenfeldt, Steffen, TUD Dresden Univ Technol, D-01062 Dresden, Germany.
   Lange, Felix, Fraunhofer Inst Proc Engn \& Packaging, D-01189 Dresden, Germany.},
DOI = {10.1016/j.procs.2024.01.085},
Keywords = {Automated Machine Learning; AutoML; Time Series Analysis; Usable
   Artificial Intelligence; UAI; Production Engineering},
Author-Email = {felix.conrad@tu-dresden.de},
