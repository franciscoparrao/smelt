   Garouani, Moncef; Hamlich, Mohamed, Univ Hassan 2, CCPS Lab, ENSAM, Casablanca, Morocco.
   Garouani, Moncef, HESTIM, Study \& Res Ctr Engn \& Management CERIM, Casablanca, Morocco.},
DOI = {10.1186/s40537-023-00687-7},
Article-Number = {14},
Keywords = {Algorithm selection; AutoML; Meta-learning; Meta-features; Data
   representation; kNN; Autoencoder},
