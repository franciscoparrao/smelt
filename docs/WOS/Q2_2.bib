   Guo, Huifeng; Tang, Ruiming; Zhou, Fengwei; Zhang, Yuzhou; Li, Zhenguo, Huawei Noahs Ark Lab, Shenzhen 518129, Peoples R China.
   Wang, Jun, UCL, Dept Comp Sci, London WC1E 6BT, England.},
DOI = {10.1109/TKDE.2020.3016482},
Keywords = {Neural networks; Frequency modulation; Kernel; Feature extraction;
   Computational modeling; Training; Recommender systems; AutoML; hashing;
   neural networks; recommender systems; deep learning; higher-order
   feature interactions},
Keywords-Plus = {HYPERPARAMETER OPTIMIZATION},
