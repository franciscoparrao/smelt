   Zhou, Mengzi, Chinese Acad Meteorol Sci, State Key Lab Severe Weather, Beijing, Peoples R China.
   Zhu, Dun, Univ Tokyo, Sch Engn, Tokyo, Japan.},
DOI = {10.1016/j.scs.2025.106908},
