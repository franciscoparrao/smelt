DOI = {10.1016/j.aime.2022.100099},
Article-Number = {100099},
Keywords = {Automated machine learning; Hyperparameter optimization; Benchmarking;
   Decision support; Production; Manufacturing},
Keywords-Plus = {METHODOLOGY; INFERENCE},
Author-Email = {maximilian.motz@ipt.fraunhofer.de},
