@article{ WOS:001511504100002,
Author = {Ma, Zhengchao and Hu, Hao and Zhou, Xiaoxia and Zhang, Hongbao and
   Zhang, Ye and Li, Gensheng and Tian, Shouceng and Wang, Tianyu},
Title = {Interpretable Automated Machine Learning Workflow for Intelligent
   Drilling in the Petroleum Industry: Case Study on Rate of Penetration
   Prediction},
Journal = {SPE JOURNAL},
Year = {2025},
Volume = {30},
Number = {6},
Pages = {3240-3259},
Month = {JUN},
Abstract = {Accurate rate of penetration (ROP) prediction is essential for
   optimizing the drilling process and improving drilling efficiency.
   Traditional empirical models often struggle to capture the complex
   nonlinear relationships between ROP and various engineering parameters.
   In this study, we introduce a research workflow that integrates
   automatic machine learning with model interpretability. The workflow
   based on this collaborative prediction strategy realizes automated data
   processing and automatic stacking integration of multiple machine
   learning models, including gradient boosting machine (GBM), extremely
   randomized trees (XRT), distributed random forest (DRF), deep learning,
   and generalized linear model (GLM). This strategy leverages the
   strengths of each model to enhance predictive performance and
   robustness. The optimal model is adaptively selected after integrated
   validation and evaluation without human intervention, which greatly
   reduces the model selection and hyperparameter optimization time for ROP
   prediction. The results indicate that the stacked model, following
   10-fold cross-validation, demonstrates the highest model prediction
   accuracy with a root mean squared error (RMSE) of 1.92 and an R2 value
   of 0.92. Remarkably, the model achieves this high performance with a
   training time of only 120 seconds, showcasing its efficiency and
   scalability. This performance was achieved after applying a series of
   preprocessing steps, including outlier handling, normalization, and
   Savitzky-Golay (SG) filtering with a window length of 7 and a polynomial
   order of 2. These preprocessing techniques effectively reduced noise,
   smoothed the data, and improved the model's ability to capture
   underlying patterns, contributing to the high predictive accuracy
   observed. Shapley additive explanations (SNAP) provide global
   interpretation of the effects of drilling parameters on ROP prediction
   as well as local explanations of the contribution of each feature to the
   local prediction. In addition, the overall trend and individual
   differences of ROP in relation to input features are analyzed through
   partial dependence plots (PDPs) and individual conditional expectation
   (ICE) plots. This makes the predictions more convincing and
   interpretable. In this research data set, torque and rotary revolutions
   per minute (RPM) have a directly positive impact on ROP, while drilling
   fluid density (DFD) exhibits clear interval thresholds, beyond which it
   exerts a negative influence. This helps to understand from a data
   perspective the specific range of ROP fluctuations influenced by
   drilling parameters. This study provides an automated machine learning
   (AutoML) workflow to accurately predict ROP, enabling researchers to
   concentrate on practical business scenarios without extensive machine
   learning expertise or frequent manual interventions. It is expected to
   accelerate the process of intelligent transformation of the scientific
   research paradigm in the petroleum sector.},
Type = {Article},
Affiliation = {Wang, TY (Corresponding Author), China Univ Petr, State Key Lab Petr Resources \& Engn, Beijing, Peoples R China.
   Ma, Zhengchao; Hu, Hao; Zhou, Xiaoxia; Li, Gensheng; Tian, Shouceng; Wang, Tianyu, China Univ Petr, State Key Lab Petr Resources \& Engn, Beijing, Peoples R China.
   Zhang, Hongbao, Sinopec Res Inst Petr Engn Co Ltd, Dongying, Peoples R China.
   Zhang, Ye, Minist Nat Resources, Chongqing Inst Geol \& Mineral Resources, Key Lab Shale Gas Explorat, Chongqing, Peoples R China.
   Zhang, Ye, Chongqing Inst Geol \& Mineral Resources, Natl \& Local Joint Engn Res Ctr Shale Gas Explorat, Chongqing, Peoples R China.},
DOI = {10.2118/226195-PA},
Author-Email = {wangty@cup.edu.cn},
Number-of-Cited-References = {49},
Times-Cited = {2},
Unique-ID = {WOS:001511504100002},
}

@article{ WOS:001508288400007,
Author = {Putra, Rachmad Vidya Wicaksana and Shafique, Muhammad},
Title = {SpiKernel: A Kernel Size Exploration Methodology for Improving Accuracy
   of the Embedded Spiking Neural Network Systems},
Journal = {IEEE EMBEDDED SYSTEMS LETTERS},
Year = {2025},
Volume = {17},
Number = {3},
Pages = {151-155},
Month = {JUN},
Abstract = {Spiking neural networks (SNNs) can offer ultralow power/energy
   consumption for machine learning-based application tasks due to their
   sparse spike-based operations. Currently, most of the SNN architectures
   need a significantly larger model size to achieve higher accuracy, which
   is not suitable for resource-constrained embedded applications.
   Therefore, developing SNNs that can achieve high accuracy with
   acceptable memory footprint is highly needed. Toward this, we propose
   SpiKernel, a novel methodology that improves the accuracy of SNNs
   through kernel size exploration. Its key steps include: 1) investigating
   the impact of different kernel sizes on the accuracy; 2) devising new
   sets of kernel sizes; 3) generating SNN architectures using neural
   architecture search based on the selected kernel sizes; and 4) analyzing
   the accuracy-memory tradeoffs for SNN model selection. The experimental
   results show that our SpiKernel achieves higher accuracy than
   state-of-the-art works (i.e., 93.24\% for CIFAR10, 70.84\% for CIFAR100,
   and 62\% for TinyImageNet) with less than 10 M parameters and up to 4.8x
   speed-up of searching time, thereby making it suitable for embedded
   applications.},
Type = {Article},
Affiliation = {Putra, RVW (Corresponding Author), New York Univ Abu Dhabi, Div Engn, EBrain Lab, Abu Dhabi, U Arab Emirates.
   Putra, Rachmad Vidya Wicaksana; Shafique, Muhammad, New York Univ Abu Dhabi, Div Engn, EBrain Lab, Abu Dhabi, U Arab Emirates.},
DOI = {10.1109/LES.2024.3510197},
Keywords = {Kernel; Accuracy; Computer architecture; Convolution; Feature
   extraction; Training; Micromechanical devices; Memory management;
   Topology; Neurons; Embedded applications; kernel size exploration;
   neural architecture search (NAS); spiking neural networks (SNNs)},
Author-Email = {rachmad.putra@nyu.edu
   muhammad.shafique@nyu.edu},
Number-of-Cited-References = {17},
Times-Cited = {2},
Unique-ID = {WOS:001508288400007},
}

@article{ WOS:001492834600001,
Author = {Giovannelli, T. and Kent, G. D. and Vicente, L. N.},
Title = {Inexact bilevel stochastic gradient methods for constrained and
   unconstrained lower-level problems},
Journal = {JOURNAL OF GLOBAL OPTIMIZATION},
Year = {2025},
Volume = {92},
Number = {3},
Pages = {569-614},
Month = {JUL},
Abstract = {Two-level stochastic optimization formulations have become instrumental
   in a number of machine learning contexts such as continual learning,
   neural architecture search, adversarial learning, and hyperparameter
   tuning. Practical stochastic bilevel optimization problems become
   challenging in optimization or learning scenarios where the number of
   variables is high or there are constraints. In this paper, we introduce
   a bilevel stochastic gradient method for bilevel problems with nonlinear
   and possibly nonconvex lower-level constraints. We also present a
   comprehensive convergence theory that addresses both the lower-level
   unconstrained and constrained cases and covers all inexact calculations
   of the adjoint gradient (also called hypergradient), such as the inexact
   solution of the lower-level problem, inexact computation of the adjoint
   formula (due to the inexact solution of the adjoint equation or use of a
   truncated Neumann series), and noisy estimates of the gradients,
   Hessians, and Jacobians involved. To promote the use of bilevel
   optimization in large-scale learning, we have developed new low-rank
   practical bilevel stochastic gradient methods (BSG-N-FD and BSG-1) that
   do not require second-order derivatives and, in the lower-level
   unconstrained case, dismiss any matrix-vector products.},
Type = {Article},
Affiliation = {Giovannelli, T (Corresponding Author), Univ Cincinnati, Dept Mech \& Mat Engn, Cincinnati, OH 45221 USA.
   Giovannelli, T., Univ Cincinnati, Dept Mech \& Mat Engn, Cincinnati, OH 45221 USA.
   Kent, G. D.; Vicente, L. N., Lehigh Univ, Dept Ind \& Syst Engn, Bethlehem, PA 18015 USA.},
DOI = {10.1007/s10898-025-01502-8},
EarlyAccessDate = {MAY 2025},
Keywords = {Bilevel optimization; DARTS; Machine learning; Stochastic gradient
   descent},
Author-Email = {giovanto@ucmail.uc.edu
   gdk220@lehigh.edu
   lnv@lehigh.edu},
Number-of-Cited-References = {65},
Times-Cited = {2},
Unique-ID = {WOS:001492834600001},
}

@article{ WOS:001488831100003,
Author = {Zito, Francesco and Cutello, Vincenzo and Pavone, Mario},
Title = {Data-driven forecasting and its role in enhanced decision-making},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2025},
Volume = {154},
Month = {AUG 15},
Abstract = {Decision-making is a crucial process for any organization, since it
   involves the selection of the most effective action from a variety of
   options. In this context, data plays an important role in driving
   decisions. Analyzing data allows us to extract patterns that enable
   better decision-making for achieving specific goals. However, to make
   the right decisions to control the behavior of a system, it is necessary
   to take into account different factors, which can be challenging.
   Indeed, in dynamic systems, numerous variables change over time, and
   understanding the future state of these systems can be crucial for
   controlling the system. Predicting future states based on historical
   data is known as time series forecasting, which can be divided into
   univariate and multivariate forecasting, with the latter being
   particularly relevant due to its consideration of multiple variables.
   Deep Learning methods enhance decision-making by identifying patterns in
   complex datasets. As data complexity grows, techniques like Automated
   Machine Learning optimize model performance. The present study
   introduces a novel methodology that integrates multivariate time series
   forecasting into decision-making frameworks. We used Automated-Machine
   Learning to develop a predictive model for forecasting future system
   states, aiding optimal decision-making. The study compares machine
   learning models based on performance metrics and computational cost
   across various domains, including weather monitoring, power consumption,
   hospital electricity monitoring, and exchange rates. We also analyzed
   the importance of the hyperparameters in identifying key factors
   affecting model performance. The obtained results show that Neural
   Architecture Search method can improve state predictor design by
   reducing computational resources and enhancing performance.},
Type = {Article},
Affiliation = {Pavone, M (Corresponding Author), Univ Catania, Dept Math \& Comp Sci, Vle Andrea Doria 6, I-95125 Catania, Italy.
   Zito, Francesco; Cutello, Vincenzo; Pavone, Mario, Univ Catania, Dept Math \& Comp Sci, Vle Andrea Doria 6, I-95125 Catania, Italy.},
DOI = {10.1016/j.engappai.2025.110934},
EarlyAccessDate = {MAY 2025},
Article-Number = {110934},
Keywords = {Multivariate time series forecasting; Automated Machine Learning;
   Decision-making; Neural architecture search; Hyperparameter importance;
   Convolutional Neural Networks; Recurrent Neural Networks; Multilayer
   perceptron},
Keywords-Plus = {MULTIVARIATE TIME-SERIES; NEURAL-NETWORKS; MODEL; PERFORMANCE},
Author-Email = {francesco.zito@phd.unict.it
   cutello@unict.it
   mpavone@dmi.unict.it},
Number-of-Cited-References = {90},
Times-Cited = {2},
Unique-ID = {WOS:001488831100003},
}

@article{ WOS:001488005100001,
Author = {Xue, Chao and Li, Jiaxing and Wang, Xiaoxing and Zhan, Yibing and Yan,
   Junchi and Li, Chun-Guang},
Title = {On neural architecture search and hyperparameter optimization: A
   max-flow based approach},
Journal = {NEURAL NETWORKS},
Year = {2025},
Volume = {188},
Month = {AUG},
Abstract = {Automated Machine Learning (AutoML) involves the automatic production of
   models for specific tasks on given datasets, which can be divided into
   two aspects: Neural Architecture Search (NAS) for model construction and
   Hyperparameter Optimization (HPO) for model training. One of the most
   important components in an AutoML strategy is the search algorithm,
   which aims to recommend effective configurations according to historical
   observations. In this work, we propose a novel max-flow based search
   algorithm for AutoML by representing NAS and HPO as a Max-Flow problem
   on a graph and thus derive a couple of novel AutoML strategies, dubbed
   MF-NAS and MF-HPO, which handle the search space and the search strategy
   graphically. To be specific, MF-NAS induces parallel edges with
   capacities by combining different operations such as skip connections,
   convolutions, and pooling, whereas MF-HPO allows parallel edges to be
   regarded as intervals within the combined search spaces. The learned
   weights and capacities of the parallel edges are alternately updated
   during the search process. To make MF-NAS and MF-HPO more efficient, we
   implement a semi-synchronous search mode for NAS and a warmup scheme for
   HPO, respectively. We conduct extensive experiments to evaluate the
   competitive efficacy and efficiency of our proposed MF-NAS and MF-HPO
   across different datasets and search spaces.},
Type = {Article},
Affiliation = {Xue, C (Corresponding Author), Beijing Univ Posts \& Telecommun, Sch Artificial Intelligence, Beijing, Peoples R China.
   Xue, Chao; Li, Chun-Guang, Beijing Univ Posts \& Telecommun, Sch Artificial Intelligence, Beijing, Peoples R China.
