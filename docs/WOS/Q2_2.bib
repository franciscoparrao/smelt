   ouellette@law.stanford.edu},
Number-of-Cited-References = {210},
Times-Cited = {17},
Unique-ID = {WOS:000612916400018},
}

@article{ WOS:000501935700088,
Author = {Soares, Elton F. de S. and Campos, Carlos Alberto V. and de Lucena,
