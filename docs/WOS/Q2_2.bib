@incollection{ WOS:001593512300140,
Author = {Theodorakopoulos, Daphne and Stahl, Frederic and Lindauer, Marius},
Editor = {Endriss, u and Melo, FS and Bach, K and Bugarin-Diz, A and Alonso-Moral, JM and Barro, S and Heintz, F},
Title = {Hyperparameter Importance Analysis for Multi-Objective AutoML},
Booktitle = {ECAI 2024},
Series = {Frontiers in Artificial Intelligence and Applications},
Year = {2024},
Volume = {392},
Pages = {1100-1107},
Abstract = {Hyperparameter optimization plays a pivotal role in enhancing the
   predictive performance and generalization capabilities of ML models.
   However, in many applications, we do not only care about predictive
   performance but also about additional objectives such as inference time,
   memory, or energy consumption. In such multi-objective scenarios,
   determining the importance of hyperparameters poses a significant
   challenge due to the complex interplay between the conflicting
   objectives. In this paper, we propose the first method for assessing the
   importance of hyperparameters in multi-objective hyperparameter
   optimization. Our approach leverages surrogate-based hyperparameter
   importance measures, i.e., fANOVA and ablation paths, to provide
   insights into the impact of hyperparameters on the optimization
   objectives. Specifically, we compute the a-priori scalarization of the
   objectives and determine the importance of the hyperparameters for
   different objective tradeoffs. Through extensive empirical evaluations
   on diverse benchmark datasets with three different objective pairs, each
   combined with accuracy, namely time, demographic parity loss, and energy
   consumption, we demonstrate the effectiveness and robustness of our
   proposed method. Our findings not only offer valuable guidance for
   hyperparameter tuning in multi-objective optimization tasks but also
   contribute to advancing the understanding of hyperparameter importance
   in complex optimization scenarios.},
Type = {Proceedings Paper},
Affiliation = {Theodorakopoulos, D (Corresponding Author), German Res Ctr Artificial Intelligence DFKI, Marine Percept Res Dept, Kaiserslautern, Germany.
   Theodorakopoulos, D (Corresponding Author), Leibniz Univ Hannover, Inst Artificial Intelligence LUH AI, Hannover, Germany.
   Theodorakopoulos, Daphne; Stahl, Frederic, German Res Ctr Artificial Intelligence DFKI, Marine Percept Res Dept, Kaiserslautern, Germany.
   Theodorakopoulos, Daphne; Lindauer, Marius, Leibniz Univ Hannover, Inst Artificial Intelligence LUH AI, Hannover, Germany.
   Lindauer, Marius, L3S Res Ctr, Hannover, Germany.},
DOI = {10.3233/FAIA240602},
Author-Email = {daphne.theodorakopoulos@dfki.de},
Number-of-Cited-References = {44},
Times-Cited = {1},
Unique-ID = {WOS:001593512300140},
}

@incollection{ WOS:001292831800013,
Author = {Tian, Aojia and Li, Wei and Lai, Pengfei and Ding, Jiangang and Yang,
   Ming and Zhao, Yuanlin and Shan, Yihui},
Book-Group-Author = {IEEE},
Title = {Multi-target Rapid Detection of Road Underground Based on NCG-RetinaNet},
Booktitle = {2024 9TH INTERNATIONAL CONFERENCE ON COMPUTER AND COMMUNICATION SYSTEMS,
   ICCCS 2024},
Year = {2024},
Pages = {73-78},
Abstract = {The successful detection of road underground defects such as voids,
   cavities and pipeline leakages plays a role in preventing road
   collapses. In this study, a ground-penetrating radar detection vehicle
   is utilized to conduct extensive, generalized detection on roads. In
   order to adapt the detection speed and accuracy of the deep learning
   network to the needs of the detecting vehicle, this paper proposes a
   deep learning-based rapid multi-target detection method of road
   underground, named NCG-RetinaNet. First, the CBAM attention mechanism is
   introduced into the RetinaNet feature extraction network to improve the
   feature expression ability. Then, the neural architecture search method
   NAS-FPN is used to enhance the fusion of different scale features and
   improve the model's generalization ability. Finally, the GIoU loss
   function is introduced to calculate the bounding error more accurately
   and improve the detection precision. The results demonstrate that
   compared to the baseline network, the detection performance of
   NCG-RetinaNet has significantly improved, with the mean average
   precision (mAP) @0.5 and mAP@0.5:0.95 increasing by 4.3\% and 5.3\%,
   respectively. After improvements, the FPS of the network is 20.3 frames
   /s, and the average precision reaches 88.7\% when the IoU is 0.5. It
   maintains high detection accuracy while ensuring rapid detection speed,
   meeting the requirements of GPR detection vehicles. Therefore, the
   method presented in this study provides reasonable support for faster
   and more accurate detection of underground voids and pipelines.},
Type = {Proceedings Paper},
Affiliation = {Tian, AJ (Corresponding Author), Changan Univ, Sch Informat Engn, Xian, Shaanxi, Peoples R China.
   Tian, Aojia; Li, Wei; Lai, Pengfei; Ding, Jiangang; Yang, Ming; Zhao, Yuanlin; Shan, Yihui, Changan Univ, Sch Informat Engn, Xian, Shaanxi, Peoples R China.},
DOI = {10.1109/ICCCS61882.2024.10603235},
Keywords = {Underground target detection; Deep learning; Ground penetrating radar;
   RetinaNet},
