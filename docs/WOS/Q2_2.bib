   Rodrigues, Fatima, Interdisciplinary Studies Res Ctr ISRC, Porto, Portugal.},
DOI = {10.1007/s10115-023-02046-7},
EarlyAccessDate = {JAN 2024},
Keywords = {Imbalanced classification; Resampling; Meta-learning; Automated machine
