@incollection{ WOS:000703866100117,
Author = {Polonskaia, Iana S. and Nikitin, Nikolay O. and Revin, Ilia and
   Vychuzhanin, Pavel and Kalyuzhnaya, V, Anna},
Book-Group-Author = {IEEE},
Title = {Multi-Objective Evolutionary Design of Composite Data-Driven Models},
Booktitle = {2021 IEEE CONGRESS ON EVOLUTIONARY COMPUTATION (CEC 2021)},
Series = {IEEE Congress on Evolutionary Computation},
Year = {2021},
Pages = {926-933},
Abstract = {In this paper, a multi-objective approach for the design of composite
   data-driven mathematical models is proposed. It allows automating the
   identification of graph-based heterogeneous pipelines that consist of
   different blocks: machine learning models, data preprocessing blocks,
   etc. The implemented approach is based on a parameter-free genetic
   algorithm (GA) for model design called GPComp@Free. It is developed to
   be part of automated machine learning solutions and to increase the
   efficiency of the modeling pipeline automation. A set of experiments was
   conducted to verify the correctness and efficiency of the proposed
   approach and substantiate the selected solutions. The experimental
   results confirm that a multi-objective approach to the model design
   allows us to achieve better diversity and quality of obtained models.
   The implemented approach is available as a part of the open-source
   AutoML framework FEDOT.},
Type = {Proceedings Paper},
Affiliation = {Polonskaia, IS (Corresponding Author), ITMO Univ, Nat Syst Simulat Lab, St Petersburg, Russia.
   Polonskaia, Iana S.; Nikitin, Nikolay O.; Revin, Ilia; Vychuzhanin, Pavel; Kalyuzhnaya, Anna, V, ITMO Univ, Nat Syst Simulat Lab, St Petersburg, Russia.},
