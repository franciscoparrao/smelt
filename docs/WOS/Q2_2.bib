@incollection{ WOS:000509665700253,
Author = {Huang, Siyu and Li, Xi and Cheng, Zhi-Qi and Zhang, Zhongfei and
   Hauptmann, Alexander},
Book-Group-Author = {ACM},
Title = {GNAS: A Greedy Neural Architecture Search Method for Multi-Attribute
   Learning},
Booktitle = {PROCEEDINGS OF THE 2018 ACM MULTIMEDIA CONFERENCE (MM'18)},
Year = {2018},
Pages = {2049-2057},
Abstract = {A key problem in deep multi-attribute learning is to effectively
   discover the inter-attribute correlation structures. Typically, the
   conventional deep multi-attribute learning approaches follow the
   pipeline of manually designing the network architectures based on
   task-specific expertise prior knowledge and careful network tunings,
   leading to the inflexibility for various complicated scenarios in
   practice. Motivated by addressing this problem, we propose an efficient
   greedy neural architecture search approach (GNAS) to automatically
   discover the optimal tree-like deep architecture for multi-attribute
   learning. In a greedy manner, GNAS divides the optimization of global
   architecture into the optimizations of individual connections step by
   step. By iteratively updating the local architectures, the global
   tree-like architecture gets converged where the bottom layers are shared
   across relevant attributes and the branches in top layers more encode
   attribute-specific features. Experiments on three benchmark
   multi-attribute datasets show the effectiveness and compactness of
   neural architectures derived by GNAS, and also demonstrate the
   efficiency of GNAS in searching neural architectures.},
Type = {Proceedings Paper},
Affiliation = {Li, X (Corresponding Author), Zhejiang Univ, Hangzhou, Peoples R China.
   Huang, Siyu; Li, Xi; Zhang, Zhongfei, Zhejiang Univ, Hangzhou, Peoples R China.
   Cheng, Zhi-Qi, Southwest Jiaotong Univ, Chengdu, Peoples R China.
   Hauptmann, Alexander, Carnegie Mellon Univ, Pittsburgh, PA 15213 USA.},
DOI = {10.1145/3240508.3240588},
Keywords = {multi-task learning; multi-attribute analysis; neural architecture
   search; greedy algorithm},
