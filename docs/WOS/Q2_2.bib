@article{ WOS:001375478500001,
Author = {Sahin, Emrehan Kutlug},
Title = {FastLSM-AutoML: Fast, reliable, and robust end-to-end AutoML tool for
   producing a landslide susceptibility map},
Journal = {STOCHASTIC ENVIRONMENTAL RESEARCH AND RISK ASSESSMENT},
Year = {2025},
Volume = {39},
Number = {10},
Pages = {4801-4825},
Month = {OCT},
Abstract = {Automated Machine Learning (AutoML) is a product of attempts to extend
   artificial intelligence (AI) by automatically deploying machine learning
   (ML) systems with minimal human expertise. The key technical hurdle in
   AutoML is optimizing the pipelines of ML systems, which includes data
   collection, data-preprocessing, feature engineering, model building,
   validation, and other critical elements. Existing ML pipelines and
   AutoML approaches fall short in accelerating interactions between
   pipeline components and in providing domain-specific pipelines. As a
   solution, this work suggests FastLSM-AutoML, a novel AutoML architecture
   that offers a domain-specific ML pipeline to produce landslide
   susceptibility map (LSM) models as fast, reliable, and robust as
   possible. FastLSM-AutoML achieves these objectives by utilizing only two
   types of data, namely elevation and landslide areas, and the system
   autonomously generates landslide causative factors (i.e., slope, aspect,
   curvature, etc.) and non-landslide areas, constructs its training and
   test sets with a ratio of 70:30, and produces ML models (i.e., Random
   Forest and eXtreme Gradient Boosting) with predefined parameters. This
   process eliminates the necessity for continuous iteration over various
   pipeline configurations, and the outcomes are evaluated by multiple
   validation metrics. FastLSM-AutoML is also available as a web
   application on the Shiny platform for testing or trial purposes. To
   demonstrate the power of this AutoML application, FastLSM-AutoML is
   applied to two different study areas (i.e., Babadag and the northern
   part of the Karabuk District, Turkiye). The findings are evaluated using
   various performance metrics, including accuracy (Acc), Kappa, Precision,
   Recall, and F1-Score. Experiments with datasets from two different study
   areas showed that the proposed AutoML approach achieved an Acc of about
   84\% for the XGBoost-12 factor model in the Babadag region, and the
   RF-12 factor model achieved an Acc of about 80\% for the northern part
   of the Karabuk district dataset.},
Type = {Article},
Affiliation = {Sahin, EK (Corresponding Author), Bolu Abant Izzet Baysal Univ, Dept Civil Engn, TR-14030 Bolu, Turkiye.
   Sahin, Emrehan Kutlug, Bolu Abant Izzet Baysal Univ, Dept Civil Engn, TR-14030 Bolu, Turkiye.},
DOI = {10.1007/s00477-024-02855-4},
EarlyAccessDate = {DEC 2024},
Keywords = {AutoML; Landslide susceptibility; Random forest; Extreme gradient
   boosting; Data-preprocessing},
Keywords-Plus = {MACHINE LEARNING-MODEL},
Author-Email = {emrehansahin@ibu.edu.tr},
Number-of-Cited-References = {62},
Times-Cited = {1},
Unique-ID = {WOS:001375478500001},
}

@article{ WOS:001374620800003,
Author = {Sun, Yupeng and Li, Tian},
Title = {A transformer-based framework for enterprise sales forecasting},
Journal = {PEERJ COMPUTER SCIENCE},
Year = {2024},
Volume = {10},
Month = {NOV 21},
Abstract = {Sales forecasting plays an important role in business operations as it
   impacts decisions on inventory management, allocation of resources, and
   financial planning. Accurate sales predictions are essential for
   optimizing cash flow management, adapting marketing and sales
   strategies, and facilitating strategic planning. This study presents a
   computational framework for predicting business sales using
   transformers, which are considered one of the most powerful deep
   learning architectures. The design of our model is specifically tailored
   to accommodate tabular data with low dimensions. The experimental
   results demonstrated that our proposed method surpasses conventional
   machine learning models, achieving reduced mean absolute error (MAE),
   mean square error (MSE), and root mean square error (RMSE), as well as
   higher R2 values of nearly 0.95. The results confirmed that the model is
   applicable not only to this research but also to similar studies that
   use lowdimensional tabular data. The improved accuracy and stability of
   our model demonstrate its potential as a useful tool for enhancing sales
   prediction, therefore facilitating more informed decision-making and
   strategic planning in corporate operations.},
Type = {Article},
Affiliation = {Sun, YP (Corresponding Author), Yunnan Univ Finance \& Econ, Accounting Sch, Kunming, Peoples R China.
