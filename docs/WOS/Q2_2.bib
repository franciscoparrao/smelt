@article{ WOS:001579116300002,
Author = {Bakos, Steve and Davoudi, Heidar},
Title = {Searching for the best student architecture in a knowledge distillation
   framework},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2025},
Volume = {328},
Month = {OCT 25},
Abstract = {Knowledge distillation aims to find a smaller model (i.e., student) that
   can perform at the level of a larger model (i.e., teacher). While the
   student model is highly beneficial in resource-constrained environments,
   finding the optimal student remains challenging due to the extensive
   search required through potential architectures and hyperparameters. To
   address this, we introduce a novel framework that integrates a caching
   mechanism and proximity analysis into Reinforcement Learning (RL) for
   Neural Architecture Search (NAS) and Hyperparameter Optimization (HPO)
   in knowledge distillation. This approach improves computational
   efficiency by avoiding redundant evaluations and estimating the
   performance of similar configurations. Our results, benchmarked against
   foundational and modern evolutionary search methods, demonstrate that
   the proposed framework can reduce full training evaluations by over 75
   \% relative to a standard RL search, offering a robust advantage in
   computationally or operationally constrained environments.},
Type = {Article},
Affiliation = {Bakos, S (Corresponding Author), Ontario Tech Univ, Dept Comp Sci, Oshawa, ON, Canada.
   Bakos, Steve; Davoudi, Heidar, Ontario Tech Univ, Dept Comp Sci, Oshawa, ON, Canada.},
DOI = {10.1016/j.knosys.2025.114210},
EarlyAccessDate = {AUG 2025},
Article-Number = {114210},
Keywords = {Reinforcement learning; Student models; Neural architecture search;
   Automl; Deep learning; Knowledge distillation; Hyperparameter
   optimization},
Author-Email = {steven.bakos@ontariotechu.net
   heidar.davoudi@ontariotechu.ca},
Number-of-Cited-References = {38},
Times-Cited = {0},
Unique-ID = {WOS:001579116300002},
}

@article{ WOS:001551587900006,
Author = {Chen, Jiaxin and Ding, Jinliang and Tan, Kay Chen and Qian, Jiancheng
   and Li, Ke},
Title = {MBL-CPDP: A Multi-Objective Bilevel Method for Cross-Project Defect
   Prediction},
Journal = {IEEE TRANSACTIONS ON SOFTWARE ENGINEERING},
Year = {2025},
Volume = {51},
Number = {8},
Pages = {2305-2328},
Month = {AUG},
Abstract = {Cross-project defect prediction (CPDP) leverages machine learning (ML)
   techniques to proactively identify software defects, especially where
   project-specific data is scarce. However, existing CPDP approaches
   suffer from three critical limitations: ineffective exploration of
   high-dimensional parameter spaces, poor adaptability across diverse
   projects with heterogeneous data distributions, and inadequate handling
   of feature redundancy and distribution discrepancies between source and
   target projects. To address these challenges, we formulate CPDP as a
   multi-objective bilevel optimization (MBLO) method, dubbed MBL-CPDP. Our
   approach comprises two nested problems: the upper-level, a
   multi-objective combinatorial optimization problem, enhances robustness
   by optimizing ML pipelines that integrate feature selection, transfer
   learning, and classification techniques, while the lower-level problem
   fine-tunes their hyperparameters. Unlike traditional methods that employ
   fragmented optimization strategies or single-objective approaches that
   introduce bias, MBL-CPDP provides a holistic, end-to-end optimization
   framework. Additionally, we propose an ensemble learning method to
   better capture cross-project distribution differences and improve
   generalization across diverse datasets. An MBLO algorithm is then
   presented to effectively solve the formulated MBLO problem. To evaluate
   MBL-CPDP's performance, we compare it with five automated ML tools and
   50 CPDP techniques across 20 projects. Extensive empirical results show
   that MBL-CPDP outperforms the comparison methods, demonstrating its
   superior adaptability and comprehensive performance evaluation
   capability.},
Type = {Article},
Affiliation = {Ding, JL (Corresponding Author), Northeastern Univ China, State Key Lab Synthet Automat Proc Ind, Shenyang 110819, Peoples R China.
   Chen, Jiaxin; Ding, Jinliang, Northeastern Univ China, State Key Lab Synthet Automat Proc Ind, Shenyang 110819, Peoples R China.
   Tan, Kay Chen, Hong Kong Polytech Univ, Dept Data Sci \& Artificial Intelligence, Hong Kong, Peoples R China.
   Qian, Jiancheng; Li, Ke, Univ Exeter, Dept Comp Sci, Exeter EX4 4QF, England.
   Li, Ke, Univ Elect Sci \& Technol China, Chengdu 611731, Peoples R China.},
DOI = {10.1109/TSE.2025.3577808},
Keywords = {Optimization; Pipelines; Transfer learning; Predictive models;
   Adaptation models; Feature extraction; Automated machine learning;
   Ensemble learning; Training; Software measurement; Cross-project defect
   prediction; software defect; multi-objective bilevel optimization;
   automated machine learning},
Keywords-Plus = {FEATURE-SELECTION; OPTIMIZATION; STATISTICS; ALGORITHM},
Author-Email = {chenjiaxin1934@gmail.com
   jlding@mail.neu.edu.cn
   kctan@polyu.edu.hk
