Unique-ID = {WOS:001282231900007},
}

@incollection{ WOS:001324524203073,
Author = {Yan, Jiahuan and Chen, Jintai and Wang, Qianxing and Chen, Danny Z. and
   Wu, Jian},
Book-Group-Author = {ASSOC COMPUTING MACHINERY},
Title = {Team up GBDTs and DNNs: Advancing Efficient and Effective Tabular
   Prediction with Tree-hybrid MLPs},
Booktitle = {PROCEEDINGS OF THE 30TH ACM SIGKDD CONFERENCE ON KNOWLEDGE DISCOVERY AND
   DATA MINING, KDD 2024},
Year = {2024},
Pages = {3679-3689},
Abstract = {Tabular datasets play a crucial role in various applications. Thus,
   developing efficient, effective, and widely compatible prediction
   algorithms for tabular data is important. Currently, two prominent model
   types, Gradient Boosted Decision Trees (GBDTs) and Deep Neural Networks
   (DNNs), have demonstrated performance advantages on distinct tabular
   prediction tasks. However, selecting an effective model for a specific
   tabular dataset is challenging, often demanding time-consuming
   hyperparameter tuning. To address this model selection dilemma, this
   paper proposes a newframework that amalgamates the advantages of both
   GBDTs and DNNs, resulting in a DNN algorithm that is as efficient as
   GBDTs and is competitively effective regardless of dataset preferences
   for GBDTs or DNNs. Our idea is rooted in an observation that deep
   learning (DL) offers a larger parameter space that can represent a
   well-performing GBDT model, yet the current back-propagation optimizer
   struggles to efficiently discover such optimal functionality. On the
   other hand, during GBDT development, hard tree pruning, entropy-driven
   feature gate, and model ensemble have proved to be more adaptable to
   tabular data. By combining these key components, we present a
   Tree-hybrid simple MLP (T-MLP). In our framework, a tensorized, rapidly
   trained GBDT feature gate, a DNN architecture pruning approach, as well
   as a vanilla back-propagation optimizer collaboratively train a randomly
   initialized MLP model. Comprehensive experiments show that T-MLP is
   competitive with extensively tuned DNNs and GBDTs in their dominating
   tabular benchmarks (88 datasets) respectively, all achieved with compact
   model storage and significantly reduced training duration. The codes and
   full experiment results are available at
   https://github.com/jyansir/tmlp.},
Type = {Proceedings Paper},
Affiliation = {Chen, JT (Corresponding Author), Univ Illinois, Urbana, IL USA.
   Yan, Jiahuan; Wang, Qianxing; Wu, Jian, Zhejiang Univ, Hangzhou, Peoples R China.
   Chen, Jintai, Univ Illinois, Urbana, IL USA.
   Chen, Danny Z., Univ Notre Dame, Notre Dame, IN USA.},
DOI = {10.1145/3637528.3671964},
Keywords = {classification and regression; tabular data; green AI; AutoML},
Author-Email = {jyansir@zju.edu.cn
   jtchen721@gmail.com
   w.qianxing@zju.edu.cn
   dchen@nd.edu
   wujian2000@zju.edu.cn},
Number-of-Cited-References = {69},
Times-Cited = {3},
Unique-ID = {WOS:001324524203073},
}

@incollection{ WOS:001285850006167,
Author = {Zhu, Hongyu and Liang, Sichu and Hu, Wentao and Li, Fang-Qi and Yuan,
   Yali and Wang, Shi-Lin and Cheng, Guang},
Book-Group-Author = {IEEE},
Title = {IMPROVE DEEP FOREST WITH LEARNABLE LAYERWISE AUGMENTATION POLICY
   SCHEDULES},
Booktitle = {2024 IEEE INTERNATIONAL CONFERENCE ON ACOUSTICS, SPEECH AND SIGNAL
   PROCESSING, ICASSP 2024},
Series = {International Conference on Acoustics Speech and Signal Processing
   ICASSP},
Year = {2024},
Pages = {6660-6664},
Abstract = {As a modern ensemble technique, Deep Forest (DF) employs a cascading
   structure to construct deep models, providing stronger representational
   power compared to traditional decision forests. However, its greedy
   multi-layer learning procedure is prone to overfitting, limiting model
   effectiveness and generalizability. This paper presents AugDF, an
   optimized Deep Forest featuring learnable, layerwise data augmentation
   policy schedules. Specifically, We introduce the Cut Mix for Tabular
   data (CMT) augmentation technique to mitigate overfitting and develop a
   population-based search algorithm to tailor augmentation intensity for
   each layer. Additionally, we propose to incorporate outputs from
   intermediate layers into a checkpoint ensemble for more stable
   performance. Experimental results show that AugDF sets new
   state-of-the-art (SOTA) benchmarks in various tabular classification
   tasks, outperforming shallow tree ensembles, deep forests, deep neural
   network, and AutoML competitors. The learned policies also transfer
   effectively to Deep Forest variants, underscoring its potential for
   enhancing non-differentiable deep learning modules in tabular signal
   processing.},
