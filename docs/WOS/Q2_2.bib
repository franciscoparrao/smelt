   Cordasco, Gennaro; Esposito, Anna, Univ Campania Luigi Vanvitelli \& IIASS, Dipartimento Psicol, I-81100 Caserta, Italy.},
DOI = {10.3390/s22041686},
Article-Number = {1686},
Keywords = {autoML; data augmentation; negative mood states recognition; feature
   extraction; SVM},
Keywords-Plus = {RECOGNITION},
Author-Email = {faundez@tecnocampus.cat
   faundez@tecnocampus.cat
   faundez@tecnocampus.cat
   cvalle@up.edu.mx
   gennaro.cordasco@unicampania.it
   faundez@tecnocampus.cat},
