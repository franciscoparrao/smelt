   Sui, Zi-jian, Liaoning Gongtou Construct Co Ltd, Tieling 112008, Peoples R China.},
DOI = {10.1016/j.cscm.2025.e05243},
EarlyAccessDate = {DEC 2025},
Article-Number = {e05243},
Keywords = {Punching shear strength; Reinforced concrete slabs; Automated machine
   learning; Structural failure prediction; Marine structures},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; MODELS},
