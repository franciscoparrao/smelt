@article{ WOS:001710476600021,
Author = {Hoseini, Sayed and Ibbels, Maximilian and Knoll, Maximilian and Quix,
   Christoph},
Title = {Towards Enhancing Data Science Agents with Semantics},
Journal = {COMPUTER SCIENCE AND INFORMATION SYSTEMS},
Year = {2026},
Volume = {23},
Number = {1},
Month = {JAN},
Abstract = {Data lakes, initially designed for storing heterogeneous datasets, have
   recently been extended with ML capabilities to unify data science tasks
   within a single platform. However, they still lack essential ML-specific
   features, limiting their effectiveness for end-to-end automation.
   Automated Machine Learning (AutoML) and Large Language Models (LLMs)
   offer potential solutions by streamlining various stages of the ML
   pipeline, yet both have significant limitations. This paper presents an
   integration of AutoML frameworks and LLMs within a data lake system. We
   introduce a metadata model to capture data analytics processes, a Python
   package wrapping existing AutoML libraries, and a module utilizing LLMs
   to automate ML tasks. A comparative evaluation indicates that AutoML
   simplifies pipeline creation but limits user control and lacks robust
   data preprocessing support. LLMs can automate individual tasks, such as
   code generation, but struggle to orchestrate complete workflows
   effectively. Both approaches risk staying as basic prototypes that still
   need manual improvement. The primary challenge lies in managing task
   interdependencies within ML pipelines. Retrieval-augmented generation
   enables dynamic access to external information but may overlook
   structured data relationships, leading to incomplete or redundant
   results. Therefore, we propose an extended vision that integrates
   multi-agent frameworks for data science with knowledge graphs that
   capture historical experience from previous ML experiments. We present
   preliminary results for developing comprehensive, context-aware ML
   agents and their integration into our data lake system SEDAR.},
Type = {Article},
Affiliation = {Quix, C (Corresponding Author), Hsch Niederrhein Univ Appl Sci, Krefeld, Germany.
   Quix, C (Corresponding Author), Fraunhofer Inst Appl Informat Technol FIT, St Augustin, Germany.
   Hoseini, Sayed; Ibbels, Maximilian; Knoll, Maximilian; Quix, Christoph, Hsch Niederrhein Univ Appl Sci, Krefeld, Germany.
   Quix, Christoph, Fraunhofer Inst Appl Informat Technol FIT, St Augustin, Germany.},
DOI = {10.2298/CSIS250320078H},
Keywords = {AutoML; LLMs; Semantic Data Lake; MLOps; Data Science Agents},
Author-Email = {sayed.hoseini@hsnr.de
   christoph.quix@fit.fraunhofer.de},
Number-of-Cited-References = {51},
Times-Cited = {0},
Unique-ID = {WOS:001710476600021},
}

@article{ WOS:001652390700001,
Author = {Jin, Yongbo and Yang, Xiaoling},
Title = {A multi-objective optimization approach for VLSI macros placement based
   on NSGA-III},
Journal = {ENGINEERING RESEARCH EXPRESS},
Year = {2026},
Volume = {8},
Number = {1},
Month = {JAN 1},
Abstract = {Macro placement represents a critical determinant of
   power-performance-area (PPA) in digital chip design, yet many current
   placers are still limited by manual parameter tuning and inefficient
   multi-objective optimization. Here, this brief proposes the
   AutoDMP-NSGA-III model, an automated framework integrating NSGA-III and
   AutoML within DREAMPlace to achieve intelligent hyperparameter-driven
   layout optimization. Notably, the model introduces a reference point
   guidance mechanism to balance competing wirelength, congestion, and
   density objectives. This represents the first reported application of
   such a mechanism within the field of digital chip physical design.
   Experimental validation under a 45 nm process demonstrates that,
   compared to the ISPD'23 AutoDMP baseline, our framework delivers
   superior placements without increasing power or area, reducing
   wirelength (WL) by 2\%-4\%; improving total negative slack (TNS) by
   60\%-80\% and worst negative slack (WNS) by 24\%-98\%; and even
   resolving all timing violations in some circuit designs. These results
   suggest a scalable, high-efficiency solution for advanced-node design,
   significantly accelerating the chip design cycle.},
Type = {Article},
Affiliation = {Yang, XL (Corresponding Author), Hubei Univ Technol, Sch Sci, Wuhan 430068, Peoples R China.
   Jin, Yongbo; Yang, Xiaoling, Hubei Univ Technol, Sch Sci, Wuhan 430068, Peoples R China.},
