}

@article{ WOS:001597096900013,
Author = {Al Atiiq, Syafiq and Gehrmann, Christian and Khalil, Karim and Sternby,
   Jakob and Yuan, Yachao},
Title = {Resilient automatic model selection for mobility prediction},
Journal = {CLUSTER COMPUTING-THE JOURNAL OF NETWORKS SOFTWARE TOOLS AND
   APPLICATIONS},
Year = {2025},
Volume = {28},
Number = {16},
Month = {OCT 17},
Abstract = {In order to avoid extensive machine learning models selection and
   optimizations, Automated Machine Learning (AutoML) has arisen as a
   practical and efficient way to apply machine learning to many different
   application areas. Data poisoning is a real threat to the accuracy of
   machine learning models in different settings, and it has in recent
   research studies been shown that the usage of AutoML can be even more
   sensitive to data poisoning than is the case for non-AutoML generated
   models. On the other hand, the usage of AutoML also has the potential of
   improving the robustness of a model by adapting the model to adversarial
   patterns. In this way, good accuracy can be maintained despite the
   attacker's efforts to poison the data. However, no previous studies have
   investigated these effects. In this paper, we examine the risks
   associated with adversarial trajectory attacks in mobile systems,
   specifically looking into mobility prediction problems. By using
   mobility data from two different simulation frameworks: a simulator
   developed by Ericsson, which is based on a real-world deployment of
   Airtel's open-network topology, and the ONE framework, we investigate
   three different AutoML frameworks and how the mobility accuracy for the
   frameworks is affected by a mobile trajectory attack. Our results show
   that re-running AutoML at every retraining is vulnerable to adversarial
   mobility poisoning and shows high accuracy variance. By contrast, using
   a single, well-chosen model from an initial AutoML search achieves more
   stable performance across adversarial conditions, even when the training
   set includes up to 10\% adversarial mobility data.},
Type = {Article},
Affiliation = {Gehrmann, C (Corresponding Author), Lund Univ, Dept Elect \& Informat Technol, Box 118, SE-22100 Lund, Sweden.
   Al Atiiq, Syafiq; Gehrmann, Christian; Khalil, Karim, Lund Univ, Dept Elect \& Informat Technol, Box 118, SE-22100 Lund, Sweden.
   Sternby, Jakob, Ericsson Res, Mobilvagen 12, S-22362 Lund, Sweden.
   Yuan, Yachao, Soochow Univ, Sch Future Sci \& Engn, 1 Jiuyong East Rd, Suzhou 215222, Jiangsu, Peoples R China.},
DOI = {10.1007/s10586-025-05661-x},
Article-Number = {1043},
Keywords = {NWDAF; 5G; Adversarial mobility},
Keywords-Plus = {ATTACKS; MACHINE},
Author-Email = {syafiq\_al.atiiq@eit.lth.se
   christian.gehmrann@eit.lth.se
   karim.khalil@eit.lth.se
   jakob.sternby@ericsson.com
   chao910904@suda.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001597096900013},
}

@article{ WOS:001594364900005,
Author = {Lecheheb, Sabah and Boulehouache, Soufiane and Brahimi, Said},
Title = {Optimized automated analysis using AutoGluon-driven deep learning for
   advancing self-adaptive systems},
Journal = {COMPUTING},
Year = {2025},
Volume = {107},
Number = {11},
Month = {OCT 15},
Abstract = {Commonly, the MAPE-K (Monitor, Analyzer, Planner, and Executor over
   Shared Knowledge) loop serves as the standard foundational framework for
   self-adaptive systems (SASs). The integration of Deep Learning (DL) into
   the Analyzer has significantly enhanced decision-making efficacy.
   However, creating DL models requires considerable expertise and time,
   often with extensive manual supervision. Moreover, in dynamic
   environments, a practical challenge emerges when models face unseen
   data, impeding real-time adaptability. This frequently necessitates
   rebuilding models from scratch to sustain Analyzer performance and
   reliability. In this paper, we explore the use of Automated Machine
   Learning (AutoML) to automate the development and selection of DL models
   for the DeltaIoT SAS dataset. Basically, we use AutoGluon, a
   state-of-the-art open-source framework, to classify our tabular dataset.
   Specifically, we focus on two DL architectures: NeuralNetFastAI (FastAI)
   and NeuralNetTorch (NN\_Torch). To the best of our knowledge, this study
   is the first to apply AutoGluon to the DeltaIoT dataset. Experimental
   evaluations have shown that AutoGluon not only reduces manual
   intervention but also outperforms manually optimized models. The best
   AutoGluon-generated DL model attains an accuracy of up to 94\%, an
   F1-score of 91\%, an MCC of 87\%, and a G-Mean close to 94\%.},
Type = {Article},
Affiliation = {Lecheheb, S (Corresponding Author), Univ 20 Aout 1955, Dept Comp Sci, LICUS Lab, Skikda, Algeria.
   Lecheheb, Sabah; Boulehouache, Soufiane, Univ 20 Aout 1955, Dept Comp Sci, LICUS Lab, Skikda, Algeria.
   Brahimi, Said, Univ 08 Mai 1945, Dept Comp Sci, Guelma, Algeria.
   Brahimi, Said, Univ Constantine 2, LIRE Lab, Constantine, Algeria.},
DOI = {10.1007/s00607-025-01562-4},
Article-Number = {212},
Keywords = {AutoML (automated machine learning); SASs (self-adaptive systems);
   MAPE-K loop; AutoGluon; Analyzer},
Author-Email = {sa.lecheheb@univ-skikda.dz
   s.boulehouache@univ-skikda.dz
   brahimi.said@univ-guelma.dz},
Number-of-Cited-References = {35},
Times-Cited = {0},
Unique-ID = {WOS:001594364900005},
}

@article{ WOS:001602553400001,
Author = {Buribayev, Zholdas and Zhassuzak, Mukhtar and Aouani, Maria and
   Zhangabay, Zhansaya and Abdirazak, Zemfira and Yerkos, Ainur},
Title = {DARTS Meets Ants: A Hybrid Search Strategy for Optimizing KAN-Based 3D
   CNNs for Violence Recognition in Video},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2025},
Volume = {15},
Number = {20},
Month = {OCT 14},
Abstract = {The optimization capabilities of Kolmogorov-Arnold Networks (KANs)
   remain largely unexplored, which has limited their practical use in
   video anomaly recognition compared to conventional 3D-CNNs. To address
   this gap, we introduce a novel hybrid optimization framework that
   combines a Minimax Ant System (MMAS) for hyperparameter selection with a
   modified DARTS strategy for adaptive tuning of the 3D KAN architecture.
   Unlike existing approaches, our method simultaneously optimizes both
   learning dynamics and architectural configurations, enabling KANs to
   better exploit their expressive power in spatiotemporal feature
   extraction. Applied to a three-class video dataset, the proposed
   approach improved model accuracy to 87\%, surpassing the performance of
   a standard 3D-CNN by 6\%.},
Type = {Article},
Affiliation = {Zhassuzak, M (Corresponding Author), Inst Informat \& Computat Technol, Alma Ata 050010, Kazakhstan.
   Buribayev, Zholdas; Zhassuzak, Mukhtar; Abdirazak, Zemfira; Yerkos, Ainur, Inst Informat \& Computat Technol, Alma Ata 050010, Kazakhstan.
   Aouani, Maria; Zhangabay, Zhansaya, Al Farabi Kazakh Natl Univ, Dept Comp Sci, Alma Ata 050040, Kazakhstan.},
DOI = {10.3390/app152011035},
Article-Number = {11035},
Keywords = {3D CNN; Kolmogorov-Arnold Network; neural architecture search; ant
   colony optimization; violence detection; spatiotemporal features},
