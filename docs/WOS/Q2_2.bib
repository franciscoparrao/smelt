DOI = {10.1080/10589759.2025.2577166},
EarlyAccessDate = {OCT 2025},
Keywords = {Aero-engine bearing; fault diagnostics; machine learning; meta-learning;
   AutoML},
Keywords-Plus = {EFFICIENT},
Author-Email = {chenyuliu@nwpu.edu.cn},
Number-of-Cited-References = {41},
