   Engel, Bernard, Purdue Univ, Dept Agr \& Biol Engn, W Lafayette, IN 47907 USA.
   Lim, Kyoung Jae, Kangwon Natl Univ, Dept Reg Infrastructure Engn, Daegu 24341, South Korea.},
DOI = {10.3390/environments12030094},
Article-Number = {94},
Keywords = {alpha factor; baseflow; machine learning; web-based program; SWAT},
