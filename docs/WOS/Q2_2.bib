   Tornede, Alexander; Wever, Marcel; Huellermeier, Eyke, Paderborn Univ, Dept Comp Sci, Warburger Str 100, D-33100 Paderborn, Germany.},
DOI = {10.1007/978-3-030-61527-7\_21},
Keywords = {Extreme algorithm selection; Dyadic ranking; Surrogate model},
Author-Email = {alexander.tornede@uni-paderborn.de
