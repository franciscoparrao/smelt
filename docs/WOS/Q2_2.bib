@article{ WOS:001151492100001,
Author = {Feng, Yining and Li, Shuanming},
Title = {Advancing the Use of Deep Learning in Loss Reserving: A Generalized
   DeepTriangle Approach},
Journal = {RISKS},
Year = {2024},
Volume = {12},
Number = {1},
Month = {JAN},
Abstract = {This paper proposes a generalized deep learning approach for predicting
   claims developments for non-life insurance reserving. The generalized
   approach offers more flexibility and accuracy in solving actuarial
   reserving problems. It predicts claims outstanding weighted by exposure
   instead of loss ratio to remove subjectivity associated with premium
   weighting. Chain-ladder predicted outstanding claims are used as part of
   the multi-task learning to remove the dependence on case estimates.
   Grid-search is introduced for hyperparameter tuning to improve model
   performance. Performance-wise, the Generalized DeepTriangle outperforms
   both traditional chain-ladder methodology, the automated machine
   learning approaches (AutoML), and the original DeepTriangle model.},
