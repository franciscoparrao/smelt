   Enriquez-Zarate, Josue, Univ Autonoma Benito Juarez de Oaxaca, Fac Sistemas Biol Innovac Tecnol, Oaxaca De Juarez, Mexico.
   Enriquez-Zarate, Josue, ICR Ingn Control Ruido SL, Barcelona, Spain.
   Cardenas-Florido, Luis A., Tecnol Nacl Mexico IT Ensenada, Ensenada, Baja California, Mexico.},
DOI = {10.1111/exsy.70024},
