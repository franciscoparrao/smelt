@article{ WOS:001608497000001,
Author = {Xie, Tao and Zhang, Cheng-Cheng and Chen, Zhuo and Wang, Bao-Jun and
   Shi, Bin},
Title = {An automated machine learning approach for near-real-time rockfall
   classification via distributed acoustic sensing along linear
   infrastructure},
Journal = {ENGINEERING GEOLOGY},
Year = {2025},
Volume = {359},
Month = {DEC},
Abstract = {Distributed acoustic sensing (DAS) using fiber-optic cables offers
   continuous seismic monitoring, providing valuable insights into hazards
   like rockfalls that threaten critical infrastructure. However,
   automated, near-realtime classification of extensive DAS datasets
   remains challenging. To address this, we developed a Random Forest
   classifier for accurate, rapid identification of rockfall events from
   DAS signals, effectively distinguishing them from common sources of
   interference. Our comprehensive DAS datasets were collected during field
   experiments at the Ganzhou and Yichun sites along the West-East Gas
   Pipeline, covering five events: rockfall, truck driving, pedestrian
   walking, manual hammering, and ambient noise. The classifier, trained
   and validated using waveform and spectral features from the Ganzhou
   dataset, achieved over 95 \% accuracy, with cross-validation accuracy
   reaching 99.2 \% through hyperparameter optimization. When tested on the
   Yichun site-despite significant environmental and operational
   differences-the model maintained an impressive accuracy of 84 \%. We
   also demonstrated that incorporating a small fraction of the Yichun data
   into the training set rapidly improved accuracy to a level comparable to
   our validation results. These findings highlight the classifier's strong
   transferability and robustness across distinct sites, confirming its
   practical value for near-real-time rockfall monitoring. Ultimately, this
   solution transforms existing distributed fiber networks into
   comprehensive seismic monitoring systems, unlocking their potential to
   enhance the safety and resilience of critical infrastructure.},
Type = {Article},
Affiliation = {Zhang, CC; Shi, B (Corresponding Author), Nanjing Univ, Sch Earth Sci \& Engn, Nanjing 210023, Peoples R China.
   Xie, Tao; Zhang, Cheng-Cheng; Chen, Zhuo; Wang, Bao-Jun; Shi, Bin, Nanjing Univ, Sch Earth Sci \& Engn, Nanjing 210023, Peoples R China.
   Xie, Tao, Hong Kong Polytech Univ, Dept Civil \& Environm Engn, Hong Kong, Peoples R China.},
DOI = {10.1016/j.enggeo.2025.108428},
EarlyAccessDate = {OCT 2025},
Article-Number = {108428},
Keywords = {Rockfall monitoring; Classification; Seismic signal; Machine learning;
   Distributed acoustic sensing (DAS)},
Keywords-Plus = {SEISMIC SIGNALS; HAZARD; LOCATION; FEATURES; HIGHWAY},
Author-Email = {zhang@nju.edu.cn
   shibin@nju.edu.cn},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001608497000001},
}

@article{ WOS:001602622800001,
Author = {Bollineni, Sai Chand},
Title = {Optimized improved ShuffleNet-transfer learning with improved
   normalization for predicting construction cash flow considering project
   complexity},
Journal = {INTERNATIONAL JOURNAL OF MODELING SIMULATION AND SCIENTIFIC COMPUTING},
Year = {2025},
Volume = {16},
Number = {06},
Month = {DEC},
Abstract = {Effective management of project and financial planning depends on
   accurate construction cash flow forecasting. The risks and variables
   unique to each project make it difficult to create an accurate cash flow
   prediction model, even after much research. Sequence-related and
   unrelated variables also have a significant impact on construction cash
   flows. An all-encompassing method to improve the precision of cash flow
   forecasting in building projects is presented in this paper: The
   Improved ShuffleNet with Transfer learning-based Construction Cash flow
   Prediction (IST-CCP) framework. After gathering data from various
   sources, the Double Sigmoid Gaussian Mixture Model Normalization (DSGMN)
   is used for preprocessing in order to standardize the data and lessen
   bias. To keep the prediction model from overfitting, data partitioning
   is used. For forecasting, a Multi-head aided ShuffleNet (M-SNet) model
   that has been improved with transfer learning is employed, utilizing
   previously learned information to improve performance. The Self-enhanced
   Kookaburra Optimization (SE-KO) Algorithm is used for hyperparameter
   optimization in order to further improve accuracy. Because building
   projects are dynamic, the resulting model offers accurate and
   well-calibrated cash flow estimates. This approach is a useful tool for
   managing construction financing and shows notable increases in forecast
   accuracy. The M-SNet model continuously outperformed the conventional
   techniques, achieving the lowest MAE of 0.142, MedAE of 0.138, MSE of
   0.083, MSLE of 0.043, and RMSE of 0.285.},
Type = {Article},
Affiliation = {Bollineni, SC (Corresponding Author), IPS Integrated Project Serv LLC, Dept Construct Management, Cary, NC 27511 USA.
   Bollineni, SC (Corresponding Author), North Carolina State Univ, Dept Civil Construct \& Environm Engn, Raleigh, NC 27606 USA.
   Bollineni, Sai Chand, IPS Integrated Project Serv LLC, Dept Construct Management, Cary, NC 27511 USA.
   Bollineni, Sai Chand, North Carolina State Univ, Dept Civil Construct \& Environm Engn, Raleigh, NC 27606 USA.},
DOI = {10.1142/S1793962325500643},
EarlyAccessDate = {OCT 2025},
Keywords = {Artificial intelligence; construction projects; M-SNet model; ShuffleNet
   model; transfer learning-based construction cash flow prediction},
Keywords-Plus = {GENETIC ALGORITHM},
Author-Email = {Bollinenisai934@gmail.com},
Number-of-Cited-References = {38},
Times-Cited = {0},
Unique-ID = {WOS:001602622800001},
}

@article{ WOS:001599770000001,
Author = {Sylligardos, Emmanouil and Paparrizos, John and Palpanas, Themis and
   Senellart, Pierre and Boniol, Paul},
Title = {MSAD: A deep dive into model selection for time series anomaly detection},
Journal = {VLDB JOURNAL},
Year = {2025},
Volume = {34},
Number = {6},
Month = {OCT 25},
Abstract = {Anomaly detection is a fundamental task for time-series analytics with
   important implications for the downstream performance of many
   applications. Despite increasing academic interest and the large number
   of methods proposed in the literature, recent benchmarks and evaluation
   studies demonstrated that no overall best anomaly detection methods
   exist when applied to very heterogeneous time series datasets.
   Therefore, the only scalable and viable solution to solve anomaly
   detection over very different time series collected from diverse domains
   is to propose a model selection method that will select, based on time
   series characteristics, the best anomaly detection methods to run.
   Existing AutoML solutions are, unfortunately, not directly applicable to
   time series anomaly detection, and no evaluation of time series-based
   approaches for model selection exists. Towards that direction, this
   paper studies the performance of time series classification methods used
   as model selection for anomaly detection. In total, we evaluate 234
   model configurations derived from 16 base classifiers across more than
   1980 time series, and we propose the first extensive experimental
   evaluation of time series classification as model selection for anomaly
   detection. Our results demonstrate that model selection methods
   outperform every single anomaly detection method while being in the same
   order of magnitude regarding execution time. This evaluation is the
   first step to demonstrate the accuracy and efficiency of time series
   classification algorithms for anomaly detection, and represents a strong
   baseline that can then be used to guide the model selection step in
   general AutoML pipelines.},
Type = {Article},
Affiliation = {Sylligardos, E (Corresponding Author), PSL Univ, Inria, CNRS, DI ENS,ENS, Paris, France.
   Sylligardos, Emmanouil; Senellart, Pierre; Boniol, Paul, PSL Univ, Inria, CNRS, DI ENS,ENS, Paris, France.
   Paparrizos, John, Ohio State Univ, Columbus, OH USA.
   Paparrizos, John, Aristotle Univ Thessaloniki, Thessaloniki, Greece.
   Palpanas, Themis, Univ Paris Cite, IUF Paris, Paris, France.},
DOI = {10.1007/s00778-025-00949-1},
Article-Number = {72},
Keywords = {Time series; Anomaly detection; Model selection; Machine learning},
Keywords-Plus = {SUPPORT},
Author-Email = {emmanouil.sylligardos@ens.fr},
Number-of-Cited-References = {101},
Times-Cited = {0},
Unique-ID = {WOS:001599770000001},
}

@article{ WOS:001600531900017,
Author = {Ankalaki, Shilpa},
Title = {Automating wastewater characteristic parameter quantitation using neural
   architecture search in AutoML systems on spectral reflectance data},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {15},
Number = {1},
Month = {OCT 23},
Abstract = {Wastewater (WW) analyses are required to establish optimal operation of
   treatment facilities, and rapid treatment assessment can greatly improve
   operational efficiency. WWTPs function through complex biochemical
   processes that exhibit high variability and are difficult to predict.
   This work presents the first in-depth study towards an original
   application of Auto Machine Learning (AutoML) models to accurately
   predict quality parameters of wastewater. This study aims to demonstrate
   the efficiency of neural network (NN) regression models built by
   applying the Neural Architectural Space (NAS) applying different search
   algorithms such as random search, grid search, Bayesian Optimization,
   and Hyperband search to predict the concentrations of various wastewater
   (WW) parameters such as biochemical oxygen demand (BOD), chemical oxygen
   demand (COD), ammonia (NH3-N), total dissolved solids (TDS), total
   alkalinity (TA), and total hardness (TH). The models are trained on data
   based on WW spectral reflectance data in the visible-near infrared range
   (400-2000 nm). The input variables consisted of spectral reflectance
   intensity of wastewater, while the output variables consisted of levels
   of six wastewater (WW) parameters, namely BOD, COD, NH3-N, TDS, TA, and
   TH. Different search algorithms were employed to identify the neural
   network (NN) architectures that provided single and multiple target
   variable (two to six target variables) predictions to the analysis.
   Experimental results indicate that the NN architecture optimized via
   Bayesian Optimization outperforms others, achieving the lowest mean
   absolute error (MAE) and a high coefficient of determination (R2). For
   single-target predictions on the validation set, the model attained R2
   values of 0.9770 for BOD, 0.9860 for COD, 0.9800 for NH3-N, 0.9776 for
   TDS, 0.9847 for TA, and 0.9639 for TH. For two target predictions on the
   validation set, the model obtained R2 values of 0.988 for BOD and 0.993
   for COD. Similarly R2 for predictions for three target variables are
   0.961 for BOD, 0.962 for COD and 0.946 for NH3-N; for four target
   predictions 0.972 for BOD, 0.970 for COD, 0.955 for NH3-N and 0.972 for
   TDS; for five predictions 0.966 for BOD, 0.966 for COD, 0.951 for NH3-N,
   0.966 for TDS and 0.966 for TA; and for six target predictions 0.987 for
   BOD, 0.99 for COD, 0.982 for NH3-N, 0.99 for TDS, 0.99 for TA and 0.718
   for TH. Bayesian optimization search-based NN predicted the TH value
   with an R2 of 0.718. The Hyperband search NN obtained better results for
   TH prediction during six target predictions i.e. 0.9772 for BOD, 0.976
   for COD, 0.975 for NH3-N, 0.976 for TDS, 0.976 for TA, and 0.899 for TH.
   This work automates the neural network architecture optimization process
   using NAS techniques. These methods systematically explore the
   hyperparameter space, removing the need for manual trial-and-error
   tuning across different datasets and target prediction tasks (both
   single and multi-target). The resulting neural network models are
   further interpreted using the LIME Explainable Artificial Intelligence
   (XAI) method.},
Type = {Article},
Affiliation = {Ankalaki, S (Corresponding Author), Manipal Acad Higher Educ, Manipal Inst Technol Bengaluru, Manipal, India.
   Ankalaki, Shilpa, Manipal Acad Higher Educ, Manipal Inst Technol Bengaluru, Manipal, India.},
DOI = {10.1038/s41598-025-21069-4},
Article-Number = {37130},
Keywords = {AutoML; Neural architecture space; Wastewater; Wastewater treatment
   plant; Neural network regression; Environment sustainability},
Keywords-Plus = {PREDICTIVE CONTROL},
Author-Email = {shilpa.ankalaki@manipal.edu},
Number-of-Cited-References = {50},
Times-Cited = {0},
Unique-ID = {WOS:001600531900017},
}

@article{ WOS:001597763000001,
Author = {Zhang, Hao and Liu, Shunuan and Luo, Bin and Hui, Cheng and Liu, Chenyu},
Title = {A meta-learning-based AutoML method for aero-engine rolling element
   bearing fault diagnostics},
Journal = {NONDESTRUCTIVE TESTING AND EVALUATION},
Year = {2025},
Month = {2025 OCT 23},
Abstract = {Rolling element bearings are crucial in aero-engines, and accurate fault
   diagnostics can avert major aircraft accidents by enabling timely
   detection and maintenance. Machine learning (ML) excels in fault
   diagnosis but requires extensive time for model architecture tuning and
   hyperparameter selection, challenging operational staff and hindering
   implementation. Recently, Automated Machine Learning (AutoML) has
   emerged to tackle hyperparameter optimization in rotating machinery
   diagnostics. Traditional AutoML techniques, such as Bayesian
   optimization, grid search, and random search, automate model selection
   and tuning. Yet, they are underutilized in aero-engine bearing fault
   diagnosis, where research remains limited. To boost automation, this
   study proposes a meta-learning-driven AutoML framework. By incorporating
   health indicators, which reflecting rotating machinery fault states as
   meta-features, the framework precisely recommends optimal architectures
   and hyperparameters, expediting intelligent diagnostic system
   deployment. Experiments on aero-engine bearing faults show this method
   outperforms other ML approaches in classifying health indicators,
   time-domain waveforms, and frequency-domain vibration spectra. It
   exhibits remarkable robustness in noisy conditions and small-sample
   scenarios.},
Type = {Article; Early Access},
Affiliation = {Liu, CY (Corresponding Author), Northwestern Polytech Univ, Sch Mech Engn, Xian, Peoples R China.
   Liu, CY (Corresponding Author), Minist Ind \& Informat Technol, Key Lab Aircraft High Performance Assembly, Xian, Peoples R China.
