   Pravin, Chandresh; De, Suparna, Univ Surrey, Sch Comp Sci \& Elect Engn, Guildford GU2 7XH, England.},
DOI = {10.1109/JIOT.2025.3599235},
Keywords = {Data models; Internet of Things; Predictive models; Computational
   modeling; Message passing; Graph convolutional networks; Transportation;
   Roads; Convolution; Buildings; Explainability; graph neural network
   (GNN); Internet of Things (IoT); NAS and hyperparameter optimization
   (NAS-HPO)},
