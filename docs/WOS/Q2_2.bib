@article{ WOS:000906259300001,
Author = {Tannemaat, M. R. and Kefalas, M. and Geraedts, V. J. and
   Remijn-Nelissen, L. and Verschuuren, A. J. M. and Koch, M. and Kononova,
   V, A. and Wang, H. and Back, T. H. W.},
Title = {Distinguishing normal, neuropathic and myopathic EMG with an automated
   machine learning approach},
Journal = {CLINICAL NEUROPHYSIOLOGY},
Year = {2023},
Volume = {146},
Pages = {49-54},
Month = {FEB},
Abstract = {Objective: Distinguishing normal, neuropathic and myopathic
   electromyography (EMG) traces can be challenging. We aimed to create an
   automated time series classification algorithm. Methods: EMGs of healthy
   controls (HC, n = 25), patients with amyotrophic lateral sclerosis (ALS,
   n = 20) and inclusion body myositis (IBM, n = 20), were retrospectively
   selected based on longitudinal clinical follow-up data (ALS and HC) or
   muscle biopsy (IBM). A machine learning pipeline was applied based on
   5-second EMG fragments of each muscle. Diagnostic yield expressed as
   area under the curve (AUC) of a receiver-operator characteristics curve,
   accuracy, sensitivity, and specificity were determined per muscle
   (muscle-level) and per patient (patient-level). Results: Diagnostic
   yield of the classification ALS vs. HC was: AUC 0.834 +/- 0.014 at
   muscle-level and 0. 856 +/- 0.009 at patient-level. For the
   classification HC vs. IBM, AUC was 0.744 +/- 0.043 at muscle-level and
   0.735 +/- 0.029 at patient-level. For the classification ALS vs. IBM,
   AUC was 0.569 +/- 0.024 at muscle -level and 0.689 +/- 0.035 at
   patient-level.Conclusions: An automated time series classification
   algorithm can distinguish EMGs from healthy indi-viduals from those of
   patients with ALS with a high diagnostic yield. Using longer EMG
   fragments with different levels of muscle activation may improve
   performance. Significance: In the future, machine learning algorithms
   may help improve the diagnostic accuracy of EMG examinations.(c) 2022
   International Federation of Clinical Neurophysiology. Published by
   Elsevier B.V. This is an open access article under the CC BY license
   (http://creativecommons.org/licenses/by/4.0/).},
Type = {Article},
Affiliation = {Tannemaat, MR (Corresponding Author), Leiden Univ, Med Ctr, Dept Neurol, Leiden, Netherlands.
   Tannemaat, M. R.; Geraedts, V. J.; Remijn-Nelissen, L.; Verschuuren, A. J. M., Leiden Univ, Med Ctr, Dept Neurol, Leiden, Netherlands.
   Kefalas, M.; Koch, M.; Kononova, A., V; Wang, H.; Back, T. H. W., Leiden Inst Adv Comp Sci, Leiden, Netherlands.
   Geraedts, V. J., Leiden Univ, Med Ctr, Dept Clin Epidemiol, Leiden, Netherlands.},
DOI = {10.1016/j.clinph.2022.11.019},
EarlyAccessDate = {DEC 2022},
Keywords = {Machine learning; Quantitative EMG; Amyotrophic lateral sclerosis;
   Inclusion body myositis},
Keywords-Plus = {INCLUSION-BODY MYOSITIS; DIAGNOSIS; CLASSIFICATION; CRITERIA; DWT},
Author-Email = {m.r.tannemaat@lumc.nl},
