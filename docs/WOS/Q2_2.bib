DOI = {10.1109/ACCESS.2026.3654275},
Keywords = {Accuracy; Training; Tiny machine learning; Computer architecture; Bayes
   methods; Computational modeling; Optimization; Jacobian matrices;
   Autonomous aerial vehicles; Real-time systems; Bayesian optimization;
   edge AI; hardware-aware neural architecture search; latency-aware deep
   learning; neural architecture search (NAS); proxy based learning;
   real-time inference; tiny machine learning (TinyML); Unmanned Aerial
   Vehicles (UAVs); zero-cost proxies},
Keywords-Plus = {OPTIMIZATION},
Author-Email = {dayananda.p@manipal.edu},
Number-of-Cited-References = {58},
Times-Cited = {0},
