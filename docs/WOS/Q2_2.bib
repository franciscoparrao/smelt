   Hand, David J., Univ London Imperial Coll Sci Technol \& Med, Dept Math, London SW7 2AZ, England.},
DOI = {10.1016/j.ijforecast.2009.09.009},
Keywords = {Calibration; Demand forecasting; Density forecasts; Inventory
   forecasting; Model selection; Prequential principle},
Keywords-Plus = {TIME-SERIES},
Author-Email = {a.brentnall@qmul.ac.uk
