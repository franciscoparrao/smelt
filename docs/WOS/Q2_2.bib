   Bodini, Matteo, Univ Milan, Via Conservatorio 7, I-20122 Milan, Italy.
   Saporetti, Camila M., Univ Estado Rio De Janeiro, BR-22000900 Rio De Janeiro, Brazil.},
DOI = {10.1016/j.fuel.2025.136480},
EarlyAccessDate = {AUG 2025},
Article-Number = {136480},
Keywords = {Lignocellulosic biomass pyrolysis; Automated machine learning (AutoML);
   Bio-oil yield prediction; Predictive modeling; Process optimization},
