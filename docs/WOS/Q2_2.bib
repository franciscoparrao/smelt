   Maitelli, Carla, Univ Fed Rio Grande do Norte, Dept Petr Engn, BR-59078970 Natal, RN, Brazil.},
DOI = {10.3390/s21134546},
Article-Number = {4546},
Keywords = {sucker-rod pumping; machine learning algorithms; dynamometer card;
