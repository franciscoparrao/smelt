   Wilson, Andrew; Wade, Daniel, US Army Aviat \& Missile Res Dev \& Engn Ctr AMRDEC, Redstone Arsenal, AL USA.},
DOI = {10.1109/MLHPC.2018.000-3},
Keywords = {hyperparameter tuning; high performance computing (HPC); genetic
   algorithms; neural architecture search (NAS)},
Number-of-Cited-References = {28},
Times-Cited = {8},
Unique-ID = {WOS:000462382400006},
