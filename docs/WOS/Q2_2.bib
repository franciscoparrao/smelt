   Flexibility},
Keywords-Plus = {BATCH-STORAGE NETWORK; OPTIMAL-DESIGN; PHARMACEUTICAL-INDUSTRY;
   OPTIMIZATION; DEMAND; CASH; TRANSACTIONS; UNCERTAINTY; PORTFOLIO;
