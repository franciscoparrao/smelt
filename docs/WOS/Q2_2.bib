@article{ WOS:001208696700016,
Author = {Poulakis, Yannis and Doulkeridis, Christos and Kyriazis, Dimosthenis},
Title = {A Survey on AutoML Methods and Systems for Clustering},
Journal = {ACM TRANSACTIONS ON KNOWLEDGE DISCOVERY FROM DATA},
Year = {2024},
Volume = {18},
Number = {5},
Month = {JUN},
Abstract = {Automated Machine Learning (AutoML) aims to identify the best-performing
   machine learning algorithm along with its input parameters for a given
   dataset and a specific machine learning task. This is a challenging
   problem, as the process of finding the best model and tuning it for a
   particular problem at hand is both time-consuming for a data scientist
   and computationally expensive. In this survey, we focus on unsupervised
   learning, and we turn our attention on AutoML methods for clustering. We
   present a systematic review that includes many recent research works for
   automated clustering. Furthermore, we provide a taxonomy for the
   classification of existing works, and we perform a qualitative
   comparison. As a result, this survey provides a comprehensive overview
   of the field of AutoML for clustering. Moreover, we identify open
   challenges for future research in this field.},
Type = {Article},
Affiliation = {Poulakis, Y (Corresponding Author), Univ Piraeus, Dept Digital Syst, Karaoli \& Dimitriou Str 80, Piraeus 18534, Greece.
   Poulakis, Yannis; Doulkeridis, Christos; Kyriazis, Dimosthenis, Univ Piraeus, Dept Digital Syst, Karaoli \& Dimitriou Str 80, Piraeus 18534, Greece.},
DOI = {10.1145/3643564},
Article-Number = {120},
Keywords = {Unsupervised learning; clustering; automated machine learning;
   metalearning; algorithm selection; hyperparameter tuning},
Keywords-Plus = {ALGORITHMS; VALIDATION; FRAMEWORK; SELECTION; RANKING; DESIGN},
Author-Email = {gpoul@unipi.gr
   cdoulk@unipi.gr
   dimos@unipi.gr},
