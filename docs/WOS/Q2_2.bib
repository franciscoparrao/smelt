}

@article{ WOS:000730193400005,
Author = {Mahjoubi, Soroush and Barhemat, Rojyar and Guo, Pengwei and Meng, Weina
   and Bao, Yi},
Title = {Prediction and multi-objective optimization of mechanical, economical,
   and environmental properties for strain-hardening cementitious
   composites (SHCC) based on automated machine learning and metaheuristic
   algorithms},
Journal = {JOURNAL OF CLEANER PRODUCTION},
Year = {2021},
Volume = {329},
Month = {DEC 20},
Abstract = {This study develops a framework for property prediction and
   multi-objective optimization of strain-hardening cementitious composites
   (SHCC) based on automated machine learning. Three machine learning
   models are developed to predict the compressive strength, tensile
   strength, and ductility of SHCC. A tree-based pipeline optimization
   method is enhanced and used to enable automatic configuration of machine
   learning models, which are trained using three datasets considering 14
   mix design variables and achieve reasonable prediction accuracy. With
   the predictive models, five objective functions are formulated for
   mechanical properties, life-cycle cost, and carbon footprint of SHCC,
   and the five objective functions are optimized in six design scenarios.
   The objective functions are optimized using innovative optimization and
   decision-making techniques (Unified Non-dominated Sorting Genetic
   Algorithm III and Technique for Order of Preference by Similarity to
   Ideal Solution). This research will promote efficient development and
   applications of high-performance SHCC in concrete and construction
   industry.},
Type = {Article},
Affiliation = {Bao, Y (Corresponding Author), Stevens Inst Technol, Dept Civil Environm \& Ocean Engn, Hoboken, NJ 07030 USA.
   Mahjoubi, Soroush; Barhemat, Rojyar; Guo, Pengwei; Meng, Weina; Bao, Yi, Stevens Inst Technol, Dept Civil Environm \& Ocean Engn, Hoboken, NJ 07030 USA.},
DOI = {10.1016/j.jclepro.2021.129665},
EarlyAccessDate = {NOV 2021},
Article-Number = {129665},
Keywords = {Automated machine learn i n g; Carbon footprint; Evolutionary algorithm;
