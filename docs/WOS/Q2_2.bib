DOI = {10.1109/TETCI.2025.3561629},
EarlyAccessDate = {APR 2025},
Keywords = {Prototypes; Vectors; Pipelines; Genetic algorithms; Computer science;
   Problem-solving; Heuristic algorithms; Binary trees; Space exploration;
   Metaheuristic; optimization; automated algorithm design; automated
   machine learning; evolutionary algorithm; evolutionary algorithm},
Keywords-Plus = {EVOLUTIONARY ALGORITHMS},
