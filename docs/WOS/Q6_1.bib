@article{ WOS:001577765700001,
Author = {Rehman, Sadique and Farooq, Aamir and Shah, Majid Hussain and Kouki,
   Marouan and Shah, Nehad Ali},
Title = {Neural and neuro-fuzzy simulation of mixed convective Carreau blood
   nanofluid flow with magnesium oxide nanoparticles},
Journal = {CASE STUDIES IN THERMAL ENGINEERING},
Year = {2025},
Volume = {75},
Month = {NOV},
Abstract = {In recent years, non-Newtonian nanofluids, particularly Carreau fluids,
   have gained attention in engineering and biomedical applications due to
   their heat transfer characteristics and controllable flow behavior. The
   shear-thinning nature of Carreau nanofluid facilitates modeling of
   complex industrial and biomedical flow phenomena, involving
   non-Newtonian behavior and enhanced thermal transport. This study
   investigates the dispersion of magnesium oxide nanoparticles within a
   blood-based Carreau nanofluid, aiming to enhance thermal conductivity
   and support applications such as targeted drug delivery, bio-thermal
   regulation, and artificial circulatory systems. The governing partial
   differential equations of momentum and energy, describing the flow and
   heat transfer characteristics of the blood-based Carreau nanofluid
   containing magnesium oxide nanoparticles, are formulated based on
   conservation laws. Local similarity transformations reduce these
   equations to nonlinear ordinary differential equations, which are solved
   using a collocation-based boundary value problem approach in Python to
   obtain reference dataset for velocity and temperature profiles. A
   machine learning framework is developed using the Keras sequential
   application programming interface to predict velocity and temperature
   distributions within the nanofluid flow. A neuro-fuzzy inference system
   estimates key engineering quantities, including the Nusselt number and
   skin friction coefficient, providing insights into flow characteristics
   and parameter sensitivity analysis. The findings show excellent
   agreement beproposed hybrid modeling approach. This study presents an
   efficient framework for analyzing and designing advanced bio-thermal
   systems involving non-Newtonian nanofluids.},
Type = {Article},
Affiliation = {Farooq, A (Corresponding Author), Zhejiang Normal Univ, Dept Math, Jinhua 321004, Peoples R China.
   Kouki, M (Corresponding Author), Northern Border Univ, Fac Comp \& Informat Technol, Dept Informat Syst, Rafha, Saudi Arabia.
