   Vibration; Machine learning; Movement; Festination},
Keywords-Plus = {DEEP BRAIN-STIMULATION; VISUAL CUES; PEOPLE; PERFORMANCE; INITIATION;
   LEVODOPA; THERAPY},
Author-Email = {jcantley001@dundee.ac.uk},
