   Dehdouh, Abdesselem, Univ Wyoming, Dept Energy \& Petr Engn, Laramie, WY 82072 USA.},
DOI = {10.3390/eng4030108},
Keywords = {CO2-EOR; solubility; interfacial tension; minimum miscibility pressure;
   machine learning},
Keywords-Plus = {MINIMUM MISCIBILITY PRESSURE; CARBON-DIOXIDE; CRUDE-OIL; SOLUBILITY;
   BEHAVIOR},
Author-Email = {mohamed.99.hamadi@gmail.com
