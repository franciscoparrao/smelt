@article{ WOS:001651979900017,
Author = {Zhang, Zhaoxu and Qian, Lei and Qiu, Yuchen and Shi, Zhenwei and Sun,
   Yuanheng and Xu, Wei},
Title = {An Automated Method for Regional-Scale Agricultural Soil Moisture
   Retrieval Using ISMN Measurements and Sentinel Data in Google Earth
   Engine},
Journal = {IEEE JOURNAL OF SELECTED TOPICS IN APPLIED EARTH OBSERVATIONS AND REMOTE
   SENSING},
Year = {2026},
Volume = {19},
Pages = {1856-1871},
Abstract = {As a critical geophysical parameter governing land-atmosphere
   interactions, soil moisture (SM) plays a pivotal role in regulating
   global water and energy cycles. Despite the proliferation of
   satellite-derived SM products, their utility in precision agriculture
   remains constrained by inherent limitations in spatial resolution and
   cross-regional generalizability. This study presents a novel machine
   learning framework that synergistically integrates multisource earth
   observation data with in-situ measurements from the International Soil
   Moisture Network (ISMN) to address these limitations. Leveraging the
   cloud-based computational capabilities of Google Earth Engine (GEE), we
   developed a high-resolution (60m) SM estimation model through
   systematically synergistic integration of Sentinel-2 multispectral
   reflectance, Sentinel-1 C-band SAR backscatter characteristics (VV, VH
   polarization, incidence angle) and ISMN ground measurements. The
   microwave-canopy interaction mechanisms were quantitatively
   characterized using the Michigan Microwave Canopy Scattering (MIMICS)
   model, informing the selection of optimal predictor variables from
   Sentinel-2 MSI spectral bands (B1-B8A, B9-B12) and SoilGrids texture
   parameters. A streamlined machine learning regression architecture was
   implemented, achieving optimized performance through feature importance
   analysis that identified clay content (32.98\%) and sand content
   (28.25\%) as dominant predictors. Validation across heterogeneous
   agricultural regions demonstrated robust performance (Bias < 0.05
   cm(3)/cm(3)) in low-to-moderate moisture regimes (< 0.36 cm(3)/cm(3)),
   with systematic underestimation observed in saturated conditions. The
   operational pipeline generated monthly composite SM maps for Henan
   Province croplands (April 2018), establishing a transferable paradigm
   for global-scale high-resolution SM monitoring, particularly in
   low-stature crop environments (e.g., winter wheat). This methodology
   advances the synergistic use of microwave-optical-soil property data
   fusion and provides critical insights for extending the framework to
   other vegetation types.},
Type = {Article},
Affiliation = {Zhang, ZX (Corresponding Author), Tiangong Univ, Sch Environm Sci \& Engn, Tianjin 300387, Peoples R China.
   Zhang, ZX (Corresponding Author), 6 Geol Team Shandong Principal Bur Geol \& Mineral, Weihai 264209, Shandong, Peoples R China.
