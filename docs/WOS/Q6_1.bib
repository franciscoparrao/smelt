   Ashraf, Adeela, Univ Hail, Coll Comp Sci \& Engn, Dept Artificial Intelligence, Hail, Saudi Arabia.
   Uddin, Raza, Univ Hail, Coll Comp Sci \& Engn, Dept Comp Sci, Hail, Saudi Arabia.
   Aqib, Jamal, Univ Hail, Coll Comp Sci \& Engn, Dept Software Engn, Hail, Saudi Arabia.},
DOI = {10.1016/j.mlwa.2026.100859},
EarlyAccessDate = {FEB 2026},
Article-Number = {100859},
Keywords = {Lightweight machine learning; Classification; IoV; Smart vehicles; Cyber
   attacks; Intrusion detection},
Keywords-Plus = {INTRUSION DETECTION SYSTEM},
