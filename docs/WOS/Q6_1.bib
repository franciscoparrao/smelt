   Tran, Duy Tan, Univ Transport Ho Chi Minh City, 02 Vo Oanh,Thanh My Tay Ward, Ho Chi Minh City, Vietnam.
   Intui, Sutasinee, Kasetsart Univ, Fac Engn Sriracha, Chon Buri, Thailand.
   Inazumi, Shinya, Shibaura Inst Technol, Coll Engn, Tokyo, Japan.},
DOI = {10.1016/j.rineng.2025.108659},
EarlyAccessDate = {DEC 2025},
Article-Number = {108659},
Keywords = {Failure envelope; Rectangular foundation; Firefly algorithm; Artificial
   neural network; Genetic Programming; FELA},
Keywords-Plus = {UNDRAINED CAPACITY; BEARING CAPACITY; LIMIT ANALYSIS; FINITE-ELEMENTS;
   PREDICTION; STABILITY},
Author-Email = {ksurapar@engr.tu.ac.th},
Number-of-Cited-References = {88},
