@article{ WOS:001567692800001,
Author = {Sahu, Sunil and Anmol, Adarsh and Nishad, Tushar and Jujjavarapu, Satya
   Eswari},
Title = {Unveiling molecular signatures for precision drug design: machine
   learning insights from trypanothione reductase, PKC-θ, and CB1},
Journal = {MOLECULAR DIVERSITY},
Year = {2025},
Month = {2025 SEP 10},
Abstract = {Traditional drug discovery methods like high-throughput screening and
   molecular docking are slow and costly. This study introduces a machine
   learning framework to predict bioactivity (pIC(5)(0)) and identify key
   molecular properties and structural features for targeting Trypanothione
   reductase (TR), Protein kinase C theta (PKC-theta), and Cannabinoid
   receptor 1 (CB1) using data from the ChEMBL database. Molecular
   fingerprints, generated via PaDEL-Descriptor and RDKit, encoded
   structural features as binary vectors. Three models-Random Forest (RF),
   Gradient Boosting (GB), and a stacking ensemble with Ridge
   Regression-predicted pIC(5)(0), with the ensemble achieving the lowest
   RMSE. Results highlight heteroatom-containing rings for TR, multiple
   ring systems for PKC-theta, and aromatic rings for CB1 as critical for
   high bioactivity. This adaptable framework accelerates drug design by
   pinpointing optimizable structures, enhancing efficiency in therapeutic
   development.},
Type = {Article; Early Access},
Affiliation = {Jujjavarapu, SE (Corresponding Author), Natl Inst Technol Raipur, Dept Biotechnol, Raipur 492001, Chhattisgarh, India.
   Sahu, Sunil; Anmol, Adarsh; Nishad, Tushar; Jujjavarapu, Satya Eswari, Natl Inst Technol Raipur, Dept Biotechnol, Raipur 492001, Chhattisgarh, India.},
DOI = {10.1007/s11030-025-11287-3},
EarlyAccessDate = {SEP 2025},
Keywords = {Machine learning; Molecular fingerprints; Protein-drug design;
   Bioactivity prediction; ChEMBL; Structural features},
Keywords-Plus = {MODEL; DOCKING},
Author-Email = {satyaeswarij.bt@nitrr.ac.in},
Number-of-Cited-References = {21},
