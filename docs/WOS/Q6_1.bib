@article{ WOS:001638063100001,
Author = {Zhou, Panpan and Shen, Haoran and Xu, Ning and Zhou, Qianwen and Yan,
   Chengguo and Li, Xinying and Lei, Nuo and Jiang, Jinghua and Song, Dan
   and Zheng, Jiaguang and Zou, Yongjin and Sun, Lixian and Han, Zhongkang
   and Fan, Xiulin and Xiao, Xuezhang and Chen, Lixin},
Title = {Ambient-condition hydrogen storage: Accelerating the development of
   high-capacity hydrides via a quantitative interpretable machine learning
   framework},
Journal = {ENERGY STORAGE MATERIALS},
Year = {2026},
Volume = {84},
Month = {JAN},
Abstract = {The development of metal hydrides is hindered by a lack of robust,
   quantitative design rules, particularly for operation under the mild
   conditions of electrolysis-based hydrogen systems. Here, we pioneered a
   quantifiable explainable machine learning (ML) framework to establish
   descriptor-guided design guidelines for high-capacity AB5-type
   rare-earth hydrides. This approach moves beyond conventional isolated
   perspectives to uncover intricate elemental interactions, which are
   captured by specific criteria including electronegativity limits,
   elemental content boundaries, and the combined descriptor
   (Al+Mn-Ni)-|Fe-Mn|-|Al-Co| <= -4.25. Guided by these findings, the
   customized La0.5Ce0.3Ca0.2Ni4.7Mn0.2Al0.1 alloy was validated with a
   remarkable roomtemperature saturated capacity of 140.2 kg/m3,
   significantly surpassing conventional hydrogen storage mediums (70 MPa
   gaseous hydrogen: 40 kg/m3; Liquid hydrogen: 70 kg/m3). Besides, it can
   achieve hydrogenation saturation under 1.6 MPa (electrolytic hydrogen
   pressure) at room temperature, and demonstrate a reversible efficiency
   of 98.12\% at 60 degrees C. Such outstanding properties can be
   attributed to the multi-element alloying strategy, which enhances
   metal-hydrogen bond strength and activates the hydrogen affinity of
   constituent elements. Thus, this work provides a precise and universal
   design model for high-performance metal hydride design.},
Type = {Article},
Affiliation = {Jiang, JH (Corresponding Author), Hohai Univ, Coll Mat Sci \& Engn, Jiangsu Prov Engn Res Ctr Struct Funct Integrated, Changzhou 213200, Jiangsu, Peoples R China.
