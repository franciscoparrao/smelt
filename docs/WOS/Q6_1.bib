@article{ WOS:000460715300003,
Author = {Cabanas, Rafael and Salmeron, Antonio and Masegosa, Andres R.},
Title = {InferPy: Probabilistic modeling with Tensorflow made easy},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2019},
Volume = {168},
Pages = {25-27},
Month = {MAR 15},
Abstract = {InferPy is a high-level Python API for probabilistic modeling built on
