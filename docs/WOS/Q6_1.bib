   Younus, Hussein A., Fayoum Univ, Fac Sci, Chem Dept, Al Fayyum 63514, Egypt.
   Ni, Wenpeng, Hunan Univ Chongqing, Res Inst, Chongqing 401120, Peoples R China.
   Ni, Wenpeng, Hunan Univ, Greater Bay Area Inst Innovat, Guangzhou 511340, Peoples R China.},
DOI = {10.1021/acssuschemeng.5c12327},
EarlyAccessDate = {MAR 2026},
Keywords = {metal-organic frameworks; bifunctional electrocatalysts; water
   splitting; density functional theory; machine learning},
