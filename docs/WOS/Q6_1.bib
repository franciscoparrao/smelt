   Suri, Jasjit S., Univ Idaho Affl, Dept Elect Engn, Pocatello, ID USA.},
DOI = {10.1016/j.cmpb.2016.02.004},
Keywords = {Coronary artery; IVUS; Carotid IMT; Machine learning; PCA; Risk
