   Tadjer, Sid Ahmed, Univ MHamed Bougara, Fac Hydrocarbon \& Chem, Electrificat Ind Enterprises Lab, Boumerdes 35000, Algeria.},
DOI = {10.3390/en17102340},
Article-Number = {2340},
Keywords = {long short-term memory algorithm; deep learning model; autoencoder
   model; anomaly detection; electrical machine},
Author-Email = {f.lachekhab@univ-boumerdes.dz
   m.benzaoui@univ-boumerdes.dz
