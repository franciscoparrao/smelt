@article{ WOS:001581750600001,
Author = {Singh, Gursharan and Arya, Shailendra Kumar and Suttee, Ashish},
Title = {Artificial Neuro-Fuzzy Inference System-based validation of brightness
   and kappa number using response surface methodology: Integrating machine
   learning for effective delignification of wheat straw-rich soda pulp},
Journal = {BIOCATALYSIS AND BIOTRANSFORMATION},
Year = {2025},
Volume = {43},
Number = {6},
Pages = {595-604},
Month = {NOV 2},
Abstract = {In this study employed ``Response Surface Methodology{''} (RSM) and
   Artificial Neuro-Fuzzy Inference System (ANFIS) models for enhanced
   process optimization. Through RSM modelling established on a central
   composite design (CCD), the optimized biobleaching conditions for wheat
   straw-based soda pulp were determined as laccase activity of similar to
   20 nkat g1 pulp, 2.0 mM, ABTS, and pH 8.0, resulting in a 5.8\% enhance
   in brightness and a 21\% decreased in kappa number (KN) after 4 h at 55
   degrees C. The RSM model demonstrated good predictive performance with
   an R2 value of 0.9340 and RMSE of 0.0583. To validate and complement the
   RSM findings, an ANFIS model was developed using 75\% of the
   experimental data for training and 25\% for testing. Although the ANFIS
   approach offered a flexible machine learning framework by integrating
   fuzzy logic and neural networks, its predictive performance (RMSE:
   2.1053; training error: -0.3530 was comparatively less robust than the
   RSM model. The comparative analysis indicates that while ANFIS provides
   a viable AI-based predictive tool, the RSM model offered superior
   accuracy in optimizing brightness and KN. Thus, this study underscores
   the effectiveness of integrating statistical and machine learning models
   for optimizing biobleaching conditions using bacterial laccases in an
   environmentally sustainable manner. Additionally, MAPE, NSE, and KLE
   criteria were followed for validation according to Bayram and \&
   Ccedil;\& imath;tako \& gbreve;lu (2022) and RSM model has indicated
   better predictive accuracy.},
