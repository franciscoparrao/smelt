}

@article{ WOS:001706749700001,
Author = {Boakye, Dennis and Deng, Chuang},
Title = {Machine-learned accelerated discovery of oxidation-resistant NiCoCrAl
   high-entropy alloys},
Journal = {COMPUTATIONAL MATERIALS SCIENCE},
Year = {2026},
Volume = {267},
Month = {MAR 10},
Abstract = {Designing oxidation-resistant bond coats from high-entropy alloys (HEAs)
   has been a serious concern primarily due to the limited understanding of
   how multiprincipal element interactions govern scale formation at
   extreme temperatures. Moreover, the use of conventional trial-and-error
   approaches is inefficient due to the wide possibilities of element
   combinations, environmental conditions, and other processing variables.
   In this study, a machine learning framework is trained on high-fidelity
   experimental data to predict the parabolic oxidation constant (kp) as a
   measure of oxidation resistance. The model not only achieves
   state-of-the-art precision (R2 = 0.91) but also reveals new oxidation
   trends in NiCoCrAl HEAs. The predictions reveal a clear,
   temperature-dependent transition in oxidation control, with Al-rich
   compositions exhibiting the lowest oxidation rates above 1100 degrees C.
   Compositions containing mixed Al-Cr ratios perform best at intermediate
   temperatures, and Cr-rich, low-Al alloys exhibit superior resistance at
   850 degrees C. The incorporation of Hf and Y led to
   composition-dependent improvements, with Hf-added alloys exhibiting the
   lowest kp. The effectiveness of Y was observed in NiColean alloys, while
   Y-Hf co-doped alloys showed saturated improvements. These results
   provide quantitative guidance for narrowing the compositional space of
   NiCoCrAl and identifying oxidation-resistant bond coats across
   service-relevant temperatures.},
Type = {Article},
Affiliation = {Deng, C (Corresponding Author), Univ Manitoba, Mech Engn, 66 Chancellors Cir, Winnipeg, MB R3T 2N2, Canada.
   Boakye, Dennis; Deng, Chuang, Univ Manitoba, Mech Engn, 66 Chancellors Cir, Winnipeg, MB R3T 2N2, Canada.},
DOI = {10.1016/j.commatsci.2026.114612},
Article-Number = {114612},
Keywords = {Machine learning; Computational modeling; Oxidation; High-entropy alloys},
Keywords-Plus = {THERMAL-BARRIER COATINGS; PHASE-STABILITY; BEHAVIOR; TEMPERATURE;
   MICROSTRUCTURE; ALUMINA; SUPERALLOYS; CREEP; TRANSFORMATION; SEGREGATION},
Author-Email = {chuang.deng@umanitoba.ca},
Number-of-Cited-References = {111},
Times-Cited = {0},
Unique-ID = {WOS:001706749700001},
}

@article{ WOS:001708808600001,
Author = {Le, Dang-Huy and Zhu, Yujie and Zhang, Tianmeng and Li, Wenyi and Hung,
   Andrew and Houshyar, Shadi and Le, Tu C.},
Title = {A Dual-Model Machine Learning Framework for Interpretable Design and
   Ensemble Prediction of C-Amidated Antimicrobial Peptides},
Journal = {ACS APPLIED MATERIALS \& INTERFACES},
Year = {2026},
Volume = {18},
Number = {10},
Pages = {14739-14754},
Month = {MAR 18},
Abstract = {Antimicrobial peptides (AMPs) offer promising alternatives to
   conventional antibiotics, yet most predictive models fail to account for
   chemical modifications that influence real-world efficacy. Among these,
   C-terminal amidation is a widely adopted and effective strategy that
   improves structural stability, membrane interaction, and protease
   resistance. In this study, we established an integrated framework for
   the design and prediction of C-terminal amidated AMPs targeting
   Escherichia coli. Our approach combined a design-oriented model based on
   an interpretable Explainable Boosting Machine (EBM), which extracts
   actionable sequence-level design rules, together with a reliable
   deployment model, built on a fine-tuned ESM2 deep learning architecture.
   The resulting tool, CAmidPred, enables both predictive classification
   and amino acid pattern analysis with outputs examined in relation to
   published alanine-scanning experiments. Using these models, we
   identified a pardaxin variant with improved activity against E. coli,
   demonstrating the practical utility of the dual-model framework in
   targeted AMP design.},
Type = {Article},
Affiliation = {Le, TC (Corresponding Author), RMIT Univ, STEM Coll, Sch Engn, Melbourne, Vic 3000, Australia.
   Le, Dang-Huy; Houshyar, Shadi; Le, Tu C., RMIT Univ, STEM Coll, Sch Engn, Melbourne, Vic 3000, Australia.
   Zhu, Yujie; Zhang, Tianmeng; Li, Wenyi, La Trobe Univ, La Trobe Inst Mol Sci, Dept Biochem \& Chem, Melbourne, Vic 3083, Australia.
