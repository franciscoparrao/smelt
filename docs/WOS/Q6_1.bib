Booktitle = {2ND INTERNATIONAL CONFERENCE ON SIMULATION AND MODELING METHODOLOGIES,
   TECHNOLOGIES AND APPLICATIONS (SMTA 2015)},
Year = {2015},
Pages = {90-93},
Abstract = {At the present, the principle between the key assembly parameters and
   performance of complex mechanical systems is not clear. In consideration
   of the situation that a large number of assembly process data has been
   stored in the manufacturing information system. Data Mining Technology
   (DM) is proposed to find the knowledge that may be hidden in the
   assembly data. Python is used as the data mining engine and its machine
   learning library Mlpy is used as algorithms library. By analyzing the
   actual assembly problems of servo mechanism, experimental data mining is
   designed and implemented by using PLS, K-means and SVM algorithms.},
