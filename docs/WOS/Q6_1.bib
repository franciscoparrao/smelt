DOI = {10.3390/brainsci14090871},
Article-Number = {871},
Keywords = {alpha-synucleinopathy; biomarker; iRBD; phenoconversion; PSG; REM sleep},
Keywords-Plus = {NEURODEGENERATION; EEG; PARKINSONS; SEVERITY},
Author-Email = {ambra.stefani@i-med.ac.at},
Number-of-Cited-References = {54},
Times-Cited = {9},
Unique-ID = {WOS:001323691400001},
}

@article{ WOS:001450637200008,
Author = {Stavrogiannis, Christos and Tsioulos, Vasilis and Sofos, Filippos},
Title = {A hybrid molecular dynamics/machine learning framework to calculate the
   viscosity and thermal conductivity of Ar, Kr, Xe, O, and Ν},
Journal = {APPLIED RESEARCH},
Year = {2024},
Volume = {3},
Number = {4},
Month = {AUG},
Abstract = {In this paper, molecular dynamics (MD) simulations and machine learning
   (ML) methods are combined to obtain the transport properties, such as
   viscosity and thermal conductivity, of five basic elements, which are
   computationally hard to obtain at the nanoscale and extremely demanding
   to estimate accurately through an experimental procedure. Starting from
   an experimental database from literature sources, we extend the (P-T)
   space on which the transport properties are calculated by employing MD
   simulations and ML predictions, in a synergistic mode. Results refer to
   all fluid states (gas, liquid, supercritical), under ambient and
   supercritical conditions, suggesting an alternative path that can be
   accurately followed to bypass expensive experiments and costly numerical
   simulations. Nine different ML algorithms are exploited and assessed on
   their prediction ability, with tree-based architectures achieving
   increased accuracy on the implied data set. The proposed computational
   platform runs fast in a common python Jupyter environment, both for MD
   and ML, and can be adjusted and extended for the calculation of material
   properties both in interpolation and extrapolation applications.},
Type = {Article},
Affiliation = {Sofos, F (Corresponding Author), Univ Thessaly, Dept Phys, Condensed Matter Phys Lab, Lamia 35100, Greece.
   Stavrogiannis, Christos; Tsioulos, Vasilis; Sofos, Filippos, Univ Thessaly, Dept Phys, Condensed Matter Phys Lab, Lamia 35100, Greece.},
DOI = {10.1002/appl.202300127},
Article-Number = {e202300127},
Keywords = {fluids; machine learning; molecular dynamics; transport properties},
Keywords-Plus = {SUPPORT VECTOR REGRESSION; ARTIFICIAL NEURAL-NETWORK;
   IRREVERSIBLE-PROCESSES; PREDICTION},
Author-Email = {fsofos@uth.gr},
Number-of-Cited-References = {53},
Times-Cited = {2},
Unique-ID = {WOS:001450637200008},
}

