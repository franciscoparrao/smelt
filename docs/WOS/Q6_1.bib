@incollection{ WOS:000790782500055,
Author = {Haryono, Stefanus A. and Thung, Ferdian and Lo, David and Lawall, Julia
   and Jiang, Lingxiao},
Book-Group-Author = {IEEE Comp Soc},
Title = {MLCatchUp: Automated Update of Deprecated Machine-Learning APIs in
   Python},
Booktitle = {2021 IEEE INTERNATIONAL CONFERENCE ON SOFTWARE MAINTENANCE AND EVOLUTION
   (ICSME 2021)},
Series = {Proceedings-IEEE International Conference on Software Maintenance},
Year = {2021},
Pages = {584-588},
Abstract = {Machine learning (ML) libraries are gaining vast popularity, especially
   in the Python programming language. Using the latest version of such
   libraries is recommended to ensure the best performance and security.
   When migrating to the latest version of a machine learning library,
   usages of deprecated APIs need to be updated, which is a time-consuming
   process. In this paper, we propose MLCatchUp, an automated API usage
   update tool for deprecated APIs of popular ML libraries written in
   Python. MLCatchUp automatically infers the required transformation to
   migrate usages of deprecated API through the differences between the
   deprecated and updated API signatures. MLCatchUp offers a readable
   transformation rule in the form of a domain specific language (DSL). We
   evaluate MLCatchUp using a dataset of 267 real-world Python code
   containing 551 usages of 68 distinct deprecated APIs, where MLCatchUp
   achieves 90.7\% accuracy. A video demonstration of MLCatchUp is
   available at https://youtu.be/5NjOPNt5iaA.},
Type = {Proceedings Paper},
Affiliation = {Haryono, SA (Corresponding Author), Singapore Management Univ, Sch Informat Syst, Singapore, Singapore.
   Haryono, Stefanus A.; Thung, Ferdian; Lo, David; Jiang, Lingxiao, Singapore Management Univ, Sch Informat Syst, Singapore, Singapore.
   Lawall, Julia, INRIA, Le Chesnay Rocquencourt, France.},
DOI = {10.1109/ICSME52107.2021.00061},
Keywords = {Python; Program Transformation; Automatic Update; Deprecated API},
Author-Email = {stefanusah@smu.edu.sg
