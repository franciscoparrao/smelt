   Ullah, Waqar, RAK Res \& Innovat Ctr, Rak, U Arab Emirates.},
DOI = {10.1007/978-3-031-68639-9\_25},
Keywords = {Outdoor comfort system; temperature prediction; humidity prediction;
   Random Forest; Neural Network; SVM; data analysis; Machine Learning; IoT},
Keywords-Plus = {THERMAL COMFORT; MODEL},
Author-Email = {Maher.alndiwee@stri.ac.uk},
Number-of-Cited-References = {22},
