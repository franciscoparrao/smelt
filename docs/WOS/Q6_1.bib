@article{ WOS:001701707200001,
Author = {Li, Yang and You, Yang and Sun, Lele and Wang, Peijun},
Title = {Text-model generation-machine learning framework and performance of
   three-sided protection steel beam temperature model},
Journal = {KSCE JOURNAL OF CIVIL ENGINEERING},
Year = {2026},
Volume = {30},
Number = {4},
Month = {APR},
Abstract = {The three-sided protection steel beam is commonly used in offshore and
   onshore oil and gas processing facilities. The top surface of the upper
   flange is exposed, causing a rapid temperature decrease in the vertical
   direction, influenced by section depth, insulation thickness, and
   conductivities. Deriving an equation to encompass these factors is
   analytically challenging. A machine learning model with fast prediction
   is a viable approach, despite the labour-intensive modelling and
   database training processes. To address this, a machine learning-based
   prediction programme connects parameter inputs, modelling, simulation,
   and data extraction using Python, ABAQUS, and MATLAB. A model generation
   agent embedded with a 2D contact detection algorithm is produced to
   establish the beam heat transfer models. For performing the large-scale
   simulation, an interruptible MATLAB terminal is adopted to control the
   sequence. Results are processed through a data pipeline and trained with
   Gradient Boosting and Deep Neural Network (DNN). In addition, a
   data-batch generator is designed to reduce memory usage and enable
   training on a single GPU. The database comprises 414 models of IPE
   sections, Universal Beam sections, and 63 welded sections, with depths
   ranging from 127 to 1500 mm. 400 degrees C and 538 degrees C steel limit
   temperatures are considered for the insulation configuration. Results
   show a root mean squared error of 1.34 degrees C between the test and
   prediction results, with gradient boosting prevailing for regression
   problems under similar training times. The test calculation time
   reflects high computational efficiency, with 83.3 \% of predictions
   completed within 60 s.},
Type = {Article},
Affiliation = {Li, Y (Corresponding Author), Univ Manchester, Fac Sci \& Engn, Booth St E, Manchester M13, England.
   Li, Yang, Univ Manchester, Fac Sci \& Engn, Booth St E, Manchester M13, England.
   You, Yang, Shandong Jiaotong Univ, Sch Transportat \& Civil Engn, Haitang Rd, Jinan 250357, Peoples R China.
   Sun, Lele, Harbin Engn Univ, Yantai Res Inst, Qingdao St, Yantai 264000, Peoples R China.
   Wang, Peijun, Shandong Univ, Sch Civil Engn, Jingshi Rd, Jinan 250061, Peoples R China.},
DOI = {10.1016/j.kscej.2025.100467},
EarlyAccessDate = {FEB 2026},
Article-Number = {100467},
Keywords = {Automated modelling; Machine learning; ABAQUS kernel scripting method;
   Fire protection; Three-sided protection steel beam},
Keywords-Plus = {FIRE},
Author-Email = {yang.li-5@manchester.ac.uk},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001701707200001},
}

@article{ WOS:001719788700011,
Author = {Mekki, Kawther and Ghezaiel, Nadia and Ben Slimene, Marwa and Neffati,
   Syrine and Rmili, Hatem and Gharsallah, Ali},
Title = {Edge machine learning over IoT for chipless RFID environmental sensing
   in smart agriculture},
Journal = {SCIENTIFIC REPORTS},
Year = {2026},
Volume = {16},
Number = {1},
Month = {FEB 18},
Abstract = {Chipless Radio Frequency Identification (RFID) has emerged as a
   promising technology for battery-free and maintenance-free sensing in
   Internet of Things (IoT) applications, particularly in smart agriculture
   where large-scale deployment and long-term autonomy are essential.
   However, practical agricultural sensing requires more than isolated tag
   or sensor designs; it demands an integrated system that jointly supports
   high-capacity identification, reliable multi-parameter environmental
   monitoring, and robust data interpretation within realistic
   radio-frequency (RF) environments. This work presents an IoT-ready
   chipless RFID framework that unifies resonator-based tag design,
   functional sensing materials, and physics-guided machine learning within
   a coherent hardware-analytics architecture. A compact 24-bit chipless
   RFID identification tag based on T-shaped resonators is designed within
   a 60 \& times; 40 mm(2) footprint, achieving dense encoding with
   approximately 100 MHz spectral spacing. The tag is validated through
   full-wave CST simulations and anechoic-chamber radar cross-section (RCS)
   measurements, demonstrating high-Q, well-isolated spectral notches.
   Building on this platform, a 12-resonator sensing variant is developed
   for dual-parameter microclimate monitoring, exploiting the
   temperature-sensitive permittivity of Taconic RF-35 and the humidity
   responsiveness of a Kapton HN/PVA bilayer, with approximately 160 MHz
   reserved per sensing slot to prevent spectral overlap. To enable
   reliable operation under deployment-realistic interference, a
   physics-driven, edge-deployable machine learning framework is
   introduced, operating on interpretable RCS features rather than raw
   spectra. A hybrid ensemble combining Random Forest, Support Vector
   Regression, and XGBoost models are developed and augmented with
   k-means-based anomaly detection. This framework achieves 96.2\%
   temperature-bin classification accuracy, with mean errors of +/- 1.3
   degrees C for temperature and +/- 2.1\% for relative humidity under
   frequency jitter, attenuation, and multipath distortions. The proposed
   co-design demonstrates a scalable, interpretable, and energy-autonomous
   solution for precision agriculture. It is compatible with edge gateways
   and cloud or serverless IoT infrastructures.},
Type = {Article},
Affiliation = {Rmili, H (Corresponding Author), Univ Tunis El Manar UTM, Natl Engn Sch Tunis ENIT, Commun Syst Lab SysCom, Tunis, Tunisia.
   Mekki, Kawther; Ben Slimene, Marwa; Neffati, Syrine, Univ Hail, Coll Comp Sci \& Engn, Dept Comp Engn, Hail 2440, Saudi Arabia.
   Ghezaiel, Nadia, Univ Hail, Coll Comp Sci, Dept Software Engn, Hail 2440, Saudi Arabia.
   Rmili, Hatem, Univ Tunis El Manar UTM, Natl Engn Sch Tunis ENIT, Commun Syst Lab SysCom, Tunis, Tunisia.
   Gharsallah, Ali, Univ Tunis El Manar, Fac Sci, Phys Dept, Lab Res Microwave Elect, Tunis 2092, Tunisia.},
DOI = {10.1038/s41598-026-38742-x},
Article-Number = {9512},
Keywords = {Chipless RFID; Smart agriculture; Internet of Things (IoT); Machine
   learning (ML); Edge computing; Digital twin; Energy-autonomous sensing;
   Environmental monitoring},
Keywords-Plus = {TAG; SYSTEM},
Author-Email = {hatem.rmili@yahoo.fr},
Number-of-Cited-References = {57},
Times-Cited = {0},
Unique-ID = {WOS:001719788700011},
}

@article{ WOS:001700047300001,
Author = {Engelsberger, Alexander and Psenickova, Magdalena and Villmann, Thomas},
Title = {Prototype-Based Classifiers and Vector Quantization on a Quantum
   Computer-Implementing Integer Arithmetic Oracles for Nearest Prototype
   Search},
Journal = {ENTROPY},
Year = {2026},
Volume = {28},
Number = {2},
Month = {FEB 16},
Abstract = {The superposition principle in quantum mechanics enables the encoding of
   an entire solution space within a single quantum state. By employing
   quantum routines such as amplitude amplification or the Quantum
   Approximate Optimization Algorithm (QAOA), this solution space can be
   explored in a computationally efficient manner to identify optimal or
   near-optimal solutions. In this article, we propose quantum circuits
   that operate on binary data representations to address a central task in
   prototype-based classification and representation learning, namely the
   so-called winner determination, which realizes the nearest prototype
   principle. We investigate quantum search algorithms to identify the
   closest prototype during prediction, as well as quantum optimization
   schemes for prototype selection in the training phase. For these
   algorithms, we design oracles based on arithmetic circuits that leverage
   quantum parallelism to apply mathematical operations simultaneously to
   multiple inputs. Furthermore, we introduce an oracle for prototype
   selection, integrated into a learning routine, which obviates the need
   for formulating the task as a binary optimization problem and thereby
   reduces the number of required auxiliary variables. All proposed oracles
   are implemented using the Python 3-based quantum machine learning
   framework PennyLane and empirically validated on synthetic benchmark
   datasets.},
Type = {Article},
Affiliation = {Villmann, T (Corresponding Author), Univ Appl Sci Mittweida, Saxon Inst Computat Intelligence \& Machine Learnin, D-09648 Mittweida, Germany.
   Villmann, T (Corresponding Author), Tech Univ Bergakad Freiberg, Fac Math \& Comp Sci, D-09599 Freiberg, Germany.
   Engelsberger, Alexander; Psenickova, Magdalena; Villmann, Thomas, Univ Appl Sci Mittweida, Saxon Inst Computat Intelligence \& Machine Learnin, D-09648 Mittweida, Germany.
   Engelsberger, Alexander, Univ Groningen, Bernoulli Inst Math Comp Sci \& Artificial Intellig, NL-9712 CP Groningen, Netherlands.
   Villmann, Thomas, Tech Univ Bergakad Freiberg, Fac Math \& Comp Sci, D-09599 Freiberg, Germany.},
DOI = {10.3390/e28020229},
Article-Number = {229},
Keywords = {vector quantization; quantum machine learning; prototype-based learning},
Author-Email = {eardev@proton.me
   villmann@hs-mittweida.de},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001700047300001},
}

@article{ WOS:001689874600001,
Author = {Li, Shu-Wen and Chen, Shan and Oliveira, Joao C. A. and Zhang, Shuo-Qing
   and Ackermann, Lutz and Hong, Xin},
Title = {Staged Diversity-Constrained Machine Learning for High-Dimensional
   Reaction Condition Optimization},
Journal = {ANGEWANDTE CHEMIE-INTERNATIONAL EDITION},
Year = {2026},
Month = {2026 FEB 15},
Abstract = {Optimizing reaction conditions in high-dimensional chemical spaces
   remains a central challenge in modern synthesis. In this context, we
   developed and evaluated a staged diversity-constrained machine learning
   framework that efficiently balances exploration and exploitation during
   condition optimization. At each stage, a within-batch diversity
   constraint promotes broad chemical coverage, while the constraint is
   progressively relaxed to focus on promising subspaces. Systematic
   evaluation across large-scale palladium-catalyzed C \& horbar;C and C \&
   horbar;N coupling datasets revealed that the number of stages, rather
   than the exploration portion, was the dominant factor governing
   optimization efficiency. A comparison with Bayesian optimization (BO)
   methods shows a dimension-dependent performance trend. Here, the staged
   diversity-constrained strategy was shown to be more advantageous in
   higher-dimensional reaction spaces, whereas BO performed better in
   lower-dimensional settings. Moreover, we developed a user-friendly
   software tool making the herein developed framework readily accessible
   for experimental chemists. Our strategy was further applied to
   challenging ruthenium-catalyzed meta-C \& horbar;H functionalization
   involving 11,880 possible conditions, only 44 experiments were required
   to identify the optimal setup (91\% yield). This work provides a
   validated and practical framework for accelerating high-dimensional
   reaction condition optimization, bridging data-driven modeling with
   experimental synthesis.},
