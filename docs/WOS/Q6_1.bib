Unique-ID = {WOS:001608948300001},
}

@article{ WOS:001607425000003,
Author = {Wang, Meilin and Ma, Hang and Zheng, Xing and Zhang, Yi and Li, Chunze
   and Shen, Pengyuan},
Title = {Multi-objective optimization of urban block morphology for thermal
   comfort and air quality: An integrated CFD-machine learning framework},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2025},
Volume = {134},
Month = {NOV 15},
Abstract = {Urban block morphology can influence thermal comfort and air quality,
   yet existing studies have focused on single environmental objectives.
   This study develops an integrated optimization framework simultaneously
   addressing thermal environment and PM2.5 concentration through a novel
   two-way coupled numerical model. Key block morphological parameters,
   including building length, width, height, spacing, and orientation, are
   used to establish a parametric geometric model of idealized residential
   blocks. The methodology further integrates physics-driven computational
   fluid dynamics simulation results to data-driven response surface
   modeling and multi-objective genetic algorithms. The proposed two-way
   coupled model captures interactions between thermal environment and
   particulate matter dispersion. Latin Hypercube Sampling is adopted to
   generates 200 morphology samples for CFD simulations. The trained
   response surface models linking morphology parameters to Universal
   Thermal Climate Index (UTCI) and AQIPM2.5 achieve 95 \% accuracy (R2 =
   0.98-0.99), enabling efficient optimization. Multi-objective
   optimization reveals trade-offs between thermal comfort and air quality,
   yielding Pareto-optimal solutions with distinct parameter ranges for
   different floor area ratios. It is found that building orientation
   within 15 degrees of prevailing winds optimizes both objectives, while
   longitudinal spacing exhibits the strongest influence (correlation +/-
   0.81). Optimal height-to-width ratios range from 0.7-1.0 for low-density
   to 1.3-1.6 for high-density developments. Case study validation and
   application of optmization strategy in Shenzhen achieves air temperature
   reductions up to 2.09 degrees C while maintaining regulatory compliance.
   The framework provides evidence-based design guidelines for hot-humid
   climates, offering urban planners practical tools for creating healthier
   residential environments while balancing development viability and
   environmental performance.},
Type = {Article},
Affiliation = {Shen, PY (Corresponding Author), Tsinghua Univ, Shenzhen Int Grad Sch, Shenzhen 518055, Peoples R China.
   Zhang, Yi; Li, Chunze; Shen, Pengyuan, Tsinghua Univ, Shenzhen Int Grad Sch, Shenzhen 518055, Peoples R China.
   Wang, Meilin; Ma, Hang, Harbin Inst Technol, Shenzhen 518055, Peoples R China.
   Zheng, Xing, City Univ Hong Kong, Dept Architecture \& Civil Engn, Kowloon, Hong Kong, Peoples R China.},
DOI = {10.1016/j.scs.2025.106921},
EarlyAccessDate = {OCT 2025},
Article-Number = {106921},
Keywords = {Urban morphology; Thermal environment; Air quality; Multi-objective
   optimization; Computational fluid dynamics},
Keywords-Plus = {POLLUTANT DISPERSION; BUILDING ENERGY; FLOW CHARACTERISTICS; STREET
   CANYONS; CLIMATE-CHANGE; HUMAN HEALTH; HOT-SUMMER; SIMULATION; GEOMETRY;
   IMPACTS},
Author-Email = {pengyuan\_pub@163.com},
Number-of-Cited-References = {76},
Times-Cited = {2},
