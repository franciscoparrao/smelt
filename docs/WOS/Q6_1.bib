Article-Number = {106875},
Keywords = {Early warning of fire-induced collapse; Real-time monitoring; Key
   monitoring physical parameters; Machine learning},
Keywords-Plus = {STEEL PORTAL FRAMES; NEURAL-NETWORKS; STRUCTURAL BEHAVIOR; SUBJECT},
Author-Email = {zhushaojun@tongji.edu.cn},
