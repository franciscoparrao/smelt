@article{ WOS:001031359600025,
Author = {Desdoigts, Louis and Pope, Benjamin J. S. and Dennis, Jordan and
   Tuthill, Peter G.},
Title = {Differentiable optics with partial derivativeLux: I-deep calibration of
   flat field and phase retrieval with automatic differentiation},
Journal = {JOURNAL OF ASTRONOMICAL TELESCOPES INSTRUMENTS AND SYSTEMS},
Year = {2023},
Volume = {9},
Number = {2},
Month = {APR 1},
Abstract = {The sensitivity limits of space telescopes are imposed by uncalibrated
   errors in the point spread function, photon-noise, background light, and
   detector sensitivity. These are typically calibrated with specialized
   wavefront sensor hardware and with flat fields obtained on the ground or
   with calibration sources, but these leave vulnerabilities to residual
   time-varying or non-common path aberrations and variations in the
   detector conditions. It is, therefore, desirable to infer these from
   science data alone, facing the prohibitively high dimensional problems
   of phase retrieval and pixel-level calibration. We introduce a new
   Python package for physical optics simulation, partial derivative Lux,
   which uses the machine learning framework JAX to achieve graphics
   processing unit acceleration and automatic differentiation (autodiff),
   and apply this to simulating astronomical imaging. In this first of a
   series of papers, we show that gradient descent enabled by autodiff can
   be used to simultaneously perform phase retrieval and calibration of
   detector sensitivity, scaling efficiently to inferring millions of
   parameters. This new framework enables high dimensional optimization and
   inference in data analysis and hardware design in astronomy and beyond,
   which we explore in subsequent papers in this series. (c) 2023 Society
   of Photo-Optical Instrumentation Engineers (SPIE)},
Type = {Article},
Affiliation = {Desdoigts, L (Corresponding Author), Univ Sydney, Sydney Inst Astron, Sch Phys, Camperdown, NSW, Australia.
   Desdoigts, Louis; Tuthill, Peter G., Univ Sydney, Sydney Inst Astron, Sch Phys, Camperdown, NSW, Australia.
   Pope, Benjamin J. S.; Dennis, Jordan, Univ Queensland, Sch Math \& Phys, St Lucia, Qld, Australia.
   Pope, Benjamin J. S., Univ Southern Queensland, Ctr Astrophys, Toowoomba, Qld, Australia.},
DOI = {10.1117/1.JATIS.9.2.028007},
Article-Number = {028007},
Keywords = {detectors; phase retrieval; simulations; diffractive optics},
Keywords-Plus = {KERNEL PHASE},
Author-Email = {louis.desdoigts@sydney.edu.au},
Number-of-Cited-References = {76},
Times-Cited = {7},
Unique-ID = {WOS:001031359600025},
}

@article{ WOS:000961893800001,
Author = {Fang, Yang and Gao, Jinshuang and Guo, Yaqing and Li, Xiaole and Yuan,
   Enwu and Yuan, Erfeng and Song, Liying and Shi, Qianqian and Yu, Haiyang
   and Zhao, Dehua and Zhang, Linlin},
Title = {Allelic phenotype prediction of phenylketonuria based on the machine
   learning method},
Journal = {HUMAN GENOMICS},
Year = {2023},
Volume = {17},
Number = {1},
Month = {MAR 31},
Abstract = {Background Phenylketonuria (PKU) is caused by mutations in the
   phenylalanine hydroxylase (PAH) gene. Our study aimed to predict the
   phenotype using the allelic genotype.
   Methods A total of 1291 PKU patients with 623 various variants were used
   as the training dataset for predicting allelic phenotypes. We designed a
   common machine learning framework to predict allelic genotypes
   associated with the phenotype.
   Results We identified 235 different mutations and 623 various allelic
   genotypes. The features extracted from the structure of mutations and
   graph properties of the PKU network to predict the phenotype of PKU were
   named PPML (PKU phenotype predicted by machine learning). The phenotype
   of PKU was classified into three different categories: classical PKU
   (cPKU), mild PKU (mPKU) and mild hyperphenylalaninemia (MHP). Three hub
   nodes (c.728G>A for cPKU, c.721 for mPKU and c.158G>A for HPA) were used
   as each classification center, and 5 node attributes were extracted from
   the network graph for machine learning training features. The area under
   the ROC curve was AUC = 0.832 for cPKU, AUC = 0.678 for mPKU and AUC =
   0.874 for MHP. This suggests that PPML is a powerful method to predict
   allelic phenotypes in PKU and can be used for genetic counseling of PKU
   families.
   Conclusions The web version of PPML predicts PKU allele classification
   supported by applicable real cases and prediction results. It is an
   online database that can be used for PKU phenotype prediction
   http://www.bioinfogenetics. info/PPML/.},
