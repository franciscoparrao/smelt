@article{ WOS:000917112500002,
Author = {Soltani, Mehran and Da Ros, Francesco and Carena, Andrea and Zibar,
   Darko},
Title = {Experimental validation of machine-learning based spectral-spatial power
   evolution shaping using Raman amplifiers},
Journal = {OPTICS EXPRESS},
Year = {2022},
Volume = {30},
Number = {25},
Pages = {45958-45969},
Month = {DEC 5},
Abstract = {We experimentally validate a real-time machine learning framework,
   capable of controlling the pump power values of Raman amplifiers to
   shape the signal power evolution in two-dimensions (2D): frequency and
   fiber distance. In our setup, power values of four first-order
   counter-propagating pumps are optimized to achieve the desired 2D power
   profile. The pump power optimization framework includes a convolutional
   neural network (CNN) followed by differential evolution (DE) technique,
   applied online to the amplifier setup to automatically achieve the
   target 2D power profiles. The results on achievable 2D profiles show
   that the framework is able to guarantee very low maximum absolute error
   (MAE) (<0.5 dB) between the obtained and the target 2D profiles.
   Moreover, the framework is tested in a multi-objective design scenario
   where the goal is to achieve the 2D profiles with flat gain levels at
   the end of the span, jointly with minimum spectral excursion over the
   entire fiber length. In this case, the experimental results assert that
   for 2D profiles with the target flat gain levels, the DE obtains less
   than 1 dB maximum gain deviation, when the setup is not physically
   limited in the pump power values. The simulation results also prove that
   with enough pump power available, better gain deviation (less than 0.6
   dB) for higher target gain levels is achievable. (c) 2022 Optica
   Publishing Group under the terms of the Optica Open Access Publishing
   Agreement},
Type = {Article},
Affiliation = {Soltani, M (Corresponding Author), Tech Univ Denmark DTU, Dept Elect \& Photon Engn, DK-2800 Lyngby, Denmark.
   Soltani, Mehran; Da Ros, Francesco; Zibar, Darko, Tech Univ Denmark DTU, Dept Elect \& Photon Engn, DK-2800 Lyngby, Denmark.
   Carena, Andrea, Politecn Torino, Dipartimento Elettron \& Telecomunicazioni DET, Corso Duca Abruzzi 24, I-10129 Turin, Italy.},
DOI = {10.1364/OE.475873},
Article-Number = {\#475873},
Keywords-Plus = {TRANSMISSION; AMPLIFICATION; LINKS; FIBER},
Author-Email = {msolt@fotonik.dtu.dk},
