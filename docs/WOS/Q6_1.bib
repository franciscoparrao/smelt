   Khodadadi, Nima, Univ Calif Berkeley, Pacific Earthquake Engn Res Peer Ctr, Dept Civil \& Environm Engn, Berkeley, CA 94720 USA.
   Nanni, Antonio, Univ Miami, Dept Civil \& Architectural Engn, Coral Gables, FL 33146 USA.},
DOI = {10.1186/s40069-025-00856-3},
Article-Number = {117},
Keywords = {MPC; Compressive strength; Machine learning; Predictive modeling;
   Experimental validation},
Keywords-Plus = {POTASSIUM PHOSPHATE; RATIO; MORTARS; BINDER},
