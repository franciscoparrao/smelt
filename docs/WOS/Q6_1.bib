Keywords = {Drought; Water stress; Tropical forests; Machine learning; Stomatal
   regulation},
Keywords-Plus = {WOOD DENSITY; HYDRAULIC ARCHITECTURE; STOMATAL CONDUCTANCE; CANOPY
   CONDUCTANCE; WATER; MODEL; RESPONSES; DYNAMICS; IMPACTS; DROUGHT},
