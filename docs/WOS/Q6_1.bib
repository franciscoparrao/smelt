@article{ WOS:001589369900010,
Author = {Akash, Md. Anonno Habib and Hossain, Md. Shameem and Islam, Md.
   Muhaiminul and Islam, Kazi Siamul and Islam, Md. Nasirul and Sony,
   Shamima Yesmin},
Title = {Optimization of methane production in anaerobic digestion: A hybrid
   approach using experimental analysis, process simulation and machine
   learning},
Journal = {RESULTS IN ENGINEERING},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {Anaerobic digestion offers a sustainable route for converting food waste
   into renewable biogas, but its efficiency requires careful optimization
   of operational parameters. This study presents an integrated
   experimental, process simulation, and machine learning framework to
   enhance methane production from food waste and cow dung codigestion. A
   batch-scale 5 L digester with a 4:2:1 substrate-to-inoculum ratio was
   pre-fermented for three months to establish microbial activity and
   initiate digestion, after which methane, temperature, and pressure were
   monitored in real time for 15 consecutive days. Methane concentration
   peaked on Day 3 at 2982 ppm, followed by a gradual decline to 378 ppm by
   Day 15, consistent with substrate depletion and reduced microbial
   activity. Aspen Plus simulations, structured on the ADM1 framework,
   identified 320 K (47 degrees C) and a hydraulic retention time of 15
   days as optimal conditions for methane yield, though limitations were
   observed in the absence of pretreatment. Complementary ML analysis
   enhanced predictive accuracy: Random Forest effectively modeled methane
   dynamics, while SVR achieved the lowest error metrics (RMSE = 339.74;
   MAPE = 1.57 \%), establishing it as the most reliable forecasting tool.
   K-Means clustering and ANFIS further provided emission phase
   categorization and interpretability of methane concentration patterns.
   The findings highlight critical factors- temperature, retention time,
   feedstock ratio, and buffering in improving AD performance. By
   integrating experimental validation, process simulation, and ML based
   forecasting, this study advances the intelligent design and scalable
   optimization of AD systems for renewable energy production.},
Type = {Article},
Affiliation = {Hossain, MS (Corresponding Author), Khulna Univ Engn \& Technol, Dept Energy Sci \& Engn, Khulna 9203, Bangladesh.
   Akash, Md. Anonno Habib; Hossain, Md. Shameem; Islam, Md. Muhaiminul; Islam, Kazi Siamul, Khulna Univ Engn \& Technol, Dept Energy Sci \& Engn, Khulna 9203, Bangladesh.
   Islam, Md. Nasirul, Mil Inst Sci \& Technol MIST, Dept Aeronaut Engn, Dhaka 1216, Bangladesh.
   Sony, Shamima Yesmin, Training Inst Chem Ind T, Operat \& Proc Technol Dept, Narsingdi, Bangladesh.},
DOI = {10.1016/j.rineng.2025.107464},
EarlyAccessDate = {SEP 2025},
Article-Number = {107464},
Keywords = {Anaerobic digestion; Methane optimization; Aspen Plus simulation;
   Machine learning; Regression models},
Keywords-Plus = {BIOGAS PRODUCTION; CO-DIGESTION; FOOD WASTE; STRAW; MODEL},
Author-Email = {shameem@ese.kuet.ac.bd},
Number-of-Cited-References = {43},
Times-Cited = {6},
Unique-ID = {WOS:001589369900010},
}

@article{ WOS:001583825700189,
Author = {Amato, Alexei and Daniele, Fabio and Agbomemewa, Lorenzo and
   Confalonieri, Matteo and Pedrazzoli, Paolo},
Title = {Multimodal machine learning framework for material selection in
   injection molding industry},
Journal = {IFAC PAPERSONLINE},
Year = {2025},
Volume = {59},
Number = {10},
Pages = {1125-1130},
Abstract = {The design phase in injection molding is critical, as it directly
   influences product quality, production efficiency, and overall
   manufacturing costs. This paper introduces a multimodal machine learning
   framework to predict product quality during the design phase, whether
   for new products or modifications of existing ones. The framework
   integrates regression, classification, and probabilistic modeling to
   evaluate material characteristics and process parameters, providing
   dimensional and mechanical performance predictions for defined products.
   This methodology minimizes defect risks, optimizes process parameters,
   and refines production systems. The results highlight the framework's
   potential to enhance efficiency, reduce waste, lower costs, and
   facilitate smarter, data-driven manufacturing aligned with Industry 4.0
   principles. Copyright (c) 2025 The Authors.},
Type = {Proceedings Paper},
Affiliation = {Amato, A (Corresponding Author), DTI Univ Appl Sci \& Arts Southern Switzerland, Via Santa 1, CH-6962 Lugano, Viganello, Switzerland.
