@article{ WOS:001625203100001,
Author = {Song, Zhantao and Zhang, Xiong and Zhang, Junjie and Ding, Honggang and
   Shao, Jingai and Yang, Haiping},
Title = {Data-driven modeling of multi-target performance in photothermal
   CO2 methanation},
Journal = {FUEL},
Year = {2026},
Volume = {407},
Number = {C},
Month = {MAR 1},
Abstract = {Photothermal CO2 methanation is a promising pathway for carbon-neutral
   fuel production by harnessing solar energy to convert greenhouse gases
   into methane. However, conventional trial-and-error catalyst development
   is often inefficient and lacks systematic guidance, limiting progress
   toward high-performance materials. Rational catalyst discovery remains
   hindered by the complex interplay of light, heat, and gas-solid
   dynamics. Herein, we establish an interpretable machine learning
   framework to predict catalytic performance directly from experimental
   descriptors. A dataset comprising 952 data points from literature,
   covering preparation, reaction, and structural features of catalysts,
   was compiled and analyzed. Among six models, ensemble learners (GBDT,
   XGB, LGBM) achieve high accuracy in predicting CH4 space-time yield
   (STY), CH4 selectivity (S-methane), and CO2 conversion (X-CO2), with R-2
   scores of 0.932, 0.927, and 0.868, respectively. SHAP (Shapley additive
   explanations) analysis identifies reaction temperature (250-400 degrees
   C), light intensity (>1.5 W <middle dot>cm(-2)), and gas-hourly space
   velocity (similar to 3.6 x 10(4) mL<middle dot> g(-1) <middle dot>h(-1))
   as key levers of control. Statistical trends suggest Mn as a promising
   promoter, which is validated experimentally by a NiMn/Al2O3 catalyst
   exhibiting 94.61 \% CO2 conversion and > 99 \% CH4 selectivity. This
   fully data-driven and interpretable approach overcomes the limitations
   of the trial-and-error paradigm and offers a deployable strategy for
   accelerated catalyst design in photothermal CO2 conversion systems.},
Type = {Article},
Affiliation = {Zhang, X (Corresponding Author), 1037 Luoyu Rd, Wuhan, Hubei, Peoples R China.
   Song, Zhantao; Zhang, Xiong; Zhang, Junjie; Ding, Honggang; Shao, Jingai; Yang, Haiping, Huazhong Univ Sci \& Technol, Sch Energy \& Power Engn, State Key Lab Coal Combust, Wuhan 430074, Peoples R China.
   Shao, Jingai, Huazhong Univ Sci \& Technol, Sch Energy \& Power Engn, Dept New Energy Sci \& Engn, Wuhan 430074, Peoples R China.},
DOI = {10.1016/j.fuel.2025.137563},
EarlyAccessDate = {NOV 2025},
Article-Number = {137563},
Keywords = {Machine Learning; Photothermal catalysis; CO2 methanation; CO2
   hydrogenation},
Keywords-Plus = {METAL; PREDICTION; CONVERSION; REDUCTION},
Author-Email = {zhangxiong107@163.com},
Number-of-Cited-References = {92},
Times-Cited = {0},
Unique-ID = {WOS:001625203100001},
}

@article{ WOS:001609396200001,
Author = {Zhao, Wanxiu and He, Zhitao and Wu, Zhixi and Zhou, Yi and Ding, Zhao
   and Chen, Hongxiang and Zhou, Yang},
Title = {Integrating SHAP Interpretability and Ensemble Machine Learning To
   Optimize Conductivity in Flexible Electronic Polymers},
Journal = {ACS APPLIED POLYMER MATERIALS},
Year = {2025},
Volume = {7},
Number = {21},
Pages = {14676-14689},
Month = {NOV 14},
Abstract = {Conductive polymers are essential materials for flexible electronics and
   energy storage, yet their electrical performance is highly sensitive to
   multivariate synthesis parameters that are difficult to optimize
   experimentally. Here, we develop a machine learning framework that
   accurately predicts polymer conductivity based on nine key synthetic
   variables. Among five tested algorithms, EXtreme Gradient Boosting
   (XGBoost) achieves the highest predictive accuracy (test R 2 = 0.933),
   while Light Gradient Boosting Machine (LightGBM) shows strong
   performance with minimal overfitting. SHapley Additive exPlanations
   (SHAP) analysis reveals that dopant species is the dominant determinant
   of conductivity (59.85\%), followed by oxidant species (17.5\%) and
   polymer type (8.5\%). The model further uncovers critical nonlinear
   relationships, including conductivity maximization at 30-60 degrees C, a
   sharp decline beyond a 2 mol/L dopant concentration, and negligible
   dependence on reaction duration after equilibrium. Notably, optimal
   conductivity arises under synergistic conditions of elevated reaction
   temperature (>80 degrees C) and low oxidant concentration (<0.2 mol/L),
   which promote molecular alignment and enhance charge carrier mobility.
   Our findings highlight that dopant-driven acid-base doping strength,
   rather than classical acid-base doping strength, serves as the primary
   factor controlling carrier transport in conductive polymers. This
   insight provides the design principles for organic electronic materials
   and demonstrates how machine learning can accelerate materials discovery
   and optimization.},
Type = {Article},
Affiliation = {Zhou, Y (Corresponding Author), Wuhan Text Univ, Sch Text Sci \& Engn, State Key Lab New Text Mat \& Adv Proc, Wuhan 430200, Peoples R China.
   Ding, Z (Corresponding Author), Chongqing Univ, Coll Mat Sci \& Engn, Natl Engn Res Ctr Magnesium Alloys, Chongqing 400044, Peoples R China.
   Zhao, Wanxiu; He, Zhitao; Wu, Zhixi; Zhou, Yi; Zhou, Yang, Wuhan Text Univ, Sch Text Sci \& Engn, State Key Lab New Text Mat \& Adv Proc, Wuhan 430200, Peoples R China.
   Ding, Zhao, Chongqing Univ, Coll Mat Sci \& Engn, Natl Engn Res Ctr Magnesium Alloys, Chongqing 400044, Peoples R China.
   Chen, Hongxiang, Wuhan Univ Sci \& Technol, Sch Chem \& Chem Engn, Wuhan 430081, Peoples R China.},
DOI = {10.1021/acsapm.5c02996},
EarlyAccessDate = {NOV 2025},
Keywords = {conductive polymers; machinelearning; SHAPanalysis; doping engineering;
   molecular ordering; flexible electronics},
Keywords-Plus = {ELECTRICAL-CONDUCTIVITY; POLYANILINE; POLYMERIZATION; POLYTHIOPHENE;
