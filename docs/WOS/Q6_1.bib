@article{ WOS:000366098400003,
Author = {O'Brien, Aidan R. and Saunders, Neil F. W. and Guo, Yi and Buske, Fabian
   A. and Scott, Rodney J. and Bauer, Denis C.},
Title = {VariantSpark: population scale clustering of genotype information},
Journal = {BMC GENOMICS},
Year = {2015},
Volume = {16},
Month = {DEC 10},
Abstract = {Background: Genomic information is increasingly used in medical practice
   giving rise to the need for efficient analysis methodology able to cope
   with thousands of individuals and millions of variants. The widely used
   Hadoop MapReduce architecture and associated machine learning library,
   Mahout, provide the means for tackling computationally challenging
   tasks. However, many genomic analyses do not fit the Map-Reduce
   paradigm. We therefore utilise the recently developed SPARK engine,
   along with its associated machine learning library, MLlib, which offers
   more flexibility in the parallelisation of population-scale
   bioinformatics tasks. The resulting tool, VARIANTSPARK provides an
   interface from MLlib to the standard variant format (VCF), offers
   seamless genome-wide sampling of variants and provides a pipeline for
   visualising results.
   Results: To demonstrate the capabilities of VARIANTSPARK, we clustered
   more than 3,000 individuals with 80 Million variants each to determine
   the population structure in the dataset. VARIANTSPARK is 80\% faster
   than the SPARK-based genome clustering approach, ADAM, the comparable
   implementation using Hadoop/Mahout, as well as ADMIXTURE, a commonly
   used tool for determining individual ancestries. It is over 90\% faster
   than traditional implementations using R and Python.
   Conclusion: The benefits of speed, resource consumption and scalability
   enables VARIANTSPARK to open up the usage of advanced, efficient machine
   learning algorithms to genomic data.},
Type = {Article},
Affiliation = {Bauer, DC (Corresponding Author), CSIRO, Hlth \& Biosecur Flagship, 11 Julius Ave, Sydney, NSW 2113, Australia.
   O'Brien, Aidan R.; Saunders, Neil F. W.; Bauer, Denis C., CSIRO, Hlth \& Biosecur Flagship, Sydney, NSW 2113, Australia.
   O'Brien, Aidan R.; Scott, Rodney J., Fac Hlth, Sch Biomed Sci \& Pharm, Newcastle, NSW 2308, Australia.
   Buske, Fabian A., Garvan Inst Med Res, Kinghorn Canc Ctr, Canc Res Div, Canc Epigenet Program, Sydney, NSW 2010, Australia.
   Buske, Fabian A., Univ New S Wales, UNSW Med, Sydney, NSW 2052, Australia.
   Guo, Yi, CSIRO, Sydney, NSW 2052, Australia.},
DOI = {10.1186/s12864-015-2269-7},
Article-Number = {1052},
Keywords = {Genotype clustering; SPARK; BigData; 1000 Genomes Project; Personal
   Genome Project; Population structure},
Keywords-Plus = {BIG DATA; CLOUD; FRAMEWORK; HADOOP},
Author-Email = {Denis.Bauer@CSIRO.au},
Number-of-Cited-References = {30},
Times-Cited = {21},
