   Ali, Kassem El Cheikh, Imperial Coll London, Dept Elect \& Elect Engn, London, England.},
DOI = {10.1007/s41748-025-00727-7},
EarlyAccessDate = {JUL 2025},
Keywords = {Coastal aquifers; Seawater intrusion management; FEFLOW; Python; SHAP;
   Random Forest},
