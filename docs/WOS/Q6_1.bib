   Yu, Jae Yong, Hallym Univ, Res Inst Data Sci \& AI Artificial Intelligence, Chuncheon Si, Gangwon Do, South Korea.
   Yu, Jae Yong, Hallym Univ, Div Data Sci, Chuncheon Si, Gangwon Do, South Korea.
   Yu, Jae Yong, Hallym Univ, Dept Emergency Med, Chuncheon Si, Gangwon Do, South Korea.},
DOI = {10.1016/j.jamda.2025.105818},
EarlyAccessDate = {SEP 2025},
