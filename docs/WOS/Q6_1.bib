   Weiner, Scott G., Brigham \& Womens Hosp, Dept Emergency Med, Div Hlth Policy \& Publ Hlth, 75 Francis St,NH 226, Boston, MA 02115 USA.},
DOI = {10.1186/s12911-021-01692-7},
Article-Number = {331},
Keywords-Plus = {BUPRENORPHINE-NALOXONE TREATMENT; ECONOMIC BURDEN; UNITED-STATES;
   INSURED PATIENTS; DEPENDENCE; ABUSE; RETENTION; COSTS; MISUSE; CARE},
Author-Email = {mnalam@neu.edu},
