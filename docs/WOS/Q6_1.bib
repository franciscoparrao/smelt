}

@article{ WOS:001090144800001,
Author = {Yan, Cheng and Feng, Xiaming and Konlan, John and Mensah, Patrick and
   Li, Guoqiang},
Title = {Overcoming the barrier: designing novel thermally robust shape memory
   vitrimers by establishing a new machine learning framework},
Journal = {PHYSICAL CHEMISTRY CHEMICAL PHYSICS},
Year = {2023},
Volume = {25},
Number = {43},
Pages = {30049-30065},
Month = {NOV 8},
Abstract = {Shape memory vitrimers (SMVs) are an emerging class of advanced
   materials that have garnered significant interest from researchers in
   the past five to six years. These materials can return to their original
   shape when exposed to a stimulus, while also healing damage they have
   sustained. However, achieving both high healing/recycling efficiency and
   a high glass transition temperature (Tg) in SMVs has been challenging,
   due to the conflicting requirements between molecular chain mobility and
   the formation and reaction of dynamic covalent bond exchange. Based on
   the understanding of chemo-physical properties, this study first
   leverages machine learning (ML), involving supervised and unsupervised
   learning approaches, to navigate this complex design space of SMVs.
   Furthermore, we elaborated the basic mathematical frameworks of ML
   approaches and comprehensively compared their performances. Based on the
   best performing model, we designed four types of thermally robust shape
   memory vitrimers (TRSMVs), which boast high recycling efficiency,
   elevated Tg, and exemplary shape memory effects, overcoming conventional
   barriers. One of the discovered samples exhibited outstanding
   performance with a Tg of 233.5 degrees C, a recycling efficiency of
   84.1\%, and a recovery stress of 33 MPa in experiments. It aligns well
   with ML predictions, showcasing the potential of our ML framework in
   driving innovative materials design and advancing the field of smart
   polymers.
   A sophisticated machine learning framework was developed to design
   thermally robust shape memory vitrimers (TRSMVs) with superior recycling
   efficiency, an elevated Tg, and outstanding shape memory properties,
   surpassing traditional limitations.},
Type = {Article},
Affiliation = {Yan, C (Corresponding Author), Southern Univ \& A\&M Coll, Dept Mech Engn, Baton Rouge, LA 70813 USA.
   Yan, Cheng; Mensah, Patrick, Southern Univ \& A\&M Coll, Dept Mech Engn, Baton Rouge, LA 70813 USA.
   Feng, Xiaming; Konlan, John; Li, Guoqiang, Louisiana State Univ, Dept Mech \& Ind Engn, Baton Rouge, LA 70803 USA.
   Feng, Xiaming, Chongqing Univ, Coll Mat Sci \& Engn, 174 Shazhengjie, Chongqing 400044, Peoples R China.},
DOI = {10.1039/d3cp03631f},
EarlyAccessDate = {OCT 2023},
Keywords-Plus = {POLYMERS},
Author-Email = {cheng.yan@sus.edu},
Number-of-Cited-References = {53},
Times-Cited = {6},
Unique-ID = {WOS:001090144800001},
}

@article{ WOS:001204064900001,
Author = {Hamadi, Mohamed and El Mehadji, Tayeb and Laalam, Aimen and Zeraibi,
   Noureddine and Tomomewo, Olusegun Stanley and Ouadi, Habib and Dehdouh,
   Abdesselem},
Title = {Prediction of Key Parameters in the Design of CO2 Miscible
   Injection via the Application of Machine Learning Algorithms},
Journal = {ENG},
Year = {2023},
Volume = {4},
Number = {3},
Pages = {1905-1932},
Month = {SEP},
Abstract = {The accurate determination of key parameters, including the
   CO2-hydrocarbon solubility ratio (Rs), interfacial tension (IFT), and
   minimum miscibility pressure (MMP), is vital for the success of
   CO2-enhanced oil recovery (CO2-EOR) projects. This study presents a
   robust machine learning framework that leverages deep neural networks
   (MLP-Adam), support vector regression (SVR-RBF) and extreme gradient
   boosting (XGBoost) algorithms to obtained accurate predictions of these
   critical parameters. The models are developed and validated using a
   comprehensive database compiled from previously published studies.
   Additionally, an in-depth analysis of various factors influencing the
   Rs, IFT, and MMP is conducted to enhance our understanding of their
   impacts. Compared to existing correlations and alternative machine
   learning models, our proposed framework not only exhibits lower
   calculation errors but also provides enhanced insights into the
   relationships among the influencing factors. The performance evaluation
   of the models using statistical indicators revealed impressive
   coefficients of determination of unseen data (0.9807 for dead oil
   solubility, 0.9835 for live oil solubility, 0.9931 for CO2-n-Alkane
   interfacial tension, and 0.9648 for minimum miscibility pressure). One
   notable advantage of our models is their ability to predict values while
   accommodating a wide range of inputs swiftly and accurately beyond the
   limitations of common correlations. The dataset employed in our study
   encompasses diverse data, spanning from heptane (C-7) to eicosane (C-20)
   in the IFT dataset, and MMP values ranging from 870 psi to 5500 psi,
   covering the entire application range of CO2-EOR. This innovative and
   robust approach presents a powerful tool for predicting crucial
   parameters in CO2-EOR projects, delivering superior accuracy, speed, and
   data diversity compared to those of the existing methods.},
Type = {Article},
Affiliation = {Laalam, A (Corresponding Author), Univ North Dakota, Dept Petr Engn, Grand Forks, ND 58202 USA.
   Hamadi, Mohamed; El Mehadji, Tayeb; Zeraibi, Noureddine, Univ Boumerdes, Dept Min \& Petr Engn, Boumerdes 35000, Algeria.
