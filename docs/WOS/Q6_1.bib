@article{ WOS:001608922500004,
Author = {Bdour, Ahmed and Alkharabsheh, Raha M.},
Title = {Real-Time Machine Learning and Wireless Sensor Network for Coastal Water
   Quality Monitoring in the Gulf of Aqaba},
Journal = {ECOLOGICAL CHEMISTRY AND ENGINEERING S-CHEMIA I INZYNIERIA EKOLOGICZNA S},
Year = {2025},
Volume = {32},
Number = {3},
Pages = {335-352},
Month = {SEP 1},
Abstract = {This study presents an advanced real-time monitoring system integrating
   wireless sensor networks with machine learning to assess water quality
   in the Gulf of Aqaba. Our hybrid machine learning framework combines
   Random Forest (500 trees, node size = 5) for feature selection with
   Artificial Neural Network ensembles (3-layer MLP with Monte Carlo
   dropout) for probabilistic forecasting. The system continuously monitors
   six critical parameters, demonstrating strong predictive performance
   through rigorous validation: dissolved oxygen (R-2 = 0.92, RMSE = 0.45
   mg/L, 95 \% CI (Confidence interval): 0.41 - 0.49), nitrite (R-2 = 0.85,
   RMSE = 0.08 mg/L, CI: 0.07 - 0.09), and turbidity (R-2 = 0.89, RMSE =
   2.3 FTU, CI: 2.1 - 2.5). Comprehensive uncertainty analysis revealed
   prediction intervals of +/- 0.38 mg/L for DO and +/- 0.10 mg/L for
   nitrite, with spatial variability lowest in open waters (CV = 8.2 \%)
   and highest near coastal zones (CV = 15 \%). Residual autocorrelation
   analysis confirmed model reliability (Moran's I < 0.12, p > 0.05) across
   the study area. Spatial-temporal analysis identified nitrite as a
   sensitive pollution indicator, with concentrations reaching 0.12 mg/L
   near urban outflows compared to background levels (< 0.05 mg/L). The
   system achieved 92 \% accuracy in the early detection of environmental
   risks, including coral bleaching precursors (temperature anomalies > 1
   degrees C) and pollution events (nitrite spikes > 0.1 mg/L). Compared to
   conventional monitoring, the platform demonstrated 20.4 \% greater
   predictive accuracy (Delta R-2 = +0.17, p < 0.01) while reducing
   operational costs by 30.2 \%, primarily through automated data
   collection and reduced manual sampling. The integration of
   high-frequency sensing, adaptive machine learning, and cloud-based
   analytics establishes a replicable framework for coastal ecosystem
   management, particularly in anthropogenically stressed environments like
   the Red Sea.},
Type = {Article},
Affiliation = {Bdour, A (Corresponding Author), Hashemite Univ, Fac Engn, Dept Civil Engn, PO Box 330127, Zarqa 13133, Jordan.
   Bdour, Ahmed, Hashemite Univ, Fac Engn, Dept Civil Engn, PO Box 330127, Zarqa 13133, Jordan.
   Alkharabsheh, Raha M., Univ Politecn Madrid, Fac Forestry \& Nat Environm Engn, R\&I Ctr Conservat Biodivers \& Sustainable Dev CBDS, Madrid, Spain.},
DOI = {10.2478/eces-2025-0016},
Keywords = {marine water quality monitoring; real-time remote monitoring; wireless
   sensor networks; machine learning predictive modelling; GIS-based
   spatial analysis; Red Sea ecosystem management},
Keywords-Plus = {SPECIES DISTRIBUTIONAL DATA; SPATIAL AUTOCORRELATION; ACCOUNT; SYSTEM;
   DESIGN; COST},
Author-Email = {bdour@hu.edu.jo
   Raha.alkharabsheh@alumnos.upm.es},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001608922500004},
}

@article{ WOS:001566239300001,
Author = {Akbari, Mohammad and Bagherzadeh, Seyed Amin and Dehkordi, Mohammd
   Hossein Razavi and Naghsh, Alireza and Azimy, Noushin and Azimy,
   Hamidreza},
Title = {Optimizing thermophysical properties of non-Newtonian nano-refrigerants
   for refrigeration systems using machine learning approaches},
Journal = {INTERNATIONAL JOURNAL OF REFRIGERATION},
Year = {2025},
Volume = {179},
Pages = {420-431},
Month = {NOV},
Abstract = {The thermophysical properties of non-Newtonian superparamagnetic
   nano-refrigerants play a pivotal role in enhancing the efficiency of
   advanced cooling and next-generation refrigeration systems. The scope of
   this study includes the prediction and optimization of thermal
   conductivity and viscosity of cobalt ferrite (CoFe2O4)-based nanofluids
   over a range of temperatures and concentrations, targeting practical use
   in refrigeration system design. This study introduces a machine learning
   framework designed to predict and optimize the thermophysical properties
   of cobalt ferrite (CoFe2O4)-based superparamagnetic nano-refrigerants,
   with a focus on applications in refrigeration and heat transfer systems.
   By leveraging the capabilities of Radial Basis Function Networks
   (RBFNs), particularly a Generalized Regression Neural Network (GRNN),
   the model captures the relationships between critical input parameters
   such as temperature and nano-refrigerant concentration and key
   thermophysical outputs, including thermal conductivity and viscosity. To
   further enhance the framework, Particle Swarm Optimization (PSO) is
   integrated for inverse modeling, enabling the identification of optimal
   decision variables that balance thermal performance and magnetocaloric
   nano-refrigerant flow behavior. Unlike previous studies that rely
   primarily on empirical correlations or conventional simulations, this
   work introduces a hybrid machine learning-optimization framework that
   enables both predictive modeling and inverse design of thermally
   responsive nanofluids. The results reveal that increasing temperature
   significantly improves thermal conductivity, with an increase of 21.13
   \% at 50 degrees C, while viscosity rises by up to 61.38 \% depending on
   nanoparticle loading at 50 degrees C. The model identifies an optimal
   mass fraction of similar to 0.3092 \% at 50 degrees C, which achieves
   the best trade-off between heat transfer enhancement and acceptable flow
   behavior. Importantly, the proposed framework incorporates physical
   consistency checks and experimental constraints, ensuring robust and
   reliable predictions. These results validate the effectiveness of the
   integrated framework in addressing the challenges of thermophysical
   modeling for advanced cooling fluids. This work not only advances the
   understanding of non-Newtonian superparamagnetic nano-refrigerants but
   also demonstrates the transformative potential of combining neural
   networks with optimization techniques for data-driven modeling in
   refrigeration and heat transfer applications. The findings offer
   valuable insights for the development of next-generation cooling systems
   with improved efficiency and performance.},
Type = {Article},
Affiliation = {Azimy, H (Corresponding Author), Islamic Azad Univ, Dept Mech Engn, Najafabad Branch, Najafabad, Iran.
   Akbari, Mohammad; Bagherzadeh, Seyed Amin; Dehkordi, Mohammd Hossein Razavi; Azimy, Hamidreza, Islamic Azad Univ, Dept Mech Engn, Najafabad Branch, Najafabad, Iran.
   Akbari, Mohammad; Bagherzadeh, Seyed Amin; Dehkordi, Mohammd Hossein Razavi, Islamic Azad Univ, Aerosp \& Energy Convers Res Ctr, Najafabad Branch, Najafabad, Iran.
   Naghsh, Alireza, Islamic Azad Univ, Dept Elect Engn, Najafabad Branch, Najafabad, Iran.
   Azimy, Noushin, Shahid Chamran Univ Ahvaz, Engn Fac, Dept Mech Engn, Ahvaz, Iran.},
DOI = {10.1016/j.ijrefrig.2025.08.016},
EarlyAccessDate = {AUG 2025},
Keywords = {Thermophysical properties; Magnetocaloric refrigeration; Non-Newtonian
   nano-refrigerants; Heat transfer enhancement; Cooling systems;
   Optimization},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; THERMAL-CONDUCTIVITY; HYBRID NANOFLUID;
   ENTROPY GENERATION; VISCOSITY; BEHAVIOR; PREDICTION; MODEL},
Author-Email = {hamidrezaazimy@gmail.com},
Number-of-Cited-References = {59},
Times-Cited = {3},
Unique-ID = {WOS:001566239300001},
}

@article{ WOS:001580833100004,
Author = {Abbas, Yassir M. and Alsaif, Abdulaziz},
Title = {Explicit gradient boosting machine for accurate compressive strength
   prediction of metakaolin-based geopolymer concrete: feature importance
   and optimization},
Journal = {JOURNAL OF MATERIALS RESEARCH AND TECHNOLOGY-JMR\&T},
Year = {2025},
Volume = {38},
Pages = {2299-2314},
Month = {SEP-OCT},
Abstract = {Understanding the compressive strength (CS) of metakaolin-based
   geopolymer concrete (MK-GPC) requires capturing the complex, nonlinear
   interactions among mix design parameters, precursor chemistry, and
   curing conditions, complexities that often elude traditional modeling
   approaches. In this study, a Gradient Boosting Machine (GBM) algorithm
   was deployed within a transparent machine learning framework to predict
   CS of MK-GPC with high accuracy, drawing on a curated dataset of 235
   experimental mix designs. A comprehensive hyperparameter search across
   1440 configurations identified the optimal model, comprising 950
   decision trees, a learning rate of 0.1, and a maximum tree depth of two.
   This configuration yielded excellent predictive performance, with R2 of
   0.99 and 0.96 for training and testing sets, respectively, demonstrating
   strong generalization across a wide range of mix scenarios. Beyond
   predictive accuracy, the model emphasized interpretability through a
   combination of Shapley additive explanations, Gini feature importance,
   and Partial Dependence Plots, which together explained the relative
   impact and nonlinear influence of input variables. Five parameters:
   coarse-to-fine aggregate ratio (CF), water-to-NaOH ratio (WN), sodium
   hydroxide content (SH), extra water (EW), and silica-to-alumina ratio
   (SA) accounted for over 85 \% of the model's explanatory power. Specific
   trends were identified, including peak CS at CF approximate to 2.12, SH
   approximate to 116.2 kg/m(3), EW approximate to 6.1 kg/m(3), SA
   approximate to 2.63, and WN within the range of 7.46-9.39. The model
   also captured critical thermal and temporal effects, with strength
   development peaking at similar to 35 degrees C and plateauing beyond 28
   days. By bridging data-driven modeling with chemical and materials
   science understanding, this study offers a rigorously validated and
   interpretable approach to optimizing MK-GPC formulations, which enables
   performance-based, sustainable mix design through evidence-led
   decision-making.},
Type = {Article},
Affiliation = {Abbas, YM; Alsaif, A (Corresponding Author), King Saud Univ, Coll Engn, Dept Civil Engn, Riyadh 12372, Saudi Arabia.
   Abbas, Yassir M.; Alsaif, Abdulaziz, King Saud Univ, Coll Engn, Dept Civil Engn, Riyadh 12372, Saudi Arabia.},
DOI = {10.1016/j.jmrt.2025.08.064},
EarlyAccessDate = {AUG 2025},
Keywords = {Compressive strength; Concrete; Geopolymer; Gradient boosting; Machine
   learning; Metakaolin},
Author-Email = {yabbas@ksu.edu.sa
   aalsaiff@ksu.edu.sa},
Number-of-Cited-References = {78},
Times-Cited = {3},
Unique-ID = {WOS:001580833100004},
}

@article{ WOS:001617397300001,
Author = {Fan, Huiyang and Mei, Zhengyang and Yan, Jianhua and Bo, Zheng and Liu,
   Zhu},
Title = {Interpretable machine learning framework for designing high ionic
   conductivity in low-temperature lithium-ion battery electrolytes},
Journal = {MATERIALS GENOME ENGINEERING ADVANCES},
Year = {2025},
Volume = {3},
Number = {4},
Month = {DEC},
Abstract = {Ionic conductivity is a critical determinant of electrolyte performance
   in lithium-ion batteries, governing functionalities such as rate
   capability and low-temperature operability. Conventional optimizations,
   empirical or simulation-based, face significant limitations in either
   resource efficiency or predictive accuracy. To address these challenges,
   we developed an interpretable machine learning (ML) framework that
   combines least absolute shrinkage and selection operator (LASSO)
   regression with SHapley Additive exPlanations analysis to elucidate
   structure-property relationships in multicomponent electrolytes. This
   framework proposes a novel descriptor, model-input-weighted sum of LASSO
   features, which quantitatively captures the collective influence of
   molecular characteristics on ionic conductivity. Our approach achieves
   state-of-the-art predictive accuracy (RMSE = 1.33 mS cm-1, = 0.88) while
   identifying two dominant molecular features: PEOE\_VSA1, representing
   surface charge distribution, and NumAtomStereoCenters, reflecting
   stereochemical complexity. This led to the design of an optimized
   ternary electrolyte (1 mol L-1 LiTFSI in MA:THF:DMF, 5:3:2 molar ratio)
   demonstrating unprecedented conductivity values: 15.74 mS cm-1 at 25
   degrees C and 2.69 mS cm-1 at -70 degrees C. These results validate our
   framework's ability to guide the development of high-performance
   electrolytes for low-temperature applications. This study establishes a
   robust ML framework for accelerated electrolyte discovery, providing
   fundamental insights into molecular determinants of ionic conductivity.},
Type = {Article},
Affiliation = {Bo, Z (Corresponding Author), Zhejiang Univ, Coll Energy Engn, State Key Lab Clean Energy Utilizat, Hangzhou 310027, Zhejiang, Peoples R China.
   Liu, Z (Corresponding Author), Zhejiang Univ, ZJU Hangzhou Global Sci \& Technol Innovat Ctr, Zhejiang Key Lab Intelligent Mfg Funct Chem, Hangzhou 311215, Peoples R China.
   Liu, Z (Corresponding Author), Zhejiang Univ, Coll Chem \& Biol Engn, Hangzhou 310012, Peoples R China.
   Fan, Huiyang; Mei, Zhengyang; Yan, Jianhua; Bo, Zheng, Zhejiang Univ, Coll Energy Engn, State Key Lab Clean Energy Utilizat, Hangzhou 310027, Zhejiang, Peoples R China.
   Liu, Zhu, Zhejiang Univ, ZJU Hangzhou Global Sci \& Technol Innovat Ctr, Zhejiang Key Lab Intelligent Mfg Funct Chem, Hangzhou 311215, Peoples R China.
   Liu, Zhu, Zhejiang Univ, Coll Chem \& Biol Engn, Hangzhou 310012, Peoples R China.},
DOI = {10.1002/mgea.70032},
EarlyAccessDate = {AUG 2025},
Keywords = {high ionic conductivity; interpretable machine learning framework;
   lithium-ion battery; low-temperature electrolytes},
Author-Email = {bozh@zju.edu.cn
   liuzhu@zju.edu.cn},
Number-of-Cited-References = {54},
