
@article{ WOS:001722548300001,
Author = {Thamizhmaran, R. and Kalaimurugan, G. and Yuvaraj, A. and Das, Kinkar
   Chandra},
Title = {Predictive modeling of immunosuppressive medication using machine
   learning and topological descriptors for liver transplant recipients},
Journal = {BIOMEDICAL SIGNAL PROCESSING AND CONTROL},
Year = {2026},
Volume = {120},
Number = {B},
Month = {JUL 1},
Abstract = {Immunosuppressive therapy is essential for long term graft survival
   after liver transplantation, yet optimizing drug selection and dosing
   remains challenging due to complex structure-property relationships.
   Existing Quantitative Structure-Property Relationship {[}QSPR] studies
   often rely on limited descriptors or linear models, restricting
   predictive accuracy and practical relevance. In this work, an integrated
   graph theoretic and machine learning framework is proposed to model
   physicochemical properties of clinically approved immunosuppressive
   drugs, namely tacrolimus, cyclosporine, and prednisone. Degree-based
   topological indices are analytically investigated, efficiently computed
   using a reproducible Python framework, and employed as molecular
   descriptors in supervised learning models. Linear regression is used as
   a baseline, while Random Forest and Extreme Gradient Boosting capture
   nonlinear dependencies. Ensemble models achieve excellent predictive
   performance, with coefficients of determination exceeding 0.99 and low
   mean absolute error {[}MAE] and Root mean square error {[}RMSE] values
   across key properties such as molecular weight, boiling point, polarity,
   and enthalpy. The study introduces new analytical relations among
   topological indices and demonstrates that combining theoretical insights
   with ensemble learning substantially improves Quantitative
   Structure-Property Relationship prediction. These results highlight the
   practical potential of graph-based machine learning models for rapid
   drug property screening and support their application in personalized
   immunosuppressive therapy and computational drug design for liver
   transplantation.},
Type = {Article},
Affiliation = {Das, KC (Corresponding Author), Sungkyunkwan Univ, Dept Math, Suwon 16419, South Korea.
   Thamizhmaran, R.; Kalaimurugan, G.; Yuvaraj, A., Thiruvalluvar Univ, Dept Math, Vellore 632115, Tamil Nadu, India.
   Das, Kinkar Chandra, Sungkyunkwan Univ, Dept Math, Suwon 16419, South Korea.},
DOI = {10.1016/j.bspc.2026.110137},
Article-Number = {110137},
Keywords = {Topological descriptors; Immunosuppressant drugs; Machine learning
   techniques; RFA and XGB; Regression},
Keywords-Plus = {BOND CONNECTIVITY INDEX},
Author-Email = {thamizhmaran2699@gmail.com
   kalaimurugan@gmail.com
   yuvaraj25028@gmail.com
   kinkardas2003@gmail.com},
Number-of-Cited-References = {41},
Times-Cited = {0},
Unique-ID = {WOS:001722548300001},
}

@article{ WOS:001699287700001,
Author = {Ramakrishnan, S. and Chinnappan, Christopher Columbus},
Title = {Parallelized hybrid ensemble machine learning framework for scalable and
   accurate rainfall prediction},
Journal = {MACHINE LEARNING WITH APPLICATIONS},
Year = {2026},
Volume = {24},
Month = {JUN},
Abstract = {Accurate rainfall forecasting is essential for agriculture, hydrological
   planning, and disaster preparedness, while balancing prediction quality
   with computational constraints. This study establishes a stacking-based
   ensemble framework for binary rainfall prediction using the Australian
   RainTomorrow dataset (over 140,000 daily observations), showing learned
   meta-feature combination outperforms probability averaging for
   imbalanced weather prediction. This study compares voting architectures
   against two-layer stacking ensembles where an XGBoost meta-learner
   optimizes weights from leakage-safe out-of-fold probabilities. Two
   ensemble families are proposed: RXL (Random Forest + XGBoost + LightGBM)
   and TriBoost (CatBoost + XGBoost + Hist-GradientBoosting), evaluated as
   voting and stacking configurations with tuned single learners. The
   methodology ensures rigor through unified preprocessing, leakage
   control, and evaluation under three protocols: stratified holdout
   (Protocol A), 5-fold cross-validation (Protocol B), and temporal split
   (Protocol C). Class imbalance is addressed via class weighting,
   fold-internal SMOTE, and threshold tuning, while temporal features
   mitigate distribution drift. Results confirm advantages for stacking
   architectures. TriBoost Stack achieves state-of-the-art performance
   under Protocol A (Accuracy 0.864, Macro F1 0.776, PR AUC 0.751, ROC AUC
   0.893) with strong minority-event detection (Recall Yes 0.565, Precision
   Yes 0.752), exceeding voting ensembles and benchmarks. RXL Stack follows
   (Accuracy 0.861, Macro F1 0.772), while voting variants underperform on
   minority-sensitive metrics. Cross-validation confirms stability
   (TriBoost Stack: Macro F1 0.772 +/- 0.004), and temporal evaluation
   validates deployment readiness (Macro F1 0.754). Analysis shows
   practical viability: parallel CPU execution and GPU acceleration deliver
   training speedups without sacrificing quality. The framework provides a
   validated solution for operational weather forecasting systems,
   balancing predictive performance and computational constraints.},
Type = {Article},
Affiliation = {Chinnappan, CC (Corresponding Author), Vellore Inst Technol, Sch Comp Sci \& Engn, Chennai, India.
   Ramakrishnan, S.; Chinnappan, Christopher Columbus, Vellore Inst Technol, Sch Comp Sci \& Engn, Chennai, India.},
DOI = {10.1016/j.mlwa.2026.100863},
Article-Number = {100863},
Keywords = {Rainfall prediction; Heterogeneous ensembles; Soft voting; Stacking;
   Class imbalance; Cross-validation; Time-based split; GPU acceleration;
   Parallel computing},
Author-Email = {ramakrishnan.s2022@vitstudent.ac.in
   christopher.columbus@vit.ac.in},
Number-of-Cited-References = {24},
Times-Cited = {0},
Unique-ID = {WOS:001699287700001},
}

@article{ WOS:001699410000001,
Author = {Caparrini, Antonio and Arroyo, Javier},
Title = {mloptimizer: Genetic algorithm-based hyperparameter optimization for
   machine learning models in python},
Journal = {SOFTWAREX},
Year = {2026},
Volume = {34},
Month = {JUN},
Abstract = {Hyperparameter optimization (HPO) in machine learning pipelines can
   significantly impact model performance. While traditional approaches
   such as manual tuning, grid search, and random search are widely
   adopted, they become inefficient when dealing with complex,
   high-dimensional search spaces. To address this limitation, this paper
   introduces mloptimizer, an open-source package that implements genetic
   algorithm-based HPO for ma chine learning models. The package integrates
   seamlessly with scikit-learn, the widely used Python machine learning
   framework, and offers compatibility with popular libraries such as
   XGBoost and CatBoost. Built on top of the DEAP (Distributed Evolutionary
   Algorithms in Python) library, mloptimizer supports parallel execution
   for efficient exploration of large search spaces. In addition, the
   package is designed to be easy to use and highly customizable, and it
   provides native integration with MLflow for experiment tracking and
   reproducibility.},
Type = {Article},
Affiliation = {Caparrini, A (Corresponding Author), Univ Complutense Madrid, Fac Estudios Estadisticos, Madrid, Spain.
   Caparrini, Antonio, Univ Complutense Madrid, Fac Estudios Estadisticos, Madrid, Spain.
   Arroyo, Javier, Univ Alcala, Dept Ciencias Comp, Madrid, Spain.
   Arroyo, Javier, Univ Complutense Madrid, Inst Tecnol Conocimiento, Madrid, Spain.},
DOI = {10.1016/j.softx.2026.102567},
Article-Number = {102567},
Keywords = {Genetic algorithms; Hyperparameter tuning; Machine learning; Python
   library; Search space},
Author-Email = {acaparri@ucm.es
   javier.arroyog@uah.es},
Number-of-Cited-References = {24},
Times-Cited = {0},
Unique-ID = {WOS:001699410000001},
}

@article{ WOS:001707440800001,
Author = {Fan, Lin and He, Yan and Mo, Yunfeng and Cao, Yiming},
Title = {An interpretable ensemble machine learning model for predicting carbon
   dioxide adsorption on magnesium oxide-based sorbents},
Journal = {ENVIRONMENTAL RESEARCH},
Year = {2026},
Volume = {297},
Month = {MAY 15},
Abstract = {Accurately predicting the carbon dioxide (CO2) adsorption capacity of
   magnesium oxide (MgO)-based sorbents is crucial for advancing carbon
   capture technologies. This study develops an interpretable machine
   learning framework to address this challenge. Fourteen candidate models
   were evaluated, with six top-performing ones selected for Bayesian
   hyperparameter optimization using the Optuna framework. A novel weighted
   ensemble model was then constructed by integrating the entropy weight
   method and the Technique for Order Preference by Similarity to Ideal
   Solution. The optimized ensemble model demonstrated outstanding
   performance on an independent test set, achieving an R2 of 0.9903 with
   MSE, RMSE, and MAE of 0.361, 0.6008, and 0.2544 respectively, surpassing
   most individual models. SHapley Additive exPlanations analysis
   identified material morphology as the most significant feature (43.8\%
   contribution), particularly granular morphology. Process parameters
   including time (23.3\%) and temperature (14.1\%) were the next major
   contributors, while pore structure variables collectively contributed
   15.3\%. The analysis further revealed complex non-linear dependencies
   and interaction effects, with the combination of medium temperature
   (200-400 degrees C) and adsorption time (100-250 min) proving optimal.
   Additionally, a web application was deployed to provide real-time
   prediction capability. This work provides both a reliable predictive
   tool and valuable mechanistic insights for designing high-performance
   MgO-based CO2 adsorbents.},
Type = {Article},
Affiliation = {He, Y (Corresponding Author), Liaoning Petrochem Univ, Sch Mech Engn, Fushun 113001, Liaoning, Peoples R China.
   Fan, Lin; Mo, Yunfeng, Liaoning Petrochem Univ, Engn Training Ctr, Fushun 113001, Liaoning, Peoples R China.
   Fan, Lin, Shenyang Univ Technol, Sch Mech Engn, Shenyang 110870, Liaoning, Peoples R China.
   He, Yan; Cao, Yiming, Liaoning Petrochem Univ, Sch Mech Engn, Fushun 113001, Liaoning, Peoples R China.},
DOI = {10.1016/j.envres.2026.124126},
Article-Number = {124126},
Keywords = {Ensemble learning; MgO-based sorbents; CO 2 adsorption; Model
   interpretation; Streamlit},
Keywords-Plus = {CO2 CAPTURE; MGO},
Author-Email = {1422017226@qq.com},
Number-of-Cited-References = {54},
Times-Cited = {1},
Unique-ID = {WOS:001707440800001},
}

@article{ WOS:001723837800002,
Author = {Huang, Jingang and Wang, Ruilin and Li, Weishuai and Yang, Yang and
   Wang, Hai and Han, Wei and Li, Huanxuan and Liu, Jie and Qiu, Shanshan
   and Xu, Xiaobin and Hou, Pingzhi},
Title = {Machine learning-assisted inverse design of pyrolyzed biochar and
   process optimization for enhanced denitrification: A stacking
   ensemble-based framework},
Journal = {PROCESS SAFETY AND ENVIRONMENTAL PROTECTION},
Year = {2026},
Volume = {210},
Month = {APR 1},
Abstract = {Pyrolyzed biochar is a carbon-sink, biomass-derived material that
   improves denitrification toward carbon-neutral wastewater treatment.
   However, its efficacy depends on complex trade-offs between biochar
   properties and operational parameters. In this study, a stacking
   ensemble-based machine learning framework was developed and validated to
   assist the inverse design of optimal biochar and process conditions for
   enhanced denitrification. Developed using a MissForest-imputed
   biochar-denitrification dataset (n = 183), the proposed Stacking3
   model-integrating XGBoost, CatBoost, and LightGBM as base learners with
   ANN as the meta-learner-demonstrated superior predictive performance. It
   achieved test R2 of 0.95 for nitrate removal efficiency (NRE) and 0.89
   for biochar-induced specific denitrification rate enhancement (Delta
   NRR), with corresponding test RMSE of 0.038 and 0.086. Through genetic
   algorithm-embedded optimization (Stacking3-GA) on a Synthpopgenerated
   biochar dataset (n = 3000), the optimal feedstock (bagasse) and
   pyrolysis conditions (10 degrees C/min, 300-500 degrees C, 60-120 min)
   were identified, along with tailored operational parameters (8-10 h,
   1.4-1.6 g/L, 31-32 degrees C, pH 7.8-8.1). Experimental validation under
   these optimized configurations confirmed accurate predictions, with
   relative errors of 16.90\% for Delta NRR and 5.27\% for NRE. This work
   established a data-driven strategy for intelligently designing biochar
   and optimizing operational conditions to advance sustainable
   denitrification processes.},
Type = {Article},
Affiliation = {Huang, JG (Corresponding Author), Hangzhou Dianzi Univ, Coll Mat \& Environm Engn, Hangzhou 310018, Peoples R China.
   Huang, Jingang; Wang, Ruilin; Li, Weishuai; Yang, Yang; Wang, Hai; Han, Wei; Li, Huanxuan; Liu, Jie; Qiu, Shanshan, Hangzhou Dianzi Univ, Coll Mat \& Environm Engn, Hangzhou 310018, Peoples R China.
   Huang, Jingang; Han, Wei; Liu, Jie; Qiu, Shanshan; Xu, Xiaobin; Hou, Pingzhi, Hangzhou Dianzi Univ, China Austria Belt \& Rd Joint Lab Artificial Intel, Hangzhou 310018, Peoples R China.},
DOI = {10.1016/j.psep.2026.108751},
Article-Number = {108751},
Keywords = {Biochar; Machine learning; Denitrification; Stacking ensemble;
   Optimization; Experimental validation},
Keywords-Plus = {ENVIRONMENTAL APPLICATION},
Author-Email = {hjg@hdu.edu.cn},
Number-of-Cited-References = {46},
Times-Cited = {0},
Unique-ID = {WOS:001723837800002},
}

@article{ WOS:001703659600001,
Author = {Choi, Hongseok and Jun, Yongjoo and Chun, Inwoo and Lee, Yungu and Lee,
   Hoseong},
Title = {Data-driven machine learning framework for thermal performance
   prediction and control of mini-channel and metal-foam assisted battery
   immersion cooling systems},
Journal = {ENERGY},
Year = {2026},
Volume = {348},
Month = {APR 1},
Abstract = {Immersion-cooling battery thermal management systems are emerging as a
   critical technology; however, their advancement has been limited by
   analysis routes being misaligned with real-time operation. High-fidelity
   computational fluid dynamics are costly for repeated what-if
   evaluations, and recent machine-learning applications have tended to be
   geometry-centric and quasi-steady, offering limited support for
   sequence-aware prediction and constraint-aware optimization. Therefore,
   an operation-level data-driven machine-learning framework is introduced
   for a mini-channel and metal-foam immersion-cooling system. An LSTM with
   an additional fully connected head (LSTM-FC) is used to jointly predict
   sequence-wide thermal responses and a spatially resolved surface
   temperature field; it is coupled to a constraint-aware inverse-design
   loop, thereby shifting the role of machine learning from geometry tuning
   to sequence-aware, control-oriented operation in immersion cooling. A
   computational model validated by experiments was employed to generate a
   comprehensive transient dataset over a wide operating range, and the
   LSTM-FC was trained to estimate key temperature indicators with low
   inference latency, achieving high accuracy and strong generalization
   under previously unseen high charging rates, mixed C-rate profiles, and
   extreme thermal conditions. The inverse design procedure optimized the
   inlet temperature and mass flow rate under explicit limits on the
   maximum temperature, temperature difference, and hotspot suppression,
   reducing the time above safety limits from 79.2\% to 5.9\% for the
   maximum temperature and from 61.4\% to 13.6\% for the temperature
   difference relative to constant operation. Therefore, the proposed
   LSTM-FC framework enables fast and accurate unsteady prediction with
   real-time constraint-aware operating point selection and establishes a
   basis for future extensions to design-level optimization and online
   adaptation.},
Type = {Article},
Affiliation = {Lee, H (Corresponding Author), Korea Univ, Dept Mech Engn, 409 Innovat Hall Bldg,Anam Dong, Seoul, South Korea.
   Choi, Hongseok; Jun, Yongjoo; Chun, Inwoo; Lee, Yungu; Lee, Hoseong, Korea Univ, Dept Mech Engn, 409 Innovat Hall Bldg,Anam Dong, Seoul, South Korea.},
DOI = {10.1016/j.energy.2026.140520},
Article-Number = {140520},
Keywords = {Machine learning; Battery thermal management; Immersion cooling; Inverse
   design; Data-driven model; Long short-term memory},
Author-Email = {hslee1@korea.ac.kr},
Number-of-Cited-References = {32},
Times-Cited = {0},
Unique-ID = {WOS:001703659600001},
}

@article{ WOS:001719977800001,
Author = {Huang, Tianmeng and Shan, Xiao and Zhang, Hanchao and Zhang, Min and
   Cai, Huangyue and Lu, Jie and Wang, Jingyang and Zhao, Xiaofeng},
Title = {Microstructure-Mediated Inverse Design of Thermal Barrier Coatings via
   Interpretable, Data-Efficient Machine Learning},
Journal = {ACS APPLIED MATERIALS \& INTERFACES},
Year = {2026},
Month = {2026 MAR 20},
Abstract = {Microstructure control is critical for thermal barrier coating (TBC)
   performance, yet the complex, nonlinear process-structure relationships
   impede predictive design. Conventional data-driven approaches are
   limited by scarce experimental data and poor physical interpretability
   in end-to-end models. Here, we present a closed-loop machine learning
   framework that decouples the process-property relationship by
   introducing microstructure as a physically interpretable intermediary,
   thereby enabling accurate optimization with only 45 training samples and
   3 validation experiments. Key microstructure features such as equiaxed
   pores, unmelted regions, and cracks are quantitatively identified from
   scanning electron microscopy images using a deep neural network-based
   image recognition module, enabling automated feature extraction for
   subsequent modeling and optimization. The resulting forward prediction
   models achieve R 2 values of 0.896, 0.878, and 0.727 for equiaxed pores,
   unmelted regions, and cracks, respectively. These models further uncover
   dominant mechanisms, including current-distance interactions that govern
   thermal energy distribution and gas flow-feed rate coupling that
   influence particle trajectory. The inverse design engine converts target
   microstructures into manufacturing parameters with 92\% structural
   reproduction accuracy and 88\% parameter prediction accuracy.
   Experimental validation confirms that coatings designed for low thermal
   conductivity achieve 35-46\% reductions at 1000 degrees C relative to
   the data set average, realized with only two fabrication iterations. By
   explicitly decomposing the process-property relationship into
   interpretable process-structure and structure-property links, this
   framework shifts TBC development from empirical iteration into
   data-efficient, intelligent precision design and offers a generalizable
   strategy for interpretable materials design under data scarcity.},
Type = {Article; Early Access},
Affiliation = {Shan, X; Zhao, XF (Corresponding Author), Shanghai Jiao Tong Univ, Sch Mat Sci \& Engn, Shanghai Key Lab Adv High Temp Mat \& Precis Formin, Shanghai 200240, Peoples R China.
   Zhang, HC (Corresponding Author), Liaoning Acad Mat, Inst Coating Technol Hydrogen Gas Turbines, Shenyang 110167, Peoples R China.
   Huang, Tianmeng; Shan, Xiao; Zhang, Min; Cai, Huangyue; Lu, Jie; Zhao, Xiaofeng, Shanghai Jiao Tong Univ, Sch Mat Sci \& Engn, Shanghai Key Lab Adv High Temp Mat \& Precis Formin, Shanghai 200240, Peoples R China.
   Zhang, Hanchao; Wang, Jingyang, Liaoning Acad Mat, Inst Coating Technol Hydrogen Gas Turbines, Shenyang 110167, Peoples R China.},
DOI = {10.1021/acsami.6c00672},
EarlyAccessDate = {MAR 2026},
Keywords = {thermal barrier coatings; microstructure-mediated design; interpretable
   machinelearning; inverse design; atmospheric plasma spray},
Keywords-Plus = {CONDUCTIVITY; OPTIMIZATION; PARAMETERS; POROSITY; APS},
Author-Email = {scientist@sjtu.edu.cn
   zhanghc@lam.ln.cn
   xiaofengzhao@sjtu.edu.cn},
Number-of-Cited-References = {60},
Times-Cited = {0},
Unique-ID = {WOS:001719977800001},
}

@article{ WOS:001718865300001,
Author = {Jandrell, Joshua R. and Cox, Mitchell A.},
Title = {Learning highly oscillatory optical fields with Fourier feature networks},
Journal = {OPTICS LETTERS},
Year = {2026},
Volume = {51},
Number = {6},
Pages = {1538-1541},
Month = {MAR 15},
Abstract = {Accurately modelling physical perturbations in optical systems is
   critical for photonic device design, yet existing characterization
   methods are often computationally prohibitive. We introduce a
   data-efficient machine learning framework that learns the
   perturbation-dependent transmission matrix of a multimode fiber. To
   circumvent the spectral bias that prevents standard neural networks from
   resolving high-frequency phase changes, we explicitly encode
   perturbations into a Fourier Feature basis. This approach enables a
   compact multi-layer perceptron to learn the mapping from sparse training
   data with high fidelity. Using experimental data from a mechanically
   deformed fiber, our model achieves a 0.996 complex correlation with the
   ground truth, improving phase accuracy by an order of magnitude over
   standard networks while using significantly fewer parameters. This
   framework transforms the transmission matrix into a continuous,
   differentiable ``digital twin{''} of the system, providing a robust tool
   for characterizing complex media in rapidly evolving environments. (c)
   2026 Optica Publishing Group. All rights, including for text and data
   mining (TDM), Artificial Intelligence (AI) training, and similar
   technologies, are reserved.},
Type = {Article},
Affiliation = {Cox, MA (Corresponding Author), Univ Witwatersrand, Sch Elect \& Informat Engn, ZA-2050 Johannesburg, South Africa.
   Jandrell, Joshua R.; Cox, Mitchell A., Univ Witwatersrand, Sch Elect \& Informat Engn, ZA-2050 Johannesburg, South Africa.},
DOI = {10.1364/OL.585472},
Author-Email = {Mitchell.Cox@wits.ac.za},
Number-of-Cited-References = {11},
Times-Cited = {0},
Unique-ID = {WOS:001718865300001},
}

@article{ WOS:001707667000001,
Author = {Ding, Yizhe and Shi, Jiacheng and Lin, Yuqian and Sun, Qiya and Zhao,
   Yuxiang and Wang, Xi and Ping, Qian and Wang, Lin and Li, Yongmei},
Title = {Unraveling the ranitidine removal mechanism in a novel
   riboflavin-mediated ultraviolet/peracetic acid system: An integrated
   density functional theory-machine learning framework},
Journal = {JOURNAL OF HAZARDOUS MATERIALS},
Year = {2026},
Volume = {506},
Month = {MAR 15},
Abstract = {In this study, a novel riboflavin-mediated ultraviolet/peracetic acid
   system (RF/UV/PAA) was developed to enhance the degradation of
   ranitidine. Under optimal conditions, ranitidine was completely removed
   within 15 min, leading to a 68.9\% mineralization rate due to the
   combined action of radical (hydroxyl radicals (\& sdot;OH) and
   carbon-centered organic radicals (R-C \& sdot;) and nonradical (singlet
   oxygen (1O2)) reactive oxidative species (ROS). Electron paramagnetic
   resonance and quenching experiments indicated that RF significantly
   promoted ROS generation, with the respective contributions of \&
   sdot;OH, R-C \& sdot;and 1O2 to ranitidine removal being 54.5\%, 15.8\%,
   and 24.3\%, respectively. Demethylation, monooxygenation, dioxygenation,
   and C-S bond cleavage were identified as the primary degradation
   pathways for ranitidine. These pathways were initially inferred from
   structural analysis of transformation products (TPs) and subsequently
   validated through density functional theory (DFT) calculations and the
   TP-Transformer model. Furthermore, an integrated DFT-machine learning
   (ML) framework was employed to elucidate the degradation mechanism, with
   a specific focus on the interactions of principal molecular features
   with ROS. The results revealed that FractionCSP3 (SHAP value = 0.30) and
   MolWt (SHAP value = 0.44) were the dominant predictors of center dot OH
   and 1O2 reactivity, respectively, whereas FormalCharge (SHAP value =
   0.40) governed the R-C center dot-mediated processes. In addition,
   SHAP-based interaction analysis revealed that electron-rich sites
   facilitate center dot OH attack, conjugated It-systems promote 1O2
   reactivity, and molecular polarization drives R-C center dot reactions.
   Our study provides not only an effective technology for ranitidine
   removal but also a quantitative, interpretable framework for predicting
   reactivity and guiding the design of photo-assisted advanced oxidation
   processes.},
Type = {Article},
Affiliation = {Wang, L (Corresponding Author), Tongji Univ, Coll Environm Sci \& Engn, Shanghai 200092, Peoples R China.
   Ding, Yizhe; Shi, Jiacheng; Lin, Yuqian; Sun, Qiya; Ping, Qian; Wang, Lin; Li, Yongmei, Tongji Univ, Coll Environm Sci \& Engn, Shanghai 200092, Peoples R China.
   Sun, Qiya; Ping, Qian; Wang, Lin; Li, Yongmei, Shanghai Inst Pollut Control \& Ecol Secur, Shanghai 200092, Peoples R China.
   Zhao, Yuxiang, Univ Hong Kong, Dept Civil Engn, Environm Microbiome Engn \& Biotechnol Lab, Hong Kong 999077, Peoples R China.
   Wang, Xi, Tongji Architectural Design Grp Co Ltd, Environm Engn Branch, Shanghai 200092, Peoples R China.},
DOI = {10.1016/j.jhazmat.2026.141618},
Article-Number = {141618},
Keywords = {Riboflavin; Ultraviolet/peracetic acid; Machine learning; Density
   functional theory; Advanced oxidation process},
Keywords-Plus = {PERACETIC-ACID; DEGRADATION; WATER; PHARMACEUTICALS; OXYGEN},
Author-Email = {wanglin@tongji.edu.cn},
Number-of-Cited-References = {85},
Times-Cited = {0},
Unique-ID = {WOS:001707667000001},
}

@article{ WOS:001701618800001,
Author = {Chen, Chao and Liang, Rui and Ge, Yadong and Wang, Ruodong and Men,
   Yanhui and Tao, Junyu and Yan, Beibei and Cheng, Zhanjun and Lv, Xuebin
   and Chen, Guanyi},
Title = {Bio-diesel quality characterization towards bio-jet fuel production
   using infrared spectroscopy and an interpretable machine learning
   framework},
Journal = {JOURNAL OF ENVIRONMENTAL MANAGEMENT},
Year = {2026},
Volume = {402},
Month = {MAR 15},
Abstract = {Efficient utilization of renewable biomass resources requires advanced
   modeling and monitoring frameworks for resource optimization and
   sustainable management systems. Biodiesel-based bio-jet fuel is a green,
   sustainable, and carbon-neutral alternative for aviation, but its
   complex and unstable composition presents significant challenges in
   industrial production-particularly in the rapid and accurate
   characterization of key quality parameters, which remains unresolved.
   This study proposes an interpretability-oriented machine learning
   framework that leverages infrared spectral descriptors to predict and
   rationalize biodiesel quality attributes. Seven machine learning models
   were evaluated, with the ensemble model outperforming others by
   achieving a mean error of 6.83\%, RMSE of 1.43, and R2 of 0.95. The
   descriptor-driven approach significantly improved both predictive
   accuracy and model robustness under +/- 3 sigma perturbation. Shapley
   value-based comparative analysis across biodiesel indicators revealed
   both shared and indicator-specific infrared drivers, with olefinic = C-H
   stretching (3007 cm-1), and CH3 symmetric bending (1363 cm-1)
   consistently contributing across multiple targets, while ester C=O
   stretching (1741 cm-1), ester C-O stretching (1233 cm-1), and O-H
   stretching (3318 cm-1) exhibiting indicator-dependent importance.
   Furthermore, the study elucidates the mechanistic relationships between
   spectral peak positions, functional group types, and biodiesel
   properties. A user-friendly interface was developed to enable real-time
   fuel quality monitoring and data-driven process adjustment for online
   industrial deployment. Overall, this framework combines spectral
   analysis with AI-based assessment to enhance bioenergy utilization and
   supports scalable deployment of biomass-derived aviation fuels within
   sustainable resource management systems.},
Type = {Article},
Affiliation = {Yan, BB (Corresponding Author), Tianjin Univ, Sch Environm Sci \& Engn, Tianjin 300350, Peoples R China.
