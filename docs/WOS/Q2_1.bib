   Dai, Keren, Chengdu Univ Technol, State Key Lab Geohazard Prevent \& Geoenvironm Prot, Chengdu, Peoples R China.},
DOI = {10.1080/17538947.2024.2409337},
Article-Number = {2409337},
Keywords = {Co-seismic landslide; Ensemble learning; Landslide susceptibility
   mapping; Luding earthquake; Machine learning},
Keywords-Plus = {M-S 7.0; LOGISTIC-REGRESSION; OPTIMIZATION ALGORITHMS;
   QUANTITATIVE-ANALYSIS; FREQUENCY RATIO; NEURAL-NETWORKS; DECISION TREE;
   PREDICTION; CHINA; SICHUAN},
Author-Email = {zhangrui@swjtu.edu.cn},
