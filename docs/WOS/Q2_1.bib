DOI = {10.1016/j.swevo.2021.100913},
EarlyAccessDate = {JUN 2021},
Article-Number = {100913},
Keywords = {Genetic Programming; Stacking; Ensemble Learning; Stacked Generalization},
Keywords-Plus = {ENSEMBLES},
