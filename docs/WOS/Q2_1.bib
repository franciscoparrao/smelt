}

@article{ WOS:001652490400001,
Author = {Yang, Haili and Xia, Hao and Liu, Sai and Chen, Shan and Hu, Xinjun and
   Xie, Liangliang and Liao, Xilong and Fei, Lei and Han, Fuhao and Tian,
   Jianping and Chen, Manjiao and Zhou, Yuqi},
Title = {Dynamic Prediction of Reducing Sugar Content in Daqu Based on a Time
   Series-Microenvironment Coupled Stacking Model},
Journal = {FOOD ANALYTICAL METHODS},
Year = {2026},
Volume = {19},
Number = {1},
Month = {JAN 2},
Abstract = {Daqu serves as a key saccharifying and fermenting agent in Baijiu
   production, and its reducing sugar content has a significant impact on
   the aroma and quality of the liquor. However, traditional methods for
   measuring reducing sugar content in Daqu are complex and suffer from
   time lag, which makes monitoring and analyzing reducing sugar levels
   during fermentation difficult. Given the influence of environmental
   variables on the reducing sugar content in Daqu, this study aimed to
   propose a time-series prediction method by combining Daqu
   microenvironment parameters with a stacked ensemble learning approach.
   The microenvironment parameters were recorded and analyzed, and
   RF-Relief was used to identify the most important monitoring points from
   various environmental variables. Single models, including support vector
   regression (SVR), eXtreme Gradient Boosting (XGBoost), random forest
   (RF), and ridge regression (RR), as well as a stacking ensemble model
   (Stacking), were established, and their prediction accuracies for
   reducing sugar content were compared. The results showed that the
   stacking model significantly outperformed the single models, achieving
   R2 values of 0.9610, 0.9661, and 0.9501 for the upper, middle, and lower
   layers, respectively. This represented an improvement by 17.08\%,
   11.58\%, and 16.47\% over SVR; by 20.09\%, 15.23\%, and 14.86\% over
   XGBoost; by 10.12\%, 6.05\%, and 9.09\% over RF; and by 7.80\%, 10.60\%,
   and 15.81\% over RR. The proposed model enabled accurate real-time
   prediction of reducing sugar content, thereby overcoming the limitations
   of traditional methods and providing reliable data support for the
   intelligent regulation of the Daqu fermentation process.},
Type = {Article},
Affiliation = {Xia, H (Corresponding Author), Sichuan Univ Sci \& Engn, Sch Mech Engn, Yibin 644000, Peoples R China.
   Yang, Haili; Xia, Hao; Hu, Xinjun; Xie, Liangliang; Liao, Xilong; Fei, Lei; Han, Fuhao; Tian, Jianping; Chen, Manjiao; Zhou, Yuqi, Sichuan Univ Sci \& Engn, Sch Mech Engn, Yibin 644000, Peoples R China.
