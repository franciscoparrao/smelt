@article{ WOS:001626465900010,
Author = {Hong, Jin-Ki and Lee, Sang-Joon},
Title = {Out-of-Fold Stacking Regression for Rapid Prediction of Time-to-Exploit
   in Newly Disclosed Vulnerabilities},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {192246-192262},
Abstract = {The Time-To-Exploit (TTE), defined as the interval between vulnerability
   disclosure and exploitation, has recently contracted to only 3-5 days,
   making it a critical tactical indicator in modern cyber operations.
   Traditional risk- or threat-based response strategies are insufficient
   to address this acceleration. To overcome this limitation, this study
   proposes a Stacking Ensemble Regression framework for rapid and
   automated TTE prediction using only limited information available at the
   disclosure stage. The framework integrates heterogeneous features-Common
   Vulnerability Scoring System (CVSS) metrics, unstructured Common
   Vulnerabilities and Exposures (CVE) descriptions, and Proof-of-Concept
   (PoC) event counts-through tailored preprocessing and optimized base
   models. Their out-of-fold predictions are aggregated by a meta model to
   improve predictive accuracy. A series of multi-stage experiments was
   conducted for each feature type. Among 24 combinations for CVSS metrics,
   Target Encoding with Ridge Regression delivered the best performance;
   among 75 combinations for CVE descriptions, SecBERT embeddings with
   mean-max pooling, Principal Component Analysis (PCA), and CatBoost
   Regression achieved the highest accuracy; and for PoC event counts,
   log-transformed features with Linear Regression were selected. The final
   stacking configuration substantially outperformed of individual base
   models, and its predictive reliability was validated through
   explainability analysis and residual analysis. Unlike prior studies
   centered on static severity scores or categorical classification, our
   approach establishes a regression-oriented paradigm for time-based
   exploit prediction. The proposed framework provides practical value for
   patch prioritization, embargo estimation, dynamic micro-segmentation,
   and seamless integration with threat-intelligence platforms.},
Type = {Article},
Affiliation = {Lee, SJ (Corresponding Author), Chonnam Natl Univ, Sch Business Adm, Gwangju 61186, South Korea.
   Hong, Jin-Ki, Chonnam Natl Univ, Dept Informat Secur Convergence, Gwangju 61186, South Korea.
   Lee, Sang-Joon, Chonnam Natl Univ, Sch Business Adm, Gwangju 61186, South Korea.},
DOI = {10.1109/ACCESS.2025.3621226},
Keywords = {Measurement; Encoding; Predictive models; Stacking; Accuracy; Regression
   tree analysis; Overfitting; Ensemble learning; Prediction algorithms;
   Linear regression; BERT pre-trained model; CVE description; CVSS base
   metrics; hold-out blending ensemble; out-of-fold cross-validation; PoC
   count; regression model; SHAP explainability; stacking ensemble;
   time-to-exploit (TTE)},
Author-Email = {s-lee@jnu.ac.kr},
Number-of-Cited-References = {32},
Times-Cited = {0},
Unique-ID = {WOS:001626465900010},
}

@incollection{ WOS:001595952900027,
Author = {Jin, Huaiyu and Yao, Chen and Zhang, Wenkang and Chen, Hua},
Editor = {Lu, H},
Title = {Strategic Medical Text Classification with Improved Blending Ensemble
   Learning},
Booktitle = {ARTIFICIAL INTELLIGENCE AND ROBOTICS, ISAIR 2024, PT II},
Series = {Communications in Computer and Information Science},
Year = {2025},
Volume = {2403},
Pages = {296-305},
Abstract = {The rapid increase in medical data has underscored the importance of
   accurately and efficiently classifying medical texts. Traditional models
   often face challenges due to the specialized language and complex
   structures inherent in these texts. To tackle this challenge, this study
   proposes a cutting-edge blending ensemble learning framework, aimed at
   transforming the classification of complex medical texts. This framework
   integrates three specially developed hybrid learners: BERT-BiLSTM-DPCNN,
   ERNIE-BiLSTM-DPCNN, and eHealth-BiLSTMDPCNN. Each learner merges the
   strengths of various advanced deep learning models, focusing on thorough
   extraction and emphasis of key features in medical texts, thereby
   enriching the input for meta-learners. A unique aspect of this method is
   the combination of insights from meta-learners through a voting process,
   which significantly enhancing the classification's accuracy and
   reliability. Rigorous testing demonstrates that our approach markedly
   outperforms existing models in critical metrics, including accuracy,
   macro precision, macro recall, and macro F1 scores, showing notable
   improvements of 8.1\%, 6.9\%, 8.1\%, and 7.7\%, respectively. This study
   represents a significant advancement in medical text analysis.},
Type = {Proceedings Paper},
Affiliation = {Chen, H (Corresponding Author), Jiangxi Normal Univ, Nanchang 330022, Jiangxi, Peoples R China.
   Jin, Huaiyu; Yao, Chen; Zhang, Wenkang; Chen, Hua, Jiangxi Normal Univ, Nanchang 330022, Jiangxi, Peoples R China.},
DOI = {10.1007/978-981-96-2914-5\_27},
Keywords = {Pre-trained models; eHealth; Medical text classification; Blending;
   Ensemble learning},
Author-Email = {hua.chen@jxnu.edu.cn},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001595952900027},
}

@incollection{ WOS:001668832800013,
Author = {Kassab, Mohamad and Belbach, Walid},
Book-Group-Author = {ACM},
Title = {Automating Requirements Classification: A Systematic Literature Review
   and Ensemble LLM-Based Approach},
Booktitle = {PROCEEDINGS OF THE 29TH INTERNATIONAL CONFERENCE ON EVALUATION AND
   ASSESSMENT IN SOFTWARE ENGINEERING, EASE COMPANION 2025},
Year = {2025},
Pages = {82-90},
Abstract = {Accurately classifying software requirements into Functional
   Requirements (FR) and Non-Functional Requirements (NFR) categories is
   essential for project success, yet manual classification remains
   labor-intensive, highly domain-dependent, and prone to ambiguity. In
   this study, we first perform a systematic literature review of 81
   peer-reviewed studies, identifying key techniques and limitations for
   mapping requirements into FRs and NFRs and then mapping the identified
   NFRs to their corresponding quality attributes. Building on the findings
   from the review, we propose an automated ensemble tool that integrates
   four Large Language Models (LLMs) using weighted voting and meta-model
   stacking algorithms to enhance both accuracy and robustness of the
   classification. We evaluated our approach on a dataset of 984
   requirements. Our tool demonstrates improvements over single-model
   classification, achieving high precision in both FR/NFR distinction and
   NFR-attribute association. The dual methodological approach in this
   study contributes to the advancement of requirements engineering by
   laying the foundation for more efficient and precise classification
   methods.},
Type = {Proceedings Paper},
Affiliation = {Kassab, M (Corresponding Author), Boston Univ, Boston, MA 02215 USA.
   Kassab, Mohamad, Boston Univ, Boston, MA 02215 USA.
   Belbach, Walid, New York Univ Abu Dhabi, Abu Dhabi, U Arab Emirates.},
DOI = {10.1145/3727967.3756825},
Keywords = {Non-Functional Requirements; Quality Attributes; Requirements
   Classification; LLM; Ontology},
Keywords-Plus = {NONFUNCTIONAL REQUIREMENTS},
Author-Email = {mkassab@bu.edu
   wb2173@nyu.edu},
