   Tan, Chao; Chen, Hui, Yibin Univ, Control Sichuan Univ, Yibin 644000, Sichuan, Peoples R China.
   Chen, Hui, Yibin Univ, Hosp, Yibin 644000, Sichuan, Peoples R China.},
DOI = {10.1016/j.jfca.2023.105766},
