   Lu, Xiao-jun, Baotou Publ Secur Bur, Criminal Invest Detachment, Baotou, Inner Mongolia, Peoples R China.
   Wang, Liang, Second Mil Med Univ, Natl Ctr Liver Canc, Shanghai, Peoples R China.},
DOI = {10.3389/fmed.2022.1083474},
Article-Number = {1083474},
Keywords = {forensic pathology; machine learning; multi-organ fusion; lab-on-chip;
   post-mortem interval},
Keywords-Plus = {TIME; CLASSIFICATION; SELECTION; MUSCLE; DEATH; RNA; PMI; DEGRADATION;
   PROTEINS; MORTIS},
