   Li, Teng, Pingdingshan Polytenchn Coll, Acad Arts, Pingdingshan 467000, Henan, Peoples R China.},
DOI = {10.1038/s41598-025-90619-7},
Article-Number = {9580},
Keywords = {Music genre classification; Convolutional neural network; Deep learning;
   Capuchin search algorithm},
Keywords-Plus = {TRANSFORM; SELECTION; ENSEMBLE},
Author-Email = {1807050217@stu.hrbust.edu.cn
   15937539636@163.com},
Number-of-Cited-References = {44},
Times-Cited = {2},
Unique-ID = {WOS:001449593100005},
}

@article{ WOS:001376990800001,
Author = {Karadeli, Onur and Kaya, Kiymet and Oguducu, Sule Gunduz},
Title = {IHML: Incremental Heuristic Meta-Learner},
Journal = {APPLIED ARTIFICIAL INTELLIGENCE},
Year = {2024},
Volume = {38},
Number = {1},
Month = {DEC 31},
Abstract = {The landscape of machine learning constantly demands innovative
   approaches to enhance algorithms' performance across diverse tasks.
   Meta-learning, known as ``learning to learn{''} is a promising way to
   overcome these diversity challenges by blending multiple algorithms.
   This study introduces the IHML: Incremental Heuristic Meta-Learner, a
   novel meta-learning algorithm for classification tasks. By leveraging a
   variety of base-learners with distinct learning dynamics, such as
   Gaussian, tree, and instance, IHML offers a comprehensive solution
   adaptable to different data characteristics. Moreover, the core
   contributions of IHML lie in its ability to tackle the optimal
   base-learner and feature sets determination mechanism with the help of
   Explainable Artificial Intelligence (XAI) and heuristic elbow methods.
   Existing work in this context utilizes XAI mostly in pre-processing the
   data or post-analysis of the results, however, IHML incorporates XAI
   into the learning process in an iterative manner and improves the
   prediction performance of the meta-learner. To observe the performance
   of the proposed IHML, we used five different datasets from astrophysics,
   physics, biology, e-commerce, and economics. The results show that the
   proposed model achieves more accuracy (in average \% 10 and at most \%
   71 improvements) compared to the baseline machine learning models in the
   literature.},
Type = {Article},
Affiliation = {Karadeli, O (Corresponding Author), Istanbul Tech Univ, Fac Comp \& Informat, Dept Comp Engn, ITU Ayazaga Campus, TR-34469 Istanbul, Turkiye.
