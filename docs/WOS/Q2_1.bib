   Wang, Qing, Tsinghua Univ, Tsinghua Natl Lab Informat Sci \& Technol, Beijing 100084, Peoples R China.},
DOI = {10.3390/app9204317},
Article-Number = {4317},
Keywords = {recursive feature elimination with cross-validation; stacked
   generalization; large for gestational age; feature engineering; machine
   learning; bioinformatics},
Keywords-Plus = {BIRTH-WEIGHT; FETAL WEIGHT; CHILDHOOD; DELIVERY; INFANTS; INSULIN},
