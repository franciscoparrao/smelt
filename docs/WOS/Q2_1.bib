}

@article{ WOS:001659755500001,
Author = {Nasretdinova, Milena and Dowd, Peter and Xu, Chaoshui},
Title = {Lithological classification of drill cores using XCT and XRF data: a
   geometallurgical perspective},
Journal = {MINERALS ENGINEERING},
Year = {2026},
Volume = {237},
Month = {MAR},
Abstract = {This study presents an integrated framework for the automated
   lithological classification of drill cores by combining X-ray computed
   tomography (XCT) and X-ray fluorescence (XRF) data within a machine
   learning setting. A total of 293 m of drill cores from the Kalkaroo
   copper-gold deposit in South Australia were classified into five
   lithological categories at 5 cm intervals. XCT voxel attenuation values
   were summarised using percentile-based descriptors to capture density
   and textural variability, while XRF provided complementary geochemical
   information. Random Forest (RF) and Extreme Gradient Boosting (XGBoost)
   classifiers were applied using drill hole-wise leave-one-out
   cross-validation to mitigate spatial autocorrelation. The integrated
   XCT-XRF dataset outperformed single-modality inputs, with the XGBoost
   method achieving the highest predictive performance (Macro-F1 = 0.86).
   SHapley Additive exPlanations (SHAP) revealed that Cu, Fe, S, Ca, and K
   were the dominant discriminators, while high-end XCT percentiles
   enhanced the resolution of dense sulphide phases. This proved critical
   for distinguishing chalcopyrite-rich intervals, which govern copper
   recovery and concentrate grade, from pyrite-dominant horizons, which
   increase lime consumption and depress flotation selectivity. Downhole
   analysis confirmed the geological plausibility of predictions and
   highlighted transitions with implications for blending, comminution
   energy and metallurgical forecasting. The results demonstrate that
   XCT-XRF integration provides robust, interpretable, high-resolution
   lithology classification with geometallurgical relevance. Quantitative
   calibration to comminution indices or flotation performance requires
   additional datasets and is outside the scope of the present study.},
Type = {Article},
Affiliation = {Nasretdinova, M (Corresponding Author), Univ Adelaide, Australian Res Council Training Ctr Integrated Ope, Adelaide 5005, Australia.
   Nasretdinova, Milena; Dowd, Peter; Xu, Chaoshui, Univ Adelaide, Australian Res Council Training Ctr Integrated Ope, Adelaide 5005, Australia.
   Nasretdinova, Milena; Dowd, Peter; Xu, Chaoshui, Univ Adelaide, Fac Sci Engn \& Technol, Adelaide 5005, Australia.},
DOI = {10.1016/j.mineng.2025.110053},
EarlyAccessDate = {JAN 2026},
Article-Number = {110053},
Keywords = {X-ray computed tomography; X-ray fluorescence; Random forest; XGBoost;
   Chalcopyrite-pyrite discrimination; Geometallurgy},
Keywords-Plus = {COMPUTED-TOMOGRAPHY; DEPOSIT; EXPLORATION},
Author-Email = {milena.nasretdinova@adelaide.edu.au},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001659755500001},
}

@article{ WOS:001659302000001,
Author = {Khan, Muhammad Farhan and Hu, Sile and Gao, Yuan and Guo, Yu and Wang,
   Yuan and Saeed, Maryam and Zhao, Yucan and Yang, Jiaqiang},
Title = {A hybrid reinforcement learning framework for adaptive multi-horizon
   electricity load forecasting: The DWRNet approach},
Journal = {COMPUTERS \& ELECTRICAL ENGINEERING},
Year = {2026},
Volume = {131},
Month = {MAR},
Abstract = {Accurate and adaptive multi-horizon electricity load forecasting is
   essential for secure operation of modern power systems and for the
   integration of variable renewable generation. This paper proposes
   DWRNet, a Dynamic Weighted Residual Network that combines statistical
   decomposition, deep residual learning, and reinforcement learning
   (RL)-based adaptive fusion. A Fruit Fly Optimization-tuned Holt-Winters
   model first extracts the dominant seasonal-trend component, while a Long
   Short-Term Memory (LSTM) network learns the nonlinear residual
   structure. A continuous-action policy-gradient controller then produces
   horizon-dependent convex weights that balance the statistical and neural
   forecasts, enabling the ensemble to adapt to changing load regimes while
   remaining lightweight enough for EMS/SCADA deployment. DWRNet is
   evaluated on four years of hourly load data from two structurally
   different power systems (Inner Mongolia, China and Germany) over 24 h,
   168 h, and 720 h horizons, and compared against strong baselines
   including SVR, LSTM, GRU, CNN, CNN-LSTM, and recent Transformer-based
   models (Informer, FEDformer) under a common rolling-origin protocol.
   Across both regions and all horizons, DWRNet consistently achieves the
   best or near-best MAE, RMSE, sMAPE and R2 values, with particularly
   notable gains on weekly and monthly forecasts. Robustness is assessed
   through crossvalidation with varying training fractions, bootstrap-based
   confidence intervals, ablation studies, and residual diagnostics, which
   collectively indicate that the improvements are stable and not
   attributable to overfitting. A complexity analysis and runtime
   benchmarks further show that the RL-based blending stage adds only
   modest offline training cost and negligible inference overhead. DWRNet
   offers a practical and scalable solution for real-time energy
   forecasting, with strong potential for use in energy management systems,
   dispatch operations, and smart grid planning.},
Type = {Article},
Affiliation = {Yang, JQ (Corresponding Author), Zhejiang Univ, Coll Elect Engn, Hangzhou 310027, Peoples R China.
   Khan, Muhammad Farhan; Hu, Sile; Gao, Yuan; Guo, Yu; Saeed, Maryam; Zhao, Yucan; Yang, Jiaqiang, Zhejiang Univ, Coll Elect Engn, Hangzhou 310027, Peoples R China.
   Hu, Sile; Guo, Yu, Zhejiang Univ, Inner Mongolia Elect Power Grp Co Ltd, Hangzhou 310001, Peoples R China.
   Wang, Yuan, Inner Mongolia Elect Power Econ \& Technol Res Inst, Hohhot 010020, Peoples R China.},
DOI = {10.1016/j.compeleceng.2025.110926},
EarlyAccessDate = {JAN 2026},
Article-Number = {110926},
Keywords = {Electricity load forecasting; Reinforcement learning; Hybrid models;
   LSTM; Holt-winters exponential smoothing; Dynamic ensemble learning;
   EMS/SCADA},
Keywords-Plus = {FLY OPTIMIZATION ALGORITHM; CONSUMPTION; DEMAND; REGRESSION; ARIMA;
   MODEL},
