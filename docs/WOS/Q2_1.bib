   Corcho, Oscar, Univ Politecn Madrid, Grp Ingn Ontol, Madrid 28660, Spain.
   Teruel, Miguel A.; Trujillo, Juan, Alicante Inst Hlth \& Biomed Res ISABIAL, Alicante 03010, Spain.},
DOI = {10.1109/ACCESS.2024.3406332},
Keywords = {Electroencephalography; Convolutional neural networks; Epilepsy; Brain
   modeling; Feature extraction; Support vector machines; Deep learning;
