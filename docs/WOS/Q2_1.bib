DOI = {10.1016/j.dibe.2024.100574},
Article-Number = {100574},
Keywords = {Ultra-high performance concrete; Supplementary cementitious materials;
   Dynamic strength; Artificial intelligence; Graphical user interface},
Keywords-Plus = {STRESS-STRAIN RELATIONSHIP; MECHANICAL-PROPERTIES; STEEL FIBER;
   BEHAVIOR; MODEL},
