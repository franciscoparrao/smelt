@article{ WOS:001689412700001,
Author = {Chen, Jian and Deng, Zhicheng and Wan, Jinquan and Wang, Yan and Yu,
   Suhua and Mo, Wanqiu},
Title = {Joint optimization of prediction and control under data-limited
   conditions: Enhanced modeling of wastewater treatment processes based on
   the TEASG optimization framework},
Journal = {JOURNAL OF WATER PROCESS ENGINEERING},
Year = {2026},
Volume = {83},
Month = {MAR},
Abstract = {Wastewater treatment plants (WWTPs) are facing the dual challenges of
   digital modeling and control optimization. To address the issues of
   insufficient model accuracy and control strategy misalignment in
   scenarios with limited data, this study proposes a optimization
   framework based on multimodule collaborative, which consists of five
   major modules: (1) Task decomposition mechanism to determine the
   modeling type for target variables; (2) Use of empirical mode
   decomposition (EMD) and feature reconstruction to enhance feature
   representation capabilities; (3) Data augmentation combined with
   trend-aware techniques to generate data samples; (4) Construction of a
   two-layer stacked ensemble learning architecture to complement the
   advantages of XGBoost, CatBoost, LightGBM, and RF algorithms; (5)
   Indicating feature interaction mechanisms based on interpretable machine
   learning methods. The predictive models for effluent total nitrogen
   (TNeff) and total electricity consumption (TEC) demonstrated that after
   optimization through the EMD-based feature reconstruction-data
   augmentation-model stacking three-module collaboration, the
   classification model accuracy improved by 12.9\% to 26.0\%, the R2 of
   the regression model increased by 6.6\% to 41.3\%, and the RMSE is
   reduced by 24.3\% to 32.5\%. The optimized TNeff models had an R2 value
   of 0.791 accuracy (classification) and 0.804 (regression), while the TEC
   models reached 0.814 accuracy and 0.924. The (GAM)-Shapley additive
   explanations (SHAP) based control strategy reduced TNeff and TEC by
   31.7\% and 21.4\% in single-objective optimization, and simultaneously
   by 13.4\% and 18.4\% under multi-objective optimization. The
   optimization framework proposed in this study provides a solution for
   WWTP intelligence in data-scarce environments by combining improved
   predictive accuracy and process-control guidance.},
Type = {Article},
Affiliation = {Wan, JQ (Corresponding Author), South China Univ Technol, Coll Environm \& Energy, Guangzhou 510006, Peoples R China.
   Chen, Jian; Wan, Jinquan; Wang, Yan, South China Univ Technol, Coll Environm \& Energy, Guangzhou 510006, Peoples R China.
   Deng, Zhicheng, Haitian Water Grp Co Ltd, Chengdu 610000, Peoples R China.
   Yu, Suhua; Mo, Wanqiu, Dongguan Dongjiang Testing Co Ltd, Dongguan 523000, Peoples R China.},
DOI = {10.1016/j.jwpe.2026.109676},
EarlyAccessDate = {FEB 2026},
Article-Number = {109676},
Keywords = {Wastewater treatment plant; Machine learning; Predictive performance
   optimization; XAI; Control guidance},
Author-Email = {ppjqwan@scut.edu.cn},
Number-of-Cited-References = {33},
Times-Cited = {0},
Unique-ID = {WOS:001689412700001},
}

@article{ WOS:001695576700001,
Author = {Farhad, Arshad and Lodhi, Muhammad Ali and Nisar, Farhan and Hadi,
   Hassan Jalil and Ahmad, Naveed and Ladan, Mohamad},
Title = {LSML-SF: a lightweight stacked ML approach for spreading factor
   allocation in mobile IoT LoRaWAN networks},
Journal = {FRONTIERS IN ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {9},
Month = {FEB 6},
Abstract = {The expansion of the Internet of Things (IoT) into consumer applications
   demands robust and energy-efficient communication protocols. Long-range
   wide area network (LoRaWAN) is a key enabler, but its performance
   depends on optimal spreading factor (SF) allocation, where traditional
   adaptive data rate (ADR) mechanisms are inadequate in dynamic
   environments. This study presents a novel lightweight stacked-ML
   approach for spreading factor (LSML-SF) allocation in mobile IoT LoRaWAN
   network. We propose a stacked ensemble model that jointly combines a
   linear stochastic gradient descent classifier (log-loss), a gradient
   boosting model, and a deep neural network (DNN) through a logistic
   regression meta-learner. The LSML-SF is trained on a vast dataset of
   225,109 samples generated from ns-3 simulations, and our model achieves
   an out-of-fold cross-validation accuracy of 85\%. Importantly, we
   demonstrate the practical feasibility of our approach through a rigorous
   computational analysis, showing the DNN component requires only 12,602
   parameters and 12.3k MAC operations per inference. When integrated into
   ns-3 simulations, our LSML-SF framework significantly outperforms
   traditional ADR mechanisms and existing ML approaches, improving the
   packet success ratio and reducing energy consumption, thereby extending
   the operational lifespan of consumer IoT devices.},
Type = {Article},
Affiliation = {Hadi, HJ (Corresponding Author), Prince Sultan Univ, Ctr Excellence Cyber Secur, Riyadh, Saudi Arabia.
   Farhad, Arshad, Bahria Univ, Dept Comp Sci, Islamabad, Pakistan.
   Lodhi, Muhammad Ali, Yangzhou Univ, Sch Informat Engn, Yangzhou, Peoples R China.
   Nisar, Farhan, Qurtaba Univ \& IT, Dept Phys \& Numer Sci, Peshawar, Pakistan.
   Hadi, Hassan Jalil, Prince Sultan Univ, Ctr Excellence Cyber Secur, Riyadh, Saudi Arabia.
   Ahmad, Naveed, Prince Sultan Univ, Software Engn Dept, Riyadh, Saudi Arabia.
   Ladan, Mohamad, Prince Sultan Univ, Coll Comp \& Informat Sci, Riyadh, Saudi Arabia.},
DOI = {10.3389/frai.2026.1704369},
Article-Number = {1704369},
Keywords = {Internet of Things (IoT); LoRaWAN; machine learning; resource
   allocation; spreading factor; stacked generalization},
Author-Email = {hhadi@psu.edu.sa},
