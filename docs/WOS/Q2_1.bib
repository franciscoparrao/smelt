   Bruno, Kansake A., SSR Min, Denver, CO USA.
   Kaba, Azupuri G. A., Western Technol Inc, 8305 Washington St. NE, Albuquerque, NM USA.},
DOI = {10.1007/s42461-022-00698-7},
EarlyAccessDate = {NOV 2022},
Keywords = {Stacked generalization; Machine learning; Vibration prediction;
   Blasting; Ensemble method},
Keywords-Plus = {PEAK PARTICLE-VELOCITY; AIR OVERPRESSURE; MODEL; CLASSIFICATION;
   SENSITIVITY; MACHINE},
