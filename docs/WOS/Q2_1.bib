@article{ WOS:000864754200002,
Author = {Mushtaq, Earum and Zameer, Aneela and Khan, Asifullah},
Title = {A two-stage stacked ensemble intrusion detection system using five base
   classifiers and MLP with optimal feature selection},
Journal = {MICROPROCESSORS AND MICROSYSTEMS},
Year = {2022},
Volume = {94},
Month = {OCT},
Abstract = {The proliferation of internet-connected services has led to significant
   growth of cyber- attacks often with devastating and grievous
   consequences. Malware is the key choice of weapon to perform any
   malevolent activity in the cyberspace. Sophisticated nature of
   cyber-attacks demand a strong intrusion detection system to secure the
   computing infrastructure as malicious software can interrupt data
   confidentiality by breaching its security system. An intrusion detection
   system with single classifier is unable to achieve significant results
   due to metamorphic and polymorphic nature of malware. In this work, we
   propose the stacked ensemble based intrusion detection system (SE-IDS)
   comprises decision tree, XGBoost, bagging classifier, extra tree and
   random forest as base leaners with multilayer perceptron (MLP) as
   meta-learner. Predictions from five base learners are used as an input
   to MLP for final classification. Benchmark dataset NSL-KDD is used to
   evaluate the proposed framework. Results in terms of performance
   indices, such as accuracy, precision, recall, F-score, detection rate,
   false alarm rate have been compared with existing techniques.
   Experimental evaluation confirms that proposed method has achieved
   desirable and promising gain in accuracy, detection rate and false alarm
   rate of 88.10\%, 0.87 and 0.17 on KDDTest(+), 78.72\%, 0.80 and 0.15 on
   KDDTest(-21) datasets respectively.},
Type = {Article},
Affiliation = {Zameer, A (Corresponding Author), Pakistan Inst Engn \& Appl Sci PIEAS, Dept Comp \& Informat Sci, PR Lab, Islamabad 45650, Pakistan.
   Mushtaq, Earum; Zameer, Aneela; Khan, Asifullah, Pakistan Inst Engn \& Appl Sci PIEAS, Dept Comp \& Informat Sci, PR Lab, Islamabad 45650, Pakistan.},
DOI = {10.1016/j.micpro.2022.104660},
EarlyAccessDate = {SEP 2022},
Article-Number = {104660},
Keywords = {Intrusion detection system; Anomaly detection; Stacking; Super learner;
   NSL-KDD},
Keywords-Plus = {NEURAL-NETWORK; ANOMALY DETECTION; MACHINE; CLASSIFICATION; FRAMEWORK;
   FOREST; IDS},
Author-Email = {aneelaz@pieas.edu.pk},
Number-of-Cited-References = {72},
Times-Cited = {30},
Unique-ID = {WOS:000864754200002},
}

@article{ WOS:000772634700003,
Author = {Qu, Na and Li, Zhongzhi and Li, Xiaoxue and Zhang, Shuai and Zheng,
   Tianfang},
Title = {Multi-parameter fire detection method based on feature depth extraction
   and stacking ensemble learning model},
Journal = {FIRE SAFETY JOURNAL},
Year = {2022},
Volume = {128},
Month = {MAR},
Abstract = {The losses caused by fire are becoming more and more serious, with the
   continuous development of social economy. If fire is detected as early
   as possible, the losses can be reduced more than 80\%. The detection
   accuracy of traditional single-parameter fire detection is low, which
   often leads to false and missing fire alarm. This paper proposes a
   multi-parameter fire detection method based on feature depth extraction
   and stacking ensemble learning model. Fire feature parameters, such as
   temperature, smoke concentration and CO concentration, are collected as
   the original data. The algorithms, based on XGboost, gradient boosted
   decision tree (GBDT), random forest and decision tree, are used to
   analyze and sort the importance of nine types of data, such as the slope
   of smoke concentration, the amplitude of CO concentration etc. Three
   types of data with high importance are selected to extract depth
   features using Hilbert Huang transform (HHT), one-dimensional
   convolution neural network (1D-CNN) and long short term memory neural
   network (LSTMNN). The extracted features are input into stacking
   ensemble learning model. Stacking ensemble learning model is a
   hierarchical combination learning classifier and improves the
   performance by learning the classification bias of the upper model.
   Experimental results show that the proposed method has higher accuracy,
   stability and efficiency against several single models (e.g., XGBoost,
   GBDT, and LSTMNN).},
Type = {Article},
Affiliation = {Qu, N (Corresponding Author), Shenyang Aerosp Univ, Sch Safety Engn, Shenyang 110136, Peoples R China.
