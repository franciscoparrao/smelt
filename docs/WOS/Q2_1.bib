   Hussein, Burhan Rashid, Univ Brunei Darussalam, Digital Sci Dept, Gadong, Brunei.},
DOI = {10.1109/CSDE53843.2021.9718387},
Keywords = {deep learning; ensemble learning; computer vision; plant species
   identification; convolutional neural networks},
