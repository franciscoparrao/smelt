   Yin, Shutao, China Agr Univ, Inst Modern Agr Ind, Chengdu 611430, Peoples R China.},
DOI = {10.1016/j.jfca.2023.105141},
EarlyAccessDate = {JAN 2023},
Article-Number = {105141},
Keywords = {Food analysis; Fluorescence hyperspectral imaging technology; Green tea;
   Adulteration; Non-destructive testing; Machine learning},
Keywords-Plus = {GRADE IDENTIFICATION; QUALITY-CONTROL},
Author-Email = {zhaoyp@sicau.edu.cn
   xulijia@sicau.edu.cn},
