Keywords-Plus = {LIGNOCELLULOSIC BIOMASS; HYDROGEN-PRODUCTION; MODEL COMPOUNDS; ADABOOST;
   GASIFICATION; OPTIMIZATION; PREDICTION; ALGORITHM; FUEL; CHALLENGES},
Author-Email = {dungtv@ut.edu.vn},
Number-of-Cited-References = {95},
