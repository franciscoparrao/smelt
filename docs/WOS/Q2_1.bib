   Karakilcik, Mehmet, Cukurova Univ, Fac Sci \& Letters, Dept Phys, TR-01330 Adana, Turkiye.},
DOI = {10.1016/j.est.2025.118720},
EarlyAccessDate = {OCT 2025},
Article-Number = {118720},
Keywords = {Renewable energy; Super Learner; Ensemble regression; Solar pond;
