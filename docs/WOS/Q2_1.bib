   Roose, James P.; Hubbard, Alan E., Univ Calif Berkeley, Div Biostat, Berkeley, CA 94720 USA.
   Suh, Insoo, Univ Calif San Francisco, Sect Endocrine Surg, San Francisco, CA 94143 USA.},
DOI = {10.1016/j.amjsurg.2020.11.055},
EarlyAccessDate = {JUL 2021},
Keywords = {Thyroidectomy; Machine learning; Surgical risk prediction},
Keywords-Plus = {RISK CALCULATOR; ACS NSQIP; REGRESSION; COMPLICATIONS; MORBIDITY;
   INFERENCE; SELECTION},
Author-Email = {cseib@stanford.edu},
Number-of-Cited-References = {29},
