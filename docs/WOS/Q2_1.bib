   Zammit-Mangion, M., Univ Malta, Dept Physiol \& Biochem, Msida, Malta.},
DOI = {10.1007/s13197-018-3131-0},
Keywords = {Adulteration; Chemometrics; EVOO; Spectrofluorimetry; Synchronised
   spectra; ANN; PLSR; PCA},
Keywords-Plus = {FATTY-ACID-COMPOSITION; 3-WAY METHODS; SPECTROMETRY; MULTIVARIATE},
