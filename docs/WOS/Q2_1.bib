Author = {Chatton, Arthur and Bally, Michele and Levesque, Renee and Malenica,
   Ivana and Platt, Robert W. and Schnitzer, Mireille E.},
Title = {Personalized dynamic super learning: an application in predicting
   hemodiafiltration convection volumes},
Journal = {JOURNAL OF THE ROYAL STATISTICAL SOCIETY SERIES C-APPLIED STATISTICS},
Year = {2025},
Volume = {74},
Number = {3},
Pages = {617-637},
Month = {JUN},
Abstract = {Obtaining continuously updated predictions is a major challenge for
   personalized medicine. Leveraging combinations of parametric regressions
   and machine learning algorithms, the personalized online super learner
   (POSL) can achieve such dynamic and personalized predictions. We adapt
   POSL to predict a repeated continuous outcome dynamically and propose a
   new way to validate such personalized or dynamic prediction models. We
   illustrate its performance by predicting the convection volume of
   patients undergoing hemodiafiltration. POSL outperformed its candidate
   learners with respect to median absolute error,
   calibration-in-the-large, discrimination, and net benefit. We finally
   discuss the choices and challenges underlying the use of POSL.},
