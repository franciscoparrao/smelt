}

@article{ WOS:001699045600001,
Author = {Koleilat, Line and Paasche, Christian Karl and Wade, Jonathan and
   Hanson, Joshua and Wassgren, Carl and Mort, Paul},
Title = {Regime map of a toroidal fluid bed granulator - Challenging formulation},
Journal = {CHEMICAL ENGINEERING RESEARCH \& DESIGN},
Year = {2026},
Volume = {227},
Pages = {811-820},
Month = {MAR},
Abstract = {Fluidized bed granulation of fine cohesive powders can be challenging
   due to poor fluidization and fines elutriation. This study investigates
   toroidal fluid bed granulation of a pharmaceutical formulation
   containing 50\% micronized acetaminophen, focusing on the effects of
   airflow rate, inlet air temperature, and binder spray rate.
   Additionally, a prewetting step, involving pre-blending a small amount
   of water to the powder blend prior to charging, was introduced to
   improve particle adhesion and reduce elutriation of the micronized
   active. The combination of prewetting and the toroidal airflow pattern
   stabilized fluidization and promoted uniform granule growth. Integrated
   mass, energy, and pressure analyses were used to develop a regime map
   linking process parameters, moisture gain, and granule properties. The
   resulting framework defines a stable operating region for this cohesive
   formulation, supporting robust scale-up and process optimization in
   pharmaceutical granulation.},
Type = {Article},
Affiliation = {Koleilat, L (Corresponding Author), Purdue Univ, Dept Agr \& Biol Engn, W Lafayette, IN 47907 USA.
   Koleilat, Line, Purdue Univ, Dept Agr \& Biol Engn, W Lafayette, IN 47907 USA.
   Paasche, Christian Karl, Huttlin GmbH Syntegon Co, Schopfheim, Germany.
   Wade, Jonathan; Hanson, Joshua, Eli Lilly \& Co, Indianapolis, IN USA.
   Wassgren, Carl, Purdue Univ, Sch Mech Engn, W Lafayette, IN 47907 USA.
   Mort, Paul, Purdue Univ, Sch Mat Engn, W Lafayette, IN 47907 USA.},
DOI = {10.1016/j.cherd.2026.02.045},
Keywords = {Ensemble regression; Image analysis; Size and shape characterization;
