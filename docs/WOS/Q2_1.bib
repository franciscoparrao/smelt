Keywords-Plus = {TRANSIENT MODEL; PERFORMANCE; OPTIMIZATION},
Author-Email = {ibozkurt@adiyaman.edu.tr},
Number-of-Cited-References = {37},
Times-Cited = {3},
Unique-ID = {WOS:001591128000001},
}

@article{ WOS:001548891900001,
Author = {Ammar, Muhammad and Javaid, Nadeem and Arishi, Ali},
Title = {An AI explained systematic modular approach for enhanced Electricity
   Theft Detection for urbanized Smart Grid environment},
Journal = {ALEXANDRIA ENGINEERING JOURNAL},
Year = {2025},
Volume = {129},
Pages = {998-1023},
Month = {OCT},
Abstract = {Electricity theft is a major issue that disrupts utilities and
   compromises the stability of urbanized Smart Grids (SG), leading to
   significant financial losses, operational disruptions, and compromised
   system stability. Traditional detection systems often face challenges
   like severe data discrepancies, high class imbalance, and volatile
   consumption patterns, which hinder their ability to detect abnormal
   movements and limit system dependability. To tackle these challenges, we
   propose a systematic modular approach that consists of three modules,
   Module-1: Data Pre-processing, Module-2: Data Balancing, and Module-3:
   Blending Classification. Initially, the data pre-processing module
   imputes missing values with interpolation, handles outliers with the
   three-sigma rule, and normalizes data with min-max scaling methods to
   enhance data quality for robust model training. Subsequently, the data
   balancing module leverages the localized randomized affine shadow
   sampling to maintain a balanced data distribution by addressing the
   class imbalance problem. Finally, the proposed SATBlend in the
   classification module utilizes AlexNet for feature extraction,
   ShuffleNet for efficient computation, and a temporal convolutional
   network for temporal correlation detection to enhance the reliability of
   advanced ETD systems. In addition to its application on the state grid
   corporation of China dataset, we evaluate SATBlend on the Pakistan
   residential electricity consumption dataset, demonstrating its
   robustness and scalability across varied real-world datasets. The
   experimental results reveal that SATBlend outperforms state-of-the-art
   machine and deep learning techniques with improved accuracy of 4\% and
   2\%, recall of 2\% and 1\%, F1-score of 2\% and 1\%, and receiver
   operating characteristic area under the curve of 3\% and 2\% for both
   datasets, respectively.Further, the 10-fold cross-validation method
   validates the main findings to prove the generalizability of the
   SATBlend model. Finally, to improve both local and global
   interpretability and explainability of SATBlend's predictions,
   explainable artificial intelligence techniques are employed, including
   local interpretable model-agnostic explanations and Shapley additive
   explanations. The results show that the well-constructed SATBlend model
   is effective in improving the detection of electricity theft while
   strengthening SG's operational and infrastructure capabilities.},
Type = {Article},
Affiliation = {Javaid, N (Corresponding Author), Natl Yunlin Univ Sci \& Technol, Int Grad Sch Artificial Intelligence, ComSens Lab, Touliu 64002, Yunlin, Taiwan.
   Ammar, Muhammad; Javaid, Nadeem, Natl Yunlin Univ Sci \& Technol, Int Grad Sch Artificial Intelligence, ComSens Lab, Touliu 64002, Yunlin, Taiwan.
   Arishi, Ali, King Khalid Univ, Dept Ind Engn, Abha 61421, Saudi Arabia.
   Arishi, Ali, King Khalid Univ, Ctr Engn \& Technol Innovat, Abha 61421, Saudi Arabia.},
DOI = {10.1016/j.aej.2025.07.040},
EarlyAccessDate = {AUG 2025},
Keywords = {AlexNet; Blending; Data balancing; Deep learning; Electricity Theft
   Detection; Local interpretable model-agnostic; explanations; Pakistan
   residential electricity consumption; Shapley additive explanations;
   ShuffleNet; Smart Grids; State grid corporation of China; Temporal
   convolutional network; 10-fold cross-validation},
Author-Email = {javaidn@yuntech.edu.tw},
Number-of-Cited-References = {37},
Times-Cited = {3},
Unique-ID = {WOS:001548891900001},
}

@article{ WOS:001548514000011,
Author = {Chen, Yingchi and Wang, Qinhui and Xie, Guilin and Tian, Zhihua and
   Zhang, Bin and Yue, Jiahe},
Title = {Sparse principal component analysis and SHAP-based explainable framework
   for SO2 concentration prediction: A multi-method stacked ensemble model},
Journal = {JOURNAL OF ENVIRONMENTAL CHEMICAL ENGINEERING},
Year = {2025},
Volume = {13},
Number = {5},
Month = {OCT},
Abstract = {This study developed an ensemble learning stacked model for predicting
   SO2 pollutant emissions based on multiple machine learning models. The
   research dataset was subjected to high-dimensional feature reduction
   using Sparse Principal Component Analysis (SPCA). Subsequently, the
   model integrated the stacked generalization ensemble method with the
   Shapley interpretation method. This integration enabled high-precision
   prediction of the initial SO2 pollutant concentration at the outlet of
   coal-fired boilers. This stacking ensemble method incorporates 17
   machine learning models in the base model pool, such as LightGBM,
   XGBoost, and CatBoost. It also integrates three stacking approaches on
   the meta-learner: the averaging method, the combination weight method,
   and the linear regression method. The results indicate that the stacked
   model demonstrates excellent predictive performance on a test set of
   over 3000 unseen data points. In the proposed integrated model, Stacked
   Model 3 (Ridge Regression Stacking) demonstrated the best performance in
   SO2 concentration prediction, surpassing other models and achieving
   optimal results on key evaluation metrics: MAE (42.421), MAPE (0.008),
   MSE (10395.3), RMSE (101.957),R2(0.979). SHAP analysis reveals the
   impact of features on the model's predictions, the past time series
   features are the most influential characteristics on the base model's
   prediction results. This study differs from traditional single-model
   prediction methods by proposing an ensemble approach that integrates
   multiple complementary base models and stacking techniques. This method
   not only provides a novel technical means for SO2 prediction in
   coal-fired boilers but also offers feasible references and solutions for
   pollution control and monitoring in other industrial sectors.},
Type = {Article},
Affiliation = {Wang, QH (Corresponding Author), Zhejiang Univ, State Key Lab Clean Energy Utilizat, Hangzhou 310027, Peoples R China.
   Chen, Yingchi; Wang, Qinhui; Xie, Guilin; Tian, Zhihua; Zhang, Bin; Yue, Jiahe, Zhejiang Univ, State Key Lab Clean Energy Utilizat, Hangzhou 310027, Peoples R China.},
DOI = {10.1016/j.jece.2025.118330},
EarlyAccessDate = {AUG 2025},
Article-Number = {118330},
Keywords = {Machine learning; Pollutant forecasting; Stacked ensemble model; SHapley
   additive explanations; Sparse principal component analysis},
Keywords-Plus = {NEURAL-NETWORK; EMISSIONS},
Author-Email = {qhwang@zju.edu.cn},
Number-of-Cited-References = {47},
Times-Cited = {3},
Unique-ID = {WOS:001548514000011},
}

@article{ WOS:001535490900001,
