DOI = {10.3389/fnins.2021.754058},
Article-Number = {754058},
Keywords = {blending; multimodal data processing; Parkinson's disease; support
   vector machine; voting based ensembles},
Keywords-Plus = {CONVOLUTIONAL NEURAL-NETWORKS; SIGNAL-PROCESSING ALGORITHMS; VOICE
