   Tranel, Daniel, Univ Iowa, Dept Psychol \& Brain Sci, Iowa City, IA USA.
   Boes, Aaron D., Univ Iowa, Carver Coll Med, Dept Psychiat, Iowa City, IA USA.
   Boes, Aaron D., Univ Iowa, Iowa Neurosci Inst, Iowa City, IA 52242 USA.},
DOI = {10.1002/hbm.70115},
Article-Number = {e70115},
Keywords-Plus = {LANGUAGE},
Author-Email = {jcgriffis@uiowa.edu},
Number-of-Cited-References = {51},
Times-Cited = {3},
Unique-ID = {WOS:001382627100001},
}

@article{ WOS:001383749600001,
Author = {Nguyen, Hai-Long and Pham, Van Su and Le, Hai-Chau},
Title = {Blending Ensemble Learning Model for 12-Lead Electrocardiogram-Based
   Arrhythmia Classification},
Journal = {COMPUTERS},
Year = {2024},
Volume = {13},
Number = {12},
Month = {DEC},
Abstract = {The increasing prevalence of heart diseases has driven the development
   of automated arrhythmia classification systems using machine learning
   and electrocardiograms (ECGs). This paper presents a novel ensemble
   learning method for classifying multiple arrhythmia types using 12-lead
   ECG signals through a blending technique. The framework employs a
   predetermined meta-model from foundation models, while the remaining
   models serve as potential base estimators, ranked by accuracy. Using
   sequential forward selection and meta-feature augmentation, the system
   determines an optimal base estimator set and creates a meta-dataset for
   the meta-model, which is optimized through grid search with k-fold
   cross-validation. Experiments conducted with seven diverse machine
   learning algorithms (Adaptive Boosting, Extreme Gradient Boosting,
   Decision Trees, k-Nearest Neighbors, Logistic Regression, Random Forest,
   and Support Vector Machine) demonstrate that the proposed blending
   solution, utilizing an LR meta-model with three optimal base models,
   achieves a superior classification accuracy of 96.48\%, offering an
   effective tool for clinical decision support.},
Type = {Article},
Affiliation = {Le, HC (Corresponding Author), Posts \& Telecommun Inst Technol, Data \& intelligent Syst Lab, Hanoi 10000, Vietnam.
   Le, HC (Corresponding Author), Posts \& Telecommun Inst Technol, Dept Data Engn, Hanoi 10000, Vietnam.
   Nguyen, Hai-Long; Le, Hai-Chau, Posts \& Telecommun Inst Technol, Data \& intelligent Syst Lab, Hanoi 10000, Vietnam.
   Pham, Van Su, Posts \& Telecommun Inst Technol, Fac Elect Engn, Hanoi 10000, Vietnam.
   Le, Hai-Chau, Posts \& Telecommun Inst Technol, Dept Data Engn, Hanoi 10000, Vietnam.},
DOI = {10.3390/computers13120316},
