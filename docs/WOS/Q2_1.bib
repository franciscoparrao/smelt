   Falson, Pierre, Lyon 1 Univ Lab, IBCP, CNRS, UMR 5086,Drug Resistance \& Membrane Prot Grp, F-69367 Lyon 07, France.
   Tran-Nguyen, Viet-Khoa, Univ Paris Cite, CNRS, INSERM, U1133,UMR8251, F-75013 Paris, France.},
DOI = {10.1021/acs.jcim.5c00374},
EarlyAccessDate = {APR 2025},
Keywords-Plus = {PERFORMANCE; RESISTANCE; HISTORY},
Author-Email = {viet-khoa.tran-nguyen@u-paris.fr
   Ahcene.Boumendjel@univ-grenoble-alpes.fr},
