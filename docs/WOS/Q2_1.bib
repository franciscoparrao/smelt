DOI = {10.18494/SAM4530},
Keywords = {SVR; LASSO; RIDGE; stacking model; sensor},
Keywords-Plus = {SUPPORT VECTOR MACHINE; REGRESSION},
Author-Email = {cltung@ncut.edu.tw},
