   Gupta, Deepali; Goyal, Nitin, Chitkara Univ, Chitkara Univ Inst Engn \& Technol, Chandigarh, Punjab, India.},
DOI = {10.32604/cmc.2022.021747},
Keywords = {Disease prediction; stack ensemble; neural network autoregression;
   exponential smoothing; auto-ARIMA; holt winter},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {dr.nitingoyal30@gmail.com},
