}

@incollection{ WOS:001289647200222,
Author = {Ibrar, Muhammad and Akbar, Aamir and Shah, Nadir and Erbad, Aiman and
   Ali, Kamran},
Book-Group-Author = {IEEE},
Title = {LRS2: Improved Link Recovery in Software-Defined Networks
   with Stacked Generalization Ensemble},
Booktitle = {20TH INTERNATIONAL WIRELESS COMMUNICATIONS \& MOBILE COMPUTING
   CONFERENCE, IWCMC 2024},
Series = {International Wireless Communications and Mobile Computing Conference},
Year = {2024},
Pages = {1339-1344},
Abstract = {Emerging megatrends like the Internet of Things (IoT), and social and
   mobile communication technologies are imposing new challenges on the
   future Internet, for which path reliability is crucial. Traditional IP
   networks are complex to operate and difficult to configure because they
   are vertically integrated: data and control plane bundled. The emerging
   Software-Defined Networking (SDN) architecture breaks vertical
   integration and separates the control logic from the data plane devices,
   such as switches and routers, providing a programmable infrastructure
   for application deployment. As a result, SDN is positioned to compute a
   reliable path for connected users in the event of a link failure
   scenario. To minimize the impact of a link failure on ongoing data
   flows, the prediction of a link failure requires careful attention.
   Machine Learning (ML) algorithms play a vital role in the link failure
   prediction process; however, they often have a low detection rate. To
   achieve a higher link failure detection rate in SDN, there is a need to
   design an enriched detection architecture, especially when employing
   ensemble ML models. This work presents LRS2, which is a
   meta-classification approach using base classifiers to compute a highly
   reliable data flow path. LRS2 utilizes a stacked generalization
   ensemble, where the base classifiers with low complexity and high
   diversity receive the original data as input, and each classifier
   predicts its sub-problem. The output is a high degree of accuracy of a
   meta-classifier in predicting a link's failure. Our experimental study
   demonstrates that the stacking ensemble has higher accuracy in
   predicting link failures than other ensembles or single classifiers used
   in the LRS2.},
Type = {Proceedings Paper},
Affiliation = {Akbar, A (Corresponding Author), Abdul Wali Khan Univ Mardan, Dept Comp Sci, Mardan, Pakistan.
   Ibrar, Muhammad; Erbad, Aiman, Hamad Bin Khalifa Univ, Coll Sci \& Engn, Doha, Qatar.
   Akbar, Aamir, Abdul Wali Khan Univ Mardan, Dept Comp Sci, Mardan, Pakistan.
   Shah, Nadir; Ali, Kamran, COMSATS Univ, Dept Comp Sci, Wah Campus, Wah, Pakistan.},
DOI = {10.1109/IWCMC61514.2024.10592609},
Keywords = {Software-Defined Networking; Links Reliability; Machine Learning;
   Stacking Ensemble},
Author-Email = {amirakbar@awkum.edu.pk
   nadirshah82@gmail.com
   AErbad@hbku.edu.qa
   kamran.ali62@yahoo.com},
Number-of-Cited-References = {15},
Times-Cited = {0},
Unique-ID = {WOS:001289647200222},
}

@incollection{ WOS:001488384100054,
Author = {Mishra, Shashank and Liang, Jia-Ming},
Book-Group-Author = {IEEE},
Title = {Optimized Multi-Model Intrusion Detection Scheme for Internet of
   Vehicles},
Booktitle = {2024 27TH INTERNATIONAL SYMPOSIUM ON WIRELESS PERSONAL MULTIMEDIA
   COMMUNICATIONS, WPMC},
Series = {International Symposium on Wireless Personal Multimedia Communications},
Year = {2024},
Pages = {283-286},
Abstract = {Intelligent vehicles are increasingly connected to the external world,
   enabling functionalities like vehicle-to-vehicle (V2V) and
   vehicle-to-everything (V2X) communication and data transmission.
   However, improving connectivity also increases the vulnerability to
   cyber-security threats, raising concerns about data privacy,
   unauthorized access, and potential system interference. Due to
   insufficient authentication and encryption, Controller Area Network
   (CAN) and external network gateway in Internet of Vehicles (IoV) is
   highly susceptible to network attacks, necessitating robust intrusion
   detection systems (IDSs). In this paper, an optimized multi-model
   intrusion detection scheme is proposed for IoV using multi-model
   stacking ensemble framework, combining k-nearest neighbors (KNN),
   bagging classifier, and random forest (RF) models. The framework
   optimizes classification hyper parameters to enhance intrusion
   detection. Simulation and experiment results show that the proposed
   multi-model framework can effectively detect the intrusion by 99.9\% on
   average and maintains a lower time complexity, thereby enhancing overall
   intra-vehicle and external network efficiency.},
Type = {Proceedings Paper},
Affiliation = {Liang, JM (Corresponding Author), Natl Univ Tainan, Tainan 700, Taiwan.
   Liang, JM (Corresponding Author), Univ Minnesota, Minneapolis, MN 55455 USA.
   Mishra, Shashank; Liang, Jia-Ming, Natl Univ Tainan, Tainan 700, Taiwan.
   Liang, Jia-Ming, Univ Minnesota, Minneapolis, MN 55455 USA.},
DOI = {10.1109/WPMC63271.2024.10863238},
Keywords = {intrusion detection; stacking ensemble; internet of vehicles (IoV);
   vehicle-to-vehicle (V2V)},
Author-Email = {jmliang@mail.nutn.edu.tw},
Number-of-Cited-References = {13},
Times-Cited = {0},
