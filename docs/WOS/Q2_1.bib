}

@article{ WOS:001683800600010,
Author = {Zhang, Lie-Ping and Zheng, Xin-Peng and Wang, Shou-Feng and Liu,
   Jin-Ming and Leng, Zhong-Tao},
Title = {Indoor Visible Light Positioning Algorithm Based on JAYA-Blending},
Journal = {ENGINEERING LETTERS},
Year = {2026},
Volume = {34},
Number = {2},
Pages = {565-575},
Month = {FEB},
Abstract = {In response to the problems of low positioning accuracy and poor
   robustness in traditional single visible light positioning algorithms in
   complex indoor environments, this paper proposes an indoor visible light
   positioning algorithm based on JAYA-Blending. The method first collects
   visible light signals and constructs a fingerprint database. Then, an
   extreme learning machine and a random forest are used as base learners,
   and their key hyperparameters are optimized using the JAYA algorithm to
   enhance their performance. Finally, the Blending ensemble strategy is
   applied, where linear regression serves as the meta-learner to fuse and
   correct the output results of the base learners, thereby obtaining the
   final positioning coordinates. The obtained simulation results verify
   that the JAYA-Blending algorithm achieves an average positioning error
   of 1.04 cm, 1.12cm, 1.34cm, and 1.96cm at four different heights of 0m,
   0.3m, 0.6m, and 0.9m, respectively. Compared to single positioning
   algorithms and the Blending algorithm, the positioning accuracy improves
   by 28.21\% to 44.32\%, with smaller root mean square error and faster
   convergence of the cumulative distribution function curve, demonstrating
   better positioning accuracy and stability.},
Type = {Article},
Affiliation = {Wang, SF (Corresponding Author), Guilin Univ Aerosp Technol, Guangxi Key Lab Special Engn Equipment \& Control, Guilin 541004, Peoples R China.
   Zhang, Lie-Ping; Zheng, Xin-Peng; Wang, Shou-Feng; Liu, Jin-Ming; Leng, Zhong-Tao, Guilin Univ Aerosp Technol, Guangxi Key Lab Special Engn Equipment \& Control, Guilin 541004, Peoples R China.},
Keywords = {indoor positioning; visible light positioning; blending ensemble; JAYA
   algorithm},
