@article{ WOS:000361422600002,
Author = {Togashi, D. and Alvarez-Jubete, L. and Rifai, H. and Cama-Moncunill, R.
   and Cruise, P. and Sullivan, C. and Cullen, P. J.},
Title = {Evaluation of diffuse reflectance near infrared fibre optical sensors in
   measurements for chemical identification and quantification for binary
   granule blends},
Journal = {JOURNAL OF NEAR INFRARED SPECTROSCOPY},
Year = {2015},
Volume = {23},
Number = {3},
Pages = {133-144},
Abstract = {In recent years, the pharmaceutical industry has focused on a better
   understanding of the real-time manufacturing process with online
   measurements. Near infrared (NIR) spectroscopy is perhaps the most used
   and acceptable technique in such a highly regulated industry. However,
   one of the big challenges in using NIR systems for in-line manufacturing
   processes is the acquisition of measurements in real-time simultaneously
   at different locations. To this end, a series of different optical
   set-ups were investigated. Results are presented here using a multipoint
   NIR system based on a Fabry-Perot Interferometer capable of recording
   simultaneously four independent spectra in four different points. NIR
   spectra of cellulose and sucrose granule mixtures were evaluated by the
   partial least-squares (PLS) regression method. By interpreting score
   values, loading of the principal components and the root mean square
   errors of cross-validation (RMSECV), differences between two sensors
   composed of fibre optics and the effect of sampling (static or motion)
   were analysed. Sensors that allow large illumination and detection areas
   against small granule sizes showed better results in reducing the
   prediction errors (RMSECV= 1.8\%) than sensors with small illumination
   and detection areas against samples with large granule sizes (RMSECV=
   9.6\%). These results are important to better understand errors
   associated with optic fibre probes and their configuration in multipoint
   NIR spectroscopy for monitoring the pharmaceutical manufacturing
   process.},
Type = {Article},
Affiliation = {Sullivan, C (Corresponding Author), Dublin Inst Technol, Sch Food Sci \& Environm Hlth, Cathal Brugha St, Dublin 1, Ireland.
   Togashi, D.; Alvarez-Jubete, L.; Rifai, H.; Cama-Moncunill, R.; Sullivan, C.; Cullen, P. J., Dublin Inst Technol, Sch Food Sci \& Environm Hlth, Dublin 1, Ireland.
   Cruise, P., Innopharmalabs, Unit 311, Dublin 18, Ireland.
   Cullen, P. J., UNSW Australia, Sch Chem Engn, Sydney, NSW 2052, Australia.},
DOI = {10.1255/jnirs.1162},
Keywords = {near infrared spectroscopy; Fabry-Perot interferometer; partial
   least-squares; blending; granulation; fibre optics; active
   pharmaceutical ingredients},
Keywords-Plus = {NIR SPECTROSCOPY; PHARMACEUTICAL APPLICATIONS; BIOMEDICAL APPLICATIONS;
   TECHNOLOGY; PROBE; SIZE; SPECTROMETER; POWDERS},
Author-Email = {patrick.j.cullen@dit.ie},
Number-of-Cited-References = {30},
