   Hu, Guiping, Rochester Inst Technol, Golisano Inst Sustainabil, Dept Sustainabil, Rochester, NY 14623 USA.
   Pham, Hieu, Univ Alabama Huntsville, Coll Business, Huntsville, AL 35899 USA.},
DOI = {10.1016/j.mlwa.2022.100251},
Article-Number = {100251},
Keywords = {Ensemble; Stacking; Optimization; Bias-variance tradeoff;
   Hyperparameters},
Keywords-Plus = {DATA ENVELOPMENT ANALYSIS; RANDOM FORESTS; PERFORMANCE; STACKING;
   CLASSIFICATION; FRAMEWORK},
Author-Email = {mohsen@iastate.edu
