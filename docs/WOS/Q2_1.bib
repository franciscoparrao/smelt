@article{ WOS:000358988900006,
Author = {Allende-Cid, Hector and Allende, Hector and Monge, Raul and Moraga,
   Claudio},
Title = {Discrete Neighborhood Representations and Modified Stacked
   Generalization Methods for Distributed Regression},
Journal = {JOURNAL OF UNIVERSAL COMPUTER SCIENCE},
Year = {2015},
Volume = {21},
Number = {6},
Pages = {842-855},
Abstract = {When distributed data sources have different contexts the problem of
   Distributed Regression becomes severe. It is the underlying law of
   probability that constitutes the context of a source. A new Distributed
   Regression System is presented, which makes use of a discrete
   representation of the probability density functions (pdfs).
   Neighborhoods of similar datasets are detected by comparing their
   approximated pdfs. This information supports an ensemble-based approach,
   and the improvement of a second level unit, as it is the case in stacked
   generalization. Two synthetic and six real data sets are used to compare
   the proposed method with other state-of-the-art models. The obtained
   results are positive for most datasets.},
