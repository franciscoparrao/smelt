   Sabri, Budi Aslinie Md, Univ Teknol MARA UiTM, Fac Dent, Ctr Populat Oral Hlth \& Clin Prevent Studies, Sungai Buloh, Malaysia.},
DOI = {10.1038/s41415-025-9105-5},
