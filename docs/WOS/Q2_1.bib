   Li, Bing, Key Res Inst Yellow River Civilizat \& Sustainable, Kaifeng, Peoples R China.
   Lu, Wanyun, Zhejiang Acad Surveying \& Mapping, Hangzhou, Peoples R China.},
DOI = {10.7717/peerj-cs.3356},
