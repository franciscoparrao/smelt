   Wang, Qianyang; Yu, Jingshan, Beijing Normal Univ, Coll Water Sci, Beijing 100875, Peoples R China.},
DOI = {10.1016/j.ejrh.2024.101653},
EarlyAccessDate = {JAN 2024},
