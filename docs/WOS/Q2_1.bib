DOI = {10.1109/TSG.2020.2985070},
Keywords = {Forecasting; Biological system modeling; Predictive models; Numerical
   models; Data models; Stacking; Locational marginal price; short-term
   forecasting; electricity market; tree-based regression; model stacking\%},
Keywords-Plus = {ELECTRICITY PRICES; POWER; SELECTION; ACCURACY; LOAD},
