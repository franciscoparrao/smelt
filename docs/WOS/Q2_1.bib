   Elshewey, Ahmed M., Suez Univ, Fac Comp \& Informat, Comp Sci Dept, Suez, Egypt.},
DOI = {10.1016/j.bspc.2023.104908},
EarlyAccessDate = {MAR 2023},
Article-Number = {104908},
Keywords = {Machine learning; Ensemble learning; Linear discriminant analysis; Deep
   neural network; dipper throated; optimization},
Keywords-Plus = {RANDOM FOREST; CLASSIFIER; REGRESSION; GRADE},
Author-Email = {mahmoud.yasin@ai.kfs.edu.eg
