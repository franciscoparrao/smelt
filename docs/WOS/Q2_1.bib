   Univ N Carolina, Sch Nursing, Chapel Hill, NC 27599 USA.},
DOI = {10.1016/S0933-3657(00)00063-4},
Keywords = {self-organizing map; model selection; decision support system; neural
   network; stacked generalization},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; CORONARY-ARTERY DISEASE;
