   Yang, Haili; Hu, Xinjun; Xie, Liangliang; Chen, Manjiao, Brewing Sci \& Technol Key Lab Sichuan Prov, Yibin 644000, Peoples R China.},
DOI = {10.1007/s12161-025-02981-x},
Article-Number = {59},
Keywords = {Daqu microenvironment; Daqu reducing sugar; Stacking model; Time series},
Keywords-Plus = {TRADITIONAL CHINESE LIQUOR; FLAVOR; REGRESSION; ALGORITHM},
