@article{ WOS:000551529600001,
Author = {Larkin, Taylor and McManus, Denise},
Title = {An analytical toast to wine: Using stacked generalization to predict
   wine preference},
Journal = {STATISTICAL ANALYSIS AND DATA MINING},
Year = {2020},
Volume = {13},
Number = {5},
Pages = {451-464},
Month = {OCT},
Abstract = {Due to the intricacies surrounding taste profiles, one's view of good
   wine is subjective. Therefore, it is advantageous to provide a more
   objective, data-driven way to assess wine preferences. Motivated by a
   previous study that modeled wine preferences using machine learning
   algorithms, this work presents an ensemble approach to predict a wine
   sample's quality level given its physiochemical properties. Results show
   the proposed framework out-performs many sophisticated models including
   the one recommended by the motivational study. Moreover, the proposed
   framework offers a simple variable importance strategy to gain insight
   as to the relevance of the predictor variables and is applied to both
   simulated and real data. Given the predictive power of using ensembles,
   especially when they can be interpretable, practitioners can use the
   following approach to provide an accurate and inferential perspective
   towards demystifying wine preferences.},
Type = {Article},
Affiliation = {Larkin, T (Corresponding Author), DataRobot Inc, Boston, MA 02110 USA.
   Larkin, Taylor, DataRobot Inc, Boston, MA 02110 USA.
   McManus, Denise, Univ Alabama, Informat Syst Stat Management Sci Dept, Tuscaloosa, AL USA.},
DOI = {10.1002/sam.11474},
EarlyAccessDate = {JUL 2020},
Keywords = {Bayesian modeling; ensemble modeling; machine learning; regularization;
   stacked generalization; variable importance; wine quality},
Keywords-Plus = {META-LEARNING FRAMEWORK; REGRESSION; SELECTION; MODELS},
Author-Email = {taylor.k.larkin@gmail.com},
Number-of-Cited-References = {46},
Times-Cited = {3},
Unique-ID = {WOS:000551529600001},
}

@article{ WOS:000455950700008,
Author = {Tan, Kun and Zhang, Yusha and Du, Qian and Du, Peijun and Jin, Xiao and
   Li, Jiayi},
Title = {Change Detection based on Stacked Generalization System with
   Segmentation Constraint},
Journal = {PHOTOGRAMMETRIC ENGINEERING AND REMOTE SENSING},
Year = {2018},
Volume = {84},
Number = {11},
Pages = {733-741},
Month = {NOV},
Abstract = {Change detection based on a multi-classifier ensemble system can take
   advantage of multiple classifiers to extract change information in
   remote sensing images. In this paper, an efficient heterogeneous
   ensemble algorithm, i.e., the stacked generalization (Sc) combined with
   image segmentation, is proposed to construct a simple multi-classifier
   ensemble system that can offer better detection accuracy with lower
   computational cost. Due to the rich spatial information in
   high-spatial-resolution remote sensing images, structure texture
   (morphological) and statistical texture features are extracted to
   construct the input data to the ensemble system along with spectral
   features. In addition, constrained analysis on segmented objects
   integrates the smaller heterogeneity segmentation map and pixel-wise
   change map to generate the final change map. The experiments were
   carried out on two ZY-3 and a QuickBird dataset. The results show that
   the proposed algorithm can integrate the advantages of both pixel-wise
   ensemble and object-oriented methods, and effectively improve the
   accuracy and stability of change detection.},
