   Zhang, Zhenhua, Stanford Univ, Dept Civil \& Environm Engn, Palo Alto, CA USA.
   Bradshaw, Patrick T., Univ Calif Berkeley, Sch Publ Hlth, Div Epidemiol, Berkeley, CA 94720 USA.
   Zhu, Yeyi, Univ Calif San Francisco, Dept Epidemiol \& Biostat, San Francisco, CA 94115 USA.},
DOI = {10.1186/s12916-022-02499-7},
