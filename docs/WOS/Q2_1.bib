   Nazir, Amril, Zayed Univ, Coll Technol Innovat, Dept Informat Syst, Abu Dhabi Campus,POB 144534, Abu Dhabi, U Arab Emirates.},
DOI = {10.3390/diagnostics12030726},
Article-Number = {726},
Keywords = {skin cancer; diagnosis; machine learning; stacking model; deep learning;
   interpretability; melanoma},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {iftiaz.alfi@northsouth.edu
   mdmahfuzur.rahman@kfupm.edu.sa
   m.shorf@tu.edu.sa
   mohd.nazir@zu.ac.ae},
Number-of-Cited-References = {29},
Times-Cited = {50},
