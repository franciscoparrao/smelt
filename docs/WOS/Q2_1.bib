   Sirohi, Ranjana, SKN Agr Univ, Jaipur, Rajasthan, India.
   Bui, Van Hung, Univ Danang, Univ Technol \& Educ, Danang, Vietnam.
   Kowalski, Jerzy, Gdansk Univ Technol, Inst Naval Architecture, Gdansk, Poland.
   Le, Huu Cuong, Ho Chi Minh City Univ Transport, Inst Maritime, Ho Chi Minh City, Vietnam.
   Tran, Viet Dung, Ho Chi Minh City Univ Transport, Inst Mech Engn, Ho Chi Minh City, Vietnam.},
DOI = {10.1177/0958305X251315408},
