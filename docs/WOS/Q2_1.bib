Article-Number = {152},
Keywords = {Young and middle-aged people; Acute myocardial infarction; Psychosocial
   maladjustment; Machine learning; Stacked generalization},
Keywords-Plus = {QUALITY-OF-LIFE; REHABILITATION; ADJUSTMENT; PREVENTION; DIAGNOSIS; WORK},
