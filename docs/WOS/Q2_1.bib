DOI = {10.1109/ACCESS.2024.3507569},
Keywords = {Reservoirs; Data models; Rocks; Support vector machines; Oils; Federated
   learning; Ensemble learning; Accuracy; Training data; Training; Data
   imbalance; resampling techniques; machine learning; stacked
   generalization; multiagent collaborative learning},
Keywords-Plus = {MARCELLUS SHALE; DATA ANALYTICS; WELL LOGS; IDENTIFICATION; PREDICTION;
