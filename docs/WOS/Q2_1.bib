@article{ WOS:001684130100001,
Author = {Singh, Akhilesh Kumar and Singh, Koushlendra Kumar and Singh, Mrityunjay
   Kumar and Ghosh, Biswajit and Kumar, G. R. Dinesh and Pais, Rajesh Shyam
   and Sharma, Vivek},
Title = {Steel defect detection based on feature selection and ensemble technique},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {168},
Month = {MAR 15},
Abstract = {Accurate and timely surface defect detection is essential to ensuring
   the quality and surface integrity of steel products, as it can save
   manufacturing costs and prevent product rejections later. This task is
   considerably more challenging in industrial contexts because to high
   dimensional feature spaces, substantial class imbalance in defect data,
   and missing values. This research introduces a comprehensive ensemble
   learning framework for predicting steel surface defects, primarily
   concentrating on defect-free galvannealed (GA) and galvanized steel
   surfaces utilized in the manufacturing of vehicle body panels. The
   proposed method enhances data quality and discriminative feature
   representation by integrating a novel Multi View Imputation and Feature
   Encoding (MVIFE) technique with feature importance ranking derived from
   the Maximal Information Coefficient (MIC). MVIFE uses Bayesian Ridge
   regression for iterative multivariate imputation, filtering out missing
   values by feature, and storing categorical features. This makes it a
   strong tool for managing inaccurate industrial data. To identify
   relevant parameters that exhibit both linear and nonlinear dependencies
   with the target variable, MIC scores are utilized. An ensemble
   classification architecture that uses Bagging, Boosting, Blending, and
   Max Voting operates on the altered feature set. A real-world dataset of
   steel defects from the Tata Steel Database, which is highly imbalanced,
   shows that the proposed approach is effective. We apply the Synthetic
   Minority Oversampling Technique (SMOTE) to address class imbalance and
   evaluate the model's performance using accuracy, precision, recall, and
   F1-score. According to experimental data, the proposed ensemble
   framework consistently outperforms single learning models. Blending gets
   the best overall F1-Score, Max Voting gets higher recall, and Blending
   gets better accuracy. These results show that the suggested method is
   useful and reliable for accurately predicting defects on steel surfaces.},
Type = {Article},
Affiliation = {Singh, AK (Corresponding Author), NIT Jamshedpur, Dept CSE, Machine Vis \& Intelligence Lab, Jamshedpur 831014, Jharkhand, India.
   Singh, Akhilesh Kumar; Singh, Koushlendra Kumar; Sharma, Vivek, NIT Jamshedpur, Dept CSE, Machine Vis \& Intelligence Lab, Jamshedpur 831014, Jharkhand, India.
