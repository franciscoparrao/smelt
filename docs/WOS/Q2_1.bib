   Karabulut, Seda, Istanbul Medipol Univ, Medipol Int Sch Med, Dept Histol \& Embryol, Istanbul, Turkey.},
DOI = {10.1016/j.rbmo.2022.06.022},
EarlyAccessDate = {NOV 2022},
