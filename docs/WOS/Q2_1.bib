}

@article{ WOS:001612441900001,
Author = {Kilicaslan, Feyza Nur and Genc, Burkay and Saglam, Fatih and Altun, Arif},
Title = {Artificial Intelligence-Assisted Determination of Suitable Age Values
   for Children's Books},
Journal = {APPLIED SCIENCES-BASEL},
Year = {2025},
Volume = {15},
Number = {21},
Month = {OCT 26},
Abstract = {Identifying age-appropriate books for children is a complex task that
   requires balancing linguistic, cognitive, and thematic factors. This
   study introduces an artificial intelligence-supported framework to
   estimate the Suitable Age Value (SAV) of Turkish children's books
   targeting the 2-18-year age range. We employ repeated, stratified 5x5
   cross-validation and report out-of-fold (OOF) metrics with 95\%
   confidence intervals for a dataset of 300 Turkish children's books. As
   classical baselines, linear/ElasticNet, SVR, Random Forest (RF), and
   XGBoost are trained on the engineered features; we also evaluate a
   rule-based Ate \& scedil;man readability baseline. For text, we use a
   frozen dbmdz/bert-base-turkish-uncased encoder inside two hybrid
   variants, Concat and Attention-gated, with fold-internal PCA and
   metadata selection; augmentation is applied only to the training folds.
   Finally, we probe a few-shot LLM pipeline (GPT-4o-mini) and a convex
   blend of RF and LLM predictions. A few-shot LLM markedly outperforms the
   zero-shot model, and zero-shot performance is unreliable. Among hybrids,
   Concat performs better than Attention-gated, yet both trail our best
   classical baseline. A convex RF + LLM blend, learned via bootstrap
   out-of-bag sampling, achieves a lower RMSE/MAE than either component and
   a slightly higher QWK. The Ate \& scedil;man baseline performance is
   substantially weaker. Overall, the findings were as follows:
   feature-based RF remains a strong baseline, few-shot LLMs add semantic
   cues, blending consistently helps, and simple hybrid concatenation beats
   a lightweight attention gate under our small-N regime.},
Type = {Article},
Affiliation = {Kiliçaslan, FN (Corresponding Author), Hacettepe Univ, Comp Engn Dept, TR-06800 Ankara, Turkiye.
   Kilicaslan, Feyza Nur; Genc, Burkay, Hacettepe Univ, Comp Engn Dept, TR-06800 Ankara, Turkiye.
   Saglam, Fatih, Ufuk Univ, Comp Engn Dept, TR-06805 Ankara, Turkiye.
   Altun, Arif, Hacettepe Univ, Dept Comp Educ \& Instruct Technol, TR-06800 Ankara, Turkiye.},
DOI = {10.3390/app152111438},
Article-Number = {11438},
Keywords = {children's books; large language models; machine learning; natural
   language processing; regression; Turkish text},
