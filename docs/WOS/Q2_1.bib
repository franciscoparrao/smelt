DOI = {10.1109/TITS.2016.2639361},
Keywords = {Identification methods; in-vehicle data recorders; classification;
   stacked generalization; supervised learning; machine learning},
Keywords-Plus = {INVOLVEMENT; CLASSIFIERS; INFORMATION; SELECTION; SEARCH},
Author-Email = {luis.matias@neclab.eu
   h.farah@tudelft.nl},
Number-of-Cited-References = {60},
