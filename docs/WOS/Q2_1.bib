   Yan, Junsheng, China Coal Res Inst, CCTEG, Beijing, Peoples R China.},
DOI = {10.3389/fdata.2025.1623883},
Article-Number = {1623883},
Keywords = {artificial intelligence; coal and gas outbursts prediction; multi-model
   fusion; XGBoost; attention mechanism},
Keywords-Plus = {MODEL; FLOW},
