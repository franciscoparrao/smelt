   Yang, Limin, Stinger Ghaffarian Technol SGT Inc, Greenbelt, MD USA.},
DOI = {10.1016/j.rse.2017.09.029},
Keywords = {Multiple classifier systems; Landsat; Change detection; Ensemble},
Keywords-Plus = {LANDSAT TIME-SERIES; SURFACE REFLECTANCE; DETECTING TRENDS; DISTURBANCE;
   CLASSIFICATION; MODEL; DYNAMICS; HARVEST; FIRE; AREA},
