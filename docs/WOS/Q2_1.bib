Keywords = {Pear; Juice; Adulteration; Bagging; Ensemble},
Keywords-Plus = {PARTIAL LEAST-SQUARES; AUTHENTICITY; REGRESSION; QUALITY; GRAPES},
Author-Email = {chaotan1112@163.com},
Number-of-Cited-References = {35},
