   Vong, Chi-Man, Univ Macau, Dept Comp \& Informat Sci, Macau, Peoples R China.},
DOI = {10.1109/TSMC.2024.3516857},
EarlyAccessDate = {JAN 2025},
Keywords = {Extreme interpretability; feature selection; stacked generalization;
   Takagi-Sugeno-Kang (TSK) fuzzy system},
Keywords-Plus = {ALGORITHMS},
Author-Email = {ml\_yuchenli@163.com
   erhaozhou@163.com
   cmvong@um.edu.mo
   wxwangst@aliyun.com},
Number-of-Cited-References = {38},
