@incollection{ WOS:001480926100007,
Author = {Ong, Leonard Evan C. and De Leon, Marlene M.},
Book-Group-Author = {ACM},
Title = {Developing BERT-based ensemble for Filipino text classification},
Booktitle = {PROCEEDINGS OF THE 8TH INTERNATIONAL CONFERENCE ON NATURAL LANGUAGE
   PROCESSING AND INFORMATION RETRIEVAL, NLPIR 2024},
Year = {2024},
Pages = {41-47},
Abstract = {Internet and social media users in the Philippines are constantly
   exposed to various forms of hate speech that may affect a person's
   beliefs and feelings which could lead to exclusion, personal attacks,
   and disregard for basic human rights. This study explores the
   effectiveness of BERT-based ensemble models for the classification of
   hate speech within the Filipino linguistic context. The study trained
   and evaluated various ensemble methods, including hard voting, soft
   voting, stacking, and blending, using the BERT models finetuned on the
   labeled Filipino hate speech dataset as base learners. Additionally,
   various metaclassifiers such as Logistic Regression, Naive Bayes,
   Decision Trees, and Support Vector Machines were experimented with for
   the stacking and blending ensembles. Based on the results obtained, the
   blending and voting ensemble methods show promising results by
   outperforming the individual BERT base learners. In contrast, the
   stacking ensemble achieved lower-than-expected performance despite being
   a more complex model.},
Type = {Proceedings Paper},
Affiliation = {Ong, LEC (Corresponding Author), Ateneo Manila Univ, Dept Informat Syst \& Comp Sci, Quezon City, NCR, Philippines.
