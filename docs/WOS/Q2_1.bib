   Kuemmerle, Tobias, Humboldt Univ, Integrat Res Inst Transformat Human Environm Syst, Berlin, Germany.},
DOI = {10.1111/geb.13911},
EarlyAccessDate = {SEP 2024},
Keywords = {ensemble; expert range map; meta-learner; range limit; realised
   distribution; SDM; species distribution modelling; stacked
   generalisation; stacking; super learner},
Keywords-Plus = {BIAS; CONSERVATION; PERFORMANCE; ENSEMBLES},
Author-Email = {julian.oeser@gmail.com},
