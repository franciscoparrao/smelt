@incollection{ WOS:000241452301117,
Author = {Li, Ya-Min and Cui, Li-Juan and Li, Kai},
Book-Group-Author = {IEEE},
Title = {Creating diversity in ensembles using clustering method from libraries
   of models},
Booktitle = {PROCEEDINGS OF 2006 INTERNATIONAL CONFERENCE ON MACHINE LEARNING AND
   CYBERNETICS, VOLS 1-7},
Year = {2006},
Pages = {1298+},
Abstract = {The diversity of an ensemble of models is known to be an important
   factor in improving its generalization performance. We present an
   ensemble method based on clustering technique from libraries of models,
   EMC (Ensemble of Models based on Clustering). It may be seen as a
   unified ensemble approach based on clustering. First, model libraries
   are generated using different learning algorithms and parameter
   settings, for example, neural networks (NNs), support vector machines
   (SVMs), and decision trees (DTs). Then clustering method is used to
   select the diverse models in ensembles. Finally, the selected partial
   models' predictions are combined by voting. Experiments with 10
   representative data sets from UCI repository demonstrate the benefit of
   ensemble selection.},
Type = {Proceedings Paper},
Affiliation = {Li, YM (Corresponding Author), Tianjin Univ, Sch Management, Tianjin 300072, Peoples R China.
