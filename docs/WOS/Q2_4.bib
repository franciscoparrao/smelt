Author-Email = {bruno.schneider@uni-konstanz.de
   dominik.jaeckle@uni-konstanz.de
   florian.stoffel@uni-konstanz.de
   diehl@dbvis.inf.uni-konstanz.de
   fuchs@dbvis.inf.uni-konstanz.de
   keim@uni-konstanz.de},
