   Pereira, Marcelo T., Inst Fed Parana IFPR, Umuarama, PR, Brazil.
   Oliveira, Luiz S., Univ Fed Parana UFPR, Curitiba, Parana, Brazil.
   Sabourin, Robert, Ecole Technol Super, Montreal, PQ, Canada.},
DOI = {10.1109/ICTAI.2018.00120},
Keywords = {Discrimination Index; Classical Test Theory; Dynamic Classifier
