}

@article{ WOS:000563731600001,
Author = {Gao, Jie and Liu, Kunhong and Wang, Beizhan and Wang, Dong and Zhang,
   Xiaoyan},
Title = {Improving deep forest by ensemble pruning based on feature vectorization
   and quantum walks},
Journal = {SOFT COMPUTING},
Year = {2021},
Volume = {25},
Number = {3, SI},
Pages = {2057-2068},
Month = {FEB},
Abstract = {Recently, a deep learning model, the deep forest (DF), was designed as
   an alternative to deep neural networks. Each cascade layer of the DF
   contains a set of random forests (RFs) with a large number of decision
   trees, some of which are of high redundancy and poor performance. To
   avoid the negative impacts of such decision trees, this paper proposes
   to optimize RFs in each cascade layer of the DF so as to realize a
   pruned deep forest (PDF) with higher performance and smaller ensemble
   size. In this paper, a new ordering-based ensemble pruning method is
   proposed based on feature vectorization and quantum walks. This method
   simultaneously considers the accuracy and the diversity of base
   classifiers, and it provides an integrated evaluation criterion for
   ordering base classifiers in the ensemble system. The effectiveness of
   the proposed method is verified by experiments and discussions.},
Type = {Article},
Affiliation = {Wang, BZ (Corresponding Author), Xiamen Univ, Sch Informat, Xiamen 361005, Peoples R China.
   Gao, Jie; Liu, Kunhong; Wang, Beizhan, Xiamen Univ, Sch Informat, Xiamen 361005, Peoples R China.
