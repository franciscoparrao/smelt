DOI = {10.1016/j.renene.2021.04.028},
EarlyAccessDate = {APR 2021},
Keywords = {Wind power forecasting; Ensemble learning; Gaussian process regression;
   Probabilistic modeling; Ensemble pruning; Model adaptation},
Keywords-Plus = {TIME-SERIES PREDICTION; NEURAL-NETWORK; OPTIMIZATION ALGORITHM; WAVELET
   TRANSFORM; SPEED; MULTISTEP; DECOMPOSITION; INTEGRATION; STRATEGY},
