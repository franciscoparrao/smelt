DOI = {10.1162/imag\_a\_00267},
Keywords = {fMRI; prediction; brain dynamics; model combination; hidden Markov
   model; subject differences},
Keywords-Plus = {FUNCTIONAL CONNECTIVITY; DISTORTION CORRECTION; FRAMEWORK; MOVEMENT},
Author-Email = {ben.griffin@keble.ox.ac.uk},
Number-of-Cited-References = {66},
