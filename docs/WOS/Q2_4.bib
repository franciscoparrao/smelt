   Du, Xuehui; Chen, Xingyuan, PLA Strategy Support Force Informat Engn Univ, Sci Rd 62, Zhengzhou 450001, Henan, Peoples R China.},
DOI = {10.1016/j.engappai.2024.108653},
EarlyAccessDate = {JUN 2024},
Article-Number = {108653},
Keywords = {Deep neural network; Model level; Uncertainty estimation; Dynamic
   ensemble selection; Adversarial robustness},
Keywords-Plus = {CLASSIFIER SELECTION; COMPETENCE; ACCURACY},
Author-Email = {18530023930@163.com
