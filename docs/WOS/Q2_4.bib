@article{ WOS:001605989500001,
Author = {Tekin, Selim Furkan and Ilhan, Fatih and Huang, Tiansheng and Hu, Sihao
   and Chow, Ka-Ho and Loper, Margaret L. and Liu, Ling},
Title = {Robust Few-Shot Ensemble Learning with Focal Diversity-Based Pruning},
Journal = {ACM TRANSACTIONS ON INTELLIGENT SYSTEMS AND TECHNOLOGY},
Year = {2025},
Volume = {16},
Number = {5},
Month = {SEP},
Abstract = {This article presents FusionShot, a focal diversity-optimized few-shot
   ensemble learning approach for boosting the robustness and
   generalization performance of pre-trained few-shot models. The article
   makes three original contributions. First, we explore the unique
   characteristics of few-shot learning to ensemble multiple few-shot (FS)
   models by creating three alternative fusion channels. Second, we
   introduce the concept of focal error diversity to learn the most
   efficient ensemble teaming strategy, rather than assuming that an
   ensemble of a larger number of base models will outperform those
   sub-ensembles of smaller size. We develop a focal diversity ensemble
   pruning method to effectively prune out the candidate ensembles with low
   ensemble error diversity and recommend top-FS ensembles with the highest
   focal error diversity. Finally, we capture the complex non-linear
   patterns of ensemble few-shot predictions by designing the
   learn-to-combine algorithm, which can learn the diverse weight
   assignments for robust ensemble fusion over different member models.
   Extensive experiments on representative few-shot benchmarks show that
   the top-K ensembles recommended by FusionShot can outperform the
   representative state-of-the-art (SOTA) few-shot models on novel tasks
   (different distributions and unknown at training) and can prevail over
   existing few-shot learners in both cross-domain settings and adversarial
   settings. For reproducibility purposes, FusionShot trained models,
   results, and code are made available at
   https://github.com/sftekin/fusionshot.},
Type = {Article},
Affiliation = {Tekin, SF (Corresponding Author), Georgia Inst Technol, Atlanta, GA 30332 USA.
   Tekin, Selim Furkan; Ilhan, Fatih; Huang, Tiansheng; Hu, Sihao; Chow, Ka-Ho; Loper, Margaret L.; Liu, Ling, Georgia Inst Technol, Atlanta, GA 30332 USA.},
DOI = {10.1145/3746457},
Article-Number = {111},
Keywords = {ensemble learning; few-shot learning; ensemble pruning; genetic
   algorithm; error diversity},
Author-Email = {stekin6@gatech.edu
   filhan3@gatech.edu
   thuang374@gatech.edu
   shu335@gatech.edu
   margaret.loper@gtri.gatech.edu
   ll72@gatech.edu},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001605989500001},
}

@article{ WOS:001556114400001,
Author = {Yulianti, Lenny Putri and Trisetyarso, Agung and Santoso, Judhi and
   Surendro, Kridanto},
Title = {A Novel Approach for Pruning Training Spaces in Ensemble Classifiers},
Journal = {IEEE TRANSACTIONS ON EMERGING TOPICS IN COMPUTATIONAL INTELLIGENCE},
Year = {2026},
Volume = {10},
Number = {1},
Pages = {647-659},
Month = {FEB},
Abstract = {Ensemble classifiers have gained attention because its high performance
   in identification and classification problems by combining accurate and
   diverse classifiers. However, combining all classifiers in an ensemble
   only add to the computational complexity of the ensemble, leading to the
   emerging of ensemble pruning paradigm. Numerous state-of-the-art studies
   explore ensemble pruning techniques, including ranking-based,
   clustering-based, and optimization-based approaches, which involve
   pruning either training spaces or trained learners. However, this
   research found two main issues, including 1) there is no existing
   studies that considers accuracy and diversity simultaneously to prune
   training spaces in ensemble, and 2) the potential of using quantum-based
   optimization approach to improve the ensemble performance by enabling to
   discover the solution of global optimum, instead of local optimum.
   Therefore, the contributions of this research are: 1) to propose a
   pruning approach that considers accuracy and diversity simultaneously to
   determine the optimal training spaces in ensemble, and 2) to propose
   quantum annealing as the novel quantum-based optimization method for
   pruning training spaces in ensemble classifiers. The proposed method was
   evaluated on 11 datasets from UCI repository. The results showcase the
   superior accuracy of the proposed method across all datasets,
   outperforming all benchmark methods. Furthermore, the proposed method
   exhibits the second-highest average diversity values after AdaBoost.
   Notably, the pruning process utilizing quantum annealing demonstrates
   faster computational times compared to particle swarm optimization.
   These results contribute valuable insights into ensemble classifiers and
   underscore the potential of leveraging quantum computing techniques for
   enhanced model performance.},
Type = {Article},
Affiliation = {Yulianti, LP (Corresponding Author), Inst Teknol Bandung, Sch Elect Engn \& Informat, Bandung 40135, Indonesia.
   Yulianti, Lenny Putri; Santoso, Judhi; Surendro, Kridanto, Inst Teknol Bandung, Sch Elect Engn \& Informat, Bandung 40135, Indonesia.
   Trisetyarso, Agung, Bina Nusantara Univ, Sch Comp Sci, Dept Math, Jakarta 11480, Indonesia.},
DOI = {10.1109/TETCI.2025.3595735},
EarlyAccessDate = {AUG 2025},
Keywords = {Training; Accuracy; Diversity reception; Indexes; Linear programming;
   Annealing; Object recognition; Computational intelligence; Particle
   swarm optimization; Ensemble classifiers; pruning; quantum annealing;
   training spaces; training spaces},
Keywords-Plus = {DIVERSITY; ACCURACY; SELECTION},
Author-Email = {33221007@std.stei.itb.ac.id
   atrisetyarso@binus.edu
   judhi@staff.stei.itb.ac.id
   endro@itb.ac.id},
Number-of-Cited-References = {53},
Times-Cited = {0},
Unique-ID = {WOS:001556114400001},
}

@article{ WOS:001522987500014,
Author = {Go, HeounMo and Park, SangHyun},
Title = {A study on classification based concurrent API calls and optimal model
   combination for tool augmented LLMs for AI agent},
Journal = {SCIENTIFIC REPORTS},
Year = {2025},
Volume = {15},
Number = {1},
Month = {JUL 1},
Abstract = {AI Agents have evolved to not only recommend content but also facilitate
   information retrieval and task processing. Developing AI Agents using
   general-purpose LLM models necessitates integration with external tools,
   leading to tool-augmented LLM studies. Despite the availability of
   multiple tools for the same purpose, existing research has not fully
   leveraged this diversity. This study categorizes external tools by type
   and proposes a method to simultaneously call tools of the same type.
   This allows for the utilization of diverse external tools in LLM
   inference, thereby achieving a higher accuracy compared to when only a
   single tool for one task is used. Experimental results show an accuracy
   improvement of 4.4-9.3\% over existing studies. Furthermore, when
   utilizing tool-augmented LLM, a multi-step reasoning approach that
   divides the process into stages such as planning and tool invocation is
   widely employed. With the rapid advancement of LLMs, enhanced models
   continue to emerge. Considering the trade-offs between performance and
   cost in models, it is crucial to find an optimal combination of models
   in each stage of tool augmented LLM. In this study, we propose a novel
   method for efficiently utilizing both enhanced LLM models and existing
   models, which reduces response errors by up to 9\%.},
Type = {Article},
Affiliation = {Park, S (Corresponding Author), Yonsei Univ, Dept Comp Sci, Yonsei Ro 50, Seoul 03722, South Korea.
   Go, HeounMo; Park, SangHyun, Yonsei Univ, Dept Comp Sci, Yonsei Ro 50, Seoul 03722, South Korea.},
DOI = {10.1038/s41598-025-06469-w},
Article-Number = {20579},
Author-Email = {sanghyun@yonsei.ac.kr},
Number-of-Cited-References = {31},
Times-Cited = {0},
Unique-ID = {WOS:001522987500014},
}

@article{ WOS:001509570200001,
Author = {Zhang, Chuan and Cai, Yong-Fang and Wu, Yu-Hui and Tian, Yu-Xin},
Title = {Unleashing the power of dynamic ensembles: a risk- and profit-driven
   framework for online loan credit risk assessment},
Journal = {INTERNATIONAL JOURNAL OF GENERAL SYSTEMS},
Year = {2025},
Month = {2025 JUN 13},
Abstract = {Effective credit risk assessment is essential in online lending,
   enabling lenders to make informed investment decisions. Recently, the
   dynamic ensemble selection (DES) technique, which adaptively selects an
   appropriate classifier ensemble for each sample, has shown great promise
   in this domain. However, traditional DES methods often rely on bootstrap
   sampling to generate base classifiers, potentially overlooking the
   intrinsic structure of input data and reducing predictive performance.
   Additionally, existing profit-oriented credit risk models fail to
   accommodate the heterogeneous risk preferences of investors. To address
   these issues, we propose a novel hybrid model, DES-CBCG-MOO, which
   combines (1) a clustering-based classifier generation (CBCG) module to
   enhance diversity among base classifiers, and (2) a multi-objective
   optimization (MOO) component that integrates NSGA-III into the META-DES
   framework to jointly optimize risk and profitability. To enhance model
   transparency, we employ SHAP for post-hoc interpretation of predictions.
   Experiments on a real-world lending dataset demonstrate that
   DES-CBCG-MOO outperforms the baselines.},
Type = {Article; Early Access},
Affiliation = {Zhang, C (Corresponding Author), Northeastern Univ, Sch Business Adm, Shenyang, Peoples R China.
   Zhang, Chuan; Cai, Yong-Fang; Wu, Yu-Hui; Tian, Yu-Xin, Northeastern Univ, Sch Business Adm, Shenyang, Peoples R China.},
DOI = {10.1080/03081079.2025.2515980},
EarlyAccessDate = {JUN 2025},
Keywords = {Credit risk assessment; investor preference analysis; ensemble learning;
   interpretability; multi-objective optimization},
Keywords-Plus = {CLASSIFIER SELECTION; GENETIC ALGORITHM; MODELS; TREE},
Author-Email = {czhang@mail.neu.edu.cn},
Number-of-Cited-References = {58},
Times-Cited = {0},
Unique-ID = {WOS:001509570200001},
}

@article{ WOS:001478437100001,
Author = {Ding, Jiaman and Jiang, Xiangyu and Jia, Lianyin and Fu, Xiaodong and
   Jiang, Ying},
Title = {Tree comprehensive diversity-based pruned deep forest},
Journal = {INTERNATIONAL JOURNAL OF MACHINE LEARNING AND CYBERNETICS},
Year = {2025},
Volume = {16},
Number = {9},
Pages = {6957-6976},
Month = {SEP},
Abstract = {Deep Forest (DF) is proposed as a deep learning model based on
   non-differentiable modules, which extends the deep learning paradigm by
   incorporating non-neural network structures and has demonstrated
   remarkable performance in several fields. DF utilizes a cascade
   structure where each layer contains one or more sets of random forests.
   However, some of these forests may include decision trees with high
   redundancy and suboptimal performance. Additionally, the feature
   representations in DF are composed of prediction class probability
   vectors, and these prediction-based representations require the
   retention of a large amount of information about the forest models for
   subsequent testing. These two characteristics of DF make it prone to
   issues related to high time, memory, and storage costs, and may even
   lead to performance degradation. To address these challenges, we design
   a novel pruning strategy aimed at optimizing random forests in cascade
   layers and propose a new deep forest model called Tree Comprehensive
   Diversity-based Pruned Deep Forest (TCDPDF). Unlike most methods that
   rely on model prediction results to measure diversity, we explore a
   diversity measure based on the morphological structure of decision
   trees. Furthermore, we propose a tree comprehensive diversity measure
   for the pruning strategy by balancing both structural diversity and
   prediction accuracy of decision trees. We conduct experiments on 12
   public datasets, and the results demonstrate that TCDPDF achieves
   competitive performance, significantly reduces the model's high
   computational complexity, and further enhances its generalization
   ability.},
Type = {Article},
Affiliation = {Jia, LY (Corresponding Author), Kunming Univ Sci \& Technol, Fac Informat Engn \& Automat, Kunming 650500, Yunnan, Peoples R China.
   Jia, LY (Corresponding Author), Kunming Univ Sci \& Technol, Artificial Intelligence Key Lab Yunnan Prov, Kunming 650500, Yunnan, Peoples R China.
   Ding, Jiaman; Jiang, Xiangyu; Jia, Lianyin; Fu, Xiaodong; Jiang, Ying, Kunming Univ Sci \& Technol, Fac Informat Engn \& Automat, Kunming 650500, Yunnan, Peoples R China.
   Ding, Jiaman; Jiang, Xiangyu; Jia, Lianyin; Fu, Xiaodong; Jiang, Ying, Kunming Univ Sci \& Technol, Artificial Intelligence Key Lab Yunnan Prov, Kunming 650500, Yunnan, Peoples R China.},
DOI = {10.1007/s13042-025-02655-4},
EarlyAccessDate = {APR 2025},
Keywords = {Ensemble pruning; Diversity measure; Deep forest; Morphological
   structure},
Keywords-Plus = {ENSEMBLE; CLASSIFICATION},
Author-Email = {lianyinjia@kust.edu.cn},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001478437100001},
}

@article{ WOS:001489190300002,
Author = {Li, Chunlong and Li, Danyang and Qin, Xue and Qin, Yuanxian and Li,
   Jialin and Yuan, Jiafan},
Title = {Clustering ensemble pruning algorithm based on vec2vec classifier
   representation},
Journal = {JOURNAL OF KING SAUD UNIVERSITY COMPUTER AND INFORMATION SCIENCES},
Year = {2025},
Volume = {37},
Number = {3},
Month = {APR 14},
Abstract = {The complementarity of ensemble learning primarily stems from the
   diversity among its classifier members, which is typically assessed by
   calculating the similarity or distance between classifiers. However,
   traditional methods for similarity or distance calculation are limited
   by the representation of classifiers, which may not accurately reflect
   the true relationships between them, leading to inferior ensemble
   pruning performance. To address this issue, this study proposes a new
   classifier representation paradigm and ensemble pruning
   algorithm(Vec2Q-CEEP). To begin with, we transform the representation of
   classifiers through spatial mapping, overcoming the limitations of
   traditional similarity calculation methods, enriching the ways of
   calculating classifier diversity, and enhancing the distinguishability
   between classifiers. Furthermore, we introduce a novel similarity
   measurement method that integrates classifier information from both the
   original and mapped spaces, enabling a more comprehensive evaluation of
   the relationships between classifiers. After conducting extensive
   experiments on 12 UCI datasets, the experimental results demonstrate
   that this algorithm outperforms several state-of-the-art ensemble
   pruning algorithms, thus validating its effectiveness and feasibility.},
Type = {Article},
Affiliation = {Li, DY (Corresponding Author), Guizhou Univ, Coll Big Data \& Informat Engn, Jiaxiu South Rd, Guiyang 550025, Peoples R China.
   Li, Chunlong; Li, Danyang; Qin, Xue; Qin, Yuanxian; Li, Jialin; Yuan, Jiafan, Guizhou Univ, Coll Big Data \& Informat Engn, Jiaxiu South Rd, Guiyang 550025, Peoples R China.},
DOI = {10.1007/s44443-025-00030-5},
Article-Number = {22},
Keywords = {Ensemble pruning; Classifier representation; Ensemble learning;
   Classifier ensemble; Classifier selection},
Keywords-Plus = {ACCURACY; DIVERSITY},
Author-Email = {Lary423@126.com
