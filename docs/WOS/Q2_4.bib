@article{ WOS:000418370200023,
Author = {Guo, Huaping and Liu, Hongbing and Li, Ran and Wu, Changan and Guo, Yibo
   and Xu, Mingliang},
Title = {Margin \& diversity based ordering ensemble pruning},
Journal = {NEUROCOMPUTING},
Year = {2018},
Volume = {275},
Pages = {237-246},
Month = {JAN 31},
Abstract = {Ensemble pruning is a technique used to improve ensemble performance and
   reduce the ensemble size by selecting an optimal or sub-optimal subset
   as the final ensemble for prediction. In this research, using example
   margin and ensemble diversity, we prove that the ensemble pruning method
   should focus more on the following two factors: (1) examples with small
   absolute margin and (2) classifiers that correctly classify more
   examples and contribute larger diversity. Based on this principle, we
   propose a novel metric called the margin \& diversity based measure
   (MDM) to explicitly evaluate the importance of individual classifiers.
   By incorporating ensemble members in a decreasing order based on the
   MDM, sub-ensembles are formed such that users can select the top T
   ensemble members for predictions. Compared to the original ensemble and
   other state-of`-the-art ensemble pruning methods, the proposed method
   shows better performance in terms of accuracy. (C) 2017 Elsevier B.V.
   All rights reserved.},
Type = {Article},
Affiliation = {Guo, HP (Corresponding Author), Xinyang Normal Univ, Sch Comp \& Informat Technol, Xinyang, Henan, Peoples R China.
   Xu, ML (Corresponding Author), Zhengzhou Univ, Ctr Interdisciplinary Informat Sci Res, Zhengzhou, Henan, Peoples R China.
   Guo, Huaping; Liu, Hongbing; Li, Ran; Wu, Changan, Xinyang Normal Univ, Sch Comp \& Informat Technol, Xinyang, Henan, Peoples R China.
   Guo, Yibo; Xu, Mingliang, Zhengzhou Univ, Ctr Interdisciplinary Informat Sci Res, Zhengzhou, Henan, Peoples R China.},
DOI = {10.1016/j.neucom.2017.06.052},
Keywords = {Example margin; Ensemble diversity; Ensemble pruning},
