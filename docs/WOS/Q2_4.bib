@article{ WOS:000447084900001,
Author = {Perez-Gallego, Pablo and Castano, Alberto and Ramon Quevedo, Jose and
   Jose del Coz, Juan},
Title = {Dynamic ensemble selection for quantification tasks},
Journal = {INFORMATION FUSION},
Year = {2019},
Volume = {45},
Pages = {1-15},
Month = {JAN},
Abstract = {Ensembles are among the most effective and successful methods for almost
   all supervised tasks. Not long ago, an ensemble approach has been
   proposed for quantification learning. The idea of such method is to
   exploit the prior knowledge about quantification tasks, building
   ensembles in which diversity is achieved by training each model with a
   different distribution. These training samples are generated taking into
   account the expected drift in class distribution. This paper extends
   this method proposing three new quantifier selection criteria
   particularly devised for quantification problems, where two of them are
   defined for dynamic ensemble selection. The experiments demonstrate
   that, in many cases, these selection functions outperform
   straightforward approaches, like averaging all models and using
   quantification accuracy to prune the ensemble. Moreover, the results
   show that performance heavily depends on the combination of the base
   quantification algorithm and the selection measure.},
Type = {Article},
Affiliation = {del Coz, JJ (Corresponding Author), Univ Oviedo, Artificial Intelligence Ctr, Gijon, Spain.
   Perez-Gallego, Pablo; Castano, Alberto; Ramon Quevedo, Jose; Jose del Coz, Juan, Univ Oviedo, Artificial Intelligence Ctr, Gijon, Spain.},
DOI = {10.1016/j.inffus.2018.01.001},
Keywords = {Quantification; Ensembles; Dynamic ensemble selection},
Keywords-Plus = {CLASSIFIER SELECTION; DIVERSITY},
Author-Email = {pablopg@uniovi.es
   castanoalberto@uniovi.es
   quevedo@uniovi.es
   juanjo@uniovi.es},
Number-of-Cited-References = {43},
Times-Cited = {41},
Unique-ID = {WOS:000447084900001},
}

@article{ WOS:000366069500004,
Author = {Krawczyk, Bartosz and Schaefer, Gerald and Wozniak, Michal},
Title = {A hybrid cost-sensitive ensemble for imbalanced breast thermogram
   classification},
Journal = {ARTIFICIAL INTELLIGENCE IN MEDICINE},
Year = {2015},
Volume = {65},
Number = {3},
Pages = {219-227},
Month = {NOV},
Abstract = {Objectives: Early recognition of breast cancer, the most commonly
   diagnosed form of cancer in women, is of crucial importance, given that
   it leads to significantly improved chances of survival. Medical
   thermography, which uses an infrared camera for thermal imaging, has
   been demonstrated as a particularly useful technique for early
   diagnosis, because it detects smaller tumors than the standard modality
   of mammography.
   Methods and material: In this paper, we analyse breast thermograms by
   extracting features describing bilateral symmetries between the two
   breast areas, and present a classification system for decision making.
   Clearly, the costs associated with missing a cancer case are much higher
   than those for mislabelling a benign case. At the same time, datasets
   contain significantly fewer malignant cases than benign ones. Standard
   classification approaches fail to consider either of these aspects. In
   this paper, we introduce a hybrid cost-sensitive classifier ensemble to
   address this challenging problem. Our approach entails a pool of
   cost-sensitive decision trees which assign a higher misclassification
   cost to the malignant class, thereby boosting its recognition rate. A
   genetic algorithm is employed for simultaneous feature selection and
   classifier fusion. As an optimisation criterion, we use a combination of
   misclassification cost and diversity to achieve both a high sensitivity
   and a heterogeneous ensemble. Furthermore, we prune our ensemble by
   discarding classifiers that contribute minimally to the decision making.
   Results: For a challenging dataset of about 150 thermograms, our
   approach achieves an excellent sensitivity of 83.10\%, while maintaining
   a high specificity of 89.44\%. This not only signifies improved
   recognition of malignant cases, it also statistically outperforms other
   state-of-the-art algorithms designed for imbalanced classification, and
   hence provides an effective approach for analysing breast thermograms.
   Conclusions: Our proposed hybrid cost-sensitive ensemble can facilitate
   a highly accurate early diagnostic of breast cancer based on thermogram
   features. It overcomes the difficulties posed by the imbalanced
   distribution of patients in the two analysed groups. (C) 2015 Elsevier
   B.V. All rights reserved.},
Type = {Article},
Affiliation = {Krawczyk, B (Corresponding Author), Wroclaw Univ Technol, Dept Syst \& Comp Networks, Wyb Wyspianskiego 27, PL-50370 Wroclaw, Poland.
   Krawczyk, Bartosz; Wozniak, Michal, Wroclaw Univ Technol, Dept Syst \& Comp Networks, PL-50370 Wroclaw, Poland.
   Schaefer, Gerald, Univ Loughborough, Dept Comp Sci, Loughborough LE11 3TU, Leics, England.},
DOI = {10.1016/j.artmed.2015.07.005},
Keywords = {Classifier ensemble; Imbalanced classification; Cost-sensitive
   classification; Ensemble pruning; Evolutionary algorithm; Breast cancer
   detection; Thermogram},
Keywords-Plus = {RECOGNITION; DIAGNOSIS; FEATURES; SYSTEM; CANCER},
Author-Email = {bartosz.krawczyk@pwr.edu.pl
   gerald.schaefer@ieee.org
   michal.wozniak@pwr.edu.pl},
Number-of-Cited-References = {49},
