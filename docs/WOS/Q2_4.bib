@article{ WOS:001714988200001,
Author = {Hou, Zhaoguo and Wang, Huawei and Xiong, Minglan and Liu, Weiwei},
Title = {Highly imbalanced intelligent identification of civil aviation
   maintenance hazards based on text mining and selective ensemble modeling},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {173},
Month = {JUN 1},
Abstract = {Accurate identification of civil aviation maintenance hazards is of
   vital engineering significance for mitigating accident risks,
   safeguarding operational safety, and optimizing maintenance efficiency.
   However, the complex linguistic features and highly imbalanced
   distribution of civil aviation maintenance logs pose significant
   challenges to existing identification algorithms. To address these
   issues, this paper proposes a method for highly imbalanced intelligent
   identification of civil aviation maintenance hazards based on text
   mining and selective ensemble modeling. Firstly, considering the domain
   specificity of maintenance logs, domain-specific text preprocessing is
   performed, followed by the term frequency-inverse document frequency
   (TF-IDF) method to achieve effective feature extraction and
   vectorization. Subsequently, on the basis of data class rebalancing via
   the instance hardness threshold (IHT) sampling, an ensemble pruning
   strategy integrating dual correlation analysis and predictive
   accuracy-based filtering is designed to effectively manage the trade-off
   between the diversity and accuracy of the base models. Finally, an
   enhanced adaptive weighted fusion algorithm (EAWFA) is constructed to
   flexibly adjust the weights for base model fusion, thereby enhancing the
   precision and engineering intervenability of hazard identification.
   Comprehensive experiments conducted on maintenance logs from an aviation
   maintenance enterprise and the aviation safety reporting system (ASRS)
   dataset validate the effectiveness and generalization capability of the
   proposed method. Comparisons with existing methods demonstrate the
   superiority of the proposed method, indicating its promising potential
   for civil aviation maintenance engineering applications.},
Type = {Article},
Affiliation = {Wang, HW (Corresponding Author), Nanjing Univ Aeronaut \& Astronaut, Coll Civil Aviat, Nanjing 211106, Peoples R China.
   Hou, Zhaoguo; Wang, Huawei; Xiong, Minglan; Liu, Weiwei, Nanjing Univ Aeronaut \& Astronaut, Coll Civil Aviat, Nanjing 211106, Peoples R China.},
DOI = {10.1016/j.engappai.2026.114403},
Article-Number = {114403},
Keywords = {Civil aviation maintenance; Hazard identification; Imbalanced data;
   Ensemble pruning; Enhanced adaptive weighted fusion algorithm},
Keywords-Plus = {SAFETY; PREDICTION},
Author-Email = {wang\_hw66@163.com},
Number-of-Cited-References = {40},
Times-Cited = {0},
Unique-ID = {WOS:001714988200001},
}

@article{ WOS:001692371400002,
Author = {Khelifa, Afifa and Ghazouani, Haythem and Barhoumi, Walid},
Title = {Unified framework for in-the-wild recognition of basic and compound
   facial expressions using label distribution learning and dynamic
   ensemble selection},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {313},
Month = {JUN 1},
Abstract = {Prior research on Facial Expression Recognition (FER) has largely
   focused on analyzing basic expressions (BFER) or compound expressions
   (CFER) separately. Nevertheless, this two-sided approach overlooks the
   nuanced spectrum of facial expressions observed in real-world settings,
   where basic and compound emotions often coexist or overlap. Relying
   solely on the recognition of basic or compound emotions does not capture
   the real nature of emotional behavior. Consequently, there is a critical
   need to develop a unified framework that integrates the recognition of
   both basic and compound facial expressions. The task of Basic-Compound
   Facial Expression Recognition (BC-FER) remains underexplored and
   presents notable challenges, including the inherent ambiguity and
   complexity of compound expressions, the visual similarities among
   certain basic emotions, and the potential for confusion between pure and
   composite emotional states. In this study, we introduce a unified
   framework for the BC-FER task. It encodes facial expressions as label
   distributions over seven basic emotions, capturing the varying degrees
   to which each label contributes to the expression, thereby modeling
   co-occurrence and gradation of affective states. To effectively leverage
   complementary expertise, the framework integrates specialized learners
   trained to recognize either basic or compound expressions and
   dynamically selects the most competent learners for each input instance.
   This synergistic combination of Label Distribution Learning (LDL) and
   Dynamic Ensemble Selection (DES) enhances significantly the robustness
   and adaptability of the method in real-world settings. Extensive
   experiments conducted on the RAF-DB in-the-wild dataset demonstrate that
   the framework achieves competitive results and can be flexibly adapted
   to both BFER and CFER tasks.},
Type = {Article},
Affiliation = {Barhoumi, W (Corresponding Author), Univ Tunis El Manar, Inst Super Informat, LIMTIC Lab, Ariana, Tunisia.
   Barhoumi, W (Corresponding Author), Univ Carthage, Ecole Natl Ingenieurs Carthage, Tunis, Tunisia.
   Khelifa, Afifa, Higher Inst Technol Studies Mahdia, Mahdia, Tunisia.
   Khelifa, Afifa; Ghazouani, Haythem; Barhoumi, Walid, Univ Tunis El Manar, Inst Super Informat, LIMTIC Lab, Ariana, Tunisia.
   Ghazouani, Haythem; Barhoumi, Walid, Univ Carthage, Ecole Natl Ingenieurs Carthage, Tunis, Tunisia.},
DOI = {10.1016/j.eswa.2026.131475},
EarlyAccessDate = {FEB 2026},
Article-Number = {131475},
Keywords = {Basic expression; Compound expression; BC-FER; Dynamic ensemble
   selection; Label distribution learning; Multi-task learning; Stacking;
   In-the-wild},
Keywords-Plus = {NEURAL-NETWORKS; TRANSFORMER; ALGORITHM},
Author-Email = {afifa.khelifa@fst.utm.tn
   haythem.ghazouani@enicar.ucar.tn
   walid.barhoumi@enicar.ucar.tn},
Number-of-Cited-References = {74},
