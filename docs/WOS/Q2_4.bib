DOI = {10.1007/978-3-030-43887-6\_30},
Keywords = {Imbalanced data; Data stream; Dynamic ensemble selection; Data
   preprocessing; Concept drift},
Keywords-Plus = {SMOTE; CLASSIFIERS; COMPETENCE; DIVERSITY},
Author-Email = {pawel.zyblewski@pwr.edu.pl
