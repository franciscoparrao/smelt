Unique-ID = {WOS:000778131000001},
}

@article{ WOS:000302762000004,
Author = {Woloszynski, Tomasz and Kurzynski, Marek and Podsiadlo, Pawel and
   Stachowiak, Gwidon W.},
Title = {A measure of competence based on random classification for dynamic
   ensemble selection},
Journal = {INFORMATION FUSION},
Year = {2012},
Volume = {13},
Number = {3},
Pages = {207-213},
Month = {JUL},
Abstract = {In this paper, a measure of competence based on random classification
   (MCR) for classifier ensembles is presented. The measure selects
   dynamically (i.e. for each test example) a subset of classifiers from
   the ensemble that perform better than a random classifier. Therefore,
   weak (incompetent) classifiers that would adversely affect the
   performance of a classification system are eliminated. When all
   classifiers in the ensemble are evaluated as incompetent, the
   classification accuracy of the system can be increased by using the
   random classifier instead. Theoretical justification for using the
   measure with the majority voting rule is given. Two MCR based systems
   were developed and their performances was compared against six multiple
   classifier systems using data sets taken from the UCI Machine Learning
   Repository and Ludmila Kuncheva Collection. The systems developed had
   typically the highest classification accuracies regardless of the
   ensemble type used (homogeneous or heterogeneous). (C) 2011 Elsevier
   B.V. All rights reserved.},
Type = {Article},
Affiliation = {Woloszynski, T (Corresponding Author), Univ Western Australia, Sch Mech \& Chem Engn, Tribol Lab, Crawley, WA 6009, Australia.
   Woloszynski, Tomasz; Podsiadlo, Pawel; Stachowiak, Gwidon W., Univ Western Australia, Sch Mech \& Chem Engn, Tribol Lab, Crawley, WA 6009, Australia.
   Kurzynski, Marek, Wroclaw Univ Technol, Fac Elect, Chair Syst \& Comp Networks, PL-50370 Wroclaw, Poland.},
DOI = {10.1016/j.inffus.2011.03.007},
Keywords = {Multiple classifier system; Dynamic ensemble selection; Competence
   measure; Random classification},
Keywords-Plus = {ACCURACY; DISSIMILARITY; CLASSIFIERS; FUSION; DIVERSITY},
Author-Email = {tom@mech.uwa.edu.au
