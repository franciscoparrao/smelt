   Li, Jingming, Anhui Univ Finance \& Econ, Sch Management Sci \& Engn, Bengbu, Peoples R China.},
DOI = {10.3233/JIFS-169993},
Keywords = {Artificial fish swarm algorithm; spread behavior; double-fault measure;
   diversity; ensemble pruning},
Keywords-Plus = {EXTREME LEARNING-MACHINE; NEURAL-NETWORKS; DIVERSITY; FRAMEWORK; DESIGN;
   MARGIN},
Author-Email = {zhiwein@163.com},
Number-of-Cited-References = {42},
