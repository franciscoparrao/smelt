   Pandey, Gaurav, Icahn Sch Med Mt Sinai, Grad Sch Biomed Sci, New York, NY 10029 USA.},
DOI = {10.1016/j.ymeth.2015.08.016},
Keywords = {Protein function prediction; Heterogeneous ensembles; Nested
   cross-validation; Diversity-performance tradeoff; Ensemble calibration;
   Distributed machine learning},
Keywords-Plus = {GENETIC INTERACTIONS; DIVERSITY; NETWORKS; FUSION},
