   Zhao, Xingwang; Dang, Chuangyin, City Univ Hong Kong, Dept Syst Engn \& Engn Management, Hong Kong, Hong Kong, Peoples R China.},
DOI = {10.1016/j.patcog.2017.04.019},
Keywords = {Clustering ensemble selection; Categorical data; Clustering validity
   indices; Quality; Diversity},
Keywords-Plus = {K-MODES ALGORITHM; CONSENSUS; IMPACT},
Author-Email = {zhaoxw84@163.com
