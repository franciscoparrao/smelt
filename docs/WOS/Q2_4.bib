@incollection{ WOS:000241262900115,
Author = {Liu, ChangE and Xia, Shanghong and Liu Jia},
Book-Group-Author = {IEEE},
Title = {Classifier ensemble selection for language verification system},
Booktitle = {2006 INTERNATIONAL CONFERENCE ON COMMUNICATIONS, CIRCUITS AND SYSTEMS
   PROCEEDINGS, VOLS 1-4: VOL 1: SIGNAL PROCESSING},
Series = {International Conference on Communications Circuits and Systems},
Year = {2006},
Pages = {505+},
Abstract = {Spoken-language verification system uses classifier combination method
   to improve its performance. The number of classifiers combined
   determines the system's costs in time and calculation. Hence, we aim to
   get the optimal classifier ensemble with less cost and good performance.
   We hope to find some characteristics of classifier ensemble closely
   linked to its equal error rate (EER) and then choose the optimal
   classifier ensemble based on them. Two new diversity measures were
   proposed. Through rank correlation coefficients between them and EER, we
   found new diversity measures had closer correlation with the performance
   of system. Final results showed combining two new measures is the most
   effective to choose the optimal classifier ensemble, which makes system
   14.71\% best relative decrease in EER and about 60\% best relative
   decrease in costs. We also explored preliminarily the robustness of this
   method over open-set corpus.},
Type = {Proceedings Paper},
Affiliation = {Liu, CE (Corresponding Author), Chinese Acad Sci, Inst Elect, Beijing 100080, Peoples R China.
   Liu, ChangE; Xia, Shanghong, Chinese Acad Sci, Inst Elect, Beijing 100080, Peoples R China.
   Liu Jia, Tsinghua Univ, Dept Elect Engn, Beijing 100084, Peoples R China.},
DOI = {10.1109/ICCCAS.2006.284687},
Author-Email = {ChangELiu@mail.ie.ac.cn},
Number-of-Cited-References = {11},
Times-Cited = {0},
Unique-ID = {WOS:000241262900115},
}
