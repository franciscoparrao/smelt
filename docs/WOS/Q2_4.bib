@article{ WOS:000369761500007,
Author = {Mousavi, Reza and Eftekhari, Mahdi and Haghighi, Mehdi Ghezelbash},
Title = {A new approach to human microRNA target prediction using ensemble
   pruning and rotation foreste},
Journal = {JOURNAL OF BIOINFORMATICS AND COMPUTATIONAL BIOLOGY},
Year = {2015},
Volume = {13},
Number = {6, SI},
Month = {DEC},
Abstract = {MicroRNAs (miRNAs) are small non-coding RNAs that have important
   functions in gene regulation. Since finding miRNA target experimentally
   is costly and needs spending much time, the use of machine learning
   methods is a growing research area for miRNA target prediction. In this
   paper, a new approach is proposed by using two popular ensemble
   strategies, i.e. Ensemble Pruning and Rotation Forest (EP-RTF), to
   predict human miRNA target. For EP, the approach utilizes Genetic
   Algorithm (GA). In other words, a subset of classifiers from the
   heterogeneous ensemble is first selected by GA. Next, the selected
   classifiers are trained based on the RTF method and then are combined
   using weighted majority voting. In addition to seeking a better subset
   of classifiers, the parameter of RTF is also optimized by GA. Findings
   of the present study confrim that the newly developed EP-RTF outperforms
   (in terms of classification accuracy, sensitivity, and specificity) the
   previously applied methods over four datasets in the field of human
   miRNA target. Diversity-error diagrams reveal that the proposed ensemble
   approach constructs individual classifiers which are more accurate and
   usually diverse than the other ensemble approaches. Given these
   experimental results, we highly recommend EP-RTF for improving the
   performance of miRNA target prediction.},
Type = {Article},
Affiliation = {Mousavi, R (Corresponding Author), Grad Univ Adv Technol, Dept Elect \& Comp Engn, Kerman, Iran.
   Mousavi, Reza; Haghighi, Mehdi Ghezelbash, Grad Univ Adv Technol, Dept Elect \& Comp Engn, Kerman, Iran.
   Eftekhari, Mahdi, Shahid Bahonar Univ Kerman, Dept Comp Engn, Kerman, Iran.},
DOI = {10.1142/S0219720015500171},
Article-Number = {1550017},
Keywords = {MicroRNA target prediction; ensemble pruning; rotation forest; weighted
   majority voting; genetic algorithm},
Keywords-Plus = {BIOGENESIS},
Author-Email = {r.mousavi@student.kgut.ac.ir
   m.eftekhari@uk.ac.ir
   m.ghezelbash@student.kgut.ac.ir},
Number-of-Cited-References = {46},
Times-Cited = {9},
Unique-ID = {WOS:000369761500007},
}

@incollection{ WOS:000668155900035,
Author = {Xie, Sihong and Gao, Jing and Fan, Wei and Turaga, Deepak and Yu, Philip
   S.},
Book-Group-Author = {ACM},
Title = {Class-Distribution Regularized Consensus Maximization for Alleviating
   Overfitting in Model Combination},
Booktitle = {PROCEEDINGS OF THE 20TH ACM SIGKDD INTERNATIONAL CONFERENCE ON KNOWLEDGE
   DISCOVERY AND DATA MINING (KDD'14)},
Year = {2014},
Pages = {303-312},
Abstract = {In data mining applications such as crowdsourcing and privacy-preserving
   data mining, one may wish to obtain consolidated predictions out of
   multiple models without access to features of the data. Besides,
   multiple models usually carry complementary predictive information,
   model combination can potentially provide more robust and accurate
   predictions by correcting independent errors from individual models.
   Various methods have been proposed to combine predictions such that the
   final predictions are maximally agreed upon by multiple base models.
   Though this maximum consensus principle has been shown to be successful,
   simply maximizing consensus can lead to less discriminative predictions
   and overfit the inevitable noise due to imperfect base models. We argue
   that proper regularization for model combination approaches is needed to
   alleviate such overfitting effect. Specifically, we analyze the
   hypothesis spaces of several model combination methods and identify the
   trade-off between model consensus and generalization ability. We propose
   a novel model called Regularized Consensus Maximization (RCM), which is
   formulated as an optimization problem to combine the maximum consensus
   and large margin principles. We theoretically show that RCM has a
   smaller upper bound on generalization error compared to the version
   without regularization. Experiments show that the proposed algorithm
   outperforms a wide spectrum of state-of-the-art model combination
   methods on 11 tasks.},
Type = {Proceedings Paper},
Affiliation = {Xie, SH (Corresponding Author), Univ Illinois, Dept Comp Sci, Chicago, IL 60612 USA.
   Xie, Sihong; Yu, Philip S., Univ Illinois, Dept Comp Sci, Chicago, IL 60612 USA.
   Gao, Jing, Univ Buffalo, Dept Comp Sci, Buffalo, NY USA.
   Turaga, Deepak, IBM TJ Watson Res, Yorktown Height, NY USA.
   Fan, Wei, Huawei Noahs Ark Lab, Hong Kong, Peoples R China.},
DOI = {10.1145/2623330.2623676},
Keywords = {Ensemble; Large Margin; Generalization Error},
Number-of-Cited-References = {39},
Times-Cited = {9},
Unique-ID = {WOS:000668155900035},
}

@incollection{ WOS:000295224300228,
Author = {Diao, Ren and Shen, Qiang},
Book-Group-Author = {IEEE},
Title = {Fuzzy-rough Classifier Ensemble Selection},
Booktitle = {IEEE INTERNATIONAL CONFERENCE ON FUZZY SYSTEMS (FUZZ 2011)},
Series = {IEEE International Conference on Fuzzy Systems},
Year = {2011},
Pages = {1516-1522},
Abstract = {Classifier ensembles constitute one of the main research directions in
   machine learning and data mining. Ensembles allow higher accuracy to be
   achieved which is otherwise often not achievable with a single
   classifier. A number of approaches have been adopted for constructing
   classifier ensembles and aggregate ensemble decisions. In most cases,
   these constructed ensembles contain redundant members that, if removed,
   may further increase ensemble diversity and produce better results.
   Smaller ensembles also relax the memory and storage requirements of an
   ensemble system, reducing its run-time overhead while improving overall
   efficiency. In this paper, a new approach to classifier ensemble
   selection based on fuzzy-rough feature selection and harmony search is
   proposed. By transforming the ensemble predictions into training
   samples, classifiers are treated as features. Harmony search is then
   used to select a minimal subset of such artificial features that
   maximises the fuzzy-rough dependency measure. The resulting technique is
   compared against the original ensemble and ensembles formed using random
   selection, under both single algorithm and mixed classifier ensemble
   environments.},
Type = {Proceedings Paper},
Affiliation = {Diao, R (Corresponding Author), Aberystwyth Univ, Dept Comp Sci, Aberystwyth SY23 3DB, Dyfed, Wales.
   Diao, Ren; Shen, Qiang, Aberystwyth Univ, Dept Comp Sci, Aberystwyth SY23 3DB, Dyfed, Wales.},
Keywords = {Classifier Ensemble Selection; Feature Selection; Harmony Search;
   Fuzzy-rough Sets},
Author-Email = {rrd09@aber.ac.uk
   qqs@aber.ac.uk},
Number-of-Cited-References = {23},
Times-Cited = {9},
Unique-ID = {WOS:000295224300228},
}

@article{ WOS:001511660800020,
Author = {Hou, Jiaye and Xu, Dongwei and Song, Fuxing and Chen, Zhuangzhi and
   Xuan, Qi and Zheng, Shilian and Lin, Yun and Yang, Xiaoniu},
Title = {Multi-View Discriminant Framework for Automatic Modulation Open Set
   Recognition},
Journal = {IEEE TRANSACTIONS ON COMMUNICATIONS},
Year = {2025},
Volume = {73},
Number = {6},
Pages = {4378-4393},
Month = {JUN},
Abstract = {Automatic Modulation Open Set Recognition (AMOSR) has practical
   significance in detecting unknown classes. However, a challenge arises
   when unknown samples closely resemble known samples, posing a formidable
   task for accurate detection. A novel AMOSR framework based on multi-view
   discriminators' joint judgment is proposed to handle this challenge.
   Firstly, utilizing signal domain knowledge, multi-dimensional features
   are extracted through varied signal time-frequency transforms and
   encoders, baesd on which multiple discriminators are created. Secondly,
   Constrained Clustering Prototype Loss and Geodesic Contrastive Loss are
   introduced to pretrain these discriminators, providing more space for
   unknown signals. Then, collaborative learning is employed to further
   fine-tune the aforementioned discriminators, enhancing information
   sharing between modalities. Furthermore, a set of indicators is
   constructed, and multi-criteria fusion is performed using the TOPSIS
   algorithm to evaluate the discrimination capabilities of different
   classifiers in both closed-set and open-set scenarios. Furthermore, a
   decision tree is constructed to segregate test signals into known and
   unknown classes, in which discriminators with higher confidence levels
   are given precedence. Finally, TOPSIS hierarchical ensemble pruning
   algorithm that considers diversity and open-set recognition capabilities
   is adopted to reduce model complexity while maintaining original
   performance. Extensive experiments conducted on modulation datasets
   demonstrate the superiority of this framework over state-of-the-art
   AMOSR results.},
Type = {Article},
Affiliation = {Xu, DW (Corresponding Author), Zhejiang Univ Technol, Inst Cyberspace Secur, Coll Informat Engn, Hangzhou 310023, Peoples R China.
   Hou, Jiaye; Xu, Dongwei; Song, Fuxing; Chen, Zhuangzhi; Xuan, Qi, Zhejiang Univ Technol, Inst Cyberspace Secur, Coll Informat Engn, Hangzhou 310023, Peoples R China.
   Hou, Jiaye; Xu, Dongwei; Song, Fuxing; Chen, Zhuangzhi; Xuan, Qi; Lin, Yun, ZJUT, Binjiang Artificial Intelligence Inst, Hangzhou 310056, Peoples R China.
   Zheng, Shilian, Natl Key Lab Electromagnet Space Secur, Innovat Studio Academician Yang, Jiaxing 314033, Peoples R China.
   Lin, Yun, Harbin Engn Univ, Coll Informat \& Commun Engn, Harbin 150009, Peoples R China.
