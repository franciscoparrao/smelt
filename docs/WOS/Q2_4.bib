@article{ WOS:000267117500001,
Author = {Ko, Albert Hung-Ren and Sabourin, Robert and Britto, Jr., Alceu De Souza},
Title = {COMPOUND DIVERSITY FUNCTIONS FOR ENSEMBLE SELECTION},
Journal = {INTERNATIONAL JOURNAL OF PATTERN RECOGNITION AND ARTIFICIAL INTELLIGENCE},
Year = {2009},
Volume = {23},
Number = {4},
Pages = {659-686},
Month = {JUN},
Abstract = {An effective way to improve a classification method's performance is to
   create ensembles of classifiers. Two elements are believed to be
   important in constructing an ensemble: (a) the performance of each
   individual classifier; and (b) diversity among the classifiers.
   Nevertheless, most works based on diversity suggest that there exists
   only weak correlation between classifier performance and ensemble
   accuracy. We propose compound diversity functions which combine the
   diversities with the performance of each individual classifier, and show
   that there is a strong correlation between the proposed functions and
   ensemble accuracy. Calculation of the correlations with different
   ensemble creation methods, different problems and different
   classification algorithms on 0.624 million ensembles suggests that most
   compound diversity functions are better than traditional diversity
   measures. The population-based Genetic Algorithm was used to search for
   the best ensembles on a handwritten numerals recognition problem and to
   evaluate 42.24 million ensembles. The statistical results indicate that
   compound diversity functions perform better than traditional diversity
   measures, and are helpful in selecting the best ensembles.},
Type = {Article},
Affiliation = {Ko, AHR (Corresponding Author), Univ Quebec, LIVIA, Ecole Technol Super, 1100 Notre Dame W St, Montreal, PQ H3C 1K3, Canada.
   Ko, Albert Hung-Ren; Sabourin, Robert, Univ Quebec, LIVIA, Ecole Technol Super, Montreal, PQ H3C 1K3, Canada.
   Britto, Alceu De Souza, Jr., Pontificia Univ Catolica Parana, PPGIA, BR-80215901 Curitiba, Parana, Brazil.},
DOI = {10.1142/S021800140900734X},
Keywords = {Diversity; ensemble of classifiers; pattern recognition; majority voting},
Keywords-Plus = {VARIANCE; BIAS},
Author-Email = {albert@livia.etsmtl.ca
   robert.sabourin@etsmtl.ca
   alceu@ppgia.pucpr.br},
