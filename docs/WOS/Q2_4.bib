   Li, Yuanke; Liu, Yiyang; Wang, Hongfei, Huazhong Univ Sci \& Technol, Sch Cyber Sci \& Engn, Hubei Engn Res Ctr Big Data Secur, Hubei Key Lab Distributed Syst Secur, Wuhan, Peoples R China.
   Zou, Dongmian, Duke Kunshan Univ, Chongzhi Ctr, Digital Innovat Res Ctr, Kunshan, Peoples R China.},
DOI = {10.1145/3746252.3761349},
Keywords = {Ensemble Learning; Graph Neural Networks; Ensemble Pruning},
Keywords-Plus = {DIVERSITY},
Author-Email = {yuanke.ada@gmail.com
   yiyangliu7777@gmail.com
   dongmian.zou@duke.edu
   hongfei@hust.edu.cn},
