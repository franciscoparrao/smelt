DOI = {10.1016/j.jksuci.2023.101672},
EarlyAccessDate = {AUG 2023},
Article-Number = {101672},
Keywords = {Cloud storage; Cloud computing; Reliability; Ensemble pruning; Accuracy
   sliding window; Latent sector error; Prediction; Random forest; Carbon
   recycling; Sustainable energy; Carbon footprint},
Keywords-Plus = {GLOWWORM SWARM OPTIMIZATION; FAILURE PREDICTION; EFFICIENT},
