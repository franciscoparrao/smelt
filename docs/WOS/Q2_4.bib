@incollection{ WOS:000364539000018,
Author = {Ahmed, Muhammad A. O. and Didaci, Luca and Fumera, Giorgio and Roli,
   Fabio},
Editor = {Schwenker, F and Roli, F and Kittler, J},
Title = {An Empirical Investigation on the Use of Diversity for Creation of
   Classifier Ensembles},
Booktitle = {MULTIPLE CLASSIFIER SYSTEMS (MCS 2015)},
Series = {Lecture Notes in Computer Science},
Year = {2015},
Volume = {9132},
Pages = {206-219},
Abstract = {We address one of the main open issues about the use of diversity in
   multiple classifier systems: the effectiveness of the explicit use of
   diversity measures for creation of classifier ensembles. So far,
   diversity measures have been mostly used for ensemble pruning, namely,
   for selecting a subset of classifiers out of an original, larger
   ensemble. Here we focus on pruning techniques based on forward/backward
   selection, since they allow a direct comparison with the simple
   estimation of accuracy of classifier ensemble. We empirically carry out
   this comparison for several diversity measures and benchmark data sets,
   using bagging as the ensemble construction technique, and majority
   voting as the fusion rule. Our results provide further and more direct
   evidence to previous observations against the effectiveness of the use
   of diversity measures for ensemble pruning, but also show that, combined
   with ensemble accuracy estimated on a validation set, diversity can have
   a regularization effect when the validation set size is small.},
Type = {Proceedings Paper},
Affiliation = {Fumera, G (Corresponding Author), Univ Cagliari, Dept Elect \& Elect Engn, Piazza Armi, I-09123 Cagliari, Italy.
   Ahmed, Muhammad A. O.; Didaci, Luca; Fumera, Giorgio; Roli, Fabio, Univ Cagliari, Dept Elect \& Elect Engn, I-09123 Cagliari, Italy.},
DOI = {10.1007/978-3-319-20248-8\_18},
Keywords = {Diversity; Ensemble pruning; Forward/backward selection; Ensemble
   construction},
Author-Email = {muhammad.ahmed@diee.unica.it
   didaci@diee.unica.it
   fumera@diee.unica.it
   roli@diee.unica.it},
Number-of-Cited-References = {23},
Times-Cited = {5},
Unique-ID = {WOS:000364539000018},
}

@incollection{ WOS:000364813200015,
Author = {Kanawati, Rushed},
Editor = {Meiselwitz, G},
Title = {Ensemble Selection for Community Detection in Complex Networks},
Booktitle = {SOCIAL COMPUTING AND SOCIAL MEDIA, SCSM 2015},
Series = {Lecture Notes in Computer Science},
Year = {2015},
Volume = {9182},
Pages = {138-147},
Abstract = {Ensemble clustering approaches have been recently applied, in a variety
   of ways, in order to enhance the quality and/or the execution time of
   community detection tasks. The quality gain that can be obtained from
   applying ensemble approaches is known to be tightly linked to both
   quality and diversity of the applied clusterings. However, most of
   existing work simply ignore this important issue of ensemble selection.
   In this paper we intend to fill this gap. We propose a graph-based
   ensemble selection approach that allow to take into account both
   criteria of quality and diversity. Different quality measures are also
   considered: cluster-oriented quality and network-oriented quality
   functions. Experiments on real network datasets show the validity of our
   approach.},
Type = {Proceedings Paper},
Affiliation = {Kanawati, R (Corresponding Author), Univ Paris 13, Sorbonne Paris Cite, LIPN, CNRS,UMR 7030, F-93430 Villetaneuse, France.
   Kanawati, Rushed, Univ Paris 13, Sorbonne Paris Cite, LIPN, CNRS,UMR 7030, F-93430 Villetaneuse, France.},
DOI = {10.1007/978-3-319-20367-6\_15},
Keywords = {Community detection; Complex networks; Ensemble clustering; Ensemble
   selection},
Keywords-Plus = {CLUSTERINGS},
Author-Email = {rushed.kanawati@lipn.univ-paris13.fr},
Number-of-Cited-References = {25},
Times-Cited = {5},
Unique-ID = {WOS:000364813200015},
}

@incollection{ WOS:000343489100129,
Author = {Yan, Yan and Yin, Xu-Cheng and Wang, Zhi-Bin and Yin, Xuwang and Yang,
   Chun and Hao, Hong-Wei},
Book-Group-Author = {IEEE},
Title = {Sorting-Based Dynamic Classifier Ensemble Selection},
Booktitle = {2013 12TH INTERNATIONAL CONFERENCE ON DOCUMENT ANALYSIS AND RECOGNITION
   (ICDAR)},
Series = {Proceedings of the International Conference on Document Analysis and
   Recognition},
Year = {2013},
Pages = {673-677},
Abstract = {In ensemble learning, a higher accuracy can be achieved by integrating
   some classifiers instead of all the classifiers. But, it is very
   difficult to select the best classifier combination which can be seen as
   an optimization problem, from a pool of classifiers. To deal with this
   problem, we propose a new classifier selection method, Sorting-based
   Dynamic Classifier Ensemble Selection (SDES), which consists of two
   stages: (1) classifier sorting, and (2) dynamic ensemble selection on
   sorted classifier sequence. In the first stage, classifiers are sorted
   based on diversity, to avoid searching for the nearest neighbors in
   dynamic ensemble selection methods and greatly improve the selection
   efficiency. In the second stage, the optimal subset of classifiers is
   selected from the sorted classifier sequence based on confidence of test
   samples, to guarantee high accuracy of the optimal classifier subset.
   Experimental results have shown the effectiveness and high efficiency of
   the proposed method.},
Type = {Proceedings Paper},
Affiliation = {Yin, XC (Corresponding Author), Univ Sci \& Technol Beijing, Sch Comp \& Commun Engn, Beijing 100083, Peoples R China.
   Yan, Yan; Yin, Xu-Cheng; Yin, Xuwang; Yang, Chun, Univ Sci \& Technol Beijing, Sch Comp \& Commun Engn, Beijing 100083, Peoples R China.
   Wang, Zhi-Bin, China Natl Engn Res Ctr, Informat Technol Agr, Beijing 100097, Peoples R China.
   Hao, Hong-Wei, Chinese Acad Sci, Inst Automat, Beijing 100190, Peoples R China.},
DOI = {10.1109/ICDAR.2013.138},
Keywords = {diversity measurement; classifier sorting; dynamic ensemble selection;
   ensemble learning},
Keywords-Plus = {COMBINING CLASSIFIERS; ACCURACY},
Author-Email = {yanyanstudy@gmail.com
   xuchengyin@ustb.edu.cn
   wzb1818@yahoo.cn
   xuwangyin@gmail.com
   ych.learning@gmail.com
   hongwei.hao@ia.ac.cn},
Number-of-Cited-References = {22},
