@incollection{ WOS:000298615102010,
Author = {Cao, Jingjing and Kwong, Sam and Wang, Hanli and Li, Ke},
Book-Group-Author = {IEEE},
Title = {Combining Interpretable Fuzzy Rule-Based Classifiers via Multi-Objective
   Hierarchical Evolutionary Algorithm},
Booktitle = {2011 IEEE INTERNATIONAL CONFERENCE ON SYSTEMS, MAN, AND CYBERNETICS
   (SMC)},
Series = {IEEE International Conference on Systems Man and Cybernetics Conference
   Proceedings},
Year = {2011},
Pages = {1771-1776},
Abstract = {The contributions of this paper are two-fold: firstly, it employs a
   multi-objective evolutionary hierarchical algorithm to obtain a
   non-dominated fuzzy rule classifier set with interpretability and
   diversity preservation. Secondly, a reduce-error based ensemble pruning
   method is utilized to decrease the size and enhance the accuracy of the
   combined fuzzy rule classifiers. In this algorithm, each chromosome
   represents a fuzzy rule classifier and compose of three different types
   of genes: control, parameter and rule genes. In each evolution
   iteration, each pair of classifiers in non-dominated solution set with
   the same multi-objective qualities are examined in terms of Q statistic
   diversity values. Then, similar classifiers are removed to preserve the
   diversity of the fuzzy system. Finally, experimental results on the ten
   UCI benchmark datasets indicate that our approach can maintain a good
   trade-off among accuracy, interpretability and diversity of fuzzy
   classifiers.},
Type = {Proceedings Paper},
Affiliation = {Cao, JJ (Corresponding Author), City Univ Hong Kong, Dept Comp Sci, Kowloon, Hong Kong, Peoples R China.
   Cao, Jingjing; Kwong, Sam; Wang, Hanli; Li, Ke, City Univ Hong Kong, Dept Comp Sci, Kowloon, Hong Kong, Peoples R China.},
Keywords = {Multi-objective evolutionary algorithm (MOEAs); Fuzzy rule-based systems
   (FRBCs); Interpretability; Ensemble diversity; Ensemble pruning},
Keywords-Plus = {CLASSIFICATION; COMPLEXITY},
Author-Email = {jingca03@student.cityu.edu.hk
