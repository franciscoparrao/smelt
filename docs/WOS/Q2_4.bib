@incollection{ WOS:000553441500149,
Author = {Saraiva Albuquerque, Regis Antonio and Josua Costa, Albert Franca and
   dos Santos, Eulanda Miranda and Sabourin, Robert and Giusti, Rafael},
Book-Group-Author = {IEEE},
Title = {A Decision-Based Dynamic Ensemble Selection Method for Concept Drift},
Booktitle = {2019 IEEE 31ST INTERNATIONAL CONFERENCE ON TOOLS WITH ARTIFICIAL
   INTELLIGENCE (ICTAI 2019)},
Series = {Proceedings-International Conference on Tools With Artificial
   Intelligence},
Year = {2019},
Pages = {1132-1139},
Abstract = {We propose an online method for concept drift detection based on dynamic
   classifier ensemble selection. The proposed method generates a pool of
   ensembles by promoting diversity among classifier members and chooses
   expert ensembles according to global prequential accuracy values. Unlike
   current dynamic ensemble selection approaches that use only local
   knowledge to select the most competent ensemble for each instance, our
   method focuses on selection taking into account the decision space.
   Consequently, it is well adapted to the context of drift detection in
   data stream problems. The results of the experiments show that the
   proposed method attained the highest detection precision and the lowest
   number of false alarms, besides competitive classification accuracy
   rates, in artificial datasets representing different types of drifts.
   Moreover, it outperformed baselines in different real-problem datasets
   in terms of classification accuracy.},
Type = {Proceedings Paper},
Affiliation = {Albuquerque, RAS (Corresponding Author), Univ Fed Amazonas, Manaus, Amazonas, Brazil.
   Saraiva Albuquerque, Regis Antonio; dos Santos, Eulanda Miranda; Giusti, Rafael, Univ Fed Amazonas, Manaus, Amazonas, Brazil.
   Josua Costa, Albert Franca, Fed Inst Amazonas, Manaus, Amazonas, Brazil.
   Sabourin, Robert, Ecole Technol Super, Montreal, PQ, Canada.},
DOI = {10.1109/ICTAI.2019.00158},
Keywords = {concept drift; dynamic ensemble selection},
Keywords-Plus = {CLASSIFIER SELECTION},
Author-Email = {regis.albuquerque1@gmail.com
