@incollection{ WOS:000462163500147,
Author = {Kurzynski, Marek and Trajdos, Pawel},
Editor = {Li, W and Li, Q and Wang, L},
Title = {An Ensemble Pruning Method Based on Class and Inter-class Competences
   for Computer-aided Medical Decisions},
Booktitle = {2018 11TH INTERNATIONAL CONGRESS ON IMAGE AND SIGNAL PROCESSING,
   BIOMEDICAL ENGINEERING AND INFORMATICS (CISP-BMEI 2018)},
Year = {2018},
Abstract = {Classifier ensemble pruning is a technique to increase ensemble accuracy
   and reduce its size. In the paper we propose a novel method of ensemble
   pruning which is based on the local class and inter-class competences of
   base classifiers for the test object. In the first step, using the
   inter-class competences, we identify classifiers that tend to commit the
   same type of errors. The identified classifiers create a common cluster.
   In the second step, classifiers in each cluster are ordered according to
   the class competence and then the top-k ones are selected from each
   cluster as the final ensemble. Experimental investigations of the
   proposed pruning method for two homogeneous pools of base classifiers
   and for three values of parameter k were conducted. In experimental
   studies we used 16 real data sets related to the various medical
   decision-making problems. Obtained results clearly show that the use of
   the ensemble pruning procedure leads to the better classification
   accuracy.},
Type = {Proceedings Paper},
Affiliation = {Kurzynski, M (Corresponding Author), Wroclaw Univ Sci \& Technol, Dept Syst \& Comp Networks, Wyb Wyspianskiego 27, PL-50370 Wroclaw, Poland.
   Kurzynski, Marek; Trajdos, Pawel, Wroclaw Univ Sci \& Technol, Dept Syst \& Comp Networks, Wyb Wyspianskiego 27, PL-50370 Wroclaw, Poland.},
Keywords-Plus = {CLASSIFICATION; CLASSIFIERS; DIVERSITY},
Number-of-Cited-References = {31},
Times-Cited = {0},
Unique-ID = {WOS:000462163500147},
}

@incollection{ WOS:000363699900039,
Author = {Dias, Kaushala and Windeatt, Terry},
Editor = {Rojas, I and Joya, G and Catala, A},
Title = {Hybrid Dynamic Learning Systems for Regression},
Booktitle = {ADVANCES IN COMPUTATIONAL INTELLIGENCE, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2015},
Volume = {9095},
Pages = {464-476},
Abstract = {Methods of introducing diversity into ensemble learning predictors for
   regression problems are presented. Two methods are proposed in this
   paper, one involving pruning and the other a hybrid approach. In these
   ensemble learning approaches, diversity is introduced while
   simultaneously training, as part of the same learning process. Here not
   all members of the ensemble are trained in the same manner, but
   selectively trained, resulting in a diverse selection of ensemble
   members that have strengths in different parts of the training set. The
   result is that the prediction accuracy and generalization ability of the
   trained ensemble is enhanced. Pruning and hybrid heuristics attempt to
   combine accurate yet complementary members; therefore these methods
   enhance the performance by dynamically modifying the pruned aggregation
   through distributing the ensemble member selection over the entire
   dataset. A comparison is drawn with Negative Correlation Learning and a
   static ensemble pruning approach used in regression to highlight the
   performance improvement yielded by the dynamic methods. Experimental
   comparison is made using Multiple Layer Perceptron predictors on
   benchmark datasets, and on a signal calibration application.},
Type = {Proceedings Paper},
Affiliation = {Dias, K (Corresponding Author), Univ Surrey, Ctr Vis Speech \& Signal Proc, Guildford GU2 5XH, Surrey, England.
   Dias, Kaushala; Windeatt, Terry, Univ Surrey, Ctr Vis Speech \& Signal Proc, Guildford GU2 5XH, Surrey, England.},
DOI = {10.1007/978-3-319-19222-2\_39},
Keywords = {Ensemble methods; Ensemble pruning; Ensemble learning; Neural networks},
Keywords-Plus = {ENSEMBLES; SELECTION},
Author-Email = {k.dias@surrey.ac.uk
   t.windeatt@surrey.ac.uk},
Number-of-Cited-References = {9},
Times-Cited = {0},
Unique-ID = {WOS:000363699900039},
}

@incollection{ WOS:000373727600011,
Author = {Kolly, Jeremy},
Editor = {FruhwirthSchnatter, S and Bitto, A and Kastner, G and Posekany, A},
Title = {Formal and Heuristic Model Averaging Methods for Predicting the US
   Unemployment Rate},
Booktitle = {BAYESIAN STATISTICS FROM METHODS TO MODELS AND APPLICATIONS: RESEARCH
   FROM BAYSM 2014},
Series = {Springer Proceedings in Mathematics \& Statistics},
Year = {2015},
Volume = {126},
Pages = {125-132},
Abstract = {We consider a logistic transform of the monthly US unemployment rate.
   For this time series, a pseudo out-of-sample forecasting competition is
   held between linear and nonlinear models and averages of these models.
   To combine predictive densities, we use two complementary methods:
   Bayesian model averaging and optimal pooling. We select the individual
   models combined by these methods with the evolution of Bayes factors
   over time. Model estimation is carried out using Markov chain Monte
   Carlo algorithms and predictive densities are evaluated with statistical
   tests and log scores. The sophisticated averages of linear and nonlinear
   models turn out to be valuable tools for predicting the US unemployment
   rate in the short-term.},
Type = {Proceedings Paper},
Affiliation = {Kolly, J (Corresponding Author), Univ Laval, Finance Insurance \& Real Estate Dept, Quebec City, PQ, Canada.
   Kolly, Jeremy, Univ Laval, Finance Insurance \& Real Estate Dept, Quebec City, PQ, Canada.
