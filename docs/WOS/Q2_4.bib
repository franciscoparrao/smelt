   mfan@zzu.edu.cn},
Number-of-Cited-References = {18},
Times-Cited = {2},
Unique-ID = {WOS:000309192100080},
}

@incollection{ WOS:000307024300043,
Author = {Guo, Huaping and Fan, Ming},
Editor = {Wang, H and Li, S and Oyama, S and Hu, XH and Qian, T},
Title = {Ensemble Pruning via Base-Classifier Replacement},
Booktitle = {WEB-AGE INFORMATION MANAGEMENT},
Series = {Lecture Notes in Computer Science},
Year = {2011},
Volume = {6897},
Pages = {505-516},
Abstract = {Ensemble pruning is a technique to increase ensemble accuracy and reduce
   its size by choosing an optimal or suboptimal subset of ensemble members
   to form subensembles for prediction. A number of greedy ensemble pruning
   methods that are based on greedy search policy have recently been
   proposed. In this paper, we contribute a new greedy ensemble pruning
   method, called EPR, based on replacement policy. Unlike traditional
   pruning methods, EPR searches for the optimal or suboptimal subensemble
   with predefined size by iteratively replacing the least important
   classifier in it with current classifier. Especially, replacement would
   not occur if the current classifier was the least important one. Also,
   we adopt diversity measure {[}1] to theoretically analyze the properties
   of EPR, based on which a new metric is proposed to guide EPR's search
   process. We evaluate the performance of EPR by comparing it with other
   advanced greenly ensemble pruning methods and obtain very promising
   results.},
Type = {Proceedings Paper},
Affiliation = {Guo, HP (Corresponding Author), Zhengzhou Univ, Sch Informat Engn, Zhengzhou, Peoples R China.
   Guo, Huaping; Fan, Ming, Zhengzhou Univ, Sch Informat Engn, Zhengzhou, Peoples R China.},
Keywords = {Ensemble Pruning; Greedy Search; Replacement Policy},
Keywords-Plus = {DIVERSITY},
