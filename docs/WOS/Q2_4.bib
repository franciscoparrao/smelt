   Zhang, Xiaoyan, Xiamen Univ, Tan Kah Kee Coll, Xiamen 363105, Peoples R China.},
DOI = {10.1007/s00500-020-05274-z},
EarlyAccessDate = {AUG 2020},
Keywords = {Deep forest; Ensemble pruning; Feature vectorization; Quantum walks},
Keywords-Plus = {CLASSIFIER; DIVERSITY; IMAGERY; MARGIN},
Author-Email = {lkhqz@xmu.edu.cn
   wangbz@xmu.edu.cn},
