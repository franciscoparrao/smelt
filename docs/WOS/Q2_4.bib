DOI = {10.1109/JSTARS.2022.3158761},
Keywords = {Hyperspectral imaging; Collaboration; Image classification;
   Classification algorithms; Kernel; Training; Heuristic algorithms;
   Collaborative representation (CR) classifiers; dynamic ensemble
   learning; hyperspectral imagery; multiview clustering (MVC); subspace
   clustering},
Keywords-Plus = {ANOMALY DETECTION; SVM ENSEMBLE; LOW-RANK; SELECTION; CLASSIFIERS;
   REPRESENTATION; COMBINATION; ACCURACY},
Author-Email = {hllu\_hhu@163.com
