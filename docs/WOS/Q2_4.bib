   Cordeiro, Paulo R. G., Inst Fed Pernambuco, Campus Barreiros, BR-55560000 Barreiros, Brazil.
   Cruz, Rafael M. O., Ecole Technol Suprieure, Software Engn Dept, Montreal, PQ, Canada.},
DOI = {10.1109/ACCESS.2023.3304912},
Keywords = {Dynamic ensemble selection; multiple classifier systems; oracle;
   hardness-aware oracle},
Keywords-Plus = {HETEROGENEOUS ENSEMBLE; CLASSIFIER ENSEMBLES; COMPETENCE; DIVERSITY;
   FUSION},
Author-Email = {prgc@cin.ufpe.br},
Number-of-Cited-References = {38},
