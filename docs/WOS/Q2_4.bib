   Atas, Pinar Karadayi, Bahcesehir Univ, Fac Engn \& Nat Sci, Dept Comp Engn, Istanbul, Turkey.
   Ozogur-Akyuz, Sureyya, Bahcesehir Univ, Dept Math, Istanbul, Turkey.},
DOI = {10.1111/coin.12267},
EarlyAccessDate = {JAN 2020},
Keywords = {clustering; DCCP; ensemble learning; ensemble pruning; k-means},
Keywords-Plus = {WEIGHTED ENSEMBLE; SELECTION; DIVERSITY; ALGORITHM; QUALITY},
Author-Email = {sureyya.akyuz@eng.bau.edu.tr},
