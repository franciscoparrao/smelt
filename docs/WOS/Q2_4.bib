   Dejaegere, Gilles, Univ Libre Bruxelles, Serv Math Gest, Blvd Triomphe CP 210-01, B-1050 Brussels, Belgium.},
DOI = {10.1016/j.ejor.2023.10.029},
EarlyAccessDate = {JAN 2024},
Keywords = {Multiple objective programming; Cluster ensembles; Ensemble selection;
   Consensus clustering},
