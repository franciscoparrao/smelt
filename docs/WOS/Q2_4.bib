   Su, Guoxiong, Beijing Dr Acne Med Res Inst, Beijing, Peoples R China.
   Ren, Yanjiao, Jilin Agr Univ, Coll Informat Technol, Smart Agr Res Inst, Changchun, Jilin, Peoples R China.},
DOI = {10.1111/srt.13166},
EarlyAccessDate = {MAY 2022},
Keywords = {acne; acne grade; deep learning; ensemble classification; ensemble
   pruning},
Keywords-Plus = {NEURAL-NETWORK; CLASSIFICATION; DEPRESSION; ALGORITHM; VULGARIS},
