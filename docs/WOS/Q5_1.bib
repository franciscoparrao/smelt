@article{ WOS:001148369400001,
Author = {Maxwell, Tania L. and Hengl, Tomislav and Parente, Leandro L. and
   Minarik, Robert and Worthington, Thomas A. and Bunting, Pete and Smart,
   Lindsey S. and Spalding, Mark D. and Landis, Emily},
Title = {Global mangrove soil organic carbon stocks dataset at 30 m resolution
   for the year 2020 based on spatiotemporal predictive machine learning},
Journal = {DATA IN BRIEF},
Year = {2023},
Volume = {50},
Month = {OCT},
Abstract = {This dataset presents global soil organic carbon stocks in mangrove
   forests at 30 m resolution, predicted for 2020. We used spatiotemporal
   ensemble machine learning to produce predictions of soil organic carbon
   content and bulk density (BD) to 1 m soil depth, which were then
   aggregated to calculate soil organic carbon stocks. This was done by
   using training data points of both SOC (\%) and BD in mangroves from a
   global dataset and from recently published studies, and globally
   consistent predictive covariate layers. A total of 10,331 soil samples
   were validated to have SOC (\%) measurements and were used for
   predictive soil mapping. We used time-series remote sensing data
   specific to time periods when the training data were sampled, as well as
   long-term (static) layers to train an ensemble of machine learning
   model. Ensemble models were used to improve performance, robustness and
   unbiasedness as opposed to just using one learner. In addition, we
   performed spatial cross-validation by using spatial blocking of training
   data points to assess model performance. We predicted SOC stocks for the
   2020 time period and applied them to a 2020 mangrove extent map,
   presenting both mean predictions and prediction intervals to represent
   the uncertainty around our predictions. Predictions are available for
   download under CC-BY license from 10.5281/zenodo.7729491 and also as
   Cloud-Optimized GeoTIFFs (global mosaics).(c) 2023 Published by Elsevier
   Inc. This is an open access article under the CC BY license (
   http://creativecommons.org/licenses/by/4.0/ )},
Type = {Article},
Affiliation = {Maxwell, TL (Corresponding Author), Univ Cambridge, Dept Zool, Conservat Sci Grp, Cambridge, England.
   Hengl, T (Corresponding Author), EnvirometriX Ltd, NL-6708 PW Wageningen, Netherlands.
   Maxwell, Tania L.; Worthington, Thomas A.; Spalding, Mark D., Univ Cambridge, Dept Zool, Conservat Sci Grp, Cambridge, England.
   Hengl, Tomislav; Parente, Leandro L., EnvirometriX Ltd, NL-6708 PW Wageningen, Netherlands.
   Minarik, Robert, OpenGeoHub Fdn, NL-6708 PW Wageningen, Netherlands.
   Bunting, Pete, Aberystwyth Univ, Dept Geog \& Earth Sci, Aberystwyth SY23 3DB, Wales.
   Smart, Lindsey S.; Landis, Emily, Nature Conservancy, Arlington, VA USA.
   Spalding, Mark D., Nature Conservancy, Strada Tolfe 14, I-53100 Siena, Italy.},
DOI = {10.1016/j.dib.2023.109621},
EarlyAccessDate = {OCT 2023},
Article-Number = {109621},
Keywords = {Blue carbon; Carbon sequestration; Coastal ecosystem; Spatial modelling;
   Mangroves},
