   Bizimana, Jean Pierre, Univ Rwanda, Dept Geog \& Urban Planning, Kigali, Rwanda.
   Mansourian, Ali, Lund Univ Profile Area Nat based Future Solut, Lund, Sweden.},
DOI = {10.4081/gh.2023.1184},
Article-Number = {1184},
Keywords = {geographically weighted random forest; variable importance; partial
