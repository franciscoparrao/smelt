   Guo, Gaoxuan, Beijing Inst Hydrogeol \& Engn Geol, Beijing 100048, Peoples R China.
   Wang, Jingbo, Australian Natl Univ, Natl Computat Infrastruct, Canberra, ACT, Australia.
   Teatini, Pietro, Univ Padua, Dept Civil Environm \& Architectural Engn, I-35121 Padua, Italy.
   Teatini, Pietro, UNESCO LaSII Land Subsidence Int Initiat, Queretaro, Mexico.},
DOI = {10.1016/j.scitotenv.2021.149244},
