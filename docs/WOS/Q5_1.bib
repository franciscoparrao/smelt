   Sun, Jingyu, Shanghai Univ Engn Sci, Sch Mat Sci \& Engineeing, Shanghai 201620, Peoples R China.},
DOI = {10.3390/buildings14113517},
Article-Number = {3517},
Keywords = {urban vitality; milk tea and coffee shops; random forest; MGWR model;
   nonlinear relationships; social interactions},
Keywords-Plus = {OPPORTUNITIES; CONNECTION; COMMUNITY; ACCESS; SPACE; CHINA; LIGHT},
Author-Email = {ts22190042p31@cumt.edu.cn
   changjiang@cumt.edu.cn
