DOI = {10.3390/w16152185},
Article-Number = {2185},
Keywords = {GEE; Tumen River transboundary basin; water body index; spatiotemporal
   variations; driving factors},
Keywords-Plus = {MANAGEMENT CURRENT; CLIMATE-CHANGE; LONG-TERM; RESOLUTION; INDEX;
   CLASSIFICATION; CHALLENGES; REGRESSION},
Author-Email = {2021010763@ybu.edu.cn
