@article{ WOS:001272902300001,
Author = {Liu, Lingbo},
Title = {An ensemble framework for explainable geospatial machine learning models},
Journal = {INTERNATIONAL JOURNAL OF APPLIED EARTH OBSERVATION AND GEOINFORMATION},
Year = {2024},
Volume = {132},
Month = {AUG},
Abstract = {Analyzing spatially varying effects is pivotal in geographic analysis.
   However, accurately capturing and interpreting this variability is
   challenging due to the increasing complexity and non-linearity of
   geospatial data. Recent advancements in integrating Geographically
   Weighted (GW) models with artificial intelligence (AI) methodologies
   offer novel approaches. However, these methods often focus on single
   algorithms and emphasize prediction over interpretability. The recent
   GeoShapley method integrates machine learning (ML) with Shapley values
   to explain the contribution of geographical features, advancing the
   combination of geospatial ML and explainable AI (XAI). Yet, it lacks
   exploration of the nonlinear interactions between geographical features
   and explanatory variables. Herein, an ensemble framework is proposed to
   merge local spatial weighting scheme with XAI and ML technologies to
   bridge this gap. Through tests on synthetic datasets and comparisons
   with GWR, MGWR, and GeoShapley, this framework is verified to enhance
   interpretability and predictive accuracy by elucidating spatial
   variability. Reproducibility is explored through the comparison of
   spatial weighting schemes and various ML models, emphasizing the
   necessity of model reproducibility to address model and parameter
   uncertainty. This framework works in both geographic regression and
   classification, offering a novel approach to understanding complex
   spatial phenomena.},
Type = {Article},
Affiliation = {Liu, LB (Corresponding Author), Harvard Univ, Ctr Geog Anal, Cambridge, MA 02138 USA.
   Liu, LB (Corresponding Author), Wuhan Univ, Sch Urban Design, Wuhan 430072, Hubei, Peoples R China.
   Liu, Lingbo, Harvard Univ, Ctr Geog Anal, Cambridge, MA 02138 USA.
   Liu, Lingbo, Wuhan Univ, Sch Urban Design, Wuhan 430072, Hubei, Peoples R China.},
DOI = {10.1016/j.jag.2024.104036},
EarlyAccessDate = {JUL 2024},
Article-Number = {104036},
Keywords = {Explainable Artificial Intelligence (XAI); GeoAI; Machine Learning;
   Spatially Varying Coefficient; Geographically Weighted Models; XGeoML},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION},
Author-Email = {lingboliu@fas.harvard.edu},
