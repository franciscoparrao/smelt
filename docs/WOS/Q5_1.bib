DOI = {10.1016/j.jhydrol.2022.128177},
EarlyAccessDate = {JUL 2022},
Article-Number = {128177},
Keywords = {Machine learning; Predictive modelling; Model portability; Model
   generalization; Histogram distance; Drain partitioning},
Keywords-Plus = {CENTRAL VALLEY; TILE DRAINAGE; WATER-FLOW; GROUNDWATER; MODELS; SURFACE;
   SCALE; CALIFORNIA; DISCHARGE; PATTERNS},
