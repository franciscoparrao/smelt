@article{ WOS:001645319200001,
Author = {Zhao, Xin and Zhao, Zhifang and Xu, Zemin and Yang, Zhiquan},
Title = {Incorporating spatial heterogeneity of environmental variables into
   landslide susceptibility prediction},
Journal = {GEOCARTO INTERNATIONAL},
Year = {2026},
Volume = {41},
Number = {1},
Month = {DEC 31},
Abstract = {Environmental variables, characterized by spatial heterogeneity, exert a
   significant impact on landslide susceptibility prediction (LSP).
   Previous studies generally assume that within the entire study area, the
   impact of each environmental variable on landslide distribution is
   spatially homogeneous-a perspective that essentially represents a global
   prediction mode. Herein, we incorporated the spatial heterogeneity of
   environmental variables into LSP modeling. Building upon the
   identification of dominant variable combinations of heterogeneous
   regions using geographically weighted regression, we proposed a zonal
   prediction method by leveraging random forest and support vector
   regression. The accuracy of our method (with an average Area Under the
   Curve (AUC) of 0.818 across all heterogeneous regions) was higher than
   that of the global prediction mode (AUC = 0.7). Furthermore, we found
   that the inter-regional distribution of dominant variables may be
   associated with landslide distribution. Our findings provide insights
   for LSP research in areas with variations in internal environmental
   characteristics.},
Type = {Article},
Affiliation = {Zhao, X; Yang, ZQ (Corresponding Author), Kunming Univ Sci \& Technol, Fac Publ Safety \& Emergency Management, Kunming, Peoples R China.
   Zhao, Xin; Yang, Zhiquan, Kunming Univ Sci \& Technol, Fac Publ Safety \& Emergency Management, Kunming, Peoples R China.
   Zhao, Zhifang, Yunnan Univ, Sch Earth Sci, Kunming, Peoples R China.
   Xu, Zemin, Kunming Univ Sci \& Technol, Fac Civil Engn \& Mech, Kunming, Peoples R China.},
DOI = {10.1080/10106049.2025.2603057},
Article-Number = {2603057},
Keywords = {Landslide susceptibility; geographically weighted regression; spatial
   heterogeneity; machine learning; zoning prediction},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; ANALYTICAL HIERARCHY PROCESS;
