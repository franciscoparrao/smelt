}

@article{ WOS:000661278600013,
Author = {Garbasevschi, Oana M. and Schmiedt, Jacob Estevam and Verma, Trivik and
   Lefter, Iulia and Altes, Willem K. Korthals and Droin, Ariane and
   Schiricke, Bjoern and Wurm, Michael},
Title = {Spatial factors influencing building age prediction and implications for
   urban residential energy modelling},
Journal = {COMPUTERS ENVIRONMENT AND URBAN SYSTEMS},
Year = {2021},
Volume = {88},
Month = {JUL},
Abstract = {Urban energy consumption is expected to continuously increase alongside
   rapid urbanization. The building sector represents a key area for
   curbing the consumption trend and reducing energy-related emissions by
   adopting energy efficiency strategies. Building age acts as a proxy for
   building insulation properties and is an important parameter for energy
   models that facilitate decision making. The present study explores the
   potential of predicting residential building age at a large geographical
   scale from open spatial data sources in eight municipalities in the
   German federal state of North-Rhine Westphalia. The proposed framework
   combines building attributes with street and block metrics as
   classification features in a Random Forest model. Results show that the
   addition of urban fabric metrics improves the accuracy of building age
   prediction in specific training scenarios. Furthermore, the findings
   highlight the way in which the spatial disposition of training and test
   samples influences classification accuracy. Additionally, the paper
   investigates the impact of age misclassification on residential building
   heat demand estimation. The age classification model leads to reasonable
   errors in energy estimates, in various scenarios of training, which
   suggests that the proposed method is a promising addition to the urban
   energy modelling toolkit.},
Type = {Article},
Affiliation = {Garbasevschi, OM (Corresponding Author), German Remote Sensing Data Ctr, D-82234 Oberpfaffenhofen, Wessling, Germany.
   Garbasevschi, Oana M.; Schiricke, Bjoern, German Aerosp Ctr DLR, Inst Solar Res, Cologne, Germany.
   Garbasevschi, Oana M.; Droin, Ariane; Wurm, Michael, German Aerosp Ctr DLR, German Remote Sensing Data Ctr DFD, Oberpfaffenhofen, Germany.
   Schmiedt, Jacob Estevam, German Aerosp Ctr DLR, Inst Protect Terr Infrastruct, St Augustin, Germany.
   Verma, Trivik; Lefter, Iulia, Delft Univ Technol, Fac Technol Policy \& Management, Delft, Netherlands.
   Altes, Willem K. Korthals, Delft Univ Technol, Fac Architecture \& Built Environm, Delft, Netherlands.},
DOI = {10.1016/j.compenvurbsys.2021.101637},
EarlyAccessDate = {APR 2021},
Article-Number = {101637},
Keywords = {Open data; Urban morphology; Spatial autocorrelation; Residential
   building age; Residential heat demand; Random forest},
