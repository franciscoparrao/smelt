   Safikhani, Abolfazl, George Mason Univ, Dept Stat, Fairfax, VA 22030 USA.
   Tepe, Emre, Univ Florida, Dept Urban \& Reg Planning, 1480 Inner Rd, Gainesville, FL 32611 USA.},
DOI = {10.1016/j.scs.2023.104390},
EarlyAccessDate = {JAN 2023},
Article-Number = {104390},
Keywords = {Land-use change; Spatio-temporal modeling; Machine learning; Big data;
   GPU parallel processing},
Keywords-Plus = {CELLULAR-AUTOMATA MODEL; RANDOM FOREST; SIMULATION; SCALE},
