   Lotfata, Aynaz, Univ Calif Davis, Sch Vet Med, Dept Pathol Microbiol \& Immunol, Davis, CA USA.},
DOI = {10.1186/s12889-025-23375-y},
Article-Number = {2230},
Keywords = {Overdose mortality; Spatial analysis; Spatial machine learning model},
