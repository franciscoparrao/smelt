   Shi, Zhou, Zhejiang Univ, Coll Environm \& Resource Sci, Key Lab Environm Remediat \& Ecol Hlth, Minist Educ, Hangzhou 310058, Peoples R China.},
DOI = {10.1016/j.jag.2024.104145},
EarlyAccessDate = {SEP 2024},
