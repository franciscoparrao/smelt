@article{ WOS:001720434900001,
Author = {Murakami, Daisuke and Comber, Alexis and Yoshida, Takahiro and
   Tsutsumida, Narumasa and Brunsdon, Chris and Nakaya, Tomoki},
Title = {Coarse-to-Fine Spatial Modeling: A Scalable, Machine-Learning-Compatible
   Framework},
Journal = {GEOGRAPHICAL ANALYSIS},
Year = {2026},
Volume = {58},
Number = {2},
Month = {MAR 19},
Abstract = {This study proposes coarse-to-fine spatial modeling (CFSM) as a scalable
   and machine learning-compatible alternative to conventional spatial
   process models. Unlike conventional covariance-based spatial models,
   CFSM represents spatial processes using a multiscale ensemble of local
   models. To ensure stable model training, larger-scale patterns that are
   easier to learn are modeled first, followed by smaller-scale patterns,
   with training terminated once the validation score stops improving. The
   training procedure, which is based on holdout validation, can be easily
   integrated with other machine learning algorithms, including random
   forests and neural networks. CFSM training is computationally efficient
   because it avoids explicit matrix inversion, which is a major
   computational bottleneck in conventional spatial Gaussian processes.
   Comparative Monte Carlo experiments demonstrated that the CFSM, as well
   as its integration with random forests, achieved superior predictive
   performance compared to existing models. Finally, we applied the
   proposed methods to an analysis of residential land prices in the Tokyo
   metropolitan area, Japan. The CFSM is implemented in an R package spCF (
   https://cran.r-project.org/web/packages/spCF/).},
Type = {Article},
Affiliation = {Murakami, D (Corresponding Author), Inst Stat Math, Dept Fundamental Stat Math, Tachikawa, Japan.
   Murakami, D (Corresponding Author), Hitotsubashi Univ, Ctr Urban \& Real Estate Studies, Kunitachi, Japan.
   Murakami, Daisuke, Inst Stat Math, Dept Fundamental Stat Math, Tachikawa, Japan.
   Murakami, Daisuke, Hitotsubashi Univ, Ctr Urban \& Real Estate Studies, Kunitachi, Japan.
   Comber, Alexis, Univ Leeds, Sch Geog, Leeds, England.
   Yoshida, Takahiro, Univ Tokyo, Ctr Spatial Informat Sci, Kashiwa, Japan.
   Tsutsumida, Narumasa, Saitama Univ, Grad Sch Sci \& Engn, Saitama, Japan.
   Brunsdon, Chris, Maynooth Univ, Natl Ctr Geocomputat, Maynooth, Ireland.
   Nakaya, Tomoki, Tohoku Univ, Grad Sch Environm Studies, Sendai, Japan.},
DOI = {10.1111/gean.70034},
Article-Number = {e70034},
Keywords = {coarse-to-fine spatial modeling; computational efficiency; Gaussian
   process; local model; random forest; spCF},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; GAUSSIAN PROCESS},
Author-Email = {dmuraka@ism.ac.jp},
Number-of-Cited-References = {46},
Times-Cited = {0},
