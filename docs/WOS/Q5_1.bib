   Gui, Zhipeng; Li, Rui; Wu, Huayi, Wuhan Univ, Collaborat Innovat Ctr Geospatial Technol, Wuhan, Peoples R China.
   Wei, Zhengyang, Stanford Univ, Inst Computat \& Math Engn, Stanford, CA 94305 USA.},
DOI = {10.1080/10095020.2021.2021785},
EarlyAccessDate = {FEB 2022},
