Article-Number = {2639808},
Keywords = {Landslide susceptibility; spatial heterogeneity; GWRF; interpretability},
Keywords-Plus = {LOGISTIC-REGRESSION; MODELS; RATIO; GIS},
Author-Email = {dinghaitao@imde.ac.cn},
Number-of-Cited-References = {52},
Times-Cited = {0},
