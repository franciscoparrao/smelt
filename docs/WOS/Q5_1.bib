}

@article{ WOS:001487830100001,
Author = {Ansari, Mohsen and Knudby, Anders and Homayouni, Saeid},
Title = {River salinity mapping through machine learning and statistical modeling
   using Landsat 8 OLI imagery},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2025},
Volume = {75},
Number = {10},
Pages = {6981-7002},
Month = {MAY 15},
Abstract = {This study uses Landsat 8 OLI imagery and 102 in situ salinity data
   points to investigate salinity mapping in the Karun River, southwestern
   Iran. A total of 24 features, including salinity indices and Landsat 8
   OLI spectral bands, were assessed using the Random Forest Feature
   Importance Score (RFFIS), Sobol' sensitivity analysis, and correlation
   with salinity to identify the most sensitive features for salinity
   estimation. These included the Red and Green bands, Salinity index 2-6,
   Normalized Suspended Material Index (NSMI), and Enhanced Green Ratio
   Index (EGRI). A total of 24 regression models, including statistical,
   kernel-based, Neural Network (NN)-based, and Decision Tree (DT)-based
   models, were evaluated using statistical error metrics and global, as
   well as local, Moran's I measures of residual spatial autocorrelation.
   The DT-based models, specifically Gradient Boosted DT (GBDT),
   outperformed other models, demonstrating low errors, bias, and
   non-significant residual spatial autocorrelation. Kernel-based models
   performed better than conventional linear models, while NN models tended
   to underfit. Residual spatial autocorrelation analysis indicated that
   models incorporating spatial information reduced residual
   autocorrelation. Landsat 8 OLI imagery effectively mapped salinity
   dynamics, revealing increased salinity from Gotvand to Ahvaz city due to
   agricultural activities and the Gachsaran formation within the
   reservoir. (c) 2025 The Author(s). Published by Elsevier B.V. on behalf
   of COSPAR. This is an open access article under the CC BY license
   (http:// creativecommons.org/licenses/by/4.0/).},
Type = {Article},
Affiliation = {Ansari, M (Corresponding Author), Univ Ottawa, Dept Geog Environm \& Geomat, 75 Laurier Ave East, Ottawa, ON K1N 6N5, Canada.
   Ansari, Mohsen; Knudby, Anders, Univ Ottawa, Dept Geog Environm \& Geomat, 75 Laurier Ave East, Ottawa, ON K1N 6N5, Canada.
   Homayouni, Saeid, Inst Natl Rech Sci, Ctr Eau Terre Environm, Quebec City, PQ, Canada.},
DOI = {10.1016/j.asr.2025.03.037},
EarlyAccessDate = {MAY 2025},
Keywords = {Water salinity; Spatial autocorrelation; Multispectral imagery;
   Regression analysis; Rivers and estuaries; Machine learning},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; FLORIDA BAY; SENSITIVITY-ANALYSIS;
   SURFACE SALINITY; NEURAL-NETWORKS; ORGANIC-MATTER; CLIMATE-CHANGE; KARUN
   RIVER; FRESH-WATER; QUALITY},
Author-Email = {Mohsen.Ansari@uottawa.ca
   aknudby@uottawa.ca
   Mohsen.Ansari@uottawa.ca},
Number-of-Cited-References = {144},
Times-Cited = {2},
