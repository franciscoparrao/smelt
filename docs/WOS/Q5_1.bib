   Shi, Dongbo, Southeast Univ, Sch Architecture, Nanjing, Peoples R China.},
DOI = {10.1007/s43762-024-00158-6},
Article-Number = {45},
Keywords = {Active Transport; Outdoor Jogging; Built Environment and Land Use;
   Variable Importance; Spatial Heterogeneity; Multi-scale Geographically
