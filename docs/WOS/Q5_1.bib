   Tang, Wenwu, Univ North Carolina Charlotte, Sch Data Sci, Charlotte, NC USA.
   Chen, Shen-En, Univ North Carolina Charlotte, Dept Civil \& Environm Engn, Charlotte, NC 28223 USA.},
DOI = {10.1080/24694452.2024.2380898},
EarlyAccessDate = {JUL 2024},
Keywords = {deep learning; GeoAI; object detection; spatial autocorrelation; 3D
   point cloud},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; CLASSIFICATION},
Author-Email = {tchen19@charlotte.edu},
