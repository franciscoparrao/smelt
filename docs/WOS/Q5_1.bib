@article{ WOS:001619655700002,
Author = {Jeon, Gyubo and Cho, Chaeyoon and Kim, Kwanchul and Choi, Woosuk},
Title = {Deep-learning-based wildfire occurrence prediction with human factors in
   Gangwon Province, South Korea},
Journal = {ECOLOGICAL INFORMATICS},
Year = {2025},
Volume = {92},
Month = {DEC},
Abstract = {The occurrence of wildfires and their damage have increased due to
   desiccation caused by global warming. Numerous studies have attempted to
   predict the occurrence of wildfires. However, predicting wildfires
   remains challenging owing to unpredictable anthropogenic activities and
   fluctuating environmental conditions. This study predicts the likelihood
   of wildfire occurrence in Gangwon Province, South Korea, by considering
   all relevant factors: meteorology, topography, and anthropogenic
   activities. A deep learning model based on a multimodal convolutional
   neural network was developed to incorporate nonlinear factors including
   temperature, humidity, wind speed, precipitation, normalized difference
   vegetation index, elevation, slope, population density, and land
   surface. The training dataset consisted of 2106 historical cases, 1053
   wildfire and 1053 nonwildfire occurrences between 2011 and 2021.
   According to the results of classification metrics, the model
   performance improved from 69 \% when using only meteorological variables
   to 74 \% when including topographic data together with the environmental
   index NDVI, and further to 77 \% when incorporating all data, including
   human factors. The error map analysis reveals no systematic regional
   bias and spatial autocorrelation in model outcomes. A combination-based
   model evaluation and a partial dependence plot (PDP) analysis were
   conducted to assess the contribution of each variable. Analysis of 31
   combinations of input features revealed that incorporating human-related
   factors improved the model's performance. Furthermore, PDP analysis
   revealed a significant association between land use-particularly in the
   residential, industrial, and agricultural sectors-and the increased
   likelihood of wildfires. In a practical test, our model, with all
   factors, more effectively identified high-risk areas in the 2022 Yanggu
   wildfire. This study suggests that a multimodal approach effectively
   integrates social and environmental factors, thereby improving the
   accuracy of wildfire prediction.},
Type = {Article},
Affiliation = {Choi, W (Corresponding Author), Sejong Univ, Dept Artificial Intelligence \& Data Sci, Seoul, South Korea.
   Jeon, Gyubo; Choi, Woosuk, Sejong Univ, Dept Artificial Intelligence \& Data Sci, Seoul, South Korea.
   Cho, Chaeyoon, Hyundai Marine \& Fire Insurance, Res Ctr, Seoul, South Korea.
   Kim, Kwanchul, Seoul Natl Univ, Adv Inst Convergence Technol, Suwon, Gyeonggi Do, South Korea.},
DOI = {10.1016/j.ecoinf.2025.103519},
EarlyAccessDate = {NOV 2025},
Article-Number = {103519},
Keywords = {Wildfire prediction; Human factor; Convolutional neural network;
   Multimodal; Deep learning},
Keywords-Plus = {FIRE; DRIVERS},
Author-Email = {wschoi@sejong.ac.kr},
Number-of-Cited-References = {56},
Times-Cited = {1},
Unique-ID = {WOS:001619655700002},
}

@article{ WOS:001620462600001,
Author = {Carbajal-Llosa, Carlos and Barja, Antony and Pizarro, Samuel},
Title = {Ensemble machine learning for digital mapping of soil pH and electrical
   conductivity in the Andean agroecosystem of Peru},
Journal = {FRONTIERS IN SOIL SCIENCE},
Year = {2025},
Volume = {5},
Month = {NOV 6},
Abstract = {In agricultural systems, soil pH and electrical conductivity (EC) are
   crucial chemical properties that directly affect nutrient availability
   and microbial activity, but the challenging environment of the Peruvian
   Andes has limited research on their estimation. This study aimed to
   develop an ensemble learning method to predict soil pH and EC in Andean
   agroecosystems using environmental predictors. By using simple and
   weighted averaging, we developed a heterogeneous ensemble learning
   approach that integrates machine learning (ML) algorithms, including
   Support Vector Machine (SVM), Artificial Neural Network (ANN), Random
   Forest (RF), and Extreme Gradient Boosting (XGBoost). The weighted
   ensemble assigns weights to models based on their predictive accuracy,
   measured by R-2 from spatial cross-validation. Spatial patterns are
   noticeable, and pH displays greater spatial clustering than EC.
   Elevation was the most important predictor in ML models for both
   parameters. Ensemble models significantly outperformed individual
   models, with the weighted ensemble achieving R-2 >0.93 and reducing RMSE
   by approximately 72\%. Among standalone models, RF and XGBoost performed
   best for pH, while SVM performed the best for EC. ANN models were the
   least effective. Uncertainty analysis indicated high confidence in pH
   predictions but moderate to high uncertainty in EC predictions,
   suggesting that EC is more challenging to predict. Ensemble models with
   optimized weighting provide robust and accurate mapping of spatially
   autocorrelated soil properties. The high-confidence pH maps are reliable
   for soil management decisions, while EC predictions, though more
   uncertain, effectively identify priority areas for future sampling and
   investigation.},
Type = {Article},
Affiliation = {Carbajal-Llosa, C (Corresponding Author), Inst Nacl Innovac Agr, Direcc Serv Estrateg Agr, Lima, Peru.
   Carbajal-Llosa, Carlos, Inst Nacl Innovac Agr, Direcc Serv Estrateg Agr, Lima, Peru.
   Barja, Antony, Univ Nacl Mayor San Marcos, Escuela Profes Ingn Geog, Fac Ingn Geol Min Met \& Geog, Lima, Peru.
   Pizarro, Samuel, Inst Nacl Innovac Agr, Direcc Serv Estrateg Agr, Estn Expt Agr Santa Ana, Huancayo, Peru.},
DOI = {10.3389/fsoil.2025.1673628},
Article-Number = {1673628},
Keywords = {ensemble learning; spatial machine learning; digital soil mapping; soil
   pH; electrical conductivity},
Keywords-Plus = {ORGANIC-CARBON; VEGETATION; SALINITY; MODELS; MOISTURE; AREAS},
Author-Email = {cmcarbajal@gmail.com},
Number-of-Cited-References = {128},
