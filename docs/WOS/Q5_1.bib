}

@article{ WOS:001538639500016,
Author = {Zarate-Cartas, Jonathan and Molina-Villegas, Alejandro},
Title = {Uncovering Patterns of Violence in Mexican Digital News Articles Through
   Data Science Methods},
Journal = {INTERNATIONAL JOURNAL OF COMBINATORIAL OPTIMIZATION PROBLEMS AND
   INFORMATICS},
Year = {2025},
Volume = {16},
Number = {3},
Pages = {195-215},
Month = {MAY-AUG},
Abstract = {Violence against women is one of the most common human rights
   violations, with its most extreme form being femicide. In this context,
   we considered it relevant to demonstrate how artificial intelligence
   tools and geospatial analysis techniques can contribute to a better and
   faster analysis of these crimes. In this study, we analysed femicides
   that occurred in Mexico between 2014 and 2022. Our data source comprised
   digital news articles from leading Mexican newspapers. The study begins
   with the preprocessing of texts and the detection of those mentioning
   femicide. Subsequently, using unsupervised learning models, we grouped
   the texts according to their semantic similarity. We then employed deep
   learning models to classify each crime according to its specific
   characteristics. Finally, we used spatial analysis tools to detect
   geographic patterns in the occurrence of these crimes in the
   metropolitan area of the Valley of Mexico, analysing the automatically
   detected characteristics as variables.},
