   Ji, Jingyi; Deng, Xiao; Xu, Mingxiang, Minist Educ, Yangling 712100, Peoples R China.},
DOI = {10.3390/rs17061086},
Article-Number = {1086},
Keywords = {soil pH; geographically weighted machine learning; genetic algorithm;
