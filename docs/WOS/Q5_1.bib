@article{ WOS:001239919800001,
Author = {Chen, Jian and Chen, Miao and Liu, Shun and Xu, Gexi and Xing,
   Hongshuang and Li, Feifan and Shi, Zuomin},
Title = {The spatial variation and drivers of soil 613C in an alpine-gorge region
   on the eastern Qinghai-Tibetan Plateau},
Journal = {CATENA},
Year = {2024},
Volume = {242},
Month = {JUL},
Abstract = {Soil stable carbon isotope (soil 6 13 C) can reflect soil carbon
   metabolic processes and record environmental and vegetation change
   information, so mapping the spatial distribution of soil 6 13 C
   (isoscapes of soil 6 13 C) can help us better understand the spatial
   variability of ecosystem carbon cycles. However, efficient approaches
   for obtaining the isoscapes of soil 6 13 C remain challenging,
   especially in mountainous areas with complex terrain. A total of 150
   soil samples were collected and their soil 6 13 C was measured to
   investigate the spatial variation of soil 6 13 C in an alpine-gorge
   region on the eastern Qinghai-Tibetan Plateau which is characterized by
   complex terrain. Four prediction methods included ordinary kriging
   interpolation, multiple linear regression, random forest regression, and
   geographically weighted regression (GWR) were selected and compared to
   find the best prediction model for mapping the isoscapes of soil 6 13 C.
   The pathways of vegetation, topography, soil, and spatial factors
   influencing the spatial variability of soil 6 13 C were explored using
   variance partitioning analysis and structural equation model. The soil 6
   13 C was significantly different among vegetation types, and ranged from
   - 27.155 \%o to - 9.647 \%o . The spatial heterogeneity of soil 6 13 C
   showed moderate variation, and was dominated by spatial structural
   factors. The GWR model had higher prediction accuracy in the modeling
   soil 6 13 C in comparison to other models. Soil carbon to nitrogen ratio
   and normalized difference vegetation index were the main factors
   determining the spatial variability of soil 6 13 C, and other
   topographic and soil factors indirectly regulated the spatial
   distribution of soil 6 13 C by influencing these two factors. Our
   results provided a useful tool (GWR model) for mapping the isoscapes of
   soil 6 13 C and explored the factors controlling the spatial variability
   of soil 6 13 C in the alpine-gorge region on the eastern Qinghai-Tibetan
   Plateau, which are important for an in-depth understanding of soil
   carbon cycling in mountain ecosystems.},
Type = {Article},
Affiliation = {Shi, ZM (Corresponding Author), Chinese Acad Forestry, Natl Forestry \& Grassland Adm, Ecol \& Nat Conservat Inst, Key Lab Forest Ecol \& Environm, Beijing 100091, Peoples R China.
