@article{ WOS:001583453700001,
Author = {Guo, Hao and Wang, Han and Zhu, Di and Wu, Lun and Fotheringham, A.
   Stewart and Liu, Yu},
Title = {RegionGCN: Spatial-Heterogeneity-Aware Graph Convolutional Networks},
Journal = {ANNALS OF THE AMERICAN ASSOCIATION OF GEOGRAPHERS},
Year = {2026},
Volume = {116},
Number = {2},
Pages = {331-347},
Month = {FEB 7},
Abstract = {Modeling spatial heterogeneity in the data generation process is
   essential for understanding and predicting geographical phenomena.
   Despite their prevalence in geospatial tasks, neural network models
   usually assume spatial stationarity, which could limit their performance
   in the presence of spatial process heterogeneity. By allowing model
   parameters to vary over space, several approaches have been proposed to
   incorporate spatial heterogeneity into neural networks. Current
   geographical weighting approaches, however, are ineffective on graph
   neural networks, yielding no significant improvement in prediction
   accuracy. We assume the crux lies in the overfitting risk brought by a
   large number of local parameters. Accordingly, we propose to model
   spatial process heterogeneity at the regional level rather than at the
   individual level, which largely reduces the number of spatially varying
   parameters. We further develop a heuristic optimization procedure to
   learn the region partition adaptively in the process of model training.
   Our proposed spatial-heterogeneity-aware graph convolutional network,
   named RegionGCN, is applied to the modeling of county-level vote share
   in the 2016 U.S. presidential election based on socioeconomic
   attributes. Results show that RegionGCN achieves significant improvement
   over the basic and geographically weighted GCNs. We also offer an
   exploratory analysis tool for the spatial variation of nonlinear
   relationships through ensemble learning of regional partitions from
   RegionGCN. Our work contributes to the practice of geospatial artificial
   intelligence in tackling spatial heterogeneity.},
Type = {Article},
Affiliation = {Liu, Y (Corresponding Author), Peking Univ, Inst Remote Sensing \& Geog Informat Syst, Sch Earth \& Space Sci, Beijing, Peoples R China.
   Guo, Hao; Wu, Lun; Liu, Yu, Peking Univ, Inst Remote Sensing \& Geog Informat Syst, Sch Earth \& Space Sci, Beijing, Peoples R China.
   Wang, Han, Univ Hong Kong, Fac Architecture, Div Landscape Architecture, Future Urban \& Sustainable Environm Lab, Hong Kong, Peoples R China.
   Zhu, Di, Univ Minnesota Twin Cities, Dept Geog Environm \& Soc, Geospatial Data Intelligence Lab, Minneapolis, MN USA.
   Fotheringham, A. Stewart, Florida State Univ, Spatial Data Sci Ctr, Dept Geog, Tallahassee, FL USA.},
DOI = {10.1080/24694452.2025.2558661},
EarlyAccessDate = {SEP 2025},
Keywords = {election analysis; GeoAI; graph convolutional networks; graph neural
   networks; spatial process heterogeneity},
Author-Email = {liuyu@urban.pku.edu.cn},
Number-of-Cited-References = {57},
Times-Cited = {2},
Unique-ID = {WOS:001583453700001},
}

@article{ WOS:001584671000002,
Author = {Jia, Chao and Du, Jiayi and Li, Zeyu and Ding, Yue and Yang, Xiao and
   Zhang, Yongwei and Liang, Hao},
Title = {Unraveling spatial heterogeneity in land subsidence: Insights from
   SBAS-InSAR and RF-MGWR coupling models},
Journal = {ENGINEERING GEOLOGY},
Year = {2025},
Volume = {357},
Month = {OCT},
Abstract = {Land subsidence, as a slowly changing geological disaster, poses a
   serious threat to urban infrastructure and environmental security. In
   this research, an evaluation framework for land subsidence risk and
   susceptibility is introduced, utilizing numerical modeling and
   data-driven methodologies. Small baseline subset interferometric
   synthetic aperture radar (SBAS-InSAR) method was used to process the
   remote sensing data of Mudan district in Shandong Province, China. A
   model for three-dimensional fluid-solid coupling in land subsidence,
   considering both ground fissures and seismic activities, was
   established. Combined with mathematical statistics and rolling window
   time lag cross-correlation algorithm, the correlation between
   groundwater, ground fissures, earthquakes, and land subsidence was
   discussed. The susceptibility of land subsidence was assessed through
   the Random Forest-Multiscale Geographically Weighted Regression
   (RF-MGWR) coupling algorithm. The research results indicated that from
   2017 to 2023, the area with subsidence exceeding 150 mm expanded
   continuously, forming a distinct subsidence funnel in the urban area,
   with the maximum land subsidence rate occurring during 2019-2020.
   Reducing the extraction of groundwater could effectively alleviate the
   incidence of land subsidence. The RF-MGWR model showed exceptional
   performance in the assessment of land subsidence susceptibility,
   addressing the limitations of dealing with spatial heterogeneity. The
   statistical analysis results showed a correlation between groundwater
   level and land subsidence. Meanwhile, the existence of a ``lag{''} in
   the response of land subsidence to groundwater level has been confirmed
   through the Rolling Window Time Lagged Cross Correlation (RW-TLCC)
   algorithm. Ground fissures were formed due to uneven subsidence of the
   earth's surface. The earthquake had little effect on land subsidence at
   the moment after the earthquake. In a short period of time, the amount
   of land subsidence decreased first and then increased gradually.},
Type = {Article},
Affiliation = {Yang, X (Corresponding Author), Shandong Univ, Inst Marine Sci \& Technol, Qingdao 266237, Peoples R China.
   Jia, Chao; Du, Jiayi; Li, Zeyu; Ding, Yue; Yang, Xiao, Shandong Univ, Inst Marine Sci \& Technol, Qingdao 266237, Peoples R China.
   Jia, Chao; Yang, Xiao, Shandong Engn Res Ctr Environm Protect \& Remediat, Jinan 250014, Peoples R China.
   Zhang, Yongwei; Liang, Hao, Shandong Prov Terr Spatial Ecol Restorat Ctr, Jinan 250014, Peoples R China.},
DOI = {10.1016/j.enggeo.2025.108334},
EarlyAccessDate = {SEP 2025},
Article-Number = {108334},
Keywords = {Land subsidence; Fluid-solid coupling model; RW-TLCC; Spatial
   heterogeneity analysis; Machine learning},
Author-Email = {shawnyang@mail.sdu.edu.cn},
