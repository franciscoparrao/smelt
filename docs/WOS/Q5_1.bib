DOI = {10.1016/j.srs.2025.100273},
EarlyAccessDate = {SEP 2025},
Article-Number = {100273},
Keywords = {Informal settlement mapping; Urban remote sensing; Data imbalance;
   Ensemble learning},
Keywords-Plus = {CLASSIFICATION; SLUMS},
