DOI = {10.1016/j.ecoenv.2025.117926},
EarlyAccessDate = {FEB 2025},
Article-Number = {117926},
Keywords = {Soil Cd/As pollution; Graph neural networks; Model interpretability;
   Spatial relationships; Deep learning},
Keywords-Plus = {HEAVY-METALS; CADMIUM; CHINA},
Author-Email = {xionghji@163.com
   panpan3004@126.com},
Number-of-Cited-References = {83},
