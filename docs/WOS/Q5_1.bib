@article{ WOS:001606326000009,
Author = {Azis, I. and Djuraidah, A. and Aidi, M. N. and Indahwati and
   Sopaheluwakan, A.},
Title = {Spatial prediction of the number of wildfire hotspots using negative
   binomial conditional autoregressive random forest},
Journal = {GLOBAL JOURNAL OF ENVIRONMENTAL SCIENCE AND MANAGEMENT-GJESM},
Year = {2025},
Volume = {11},
Number = {4},
Pages = {1509-1526},
Month = {FAL},
Abstract = {BACKGROUND AND OBJECTIVES: Predicting the spatial distribution of
   wildfire hotspots is crucial for forest fire mitigation, particularly in
   high-risk regions such as Kalimantan Island, Indonesia. Hotspots are
   defined as locations where thermal anomalies are present, surpassing the
   usual background temperature. An integrated framework is proposed: a
   negative binomial conditional autoregressive random forest. The approach
   is designed to capture nonlinearity in meteorological drivers,
   over-dispersion in the number of hotspots, and spatial dependence among
   neighboring grid cells. This study aims to estimate the number of
   hotspots and to pinpoint the meteorological factors that significantly
   affect the emergence of hotspots. METHODS: The number of hotspots in
   Kalimantan for September 2024 were analyzed on a grid. Predictors
   included air temperature, precipitation, relative humidity, wind speed,
   and dry days. These variables were aggregated into spatial grids with a
   resolution of 0.25 degree by 0.25 degree. The study conducted a
   simulation where the levels of spatial autocorrelation, alternative
   spatial weight matrices, the ratios of predictorvariance to spatial
   residual variance, and sample sizes were modified. Model performance was
   evaluated using root mean square error and mean absolute error.
   FINDINGS: The proposed model consistently outperformed the conventional
   conditional autoregressive model in both simulated and empirical
   datasets. Gains were largest when predictor variance exceeded spatial
   residual variance. Across most scenarios, reductions in root mean square
   error by 24 percent and in mean absolute error by 33.3 percent were
   observed. It was observed that the results remained stable when
   alternative spatial weight matrices were applied. In the empirical
   application, the model accurately predicted the spatial distribution of
   hotspots. Overestimation occurred in approximately 21.43 percent of the
   grid cells of the observed. Air temperature and relative humidity
   emerged as the leading predictors, but their relative significance
   changed across distinct spatial clusters. Meteorological effects were
   weaker in wet, humid clusters and stronger in hot, dry clusters.
   CONCLUSION: Practical accuracy improvements for spatial prediction of
   the number of hotspots are generated by the integrated framework. It is
   advisable to integrate into operational early-warning systems and
   decision support mechanisms for the prevention of forest and land fires
   in tropical areas susceptible to fires.},
Type = {Article},
Affiliation = {Djuraidah, A (Corresponding Author), IPB Univ, Sch Data Sci Math \& Informat, Bogor, Indonesia.
   Azis, I.; Djuraidah, A.; Aidi, M. N.; Indahwati, IPB Univ, Sch Data Sci Math \& Informat, Bogor, Indonesia.
   Sopaheluwakan, A., Meteorol Climatol \& Geophys Agcy BMKG, Jakarta, Indonesia.},
DOI = {10.22034/gjesm.2025.04.09},
Keywords = {Conditional autoregressive; Hotspots; Negative binomial distribution;
   Random forest; Spatial model},
Author-Email = {irfaniazis@apps.ipb.ac.id
   anikdjuraidah@apps.ipb.ac.id
   muhammadai@apps.ipb.ac.id
   indahwati@apps.ipb.ac.id
   ardhasena@bmkg.go.id},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001606326000009},
}

@article{ WOS:001608922500004,
Author = {Bdour, Ahmed and Alkharabsheh, Raha M.},
Title = {Real-Time Machine Learning and Wireless Sensor Network for Coastal Water
   Quality Monitoring in the Gulf of Aqaba},
Journal = {ECOLOGICAL CHEMISTRY AND ENGINEERING S-CHEMIA I INZYNIERIA EKOLOGICZNA S},
Year = {2025},
Volume = {32},
Number = {3},
Pages = {335-352},
Month = {SEP 1},
Abstract = {This study presents an advanced real-time monitoring system integrating
   wireless sensor networks with machine learning to assess water quality
   in the Gulf of Aqaba. Our hybrid machine learning framework combines
   Random Forest (500 trees, node size = 5) for feature selection with
   Artificial Neural Network ensembles (3-layer MLP with Monte Carlo
   dropout) for probabilistic forecasting. The system continuously monitors
   six critical parameters, demonstrating strong predictive performance
   through rigorous validation: dissolved oxygen (R-2 = 0.92, RMSE = 0.45
   mg/L, 95 \% CI (Confidence interval): 0.41 - 0.49), nitrite (R-2 = 0.85,
   RMSE = 0.08 mg/L, CI: 0.07 - 0.09), and turbidity (R-2 = 0.89, RMSE =
   2.3 FTU, CI: 2.1 - 2.5). Comprehensive uncertainty analysis revealed
   prediction intervals of +/- 0.38 mg/L for DO and +/- 0.10 mg/L for
   nitrite, with spatial variability lowest in open waters (CV = 8.2 \%)
   and highest near coastal zones (CV = 15 \%). Residual autocorrelation
   analysis confirmed model reliability (Moran's I < 0.12, p > 0.05) across
   the study area. Spatial-temporal analysis identified nitrite as a
   sensitive pollution indicator, with concentrations reaching 0.12 mg/L
   near urban outflows compared to background levels (< 0.05 mg/L). The
   system achieved 92 \% accuracy in the early detection of environmental
   risks, including coral bleaching precursors (temperature anomalies > 1
   degrees C) and pollution events (nitrite spikes > 0.1 mg/L). Compared to
   conventional monitoring, the platform demonstrated 20.4 \% greater
   predictive accuracy (Delta R-2 = +0.17, p < 0.01) while reducing
   operational costs by 30.2 \%, primarily through automated data
   collection and reduced manual sampling. The integration of
   high-frequency sensing, adaptive machine learning, and cloud-based
   analytics establishes a replicable framework for coastal ecosystem
   management, particularly in anthropogenically stressed environments like
   the Red Sea.},
Type = {Article},
Affiliation = {Bdour, A (Corresponding Author), Hashemite Univ, Fac Engn, Dept Civil Engn, PO Box 330127, Zarqa 13133, Jordan.
   Bdour, Ahmed, Hashemite Univ, Fac Engn, Dept Civil Engn, PO Box 330127, Zarqa 13133, Jordan.
   Alkharabsheh, Raha M., Univ Politecn Madrid, Fac Forestry \& Nat Environm Engn, R\&I Ctr Conservat Biodivers \& Sustainable Dev CBDS, Madrid, Spain.},
DOI = {10.2478/eces-2025-0016},
Keywords = {marine water quality monitoring; real-time remote monitoring; wireless
   sensor networks; machine learning predictive modelling; GIS-based
   spatial analysis; Red Sea ecosystem management},
Keywords-Plus = {SPECIES DISTRIBUTIONAL DATA; SPATIAL AUTOCORRELATION; ACCOUNT; SYSTEM;
   DESIGN; COST},
Author-Email = {bdour@hu.edu.jo
   Raha.alkharabsheh@alumnos.upm.es},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001608922500004},
}

@article{ WOS:001529600100037,
Author = {Song, Lijian and Lou, Jia and Liu, Kai-di},
Title = {Exploring the Economic Value of Urban Green Spaces: A Dual-Perspective
   Analysis Inside and Outside Residential Communities},
Journal = {JOURNAL OF URBAN PLANNING AND DEVELOPMENT},
Year = {2025},
Volume = {151},
Number = {3},
Month = {SEP 1},
Abstract = {The economic benefits of urban green spaces (UGSs) have become a key
   concern since they provide residents with various environmental
   benefits. In addition to the impact of accessibility on housing prices,
   the effect of the attributes and scale of UGSs is worth a deep study.
   This study adopted a cross-dual analysis framework, integrating
   perspectives on scale and marginal effects to evaluate the economic
   benefits of UGSs. This framework was used to analyze the economic
   benefits of UGSs across three dimensions: within and outside residential
   communities, at different scales, and with varying accessibility. The
   empirical analysis was conducted using the random forest model, the
   hedonic price model, and geographically weighted regression, taking
   Qingdao as an example. The results showed the following: (1) Public
   green spaces hold more excellent economic value than residential green
   spaces. (2) Regarding the scale effect, residential green spaces hold
   more excellent economic value than parks, although the marginal effect
   shows the reverse. Central green spaces exhibit the lowest economic
   value among these three types of UGSs. (3) Small UGSs offer higher
   economic value than large UGSs. (4) The relationship between
   accessibility and the economic value of UGSs is not linear. UGSs with
   moderate accessibility (900-1,800 m) possess the highest economic value.
   These results provide valuable insights for optimizing UGS planning,
   enhancing resident well-being, and advancing sustainable urban
   development.},
Type = {Article},
Affiliation = {Liu, KD (Corresponding Author), Shandong Univ, Qingdao Inst Humanities \& Social Sci, 72,Binhai Rd, Qingdao 266237, Peoples R China.
   Song, Lijian; Lou, Jia; Liu, Kai-di, Shandong Univ, Qingdao Inst Humanities \& Social Sci, 72,Binhai Rd, Qingdao 266237, Peoples R China.
   Lou, Jia, Shandong Univ, Ctr Yellow River Ecosyst Prod, Qingdao 266237, Peoples R China.},
DOI = {10.1061/JUPDDM.UPENG-5458},
Article-Number = {05025022},
Keywords = {Accessibility; Economic benefit; Housing price; Scale effect; Marginal
   effect},
Keywords-Plus = {HEDONIC PRICING ANALYSIS; PRICES; FOREST; MARKET},
Author-Email = {songlijian@mail.sdu.edu.cn
   lou-jia@mail.sdu.edu.cn
