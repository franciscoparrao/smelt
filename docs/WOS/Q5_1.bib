}

@article{ WOS:000411166600033,
Author = {Medrzycki, Piotr and Jarzyna, Ingeborga and Obidzinski, Artur and
   Tokarska-Guzik, Barbara and Sotek, Zofia and Pabjanek, Piotr and
   Pytlarczyk, Adam and Sachajdakiewicz, Izabela},
Title = {Simple yet effective: Historical proximity variables improve the species
   distribution models for invasive giant hogweed (Heracleum
   mantegazzianum s. l.) in Poland},
Journal = {PLOS ONE},
Year = {2017},
Volume = {12},
Number = {9},
Month = {SEP 19},
Abstract = {Species distribution models are scarcely applicable to invasive species
   because of their breaking of the models' assumptions. So far, few
   mechanistic, semi-mechanistic or statistical solutions like dispersal
   constraints or propagule limitation have been applied. We evaluated a
   novel quasi-semi-mechanistic approach for regional scale models, using
   historical proximity variables (HPV) representing a state of the
   population in a given moment in the past. Our aim was to test the
   effects of addition of HPV sets of different minimal recentness,
   information capacity and the total number of variables on the quality of
   the species distribution model for Heracleum mantegazzianum on 116000
   km(2) in Poland. As environmental predictors, we used fragments of 103
   1x1 km, world-wide, free-access rasters from WorldGrids. org. Single and
   ensemble models were computed using BIO-MOD2 package 3.1.47 working in R
   environment 3.1.0. The addition of HPV improved the quality of single
   and ensemble models from poor to good and excellent. The quality was the
   highest for the variants with HPVs based on the distance from the most
   recent past occurrences. It was mostly affected by the algorithm type,
   but all HPV traits (minimal recentness, information capacity, model type
   or the number of the time periods) were significantly important
   determinants. The addition of HPVs improved the quality of current
   projections, raising the occurrence probability in regions where the
   species had occurred before. We conclude that HPV addition enables
   semi-realistic estimation of the rate of spread and can be applied to
   the short-term forecasting of invasive or declining species, which also
   break equal-dispersal probability assumptions.},
Type = {Article},
Affiliation = {Medrzycki, P (Corresponding Author), Univ Ecol \& Management Warsaw, Fac Ecol, Lab Appl Plant Ecol, Warsaw, Poland.
   Medrzycki, Piotr; Pytlarczyk, Adam; Sachajdakiewicz, Izabela, Univ Ecol \& Management Warsaw, Fac Ecol, Lab Appl Plant Ecol, Warsaw, Poland.
   Jarzyna, Ingeborga, Univ Warsaw, Fac Biol, Biol \& Chem Res Ctr, Dept Plant Ecol \& Environm Protect, Warsaw, Poland.
   Obidzinski, Artur, Warsaw Univ Life Sci, Fac Forestry, Dept Forest Bot, Warsaw, Poland.
   Tokarska-Guzik, Barbara, Univ Silesia Katowice, Fac Biol \& Environm Protect, Deptartment Bot \& Nat Protect, Katowice, Poland.
   Sotek, Zofia, Univ Szczecin, Dept Bot \& Nat Conservat, Fac Biol, Szczecin, Poland.
   Pabjanek, Piotr, Univ Warsaw, Fac Geog \& Reg Studies, Dept Geoinformat Cartog \& Remote Sensing, Warsaw, Poland.},
DOI = {10.1371/journal.pone.0184677},
Article-Number = {e0184677},
Keywords-Plus = {SPATIAL AUTOCORRELATION; PHRAGMITES-AUSTRALIS; PROPAGULE PRESSURE;
   PLANT; CONSTRAINTS; BIODIVERSITY; PREDICTIONS; DISPERSAL; DYNAMICS;
   PATTERNS},
Author-Email = {piotr.medrzycki@pser.pl},
Number-of-Cited-References = {67},
