@article{ WOS:001665622800010,
Author = {Lv, Jianping},
Title = {Modeling Fluoride Governance in Arid Vegetation Systems Under Climate
   Change: Deep Learning and Bayesian Optimization for Altay, China},
Journal = {FLUORIDE},
Year = {2025},
Volume = {58},
Number = {S},
Month = {JUL-SEP},
Abstract = {Background: Mobilization of excessive levels of fluoride in arid
   ecosystems creates the daunting environmental and population-health
   hazard, especially in the Chinese Xinjiang Altay Prefecture.
   Conventional and ad hoc point-of-use defluoridation solutions treat
   symptoms and fail to recognize watershed-level causes, which are,
   respectively, coupled vegetationhydrology processes and rainfall
   accentuation. Objectives: This paper provides a data-driven high
   resolution framework which can integrate Convolutional Long Short-Term
   Memory (ConvLSTM) networks and Bayesian optimization to (1) predict the
   fluoride concentration in soil at 100 m resolution in present and future
   climates, and (2) define optimal portfolios of interventions (increases
   in vegetation cover and reductions to micro-catchment storage) to solve
   fluoride and improve it in the future. Methods: Current study combined
   Sentinel-2/Landsat-8 remotely sensed indices (NDVI, land-surface
   temperature and soil moisture proxies), community-model climate
   projection downscaled end-point scenarios (RCP4.5/8.5) and in situ
   fluoride analyses of thirty field plots. A ConvLSTM model was
   hyperparameter optimized through Optuna Gaussian-process sampler (50
   trials, 5-folds spatial cross-validation). The most important drivers
   were quantified using SHAP analysis, and the simulation was done within
   the optimized network to define intervention scenarios. Results: The
   fine-tuned ConvLSTM recorded RMSE = 0.42 mg/kg, R 2 = 0.87held-out
   plots, beating CNN/LSTM baselines by 10 percent minimum. NDVI and recent
   rainfall became influential points of prediction. The condition of
   high-risk hotspots spreads north under RCP8.5 (2050). Mean fluoride
   reduction by simulated interventions, +30 percent vegetation cover and
   +15 mm retention had 34 percent efficacy, of which more than 90 percent
   was maintained across climate futures. Conclusions: A combined approach
   to modeling advanced spatiotemporal structures and efficient
   hyperparameter optimisation forms the basis of our framework, which is
   able to produce both an accurate risk map and usable governance
   strategy. The method is a scalable model to handle fluoride pollution in
   drought-stricken sceneries facing climate insecurity.},
Type = {Article},
Affiliation = {Lv, JP (Corresponding Author), North Minzu Univ, Sch Math \& Informat Sci, Yinchuan 750021, Ningxia, Peoples R China.
   Lv, Jianping, North Minzu Univ, Sch Math \& Informat Sci, Yinchuan 750021, Ningxia, Peoples R China.},
Article-Number = {e379},
Keywords = {ConvLSTM; Bayesian optimization; Fluoride risk; Arid ecosystems;
   Vegetation interventions},
Author-Email = {aoyanqun\_1209@163.com},
Number-of-Cited-References = {29},
Times-Cited = {0},
Unique-ID = {WOS:001665622800010},
}

@article{ WOS:001519755900002,
Author = {Yin, Yue and Gao, Bingbo and Xu, Hao and Wang, Yuxue and Xie, Dongkai
   and Liu, Yanqing and Wang, Chenyi},
Title = {Soil organic matter mapping in complex terrains considering spatial
   heterogeneity},
Journal = {ENVIRONMENTAL MODELLING \& SOFTWARE},
Year = {2025},
Volume = {192},
Month = {AUG},
Abstract = {The intricate topography and weak spatial autocorrelation in mountainous
   areas contribute to strong local and directional heterogeneity in the
   spatial distribution of soil organic matter (SOM). The relationships
   between SOM and auxiliary variables also exhibit spatial disparities.
   This mixed heterogeneity seriously affects the prediction accuracy of
   SOM's spatial distribution. Furthermore, the high cost and challenges
   associated with sampling in mountainous areas result in limited
   availability, sparseness, and uneven spatial distribution of soil
   samples, thereby intensifying the difficulty of precise spatial
   prediction. The newly developed two-point machine learning method (TPML)
   adeptly manages local heterogeneity and heterogeneous relationships by a
   two-step modeling approach, but its application in addressing
   directional heterogeneity remains unexplored. This study investigates
   whether explicitly integrating directional information between two
   points as an auxiliary variable in the TPML modeling process can enhance
   the prediction accuracy of SOM in complex terrains characterized by
   small sample sizes. In this study, multiple sets of comparative
   experiments were conducted to assess the accuracy of various
   methodologies, including TPML, ordinary kriging, random forest, and
   random forest regression kriging. The results indicate that (1) TPML can
   capture the local and directional heterogeneity in the distribution of
   SOM in mountainous areas, addressing the spatially varying relationship
   between SOM and auxiliary variables. (2) TPML demonstrates the capacity
   to characterize the directional heterogeneity of SOM even without the
   inclusion of directional information as an auxiliary variable. (3)
   Through cross-validation, TPML emerges as the most accurate predictive
   method. Mapping outcomes reveal that TPML can produce precise and
   coherent spatial distribution maps of SOM with fine spatial details.},
Type = {Article},
Affiliation = {Gao, BB (Corresponding Author), China Agr Univ, Coll Land Sci \& Technol, 17 Qinghua East Rd, Beijing 100193, Peoples R China.
   Yin, Yue; Gao, Bingbo; Wang, Yuxue; Xie, Dongkai; Liu, Yanqing; Wang, Chenyi, China Agr Univ, Coll Land Sci \& Technol, 17 Qinghua East Rd, Beijing 100193, Peoples R China.
   Xu, Hao, Shandong Acad Agr Sci, Jinan 250100, Peoples R China.},
DOI = {10.1016/j.envsoft.2025.106569},
EarlyAccessDate = {JUN 2025},
Article-Number = {106569},
Keywords = {Soil organic matter; Mountainous areas; Complex terrain; Limited sample
   size; Spatial distribution prediction; Two-point machine learning},
Keywords-Plus = {PREDICTION; REGRESSION},
Author-Email = {gaobingbo@cau.edu.cn},
Number-of-Cited-References = {54},
Times-Cited = {0},
Unique-ID = {WOS:001519755900002},
}

@article{ WOS:001514236700001,
Author = {Li, Daichao and Jin, Xinlei and Xu, Fangnian and Liang, Juanzhu and
   Wang, Xiaohui},
Title = {Fine simulation and spatiotemporal analysis of urban PM2.5
   using Mobile monitoring data},
Journal = {URBAN CLIMATE},
Year = {2025},
Volume = {62},
Month = {AUG},
Abstract = {Particulate matter with an aerodynamic diameter of 2.5 mu m or less
   (PM2.5) concentrations exhibit significant spatiotemporal variability
   due to diverse urban scenarios, making accurate PM2.5 simulation
   challenging. This study used PM2.5 mobile monitoring data and considered
   the impact of urban scenarios on PM2.5. A hybrid PM2.5 simulation model
   was developed by integrating the Multiscale Geographically Weighted
   Regression model (MGWR) and Extreme Gradient Boosting (XGBoost),
   referred to as MGWR-XGBoost. Nested buffer analysis, combined with
   feature importance and partial dependence plots, was employed to
   quantify the scale-dependent effects of urban scenarios on PM2.5.
   Additionally, spatiotemporal patterns of PM2.5 concentrations across
   different urban scenarios were analyzed. The results showed that the
   MGWR-XGBoost model, which introduced urban scenario variables, achieved
   a mean improvement of 10.5 \% in the coefficient of determination (R2)
   and a mean reduction of 1.52 mu g/m3 in the root mean square error
   (RMSE), thereby enabling intra-city PM2.5 simulations at a spatial
   resolution of 100 m x 100 m. Quantitative analysis revealed that roads
   and industrial areas could influence PM2.5 concentrations at a regional
   scale (1000-1500 m buffers), whereas residential areas, parks, sports
   services, and educational and medical units primarily exhibited more
   localized impacts (100-500 m buffers). Spatially, PM2.5 concentrations
   in the study area exhibited a southeast-high, northwestlow pattern, with
   higher pollution in construction sites, roads, and heavy and light
   industrial areas. Temporally, PM2.5 pollution levels across different
   urban scenarios exhibited a rise-fall-rise pattern. The findings provide
   support for fine-scale PM2.5 monitoring, urban planning, and pollution
   control.},
Type = {Article},
Affiliation = {Liang, JZ (Corresponding Author), Fuzhou Univ, Acad Digital China Fujian, 2 Xueyuan Rd, Fuzhou 350108, Minhou, Peoples R China.
   Li, Daichao; Jin, Xinlei; Xu, Fangnian; Liang, Juanzhu, Fuzhou Univ, Acad Digital China Fujian, 2 Xueyuan Rd, Fuzhou 350108, Minhou, Peoples R China.
   Li, Daichao; Jin, Xinlei; Xu, Fangnian; Liang, Juanzhu, Fuzhou Univ, Key Lab Spatial Data Min \& Informat Sharing Minist, Minist Educ, Fuzhou 350108, Peoples R China.
   Wang, Xiaohui, Zhejiang Acad Surveying \& Mapping, Hangzhou 310023, Peoples R China.},
DOI = {10.1016/j.uclim.2025.102498},
EarlyAccessDate = {JUN 2025},
Article-Number = {102498},
Keywords = {PM 2.5 concentration; Urban scenarios; MGWR-XGBoost; Feature importance;
   Partial dependence plots},
Keywords-Plus = {LAND-USE REGRESSION; AIR-QUALITY; DAILY MORTALITY; AMBIENT PM2.5; TERM
   EXPOSURE; RESOLUTION; POLLUTION; IMPACTS; REDUCTION; AREAS},
