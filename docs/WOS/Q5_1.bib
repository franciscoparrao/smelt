DOI = {10.3390/f16010142},
Article-Number = {142},
Keywords = {FVC; spatial-temporal variation; spatial autocorrelation; geodetector
   model; machine learning},
Keywords-Plus = {SPATIAL AUTOCORRELATION; TEMPERATURE; PRECIPITATION; DYNAMICS; FOREST;
