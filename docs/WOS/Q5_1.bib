@article{ WOS:001669957900001,
Author = {Yan, Yuqiao and Li, Yaoyu and Jia, Shujie and Bai, Yangfan and Cao,
   Boxin and Mashori, Abdul Sattar and Li, Fuzhong and Zhang, Wuping},
Title = {Integration of UAV Multispectral and Meteorological Data to Improve
   Maize Yield Prediction Accuracy},
Journal = {AGRONOMY-BASEL},
Year = {2026},
Volume = {16},
Number = {2},
Month = {JAN 8},
Abstract = {This study, conducted in the Lifang Dryland Experimental Area in
   Jinzhong, Shanxi Province, China, aimed to develop a method to
   accurately predict maize yield by combining UAV multispectral data with
   meteorological information. A DJI Mavic 3M UAV was used to capture
   four-band imagery (red, green, red-edge, and near-infrared), from which
   16 vegetation indices were calculated, along with daily meteorological
   data. Among eight machine learning algorithms tested, ensemble models,
   Random Forest and Gradient Boosting Trees performed best, with R2 values
   of 0.8696 and 0.8163, respectively. SHAP analysis identified MSR and RVI
   as the most important features. The prediction accuracy varied across
   growth stages, with the jointing stage showing the highest performance
   (R2 = 0.7161), followed by the flowering stage (R2 = 0.6588). The yield
   exhibited a strip-like spatial distribution, ranging from 6450 to 9600
   kg<middle dot>ha-1, influenced by field management, soil
   characteristics, and microtopography. K-means clustering revealed
   high-yield areas in the central-northern region and low-yield areas in
   the south, supported by a global Moran's I index of 0.4290, indicating
   moderate positive spatial autocorrelation. This study demonstrates that
   integrating UAV multispectral data, meteorological information, and
   machine learning can achieve accurate yield prediction (with a relative
   RMSE of about 2.8\%) and provides a quantitative analytical framework
   for spatial management in drought-prone areas.},
Type = {Article},
Affiliation = {Li, FZ; Zhang, WP (Corresponding Author), Shanxi Agr Univ, Coll Software, Jinzhong 030801, Peoples R China.
   Yan, Yuqiao; Jia, Shujie; Bai, Yangfan; Cao, Boxin; Mashori, Abdul Sattar; Li, Fuzhong; Zhang, Wuping, Shanxi Agr Univ, Coll Software, Jinzhong 030801, Peoples R China.
   Li, Yaoyu; Mashori, Abdul Sattar, Shanxi Agr Univ, Coll Agr Engn, Jinzhong 030006, Peoples R China.},
DOI = {10.3390/agronomy16020163},
Article-Number = {163},
Keywords = {maize yield; UAV multispectral; machine learning; vegetation indices;
   spatial autocorrelation},
Author-Email = {202430824@stu.sxau.edu.cn
   lifuzhong@sxau.edu.cn
   zhangwuping@stu.sxau.edu.cn},
Number-of-Cited-References = {44},
Times-Cited = {0},
Unique-ID = {WOS:001669957900001},
}

@article{ WOS:001662754500001,
Author = {Li, Yijun and Zhong, Xueting and Gong, Huili and Hen, Beibei and Zhou,
   Chaofan and Li, Hao and Wang, Xincheng and Xu, Lewei},
Title = {Spatiotemporal evolution and attribution analysis of groundwater drought
   in the North China Plain: GGDI constructed based on downscaled GRACE
   GWSA},
Journal = {JOURNAL OF HYDROLOGY-REGIONAL STUDIES},
Year = {2026},
Volume = {63},
Month = {FEB},
Abstract = {Study Region: North China Plain (NCP), China. Study Focus: To address
   the limitations of low-resolution data accuracy and insufficient
   quantitative characterization of driving mechanisms in groundwater
   drought assessment in the NCP, this study proposes a systematic research
   framework: downscaling GRACE data using Geographically Weighted
   Regression (GWR) to reconstruct 0.05 degrees Groundwater Storage
   Anomalies (GWSA) for 2002-2023 and construct the GRACE Groundwater
   Drought Index (GGDI). Furthermore, combining Random Forest (RF) with
   Geographic Detector (GD) reveals the quantitative contributions of
   natural and anthropogenic factors and their interactions (2003-2022).
   This framework overcomes the limitations of traditional research in
   spatiotemporal resolution and mechanistic interpretation, providing a
   new methodological approach for regional groundwater drought research.
   New Hydrological Insights for the Region: (1) From 2002-2023, the 0.05
   degrees GWSA exhibited higher accuracy than the 0.25 degrees, revealing
   a-17.81 +/- 3.31 mm/yr decline. (2) Drought was mild in the northeast
   and severe in the southwest. The 0.05 degrees GWSA first detected relief
   in approximately 4 \% of the region (e.g., northern Beijing and
   northwestern Cangzhou). Fifteen drought events were identified during
   the study period, showing increasing frequency and intensity. The GGDI
   rebounded in 2016 and 2021 due to rainfall, the South-to-North Water
   Diversion, and groundwater-withdrawal restrictions. (3) Groundwater
   extraction was the dominant driver (contributing 45 \%), and its
   interaction with precipitation markedly amplified drought risk (q =
   0.83), particularly in fine-grained aquifer areas.},
Type = {Article},
Affiliation = {Li, YJ; Gong, HL (Corresponding Author), 105 North Rd,West 3rd Ring Rd, Beijing, Peoples R China.
   Li, Yijun; Zhong, Xueting; Gong, Huili; Hen, Beibei; Zhou, Chaofan; Wang, Xincheng; Xu, Lewei, Capital Normal Univ, Key Lab Minist Educ Land Subsidence Mech \& Prevent, Beijing 100048, Peoples R China.
   Li, Yijun; Zhong, Xueting; Gong, Huili; Hen, Beibei; Zhou, Chaofan; Wang, Xincheng; Xu, Lewei, Capital Normal Univ, Coll Resource Environm \& Tourism, Beijing 100048, Peoples R China.
   Li, Yijun; Zhong, Xueting; Gong, Huili; Hen, Beibei; Zhou, Chaofan; Wang, Xincheng; Xu, Lewei, Capital Normal Univ, Beijing Lab Water Resources Secur, Beijing 100048, Peoples R China.
   Li, Hao, Henan Polytech Univ, Sch Surveying \& Land Informat Engn, Jiaozuo 454000, Peoples R China.},
DOI = {10.1016/j.ejrh.2026.103103},
EarlyAccessDate = {JAN 2026},
Article-Number = {103103},
Keywords = {GRACE; Downscaling; Groundwater drought; GGDI; Driver-response; NCP},
Keywords-Plus = {WATER; REGRESSION; DEPLETION},
Author-Email = {2230902136@cnu.edu.cn
   gonghl@cnu.edu.cn},
Number-of-Cited-References = {57},
Times-Cited = {0},
Unique-ID = {WOS:001662754500001},
}

@article{ WOS:001681630500004,
Author = {Mahdiyanfar, Hossein},
Title = {Advancing censored geochemical Au prediction through Bayesian spatial
   models and Random Forest with fractal-based background separation},
Journal = {SCIENTIFIC REPORTS},
Year = {2026},
Volume = {16},
Number = {1},
Month = {JAN 6},
Abstract = {Censored geochemical data, particularly below detection limits,
   challenge mineral exploration by biasing anomaly delineation and spatial
   patterns. This study presents a multi-stage framework combining Bayesian
   Gaussian Random Field (BGRF) modeling with Random Forest (RF) learning,
   enhanced by fractal-based background separation, to accurately predict
   censored Au concentrations. 14 samples with gold concentrations below 5
   ppb were hypothesized as censored data to enable a more accurate
   evaluation of the model's performance based on their real Au
   concentrations. Unlike constant substitution methods, the framework
   preserves censored information and reconstructs spatial variability
   through probabilistic inference and nonlinear learning. The BGRF model
   incorporates spatial coordinates and Cu as the principal covariate to
   capture spatial autocorrelation and inter-element associations,
   producing probabilistic estimates for hypothesized censored data (HCD)
   that are then used to train the RF under a 5-fold out-of-fold scheme.
   The HCD estimated by spatial BGRF covariate model were performed as
   inputs for RF prediction model. A targeted calibration and scaling
   procedure reduces detection-limit bias and improves low-range
   predictions. Comparative analyses show that the calibrated and scaled
   RF-BGRF model substantially enhances accuracy and preserves realistic
   geochemical structures, outperforming half the detection limit (LD-half)
   or the detection limit divided by the square root of two (LD-rad2)
   approaches. This framework offers a promising tool for refining
   left-censored geochemical data in complex geological environments.},
Type = {Article},
Affiliation = {Mahdiyanfar, H (Corresponding Author), Univ Gonabad, Dept Min Engn, Gonabad, Iran.
   Mahdiyanfar, Hossein, Univ Gonabad, Dept Min Engn, Gonabad, Iran.},
DOI = {10.1038/s41598-026-34999-4},
Article-Number = {4763},
Keywords = {Censored geochemical data; Bayesian Gaussian Random Field (BGRF); Random
   Forest (RF); Fractal analysis; Spatial modeling},
Keywords-Plus = {ANOMALIES; INFERENCE; CU},
Author-Email = {Hssn.mahdiyanfar@gmail.com},
Number-of-Cited-References = {39},
Times-Cited = {0},
Unique-ID = {WOS:001681630500004},
}

@article{ WOS:001659755500001,
Author = {Nasretdinova, Milena and Dowd, Peter and Xu, Chaoshui},
Title = {Lithological classification of drill cores using XCT and XRF data: a
   geometallurgical perspective},
Journal = {MINERALS ENGINEERING},
Year = {2026},
Volume = {237},
Month = {MAR},
Abstract = {This study presents an integrated framework for the automated
   lithological classification of drill cores by combining X-ray computed
   tomography (XCT) and X-ray fluorescence (XRF) data within a machine
   learning setting. A total of 293 m of drill cores from the Kalkaroo
   copper-gold deposit in South Australia were classified into five
   lithological categories at 5 cm intervals. XCT voxel attenuation values
   were summarised using percentile-based descriptors to capture density
   and textural variability, while XRF provided complementary geochemical
   information. Random Forest (RF) and Extreme Gradient Boosting (XGBoost)
   classifiers were applied using drill hole-wise leave-one-out
   cross-validation to mitigate spatial autocorrelation. The integrated
   XCT-XRF dataset outperformed single-modality inputs, with the XGBoost
   method achieving the highest predictive performance (Macro-F1 = 0.86).
   SHapley Additive exPlanations (SHAP) revealed that Cu, Fe, S, Ca, and K
   were the dominant discriminators, while high-end XCT percentiles
   enhanced the resolution of dense sulphide phases. This proved critical
   for distinguishing chalcopyrite-rich intervals, which govern copper
   recovery and concentrate grade, from pyrite-dominant horizons, which
   increase lime consumption and depress flotation selectivity. Downhole
   analysis confirmed the geological plausibility of predictions and
   highlighted transitions with implications for blending, comminution
   energy and metallurgical forecasting. The results demonstrate that
   XCT-XRF integration provides robust, interpretable, high-resolution
   lithology classification with geometallurgical relevance. Quantitative
   calibration to comminution indices or flotation performance requires
   additional datasets and is outside the scope of the present study.},
Type = {Article},
Affiliation = {Nasretdinova, M (Corresponding Author), Univ Adelaide, Australian Res Council Training Ctr Integrated Ope, Adelaide 5005, Australia.
   Nasretdinova, Milena; Dowd, Peter; Xu, Chaoshui, Univ Adelaide, Australian Res Council Training Ctr Integrated Ope, Adelaide 5005, Australia.
   Nasretdinova, Milena; Dowd, Peter; Xu, Chaoshui, Univ Adelaide, Fac Sci Engn \& Technol, Adelaide 5005, Australia.},
DOI = {10.1016/j.mineng.2025.110053},
EarlyAccessDate = {JAN 2026},
Article-Number = {110053},
Keywords = {X-ray computed tomography; X-ray fluorescence; Random forest; XGBoost;
   Chalcopyrite-pyrite discrimination; Geometallurgy},
Keywords-Plus = {COMPUTED-TOMOGRAPHY; DEPOSIT; EXPLORATION},
Author-Email = {milena.nasretdinova@adelaide.edu.au},
Number-of-Cited-References = {55},
Times-Cited = {0},
Unique-ID = {WOS:001659755500001},
}

@article{ WOS:001652944800001,
Author = {Xi, Shilong and Wang, Xiaohui and Qiu, Ziyi and Luo, Yang and Lin, Kejun},
Title = {Urban Sprawl Undermines Agricultural Supply Chain Resilience: Amplifying
   Role of Resource Misallocation and Its Threshold Effects},
Journal = {FOOD AND ENERGY SECURITY},
Year = {2026},
Volume = {15},
Number = {1},
Month = {JAN 2},
Abstract = {The acceleration of urbanization and its resultant expansion of urban
   sprawl (US) have significantly reshaped agricultural supply chain
   resilience (ASCR). In this study, we focused on the effects of US and
   the induction of imbalances in resource allocation. To accomplish this
   goal, we analyzed the data using a Geographically Weighted Random Forest
   (GWRF) with SHAP values, a moderated effects model, and Bayesian Kernel
   Machine Regression (BKMR). These analyses enabled us to evaluate how US
   undermines ASCR via resource misallocation (RM), with an emphasis on the
   nonlinear dynamics and spatial heterogeneity of RM. Our results indicate
   that an apparent nonlinear threshold effect exists between US and ASCR.
   When US remains below a critical threshold value of 0.33, moderate
   expansion enhances supply chain resilience. However, once this limit is
   surpassed, the negative impact of US intensifies exponentially. In
   addition, we found evidence of spatial disparities, with eastern coastal
   regions exhibiting more pronounced vulnerabilities, while specific
   megacity clusters displayed a positive response. RM functions as an
   amplifier, under conditions where capital distortion (CD) and land
   distortion (LAD) substantially magnify the marginal adverse effects of
   US at lower levels. In contrast, labor distortion (LD) demonstrates
   relatively stable effects, though these effects were spatially
   differentiated. Collectively, these distortions operate through a
   cyclical mechanism of ``market inefficiency-spatial crowding-labor
   mismatch,{''} the net effect of which systematically erodes resilience.
   Compared with previous studies that mainly focus on linear mean effects
   or single-factor misallocations, in this study we employed a combined
   GWRF-SHAP and BKMR framework to systematically reveal the
   threshold-dependent spatially heterogeneous effects of US and the
   nonlinear amplification mechanisms of multidimensional RM. With this
   approach, quantifiable evidence for enhancing agricultural supply chain
   resilience management in developing countries can be achieved.
   Accordingly, policy recommendations are proposed to underscore the
   urgency of establishing urban growth boundary controls and corrective
   mechanisms for land misallocation to sever the amplification loop of
   this process.},
Type = {Article},
Affiliation = {Lin, KJ (Corresponding Author), Zhejiang Ocean Univ, Sch Econ \& Management, Zhoushan, Peoples R China.
   Xi, Shilong; Wang, Xiaohui; Qiu, Ziyi; Lin, Kejun, Zhejiang Ocean Univ, Sch Econ \& Management, Zhoushan, Peoples R China.
   Luo, Yang, Catholic Univ Korea, Dept Educ, Bucheon Si, South Korea.},
DOI = {10.1002/fes3.70184},
Article-Number = {e70184},
Keywords = {agricultural supply chain resilience; nonlinear relationship; resource
   misallocation; spatial heterogeneity; urban sprawl},
Keywords-Plus = {LAND; SUSTAINABILITY; REGIONS},
Author-Email = {linkejun@zjou.edu.cn},
Number-of-Cited-References = {127},
Times-Cited = {0},
Unique-ID = {WOS:001652944800001},
}

@article{ WOS:001659769800001,
Author = {Zhang, Xuemao and Xie, Binggeng and Li, Junhan and Yuan, Chuan and Zhou,
   Kaichun and Xie, Jing and Pang, Xiaofei},
Title = {Spatiotemporal patterns and drivers of ecosystem service interactions in
   karst regions: Insights for environmental protection and sustainability},
Journal = {ISCIENCE},
Year = {2026},
Volume = {29},
Number = {1},
Month = {JAN 16},
Abstract = {Comprehending the interrelationships among ecosystem services (ESs)
   across temporal and spatial scales is fundamental for effective ES
   management. In this study, correlation analysis, geographically weighted
   regression (GWR), self-organizing maps (SOMs), and random forest
   modeling (RFM) were used to comparatively analyze the interrelationships
   among eight ESs at grid (1 km x 1 km) and township scales in a karst
   region of China from 2000 to 2020. The results showed that food
   production (FP) exhibited the greatest increase, whereas water
   purification rate (WP) changed minimally. Nine ES pairs exhibited
   trade-offs, primarily involving the FP, whereas most of the other ES
   pairs demonstrated synergies. Four distinct ecosystem service bundles
   (ESBs) were identified at both scales, although their composition and
   abundance varied. Natural, anthropogenic, and landscape pattern factors
   influenced ESs differently at different scales. This study reveals
   complex multiscale ES interactions and offers guidance for spatial
   planning and sustainable ES management in karst regions.},
Type = {Article},
Affiliation = {Xie, BG (Corresponding Author), Hunan Normal Univ, Sch Geog Sci, Changsha 410081, Peoples R China.
   Zhang, Xuemao; Xie, Binggeng; Zhou, Kaichun; Xie, Jing; Pang, Xiaofei, Hunan Normal Univ, Sch Geog Sci, Changsha 410081, Peoples R China.
   Li, Junhan, Chinese Acad Sci, Inst Geochem, State Key Lab Environm Geochem, Guiyang 550081, Peoples R China.
   Yuan, Chuan, Southwest Univ, Sch Life Sci, Chongqing 400715, Peoples R China.},
DOI = {10.1016/j.isci.2025.114399},
EarlyAccessDate = {JAN 2026},
Article-Number = {114399},
Keywords-Plus = {TRADE-OFFS; SYNERGIES; BUNDLES; SOILS},
Author-Email = {xbgyb1961@163.com},
Number-of-Cited-References = {72},
Times-Cited = {0},
Unique-ID = {WOS:001659769800001},
}

@article{ WOS:001669322600006,
Author = {Ghio, Daniela and Hoyos-Hoyos, Sarah and Liu, Gavin and Kyeremeh,
   Emmanuel and Mcleman, Robert and Resch, Gabby and Mazalek, Ali},
Title = {Modeling the Spatial Interplay Between Migration and Environmental
   Conditions},
Journal = {ENVIRONMETRICS},
Year = {2026},
Volume = {37},
Number = {1},
Month = {JAN},
Abstract = {The measurement and modeling of migration patterns and potential drivers
   are often limited by the quality of spatial data at local levels. Our
   aim is to address these constraints by advantaging of consolidated
   techniques in geospatial regression and emerging machine-learning
   approaches to explore how selected contextual socio-economic and
   environmental factors are related to migration trends. We define a
   three-step empirical strategy. First, we use the
   Geographically-Weighted-Regression to model the spatial variation at
   local scales. Second, we adopt the
   Multiscale-Geographically-Weighted-Regression to focus on the spatial
   heterogeneity across geographical scales. Third, we adopt the
   Geographically-Weighted-Random-Forest-Regression to validate variations
   across multiple local models. To illustrate, we apply the proposed
   methodology to selected environmental factors and gridded estimates of
   net migration patterns in Ghana, between 1985 and 2014. By the
   comparison of results, we argue the models' complementary explaining the
   contribution of each method to depict the spatial variability of
   migration environmental factors.},
Type = {Article},
Affiliation = {Ghio, D (Corresponding Author), Univ Catania, Catania, Italy.
   Ghio, D (Corresponding Author), Toronto Metropolitan Univ, Toronto, ON, Canada.
   Ghio, Daniela, Univ Catania, Catania, Italy.
   Ghio, Daniela; Hoyos-Hoyos, Sarah; Liu, Gavin; Kyeremeh, Emmanuel; Mazalek, Ali, Toronto Metropolitan Univ, Toronto, ON, Canada.
   Mcleman, Robert, Wilfrid Laurier Univ, Waterloo, ON, Canada.
   Resch, Gabby, Ontario Tech Univ, Toronto, ON, Canada.},
DOI = {10.1002/env.70070},
Article-Number = {e70070},
Keywords-Plus = {CLIMATE-CHANGE; CAUSAL INFERENCE; NORTHERN GHANA; UNEMPLOYMENT;
   VARIABILITY; MOBILITY; DROUGHT; ECONOMY; HAZARD; LAND},
Author-Email = {daniela.ghio@unict.it},
Number-of-Cited-References = {98},
Times-Cited = {0},
Unique-ID = {WOS:001669322600006},
}

@article{ WOS:001698301600003,
Author = {Ouyang, Liping and He, Yichen and Chen, Zufan and He, Ke},
Title = {Dynamic monitoring and evolution of urban green space landscape
   sustainability based on spatiotemporal analysis algorithm},
Journal = {INTERNATIONAL JOURNAL OF ENVIRONMENT AND SUSTAINABLE DEVELOPMENT},
Year = {2026},
Volume = {25},
Number = {5},
Abstract = {To address the issue of disconnect between the spatial-temporal
   characteristics of urban green space landscape dynamics and
   sustainability assessment, this study utilises the spatial-temporal
   DBSCAN (ST-DBSCAN) algorithm to identify hotspot areas of green space
   coverage changes and the spatial-temporal variations in green space
   fragmentation, and combines this with a geographically weighted
   regression (GTWR) model to quantitatively analyse the impact of driving
   factors such as population growth and land development intensity on the
   ecological service functions of green spaces. The experimental results
   show that the LSTM+ST-ConvNet model predicts the green space area for
   2020-2024 with an error of only 50 square kilometres, outperforming
   other prediction models such as ARIMA, XGBoost, and Random Forest (the
   ARIMA model had an error of 70 square kilometres). This model can more
   accurately predict trends in green space area changes, providing
   theoretical support for urban green space.},
