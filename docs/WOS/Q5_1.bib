   Yang, Jun, Northeastern Univ, Jangho Architecture Coll, Shenyang 110169, Peoples R China.},
DOI = {10.1109/JSTARS.2024.3416184},
Keywords = {Drivers; land surface temperature (LST); urban functional zones (UFZs);
   urban thermal environment; Drivers; land surface temperature (LST);
   urban functional zones (UFZs); urban thermal environment},
Keywords-Plus = {HEAT-ISLAND; CLIMATE; CITIES; CHINA; MORPHOLOGY; CONTRAST; IMPACTS},
