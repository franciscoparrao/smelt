   Li, Mingsong, Univ Elect Sci \& Technol China, Yangtze Delta Reg Inst, Huzhou 313099, Peoples R China.},
DOI = {10.1109/LGRS.2023.3255785},
Article-Number = {7000605},
Keywords = {Land surface temperature; Spatial resolution; Radio frequency; Remote
