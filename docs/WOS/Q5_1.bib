   Kapadia, Anuj; Peluso, Alina, Oak Ridge Natl Lab, Computat Sci \& Engn Div, Oak Ridge, TN 37830 USA.
   Trafton, Jodie, Vet Hlth Adm, Off Mental Hlth \& Suicide Prevent, Palo Alto, CA 94304 USA.},
DOI = {10.1109/BigData62323.2024.10825016},
Keywords = {Geographically Weighted Random Forest; Spatial Modeling; Suicide;
   Machine Learning; Mental Health},
Keywords-Plus = {FEATURE-SELECTION; CLUSTERS; RATES},
