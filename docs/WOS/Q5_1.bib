   Li, Mengwei, Fujian Yijing Ecol Construction Grp Co Ltd, Xiamen 361000, Peoples R China.},
DOI = {10.1016/j.jclepro.2025.146060},
EarlyAccessDate = {JUN 2025},
Article-Number = {146060},
Keywords = {Forest carbon sequestration; Forest carbon loss; Urbanization carbon
   loss; SHapley additive exPlanations (SHAP); Multiscale geographically
   weighted regression; (MGWR)},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; CHINA},
