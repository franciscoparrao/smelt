   Aguilera, Juan, UTHlth Houston, Ctr Community Hlth Impact, Sch Publ Hlth, El Paso, TX 79902 USA.},
DOI = {10.3390/ijgi14030105},
Article-Number = {105},
Keywords = {large cities; spatial analysis; sociodemographic; built environment;
   ambient air pollution; urban heat islands; healthcare facilities;
