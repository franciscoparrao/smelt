@article{ WOS:001543237400002,
Author = {Hu, Chunguang and Tao, Yuxuan and Zhang, Maomao and Fan, Houbao and Xu,
   Nan and Sun, Yucheng and Yuan, Ruidi and Zhao, Jianqing},
Title = {Unveiling the impact of 2D/3D urban morphology on thermal comfort across
   urban-rural gradients using machine learning},
Journal = {ENERGY AND BUILDINGS},
Year = {2025},
Volume = {346},
Month = {NOV 1},
Abstract = {Urban morphology significantly shapes the spatial distribution of
   thermal comfort (TC), with marked heterogeneity across urban-rural
   gradients. Existing studies often neglect the synergistic effects and
   spatial variability of 2D/3D urban morphology indicators, hindering a
   comprehensive understanding of TC drivers. This study examines the
   Qinhuai River Basin, China, using a tripartite classification (urban
   core, suburban, rural) to analyze the impact of 14 2D/3D urban
   morphology indicators on TC. Spatial autocorrelation analysis identifies
   significant TC clustering, while a random forest regression (RFR) model
   paired with SHAP (Shapley Additive exPlanations) quantifies indicator
   contributions and spatial variations. Findings reveal a clear
   urban-rural gradient: 3D parameters (e.g., Mean Building Height {[}MBH],
   Standard Deviation of Height {[}SDH], Mean Building Volume {[}MBV])
   dominate in urban cores, suburban areas show mixed responses (SDH, MBH,
   Mean Footprint Area {[}MFA]), and rural regions balance
   natural-anthropogenic effects (MBH, MBV, MFA). SHAP analysis highlights
   urban cores' heat island exacerbation by high-rise structures (MBH
   standard deviation: 0.021; SDH: 0.0147), complex land-use effects in
   suburbs (SDH range:-0.079 to 0.041), and natural cooling in rural areas
   (MBH mean: 0.00112; MFA: 0.00132). MBH, MFA, and SDH are key TC
   predictors, while Distance-to-Height Ratio (DH) suggests optimizing
   street layouts for better ventilation. This study offers a scientific
   basis for tailored thermal management and urban morphology optimization,
   enhancing TC and sustainable development across urban--rural gradients.},
Type = {Article},
Affiliation = {Zhao, JQ (Corresponding Author), Jiangsu Second Normal Univ, Sch Geog, Key Lab Climate Risk \& Urban Rural Smart Governanc, Nanjing 210013, Peoples R China.
