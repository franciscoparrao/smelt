Keywords = {Convolutional long short-term memory (ConvLSTM); deep learning;
   normalized difference vegetation index (NDVI); spatial weight;
   spatiotemporal prediction; Convolutional long short-term memory
   (ConvLSTM); deep learning; normalized difference vegetation index
   (NDVI); spatial weight; spatiotemporal prediction},
