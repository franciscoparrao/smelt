@article{ WOS:001634862900002,
Author = {Chen, Hsin-Yu and Yeh, Hsin-Fu},
Title = {Baseflow index dynamics and its non-monotonic drivers from a
   spatiotemporal heterogeneity perspective},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {665},
Month = {FEB},
Abstract = {This study analyzed the dynamics and drivers of base flow index (BFI),
   defined as the ratio of base flow to total streamflow, using data from
   60 Taiwanese catchments from 1960 to 2022. BFI is an informative
   indicator in hydrological, environmental, and disaster management
   applications and is influenced by a wide range of static and
   time-varying catchment attributes. However, the spatial and temporal
   driving mechanisms of catchment attributes on BFI are often overlooked.
   The Geographically and Temporally Weighted Regression (GTWR) is a
   well-established model for providing flexible coefficient settings for
   the exploration of these spatiotemporal heterogeneity mechanisms. This
   study included static physiographic factors and time-varying factors
   such as rainfall characteristics and land cover change. The results show
   that (1) BFI is significant spatial and temporal non-stationarity, with
   both increasing and decreasing trends over time and statistically
   significant spatial clustering. (2) GTWR has the best performance
   compared to GWR and pooled regression and even outperformed the random
   forest method. (3) Most of the attributes showed non-monotonic effects
   on BFI, with coefficients varying positive or negative depending on time
   and space. In contrast, coefficients of simple daily intensity index
   (SDII) are consistently negative across all locations and time periods,
   indicating a monotonically negative influence on BFI. (4) Both GTWR and
   Random Forest analyses consistently identified SDII as the most dominant
   driver of BFI. The findings provide deeper insights into the drivers of
   BFI and highlight the necessity of accounting for spatiotemporal
   heterogeneity in hydrological signature analysis. The results can
   support sustainable water resources management and land-use planning
   under changing hydroclimatic conditions.},
Type = {Article},
Affiliation = {Yeh, HF (Corresponding Author), Natl Cheng Kung Univ, Dept Resources Engn, Tainan 701, Taiwan.
   Chen, Hsin-Yu; Yeh, Hsin-Fu, Natl Cheng Kung Univ, Dept Resources Engn, Tainan 701, Taiwan.},
DOI = {10.1016/j.jhydrol.2025.134692},
EarlyAccessDate = {DEC 2025},
Article-Number = {134692},
Keywords = {Baseflow index; Catchment attributes; Geographically and temporally
   weighted regression (GTWR); Spatiotemporal heterogeneity},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; FLOW INDEX; GROUNDWATER RECHARGE;
   CATCHMENT PROPERTIES; UNITED-STATES; LAND-USE; REGIONALIZATION;
   RECESSION; RAINFALL; IMPACTS},
Author-Email = {hfyeh@mail.ncku.edu.tw},
Number-of-Cited-References = {97},
Times-Cited = {0},
Unique-ID = {WOS:001634862900002},
}

@article{ WOS:001635904600001,
Author = {Li, Yurou and Wang, Weiwei and Liao, Qiulin and Cao, Yuchi and Chen,
   Jiaao and Xiao, Peng and Huang, Xuejia and Liu, Xiaoru and Liao,
   Jingpeng and Yang, Jiangfeng and Shen, Shouyun},
Title = {Attractiveness of urban open spaces in the information Era: Exploring
   the influence of environmental attributes and online reviews},
Journal = {LANDSCAPE AND URBAN PLANNING},
Year = {2026},
Volume = {267},
Month = {MAR},
Abstract = {In the information age, social media has reshaped public perceptions of
   urban open spaces (UOS). Traditional strategies for enhancing urban open
   space attractiveness (UOSA), focused on urban physical forms, urban
   function, social-economy, and landscape character, which show
   limitations in explaining UOSA. To address this gap, this study compares
   traditional environmental attributes with online reviews (ORs). The
   influence mechanism framework reveals that ORs affect UOSA by satisfying
   individual space identity and reshaping perceptions of environmental
   attributes. Taking Changsha, China, as a case, we constructed a UOSA
   assessment framework using geolocated social media data and exploring
   the influencing mechanisms under different temporal scenarios in UOS.
   The integrated impact index system, combining environmental attributes
   and ORs, was developed, and Geographically Weighted Random Forest was
   used to analyze influencing mechanisms. Lasso regression assessed factor
   sensitivity. The results show that: (1) UOSA exhibits spatiotemporal
   differentiation. (2) ORs significantly outweigh other factors in
   influencing UOSA (Wilcoxon Signed-Rank test, p < 0.01), with attention
   and online popularity being the most influential (1 and 0.814). The
   findings underscore ORs' critical role and provide insights for
   sustainable UOS planning and management.},
Type = {Article},
Affiliation = {Shen, SY (Corresponding Author), Hunan Prov Ctr Big Data Engn Technol Res Nat Conse, 498 South Shaoshan Rd, Changsha 410004, Hunan, Peoples R China.
