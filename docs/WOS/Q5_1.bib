Keywords = {Outdoor jogging activity; Visual environment; City image data;
   Trajectory data; MGWR},
Keywords-Plus = {VOLUNTEERED GEOGRAPHIC INFORMATION; STREET VIEW; URBAN; PERCEPTIONS},
Author-Email = {ywgismap@cqu.edu.cn},
