   Yunta-Mezquita, Felipe; Vieira, Diana, European Commiss, Joint Res Ctr, Via E Fermi 2749, I-21027 Ispra, VA, Italy.},
DOI = {10.1016/j.jhazmat.2025.140872},
EarlyAccessDate = {DEC 2025},
Article-Number = {140872},
Keywords = {Cadmium; Potentially toxic elements; Local model; Outlier; SHAP},
Keywords-Plus = {SPATIAL AUTOCORRELATION; SOIL; REGRESSION; ADSORPTION; CD},
