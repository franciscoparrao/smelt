   Ho, Viet Hoang; Ho, Thanh Ha, Hue Univ, Univ Agr \& Forestry, 102 Phung Hung Str, Hue City 53000, Vietnam.},
DOI = {10.1016/j.ecolmodel.2025.111242},
EarlyAccessDate = {JUN 2025},
Article-Number = {111242},
Keywords = {Forest aboveground biomass density; Random forest; Ordinary kriging;
   Co-kriging; Multispectral; Multi-frequency synthetic aperture radar},
Keywords-Plus = {LANDSAT TM DATA; VEGETATION INDEX; MANAGING FORESTS; TEXTURE; SAR;
   SENTINEL-1; CLIMATE; STOCKS; RADAR; RED},
Author-Email = {paoe9ws1@s.okayama-u.ac.jp},
Number-of-Cited-References = {127},
