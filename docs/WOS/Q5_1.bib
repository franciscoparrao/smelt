@article{ WOS:001543093000002,
Author = {Ksantini, F. and Quemada, M. and Arencibia-Perez, N. and Almeida-Naunay,
   A. F. and Sanz, E. and Tarquis, Ana M.},
Title = {Impact of data spatial resolution on barley yield prediction mapping},
Journal = {SMART AGRICULTURAL TECHNOLOGY},
Year = {2025},
Volume = {12},
Month = {DEC},
Abstract = {Data-driven models and remote sensing techniques offer great crop
   monitoring and yield prediction potential. The choice of spatial
   resolution plays a key role in model performance, as the resolution of
   data input influences prediction quality. This work explores different
   spatial scales of 6 m, 12 m and 24 m resolution using regression-based
   models, including Simple Linear Regression, Multiple Linear Regression
   and Random Forest Regression. Specifically, it investigates how changes
   in spatial resolution affect the predictive accuracy of yield models.
   Through the evaluation and comparison of the different models at these
   different spatial resolutions, the study aims to identify the most
   effective approach for each resolution, considering the specific
   variables used by each model. The results show that Random Forest
   Regression achieves the highest accuracy at 6 m (R2= 0.93, RMSE = 0.15)
   and 12 m (R2 = 0.93, RMSE = 0.17). At 24 m, Stepwise Multiple Linear
   Regression performs better (R2 = 0.81, RMSE = 0.26) due to data
   limitations. Beyond traditional accuracy metrics, spatial validation was
   performed using Moran index and Structural similarity index (SSIM) to
   assess spatial autocorrelation and pattern preservation. Random Forest
   Regression at 6 m (Moran I = 0.12, SSIM =0.92) and 12 m (Moran I = 0.25,
   SSIM = 0.96), capturing spatial heterogeneity and structural similarity
   effectively, while Stepwise Multiple Linear Regression at 24 m also
   maintained a strong spatial accuracy (Moran I = 0.39, SSIM = 0.72). In
   addition, vegetation indices, particularly the Normalised Vegetation
   Index, significantly improve prediction accuracy. Overall, the results
   underline the importance of selecting an optimal spatial resolution that
   balances model accuracy and data availability, providing valuable
   information for optimising barley yield prediction.},
