@article{ WOS:001614259400004,
Author = {He, Mingxia and Niu, Jie and Liu, Dongdong and Wu, Chuanhao and Wu, Pan
   and Hu, Bill X.},
Title = {Quantifying the impact of dam-related barriers on river fragmentation
   and water quality across China},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {664},
Number = {B},
Month = {JAN},
Abstract = {River fragmentation, caused by the construction of dam-related barriers
   such as dams, locks, and weirs, is a major issue impacting aquatic
   ecosystems and water quality. This study combined deep learning, remote
   sensing imagery, and manual validation to detect dam-related barriers in
   major river basins of China and focused on the river fragmentation
   levels and the impacts of these barriers on water quality. The proposed
   deep learning model achieved high performance with a precision of 0.9112
   and a recall of 0.8940 in barrier detection, and generated a dam-related
   barrier dataset comprising 12,962 instances. Results show that low-head
   dams (55 \%) and partial dams (26 \%) are the most prevalent dam-related
   barrier types. Connectivity metrics revealed that the Southeast Basin
   exhibited the highest fragmentation, while the Southwest Basin exhibited
   the lowest. Only 24.04 \% of the river network remained connected under
   all-barrier conditions, compared to 40.87 \% when only large dams were
   considered, indicating more severe fragmentation primarily driven by the
   widespread distribution of small dams. Geographically weighted
   regression model analysis showed stable performance across scenarios
   (PBIAS - 7 to + 3) and revealed that the cumulative impact of small dams
   on conductivity, turbidity, permanganate index, and total nitrogen often
   exceeded that of individual large dams. These findings demonstrate the
   critical role of small dams in altering water quality and river
   connectivity, and highlight the need to consider their cumulative
   effects in river management strategies.},
Type = {Article},
Affiliation = {Niu, J (Corresponding Author), Guizhou Univ, Coll Resources \& Environm Engn, Key Lab Karst Georesources \& Environm, Minist Educ, Guiyang 550025, Peoples R China.
   He, Mingxia; Niu, Jie; Liu, Dongdong; Wu, Pan, Guizhou Univ, Coll Resources \& Environm Engn, Key Lab Karst Georesources \& Environm, Minist Educ, Guiyang 550025, Peoples R China.
