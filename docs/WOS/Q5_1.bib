   Cerda, Artemi, Univ Valencia, Dept Geog, Soil Eros \& Degradat Res Grp, Blasco Ibanez 28, Valencia 46010, Spain.},
DOI = {10.1016/j.scs.2021.102784},
EarlyAccessDate = {FEB 2021},
