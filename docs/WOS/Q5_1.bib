@article{ WOS:001667881800001,
Author = {Yun, Zhaode and Wang, Yintang and Liu, Pan and Li, Lingjie and Liu, Yong
   and Liu, Yang},
Title = {Addressing class imbalance extends the performance frontier of
   classification-regression satellite-gauge precipitation fusion},
Journal = {JOURNAL OF HYDROLOGY},
Year = {2026},
Volume = {667},
Month = {MAR},
Abstract = {The classification-regression framework for precipitation fusion has
   been widely applied to enhance the spatiotemporal accuracy of
   precipitation estimates. However, existing frameworks often overlook the
   sample imbalance among different precipitation types, thereby limiting
   further improvements in fusion accuracy. To overcome these issues, we
   propose a classification-regression satellite-gauge precipitation fusion
   framework that explicitly addresses sample imbalance. In the
   classification stage, we apply oversampling, undersampling, and hybrid
   sampling strategies designed to balance class distribution, combined
   with Random Forest (RF) and KNearest Neighbors (KNN) models to identify
   rain/no rain and relatively heavy/normal precipitation classes. In the
   regression stage, virtual precipitation samples generated through
   sampling are incorporated into RF to enhance estimation in relatively
   heavy rainfall regions. Spatial autocorrelation variables and auxiliary
   variables are also integrated into RF to generate a preliminary fused
   precipitation product. The final fused dataset, ImbCRPF, combines the
   optimal classification and regression results. Applied to heavy rainfall
   events in the Chaohu and Taihu Lake basins, ImbCRPF outperforms the
   mainstream RF-RF model. Its 0.01 degrees dataset improves the F1 scores
   for no rain and relatively heavy rainfall by 0.28 and 0.13, while the
   0.1 degrees dataset yields gains of 0.18 and 0.06, respectively. The two
   datasets also increase KGE by 0.26 and 0.14 over the RF-RF. This
   framework is the first to address sample imbalance in precipitation
   fusion, effectively extending the upper limits of estimation accuracy.},
Type = {Article},
Affiliation = {Liu, P (Corresponding Author), Wuhan Univ, State Key Lab Water Resources Engn \& Management, Wuhan 430072, Peoples R China.
   Wang, YT (Corresponding Author), Nanjing Hydraul Res Inst, Natl Key Lab Water Disaster Prevent, Nanjing 210029, Peoples R China.
   Yun, Zhaode; Liu, Pan; Liu, Yang, Wuhan Univ, State Key Lab Water Resources Engn \& Management, Wuhan 430072, Peoples R China.
   Yun, Zhaode; Liu, Pan; Liu, Yang, Wuhan Univ, Hubei Prov Key Lab Water Syst Sci Sponge City Cons, Wuhan 430072, Peoples R China.
   Yun, Zhaode; Wang, Yintang; Li, Lingjie; Liu, Yong, Nanjing Hydraul Res Inst, Natl Key Lab Water Disaster Prevent, Nanjing 210029, Peoples R China.
   Wang, Yintang; Li, Lingjie, Yangtze Inst Conservat \& Dev, Nanjing 210098, Peoples R China.},
DOI = {10.1016/j.jhydrol.2025.134898},
EarlyAccessDate = {JAN 2026},
Article-Number = {134898},
Keywords = {Precipitation fusion; Class-Imbalance; Sampling; Extreme precipitation;
   Random forest},
Keywords-Plus = {SMOTE},
Author-Email = {ytwang@nhri.cn
   liupan@whu.edu.cn},
