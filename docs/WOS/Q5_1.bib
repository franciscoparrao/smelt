@article{ WOS:000763038900001,
Author = {Guliker, Evert and Folmer, Erwin and van Sinderen, Marten},
Title = {Spatial Determinants of Real Estate Appraisals in The Netherlands: A
   Machine Learning Approach},
Journal = {ISPRS INTERNATIONAL JOURNAL OF GEO-INFORMATION},
Year = {2022},
Volume = {11},
Number = {2},
Month = {FEB},
Abstract = {With the rapidly increasing house prices in the Netherlands, there is a
   growing need for more localised value predictions for mortgage
   collaterals within the financial sector. Many existing studies focus on
   modelling house prices for an individual city; however, these models are
   often not interesting for mortgage lenders with assets spread out all
   over the country. That is why, with the current abundance of national
   geospatial datasets, this paper implements and compares three hedonic
   pricing models (linear regression, geographically weighted regression,
   and extreme gradient boosting-XGBoost) to model real estate appraisals
   values for five large municipalities in different parts of the
   Netherlands. The appraisal values used to train the model are provided
   by Stater N.V., which is the largest mortgage service provider in the
   Netherlands. Out of the three implemented models, the XGBoost model has
   the highest accuracy. XGBoost can explain 83\% of the variance with an
   RMSE of euro65,312, an MAE of euro43,625, and an MAPE of 6.35\% across
   the five municipalities. The two most important variables in the model
   are the total living area and taxation value, which were taken from
   publicly available datasets. Furthermore, a comparison is made between
   indexation and XGBoost, which shows that the XGBoost model is able to
   more accurately predict the appraisal values of different types of
   houses. The remaining unexplained variance is most probably caused by
   the lack of good indicators for the condition of the house. Overall,
   this paper highlights the benefits of open geospatial datasets to build
   a national real estate appraisal model.},
Type = {Article},
Affiliation = {Folmer, E (Corresponding Author), Univ Twente, Fac Behav Management \& Social Sci BMS, NL-7522 NB Enschede, Netherlands.
   Guliker, Evert; Folmer, Erwin, Univ Twente, Fac Behav Management \& Social Sci BMS, NL-7522 NB Enschede, Netherlands.
   Guliker, Evert; van Sinderen, Marten, Univ Twente, Fac Elect Engn Math \& Comp Sci EEMCS, NL-7522 NB Enschede, Netherlands.
   Guliker, Evert, Stater NV, NL-3826 PA Amersfoort, Netherlands.
   Folmer, Erwin, Kadaster, NL-7311 KZ Apeldoorn, Netherlands.},
DOI = {10.3390/ijgi11020125},
Article-Number = {125},
Keywords = {real estate values modelling; housing market; housing price; real estate
   appraisals; hedonic model; extreme gradient boosting; geographically
   weighted regression; The Netherlands},
Keywords-Plus = {HEDONIC PRICING ANALYSIS; HOUSE PRICES; REPEAT SALES; OPEN SPACE;
   IMPACT; SITES},
Author-Email = {b.e.guliker@alumnus.utwente.nl
   erwin.folmer@utwente.nl
   m.j.vansinderen@utwente.nl},
