   Jiao, Xinyu, Shanghai Jiao Tong Univ, Sch Design, Shanghai 200240, Peoples R China.},
DOI = {10.1109/ACCESS.2024.3445995},
Keywords = {Urban areas; Blogs; Social networking (online); Cognition; Big Data;
