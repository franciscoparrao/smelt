Affiliation = {Chen, XH (Corresponding Author), Sun Yat Sen Univ, Sch Civil Engn, Guangzhou 510275, Peoples R China.
   He, Kunlong; Chen, Xiaohong, Sun Yat Sen Univ, Sch Civil Engn, Guangzhou 510275, Peoples R China.
   Liu, Jiao, Southwest Univ Sci \& Technol Mianyang, Sch Environm \& Resources, Mianyang 621010, Peoples R China.
   Liu, Jiao, Natl Remote Sensing Ctr China, Mianyang 621010, Peoples R China.
   Zhao, Dongmei, Chinese Acad Sci, Inst Mt Hazards \& Environm, Chengdu 610041, Peoples R China.},
DOI = {10.1016/j.scitotenv.2023.162378},
EarlyAccessDate = {FEB 2023},
Article-Number = {162378},
Keywords = {GPM; Precipitation; Tibetan Plateau; Merged; Spatial resolution;
