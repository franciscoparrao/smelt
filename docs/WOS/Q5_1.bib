Unique-ID = {WOS:001582570200001},
}

@article{ WOS:001567801100001,
Author = {Luo, Menglin and Sun, Ming},
Title = {Accessibility assessment and optimization of public charging stations
   from a categorical perspective: A case study in Nanjing based on
   charging travel chains},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2025},
Volume = {131},
Month = {SEP 1},
Abstract = {This study examines supply-demand imbalances and service inefficiencies
   in the layout of public charging stations (PCSs) for new energy vehicles
   in central Nanjing. A framework of ``Spatial Efficiency-Supply and
   Demand Diagnosis-Site Selection Optimisation{''} is established.
   Theoretically, a dual-stage travel chain accessibility model is
   introduced, evaluating both driving and walking accessibility while
   integrating road hierarchy, vehicle ownership, and public facility data.
   Methodologically, an improved Gaussian two-step floating catchment area
   method (G2SFCA) and a cumulative opportunity model (COM) quantify
   accessibility; spatial autocorrelation tests supply-demand matching; and
   multi-scale geographically weighted regression with grid
   search-optimised extreme gradient boosting provides grid-level siting
   recommendations. Strategically, a category-based response is proposed to
   align PCSs with urban functions. Results show that despite high overall
   density, fast PCSs exhibit service gaps in old urban areas; slow PCSs
   are evenly distributed but weakly integrated with communities; and
   ultra-fast PCSs must balance industrial coverage with premium service
   demand. Supply-demand clustering highlights key mismatch zones. At the
   same time, the optimised siting map suggests enhancing utilisation of
   fast PCSs in high-demand grids, strengthening the community service
   network of slow PCSs, and coupling industrial and high-end functions of
   ultra-fast PCSs. Overall, the framework enhances coordinated dual-stage
   accessibility and offers a transferable approach to reconcile
   infrastructure provision with urban constraints in dense cities,
   providing a robust basis for precise transport infrastructure planning
   under carbon-neutrality goals.},
Type = {Article},
Affiliation = {Sun, M (Corresponding Author), Northeast Forestry Univ, Sch Landscape, Harbin 150400, Peoples R China.
   Luo, Menglin; Sun, Ming, Northeast Forestry Univ, Sch Landscape, Harbin 150400, Peoples R China.},
DOI = {10.1016/j.scs.2025.106771},
EarlyAccessDate = {SEP 2025},
Article-Number = {106771},
Keywords = {New energy vehicle (NEV); Public charging station (PCS); Accessibility;
   Travel chain; Site optimisation; electricity to vehicles.},
Keywords-Plus = {SPATIAL ACCESSIBILITY; DEMAND},
Author-Email = {sunming@nefu.edu.cn},
Number-of-Cited-References = {68},
Times-Cited = {0},
Unique-ID = {WOS:001567801100001},
}

@article{ WOS:001566067000001,
Author = {Wang, Yunda and Chen, Xudounan and Dai, Fei and Chen, Ming},
Title = {Valuing the characteristics of urban green spaces to delineate their
   differential economic benefits based on housing value},
Journal = {ENVIRONMENTAL AND SUSTAINABILITY INDICATORS},
Year = {2025},
Volume = {28},
Month = {DEC},
Abstract = {Urban green spaces (UGS) offer significant economic benefits that are
   well captured by housing value. Traditional valuation research focuses
   on the impact of UGS size and proximity on housing prices, neglecting
   the contribution of other green space characteristics such as quality,
   type, and shape, as well as how to guide the balanced construction of
   UGS. To address this gap, we use Wuhan, a Chinese city with high housing
   sales volume, as a case study. We use multi-source geographic big data
   and machine learning to comprehensively evaluate the characteristics and
   value added by UGS, deploying a combined random forest and multi-scale
   geographically weighted regression model. We find that the quality,
   type, and shape of UGS have far greater ability to add value to housing
   than do UGS scale and distance. In particular, quality-related
   characteristics exhibit an extremely large and stable positive effect on
   housing value. In addition, we also discovered threshold effects of
   scale, type, shape, and quality characteristics, beyond which the
   value-added benefits of green spaces will be greatly reduced. Based on
   these findings, we group green space characteristics by value added and
   propose a method of regulating green spaces in Wuhan. This method will
   help urban planners and policy makers better identify the differences in
   value added by the multiple characteristics of green spaces and provide
   new guidance for optimising their features.},
Type = {Article},
Affiliation = {Dai, F (Corresponding Author), Huazhong Univ Sci \& Technol, Sch Architecture \& Urban Planning, Wuhan 430074, Peoples R China.
   Wang, Yunda; Dai, Fei, Huazhong Univ Sci \& Technol, Sch Architecture \& Urban Planning, Wuhan 430074, Peoples R China.
