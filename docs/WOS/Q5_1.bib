   Zhao, Yu-Guo; Zhang, Gan-Lin, Univ Chinese Acad Sci, Beijing 100049, Peoples R China.},
DOI = {10.1016/j.geoderma.2019.114145},
Article-Number = {114145},
Keywords = {Digital soil mapping; Machine learning; Ensemble learning; Uncertainty;
