Keywords-Plus = {AIR-POLLUTION; HAZE POLLUTION; PATTERNS; EXPOSURE; QUALITY; FOREST},
Author-Email = {tangjiayi24@hunnu.edu.cn},
Number-of-Cited-References = {61},
