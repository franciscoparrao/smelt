@article{ WOS:000626308200001,
Author = {Guo, Bin and Bian, Yi and Zhang, Dingming and Su, Yi and Wang, Xiaoxia
   and Zhang, Bo and Wang, Yan and Chen, Qiuji and Wu, Yarui and Luo,
   Pingping},
Title = {Estimating Socio-Economic Parameters via Machine Learning Methods Using
   Luojia1-01 Nighttime Light Remotely Sensed Images at Multiple Scales of
   China in 2018},
Journal = {IEEE ACCESS},
Year = {2021},
Volume = {9},
Pages = {34352-34365},
Abstract = {Mapping socio-economic indicators with a raster format is still a great
   challenge. The nighttime light (NTL) datasets have been widely utilized
   to estimate the socio-economic parameters. However, the precision of the
   published datasets was too coarse to meet related issues such as flood
   losses assessment, urban planning, and epidemiological studies. The
   present study calibrated gross domestic product (GDP), population (POP),
   electric consumption (EC), and urban build-up area (B-A) at 100 m
   resolution for 45 cities of China in 2018 using Luojia1-01 NTL datasets
   via random forest (RF) as well as geographically weighted regression
   (GWR) model. The linear regression (LR), back propagation neural network
   (BPNN), and support vector machine (SVM) methods were selected for
   comparison with GWR and RF models. Besides, the Suomi National
   Polar-Orbiting Partnership-Visible Infrared Imaging Radiometer Suite
   (NPP-VIIRS) was chosen for comparison with Luojia1-01. The ten-folded
   cross-validation (CV) has been used for evaluating accuracy at county
   and city scales. Finally, the distribution maps of socio-economic
   parameters were illustrated and some findings were obtained. First, the
   validation results revealed that the calibration at the city-scale
   outperformed the county or district scale. Second, the precision of the
   Luojia1-01 NTL dataset surpassed the NPP-VIIRS NTL dataset on the same
   administrative scale except for some specific situations. Third, the
   precision of the simulation for the gross domestic product (GDP) is the
   highest than the others, followed by electric consumption (EC), build-up
   area (B-A), and population (POP). Fourth, the optimum model varied
   according to the socio-economic parameters. Fifth, the distribution of
   socio-economic parameters exhibited obvious spatial heterogeneity. This
   paper can supply scientific support for calibrating socio-economic
   parameters in other regions.},
Type = {Article},
Affiliation = {Guo, B (Corresponding Author), Xian Univ Sci \& Technol, Coll Geomat, Xian 710054, Peoples R China.
   Luo, PP (Corresponding Author), Changan Univ, Key Lab Subsurface Hydrol \& Ecol Effects Arid Reg, Minist Educ, Xian 710054, Peoples R China.
   Luo, PP (Corresponding Author), Changan Univ, Sch Water \& Environm, Xian 710054, Peoples R China.
   Guo, Bin; Bian, Yi; Zhang, Dingming; Su, Yi; Wang, Xiaoxia; Zhang, Bo; Wang, Yan; Chen, Qiuji; Wu, Yarui, Xian Univ Sci \& Technol, Coll Geomat, Xian 710054, Peoples R China.
   Luo, Pingping, Changan Univ, Key Lab Subsurface Hydrol \& Ecol Effects Arid Reg, Minist Educ, Xian 710054, Peoples R China.
   Luo, Pingping, Changan Univ, Sch Water \& Environm, Xian 710054, Peoples R China.},
DOI = {10.1109/ACCESS.2021.3059865},
Keywords = {Spatial resolution; Licenses; Radio frequency; Data models; Biological
