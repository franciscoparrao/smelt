Unique-ID = {WOS:001654581000001},
}

@incollection{ WOS:001671757700017,
Author = {Deniz, Oguz and Pekkan, Huseyin and Ozbayoglu, A. Murat},
Editor = {Matoba, O and Shaw, JA and Valenta, CR},
Title = {From spectral indices to actionable insights: Sensitivity analysis of a
   multispectral U-Net for spatially-optimized urban heat island mitigation},
Booktitle = {SPIE FUTURE SENSING TECHNOLOGIES 2025},
Series = {Proceedings of SPIE},
Year = {2025},
Volume = {13710},
Abstract = {Urban heat island (UHI)(1) effects present significant challenges for
   sustainable urban development. Within the UDENE2 project, a
   deep-learning framework was established to model land surface
   temperature (LST) from remotely sensed urban indices, assess the
   effectiveness of green and blue infrastructure interventions such as
   linked park systems, and identify thermally analogous regions across
   cities. A compact U-Net3 architecture was trained on six spectral
   indices obtained from Google Earth Engine(4) (NDVI,(5) NDBI,(6) NDWI,(7)
   SAVI,(8) IBI,(9) EVI10), with corresponding LST values serving as the
   prediction target. The primary case study was conducted on 50x50-pixel
   windows at 30 m resolution from. Istanbul, with further validation in
   San Francisco and Abu Dhabi to ensure robustness across different
   climatic contexts. To enhance interpretability and minimize spatial
   autocorrelation, a spatial block partitioning strategy was employed, and
   a multi-method sensitivity analysis was implemented. This included
   channel ablation, input perturbation, spatial occlusion, and
   gradient-based explainability techniques. Results consistently
   highlighted the dominant cooling influence of vegetation indices (EVI,
   SAVI, NDVI), with preservation of existing green areas demonstrating
   greater impact than equivalent new additions. Context-dependent effects
   were also observed, particularly for NDWI, reflecting complex
   interactions between urban water features and the surrounding built
   environment. Overall, the proposed framework provides robust and
   interpretable evidence to support urban planners in the design and
   strategic placement of green and blue infrastructure for effective UHI
   mitigation across diverse urban landscapes.},
Type = {Proceedings Paper},
Affiliation = {Deniz, O (Corresponding Author), TOBB Univ Econ \& Technol, Sogutozu St 43, TR-06560 Ankara, Turkiye.
   Deniz, Oguz; Pekkan, Huseyin; Ozbayoglu, A. Murat, TOBB Univ Econ \& Technol, Sogutozu St 43, TR-06560 Ankara, Turkiye.},
DOI = {10.1117/12.3073733},
Article-Number = {137100R},
Keywords = {Urban Heat Island Mitigation; Sensitivity Analysis; Similarity Analysis;
   Environmental Remote and Proximal Sensing},
Keywords-Plus = {VEGETATION INDEX; TEMPERATURE; CLIMATE; GREEN; WATER},
Author-Email = {oguzdeniz179@gmail.com},
Number-of-Cited-References = {45},
Times-Cited = {0},
Unique-ID = {WOS:001671757700017},
}

@incollection{ WOS:001695375000030,
Author = {Ding, Shiqi and Wu, Lingzi},
Editor = {Jafari, A and Zhu, Y},
Title = {Analyzing Public Electric Vehicle Charging Distribution and Urban
   Socio-Spatial Characteristics Using Geographically Weighted Machine
   Learning},
Booktitle = {COMPUTING IN CIVIL ENGINEERING 2025: RESILIENT, ROBOTIC, AND EDUCATIONAL
   SYSTEMS},
Year = {2025},
Pages = {263-272},
Abstract = {To understand the equitable distribution of public electric vehicle
   charging infrastructure (EVCI), previous studies have used
   geographically weighted regression (GWR) to evaluate the spatial
   heterogeneity between EVCI and urban socio-spatial characteristics.
   However, GWR is susceptible to outliers and multicollinearity and
   overlooks the nonlinear relationships inherent in complex urban
   dynamics. This study advances EVCI distribution evaluation by
   incorporating two geographically weighted machine learning approaches,
   random forest (GW-RF) and extreme gradient boosting (GW-XGB), while
   using GWR for comparison. Focusing on nonlinear spatial relationships,
   we examined the EVCI distribution in King County, Washington,
   considering 20 socio-spatial factors. We interpreted the within-sample
   feature importance scores by combining the two machine learning
   approaches. Compared with GWR, we found that population density and
   multi-unit housing proportion are the two key factors related to EVCI
   distribution. The results indicate that future EVCI planning should
   prioritize residential charging needs to support broader transportation
   electrification goals across diverse communities.},
Type = {Proceedings Paper},
Affiliation = {Ding, SQ (Corresponding Author), Univ Washington, Dept Urban Design \& Planning, Seattle, WA 98195 USA.
   Ding, Shiqi, Univ Washington, Dept Urban Design \& Planning, Seattle, WA 98195 USA.
   Wu, Lingzi, Univ Washington, Dept Construct Management, Seattle, WA USA.},
Author-Email = {shiqidi@uw.edu
   lingwu@uw.edu},
Number-of-Cited-References = {17},
Times-Cited = {0},
Unique-ID = {WOS:001695375000030},
}

@article{ WOS:001484303600018,
Author = {He, Kunlong and Zhao, Wei and Brocca, Luca and Quintana-Segui, Pere and
   Chen, Xiaohong},
Title = {SMPD-MERG: A Hybrid Downscaling Model for High-Resolution Daily
   Precipitation Estimation via Merging Surface Soil Moisture and
   Multisource Precipitation Data},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2025},
Volume = {63},
Abstract = {Currently, the poor spatial resolution (10-50 km) and accuracy of
   satellite-based precipitation products (SPP) limit their applications at
   regional scales. To overcome these issues, a hybrid downscaling
   framework, named soil moisture-based precipitation downscaling and
   merging (SMPD-MERG) methods, that merge soil moisture-based
   precipitation downscaling results with European Space Agency (ESA)
   climate change initiative (CCI) soil moisture product and multisource
   data from rain gauge measurements and European Center for Medium-Range
   Weather Forecasts (ECMWFs) ERA5-Land precipitation data with random
   forest (RF) model was proposed to derive high-resolution and
   high-accuracy precipitation data at daily scale. The method was
   successfully applied to the global precipitation measurement (GPM) daily
   precipitation product and improved its spatial resolution from 10 to 1
   km in the central part of the Iberia Peninsula during 2016-2018. The
   validation with field measurements revealed that the proposed method has
   good performance with correlation coefficient (CC), relative bias
   (BIAS), root mean square error (RMSE), and the modified Kling-Gupta
   efficiency (KGE') values of 0.94, 1.00\%, 1.27 mm, and 0.88,
   respectively. Meanwhile, the intercomparison with other downscaling
   algorithms including geographically weighted regression (GWR) and
   interpolation methods, highlights the significant advantages of the
   proposed method. It improves the CC from around 0.60 to over 0.90,
   reducing the RMSE to below 1.30 mm, and decreasing BIAS by nearly an
   order of magnitude. In general, different from previous empirical
   downscaling methods, the proposed method not only considers the physical
   dynamics of the precipitation process but also well integrates the
   advantage of multisource data. According to the satisfactory downscaling
   accuracy, this method shows good potential for producing high-quality
   precipitation data with high spatiotemporal resolution.},
Type = {Article},
Affiliation = {Zhao, W (Corresponding Author), Chinese Acad Sci, Inst Mt Hazards \& Environm, Chengdu 610299, Peoples R China.
   He, Kunlong; Chen, Xiaohong, Sun Yat Sen Univ, Sch Civil Engn, Guangzhou 510275, Peoples R China.
