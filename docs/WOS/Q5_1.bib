Unique-ID = {WOS:000402217800001},
}

@article{ WOS:000897483700013,
Author = {Ye, Miao and Zhu, Lin and Li, Xiaojuan and Ke, Yinghai and Huang, Yong
   and Chen, Beibei and Yu, Huilin and Li, Huan and Feng, Hui},
Title = {Estimation of the soil arsenic concentration using a geographically
   weighted XGBoost model based on hyperspectral data},
Journal = {SCIENCE OF THE TOTAL ENVIRONMENT},
Year = {2023},
Volume = {858},
Number = {1},
Month = {FEB 1},
Abstract = {Considering the high toxicity of arsenic (As), its contamination of soil
   represents an alarming environmental and public health issue. Existing
   soil heavy metal concentration estimation models based on hyperspectral
   data ignore the spatial nonstationarity of the relationship between the
   soil spectrum and heavy metal concentration. A novel model
   (geographically weighted eXtreme gradient boosting or GW-XGBoost model)
   combining geographically weighted regression (GWR) method with XGBoost
   algorithm was proposed. The northeast district of Beijing, China, was
   chosen as a case study area to assess the effectiveness of the proposed
   model. The GW-XGBoost model was established to estimate the As
   concentration based on the typical spectrum of As and the spatial
   correlation between the spectrum and As concentration obtained using the
   GWR method, and the result was compared to that obtained with the
   XGBoost and GWR models. The accuracy of the GW-XGBoost model was
   obviously better than that of the other models (R-GW-XGBoost(2) = 0.90,
   R-XGBoost(2) = 0.48, and R-GWR(2) = 0.74). Therefore, the proposed model
   is reliable, as it considers the spatial correlation between the
   spectrum and As concentration.},
