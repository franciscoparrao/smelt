@article{ WOS:001545685200001,
Author = {Gao, Feng and Deng, Xingdong and Liao, Shunyi and Liu, Yang and Chen,
   Wangyang and Li, Guanyao},
Title = {Comparing visitation patterns in distinct types of parks using
   geospatial data and interpretable machine learning},
Journal = {URBAN FORESTRY \& URBAN GREENING},
Year = {2025},
Volume = {112},
Month = {OCT},
Abstract = {Understanding park visitation is crucial for effective urban planning
   and management, enhancing the quality of life and environmental
   sustainability in cities. However, existing literature often treats all
   park types as a single category and overlooks the nonlinear
   relationships between environmental factors and park visitation. This
   study addresses these gaps by employing mobile phone signaling data to
   quantitatively identify park visitation in Guangzhou, focusing on four
   distinct park types. We apply the multiple linear regression,
   geographically weighted regression, and the eXtreme gradient boosting
   with SHapley additive exPlanations (XGBoost-SHAP) models to analyse the
   visitation characteristics. The results indicate that the machine
   learning model exhibits superior predictive accuracy, capturing various
   factors' nonlinear and threshold effects on park visitation.
   Importantly, these effects differ significantly across park types,
   highlighting the need for targeted urban planning and management
   strategies. This study contributes to a more nuanced understanding of
   urban parks' hierarchical and diverse use patterns, underscoring the
   importance of interdisciplinary and comprehensive research in this
   field.},
Type = {Article},
Affiliation = {Deng, XD (Corresponding Author), Guangzhou Urban Planning \& Design Survey Res Inst, Guangzhou 510060, Peoples R China.
   Gao, Feng; Deng, Xingdong; Liao, Shunyi; Liu, Yang; Chen, Wangyang; Li, Guanyao, Guangzhou Urban Planning \& Design Survey Res Inst, Guangzhou 510060, Peoples R China.
