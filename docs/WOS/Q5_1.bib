DOI = {10.5194/isprs-archives-XLIII-B4-2022-537-2022},
Keywords = {Traffic Flow; Urban Big Data; Spatial Analysis; Deep Learning; Computer
   Vision},
Author-Email = {y.li.17@research.gla.ac.uk
