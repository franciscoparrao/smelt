@article{ WOS:001487155100001,
Author = {Bi, Shibo and Tian, Zheng and Zhang, Yi and Dai, Fei},
Title = {The role of urban green space morphology and threshold in cooling
   efficiency: Evidence from five cities, China},
Journal = {JOURNAL OF CLEANER PRODUCTION},
Year = {2025},
Volume = {509},
Month = {JUN 1},
Abstract = {Urban heat islands pose significant public health risks due to elevated
   land surface temperatures (LSTs). Although urban green spaces (UGSs)
   effectively mitigate LST, enhancing cooling efficiency through
   optimizing UGS morphology (UGSM) remains a challenge. This study
   identifies UGSM types in five megacities through morphological spatial
   pattern analysis (MSPA) and hierarchical clustering. To identify
   high-efficiency cooling regions, a novel method based on multiscale
   geographically weighted regression (MGWR) was developed and
   interactively validated via random forest and XGBoost models. We found
   that high-efficiency cooling regions are primarily concentrated in
   higher LST zones (MH, H). In these regions, significant spatial
   non-stationary effects of UGSMs impact on the LST were observed.
   Compared with that of the whole region, the explanatory efficiency of
   UGSMs for LST variation increased by more than 15 \%. In high-efficiency
   cooling regions, the bridge-dominated mixed UGSM (Bri-MUGSM) exhibited
   the highest explanatory power, explaining over 91 \% of the LST
   variation with XGBoost. Notably, 85.72 \% of the UGSM indicators (MSPs)
   exhibited nonlinear threshold impacts on the LST. Among all the UGSMs,
   for cores with values below 40 ha/km2, every 10 ha increase corresponds
   to an approximate 1 degrees C decrease in LST. When perforation exceeds
   approximately 20 ha/km2, it continues to effectively mitigate LST, while
   the cooling efficiency of other MSPs shows relatively typical
   environmental dependency due to significant differences in different
   UGSMs. This study provides scientific foundation for identifying
   high-efficiency cooling regions, thereby improving the UGS cooling
   efficiency and introduces a new diagnostic framework for identifying
   high-efficiency UGS areas to address other environmental challenges.},
Type = {Article},
Affiliation = {Zhang, Y (Corresponding Author), Nanjing Univ Sci \& Technol, Sch Design Art \& Media, Nanjing 210094, Peoples R China.
   Dai, F (Corresponding Author), Huazhong Univ Sci \& Technol, Sch Architecture \& Urban Planning, Wuhan 430074, Peoples R China.
