   Franch, Marc, Univ Girona, Dept Ciencies Ambientals, PECAT Res Grp, Girona 17003, Spain.},
DOI = {10.3390/ijgi10050343},
Article-Number = {343},
Keywords = {ecological niche modeling; geographically weighted regression; logistic
   regression; road ecology; spatial regression; wildlife-vehicle collision},
Keywords-Plus = {TOAD BUFO-BUFO; NON-STATIONARITY; MORTALITY LEVELS; LANDSCAPE; PATTERNS;
   FRAGMENTATION; DISTRIBUTIONS; DECLINES},
