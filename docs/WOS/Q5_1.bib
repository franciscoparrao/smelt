@article{ WOS:001609239000001,
Author = {Wire, Kyle},
Title = {Advancing urban extreme heat modeling with spatial machine learning
   ensembles: A case study for providence, Rhode Island},
Journal = {URBAN CLIMATE},
Year = {2025},
Volume = {64},
Month = {DEC},
Abstract = {Urban extreme heat demands neighborhood-scale prediction that respects
   spatial heterogeneity and avoids validation leakage. We present a
   scale-aware spatial ensemble for modeling current ambient air
   temperature (AAT) in Providence, Rhode Island, integrating
   geographically weighted diagnostics (GWEN), spatial linear and nonlinear
   learners (MGWR, GWRF, GGPGAM), graph-based spatial features (Laplacian
   eigenmaps), and stacked meta-learning (LightGBM) evaluated with
   buffered, block-based spatial cross-validation across multiple
   resolutions and partition sizes. The target variable is the CAPA/NOAA
   Heat Watch Afternoon AAT surface aggregated to our analysis grid; we use
   CAPA's finalized product without modifying CAPA QC or modeling. Across
   20 cross-scale runs, spatial learners consistently outperformed an OLS
   benchmark, and stacking further improved skill. Under the representative
   30 m grid with a 300 m buffer, base-model performance was MGWR R-2 =
   0.74, GWRF R-2 = 0.78, GGPGAM R-2 = 0.71; the meta-learner achieved R-2
   = 0.81, and adding Laplacian eigenmap features yielded the best observed
   correlation, R-2 = 0.85. In the same configuration, RMSE dropped from
   1.456 degrees F (OLS) to 0.669 degrees F (stacked + Laplacian), a 54.1
   \% reduction versus OLS and a 16.7 \% reduction relative to the best
   base learner. Residual spatial structure was substantially reduced: the
   ensemble cut Moran's I by similar to 38-82 \% across runs; in the best
   30 m/300 m run, residual Moran's I fell to 0.54 (z = 513.8) from raw
   AAT's 0.96 (z = 868.5), a 43.6 \% reduction. These results show that
   treating spatial scale and validation design as first-class choices,
   while combining complementary spatial learners with graph-based
   features, yields higher-fidelity, leakage-resistant AAT maps at
   actionable urban scales for planning and heat-health applications.},
Type = {Article},
Affiliation = {Wire, K (Corresponding Author), Kleinfelder, Philadelphia, PA 19053 USA.
   Wire, Kyle, Kleinfelder, Philadelphia, PA 19053 USA.},
DOI = {10.1016/j.uclim.2025.102671},
EarlyAccessDate = {OCT 2025},
Article-Number = {102671},
Keywords = {Urban heat island; Spatial machine learning; Geographically weighted
   regression; Random Forest; Laplacian eigenmaps; Spatial
   cross-validation; Climate adaptation; Remote sensing; Ensemble modeling},
Author-Email = {Kylewire1899@gmail.com},
Number-of-Cited-References = {25},
Times-Cited = {0},
Unique-ID = {WOS:001609239000001},
}

@article{ WOS:001597418200001,
Author = {Moharana, Pravash Chandra and Naitam, Ravindra and Shirale, Abhay
   Omprakash and Adamala, Sirisha and Dash, Ch. Jyotiprava and Amrutha, B.
   and Raghuvanshi, Mahendra Singh and Karthikeyan, Karunakaran and Biswas,
   Hrittick and Patil, Nitin Gorakh},
Title = {Modeling climate-resilient crop suitability in central India using
   machine learning and species distribution approaches},
Journal = {THEORETICAL AND APPLIED CLIMATOLOGY},
Year = {2025},
Volume = {156},
Number = {11},
Month = {OCT 22},
Abstract = {Climate change and its associated variability are expected to alter the
   geographic viability of land for cultivating various crops. Anticipating
   both current and future spatial shifts in land suitability for soybean
   (Glycine max) and cotton (Gossypium hirsutum) is critical for guiding
   adaptive responses, especially in India's agriculturally significant
   black soil zones. This research investigates the cultivation potential
   of these crops using Species Distribution Models (SDMs) in combination
   with machine learning algorithms. Through GPS-assisted field surveys,
   352 occurrence points for soybean and 251 for cotton were documented. A
   comprehensive suite of 57 predictor variables-covering climatic,
   topographic, and soil characteristics-were used to model suitability
   across three timeframes: present, 2050, and 2070. The most influential
   predictors included soil parameters like organic carbon, CaCO3, channel
   network base level, precipitation of wettest month (BIO13) and min
   temperature of coldest month (BIO6). Under random cross-validation,
   Random Forest consistently outperformed other models for soybean (AUC =
   0.89 +/- 0.02, TSS = 0.61 +/- 0.05, Kappa = 0.64 +/- 0.10) and cotton
   (AUC = 0.85 +/- 0.00, TSS = 0.56 +/- 0.01, Kappa = 0.54 +/- 0.02). In
   contrast, spatial cross-validation resulted in markedly lower accuracy
   across all models and crops, with AUC values clustering between 0.55 and
   0.62. For soybean, the current suitability map identified approximately
   147,203 ha as highly suitable, 162,979 ha as moderately suitable and
   132,014 ha as marginally suitable. Similarly, for cotton, 104,999 ha
   area was identified as highly suitable. Future projections under four
   climate scenarios (RCP2.6, RCP4.5, RCP6.0, and RCP8.5) suggest a general
   expansion in overall suitability by mid and late century. Nevertheless,
   highly suitable zones for soybean are expected to shrink by 9.0\% under
   RCP2.6, while cotton suitability remains relatively consistent across
   all projected scenarios. These insights are crucial for developing
   climate-smart agricultural strategies and promoting sustainable land
   resource management.},
Type = {Article},
Affiliation = {Moharana, PC (Corresponding Author), ICAR Natl Bur Soil Survey \& Land Use Planning, Nagpur 440033, India.
   Moharana, Pravash Chandra; Naitam, Ravindra; Shirale, Abhay Omprakash; Adamala, Sirisha; Dash, Ch. Jyotiprava; Raghuvanshi, Mahendra Singh; Karthikeyan, Karunakaran; Biswas, Hrittick; Patil, Nitin Gorakh, ICAR Natl Bur Soil Survey \& Land Use Planning, Nagpur 440033, India.
