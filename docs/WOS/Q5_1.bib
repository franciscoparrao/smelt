@article{ WOS:000517932000001,
Author = {Izadi, Somayeh and Sohrabi, Hormoz and Khaledi, Majid Jafari},
Title = {Estimation of coppice forest characteristics using spatial and
   non-spatial models and Landsat data},
Journal = {JOURNAL OF SPATIAL SCIENCE},
Year = {2022},
Volume = {67},
Number = {1},
Pages = {143-156},
Month = {JAN 2},
Abstract = {Accurate spatial modelling of forest characteristics is one of the most
   important challenges in remote sensing applications. In this study, we
   compared the ability of Multiple Linear Regression (MLR), Geographically
   weighted regression (GWR), and Random Forest (RF) to estimate different
   forest attributes based on field sample data and Landsat 8 image. CA was
   modelled with the highest accuracy compared to other variables using
   GWR. GWR outperformed other methods. The highest and the lowest values
   of RMSE were for BA using RF (31.0\%) and CA using GWR (12.0\%),
   respectively.},
