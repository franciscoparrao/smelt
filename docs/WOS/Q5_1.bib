Keywords = {What-if scenarios; planning support system; big data; value uplift; land
   economics},
Keywords-Plus = {SCHOOL QUALITY; SUPPORT; IMPACTS; TRANSPORT; SYSTEM},
Author-Email = {c.pettit@unsw.edu.au},
