@article{ WOS:001654581000001,
Author = {Bindajam, Ahmed Ali and Mallick, Javed and Hang, Hoang Thi and Singh,
   Chander Kumar},
Title = {Advanced predictive modelling of urban expansion and land surface
   temperature dynamics using multi-scale machine learning approaches},
Journal = {ADVANCES IN SPACE RESEARCH},
Year = {2026},
Volume = {77},
Number = {2},
Pages = {1679-1702},
Month = {JAN 15},
Abstract = {Rapid urbanization alters land use and land cover (LULC), increasing
   landscape fragmentation and intensifying land surface temperature (LST),
   thereby posing significant challenges for sustainable urban planning.
   This study aims to systematically quantify urban expansion, assess its
   morphological and thermal impacts, and forecast future LST dynamics in
   Lucknow, India, from 1991 to 2021. Using multi-decadal Landsat data, we
   developed year-specific Random Forest (RF) classifiers trained on 17
   features including six spectral bands (Blue, Green, Red, NIR, SWIR1,
   SWIR2), three indices (NDVI, NDBI, NDWI), and eight GLCM texture metrics
   extracted from NIR and SWIR1 bands. Spatial autocorrelation of training
   samples was evaluated using Moran's I (0.35-0.48), and mitigated through
   spatial separation and cross-validated grid search optimization. LULC
   models achieved high accuracy with test accuracies of 88.00 \% (1991),
   86.12 \% (2001), 88.13 \% (2011), and 87.67 \% (2021), and kappa values
   ranging from 0.8562 to 0.8741. LST was retrieved using the Mono-Window
   Algorithm (MWA), revealing a mean LST increase of similar to 2.5 degrees
   C per decade, with 55 \% of the region exceeding 30 degrees C by 2021.
   Morphological Spatial Pattern Analysis (MSPA) identified growing
   fragmentation in agricultural and open land (e.g., loss of core and
   bridge elements) and densification in built-up zones. Polynomial
   regression models (degrees 2-4) were used to forecast LST for 2031
   across MSPA classes, predicting highest values in built-up cores (34.30
   degrees C) and bridges (32.51 degrees C), and lowest in core agriculture
   (25.77 degrees C). These findings confirm that landscape form and
   composition strongly regulate urban thermal patterns. The study presents
   an integrated modeling pipeline linking machine learning classification,
   thermal retrieval, and morphological analysis to anticipate urban heat
   trajectories, providing critical insights for climate-adaptive land use
   planning and resilient urban design. (c) 2025 COSPAR. Published by
   Elsevier B.V. All rights are reserved, including those for text and data
   mining, AI training, and similar technologies.},
Type = {Article},
Affiliation = {Mallick, J (Corresponding Author), King Khalid Univ, Coll Engn, Dept Civil Engn, Abha, Saudi Arabia.
   Bindajam, Ahmed Ali, King Khalid Univ, Coll Architecture \& Planning, Dept Architecture, Abha, Saudi Arabia.
   Mallick, Javed, King Khalid Univ, Coll Engn, Dept Civil Engn, Abha, Saudi Arabia.
   Hang, Hoang Thi; Singh, Chander Kumar, TERI Sch Adv Studies, Dept Energy \& Environm, Analyt \& Geochem Lab, New Delhi, India.
   Singh, Chander Kumar, Gautam Buddha Univ, Sch Vocat Studies \& Appl Sci, Dept Environm Sci, Greater Noida 201312, UP, India.},
DOI = {10.1016/j.asr.2025.10.080},
EarlyAccessDate = {JAN 2025},
Keywords = {Land surface temperature; Land use and land cover; Random forest
