   Qiu, Yinguo, Chinese Acad Sci, Nanjing Inst Geog \& Limnol, Key Lab Watershed Geog Sci, Nanjing 210008, Peoples R China.
   Zhang, Xiang; Wang, Chao; Chen, Nengcheng, Wuhan Univ, Hubei Luojia Lab, Wuhan 430079, Peoples R China.},
DOI = {10.1016/j.srs.2025.100224},
EarlyAccessDate = {APR 2025},
Article-Number = {100224},
Keywords = {Phytoplankton blooms; Coastal sea; Climate change; Eutrophication;
   Machine learning; Water management},
Keywords-Plus = {HARMFUL ALGAL BLOOMS; YELLOW SEA},
