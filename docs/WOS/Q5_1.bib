   McSharry, Patrick, Carnegie Mellon Univ, Machine Learning \& Big Data, Pittsburgh, PA 15213 USA.
   McSharry, Patrick, Univ Oxford, Oxford, England.},
Keywords = {classification; deep learning; satellite imagery; transfer learning;
   urban planning; remote sensing; monitoring},
