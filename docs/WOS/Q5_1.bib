@article{ WOS:000637035600015,
Author = {Schartel, Tyler E. and Cooper, Monica L. and May, Aubrey and Daugherty,
   Matthew P.},
Title = {Quantifying Planococcus ficus (Hemiptera: Pseudococcidae)
   Invasion in Northern California Vineyards to Inform Management Strategy},
Journal = {ENVIRONMENTAL ENTOMOLOGY},
Year = {2021},
Volume = {50},
Number = {1},
Pages = {138-148},
Month = {FEB},
Abstract = {The spread and impact of invasive species in exotic ranges can be
   mitigated by increased understanding of pest invasion dynamics. Here, we
   used geospatial analyses and habitat suitability modeling to
   characterize the invasion of an important vineyard pest, vine mealybug
   (Planococcus ficus Signoret, Hemiptera: Pseudococcidae), using nearly
   15,000 trapping records from throughout Napa County, California, between
   2012 and 2017. Spatial autocorrelation among P. ficus detections was
   strongest at distances of similar to 250 m and detectable at regional
   scales (up to 40 km), estimates of the rate and directionality of spread
   were highly idiosyncratic, and R. ficus detection hotspots were
   spatiotemporally dynamic. Generalized linear model, boosted regression
   tree, and random forest modeling methods performed well in predicting
   habitat suitability for R. ficus. The most important predictors of P.
   ficus occurrence were a positive effect of precipitation in the driest
   month, and negative effects of elevation and distance to nearest winery.
   Our results indicate that 250-m quarantine and treatment zones around R.
   ficus detections are likely sufficient to encompass most local
   establishment and spread, and that implementing localized regulatory
   procedures may limit inadvertent P. ficus spread via anthropogenic
   pathways. Finally, surveys of P. ficus presence at >300 vineyard sites
   validated that habitat suitability estimates were significantly and
   positively associated with P. ficus frequency of occurrence. Our
   findings indicate that habitat suitability predictions may offer a
   robust tool for identifying areas in the study region at risk to future
   P. ficus invasion and prioritizing locations for early detection and
   preventative management efforts.},
Type = {Article},
Affiliation = {Schartel, TE (Corresponding Author), Univ Calif Riverside, Dept Entomol, Riverside, CA 92521 USA.
   Schartel, TE (Corresponding Author), Univ Illinois, Prairie Res Inst, Illinois Nat Hist Survey, 1816 South Oak St, Champaign, IL 61820 USA.
   Schartel, Tyler E.; Daugherty, Matthew P., Univ Calif Riverside, Dept Entomol, Riverside, CA 92521 USA.
   Cooper, Monica L.; May, Aubrey, Univ Calif Napa, Cooperat Extens, Napa, CA 94558 USA.
   Schartel, Tyler E., Univ Illinois, Prairie Res Inst, Illinois Nat Hist Survey, 1816 South Oak St, Champaign, IL 61820 USA.},
DOI = {10.1093/ee/nvaa141},
Keywords = {invasion dynamics; invasion risk; invasion hotspot; integrated pest
   management},
Keywords-Plus = {SPECIES DISTRIBUTION MODELS; BIOLOGICAL INVASIONS; ECOLOGICAL-NICHE;
   VINE MEALYBUG; INSECT; RISK; PEST; DISPERSAL; HOMOPTERA; IMPACTS},
Author-Email = {tyschartel@yahoo.com},
Number-of-Cited-References = {84},
