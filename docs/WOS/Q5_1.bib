   Sirri, Mesut, Siirt Univ, Kurtalan Vocat High Sch, Dept Plant \& Anim Prod, Siirt, Turkiye.},
DOI = {10.1007/s10661-022-10813-2},
Article-Number = {317},
Keywords = {Spatial modeling; Artificial neural network; Adaptive neuro-fuzzy
   inference system; Geoaccumulation index; Modified contamination factor;
   Nemerow pollution index},
Keywords-Plus = {NEURAL-NETWORKS; ORGANIC-MATTER; PREDICTION; INDEXES; CONTAMINATION;
   CADMIUM; FUZZY; LEAD; AGROECOSYSTEMS; IDENTIFICATION},
Author-Email = {elifgunal@yahoo.com
