   Wang, Ziqi; Chen, Zeyin, Tongji Univ, Coll Architecture \& Urban Planning, Shanghai 200092, Peoples R China.
   Zhang, Xiuning, Univ Coll London UCL, Bartlett Ctr Adv Spatial Anal, London W1T 4TJ, England.
   Qiao, Renlu, Tongji Univ, Shanghai Res Inst Intelligent Autonomous Syst, Shanghai 200092, Peoples R China.},
DOI = {10.1016/j.habitatint.2025.103629},
EarlyAccessDate = {NOV 2025},
