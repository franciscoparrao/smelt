   Kalimenze, John Desderius, Geol Survey Tanzania GST, POB 903, Dodoma, Tanzania.},
DOI = {10.1016/j.oreoa.2024.100065},
EarlyAccessDate = {AUG 2024},
Article-Number = {100065},
Keywords = {Machine learning; Gold prospect; Central Tanzania; East Africa;
   Predictive modeling},
