Keywords-Plus = {PREVALENCE; BURDEN; EPIDEMIOLOGY; CHILDREN; IMPACTS},
Author-Email = {a.mohammadi@uma.ac.ir
   epishagar2018@gmail.com},
Number-of-Cited-References = {114},
