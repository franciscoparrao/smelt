}

@article{ WOS:000262016500007,
Author = {Marmion, Mathieu and Hjort, Jan and Thuiller, Wilfried and Luoto, Miska},
Title = {A comparison of predictive methods in modelling the distribution of
   periglacial landforms in Finnish Lapland},
Journal = {EARTH SURFACE PROCESSES AND LANDFORMS},
Year = {2008},
Volume = {33},
Number = {14},
Pages = {2241-2254},
Month = {DEC},
Abstract = {This study compares the predictive accuracy of eight state-of-the-art
   modelling techniques for 12 landforms types in a cold environment. The
   methods used are Random Forest (RF), Artificial Neural Networks (ANN),
   Generalized Boosting Methods (GBM), Generalized Linear Models (GLM),
   Generalized Additive Models (GAM), Multivariate Adaptive Regression
   Splines (MARS), Classification Tree Analysis (CTA) unit Mixture
   Discriminant Analysis (MDA). The spatial distributions of 12 periglacial
   landforms types were recorded in sub-Arctic landscape of northern
   Finland in 2032 grid squares at a resolution of 25 ha. First, three
   topographic variables were implemented into the eight modelling
   techniques (simple model), and then six other variables were added
   (three soil and three vegetation variables; complex model) to reflect
   the environmental conditions of each grid square. The predictive
   accuracy was measured by two methods: the area under the curve (AUC) of
   a receiver operating characteristic (ROC) plot, and the Kappa index (K),
   based on spatially independent model evaluation data. The mean AUC
   values of the simple models varied between 0.709 and 0.796, whereas the
   AUC values of the complex model ranged from 0.725 to 0.825. For both
   simple and complex models GAM, GLM, ANN and GBM provided the highest
   predictive performances based on both AUC and kappa values. The results
   encourage further applications of the novel modelling methods in
   geomorphology. Copyright (D 2008 John Wiley \& Sons, Ltd.},
Type = {Article},
Affiliation = {Marmion, M (Corresponding Author), Univ Oulu, Thule Inst, POB 7300, Oulu 90014, Finland.
   Marmion, Mathieu; Luoto, Miska, Univ Oulu, Thule Inst, Oulu 90014, Finland.
   Marmion, Mathieu; Luoto, Miska, Univ Oulu, Dept Geog, Oulu 90014, Finland.
   Hjort, Jan, Univ Helsinki, Dept Geog, FIN-00014 Helsinki, Finland.
   Thuiller, Wilfried, Univ Grenoble 1, CNRS, Lab Ecol Alpine, UMR 5553, F-38041 Grenoble 9, France.},
DOI = {10.1002/esp.1695},
Keywords = {spatial modelling; statistical techniques; AUC; Kappa; predictive
   performance},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; SPECIES DISTRIBUTIONS; SPATIAL
   AUTOCORRELATION; LOGISTIC-REGRESSION; PERMAFROST; GIS; CLIMATE; SCALE;
   CLASSIFICATIONS; DETERMINANTS},
Author-Email = {Mathieu.marmion@oulu.fi},
Number-of-Cited-References = {70},
Times-Cited = {52},
