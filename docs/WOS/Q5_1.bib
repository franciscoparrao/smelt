   Lin, Yuying, Fujian Normal Univ, Sch Culture Tourism \& Publ Adm, Fuzhou 350117, Peoples R China.},
DOI = {10.1007/s10668-025-07029-y},
EarlyAccessDate = {NOV 2025},
