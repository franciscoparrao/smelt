@article{ WOS:001054468000001,
Author = {Nguyen, Giang V. and Le, Xuan-Hien and Van, Linh Nguyen and May, Do Thi
   Tuyet and Jung, Sungho and Lee, Giha},
Title = {Machine learning approaches for reconstructing gridded precipitation
   based on multiple source products},
Journal = {JOURNAL OF HYDROLOGY-REGIONAL STUDIES},
Year = {2023},
Volume = {48},
Month = {AUG},
Abstract = {Study region: South Korea is situated in the northeastern region of Asia
   Study focus:: Recent technological developments have enabled
   multi-source precipitation products (MSPs), including satellite-based
   and model-based, to be useful data sources for quantifying the
   spatiotemporal variations in precipitation. Unfortunately, the main
   limitation of MSPs in potential applications is inheritance errors with
   high uncertainty. To tackle this problem, the capabilities of six
   machine learning algorithms (Ridge Linear Regression, k-Nearest
   Neighbors, Support Vector Regression, Gradient Boosting Decision Tree,
   Light Gradient Boosting Machine, and Random Forest) to produce new
   precipitation product by merging MSPs with ground-based data have
   investigated. Ground-based data from 2003 to 2017 were utilized for
   train and valid process. The robustness of the ML algorithms was
   highlighted using several evaluation metrics such as continuous indices
   (modified Kling-Gupta Efficiency and root mean square error) and
   categorical indices (probability of detection, false alarm rate, and
   critical success index). New hydrological insights for the region: The
   results indicate that (1) the ML approaches can merge MSPs with observed
   data for accurately estimate rainfall, particularly in basins with
   sparsely distributed rain gauge stations. (2) The merged precipitation
   products generated from the six ML approaches showed significant
   agreement and high accuracy with observation data considering rainfall
   intensity estimation and improved the capability of detecting rain and
   non-rain events over South Korea.},
