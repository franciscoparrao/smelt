   Liu, Yaoqian, Southwest Jiaotong Univ, SWJTU LEEDS Joint Sch, Chengdu 610031, Peoples R China.},
DOI = {10.3390/land14122315},
Article-Number = {2315},
Keywords = {built environment; mobile physical activity; perceptual perspective;
   machine learning; nonlinear effects; interactive effects; urban planning},
Keywords-Plus = {JOGGING BEHAVIOR},
Author-Email = {flopink@outlook.com
