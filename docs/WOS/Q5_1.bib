   Wang, Yuxia, Shandong Agr \& Engn Univ, Sch Land Resources \& Surveying, Jinan, Peoples R China.},
DOI = {10.1002/ldr.5413},
EarlyAccessDate = {DEC 2024},
Keywords = {accuracy; gridded livestock mapping; residual assignment; trend
   modeling; uncertainty},
Keywords-Plus = {TIME-SERIES; CHINA; GRASSLAND; SYSTEMS},
Author-Email = {pengg@chd.edu.cn},
