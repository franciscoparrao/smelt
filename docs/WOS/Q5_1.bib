@article{ WOS:001325756100001,
Author = {Yue, Hui and Wang, Zhixiong and Liu, Ying},
Title = {Comprehensive Assessment of the Ecosystem in Yellow River Basin Based on
   Pattern-Quality-Service Model},
Journal = {ENVIRONMENTAL MODELING \& ASSESSMENT},
Year = {2025},
Volume = {30},
Number = {2},
Pages = {337-348},
Month = {APR},
Abstract = {Ecosystem comprehensive assessment analyzes the capacity of ecosystems
   to provide production and services that are important for human
   development. Most studies focused on a single ecosystem service and
   product measurement, but few studies focused on modeling ecosystem
   characteristics and relationships between ecosystems from multiple
   perspectives. This study focused on the ecosystem status of the Yellow
   River Basin (YRB) from 1989 to 2020 and established a
   pattern-quality-service framework to propose a comprehensive ecosystem
   status assessment model (CEA). Univariate linear regression and spatial
   autocorrelation analysis were used to investigate the temporal and
   spatial trends of CEA in the basin, while the random forest model was
   employed to reveal the spatial distribution of driving forces in the
   basin. The results showed that the CEA spatial pattern decreased
   significantly from south to north in the YRB. The CEA in the basin was
   mainly medium grade and fair grade. The CEA was significantly improved
   in 82.7\% of the regions, mainly in the upper and middle reaches of the
   YRB. The spatial clustering of CEA in the YRB exhibited significant
   spatial heterogeneity. The source region was dominated by High-High
   clusters, the upper and middle reaches were covered by a large number of
   Low-Low clusters, and the lower reaches showed High-High clusters and
   Not Significant clusters. With the passage of time, the low-value area
   decreased and the high-value area increased. The upper and lower reaches
   of the YRB were mainly affected by natural factors, and the social and
   economic impacts were mainly concentrated in the middle reaches of the
   basin. In summary, The CEA could directly and objectively reflect the
   changes in the status of the ecosystem, which could provide
   decision-making support for regional ecological protection and
   high-quality development.},
Type = {Article},
Affiliation = {Yue, H (Corresponding Author), Minist Nat Resources, Key Lab Mine Geol Hazards Mech \& Control, Xian 710054, Shaanxi, Peoples R China.
   Yue, H (Corresponding Author), Xian Univ Sci \& Technol, Coll Geomat, Xian 710054, Peoples R China.
   Yue, Hui; Liu, Ying, Minist Nat Resources, Key Lab Mine Geol Hazards Mech \& Control, Xian 710054, Shaanxi, Peoples R China.
   Yue, Hui; Wang, Zhixiong; Liu, Ying, Xian Univ Sci \& Technol, Coll Geomat, Xian 710054, Peoples R China.},
