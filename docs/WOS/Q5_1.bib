   Matazi, Alain Kangela, Univ Catholique Bukavu UCB, Fac Agron, Dept Soil Sci, BP 285, Bukavu, DEM REP CONGO.},
DOI = {10.1007/s40808-023-01788-1},
EarlyAccessDate = {JUN 2023},
Keywords = {Spatial linear regression; Flexibility; Uncertainty; INLA-SPDE; RFRK;
   RF; DSM},
Keywords-Plus = {ORGANIC-CARBON STOCKS; SPATIOTEMPORAL MODELS; REGIONAL-SCALE; MATTER;
