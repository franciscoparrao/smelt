   Chen, Jinliu, China Portugal Joint Lab Cultural Heritage Conserv, Suzhou 215000, Peoples R China.
   Li, Nan, Suzhou City Univ, Sch Digital Econ \& Management, Suzhou 215000, Peoples R China.},
DOI = {10.3390/buildings15101740},
Article-Number = {1740},
Keywords = {sustainable urban planning and regeneration; human perception analytics;
   built environment; life satisfaction measurements; GBDT},
Keywords-Plus = {NEIGHBORHOOD SATISFACTION; INCOME INEQUALITY; DETERMINANTS; IMPACT;
   VALUES; TRAVEL; WELL},
