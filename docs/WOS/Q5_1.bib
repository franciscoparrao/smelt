@article{ WOS:000858301900001,
Author = {Georganos, Stefanos and Kalogirou, Stamatis},
Title = {A Forest of Forests: A Spatially Weighted and Computationally Efficient
   Formulation of Geographical Random Forests},
Journal = {ISPRS INTERNATIONAL JOURNAL OF GEO-INFORMATION},
Year = {2022},
Volume = {11},
Number = {9},
Month = {SEP},
Abstract = {The aim of this paper is to present developments of an advanced
   geospatial analytics algorithm that improves the prediction power of a
   random forest regression model while addressing the issue of spatial
   dependence commonly found in geographical data. We applied the
   methodology to a simple model of mean household income in the European
   Union regions to allow easy understanding and reproducibility of the
   analysis. The results are encouraging and suggest an improvement in the
   prediction power compared to previous techniques. The algorithm has been
   implemented in R and is available in the updated version of the
   SpatialML package in the CRAN repository.},
