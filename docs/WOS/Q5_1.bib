DOI = {10.3390/su172210278},
Article-Number = {10278},
Keywords = {urban vitality; urban form; metro station areas; GBDT-LL model; temporal
   dynamics},
Keywords-Plus = {NODE-PLACE MODEL; LAND-USE; BUILT ENVIRONMENT; TRANSPORT; ASSOCIATIONS;
   INTEGRATION; IMPACTS; TRAVEL},
