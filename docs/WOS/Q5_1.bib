@article{ WOS:001582570200001,
Author = {Ma, Ruochen and Xu, Yunchen and Tang, Yan and Zhang, Sihan and Liao,
   Yuhui and Furuya, Katsunori},
Title = {Development of a data-driven spatial framework for optimizing vertical
   greening in high-density Tokyo},
Journal = {SUSTAINABLE CITIES AND SOCIETY},
Year = {2025},
Volume = {132},
Month = {SEP 15},
Abstract = {Vertical greening systems (VGS) can expand urban greenery where ground
   space is scarce, yet citywide assessments of spatial need remain
   limited. We develop a data-driven framework to evaluate how current VGS
   provision aligns with demand across Tokyo's 23 wards. From 88,750
   street-view images, a YOLOv8 model mapped 7205 VGS and distinguished
   green fa \& ccedil;ades from living walls. Ordinary least squares and
   geographically weighted regression assessed correspondence with four
   indicator groups, and a vertical greening demand index (VGDI) with
   hybrid analytic hierarchy process (AHP) and Entropy weights translated
   these relations into priority zones. Results show clustered, uneven
   distributions; the clearest correspondence with land use indicators; and
   spatially varying mismatches for other groups, highlighting
   supply-demand gaps and actionable targets for policy. The originality of
   this study lies in linking fa \& ccedil;ade-scale YOLOv8 detection with
   GWR and a hybrid demand index at city scale, thereby operationalizing
   supply-demand alignment and offering a transferable approach for compact
   cities.},
Type = {Article},
Affiliation = {Furuya, K (Corresponding Author), Chiba Univ, Grad Sch Hort, Matsudo, Chiba 2718510, Japan.
   Ma, Ruochen; Xu, Yunchen; Tang, Yan; Zhang, Sihan; Liao, Yuhui; Furuya, Katsunori, Chiba Univ, Grad Sch Hort, Matsudo, Chiba 2718510, Japan.},
DOI = {10.1016/j.scs.2025.106798},
EarlyAccessDate = {SEP 2025},
Article-Number = {106798},
Keywords = {Vertical greening systems; Urban green infrastructure; Spatial demand
   assessment; Street view imagery; Deep learning; Object detection},
Keywords-Plus = {GREENERY SYSTEMS; THERMAL PERFORMANCE; INFRASTRUCTURE; VEGETATION;
   BUILDINGS; FACADES; TEMPERATURE; SIMULATION; IMPACT; WALLS},
Author-Email = {k.furuya@faculty.chiba-u.jp},
Number-of-Cited-References = {126},
