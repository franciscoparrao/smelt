@incollection{ WOS:001578294100016,
Author = {Middleton, G. D. and Di, Liping},
Book-Group-Author = {IEEE},
Title = {Accelerating Agro-Geoinformatics ML with GeoParquet},
Booktitle = {2025 13TH INTERNATIONAL CONFERENCE ON AGRO-GEOINFORMATICS,
   AGRO-GEOINFORMATICS},
Series = {International Conference on Agro-Geoinformatics},
Year = {2025},
Pages = {82-86},
Abstract = {GeoParquet, introduced by the Open Geospatial Consortium in 2022,
   extends Apache Parquet's columnar architecture with native geometry and
   coordinate reference system support, offering a modern alternative to
   legacy spatial tabular formats. This study benchmarks GeoParquet against
   CSV, JSON, GeoJSON, and GeoPackage for land cover classification using
   Sentinel-2 imagery and ESA WorldCover labels, evaluated at city and
   state scales in New Hampshire. Support Vector Machine, Random Forest,
   and XGBoost models were trained and validated under identical workflows,
   with processing metrics collected for file I/O, model fitting, and
   prediction. Across all models and scales, GeoParquet achieved the
   smallest file sizes (75-90 \% reductions), fastest read/write speeds (up
   to 130x faster reads and 100x faster writes than GeoJSON), and lowest
   total runtimes, with efficiency gains increasing with dataset size and
   model complexity. At the state scale, total runtimes were up to 21.2x
   faster than GeoJSON and 10.6x faster than CSV. Results demonstrate that
   GeoParquet eliminates many I/O bottlenecks inherent to older formats,
   improving scalability and computational performance in spatial machine
   learning workflows. These findings support adoption of GeoParquet as a
   preferred storage format for large-scale geographic data science.},
Type = {Proceedings Paper},
Affiliation = {Middleton, GD (Corresponding Author), George Mason Univ, Geog \& Geoinformat Sci, Fairfax, VA 22030 USA.
   Middleton, G. D.; Di, Liping, George Mason Univ, Geog \& Geoinformat Sci, Fairfax, VA 22030 USA.},
DOI = {10.1109/Agro-Geoinformatics66479.2025.11136321},
Keywords = {GeoParquet; spatial machine learning; file format benchmarking; land
   cover classification},
Author-Email = {gmiddle@gmu.edu
   ldi@gmu.edu},
Number-of-Cited-References = {28},
Times-Cited = {0},
Unique-ID = {WOS:001578294100016},
}

@article{ WOS:001567061200010,
Author = {Wang, Xu and Xu, Hang and Han, Fuli and Fang, Xiaonan and Zhou, Zhen and
   Zhou, Jianwei and Yang, Xianhua},
Title = {Estimating Reclaimed Grass Aboveground Biomass of Reclaimed Mining Area
   Across Spatial and Temporal Scales With Sentinel-1 and Sentinel-2 Data},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2025},
Volume = {63},
Abstract = {Mining activities destroy vegetation and soil systems, posing a serious
   threat to ecological security. Reclamation is considered to be an
   effective and sustainable strategy for improving postmining ecological
   quality and ecosystem function. Monitoring aboveground biomass (AGB) in
   reclaimed mining areas is crucial for assessing and managing
   reclamation. The combination of remote sensing and machine learning
   algorithms is widely used for regional-scale AGB estimation. However,
   the feasibility of this approach for assessing AGB in reclaimed mine
   sites still remains poorly understood. In this study, we employed a
   variety of data sources (Sentinel-1, Sentinel-2, and their combinations)
   and coupled them with diverse regression algorithms (including the
   linear model, LMR; support vector regression (SVR); random forest, RF;
   and cubist, CB) to estimate herbaceous AGB in typical reclaimed mining
   areas of Sichuan Province, China. Moreover, we evaluated the
   temporal-spatial generalizability of the model by training and
   validating it across distinct geographic regions and time periods. The
   results showed that 1) with regard to the aspects of model accuracy and
   stability, the SVR model employing the combination of MSI and SAR data
   is a superior approach for estimating the AGB of reclaimed mines at the
   Sentinel scale (RMSE = 90.367 g/m(2), R-2 =0.597 , and mean absolute
   error (MAE) = 59.721 g/m(2)). The most informative SAR metric for
   estimating AGB is VV. The spectral information from the visible (VIS),
   red-edge, and shortwave infrared (SWIR) regions is of considerable
   importance, with significant contributions from both water and
   soil-adjusted indices. 3) Integration of Sentinel optical and SAR
   datasets helps to improve AGB estimation for reclaimed mining area
   grass. 4) The models demonstrated suboptimal performance in temporal and
   spatial cross-validation (CV), exhibiting limited temporal-spatial
   generalizability. The proposed framework in this study has great
   potential to generate robust grass AGB for reclaimed mining areas across
   regions and time scales. In addition, it provides valuable insights for
   dynamically guiding the recovery and monitoring of restored ecosystems.},
Type = {Article},
Affiliation = {Wang, X (Corresponding Author), China Univ Geosci Wuhan, Sch Geog \& Informat Engn, Wuhan 430074, Peoples R China.
   Wang, Xu; Xu, Hang; Han, Fuli; Fang, Xiaonan; Zhou, Zhen, China Univ Geosci Wuhan, Sch Geog \& Informat Engn, Wuhan 430074, Peoples R China.
   Zhou, Jianwei, China Univ Geosci, Sch Environm Studies, Wuhan 430074, Peoples R China.
