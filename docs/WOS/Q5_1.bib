@article{ WOS:001248562800001,
Author = {Ma, Jiamin and Shi, Pu},
Title = {Remotely sensed inter-field variation in soil organic carbon content as
   influenced by the cumulative effect of conservation tillage in northeast
   China},
Journal = {SOIL \& TILLAGE RESEARCH},
Year = {2024},
Volume = {243},
Month = {NOV},
Abstract = {Conservation tillage is among the most widely adopted sustainable
   cropland management practices to enhance soil organic carbon (SOC)
   storage. The overall positive effect of conservation tillage on SOC
   sequestration has been well-documented through paired-plot field trials,
   but limited knowledge is available on the spatial heterogeneity of their
   relationship. To address this issue, effective mapping tools are needed
   to capture the fieldspecific patterns of SOC and tillage practice. Here,
   we developed an integrated remote sensing approach whereby the
   spatiotemporal evolution of tillage practice through 2017-2021 and the
   field-specific SOC pattern in 2021 were individually mapped in an
   agricultural region (7000 km2) of northeast China. Topsoil sampling was
   conducted in 287 georeferenced fields for SOC measurement and the
   tillage practice was also surveyed in 257 fields. Sentinel-2 bare soil
   spectra, together with SOC-related spectral indices, were used to
   establish a random forest (RF) model for parcel-based SOC mapping. The
   shortwave infrared angle (SWIRA) index, sensitive to varying crop
   residue cover but robust to soil moisture disturbance, was used as a
   proxy to quantify the expansion of conservation tillage over time.
   Results show that the spectra-based RF model yielded accurate SOC
   prediction (R2: 0.81; RMSE: 1.72 g/kg) and the resulting map
   demonstrated clear inter-field variations. The SWIRA index was found
   effective in revealing a drastic increase in the number of conservation
   tillage fields during the investigation period. Summing the temporal
   maps of SWIRA, SWIRAsum was indeed a significant factor controlling the
   SOC variation at the regional scale. Partial dependence analysis further
   showed an increasing marginal effect of cumulative conservation tillage
   on SOC. From the spatial perspective, geographically weighted regression
   analysis identified the hotspots where SWIRAsum was most influential.
   Closer inspection into the hotspots indicated that areas with low SOC
   levels reacted more strongly to increasing SWIRAsum. This study provided
   a methodological framework for the concurrent mapping of SOC and tillage
   practice through optical remote sensing, thus facilitating a spatially
   explicit understanding of how SOC storage could be enhanced.},
Type = {Article},
Affiliation = {Shi, P (Corresponding Author), Coll Earth Sci, Changchun 130061, Peoples R China.
   Ma, Jiamin; Shi, Pu, Jilin Univ, Coll Earth Sci, Changchun 130061, Peoples R China.
   Ma, Jiamin; Shi, Pu, UCLouvain, Earth \& Life Inst, B-1348 Louvain La Neuve, Belgium.
   Shi, Pu, Coll Earth Sci, Changchun 130061, Peoples R China.},
DOI = {10.1016/j.still.2024.106170},
EarlyAccessDate = {MAY 2024},
Article-Number = {106170},
Keywords = {Soil organic carbon mapping; Conservation tillage; Sentinel-2; Bare soil
   imaging; Crop residue cover; Spatial heterogeneity},
Keywords-Plus = {CROP RESIDUE; EROSION; REGION; COVER; INDEX},
Author-Email = {shipu@jlu.edu.cn},
Number-of-Cited-References = {65},
Times-Cited = {14},
Unique-ID = {WOS:001248562800001},
}

@article{ WOS:001220257900001,
Author = {He, Huanhuan and Wang, Jinjie and Ding, Jianli and Wang, Lei},
Title = {Spatial Downscaling of Precipitation Data in Arid Regions Based on the
   XGBoost-MGWR Model: A Case Study of the Turpan-Hami Region},
Journal = {LAND},
Year = {2024},
Volume = {13},
Number = {4},
Month = {APR},
Abstract = {Accurate and reliable precipitation data are important for analyzing
   regional precipitation distribution, water resource management, and
   ecological environment construction. Due to the scarcity of
   meteorological stations in the Turpan-Hami region, precipitation
   observation conditions are limited, and it is difficult to obtain
   precipitation data. Firstly, the applicability of TRMM 3B43v7,
   GPM\_3IMERGM 06, and CMORPH CDR satellite precipitation data for the
   Turpan-Hami Region was evaluated, and the products with better
   applicability were selected. Next, the Extreme Gradient Boosting
   Algorithm (XGBoost) and the Shapley Additive Explanations for Machine
   Learning (SHAP) model were combined to carry out a feature importance
   analysis on the climate factors affecting precipitation (mean
   temperature, actual evapotranspiration, wind speed, cloud cover), from
   which climate factors with a greater influence on precipitation were
   selected. Combined with climate factors, normalized difference
   vegetation index (NDVI), slope, aspect, and elevation as explanatory
   variables, a Multi-Scale Geographically Weighted Regression (MGWR) model
   was constructed to obtain the monthly precipitation data of 1 km spatial
   resolution in the Turpan-Hami area from 2001 to 2020. Finally, the
   spatiotemporal distribution characteristics and changing trend of
   precipitation in the Turpan-Hami region from 2001 to 2020 were analyzed.
   The results show that (1) GPM\_3IMERGM 06 satellite precipitation data
   exhibits good applicability in the Turpan-Hami region. (2) The precision
   verification of the downscaling results from a monthly scale and an
   annual scale shows that the accuracy and spatial resolution of the data
   are improved after downscaling. (3) From 2001 to 2020, the precipitation
   in the Turpan-Hami region showed an insignificantly increasing trend.},
Type = {Article},
Affiliation = {Ding, JL (Corresponding Author), Xinjiang Univ, Coll Geog \& Remote Sensing Sci, Urumqi 830017, Peoples R China.
   Ding, JL (Corresponding Author), Xinjiang Univ, Xinjiang Key Lab Oasis Ecol, Urumqi 830017, Peoples R China.
