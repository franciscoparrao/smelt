   Effati, Meysam; Arabani, Mahyar, Univ Guilan, Fac Engn, Room 314,Second Floor,5th Kilometer Persian Gulf H, Rasht 4199613776, Guilan, Iran.},
DOI = {10.1016/j.rineng.2024.103344},
EarlyAccessDate = {NOV 2024},
Article-Number = {103344},
Keywords = {Horizontal curve; Injury severity; Machine learning; Mountainous area;
   Road safety; Rural roads; Spatial analysis},
Keywords-Plus = {RELIABILITY-BASED DESIGN; INJURY SEVERITY; VEHICLE CRASHES; SAFETY;
