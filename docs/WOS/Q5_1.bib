   Yuan, Jiaxin; Wang, Xuhong; Feng, Zihao; Zhang, Ying; Yu, Mengqianxi, Northwest Univ, Shaanxi Xian Urban Forest Ecosyst Res Stn, Xian 710127, Peoples R China.},
DOI = {10.3390/rs15184613},
Article-Number = {4613},
