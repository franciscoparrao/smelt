   Shang, Kun, MNR, Land Satellite Remote Sensing Applicat Ctr, 1 Baisheng Village, Beijing 100048, Peoples R China.},
DOI = {10.1016/j.still.2025.106815},
EarlyAccessDate = {AUG 2025},
Article-Number = {106815},
Keywords = {Soil organic matter; Hyperspectral satellite image; Soil moisture
   correction; Sample expansion; Improved OSC algorithm},
Keywords-Plus = {MONITORING SOIL; BLACK SOIL; MOISTURE; CARBON; MACHINE; REGION; INDEX},
