@article{ WOS:001648532400019,
Author = {Jeon, Dasom and Ryu, Jae-Hyun and Lee, Soo-Jin and Lee, Kyung-do},
Title = {Modeling Yield Variability in Baromi2 Rice Using Sentinel-2-Derived
   Phenology and Environmental Drivers},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {212838-212855},
Abstract = {Understanding how phenological, soil, and topographic factors interact
   to shape rice yield is essential in reclaimed paddy soils. We built an
   interpretable modeling framework that combines Sentinel-2 NDVI-based
   phenological metrics with soil, topographic, and phenology-aligned
   meteorological variables to describe yield variability of the floury
   rice cultivar Baromi2 across ten regions in South Korea. Fifteen
   phenology indicators were derived from Savitzky-Golay-smoothed NDVI
   trajectories, while 52 environmental variables were screened
   sequentially through Variance Inflation Factor (VIF < 5), Recursive
   Feature Elimination (RFE), and Permutation Importance (PI) before Random
   Forest regression to ensure transparency and control multicollinearity.
   In the phenology-only model, late-season greenness (OffsetV) explained
   about 62 \% of yield variation (R- 2=0.623 ). The environment-only model
   showed that soil Mg concentration and Altitude were the strongest
   drivers (R- 2=0.620 ). Combining all predictors improved accuracy
   slightly (R 2=0.648 ; Delta R-2 approximate to 0.025 ) and removed
   spatial autocorrelation, suggesting that phenology chiefly mediates soil
   and terrain effects rather than adding large independent power. Partial
   dependence analysis indicated that Mg > 2 mg/kg lowered yield by roughly
   10-12\%, whereas moderate Altitude (0-10 m) raised it by approximate to
   6 \%. This harmonized VIF-RFE-PI workflow follows explainable-AI
   principles and shows that, under irrigated and climatically steady
   conditions, phenology and soil variables provide more consistent yield
   signals than weather aggregates. The framework supports
   precision-agriculture applications and can be adapted across years and
   cultivars to advance sustainable rice-yield management.},
Type = {Article},
Affiliation = {Jeon, D; Lee, KD (Corresponding Author), Natl Agr Satellite Ctr, Rural Dev Adm, Natl Inst Agr Sci, Jeonju 54875, South Korea.
   Jeon, Dasom; Ryu, Jae-Hyun; Lee, Soo-Jin; Lee, Kyung-do, Natl Agr Satellite Ctr, Rural Dev Adm, Natl Inst Agr Sci, Jeonju 54875, South Korea.},
DOI = {10.1109/ACCESS.2025.3640184},
Keywords = {Phenology; Soil; Crops; Normalized difference vegetation index; Timing;
   Precipitation; Data mining; Satellites; Reflectivity; Green products;
   Baromi2; environmental drivers; phenology traits; precision agriculture;
   random forest; rice yield prediction; Sentinel-2 NDVI time-series},
Keywords-Plus = {NDVI TIME-SERIES; CROP PHENOLOGY; GRAIN-YIELD; SOLAR-RADIATION; WHEAT
   YIELD; MODIS NDVI; LEAF-AREA; QUALITY; TEMPERATURE; SENESCENCE},
Author-Email = {ds4418@korea.kr
   kdlee11@korea.kr},
