   Wang, Shaohua, Aerosp Informat Res Inst, Chinese Acad Sci, Key Lab Remote Sensing \& Digital Earth, Beijing, Peoples R China.},
DOI = {10.1080/10095020.2026.2616557},
EarlyAccessDate = {FEB 2026},
Keywords = {Urban vitality; street view images; block scale; urban perception;
   spatial modeling},
