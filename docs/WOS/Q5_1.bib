   Chen, Michael K. T., Cent Policy Univ, Dept Transportat, Taoyuan, Taiwan.
   Hsu, Tien-Pen, Natl Taiwan Univ, Dept Civil Engn, Taipei, Taiwan.},
DOI = {10.1080/23249935.2024.2437477},
