Keywords-Plus = {LANDSAT TIME-SERIES; AIRBORNE LIDAR; RANDOM FOREST; SURFACE REFLECTANCE;
   ETM PLUS; COVER; INDEX; IMAGERY; REGRESSION; SAMPLES},
