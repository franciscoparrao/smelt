   Soltani, Ali; Aghaei, Fatemeh, Shiraz Univ, Dept Urban Planning, Shiraz, Iran.
   Pettit, Christopher James, Univ New South Wales, City Futures Res Ctr, Sydney 2052, Australia.},
DOI = {10.1016/j.cities.2022.103941},
EarlyAccessDate = {AUG 2022},
