   Wu, Yarui, Xian Univ Sci \& Technol, Coll Geomatics, Xian 710054, Peoples R China.
   Wang, Lei, Tianjin Univ, Sch Architecture, Tianjin 300072, Peoples R China.},
DOI = {10.3390/buildings15203721},
