   Kwan, Mei-Po, Univ Utrecht, Fac Geosci, Dept Human Geog \& Spatial Planning, POB 80125, NL-3508 TC Utrecht, Netherlands.},
DOI = {10.3390/su9050819},
Article-Number = {819},
Keywords = {fire risk; Random Forest; spatial econometric models; autocorrelation;
