@article{ WOS:001578209300001,
Author = {Gu, Tianshun and Zhao, Hongbo and Yue, Li and Liu, Yangyang and Guo,
   Jiaojiao and Tang, Junqing and Zhao, Pengjun},
Title = {Spatial heterogeneity of urban resilience: Quantifying key determinants
   by spatial machine learning model embedded in density-structure-function
   framework},
Journal = {CITIES},
Year = {2025},
Volume = {167},
Month = {DEC},
Abstract = {With rapid urbanization and escalating climate risks, enhancing urban
   resilience has become increasingly critical for improving the adaptive
   capacity of urban systems. However, understanding the nonlinear and
   spatial heterogeneity relationships between urban function, density,
   structure, and urban resilience remains a significant challenge. Here,
   we developed an enhanced Grey Relation Analysis-TOPSIS method integrated
   with the Random Forest (RF) algorithm (RF-GRA-TOPSIS) to evaluate urban
   resilience. Additionally, a ``Density-Structure-Function (D-S-F){''}
   analysis framework was constructed based on urban functional space and
   landscape ecology theory. The Geographically weighted Random Forest
   (GWRF) model was further employed to identify the key factors
   influencing urban resilience, effectively accounting for nonlinearity
   and spatial heterogeneity. We validated the proposed methodology and
   framework using multi-source data at the urban block scale in Zhengzhou
   City, China. The findings show that: (1) From 2005 to 2020, Zhengzhou's
   urban resilience increased by 4.5 \%, while spatial disparities declined
   by 17.1 \%, forming a distinct core-periphery pattern. (2)
   Transportation, healthcare, and government services were identified as
   the dominant factors influencing urban resilience, with population
   density and vegetation coverage also contributing significantly. (3)
   These factors exhibited significant nonlinear and spatially varying
   effects, with pronounced impacts (\%IncMSE) observed in Zhengzhou's
   central districts. (4) The GWRF model outperformed traditional
   models-including Ordinary Least Squares, Spatial Regression Tree,
   Geographically Weighted Regression, and RF-by enhancing explanatory
   power (R2) by 3-16 \%. Overall, urban resilience is determined by the
   integrated effects of density, structure, and function, with urban
   function exerting the predominant influence. This study provides
   actionable insights for disaster risk management and the development of
   resilient cities in rapidly urbanizing regions globally.},
Type = {Article},
Affiliation = {Zhao, HB (Corresponding Author), Henan Univ, Key Res Inst Yellow River Civilizat \& Sustainable, Kaifeng 475001, Peoples R China.
   Zhao, HB (Corresponding Author), Henan Univ, Collaborat Innovat Ctr Yellow River Civilizat, Henan Prov \& Minist Educ, Kaifeng 475001, Peoples R China.
