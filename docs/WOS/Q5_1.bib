Keywords = {House price appreciation rate; Street view images; House photos; Human
   mobility patterns; Geographically weighted regression},
Keywords-Plus = {STREET VIEW; NEIGHBORHOODS; IMAGERY; MARKET},
Author-Email = {zhangfan@mit.edu},
Number-of-Cited-References = {42},
Times-Cited = {154},
