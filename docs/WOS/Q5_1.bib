   Shrestha, Poojan; Divaris, Kimon, Univ North Carolina Chapel Hill, Gillings Sch Global Publ Hlth, Dept Epidemiol, Chapel Hill, NC USA.},
DOI = {10.1214/21-AOAS1516},
Keywords = {Missing values; spatial interpolation; clustering; multiple imputation;
   random forest},
Keywords-Plus = {ORAL-HEALTH; INTERPOLATION},
Author-Email = {yugu@live.unc.edu
   jpreisse@bios.unc.edu
