   Zhang, Yi; Zhai, Siwei; Huang, Jingfei; Li, Xuelin; Wang, Wei; Yin, Fei; Ma, Yue, Sichuan Univ, West China Hosp 4, Chengdu, Sichuan, Peoples R China.
   Zhang, Tao; Ma, Yue, Sichuan Univ, Inst Syst Epidemiol, West China Sch Publ Hlth, Chengdu, Peoples R China.
   Zhang, Tao; Ma, Yue, Sichuan Univ, West China Hosp 4, Chengdu, Peoples R China.},
DOI = {10.1016/j.jclepro.2022.134890},
EarlyAccessDate = {NOV 2022},
