@incollection{ WOS:001661285300122,
Author = {Li, Yiting},
Editor = {Zhang, G and Lin, Z and Chen, C and Liu, J and Ou, S and Yan, Q},
Title = {Exploring the Impact of the Built Environment on Traffic Accidents Using
   a Multi-Scale Geographically Weighted Random Forest Model},
Booktitle = {CICTP 2025: TRANSPORTATION, ARTIFICIAL INTELLIGENCE, AND ENERGY},
Year = {2025},
Pages = {1288-1297},
Abstract = {Exploring the potential impacts of built environment factors on traffic
   accidents is crucial for rational and coordinated urban planning, as
   well as for enhancing traffic safety. Previous studies have typically
   analyzed the spatial variability and non-linearity of the built
   environment's impact on traffic accidents separately, often overlooking
   the benefits of integrating these two aspects. To address this gap, this
   paper develops an innovative Multi-Scale Geographically Weighted Random
   Forest model. Initially, this study refined the built environment
   indicators, applied the MGWR model to calculate regression coefficients
   for traffic accident rate, and visually analyzed the spatial variability
   of these impacts. Subsequently, these coefficients were incorporated
   into the RF model to train and predict the non-linear impacts on the
   traffic accident rate. Finally, the importance of each built environment
   explanatory variable was ranked to guide traffic planning and safety
   management.},
Type = {Proceedings Paper},
Affiliation = {Li, YT (Corresponding Author), Changan Univ, Sch Transportat Engn, Xian, Peoples R China.
   Li, Yiting, Changan Univ, Sch Transportat Engn, Xian, Peoples R China.},
Keywords-Plus = {CRASH FREQUENCY},
Author-Email = {13298760454@163.com},
Number-of-Cited-References = {15},
Times-Cited = {0},
Unique-ID = {WOS:001661285300122},
}

@incollection{ WOS:001661285300272,
Author = {Luo, Wei and Zhang, Huixin and Wang, Jianyu and Zhu, Zimo and Yang, Anan},
Editor = {Zhang, G and Lin, Z and Chen, C and Liu, J and Ou, S and Yan, Q},
Title = {Nonlinear Impact of Built Environment on Urban Metro Ridership Flow
   Based on Explainable Machine Learning},
Booktitle = {CICTP 2025: TRANSPORTATION, ARTIFICIAL INTELLIGENCE, AND ENERGY},
Year = {2025},
Pages = {2856-2865},
Abstract = {Urban metro ridership is strongly impacted by the built environment, but
   traditional linear models often miss its nonlinear effects. This paper
   explores the nonlinear impact of the built environment on ridership from
   three perspectives: land use, transportation, and station attributes.
   The proposed eXtreme Gradient Boosting (XGBoost) model, combined with
   the SHapley Additive exPlanation (SHAP) framework, quantifies the
   influence and importance of various built environment factors, capturing
   their nonlinear relationship with metro ridership. An empirical study of
   Beijing's metro ridership shows that XGBoost outperforms Ordinary Least
   Squares (OLS), Geographically Weighted Regression (GWR), Time-Weighted
   Regression (TWR), and Geographical and Temporal Weighted Regression
   (GTWR) models in accuracy. Results indicate that built environment
   characteristics have a nonlinear influence on urban rail transit
   ridership, and by considering land use, transportation features, and
   station attributes, metro travel convenience and comfort can be
   enhanced, aiding scientifically guided metro planning.},
Type = {Proceedings Paper},
Affiliation = {Wang, JY (Corresponding Author), Beijing Univ Civil Engn \& Architecture, Beijing Key Lab Gen Aviat Technol, Beijing, Peoples R China.
   Luo, Wei; Zhang, Huixin; Wang, Jianyu; Zhu, Zimo, Beijing Univ Civil Engn \& Architecture, Beijing Key Lab Gen Aviat Technol, Beijing, Peoples R China.
