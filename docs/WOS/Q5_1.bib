   Csamer, Arpad, Univ Debrecen, Cosmochem \& Cosm Methods Res Grp, H-4032 Debrecen, Hungary.},
DOI = {10.1016/j.ejrs.2024.07.003},
EarlyAccessDate = {JUL 2024},
Keywords = {PRISMA; Landsat 9; Random forest; Geological mapping},
