@article{ WOS:001677972500001,
Author = {Gandhi, Fenil},
Title = {Interpretable machine learning for daily precipitation forecasting:
   spatiotemporal dynamics and extreme event prediction in New Jersey},
Journal = {HYDROLOGICAL SCIENCES JOURNAL},
Year = {2026},
Month = {2026 FEB 2},
Abstract = {Accurate daily precipitation forecasting is essential for operational
   hydrology. This study evaluates six machine learning (ML) models for
   1-day-ahead precipitation forecasting across 31 diverse stations in New
   Jersey (NJ), USA, using an integrated meteorological, remote sensing,
   and topographic dataset. Model performance was assessed for both general
   and 95th percentile extreme events. Ensemble models (random forest and
   XGBoost) consistently outperform other methods, particularly for
   high-impact extremes. Explainable AI (XAI) techniques, specifically
   SHAP, were used to interpret the models, revealing antecedent moisture
   conditions as dominant predictors. Crucially, the analysis demonstrates
   predictor importance is significantly modulated by land use/land cover
   (LULC), with urban areas showing heightened sensitivity to recent
   rainfall, reflecting the altered hydrological response of impervious
   catchments. Spatiotemporal analyses confirm predictive drivers are
   geographically structured. This research validates interpretable ML as a
   tool to improve forecast skill and enhance scientific understanding of
   heterogeneous hydrological processes.},
Type = {Article; Early Access},
Affiliation = {Gandhi, F (Corresponding Author), Sardar Vallabhbhai Natl Inst Technol, Dept Civil Engn, Surat, India.
   Gandhi, Fenil, Sardar Vallabhbhai Natl Inst Technol, Dept Civil Engn, Surat, India.},
DOI = {10.1080/02626667.2025.2609895},
EarlyAccessDate = {FEB 2026},
Keywords = {XGBoost; random forest; hydrological forecasting; SHAP; spatial
   autocorrelation (LISA); extreme events},
Keywords-Plus = {WEATHER},
Author-Email = {fenilgandhi15@gmail.com},
Number-of-Cited-References = {46},
