@article{ WOS:001708302500018,
Author = {Saravanakumar, R. and Jain, Rajni and Singh, Vaibhav Kumar and
   Bharadwaj, Anshu and Sehgal, Vinay Kumar and Biswas, Ankur and Arora,
   Alka and Krishna, Hari},
Title = {Hybridizing deep learning algorithms and geostatistical approaches for
   improved crop yield disaggregation},
Journal = {PLOS ONE},
Year = {2026},
Volume = {21},
Number = {3},
Month = {MAR 6},
Abstract = {Reliable crop yield estimates at fine spatial resolution are essential
   for precision agriculture, food security planning, and insurance
   schemes. However, yield statistics are reported at coarser
   administrative levels, limiting their applicability for field-scale
   analysis. This study proposes a multi-stage hybridized framework that
   integrates deep learning (DL) models with geostatistical residual
   kriging to disaggregate village-level crop yield statistics to the pixel
   level. The proposed methodology is demonstrated using wheat and mustard
   crops as case study in the semi-arid districts, Haryana, India. The
   study identifies suitable data combination by evaluating multiple
   combinations of soil, weather, Sentinel-1, and Sentinel-2 bands data for
   yield disaggregation. Results show that datasets combining spectral and
   weather information consistently outperform other data combinations.
   Validation results showed that the strongest numerical accuracy was
   observed for machine learning algorithms, e.g., random forest, with an
   R2 of 0.9949, but it lacks spatial realism. On the other hand, DL models
   had comparable numerical accuracy and also produced smoother and more
   realistic spatial transitions but exhibited spatially structured
   residuals. To mitigate these spatial biases, residual kriging was
   applied to DL outputs, resulting in RMSE reduction of 35-45\% and
   generating smoother pixel-level maps that preserved fine-scale
   heterogeneity and aligned with reported village yields. Moran's I
   analysis confirmed significant residual spatial autocorrelation for DL
   models, justifying the use of geostatistical correction. Thus, the
   proposed hybridized framework emerged as best for balancing statistical
   accuracy with spatially realistic yield disaggregation. This study
   provides one of the first empirical demonstrations of village-to-pixel
   yield disaggregation using the identified weather and satellite band
   data combination.},
Type = {Article},
Affiliation = {Singh, VK (Corresponding Author), ICAR Indian Agr Res Inst, New Delhi, India.
   Jain, R (Corresponding Author), ICAR Natl Inst Agr Econ \& Policy Res, New Delhi, India.
   Saravanakumar, R.; Singh, Vaibhav Kumar; Sehgal, Vinay Kumar; Krishna, Hari, ICAR Indian Agr Res Inst, New Delhi, India.
   Saravanakumar, R.; Bharadwaj, Anshu; Biswas, Ankur; Arora, Alka, ICAR Indian Agr Stat Res Inst, New Delhi, India.
   Jain, Rajni, ICAR Natl Inst Agr Econ \& Policy Res, New Delhi, India.},
DOI = {10.1371/journal.pone.0344081},
Article-Number = {e0344081},
Keywords-Plus = {SUSTAINABLE INTENSIFICATION; RIDGE-REGRESSION; AGRICULTURE; PREDICTION;
   SHRINKAGE},
Author-Email = {Rajni.jain@icar.org.in
   dr.singhvaibhav@gmail.com},
Number-of-Cited-References = {65},
Times-Cited = {0},
Unique-ID = {WOS:001708302500018},
}

@article{ WOS:001705655200001,
Author = {Goumrasa, Abdeldjalil and Matougui, Zakaria and Belaroui, Abdelhakim and
   Akziz, Djamal and Guettouche, Mohamed Said},
Title = {An integrated approach leveraging remote sensing, geospatial analysis,
   and machine learning algorithms for high-resolution wildfire
   susceptibility assessment and identification of environmental drivers in
   El Tarf Province, Algeria},
Journal = {ENVIRONMENTAL MONITORING AND ASSESSMENT},
Year = {2026},
Volume = {198},
Number = {3},
Month = {MAR 4},
Abstract = {The growing frequency and extent of wildfires constitute a significant
   environmental challenge, posing serious threats to ecosystems,
   biodiversity, and human livelihoods. This study presents a comprehensive
   wildfire susceptibility assessment for El Tarf Province, one of the most
   fire-prone yet understudied regions in Algeria. Long-term Landsat
   imagery (1995-2024) combined with four machine learning algorithms was
   used to produce high-resolution susceptibility maps and identify the key
   environmental and bioclimatic drivers of wildfire occurrence. Ten
   conditioning factors representing topographic, vegetative, edaphic, and
   climatic conditions were integrated, with elevation, Enhanced Vegetation
   Index (EVI), wind speed, and precipitation emerging as dominant
   predictors. Among the tested models, Random Forest achieved the highest
   predictive performance (ROC-AUC = 0.897), closely followed by XGBoost
   (0.896), while LightGBM provided an optimal balance between accuracy
   (0.875) and computational efficiency. Logistic Regression, though
   simpler, performed reasonably well (0.794). The Landsat-derived wildfire
   inventory comprised approximately 622,221 burned pixels and was
   subsequently split into a pre-2017 training set (72.8\%) and a post-2017
   testing set (27.2\%) to evaluate model generalization over time. Spatial
   block cross-validation was applied to reduce spatial autocorrelation and
   enhance model generalization. This methodological framework, combining
   spatial and temporal validation, temporal hold-out, and spatial
   blocking, strengthens the robustness and reliability of wildfire
   susceptibility modeling. Interpretability analyses based on SHAP values,
   Gini importance, and permutation importance identified the contributions
   of underexplored variables, including vegetation type, soil type, and
   soil organic carbon (SOC). The resulting susceptibility maps provide
   valuable insights for spatial planning and ecosystem management,
   supporting evidence-based strategies to enhance environmental resilience
   and biodiversity conservation in Mediterranean landscapes.},
Type = {Article},
Affiliation = {Goumrasa, A (Corresponding Author), USTHB, Lab Geomorphol \& Geohazard G\&G, FSTGAT, Algiers, Algeria.
   Goumrasa, Abdeldjalil; Akziz, Djamal; Guettouche, Mohamed Said, USTHB, Lab Geomorphol \& Geohazard G\&G, FSTGAT, Algiers, Algeria.
   Matougui, Zakaria, Ctr Rech Amenagement Terr CRAT, Campus Zouaghi Slimane,Route Ain El Bey, Constantine, Algeria.
   Belaroui, Abdelhakim, USTHB, Lab Geoenvironm, FSTGAT, Algiers, Algeria.},
DOI = {10.1007/s10661-026-15080-z},
Article-Number = {275},
Keywords = {Wildfire susceptibility; Landsat-based inventory; Machine learning;
   Spatial-temporal validation; SHAP analysis; Permutation importance; El
   Tarf Province, Algeria},
Keywords-Plus = {SPATIAL VARIABILITY; FOREST-FIRE; INFORMATION},
Author-Email = {djalilgoumrassa@gmail.com
   z.matougui@gmail.com
   belarouiabdelhakim@gmail.com
   djamalakziz@gmail.com
   msguettouche61@gmail.com},
Number-of-Cited-References = {91},
Times-Cited = {0},
Unique-ID = {WOS:001705655200001},
}

@article{ WOS:001686682900001,
Author = {Qin, Dingyi and Puttanapong, Nattapong},
Title = {Evaluating LJ1-01 nighttime light data for economic analysis at China's
   county level},
Journal = {REMOTE SENSING LETTERS},
Year = {2026},
Volume = {17},
Number = {3},
Pages = {324-335},
Month = {MAR 4},
Abstract = {This paper presents two contributions to the application of night-time
   light (NTL) data in socioeconomic research. Using 2018 data from 992
   Chinese counties, we first demonstrate that high-resolution LJ1-01
   imagery exhibits stronger correlations with ground data than the widely
   used Suomi National Polar-orbiting Partnership - Visible Infrared
   Imaging Radiometer Suite (NPP-VIIRS). Second, we show that LJ1-01
   consistently outperforms NPP-VIIRS in both Random Forest and
   Geographically Weighted Regression models, which capture nonlinear and
   spatially nonstationary relationships between NTL and socioeconomic
   activity. These findings distinguish LJ1-01 as a superior data source
   for fine-scale monitoring and provide methodological guidance for
   integrating remote sensing into economic analysis and policymaking},
Type = {Article},
Affiliation = {Puttanapong, N (Corresponding Author), Thammasat Univ, Fac Econ, Bangkok 10200, Thailand.
   Qin, Dingyi; Puttanapong, Nattapong, Thammasat Univ, Fac Econ, Bangkok 10200, Thailand.},
DOI = {10.1080/2150704X.2026.2629349},
Keywords = {Night-time Light; China},
Author-Email = {nattapong@econ.tu.ac.th},
Number-of-Cited-References = {18},
Times-Cited = {0},
Unique-ID = {WOS:001686682900001},
}

@article{ WOS:001706719900001,
Author = {Zhou, Lei and Li, Guanglu and Li, Han},
Title = {E-Commerce and Spatial Rebalancing of the Catering Industry in Zhuhai,
   China: a Pre- and Post-Pandemic Comparison},
Journal = {APPLIED SPATIAL ANALYSIS AND POLICY},
Year = {2026},
Volume = {19},
Number = {1},
Month = {MAR 4},
Abstract = {The rise of e-commerce and the gig economy, accelerated by COVID-19, has
   rapidly expanded online-to-offline (O2O) takeaway services and reshaped
   the spatial distribution of the catering industry in Chinese cities. To
   examine this process in China, we first analyzed the spatial evolution
   of the catering industry in Zhuhai before (2019) and after (2023) the
   pandemic using a hotspot detection model, with particular attention to
   differences between traditional restaurants and those adopting O2O
   takeaway services. We find that the traditional core-periphery spatial
   structure of the catering sector has been disrupted and has evolved into
   a more non-hierarchical pattern. O2O takeaway restaurants are more
   diffusely distributed and contribute to the decline of traditional
   restaurants, a transformation that has been further accelerated by the
   pandemic. Further analysis using random forest and multi-level
   geographically weighted regression models suggests that this
   transformation is primarily driven by behavioral changes among a growing
   segment of younger, better-educated, digitally proficient,
   higher-income, and time-constrained consumers, which aligns with the
   innovation diffusion hypothesis.},
Type = {Article},
Affiliation = {Li, H (Corresponding Author), Univ Miami, Dept Geog \& Sustainable Dev, Coral Gables, FL 33146 USA.
   Zhou, Lei; Li, Guanglu, Nanjing Univ Posts \& Telecommun, Sch Internet Things, Nanjing, Peoples R China.
   Li, Han, Univ Miami, Dept Geog \& Sustainable Dev, Coral Gables, FL 33146 USA.},
DOI = {10.1007/s12061-026-09839-7},
Article-Number = {61},
Keywords = {E-commerce; O2O takeaway catering; Innovation diffusion hypothesis;
   Efficiency hypothesis},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; ONLINE FOOD DELIVERY; RESTAURANTS;
   LOCATION; SERVICES; ADOPTION},
Author-Email = {zhoulei@njupt.edu.cn
   1023172910@njupt.edu.cn
   han.li@miami.edu},
Number-of-Cited-References = {66},
