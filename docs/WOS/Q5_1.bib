   Qin, Cheng-Zhi; Zhu, A-Xing, Jiangsu Ctr Collaborat Innovat Geog Informat Resou, Nanjing 210023, Peoples R China.
   Zhu, A-Xing, Nanjing Normal Univ, Sch Geog, Nanjing 210023, Jiangsu, Peoples R China.
   Zhu, A-Xing, Nanjing Normal Univ, Minist Educ, Key Lab Virtual Geog Environm, Nanjing 210023, Jiangsu, Peoples R China.
   Zhu, A-Xing, Univ Wisconsin Madison, Dept Geog, Madison, WI USA.},
DOI = {10.1016/j.geoderma.2023.116683},
EarlyAccessDate = {OCT 2023},
Article-Number = {116683},
Keywords = {Digital soil mapping; Environmental similarity; Large area; Individual
   Predictive Soil Mapping (iPSM); Inverse distance weight (IDW)},
Keywords-Plus = {GEOGRAPHICALLY WEIGHTED REGRESSION; PATTERNS; INTERPOLATION; PREDICTION;
   INFERENCE; SCIENCE},
Author-Email = {qincz@lreis.ac.cn},
