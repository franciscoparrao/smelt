   Kang, Yuhao; Zhang, Fan; Ratti, Carlo, MIT, Senseable City Lab, 77 Massachusetts Ave, Cambridge, MA 02139 USA.
   Peng, Wenzhe, MIT, Dept Architecture, 77 Massachusetts Ave, Cambridge, MA 02139 USA.},
DOI = {10.1016/j.cities.2021.103333},
EarlyAccessDate = {JUL 2021},
Article-Number = {103333},
Keywords = {Hedonic pricing model; Human dynamics; Human perception; Street-view
   images; Sense of place; GeoAI},
