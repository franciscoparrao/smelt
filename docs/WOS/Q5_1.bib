   Thill, Jean-Claude, Univ North Carolina, Sch Data Sci, 9201 Univ City Blvd, Charlotte, NC 28223 USA.},
DOI = {10.3390/ijgi10090600},
Article-Number = {600},
Keywords = {spatial machine learning; spatial dependence; spatial heterogeneity;
   scale; spatial observation matrix; learning algorithm; deep learning},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; AREAL UNIT PROBLEM; IMAGE TEXTURE; TRAFFIC
