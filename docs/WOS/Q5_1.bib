   Vermeulen, Roel, Univ Utrecht, Univ Med Ctr, Julius Ctr Hlth Sci \& Primary Care, Utrecht, Netherlands.},
DOI = {10.1016/j.envint.2022.107485},
EarlyAccessDate = {AUG 2022},
Article-Number = {107485},
Keywords = {Spatially varying coefficient; Spatiotemporal variation; Geographically
