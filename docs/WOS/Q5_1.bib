   Bayala, Jules, CIFOR ICRAF, Ctr Int Forestry Res CIFOR World Agroforestry ICR, Sahel 06,BP 9478, Ouagadougou 06, Burkina Faso.},
DOI = {10.1007/s10457-022-00791-2},
