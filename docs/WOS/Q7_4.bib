   Tasu, Jean Pierre; Cheze Le Rest, Catherine, Univ Poitiers, Med Sch, F-86000 Poitiers, France.
   Tasu, Jean Pierre, Univ Poitiers Hosp, Radiol Dept, F-86000 Poitiers, France.},
DOI = {10.3390/cancers14235931},
Article-Number = {5931},
