   Mao, Wenjie, Shantou Univ Med Coll, Yue Bei Peoples Hosp, Emergency Dept, Shaoguan, Peoples R China.},
DOI = {10.3389/fgene.2022.900380},
Article-Number = {900380},
Keywords = {hepatocellular carcinoma; proliferation; gene signature; immune
   checkpoint inhibitors; antitumor drugs},
Keywords-Plus = {CELL-PROLIFERATION; SURVIVAL; PROMOTES; INVASION; IDENTIFICATION;
