DOI = {10.1007/s10238-025-01869-8},
Article-Number = {319},
Keywords = {Micrometastasis; Sentinel lymph node; Axillary lymph node dissection;
   Breast cancer; Surveillance, Epidemiology, and End Results (SEER)
