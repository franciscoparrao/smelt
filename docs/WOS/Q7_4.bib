   Xia, Luping, Shangrao Peoples Hosp, Dept Resp \& Crit Care Med, Shangrao, Peoples R China.},
DOI = {10.21037/jtd-24-1530},
Keywords = {Lung adenocarcinoma (LUAD); The Cancer Genome Atlas (TCGA); survival
   analysis; immunotherapy},
