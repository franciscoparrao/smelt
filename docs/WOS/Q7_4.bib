   Gong, Jian, Capital Med Univ, Beijing Tiantan Hosp, Dept Neurosurg, 119 Nansihuan West Rd, Beijing 100070, Peoples R China.},
DOI = {10.1007/s00330-023-10316-9},
EarlyAccessDate = {NOV 2023},
