   Sonabend, Raphael, OSPO Now, London, England.},
DOI = {10.1007/978-3-032-06109-6\_5},
Keywords = {Proper Scoring Rules; Survival Analysis; Neural Networks},
Author-Email = {philipp.kopper@stat.uni-muenchen.de
