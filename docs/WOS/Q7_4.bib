   Liu, Li, Jiangnan Univ, Affiliated Hosp, Big Data Ctr, 1000 Hefeng Rd, Wuxi 214000, Peoples R China.},
DOI = {10.1016/j.acra.2024.12.022},
EarlyAccessDate = {APR 2025},
