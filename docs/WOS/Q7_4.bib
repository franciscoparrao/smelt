   Wu, Haiying, Sun Yat Sen Univ, Canc Ctr, Dept Radiat Oncol, Guangzhou, Guangdong, Peoples R China.},
DOI = {10.12968/hmed.2025.0232},
Article-Number = {0232},
Keywords = {diffuse large B-cell lymphoma; stomach neoplasm; prognosis; risk
   assessment},
Keywords-Plus = {DLBCL; CHOP},
