   Muller-Franzes, Gustav; Bruners, Philipp; Kuhl, Christiane; Truhn, Daniel, Univ Hosp RWTH Aachen, Dept Diagnost \& Intervent Radiol, Aachen, Germany.},
DOI = {10.1002/jhbp.1249},
EarlyAccessDate = {OCT 2022},
Keywords = {colorectal cancer; liver; machine learning; metastases; survival},
