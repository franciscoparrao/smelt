   Lu, Ruogu, Chinese Peoples Liberat Army Gen Hosp, Med Innovat Res Dept, Beijing, Peoples R China.},
DOI = {10.1097/JS9.0000000000003525},
Keywords = {glycemic variability; machine learning; MIMIC-IV database; sepsis;
