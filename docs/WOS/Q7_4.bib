   Hamoudi, Rifat, Univ Sharjah, Biomedically Informed Artificial Intelligence Lab, BIMAI Lab, POB 27272, Sharjah, U Arab Emirates.},
DOI = {10.3390/biomedinformatics4020081},
Keywords = {anomaly detection; gene expression; diffuse large B-cell lymphoma;
