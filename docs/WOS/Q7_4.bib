   Xu, Danfeng, Shanghai Jiao Tong Univ, Sch Biomed Engn, 197 Ruijin Er Rd, Shanghai 200025, Peoples R China.},
DOI = {10.1002/cam4.5449},
EarlyAccessDate = {NOV 2022},
Keywords = {biomarker; clear cell renal cell carcinoma; CTLA4; machine learning;
   radiomics signature},
Keywords-Plus = {PEMBROLIZUMAB; THERAPY},
