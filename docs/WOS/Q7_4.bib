   Burke, Bernard; Krishnan, Nithya, Coventry Univ, Res Ctr Hlth \& Life Sci, Coventry, England.
   Shroff, Arun; Shroff, Sunil, MOHAN Fdn, Xtend AI, Medindia net, Gurugram, India.
   Briggs, David, NHS Blood \& Transplant, Histocompatibil \& Immunogenet, Birmingham, England.
   Briggs, David, Univ Birmingham, Inst Immunol \& Immunotherapy, Birmingham, England.},
DOI = {10.1097/MAT.0000000000002190},
Keywords = {kidney allocation schemes; artificial intelligence},
Keywords-Plus = {SURVIVAL; DISPARITIES; IMPACT; COST},
