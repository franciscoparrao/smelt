   Qiao, Wenying; Jin, Ronghua, Changping Lab, Beijing 102206, Peoples R China.
   Li, Kang, Capital Med Univ, Beijing Youan Hosp, Res Ctr Biomed Resources, Beijing 100069, Peoples R China.},
DOI = {10.2147/JHC.S465962},
Keywords = {hepatocellular carcinoma; HCC; ablation; nomogram; recurrence;
   albumin-bilirubin; ALBI},
Keywords-Plus = {RADIOFREQUENCY ABLATION; HCC PATIENTS; LIVER; PROGNOSIS; RATIO; SCORE},
