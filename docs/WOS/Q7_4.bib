   Neven, Patrick, Univ Hosp Leuven, Dept Gynaecol Oncol, Louvain, Belgium.
   Neven, Patrick, Univ Hosp Leuven, MBC, Louvain, Belgium.
   Harvey, Vernon, Auckland City Hosp, Reg Canc Ctr, Auckland, New Zealand.
   Boyd, Stephen, Stanford Univ, Dept Elect Engn, Stanford, CA 94305 USA.},
DOI = {10.1016/j.neucom.2012.12.049},
Keywords = {Survival analysis; Monotonic regression; Breast cancer prognosis},
Keywords-Plus = {TRANSFORMATION MODELS; REGRESSION MODELS; OPTIMAL CUTPOINTS;
   BREAST-CANCER; CENSORED-DATA; RANKING; INDEX},
Author-Email = {vanya.vanbelle@esat.kuleuven.be},
