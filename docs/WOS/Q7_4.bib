   Dong, Jian, Fudan Univ, Zhongshan Hosp, Dept Orthopaed Surg, Wusong Branch, Shanghai 200940, Peoples R China.},
DOI = {10.1007/s10238-025-01992-6},
Article-Number = {102},
Keywords = {Hepatocellular carcinoma; Spinal metastases; Molecular subtypes; Machine
   learning; Prognostic analysis; Overall survival},
Keywords-Plus = {LUNG-CANCER PATIENTS; BONE METASTASES; PERCUTANEOUS VERTEBROPLASTY;
