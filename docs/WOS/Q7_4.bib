   Wang, Ke; Zheng, Chu; Yang, Hong; Liu, Yanling; Zhang, Yanbo, Shanxi Med Univ, Shanxi Prov Key Lab Major Dis Risk Assessment, Taiyuan, Peoples R China.
   Tian, Jing; Han, Qinghua, Shanxi Med Univ, Dept Cardiol, Affiliated Hosp 1, Taiyuan, Peoples R China.},
DOI = {10.1016/j.compbiomed.2021.104813},
EarlyAccessDate = {SEP 2021},
