@article{ WOS:000936822600001,
Author = {Rytgaard, Helene C. W. and Ekstrom, Claus T. and Kessing, Lars V. and
   Gerds, Thomas A.},
Title = {Ranking of average treatment effects with generalized random forests for
   time-to-event outcomes},
Journal = {STATISTICS IN MEDICINE},
Year = {2023},
Volume = {42},
Number = {10},
Pages = {1542-1564},
Month = {MAY 10},
Abstract = {Linkage between drug claims data and clinical outcome allows a
   data-driven experimental approach to drug repurposing. We develop an
   estimation procedure based on generalized random forests for estimation
   of time-point specific average treatment effects in a time-to-event
   setting with competing risks. To handle right-censoring, we propose a
   two-step procedure for estimation, applying inverse probability
   weighting to construct time-point specific weighted outcomes as input
   for the generalized random forest. The generalized random forests
   adaptively handle covariate effects on the treatment assignment by
   applying a splitting rule that targets a causal parameter. Using
   simulated data we demonstrate that the method is effective for a causal
   search through a list of treatments to be ranked according to the
   magnitude of their effect on clinical outcome. We illustrate the method
   using the Danish national health registries where it is of interest to
   discover drugs with an unexpected protective effect against relapse of
   severe depression.},
Type = {Article},
Affiliation = {Rytgaard, HCW (Corresponding Author), Univ Copenhagen, Sect Biostat, Oster Farimagsgade 5, DK-1014 Copenhagen, Denmark.
   Rytgaard, Helene C. W.; Ekstrom, Claus T.; Gerds, Thomas A., Univ Copenhagen, Sect Biostat, Copenhagen, Denmark.
   Kessing, Lars V., Univ Copenhagen, Copenhagen Affect Disorder Res Ctr CAD, Psychiat Ctr Copenhagen, Rigshospitalet, Copenhagen, Denmark.
   Rytgaard, Helene C. W., Univ Copenhagen, Sect Biostat, Oster Farimagsgade 5, DK-1014 Copenhagen, Denmark.},
DOI = {10.1002/sim.9686},
EarlyAccessDate = {FEB 2023},
Keywords = {average treatment effect; competing risks; random forests; time-to-event},
Keywords-Plus = {VARIABLE SELECTION; RISK},
Author-Email = {hely@sund.ku.dk},
Number-of-Cited-References = {34},
Times-Cited = {1},
Unique-ID = {WOS:000936822600001},
}

@article{ WOS:000984290700024,
Author = {Choi, Taehwa and Lee, Hyunjun and Choi, Sangbum},
Title = {Accountable survival contrast-learning for optimal dynamic treatment
   regimes},
Journal = {SCIENTIFIC REPORTS},
Year = {2023},
Volume = {13},
Number = {1},
Month = {FEB 8},
Abstract = {Dynamic treatment regime (DTR) is an emerging paradigm in recent medical
   studies, which searches a series of decision rules to assign optimal
   treatments to each patient by taking into account individual features
   such as genetic, environmental, and social factors. Although there is a
   large and growing literature on statistical methods to estimate optimal
   treatment regimes, most methodologies focused on complete data. In this
   article, we propose an accountable contrast-learning algorithm for
   optimal dynamic treatment regime with survival endpoints. Our estimating
   procedure is originated from a doubly-robust weighted classification
   scheme, which is a model-based contrast-learning method that directly
   characterizes the interaction terms between predictors and treatments
   without main effects. To reflect the censorship, we adopt the
   pseudo-value approach that replaces survival quantities with
   pseudo-observations for the time-to-event outcome. Unlike many existing
   approaches, mostly based on complicated outcome regression modeling or
   inverse-probability weighting schemes, the pseudo-value approach greatly
   simplifies the estimating procedure for optimal treatment regime by
   allowing investigators to conveniently apply standard machine learning
   techniques to censored survival data without losing much efficiency. We
   further explore a SCAD-penalization to find informative clinical
   variables and modified algorithms to handle multiple treatment options
   by searching upper and lower bounds of the objective function. We
   demonstrate the utility of our proposal via extensive simulations and
   application to AIDS data.},
Type = {Article},
Affiliation = {Choi, S (Corresponding Author), Korea Univ, Dept Stat, Seoul, South Korea.
   Choi, Taehwa, Duke Univ, Dept Biostat \& Bioinformat, Durham, NC USA.
   Lee, Hyunjun, SK Inc C\&C, Seoul, South Korea.
   Choi, Sangbum, Korea Univ, Dept Stat, Seoul, South Korea.},
DOI = {10.1038/s41598-023-29106-w},
Article-Number = {2250},
Keywords-Plus = {ESTIMATING INDIVIDUALIZED TREATMENT; PSEUDO-OBSERVATIONS; INFERENCE;
   SELECTION; MODELS},
Author-Email = {choisang@korea.ac.kr},
Number-of-Cited-References = {49},
Times-Cited = {1},
Unique-ID = {WOS:000984290700024},
}

@article{ WOS:000918956300001,
Author = {Wang, Yikai and Ma, Le and Xue, Pengjun and Qin, Bianni and Wang, Ting
   and Li, Bo and Wu, Lina and Zhao, Liyan and Liu, Xiongtao},
Title = {Construction and Analysis of Hepatocellular Carcinoma Prognostic Model
   Based on Random Forest},
Journal = {CANADIAN JOURNAL OF GASTROENTEROLOGY AND HEPATOLOGY},
Year = {2023},
Volume = {2023},
Month = {JAN 12},
Abstract = {Introduction and Aims. Hepatocellular carcinoma (HCC) is one of the most
   lethal tumors of the digestive system, but its mechanisms remain
   unclear. The purpose of this study was to study HCC-related genes, build
   a survival prognosis prediction model, and provide references for
   treatment and mechanism research. Methods. Transcriptome data and
   clinical data of HCC were downloaded from the TCGA database. Screen
   important genes based on the random forest method, combined with
   differential expression genes (DEGs) to screen out important DEGs. The
   Kaplan-Meier curve was used to evaluate its prognostic significance. Cox
   regression analysis was used to construct a survival prognosis
   prediction model, and the ROC curve was used to verify it. Finally, the
   mechanism of action was explored through GO and KEGG pathway enrichment
   and GeneMANIA coexpression analyses. Results. Seven important DEGs were
   identified, three were highly expressed and four were lowly expressed.
   Among them, GPRIN1, MYBL2, and GSTM5 were closely related to prognosis
   (P < 0.05). After the survival prognosis prediction model was
   established, the survival analysis showed that the survival time of the
   high-risk group was significantly shortened (P < 0.001), but the ROC
   analysis indicated that the model was not superior to staging. Twenty
   coexpressed genes were screened, and enrichment analysis indicated that
   glutathione metabolism was an important mechanism for these genes to
   regulate HCC progression. Conclusion. This study revealed the important
   DEGs affecting HCC progression and provided references for clinical
   assessment of patient prognosis and exploration of HCC progression
   mechanisms through the construction of predictive models and gene
   enrichment analysis.},
