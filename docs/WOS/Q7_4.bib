   Yu, Mingjun, China Med Univ, Dept Med Affairs, Shengjing Hosp, Shenyang 110004, Peoples R China.
   Zhou, Wen, Dalian Municipal Cent Hosp, Dept Pain Management, Dalian 116033, Peoples R China.
   Gu, Xiao, China Med Univ, Dept Oncol, Shengjing Hosp, Shenyang 110004, Peoples R China.
   Yu, Shijia, China Med Univ, Dept Neurol, Shengjing Hosp, Shenyang 110004, Peoples R China.},
DOI = {10.1038/s41598-025-90128-7},
