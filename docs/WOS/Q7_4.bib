   Ong, Marcus Eng Hock, Singapore Gen Hosp, Dept Emergency Med, Singapore, Singapore.
   Liu, Nan, Natl Univ Singapore, Inst Data Sci, Singapore, Singapore.
   Liu, Nan, Singapore Hlth Serv, Hlth Serv Res Ctr, Singapore, Singapore.
   Chakraborty, Bibhas, Natl Univ Singapore, Dept Stat \& Data Sci, Singapore, Singapore.},
DOI = {10.1016/j.jbi.2021.103959},
EarlyAccessDate = {DEC 2021},
