   Sun, Na, China Med Univ, Shengjing Hosp, Dept Radiol, Shenyang, Liaoning, Peoples R China.},
DOI = {10.1096/fj.202301353RR},
Article-Number = {e23529},
Keywords = {head and neck squamous cell carcinoma; machine learning; overall
   survival; radiomics; gamma delta T cells},
Keywords-Plus = {TUMOR; LANDSCAPE},
