   Fei, Peiwen, Univ Hawaii, Canc Biol Program, Canc Ctr, Honolulu, HI USA.
   Lu, Lingeng; Risch, Harvey, Yale Sch Publ Hlth, Dept Chron Dis Epidemiol, New Haven, CT USA.},
DOI = {10.1038/s41598-023-45932-4},
Article-Number = {18962},
Keywords-Plus = {NIVOLUMAB PLUS IPILIMUMAB},
Author-Email = {hyu@cc.hawaii.edu},
