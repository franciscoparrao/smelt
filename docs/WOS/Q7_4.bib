   Attia, John, Univ Newcastle, Sch Med \& Publ Hlth, Newcastle, NSW, Australia.},
DOI = {10.1186/s12911-025-02964-2},
Article-Number = {134},
Keywords = {Glucose variability; Diabetes complications; Coefficient of variation;
   Prognostic factors; Machine learning},
Keywords-Plus = {GLYCEMIC VARIABILITY},
Author-Email = {panu.loo@mahidol.ac.th},
