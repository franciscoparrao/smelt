   Gkoutos, Georgios V.; Acharjee, Animesh, Univ Birmingham, Ctr Hlth Data Res, Birmingham, England.},
DOI = {10.1002/cam4.70434},
Article-Number = {e70434},
Keywords = {clustering; machine learning; microbiome; personalised medicine;
   survival analysis},
Keywords-Plus = {GUT MICROBIOTA; GEN. NOV.; RECLASSIFICATION; PROTEOBACTERIA; GENOMICS;
   SET},
