   Yonetsu, Taishi; Sasano, Tetsuo, Tokyo Med \& Dent Univ, Dept Cardiovasc Med, Tokyo, Japan.},
DOI = {10.1016/j.ijcard.2021.03.019},
EarlyAccessDate = {MAY 2021},
