   Yang, Hanshi, Xuzhou Med Univ, Dept Orthoped, Affiliated Huaian Hosp, Huaian 223003, Jiangsu, Peoples R China.
   Yang, Hanshi, Second Peoples Hosp Huaian, Huaian 223003, Jiangsu, Peoples R China.},
DOI = {10.1002/tox.24269},
EarlyAccessDate = {APR 2024},
Keywords = {GEO; machine learning; osteosarcoma; programmed cell death; TARGET},
Keywords-Plus = {CHILDHOOD; CANCER; TUMORS},
