   Arjomandi, Mehrdad, San Francisco Vet Affairs Hlth Care Syst, San Francisco, CA USA.
   Arjomandi, Mehrdad, Univ Calif San Francisco, San Francisco, CA USA.},
DOI = {10.1513/AnnalsATS.202411-1205OC},
