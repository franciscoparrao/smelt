   Lin, Lian-Yu, Natl Taiwan Univ, Coll Med, Dept Internal Med, Taipei, Taiwan.
   Chen, Tony Hsiu-Hsi, Natl Taiwan Univ, Inst Epidemiol \& Prevent Med, Coll Publ Hlth, Taipei, Taiwan.},
DOI = {10.1186/s12933-023-01767-x},
Article-Number = {35},
Keywords = {Prediabetes; Atrial fibrillation; Heart failure; Random survival forest},
Keywords-Plus = {METABOLIC SYNDROME; DIABETES-MELLITUS; GLYCEMIC SPECTRUM; HEART-FAILURE;
   DISEASE; HEMOGLOBIN},
