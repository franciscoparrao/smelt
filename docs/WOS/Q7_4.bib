Keywords = {angiopoietin-2; predictive biomarkers; VEGF; KRAS mutation status; phase
   II clinical trial; colorectal cancer; vanucizumab; bevacizumab},
Keywords-Plus = {METASTATIC COLORECTAL-CANCER; PHASE-III; TUMOR ANGIOGENESIS; 1ST-LINE
