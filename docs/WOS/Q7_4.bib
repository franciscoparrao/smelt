   Tome, Wolfgang A., Albert Einstein Coll Med, Dept Neurol, Bronx, NY 10461 USA.
   Garg, Madhur K., Montefiore Med Ctr, Dept Otorhinolaryngol Head \& Neck Surg, Bronx, NY 10461 USA.},
DOI = {10.1016/j.phro.2022.02.005},
Keywords = {Radiomics; Positron emission tomography; Oropharyngeal cancer; Risk
   stratification},
Keywords-Plus = {HUMAN-PAPILLOMAVIRUS; RADIATION-THERAPY; RANDOMIZED-TRIAL; HEAD;
