@article{ WOS:000302032600058,
Author = {Stajduhar, Ivan and Dalbelo-Basic, Bojana},
Title = {Uncensoring censored data for machine learning: A likelihood-based
   approach},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2012},
Volume = {39},
Number = {8},
Pages = {7226-7234},
Month = {JUN 15},
Abstract = {Various machine learning techniques have been applied to different
   problems in survival analysis in the last decade. They were usually
   adapted to learning from censored survival data by using the information
   on observation time. This includes learning from parts of the data or
   interventions to the learning algorithms. Efficient models were
   established in various fields of clinical medicine and bioinformatics.
   In this paper, we propose a pre-processing method for adapting the
   censored survival data to be used with ordinary machine learning
   algorithms. This is done by pre-assigning censored instances a positive
   or negative outcome according to their features and observation time.
   The proposed procedure calculates the goodness of fit of each censored
   instance to both the distribution of positives and the spoiled
   distribution of negatives in the entire dataset and relabels that
   instance accordingly. We performed a thorough empirical testing of our
   method in a simulation study and on two real-world medical datasets,
   using the naive Bayes classifier and decision trees. When compared to
   one of the popular ML methods dealing with survival, our method provided
   good results, especially when applied to heavily censored data. (C) 2012
   Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Stajduhar, I (Corresponding Author), Univ Rijeka, Fac Engn, Dept Comp Engn, Vukovarska 58, Rijeka 51000, Croatia.
   Stajduhar, Ivan, Univ Rijeka, Fac Engn, Dept Comp Engn, Rijeka 51000, Croatia.
   Dalbelo-Basic, Bojana, Univ Zagreb, Fac Elect Engn \& Comp, Dept Elect Microelect Comp \& Intelligent Syst, Zagreb 10000, Croatia.},
DOI = {10.1016/j.eswa.2012.01.054},
Keywords = {Survival analysis; Censoring; Machine learning; Denoising; Data
   likelihood; Classification},
Keywords-Plus = {NEURAL-NETWORKS; SURVIVAL-DATA; PROGNOSIS; CANCER; SEPARATION; DIAGNOSIS},
Author-Email = {ivan.stajduhar@riteh.hr},
Number-of-Cited-References = {40},
Times-Cited = {14},
