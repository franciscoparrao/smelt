}

@incollection{ WOS:000870701000020,
Author = {Kopper, Philipp and Wiegrebe, Simon and Bischl, Bernd and Bender,
   Andreas and Rugamer, David},
Editor = {Gama, J and Li, T and Yu, Y and Chen, E and Zheng, Y and Teng, F},
Title = {DeepPAMM: Deep Piecewise Exponential Additive Mixed Models for Complex
   Hazard Structures in Survival Analysis},
Booktitle = {ADVANCES IN KNOWLEDGE DISCOVERY AND DATA MINING, PAKDD 2022, PT II},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2022},
Volume = {13281},
Pages = {249-261},
Abstract = {Survival analysis (SA) is an active field of research that is concerned
   with time-to-event outcomes and is prevalent in many domains,
   particularly biomedical applications. Despite its importance, SA remains
   challenging due to small-scale data sets and complex outcome
   distributions, concealed by truncation and censoring processes. The
   piecewise exponential additive mixed model (PAMM) is a model class
   addressing many of these challenges, yet PAMMs are not applicable in
   high-dimensional feature settings or in the case of unstructured or
   multimodal data. We unify existing approaches by proposing DeepPAMM, a
   versatile deep learning framework that is well-founded from a
   statistical point of view, yet with enough flexibility for modeling
   complex hazard structures. We illustrate that DeepPAMMis competitive
   with other machine learning approaches with respect to predictive
   performance while maintaining interpretability through benchmark
   experiments and an extended case study.},
Type = {Proceedings Paper},
Affiliation = {Kopper, P (Corresponding Author), Ludwig Maximilians Univ Munchen, Dept Stat, Ludwigstr 33, D-80539 Munich, Germany.
   Kopper, Philipp; Wiegrebe, Simon; Bischl, Bernd; Bender, Andreas; Rugamer, David, Ludwig Maximilians Univ Munchen, Dept Stat, Ludwigstr 33, D-80539 Munich, Germany.},
DOI = {10.1007/978-3-031-05936-0\_20},
Keywords = {Deep learning; Time-to-event data; Survival analysis; Interpretability;
   Random effects; Mixed models},
Author-Email = {philipp.kopper@stat.uni-muenchen.de},
Number-of-Cited-References = {45},
Times-Cited = {13},
