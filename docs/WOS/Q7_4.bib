   Skupien, Jovito Adiel; Marchiori, Fabiana Teixeira, Franciscan Univ, Postgrad Program Hlth \& Life Sci, Santa Maria, RS, Brazil.},
DOI = {10.1111/iej.70048},
EarlyAccessDate = {OCT 2025},
