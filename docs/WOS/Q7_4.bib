   Alabbasi, Marah, Mutah Univ, Fac Med, Al Karak, Jordan.
   Irsheidat, Kinda Akram, Jordan Univ Sci \& Technol, Fac Med, Dept Obstet \& Gynecol, Irbid, Jordan.},
DOI = {10.1002/ijgo.15845},
EarlyAccessDate = {AUG 2024},
Keywords = {clinical decision-making; machine learning; ovarian neoplasms;
   prognosis; struma ovarii; survival analysis},
Keywords-Plus = {MANAGEMENT; SURVIVAL; CANCER; SERIES},
Author-Email = {20512019200112@medicine.zu.edu.eg},
Number-of-Cited-References = {37},
