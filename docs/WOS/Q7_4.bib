@article{ WOS:000862853300001,
Author = {Ye, Yan and Zhang, Xueliang and Li, Teng and Ma, Jiaqiang and Wang, Ran
   and Wu, Chunmei and Wang, Runci and Bao, Chunde and Ye, Shuang and Shen,
   Nan and Guo, Qiang and Fu, Qiong and Zhang, Xiaoming},
Title = {Two Distinct Immune Cell Signatures Predict the Clinical Outcomes in
   Patients With Amyopathic Dermatomyositis With Interstitial Lung Disease},
Journal = {ARTHRITIS \& RHEUMATOLOGY},
Year = {2022},
Volume = {74},
Number = {11},
Pages = {1822-1832},
Month = {NOV},
Abstract = {Objective Amyopathic dermatomyositis (ADM) is a heterogeneous and
   life-threatening autoimmune disease with a high mortality rate. In
   particular, anti-melanoma differentiation-associated protein 5
   antibody-positive patients are at a high risk of developing rapidly
   progressive interstitial lung disease (RPILD). This study was undertaken
   to identify immunologic signatures among patients who have ADM with ILD
   (ADM-ILD) and to discover the biomarkers predicting prognosis. Methods
   The landscape of 42 immune cell phenotypes in the peripheral blood of 82
   ADM-ILD patients and 82 age- and sex-matched healthy donors was assessed
   by multicolor flow cytometry. Patients were stratified using an
   unsupervised machine learning method (hierarchical clustering analysis)
   by immune cell subsets. Multiple Wilcoxon's signed rank tests and
   supervised machine learning methods were performed to identify important
   immune cell subsets. Kaplan-Meier survival analysis with log rank tests
   was used to create survival curves. Results We identified 2 distinct
   clusters correlating with different disease activities and clinical
   outcomes in ADM-ILD. Cluster 1 was enriched in the activated
   CD45RA+HLA-DR+CD8+ T cells with decreased CD56(dim) natural killer cell
   proportions and showed a higher prevalence of RPILD and higher
   mortality. In contrast, the other subgroup, cluster 2 (the nonactivated
   T cell-dominant cluster), displayed favorable clinical outcomes with
   high survival rates. Our data also revealed that immunophenotype was an
   independent risk factor associated with 1-year survival. Conclusion
   Peripheral immunologic features may have the potential to stratify
   patients with ADM-ILD according to different disease severity and
   clinical outcomes, which may have implications for outcome prediction,
   pathogenesis study, and therapy selection.},
Type = {Article},
Affiliation = {Guo, Q; Fu, Q (Corresponding Author), Shanghai Jiao Tong Univ, Renji Hosp, Sch Med, Dept Rheumatol, Shanghai, Peoples R China.
   Zhang, XM (Corresponding Author), Chinese Acad Sci, Univ Chinese Acad Sci, Ctr Microbes Dev \& Hlth, Key Lab Mol Virol \& Immunol,Inst Pasteur Shanghai, Shanghai, Peoples R China.
