@article{ WOS:001369260500007,
Author = {Lorenz, Elizabeth C. and Smith, Byron H. and Liang, Yun and Park, Walter
   D. and Bentall, Andrew J. and Dhala, Atiya F. and Waterman, Amy D. and
   Kennedy, Cassie C. and Hickson, LaTonya J. and Rule, Andrew D. and
   Cheville, Andrea L. and Lebrasseur, Nathan K. and Stegall, Mark D.},
Title = {Increased Pretransplant Inflammatory Biomarkers Predict Death With
   Function After Kidney Transplantation},
Journal = {TRANSPLANTATION},
Year = {2024},
Volume = {108},
Number = {12},
Pages = {2434-2445},
Month = {DEC},
Abstract = {Background. Chronic systemic inflammation is associated with mortality
   in patients with chronic kidney disease, cardiovascular disease, and
   diabetes. The goal of this study was to examine the relationship between
   pretransplant inflammatory biomarkers (growth differentiation factor-15
   {[}GDF-15], interleukin-6 {[}IL-6], soluble tumor necrosis factor
   receptor-1, monokine induced by gamma interferon/chemokine {[}C-X-C
   motif] ligand 9 {[}MIG/CXCL9], monocyte chemoattractant protein-1,
   soluble FAS, tumor necrosis factor-alpha, interleukin-15, and
   interleukin-1 beta) and death with function (DWF) after kidney
   transplantation (KT). Methods. We retrospectively measured inflammatory
   biomarker levels in serum collected up to 1 y before KT (time from blood
   draw to KT was 130 +/- 110 d) in recipients transplanted between January
   2006 and December 2018. Kaplan-Meier estimation, Cox regression, and
   Gradient Boosting Machine modeling were used to examine the relationship
   between inflammatory biomarkers and DWF. Results. Our cohort consisted
   of 1595 KT recipients, of whom 62.9\% were male and 83.2\% were
   non-Hispanic White. Over a mean follow-up of 7.4 +/- 3.9 y, 21.2\% of
   patients (n = 338) experienced DWF. Patients with the highest quartile
   levels of GDF-15 (>4766 pg/mL), IL-6 (>6.11 pg/mL), and MIG/CXCL9 (>
   5835 pg/mL) had increased rates of DWF, and each predicted mortality
   independently of the others. When adjusted for clinical factors (age,
   diabetes, etc), the highest quartile levels of GDF-15 and IL-6 remained
   independently associated with DWF. Adding inflammatory markers to a
   clinical Cox model improved the C-statistic for DWF from 0.727 to 0.762
   using a Gradient Boosting Machine modeling approach. Conclusions. These
   findings suggest that pre-KT serum concentrations of GDF-15, IL-6, and
   MIG/CXCL9 may help to risk stratify and manage patients undergoing KT
   and suggests that chronic inflammation may play a role in mortality in
   KT recipients.},
Type = {Article},
Affiliation = {Lorenz, EC (Corresponding Author), Baylor Coll Med, Sect Nephrol, One Baylor Plaza, Houston, TX 77030 USA.
   Lorenz, Elizabeth C., Baylor Coll Med, Sect Nephrol, One Baylor Plaza, Houston, TX 77030 USA.
   Smith, Byron H., Mayo Clin, Dept Quantitat Hlth Sci, Rochester, MN USA.
   Liang, Yun; Park, Walter D.; Stegall, Mark D., Mayo Clin, Dept Surg, Rochester, MN USA.
   Bentall, Andrew J.; Rule, Andrew D., Mayo Clin, Div Nephrol \& Hypertens, Rochester, MN USA.
   Dhala, Atiya F.; Waterman, Amy D., Houston Methodist Hosp, Dept Surg, Houston, TX USA.
   Kennedy, Cassie C., Mayo Clin, Div Pulm Crit Care \& Sleep Med, Rochester, MN USA.
   Hickson, LaTonya J., Mayo Clin, Div Nephrol \& Hypertens, Jacksonville, FL USA.
   Cheville, Andrea L.; Lebrasseur, Nathan K., Mayo Clin, Dept Phys Med \& Rehabil, Rochester, MN USA.},
DOI = {10.1097/TP.0000000000005103},
Keywords-Plus = {MONOCYTE CHEMOATTRACTANT PROTEIN-1; ELEVATED SERUM-LEVELS; PROGNOSTIC
   UTILITY; MORTALITY; DIFFERENTIATION; OBESITY; MCP-1; IL-6;
   INTERLEUKIN-6; HEMODIALYSIS},
