DOI = {10.1186/s12885-025-13688-x},
Article-Number = {310},
Keywords = {Bladder cancer; Molecular subtypes; Deep learning features; Whole-slide
   images; Machine learning},
Keywords-Plus = {IDENTIFICATION},
