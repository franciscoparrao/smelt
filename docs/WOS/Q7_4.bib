   Li, Yuan, Chinese Acad Med Sci \& Peking Union Med Coll, Natl Ctr Cardiovasc Dis, Dept Cardiovasc Surg, Fuwai Hosp, Beijing, Peoples R China.},
DOI = {10.3389/fcvm.2026.1638901},
