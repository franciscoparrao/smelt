   Ausset, Guillaume; Ciffreo, Tom; Papin, Timothee, BNP Paribas, Paris, France.},
DOI = {10.1109/DSAA53316.2021.9564222},
Keywords = {survival analysis; normalizing flows; financial modelling; portfolio
