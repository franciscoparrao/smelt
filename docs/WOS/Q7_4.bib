Keywords = {adult-type diffuse glioma; machine learning; neutrophil
   percentage-to-albumin ratio; NPAR; prediction model; prognosis},
Author-Email = {zhoulili0@126.com},
Number-of-Cited-References = {44},
Times-Cited = {0},
