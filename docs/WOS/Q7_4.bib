   Rizzo, Giovanna, Italian Natl Res Council, Inst Intelligent Ind Technol \& Syst, Via Alfonso Corti 12, I-20133 Milan, Italy.},
DOI = {10.3390/app14166923},
Article-Number = {6923},
Keywords = {computer tomography; feature construction; genetic programming;
   radiomics; non-small cell lung cancer},
Keywords-Plus = {CLASSIFICATION; INFORMATION; 2D},
Author-Email = {elisa.scalco@itb.cnr.it
   wgomez@cinvestav.mx
   giovanna.rizzo@stiima.cnr.it},
