   Sun, Tao; Guo, Mixue; Zhao, Wei, Ningxia Med Univ, Sch Basic Med, Yinchuan, Peoples R China.
   Sun, Tao; Yan, Hui, Cent Hosp Shaoyang, Dept Hematol \& Oncol Lab, Shaoyang, Hunan, Peoples R China.
   Sun, Tao; Guo, Mixue; Zhao, Wei, Ningxia Med Univ, Ningxia Key Lab Prevent \& Treatment Common Infect, Yinchuan, Peoples R China.
   Liu, Jun, Shaoyang Univ, Dept Sci Res, Affiliated Hosp 1, Shaoyang, Hunan, Peoples R China.},
DOI = {10.3389/fendo.2026.1797342},
