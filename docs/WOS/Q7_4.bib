   proportional hazard model},
Keywords-Plus = {PULMONARY ADENOCARCINOMA; NOMOGRAM; SURVIVAL; CANCER; PATTERNS},
Author-Email = {swan@unmc.edu
   luolianxiang321@gdmu.edu.cn},
Number-of-Cited-References = {43},
Times-Cited = {2},
