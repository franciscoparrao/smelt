@article{ WOS:001368913000001,
Author = {Sun, Chen and Jiang, Chenggang and Wang, Xi and Ma, Shunchang and Zhang,
   Dainan and Jia, Wang},
Title = {MR-Based Radiomics Predicts CDK6 Expression and Prognostic Value in
