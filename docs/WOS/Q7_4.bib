   Zhang, Mingzhi, Zhengzhou Univ, Dept Oncol, Affiliated Hosp 1, 1 Jianshe Rd, Zhengzhou 450052, Henan, Peoples R China.},
DOI = {10.2147/IJGM.S409006},
Keywords = {anoikis; lung adenocarcinoma; ITGB4; machine learning; prognosis},
Keywords-Plus = {PAN-CANCER ANALYSIS; ITGB4; CELLS},
