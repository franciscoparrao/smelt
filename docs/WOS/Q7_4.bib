DOI = {10.1109/SmartWorld-UIC-ATC-SCALCOM-IOP-SCI.2019.00212},
Keywords = {turnover prediction; survival analysis; Cox proportional hazards model;
   random forest},
Author-Email = {zhu.qw@qq.com
