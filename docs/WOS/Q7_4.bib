   Zhang, Yaxin, Fujian Med Univ, Xiamen Humanity Hosp, Dept Neurol, 3777 Xian Yue Rd, Xiamen 361009, Fujian, Peoples R China.},
DOI = {10.1038/s41598-025-21524-2},
