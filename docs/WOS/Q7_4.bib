   Zhang, Qing; Kong, Beihua; Song, Kun, Shandong Univ, Qilu Hosp, Gynecol Oncol Key Lab, Jinan, Shandong, Peoples R China.},
DOI = {10.1002/onco.13956},
EarlyAccessDate = {SEP 2021},
Keywords = {Cervical cancer; Intermediate-risk factor; Adjuvant therapy; Sedlis
   criteria; Prediction model; Machine learning algorithm},
