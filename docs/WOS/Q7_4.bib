   Ha, Il Do, Pukyong Natl Univ, Dept Artificial Intelligence Convergence, Busan 48513, South Korea.},
DOI = {10.3390/math9111244},
Article-Number = {1244},
Keywords = {censored data; machine learning; deep learning; DNNSurv; survival
   analysis},
