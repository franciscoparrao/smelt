@article{ WOS:001636201200001,
Author = {Ge, Teng and Zou, Rongjun and Bo, Jingyu and Yang, Liangbin and Hu,
   Jinlin and Ning, Bo and Li, Yingwen and Pan, Zongqi and Sun, Pengtao and
   Chen, Sinan and Ju, Jiaxin and Zhang, Miao and He, Kunyang and Li,
   Guanmou and Wang, Chaojie and Peng, Jihai and Yang, Zhimin and Fan,
   Xiaoping},
Title = {Machine learning prediction of myocardial ischaemia-reperfusion injury:
   Clinical features and Qishen Yiqi dripping pills mechanism},
Journal = {PHYTOMEDICINE},
Year = {2026},
Volume = {150},
Month = {JAN},
Abstract = {Background: Myocardial ischaemia-reperfusion injury (MIRI) is a common
   complication following cardiopulmonary bypass (CPB) surgery. Most
   existing studies focus on basic research, with limited exploration of
   clinical patterns. The aim of this study was to analyse the key factors
   influencing postoperative mortality in MIRI patients, incorporate
   traditional Chinese medicine (TCM) classifications to reflect overall
   patient status, construct an optimal machine learning model for precise
   prognosis assessment, and investigate the intervention mechanism of
   Qishen Yiqi dripping pills (QSYQ). Methods: Clinical data from patients
   who underwent CPB at Guangdong Provincial Hospital of Traditional
   Chinese Medicine from October 2019 to October 2024 were collected. Ten
   machine learning algorithms were employed to construct predictive
   models. The feature importance was ranked using permutation importance,
   and both local and global explanations were provided through the SHAP
   values. Kaplan-Meier survival analysis was used to compare in-hospital
   survival between patients with complex and simple TCM classifications.
   Results: A total of 900 patients were included. LightGBM was identified
   as the optimal machine learning model, with an ROC\_AUC of 0.943 in the
   training set and 0.743 in the test set. Permutation-based feature
   importance ranking and SHAP analysis indicated that complex TCM
   classification is an important factor of postoperative mortality in
   patients undergoing CPB. Kaplan-Meier survival analysis revealed that
   patients with simple TCM classification had higher survival rates than
   those with complex TCM classification did. Experimental section:
   Methods: UPLC-MS/MS was used to determine the blood components of QSYQ.
   Network pharmacology and molecular dynamics simulations were employed to
   predict the core targets and inflammation regulating mechanisms of QSYQ
   in the treatment of MIRI. In vivo experiments and surface plasmon
   resonance (SPR) assays were conducted for further validation. Results:
   Network pharmacology analysis revealed IL-6 as the core target of QSYQ
   in MIRI treatment. UPLC-MS/ MS results revealed that the plasma
   concentrations of calycosin-7-O-glucoside, notoginsenoside R1, and
   neo-cryptotanshinone increased significantly after administration.
   Molecular dynamics simulations and SPR exper-iments further confirmed
   the binding interactions between calycosin-7-O-glucoside,
   notoginsenoside R1, neocryptotanshinone, and IL-6. In vivo experiments
   in mice demonstrated that QSYQ significantly improved cardiac function
   following MIRI, suppressed inflammatory responses, and effectively
   alleviated pathological changes in myocardial tissue. Conclusion: This
   study is the first to incorporate TCM classification into a machine
   learning model for patients undergoing CPB, establishing a framework for
   the precise prediction of postoperative mortality. These findings
   indicate that complex TCM classification is a key that is significantly
   associated with patient prognosis. Kaplan- Meier survival analysis
   further confirmed the unique value of complex TCM classification in
   predicting mortality risk. In addition, by integrating network
   pharmacology, molecular dynamics simulations, UPLC-MS/MS anal-ysis, and
   SPR techniques, this study systematically explored the mechanism through
   which QSYQ affects the treatment of MIRI. The results demonstrate that
   QSYQ significantly improves cardiac function, alleviates inflammation,
   and mitigates pathological damage by modulating the core target IL-6.},
Type = {Article},
Affiliation = {Fan, XP (Corresponding Author), Guangzhou Univ Chinese Med, Guangdong Prov Hosp Chinese Med, Affiliated Hosp 2, Dept Cardiovasc Surg, Guangzhou 510120, Guangdong, Peoples R China.
