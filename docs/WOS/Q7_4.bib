   Couper, David J., Univ N Carolina, Dept Biostat, Collaborat Studies Coordinating Ctr, 123 W Franklin St,Suite 450, Chapel Hill, NC 27516 USA.},
DOI = {10.1093/biomet/asac047},
EarlyAccessDate = {DEC 2022},
Keywords = {Conditionally independent censoring; Dynamic treatment regime; Empirical
   process; Precision medicine; Random forest; Reinforcement learning;
   Survival analysis},
Keywords-Plus = {INFERENCE; SAFETY; RISK},
Author-Email = {hunyong.cho@gmail.com
   sthollow@ncsu.edu
   david\_couper@unc.edu
   kosorok@unc.edu},
Number-of-Cited-References = {47},
