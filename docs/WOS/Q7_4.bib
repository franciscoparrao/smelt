@article{ WOS:001179870200001,
Author = {Fan, Binna and Fan, Binting and Sun, Na and Zou, Huawei and Gu, Xiao},
Title = {A radiomics model to predict γδ T-cell abundance and overall survival in
   head and neck squamous cell carcinoma},
Journal = {FASEB JOURNAL},
Year = {2024},
Volume = {38},
Number = {5},
Month = {MAR 5},
Abstract = {gamma delta T cells are becoming increasingly popular because of their
   attractive potential for antitumor immunotherapy. However, the role and
   assessment of gamma delta T cells in head and neck squamous cell
   carcinoma (HNSCC) are not well understood. We aimed to explore the
   prognostic value of gamma delta T cell and predict its abundance using a
   radiomics model. Computer tomography images with corresponding gene
   expression data and clinicopathological data were obtained from online
   databases. After outlining the volumes of interest manually, the
   radiomic features were screened using maximum melevance minimum
   redundancy and recursive feature elimination algorithms. A radiomics
   model was developed to predict gamma delta T-cell abundance using
   gradient boosting machine. Kaplan-Meier survival curves and univariate
   and multivariate Cox regression analyses were used for the survival
   analysis. In this study, we confirmed that gamma delta T-cell abundance
   was an independent predictor of favorable overall survival (OS) in
   patients with HNSCC. Moreover, a radiomics model was built to predict
   the gamma delta T-cell abundance level (the areas under the operating
   characteristic curves of 0.847 and 0.798 in the training and validation
   sets, respectively). The calibration and decision curves analysis
   demonstrated the fitness of the model. The high radiomic score was an
   independent protective factor for OS. Our results indicated that gamma
   delta T-cell abundance was a promising prognostic predictor in HNSCC,
   and the radiomics model could discriminate its abundance levels and
   predict OS. The noninvasive radiomics model provided a potentially
   powerful prediction tool to aid clinical judgment and antitumor
   immunotherapy.},
Type = {Article},
Affiliation = {Gu, X (Corresponding Author), China Med Univ, Shengjing Hosp, Dept Oncol, Shenyang 110000, Liaoning, Peoples R China.
   Fan, Binna; Zou, Huawei; Gu, Xiao, China Med Univ, Shengjing Hosp, Dept Oncol, Shenyang 110000, Liaoning, Peoples R China.
