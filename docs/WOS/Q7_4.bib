Keywords = {Glomerulonephritis; IgA nephropathy; Machine learning; Heterogeneous
   treatment response; Decision support; Precision medicine},
Keywords-Plus = {OXFORD CLASSIFICATION; PROLIFERATIVE LESIONS; INVERSE PROBABILITY;
