   Reiser, Maximilian, Univ Munich, Dept Radiol, D-80336 Munich, Germany.},
DOI = {10.1093/schbul/sbu078},
Keywords = {neuroanatomical biomarker; individualized risk stratification;
   cross-center; machine learning},
Keywords-Plus = {ULTRA-HIGH-RISK; SUPPORT VECTOR MACHINE; CLINICAL HIGH-RISK;
   GRAY-MATTER; PATTERN-CLASSIFICATION; 1ST-EPISODE PSYCHOSIS; HUMAN
   CEREBELLUM; MENTAL STATES; SCHIZOPHRENIA; VULNERABILITY},
Author-Email = {nikolaos.koutsouleris@med.uni-muenchen.de},
