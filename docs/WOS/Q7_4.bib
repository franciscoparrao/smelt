   Yuan, Wenhua, Xichang Peoples Hosp, Dept Orthoped, Xichang 615000, Sichuan, Peoples R China.},
DOI = {10.1016/j.ygeno.2020.10.010},
EarlyAccessDate = {JAN 2021},
Keywords = {Osteosarcoma; LncRNA; DNA methylation; Biomarker; Prognosis},
Author-Email = {jieqq16@lzu.edu.cn},
Number-of-Cited-References = {50},
Times-Cited = {18},
