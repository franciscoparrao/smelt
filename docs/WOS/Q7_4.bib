   Gonzalez-Davila, Enrique, Univ La Laguna, Dept Estadist \& Invest Operat, San Cristobal la Laguna, Spain.
   Diaz-Gonzalez, Federico, Univ La Laguna, Dept Med Interna Dermatol \& Psiquiat, San Cristobal la Laguna, Spain.},
DOI = {10.3389/fmed.2021.815881},
