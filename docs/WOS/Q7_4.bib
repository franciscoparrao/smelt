   Perez-Martinez, Antonio, La Paz Univ Hosp, Pediat Hematooncol, P Castellana 261, Madrid 28046, Spain.},
DOI = {10.1111/ejh.14184},
EarlyAccessDate = {FEB 2024},
Keywords = {artificial intelligence; hematopoietic stem cell transplantation;
   predictive model; prognostic index},
Keywords-Plus = {ACUTE-LEUKEMIA; INDEX; SCORE},
