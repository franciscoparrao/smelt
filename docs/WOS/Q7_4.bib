   Abouqal, Redouane, Mohamed V Univ, Fac Med \& Pharm, Dept Publ Hlth, Lab Biostat Clin \& Epidemiol Res, Rabat 10000, Morocco.},
DOI = {10.1016/j.jcrc.2026.155504},
Article-Number = {155504},
Keywords = {Machine learning; Septic shock; Vasoplegia; Septic cardiopathy;
   Low-resource setting; Echocardiography; Phenotypes},
Keywords-Plus = {DYSFUNCTION},
Author-Email = {younes.aissaoui@uca.ma},
Number-of-Cited-References = {37},
