   Lin, Guihan; Chen, Weiyue; Jiang, Chengli; Hu, Weiming; Sun, Jinhong; Xia, Shuiwei; Lu, Chenying; Chen, Minjiang; Ji, Jiansong; Chen, Weiqian, Wenzhou Med Univ, Lishui Cent Hosp, Affiliated Hosp 5, Dept Radiol, Lishui, Peoples R China.
   Xu, Lei; Yan, Zhihan, Wenzhou Med Univ, Affiliated Hosp 2, Wenzhou Key Lab Struct \& Funct Imaging, Wenzhou, Peoples R China.
   Chen, Yongjun, Lishui Peoples Hosp, Dept Radiol, Lishui, Peoples R China.
   Jing, Yang, Huiying Med Technol Co Ltd, Beijing, Peoples R China.},
DOI = {10.21037/qims-2025-1760},
Article-Number = {114},
Keywords = {Type 2 diabetes mellitus (T2DM); ischemic stroke (IS); perivascular
   adipose tissue (PVAT); event-free survival (EFS); SHapley Additive
   exPlanation (SHAP)},
Keywords-Plus = {MYOCARDIAL-INFARCTION; BLOOD-PRESSURE; RISK; MORTALITY; METAANALYSIS;
   CHOLESTEROL; DISEASE},
Author-Email = {jstcty@wmu.edu.cn
   ls2119088@126.com},
