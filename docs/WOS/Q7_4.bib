   Wang, Qi; Sun, Lina; Jin, Ronghua, Capital Med Univ, Beijing Inst Hepatol, Beijing Youan Hosp, Beijing 100069, Peoples R China.
   Zhang, Gongming; Chen, Zhuangzhuang; Li, Guangming, Capital Med Univ, Beijing Youan Hosp, Dept Gen Surg, 8 Xitoutiao,Youanmenwai St, Beijing 100069, Peoples R China.},
DOI = {10.3892/ol.2025.15056},
Article-Number = {310},
