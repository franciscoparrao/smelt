   Yu, Yizhou, Univ Hong Kong, Dept Comp Sci, Hong Kong, Peoples R China.},
DOI = {10.1007/s00330-022-09337-7},
EarlyAccessDate = {DEC 2022},
Keywords = {Immunotherapy; Immune checkpoint inhibitors; Lung neoplasms; Machine
   learning; Progression-free survival},
