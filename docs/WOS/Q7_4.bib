DOI = {10.1016/j.jss.2025.09.007},
EarlyAccessDate = {OCT 2025},
Keywords = {Intrahepatic cholangiocarcinoma; Long-term prognosis; Machine learning;
   Tumor-infiltrated lymphocytes; Tumor-stroma ratio},
Keywords-Plus = {INFILTRATING LYMPHOCYTES; CARCINOMA; SURVIVAL},
