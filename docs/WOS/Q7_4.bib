   Univ Calif Berkeley, Div Biostat, Berkeley, CA 94720 USA.
   Yale Univ, Sch Med, Div Biostat Epidemiol \& Publ Hlth, New Haven, CT 06520 USA.},
DOI = {10.1093/biostatistics/kxj011},
Keywords = {censoring; cross-validation; ensemble methods; IPC weights; loss
   function; prediction; prognostic factors; survival analysis},
Keywords-Plus = {REGRESSION-MODELS; ACCURACY; SPLINES},
Author-Email = {Torsten.Hothorn@rzmail.uni-erlangen.de},
Number-of-Cited-References = {55},
