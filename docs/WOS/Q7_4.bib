   Chen, Yanhua, Zhengzhou Univ, Sch Comp \& Artificial Intelligence, 100 Sci Ave,High Tech Zone, Zhengzhou 450001, Henan, Peoples R China.},
DOI = {10.1186/s13075-025-03477-z},
Article-Number = {25},
Keywords = {Giant cell arteritis; Age; Red cell distribution width; Mediation
   analyses; Machine learning},
Keywords-Plus = {RATES},
