@article{ WOS:000826631800001,
Author = {Wang, Yizhuo and Flowers, Christopher R. and Li, Ziyi and Huang, Xuelin},
Title = {CondiS web app: imputation of censored lifetimes for machine
   learning-based survival analysis},
Journal = {BIOINFORMATICS},
Year = {2022},
Volume = {38},
Number = {17},
Pages = {4252-4254},
Month = {SEP 2},
Abstract = {In the era of big data, machine learning techniques are widely applied
   to every area in biomedical research including survival analysis. It is
   well recognized that censoring, which is a common missing issue in
   survival time data, hampers the direct usage of these machine learning
   techniques. Here, we present CondiS, a web toolkit with graphical user
   interface to help impute the survival times for censored observations
   and predict the survival times for future enrolled patients. CondiS
   imputes a censored survival time based on its distribution conditional
   on its observed part. When covariates are available, CondiS-X
   incorporates this information to further increase the imputation
   accuracy. Users can also upload data of newly enrolled patients and
   predict their survival times. As the first web-app tool with an
   imputation function for censored lifetime data, CondiS web can
   facilitate conducting survival analysis with machine learning
   approaches.},
Type = {Article},
Affiliation = {Li, ZY; Huang, XL (Corresponding Author), Univ Texas MD Anderson Canc Ctr, Dept Biostat, Houston, TX 77030 USA.
   Wang, Yizhuo; Li, Ziyi; Huang, Xuelin, Univ Texas MD Anderson Canc Ctr, Dept Biostat, Houston, TX 77030 USA.
   Flowers, Christopher R., Univ Texas MD Anderson Canc Ctr, Dept Lymphoma Myeloma, Houston, TX 77030 USA.},
DOI = {10.1093/bioinformatics/btac461},
EarlyAccessDate = {JUL 2022},
Keywords-Plus = {NETWORKS},
Author-Email = {zli16@mdanderson.org
   xlhuang@mdanderson.org},
Number-of-Cited-References = {16},
