}

@article{ WOS:000653450500002,
Author = {Wilson, Christopher M. and Li, Kaiqiao and Sun, Qiang and Kuan, Pei Fen
   and Wang, Xuefeng},
Title = {Fenchel duality of Cox partial likelihood with an application in
   survival kernel learning},
Journal = {ARTIFICIAL INTELLIGENCE IN MEDICINE},
Year = {2021},
Volume = {116},
Month = {JUN},
Abstract = {The Cox proportional hazard model is one of the most widely used methods
   in modeling time-to-event data in the health sciences. Due to the
   simplicity of the Cox partial likelihood function, many machine learning
   algorithms use it for survival data. However, due to the nature of
   censored data, the optimization problem becomes intractable when more
   complicated regularization is employed, which is necessary when dealing
   with high dimensional omic data. In this paper, we show that a convex
   conjugate function of the Cox loss function based on Fenchel duality
   exists, and provide an alternative framework to optimization based on
   the primal form. Furthermore, the dual form suggests an efficient
   algorithm for solving the kernel learning problem with censored survival
   outcomes. We illustrate performance and properties of the derived
   duality form of Cox partial likelihood loss in multiple kernel learning
   problems with simulated and the Skin Cutaneous Melanoma TCGA datasets.},
Type = {Article},
Affiliation = {Wang, XF (Corresponding Author), H Lee Moffitt Canc Ctr \& Res Inst, Dept Biostat \& Bioinformat, Tampa, FL 33612 USA.
   Wilson, Christopher M.; Wang, Xuefeng, H Lee Moffitt Canc Ctr \& Res Inst, Dept Biostat \& Bioinformat, Tampa, FL 33612 USA.
   Li, Kaiqiao; Kuan, Pei Fen, SUNY Stony Brook, Dept Appl Math \& Stat, Stony Brook, NY 11794 USA.
   Sun, Qiang, Univ Toronto, Dept Stat Sci, Toronto, ON M5S 3G3, Canada.},
DOI = {10.1016/j.artmed.2021.102077},
EarlyAccessDate = {MAY 2021},
Article-Number = {102077},
Keywords = {Convex conjugate; Cox model; Convex optimization; Multiple kernel
   learning; Fenchel dual; Survival data},
Keywords-Plus = {VARIABLE SELECTION; MODELS; REGULARIZATION; PROGRESSION; EFFICIENCY;
   LASSO},
Author-Email = {xuefeng.wang@moffitt.org},
Number-of-Cited-References = {43},
