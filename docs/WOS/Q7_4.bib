   Wang, Zhishan; Liao, Hai, Guangxi Med Univ, Canc Hosp, Dept Radiol, Nanning, Peoples R China.
   Gu, Ruozhen, KnowX Tech Inc, Toronto, ON, Canada.
   Zhang, Yuqin, Ningbo Univ, Dept Radiol, Affiliated Lihuili Hosp, Ningbo, Peoples R China.},
DOI = {10.1186/s13244-025-02009-2},
