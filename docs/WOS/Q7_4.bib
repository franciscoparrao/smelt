   Vazquez-Benitez, Gabriela; O'Connor, Patrick J., HealthPartners Inst Educ \& Res, Mailstop 23301A,POB 1524, Minneapolis, MN 55440 USA.},
DOI = {10.1016/j.jbi.2016.03.009},
Keywords = {Censored data; Electronic health data; Inverse probability weighting;
   Machine learning; Risk prediction; Survival analysis},
Keywords-Plus = {CARDIOVASCULAR RISK PREDICTION; BAYESIAN NETWORKS; SURVIVAL-DATA;
   REGRESSION; VALIDATION; ALGORITHMS; SYSTEM},
Author-Email = {vock@umn.edu
