   Liu, Xiaoxia, Dongtai Peoples Hosp, Dept Infect Dis, Dongtai City 224200, Jiangsu, Peoples R China.},
DOI = {10.1016/j.compbiolchem.2025.108700},
EarlyAccessDate = {OCT 2025},
