   Tang, Tingting, Hangzhou Normal Univ, Affiliated Hosp, Dept Hematol \& Oncol, Hangzhou 310015, Zhejiang, Peoples R China.
   Wang, Jianjun, Hangzhou Normal Univ, Affiliated Hosp, Dept Pneumol, Hangzhou 310015, Zhejiang, Peoples R China.},
DOI = {10.1016/j.ejso.2025.109729},
