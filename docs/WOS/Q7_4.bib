   Wang, Hong, Cent South Univ, Sch Informat Sci \& Engn, Changsha, Hunan, Peoples R China.},
DOI = {10.1016/j.artmed.2017.06.005},
Keywords = {Survival ensemble; Random forest; Time-to-event data; Censored data;
   Space extension},
Keywords-Plus = {PROPORTIONAL HAZARDS MODEL; REGULARIZED ESTIMATION; VARIABLE SELECTION;
   VALIDATION; REGRESSION},
Author-Email = {wh@csu.edu.cn
