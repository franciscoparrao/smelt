   survival forest},
Keywords-Plus = {FUNCTIONAL-ACTIVITIES QUESTIONNAIRE; MILD COGNITIVE IMPAIRMENT;
   PROGRESSION; DEMENTIA; EPIDEMIOLOGY; DIAGNOSIS},
Author-Email = {l.tapak@umsha.ac.ir},
