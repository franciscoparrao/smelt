Affiliation = {Softic, S (Corresponding Author), CAMPUS 02 Univ Appl Sci, IT \& Business Informat, Graz, Austria.
   Softic, S., CAMPUS 02 Univ Appl Sci, IT \& Business Informat, Graz, Austria.
   Hrnjica, B., Univ Bihac, Fac Tech Engn, Bihac, Bosnia \& Herceg.},
