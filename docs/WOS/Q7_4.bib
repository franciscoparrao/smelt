   Friedlander, Paul L., Tulane Univ, Dept Otolaryngol, Sch Med, New Orleans, LA 70112 USA.
   Abdel-Mageed, Asim B., Tulane Univ, Dept Urol, Sch Med, New Orleans, LA 70112 USA.},
DOI = {10.1016/j.surg.2019.06.058},
Keywords-Plus = {BRAF MUTATION; SIZE; WELL},
