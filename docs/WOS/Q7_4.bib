   Li, Jiaxin, Anyang Univ, Anyang 455000, Peoples R China.
   You, Liuxia, Fujian Med Univ, Affiliated Hosp 2, Quanzhou 362000, Fujian, Peoples R China.},
DOI = {10.1038/s41598-024-53145-6},
Article-Number = {5273},
Keywords-Plus = {CANCER STATISTICS; HEAD},
