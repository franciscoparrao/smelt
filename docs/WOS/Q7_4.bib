   Shao, Yanping, Taizhou Hosp Zhejiang, Prov affiliated Wenzhou Med Univ, Dept Hematol, Taizhou, Peoples R China.},
DOI = {10.3389/fimmu.2022.1040661},
Article-Number = {1040661},
Keywords = {acute myeloid leukemia; TRP; signature; schip1; machine learning},
Keywords-Plus = {TRP CHANNELS; MICROARRAY; SET},
