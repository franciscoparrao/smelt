Author = {Nguyen, Thanh Dat and Nguyen, Quynh-Mai Thi and Nguyen, Tuong Van and
   Bui, Phuong Thi and Nguyen, Kim Nhuong Thi and Nguyen, Minh Nam},
Title = {Prediction of Lung Metastasis in Breast Cancer Patients Using Machine
