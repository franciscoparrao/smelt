@incollection{ WOS:000387730800013,
Author = {Minn, Sein and Desmarais, Michel C. and Fu, ShunKai},
Editor = {Verbert, K and Sharples, M and Klobucar, T},
Title = {ERefinement of a Q-matrix with an Ensemble Technique Based on
   Multi-label Classification Algorithms},
Booktitle = {ADAPTIVE AND ADAPTABLE LEARNING, EC-TEL 2016},
Series = {Lecture Notes in Computer Science},
Year = {2016},
Volume = {9891},
Pages = {165-178},
Abstract = {There are numerous algorithms and tools to help an expert map exercises
   and tasks to underlying skills. The last decade has witnessed a wealth
   of data driven approaches aiming to refine expert-defined mappings of
   tasks to skill. This refinement can be seen as a classification problem:
   for each possible mapping of task to skill, the classifier has to decide
   whether the expert's advice is correct, or incorrect. Whereas most
   algorithms are working at the level of individual mappings, we introduce
   an approach based on a multi-label classification algorithm that is
   trained on the mapping of a task to all skills simultaneously. The
   approach is shown to outperform the existing task to skill mapping
   refinement techniques.},
Type = {Proceedings Paper},
Affiliation = {Minn, S (Corresponding Author), Polytech Montreal, Montreal, PQ, Canada.
   Minn, Sein; Desmarais, Michel C., Polytech Montreal, Montreal, PQ, Canada.
   Fu, ShunKai, Huaqiao Univ, Quanzhou, Peoples R China.},
DOI = {10.1007/978-3-319-45153-4\_13},
Keywords = {Student model; Skills modeling; Psychometrics; Q-matrix validation;
   Multi-label skills assessment},
Keywords-Plus = {COGNITIVE DIAGNOSIS; DINA MODEL},
Author-Email = {sein.minn@polymtl.ca
   michel.desmarais@polymtl.ca
   fusk@hqu.edu.cn},
Number-of-Cited-References = {19},
Times-Cited = {2},
Unique-ID = {WOS:000387730800013},
}

@article{ WOS:000365582600004,
Author = {Li, Peipei and Wu, Xindong and Hu, Xuegang and Wang, Hao},
Title = {AN INCREMENTAL DECISION TREE FOR MINING MULTILABEL DATA},
Journal = {APPLIED ARTIFICIAL INTELLIGENCE},
Year = {2015},
Volume = {29},
Number = {10},
Pages = {992-1014},
Month = {NOV 26},
Abstract = {Mining with multilabel data is a popular topic in data mining. When
   performing classification on multilabel data, existing methods using
   traditional classifiers, such as support vector machines (SVMs),
   k-nearest neighbor (k-NN), and decision trees, have relatively poor
   accuracy and efficiency. Motivated by this, we present a new algorithm
   adaptation method, namely, a decision tree-based method for multilabel
   classification in domains with large-scale data sets called decision
   tree for multi-label classification (DTML). We build an incremental
   decision tree to reduce the learning time and divide the training data
   and adopt the k-NN classifier at leaves to improve the classification
   accuracy. Extensive studies show that our algorithm can efficiently
   learn from multilabel data while maintaining good performance on
   example-based evaluation metrics compared to nine state-of-the-art
   multilabel classification methods. Thus, we draw a conclusion that we
   provide an efficient and effective incremental algorithm adaptation
   method for multilabel classification especially in domains with
   large-scale multilabel data.},
Type = {Article},
Affiliation = {Wang, H (Corresponding Author), Hefei Univ Technol, Dept Comp Sci \& Informat Engn, Tunxi Rd 293, Hefei 230009, Anhui, Peoples R China.
   Li, Peipei; Hu, Xuegang; Wang, Hao, Hefei Univ Technol, Dept Comp Sci \& Informat Engn, Hefei 230009, Anhui, Peoples R China.
   Wu, Xindong, Univ Vermont, Dept Comp Sci, Burlington, VT USA.},
DOI = {10.1080/08839514.2015.1097154},
Author-Email = {jsjxwangh@hfut.edu.cn},
Number-of-Cited-References = {27},
Times-Cited = {2},
Unique-ID = {WOS:000365582600004},
}

@incollection{ WOS:000381029800140,
Author = {Burkhardt, Sophie and Kramer, Stefan},
Editor = {Shin, D},
Title = {On the Spectrum between Binary Relevance and Classifier Chains in
   Multi-Label Classification},
Booktitle = {30TH ANNUAL ACM SYMPOSIUM ON APPLIED COMPUTING, VOLS I AND II},
Year = {2015},
Pages = {885-892},
Abstract = {Two fundamental and prominent methods for multi-label classification,
   Binary Relevance (BR) and Classifier Chains (CC), are usually considered
   to be distinct methods without direct relationship. However, BR and CC
   can be generalized to one single method: blockwise classifier chains
   (BCC), where labels within a block (i.e. a group of labels of fixed
   size) are predicted independently as in BR but then combined to predict
   the next block's labels as in CC. In other words, only the blocks are
   connected in a chain. BR is then a special case of BCC with a block size
   equal to the number of labels, and CC a special case with a block size
   equal to one. The rationale behind BCC is to limit the propagation of
   errors made by inaccurate classifiers early in the chain, which should
   be alleviated by the expected block effect. Another, yet different
   generalization is based on the divide-and-conquer principle, not error
   propagation, but fails to exhibit the desired block effect. Ensembles of
   BCC are also discussed and experiments confirm that their performance is
   on par with ensembles of CC. Further experiments show the effect of the
   block size, in particular with respect to the performance of the two
   extremes, BR and CC. As it turns out, some regions of the block size
   parameter space lead to degraded performance, whereas others improve
   performance to a noticeable but modest extent.},
Type = {Proceedings Paper},
Affiliation = {Burkhardt, S (Corresponding Author), Inst Comp Sci, Staudingerweg 9, D-55128 Mainz, Germany.
   Burkhardt, Sophie; Kramer, Stefan, Inst Comp Sci, Staudingerweg 9, D-55128 Mainz, Germany.},
DOI = {10.1145/2695664.2695854},
Author-Email = {burkhardt@informatik.uni-mainz.de
   kramer@informatik.uni-mainz.de},
Number-of-Cited-References = {12},
Times-Cited = {2},
Unique-ID = {WOS:000381029800140},
}

@incollection{ WOS:000380547600003,
Author = {Iyer, V. and Shetty, S. and Iyengar, S. S.},
Editor = {Yang, C and Clarke, K and Yuan, M and Yu, M and Li, M and Guan, W and Sun, M and Huang, B},
Title = {STATISTICAL METHODS IN AI: RARE EVENT LEARNING USING ASSOCIATIVE RULES
   AND HIGHER-ORDER STATISTICS},
Booktitle = {ISPRS INTERNATIONAL WORKSHOP ON SPATIOTEMPORAL COMPUTING},
Year = {2015},
Pages = {119-130},
Abstract = {Rare event learning has not been actively researched since lately due to
   the unavailability of algorithms which deal with big samples. The
   research addresses spatio-temporal streams from multi-resolution sensors
   to find actionable items from a perspective of real-time algorithms.
   This computing framework is independent of the number of input samples,
   application domain, labelled or label-less streams. A sampling overlap
   algorithm such as Brooks-Iyengar is used for dealing with noisy sensor
   streams. We extend the existing noise pre-processing algorithms using
   Data-Cleaning trees. Pre-processing using ensemble of trees using
   bagging and multi-target regression showed robustness to random noise
   and missing data. As spatio-temporal streams are highly statistically
   correlated, we prove that a temporal window based sampling from sensor
   data streams converges after n samples using Hoeffding bounds. Which can
   be used for fast prediction of new samples in real-time. The
   Data-cleaning tree model uses a nonparametric node splitting technique,
   which can be learned in an iterative way which scales linearly in memory
   consumption for any size input stream. The improved task based ensemble
   extraction is compared with non-linear computation models using various
   SVM kernels for speed and accuracy. We show using empirical datasets the
   explicit rule learning computation is linear in time and is only
   dependent on the number of leafs present in the tree ensemble. The use
   of unpruned trees (t) in our proposed ensemble always yields minimum
   number (m) of leafs keeping pre-processing computation to n x t log m
   compared to N-2 for Gram Matrix. We also show that the task based
   feature induction yields higher Qualify of Data (QoD) in the feature
   space compared to kernel methods using Gram Matrix.},
Type = {Proceedings Paper},
Affiliation = {Iyer, V (Corresponding Author), Tennessee State Univ, Elect \& Comp Engn, Nashville, TN 37210 USA.
   Iyer, V.; Shetty, S., Tennessee State Univ, Elect \& Comp Engn, Nashville, TN 37210 USA.
   Iyengar, S. S., Florida Int Univ, Sch Comp \& Informat Sci, Miami, FL 33199 USA.},
DOI = {10.5194/isprsannals-II-4-W2-119-2015},
Keywords = {Hoeffding Bounds; Big Samples; Trajectories; Spatio-Temporal Mining;
   Statistical Methods; Overlap-Function; AI And Kernel Methods; Random
   Forest Ensembles},
Author-Email = {viyer@tnstate.edu
   sshetty@tnstate.edu
   iyengar@cis.fiu.edu},
Number-of-Cited-References = {26},
Times-Cited = {2},
Unique-ID = {WOS:000380547600003},
}

@article{ WOS:000327353700005,
Author = {Gjorgjevikj, Dejan and Madjarov, Gjorgji and Dzeroski, Saso},
Title = {HYBRID DECISION TREE ARCHITECTURE UTILIZING LOCAL SVMs FOR EFFICIENT
   MULTI-LABEL LEARNING},
Journal = {INTERNATIONAL JOURNAL OF PATTERN RECOGNITION AND ARTIFICIAL INTELLIGENCE},
Year = {2013},
Volume = {27},
Number = {7},
Month = {NOV},
Abstract = {Multi-label learning (MLL) problems abound in many areas, including text
   categorization, protein function classification, and semantic annotation
   of multimedia. Issues that severely limit the applicability of many
   current machine learning approaches to MLL are the large-scale problem,
   which have a strong impact on the computational complexity of learning.
   These problems are especially pronounced for approaches that transform
   MLL problems into a set of binary classification problems for which
   Support Vector Machines (SVMs) are used. On the other hand, the most
   efficient approaches to MLL, based on decision trees, have clearly lower
   predictive performance. We propose a hybrid decision tree architecture,
   where the leaves do not give multi-label predictions directly, but
   rather utilize local SVM-based classifiers giving multi-label
   predictions. A binary relevance architecture is employed in the leaves,
   where a binary SVM classifier is built for each of the labels relevant
   to that particular leaf. We use a broad range of multi-label datasets
   with a variety of evaluation measures to evaluate the proposed method
   against related and state-of-the-art methods, both in terms of
   predictive performance and time complexity. Our hybrid architecture on
   almost every large classification problem outperforms the competing
   approaches in terms of the predictive performance, while its
   computational efficiency is significantly improved as a result of the
   integrated decision tree.},
Type = {Article},
Affiliation = {Madjarov, G (Corresponding Author), Ss Cyril \& Methodius Univ, Fac Comp Sci \& Engn, Rudgjer Boshkovikj 16, Skopje 1000, Macedonia.
   Gjorgjevikj, Dejan; Madjarov, Gjorgji, Ss Cyril \& Methodius Univ, Fac Comp Sci \& Engn, Skopje 1000, Macedonia.
   Dzeroski, Saso, Jozef Stefan Inst, Dept Knowledge Technol, Ljubljana 1000, Slovenia.},
DOI = {10.1142/S021800141351004X},
Article-Number = {1351004},
Keywords = {Multi-label; learning; hybrid; architecture; decision tree; SVM},
Keywords-Plus = {SUPPORT VECTOR MACHINES; CLASSIFICATION},
Author-Email = {dejan.gjorgevikj@finki.ukim.mk
   gjorgji.madjarov@finki.ukim.mk
   saso.dzeroski@ijs.si},
Number-of-Cited-References = {62},
Times-Cited = {2},
Unique-ID = {WOS:000327353700005},
}
