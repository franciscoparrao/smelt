Keywords = {TBM performance prediction; Graph convolutional networks; Attention
   mechanism; Multi-output regression; Tunnel excavation},
Keywords-Plus = {NEURAL-NETWORKS},
Author-Email = {panyue001@sjtu.edu.cn
