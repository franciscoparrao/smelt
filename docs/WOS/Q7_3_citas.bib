@article{ WOS:000403119400011,
Author = {Tehrani, Ali Fallah and Ahrens, Diane},
Title = {Modeling label dependence for multi-label classification using the
   Choquistic regression},
Journal = {PATTERN RECOGNITION LETTERS},
Year = {2017},
Volume = {92},
Pages = {75-80},
Month = {JUN 1},
Abstract = {While an incorrect identification of underlying dependency in data can
   lead to a flawed conclusion, recognizing legitimate dependency allows
   for the opportunity to adapt a model in a correct manner. In this
   regard, modeling the inter-dependencies in multi-label classification
   (multi target prediction) is one of the challenging tasks from a machine
   learning point of view. While common approaches seek to exploit
   so-called correlated information from labels, this can be improved by
   assuming the interactions between labels. A well-known tool to model the
   interaction between attributes is the Choquet integral; it enables one
   to model non-linear dependencies between attributes. Beyond identifying
   proper prior knowledge in data (if such knowledge exists), establishing
   suitable models that are in agreement with prior knowledge is not always
   a trivial task. In this paper, we propose a first step towards modeling
   label dependencies for multi-target classifications in terms of positive
   and negative interactions. In the experimental, we demonstrate real
   gains by applying this approach. (C) 2017 Elsevier B.V. All rights
   reserved.},
Type = {Article},
Affiliation = {Tehrani, AF (Corresponding Author), Deggendorf Inst Technol, Technol Campus Grafenau, Deggendorf, Germany.
   Tehrani, Ali Fallah; Ahrens, Diane, Deggendorf Inst Technol, Technol Campus Grafenau, Deggendorf, Germany.},
DOI = {10.1016/j.patrec.2017.04.018},
Keywords = {Choquet integral; Choquistic regression; Label interaction; Label
   dependence; Multi-label classification},
Keywords-Plus = {ENSEMBLE},
Author-Email = {ali.fallahtehrani@th-deg.de},
Number-of-Cited-References = {24},
Times-Cited = {4},
Unique-ID = {WOS:000403119400011},
}

@incollection{ WOS:000722629000019,
Author = {Mileski, Vanja and DZeroski, Saso and Kocev, Dragi},
Editor = {Adams, N and Tucker, A and Weston, D},
Title = {Predictive Clustering Trees for Hierarchical Multi-Target Regression},
Booktitle = {ADVANCES IN INTELLIGENT DATA ANALYSIS XVI, IDA 2017},
Series = {Lecture Notes in Computer Science},
Year = {2017},
Volume = {10584},
Pages = {223-234},
Abstract = {Multi-target regression (MTR) is the task of learning predictive models
   for problems with multiple continuous target variables. In this work, we
   introduce the task of hierarchical multi-target regression (HMTR), where
   these target variables are organized in a hierarchy. The hierarchy
   contains the target variables and has an aggregation function that
   defines the parent child relationships in the hierarchy. This
   information can be used by learning methods to obtain better predictive
   models. We then propose to extend the approach of predictive clustering
   trees for MTR towards addressing the task of HMTR. The information from
   the hierarchy is exploited by defining the variance function through a
   weighted Euclidean distance. We evaluate the proposed method on 4
   practically relevant HMTR datasets. The results show that HMTR performs
   better than standard MTR. Finally, we illustrate the enhanced
   interpretability potential of PCTs for HMTR.},
Type = {Proceedings Paper},
Affiliation = {Mileski, V (Corresponding Author), Jozef Stefan Inst, Dept Knowledge Technol, Ljubljana, Slovenia.
