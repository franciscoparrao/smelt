   Nakano, Felipe Kenji; Vens, Celine, Katholieke Univ Leuven, Itec, imec Res Grp, Etienne Sabbelaan 53, B-8500 Kortrijk, Belgium.},
DOI = {10.1016/j.compbiomed.2022.106423},
EarlyAccessDate = {DEC 2022},
Article-Number = {106423},
Keywords = {Detecting missing annotations; Hierarchical multi -label classification;
   Structured output prediction; Gene function prediction; Gene ontology
