}

@incollection{ WOS:000391925900029,
Author = {Hai Vu and Tachtatzis, Christos and Murray, Paul and Harle, David and
   Trung Kien Dao and Thi-Lan Le and Andonovic, Ivan and Marshall, Stephen},
Editor = {Cao, T and Ho, YS},
Title = {Spatial and Spectral Features Utilization on a HyperSpectral Imaging
   System for Rice Seed Varietal Purity Inspection},
Booktitle = {2016 IEEE RIVF INTERNATIONAL CONFERENCE ON COMPUTING \& COMMUNICATION
   TECHNOLOGIES, RESEARCH, INNOVATION, AND VISION FOR THE FUTURE (RIVF)},
Year = {2016},
Pages = {169-174},
Abstract = {A conventional method to inspect the varietal purity of rice seeds is
   based on human visual inspection where a random sample is drawn from a
   batch. This is a tedious, laborious, time consuming and extremely
   inefficient task. This paper presents an automatic rice seed inspection
   method using Hyperspectral imaging and machine learning, to
   automatically detect unwanted seeds from other varieties which may be
   contained in a batch. Hyperspectral image data from Near-infrared (NIR)
