   Liang, Shunlin, Univ Hong Kong, Dept Geog, Hong Kong 999077, Peoples R China.},
DOI = {10.1016/j.rse.2022.113132},
EarlyAccessDate = {JUN 2022},
Article-Number = {113132},
Keywords = {Machine learning; Random forest regression; Multiple variables;
   Radiative transfer models (RTMs); VIIRS product},
Keywords-Plus = {LEAF-AREA INDEX; CARBON-DIOXIDE; S-NPP; SURFACE; ALBEDO; REFLECTANCE;
   VALIDATION; SENTINEL-2; RETRIEVAL; FLUXNET},
Author-Email = {mahanrs@whu.edu.cn
   sliang@umd.edu},
