Keywords = {AdaBoostSeq; Structured Output Learning; Structured Output Prediction;
   Structured Prediction; Multi-label classification; Sequence Prediction;
   Sequential Output Prediction; Ensemble Method; Classifier Fusion;
   Classification},
Author-Email = {tomasz.kajdanowicz@pwr.wroc.pl
   kazienko@pwr.wroc.pl},
Number-of-Cited-References = {28},
