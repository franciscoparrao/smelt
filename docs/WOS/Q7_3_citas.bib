   Wang, Hua Sheng, Queen Mary Univ London, Sch Engn \& Mat Sci, Mile End Rd, London E1 4NS, England.},
DOI = {10.1016/j.scs.2025.106208},
EarlyAccessDate = {FEB 2025},
Article-Number = {106208},
Keywords = {Urban design; CFD simulation; Machine learning; Wind environment;
   Pollution dispersion; Pedestrian comfort; Wind load},
Keywords-Plus = {THERMAL POWER-PLANTS; SIMULATION; DISPERSION; BUILDINGS; SAFETY; MODEL},
Author-Email = {baitureyeva.aiymzhan@gmail.com},
Number-of-Cited-References = {83},
