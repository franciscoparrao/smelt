   Hu, Xiaolan, Xiamen Univ, Coll Mat, Siming South Rd 422, Xiamen 361005, Fujian, Peoples R China.},
DOI = {10.1177/14759217241270792},
EarlyAccessDate = {SEP 2024},
Keywords = {Bolted joints; loosening; crack; piezoelectric ultrasonic guided wave;
   machine learning},
Author-Email = {sunhu@xmu.edu.cn
   xlhu@xmu.edu.cn},
Number-of-Cited-References = {34},
