DOI = {10.1016/j.matcom.2023.07.032},
EarlyAccessDate = {MAY 2024},
Keywords = {Multi-label feature selection; q-rung orthopair fuzzy set; Ridge
   regression; CODAS algorithm},
Keywords-Plus = {SUPPORT VECTOR MACHINE; TRANSFORMATION; ENSEMBLE},
Author-Email = {j.satheesh@buc.edu.in},
Number-of-Cited-References = {60},
