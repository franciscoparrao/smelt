   Lu, Ai-Ping; Cao, Dong-Sheng, Hong Kong Baptist Univ, Inst Adv Translat Med Bone \& Joint Dis, Sch Chinese Med, Hong Kong, Hong Kong, Peoples R China.},
DOI = {10.1007/s10822-016-9915-2},
