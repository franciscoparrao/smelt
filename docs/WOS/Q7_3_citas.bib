DOI = {10.1016/j.iot.2020.100324},
Article-Number = {100324},
Keywords = {Activity recognition; Classifier chain; Ensemble learning; Multi-label
   classification; Smart home},
Keywords-Plus = {SYSTEM; SENSOR},
