Keywords = {Photovoltaic systems; Compound faults; Multi-label learning; Fault
   diagnosis; I-V curves},
Keywords-Plus = {NEURAL-NETWORK; INTELLIGENT},
Author-Email = {kjzhang@seu.edu.cn},
Number-of-Cited-References = {42},
