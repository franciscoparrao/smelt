   Deng, Nai-Yang, China Agr Univ, Coll Sci, Beijing 100083, Peoples R China.},
DOI = {10.1016/j.patcog.2015.10.008},
Keywords = {Multi-label classification; Support vector machines; Twin support vector
   machines; Quadratic programming; Successive overrelaxation},
Keywords-Plus = {CLASSIFICATION; ENSEMBLE; SVM},
Author-Email = {wjcper2008@126.com
