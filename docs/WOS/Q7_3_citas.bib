   Cai, Hengfan; Wang, Yanjun; Lin, Yunhao; Li, Shaochun; Wang, Mengjie; Teng, Fei, Hunan Univ Sci \& Technol, Sch Earth Sci \& Spatial Informat Engn, Xiangtan 411201, Peoples R China.},
DOI = {10.3390/electronics11193041},
