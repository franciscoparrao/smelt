   Bermak, Amine, Hong Kong Univ Sci \& Technol, Dept Elect \& Comp Engn, Hong Kong, Peoples R China.
   Bermak, Amine, Hamad Bin Khalifa Univ, Coll Sci \& Engn, Doha, Qatar.},
DOI = {10.1109/ACCESS.2019.2892754},
Keywords = {Mixture gases recognition; deep convolutional neural network;
   multi-label classification},
Keywords-Plus = {ELECTRONIC NOSE},
Author-Email = {eexpan@szu.edu.cn},
Number-of-Cited-References = {22},
