Keywords = {Data-driven models; Multiple target regression; Sustainable
   manufacturing; Waste valorisation; Process manufacturing; Digital
   manufacturing},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORKS; SUPPORT VECTOR REGRESSION; SYSTEMS;
   OPTIMIZATION; PERFORMANCE; GENERATION; FRAMEWORK; INDEX; TREES; ANN},
