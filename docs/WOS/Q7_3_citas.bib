   Li, Guozheng, China Acad Chinese Med Sci, Data Ctr Tradit Chinese Med, Beijing 100700, Peoples R China.
   Zhang, Lei, China Acad Chinese Med Sci, Inst Basic Res Clin Med, Beijing 100700, Peoples R China.},
DOI = {10.1109/ACCESS.2019.2931035},
Keywords = {Bioinformatics; multi-label learning; embedded feature selection},
Keywords-Plus = {SUBCELLULAR-LOCALIZATION; VIRUS PROTEINS; INFORMATION; PREDICTION},
