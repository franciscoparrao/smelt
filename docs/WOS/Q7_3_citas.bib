   Abilio, Ramon, Inst Fed Sao Paulo, Capivari, Brazil.
   Abilio, Ramon, Univ Estadual Campinas, Programa Posgrad Tecnol, Limeira, Brazil.
   Koerich, Alessandro Lameiras, Univ Quebec, Ecole Technol Super, Montreal, PQ, Canada.
   Britto Jr, Alceu de souza, Univ Estadual Ponta Grossa, Ponta Grossa, Brazil.},
DOI = {10.1145/3704922},
Article-Number = {27},
Keywords = {Concept drift; text stream mining; semantic shift; representation shift;
   drift detection},
Keywords-Plus = {MULTI-LABEL CLASSIFICATION; DYNAMIC ENVIRONMENTS; RECURRING CONTEXTS;
   TOPIC MODEL; ONLINE; CLASSIFIERS; FRAMEWORK; ENSEMBLE; DISTANCE},
Author-Email = {cristiano.garcia@ifsc.edu.br
   ramon.abilio@ifsp.edu.br
   alessandro.lameiraskoerich@etsmtl.ca
   alceu@ppgia.pucpr.br
