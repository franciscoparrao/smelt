   Yang, Simon X., Univ Guelph, Adv Robot \& Intelligent Syst ARIS Lab, Sch Engn, Guelph, ON N1G 2W1, Canada.},
DOI = {10.1109/ACCESS.2019.2913428},
Keywords = {Disease prognosis; first hitting time; gradient boosting decision tree;
