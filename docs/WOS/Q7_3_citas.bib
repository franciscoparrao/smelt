}

@article{ WOS:000475306200021,
Author = {Wu, Xin and Gao, Yuchen and Jiao, Dian},
Title = {Multi-Label Classification Based on Random Forest Algorithm for
   Non-Intrusive Load Monitoring System},
Journal = {PROCESSES},
Year = {2019},
Volume = {7},
Number = {6},
Month = {JUN},
Abstract = {Non-intrusive load monitoring (NILM) is an effective method to optimize
   energy consumption patterns. Since the concept of NILM was proposed,
   extensive research has focused on energy disaggregation or load
   identification. The traditional method is to disaggregate mixed signals,
   and then identify the independent load. This paper proposes a
   multi-label classification method using Random Forest (RF) as a learning
   algorithm for non-intrusive load identification. Multi-label
   classification can be used to determine which categories data belong to.
   This classification can help to identify the operation states of
   independent loads from mixed signals without disaggregation. The
   experiments are conducted in real environment and public data set
   respectively. Several basic electrical features are selected as the
   classification feature to build the classification model. These features
   are also compared to select the most suitable features for
   classification by feature importance parameters. The classification
   accuracy and F-score of the proposed method can reach 0.97 and 0.98,
   respectively.},
Type = {Article},
Affiliation = {Gao, YC (Corresponding Author), North China Elect Power Univ, Sch Elect \& Elect Engn, Beijing 102206, Peoples R China.
   Wu, Xin; Gao, Yuchen; Jiao, Dian, North China Elect Power Univ, Sch Elect \& Elect Engn, Beijing 102206, Peoples R China.},
DOI = {10.3390/pr7060337},
Article-Number = {337},
Keywords = {non-intrusive load monitoring; multi-label classification; random forest},
Keywords-Plus = {IDENTIFICATION; DISAGGREGATION; RECOGNITION; MANAGEMENT; TREES; HOME},
Author-Email = {wuxin07@ncepu.edu.cn
