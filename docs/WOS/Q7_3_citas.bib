   Lee, Tsung-Ju, Feng Chia Univ, Dept Finance, Taichung 40724, Taiwan.},
DOI = {10.1109/ACCESS.2020.2976851},
Keywords = {Clustering algorithms; Classification algorithms; Partitioning
   algorithms; Internet of Things; Machine learning; Sensors; Decision
   trees; Clustering; generalized linear mixed model (GLMM); meta-learning;
   multi-label classification},
Keywords-Plus = {ENSEMBLE},
Author-Email = {freeman.tjlee@mail.fcu.edu.tw},
Number-of-Cited-References = {37},
Times-Cited = {18},
