   Tao, Zhifu, Anhui Univ, Sch Big Data \& Stat, 111 Jiulong Rd, Hefei 230601, Anhui, Peoples R China.},
DOI = {10.1016/j.eneco.2022.106502},
EarlyAccessDate = {JAN 2023},
Article-Number = {106502},
Keywords = {Carbon price forecasting; Interval time series; Combination of interval
   variables; ICEEMDAN; I-ksigma},
Keywords-Plus = {DECOMPOSITION; PREDICTION; MARKET; CHINA; COMBINATION; REGRESSION;
