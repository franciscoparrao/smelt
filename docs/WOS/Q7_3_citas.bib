Unique-ID = {WOS:000426939700012},
}

@article{ WOS:000386052400006,
Author = {Aniceto, Natalia and Freitas, Alex A. and Bender, Andreas and
   Ghafourian, Taravat},
Title = {Simultaneous Prediction of four ATP-binding Cassette Transporters'
   Substrates Using Multi-label QSAR},
Journal = {MOLECULAR INFORMATICS},
Year = {2016},
Volume = {35},
Number = {10},
Pages = {514-528},
Month = {OCT},
Abstract = {Efflux by the ATP-binding cassette (ABC) transporters affects the
   pharmacokinetic profile of drugs and it has been implicated in drug-drug
   interactions as well as its major role in multi-drug resistance in
   cancer. It is therefore important for the pharmaceutical industry to be
   able to understand what phenomena rule ABC substrate recognition.
   Considering a high degree of substrate overlap between various members
   of ABC transporter family, it is advantageous to employ a multi-label
   classification approach where predictions made for one transporter can
   be used for modeling of the other ABC transporters. Here, we present
   decision tree-based QSAR classification models able to simultaneously
   predict substrates and non-substrates for BCRP1, P-gp/MDR1 and MRP1 and
   MRP2, using a dataset of 1493 compounds. To this end, two multi-label
   classification QSAR modelling approaches were adopted: Binary Relevance
   (BR) and Classifier Chain (CC). Even though both multi-label models
   yielded similar predictive performances in terms of overall accuracies
   (close to 70\%), the CC model overcame the problem of skewed performance
   towards identifying substrates compared with non-substrates, which is a
   common problem in the literature. The models were thoroughly validated
   by using external testing, applicability domain and activity cliffs
   characterization. In conclusion, a multi-label classification approach
   is an appropriate alternative for the prediction of ABC efflux.},
Type = {Article},
Affiliation = {Ghafourian, T (Corresponding Author), Univ Sussex, Sch Life Sci, JMS Bldg, Brighton BN1 9QG, E Sussex, England.
   Aniceto, Natalia, Univ Kent, Medway Sch Pharm, Anson Bldg,Cent Ave, Chatham ME4 4TB, Kent, England.
   Aniceto, Natalia, Univ Greenwich, Medway Sch Pharm, Anson Bldg,Cent Ave, Chatham ME4 4TB, Kent, England.
   Freitas, Alex A., Univ Kent, Sch Comp, Canterbury CT2 7NF, Kent, England.
   Bender, Andreas, Univ Cambridge, Dept Chem, Ctr Mol Sci Informat, Lensfield Rd, Cambridge CB2 1EW, England.
   Ghafourian, Taravat, Univ Sussex, Sch Life Sci, JMS Bldg, Brighton BN1 9QG, E Sussex, England.},
DOI = {10.1002/minf.201600036},
Keywords = {Multi-label Classification; QSAR; Transporter; P-glycoprotein;
   Multidrug-resistance Associated Protein; Breast Cancer Resistance
   Protein; BCRP1; MRP1; MRP2},
Keywords-Plus = {FEATURE-SELECTION METHODS; ACTIVITY CLIFFS; P-GP; ABSORPTION; TOXICITY;
