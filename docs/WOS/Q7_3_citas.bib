@incollection{ WOS:000485488901068,
Author = {Kulkarni, Ashish and Uppalapati, Narasimha Raju and Singh, Pankaj and
   Ramakrishnan, Ganesh},
Book-Group-Author = {AAAI},
Title = {An Interactive Multi-Label Consensus Labeling Model for Multiple Labeler
   Judgments},
Booktitle = {THIRTY-SECOND AAAI CONFERENCE ON ARTIFICIAL INTELLIGENCE / THIRTIETH
   INNOVATIVE APPLICATIONS OF ARTIFICIAL INTELLIGENCE CONFERENCE / EIGHTH
   AAAI SYMPOSIUM ON EDUCATIONAL ADVANCES IN ARTIFICIAL INTELLIGENCE},
Series = {AAAI Conference on Artificial Intelligence},
Year = {2018},
Pages = {1479-1486},
Abstract = {Multi-label classification is crucial to several practical applications
   including document categorization, video tagging, targeted advertising
   etc. Training a multi-label classifier requires a large amount of
   labeled data which is often unavailable or scarce. Labeled data is then
   acquired by consulting multiple labelers-both human and machine.
   Inspired by ensemble methods, our premise is that labels inferred with
   high consensus among labelers, might be closer to the ground truth. We
   propose strategies based on interaction and active learning to obtain
   higher quality labels that potentially lead to greater consensus. We
   propose a novel formulation that aims to collectively optimize the cost
   of labeling, labeler reliability, label-label correlation and
   inter-labeler consensus. Evaluation on data labeled by multiple labelers
   (both human and machine) shows that our consensus output is closer to
   the ground truth when compared to the ``majority{''} baseline. We
   present illustrative cases where it even improves over the existing
   ground truth. We also present active learning strategies to leverage our
   consensus model in interactive learning settings. Experiments on several
   real-world datasets (publicly available) demonstrate the efficacy of our
   approach in achieving promising classification results with fewer
   labeled data.},
Type = {Proceedings Paper},
Affiliation = {Kulkarni, A (Corresponding Author), Amazon, Bangalore, Karnataka, India.
   Kulkarni, Ashish, Amazon, Bangalore, Karnataka, India.
   Uppalapati, Narasimha Raju, Samsung R\&D Inst, Bangalore, Karnataka, India.
   Singh, Pankaj, Lokavidya Technol Pvt Ltd, Mumbai, Maharashtra, India.
   Ramakrishnan, Ganesh, Indian Inst Technol, Dept Comp Sci \& Engn, Mumbai, Maharashtra, India.},
Author-Email = {kulashish@gmail.com
   raju.atl007@gmail.com
   pr.pankajsingh@gmail.com
   ganesh@cse.iitb.ac.in},
Number-of-Cited-References = {30},
Times-Cited = {6},
Unique-ID = {WOS:000485488901068},
}

@article{ WOS:000459214900064,
Author = {Moral-Garcia, Serafin and Mantas, Carlos J. and Castellano, Javier G.
   and Abellan, Joaquin},
Title = {Using Credal-C4.5 with Binary Relevance for Multi-Label Classification},
Journal = {JOURNAL OF INTELLIGENT \& FUZZY SYSTEMS},
Year = {2018},
Volume = {35},
Number = {6},
Pages = {6501-6512},
Abstract = {Binary Relevance (BR) is a simple and direct approach to the Multi-Label
   Classification (MLC). It decomposes the multi-label problem into several
   binary problems, one per label. It uses an algorithm of traditional
   supervised classification in order to solve these binary problems. On
   the other hand, Credal C4.5 (CC4.5) is a modification of the classical
   C4.5. CC4.5 estimates the probability of the class variable by using
   imprecise probabilities. In the literature, this new classification
   algorithm has obtained better results than C4.5 when both have been
   applied on datasets with class noise. In MLC, since there are not just a
   class, but multiple labels are disposed, it is more probable that there
   is intrinsic noise than in traditional classification. From the previous
   reasons, in this work it is studied the performance of BR using Credal
   C4.5 as base classifier versus BR with C4.5. It is carried out an
   experimental study with several muti-label datasets and a considerable
   number of measures for MLC. This study shows that the performance of BR
   is improved when it uses CC4.5 as base classifier versus BR with C4.5.
   In consequence, it is probably suitable to apply imprecise probabilities
   in Decision Trees within the MLC field too.},
Type = {Article},
Affiliation = {Moral-García, S (Corresponding Author), Univ Granada, Dept Comp Sci \& Artificial Intelligence, Granada, Spain.
   Moral-Garcia, Serafin; Mantas, Carlos J.; Castellano, Javier G.; Abellan, Joaquin, Univ Granada, Dept Comp Sci \& Artificial Intelligence, Granada, Spain.},
DOI = {10.3233/JIFS-18746},
Keywords = {Multi-label classification; Binary Relevance; Credal C4.5; C4.5;
   imprecise probabilities},
Keywords-Plus = {IMPRECISE PROBABILITIES; DECISION TREES; CLASSIFIERS; PREDICTION;
   ENSEMBLES},
Author-Email = {seramoral@decsai.ugr.es},
Number-of-Cited-References = {28},
Times-Cited = {6},
Unique-ID = {WOS:000459214900064},
}

@incollection{ WOS:000495071900105,
Author = {Sakri, Oumayma and Godin, Christelle and Vila, Gael and Labyt, Etienne
   and Charbonnier, Sylvie and Campagne, Aurelie},
Book-Group-Author = {IEEE},
Title = {A Multi-User Multi-Task Model For Stress Monitoring From Wearable
   Sensors},
Booktitle = {2018 21ST INTERNATIONAL CONFERENCE ON INFORMATION FUSION (FUSION)},
Year = {2018},
Pages = {761-766},
Abstract = {This study presents results on stress monitoring based on peripheral
   physiological signals acquired from wearable sensors. Using machine
   learning methods on data collected during laboratory experiment on 6
   subjects exposed to 3 kinds of well-known stress tasks (TSST, MST and
   SECPT), the influence of the inter-subject and the inter-task
   variability on stress/no stress classification is evaluated. The
   relevant set of features and the type of classifier (choice between SVM,
   Decision Tree, and Naive Bayes) are first selected by using
   Leave-One-Subject-Out (LOSO) cross validation. The model learnt on the 3
   tasks reach 85\% of good classification rate over the validation set,
   using SVMs as classifier and as features: the mean of the heart rate and
   the sum of all skin response's width-prominence products. After that,
   different results obtained using several partitioning of
   learning/validation sets are compared (e.g. learning on one task and on
   all subjects and validating on the other tasks) in order to evaluate the
   subjects and tasks influence. We observe that our model is robust to the
   inter-subject and the inter-task variability with small differences for
   SECPT which suggests a slightly different physiological reaction to
   physical stressors.},
Type = {Proceedings Paper},
Affiliation = {Sakri, O (Corresponding Author), Univ Grenoble Alpes, F-38402 Grenoble, France.
   Sakri, O (Corresponding Author), CEA, LETI, MINATEC Campus, F-38054 Grenoble, France.
