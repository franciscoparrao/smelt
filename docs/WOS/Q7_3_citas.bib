@article{ WOS:000802760400010,
Author = {Adiyeke, Esra and Baydogan, Mustafa Gokce},
Title = {Semi-supervised extensions of multi-task tree ensembles},
Journal = {PATTERN RECOGNITION},
Year = {2022},
Volume = {123},
Month = {MAR},
Abstract = {Scale inconsistency is a widely encountered issue in multi-output
   learning problems. Specifically, target sets with multiple real valued
   or a mixture of categorical and real valued variables require addressing
   the scale differences to obtain predictive models with sufficiently good
   performance. Data transformation techniques are often employed to solve
   that problem. However, these operations are susceptible to different
   shortcomings such as changing the statistical properties of the data and
   increase the computational burden. Scale differences also pose problem
   in semi-supervised learning (SSL) models as they require processing of
   unsupervised information where distance measures are commonly employed.
   Classical distance metrics can be criticized as they lose efficiency
   when variables exhibit type or scale differences, too. Besides, in
   higher dimensions distance metrics cause problems due to loss of
   discriminative power. This paper introduces alternative semi-supervised
   tree-based strategies that are robust to scale differences both in terms
   of feature and target variables. We propose use of a scale-invariant
   proximity measure by means of tree-based ensembles to preserve the
   original characteristics of the data. We update classical tree
   derivation procedure to a multi-criteria form to resolve scale
   inconsistencies. We define proximity based clustering indicators and
   extend the supervised model with unsupervised criteria. Our experiments
   show that proposed method significantly outperforms its benchmark
   learning model that is predictive clustering trees.(c) 2021 Elsevier
   Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Adiyeke, E (Corresponding Author), Bahcesehir Univ, Dept Ind Engn, Ciragan Cad 4-6, TR-34353 Istanbul, Turkey.
   Adiyeke, Esra, Bahcesehir Univ, Dept Ind Engn, Ciragan Cad 4-6, TR-34353 Istanbul, Turkey.
   Adiyeke, Esra, Univ Florida, Coll Med, Dept Med, Gainesville, FL USA.
   Adiyeke, Esra, Univ Florida, Precis \& Intelligent Syst Med Res Partnership PRI, Gainesville, FL USA.
   Baydogan, Mustafa Gokce, Bogazici Univ, Dept Ind Engn, TR-34342 Istanbul, Turkey.},
DOI = {10.1016/j.patcog.2021.108393},
Article-Number = {108393},
Keywords = {Semi-supervised learning; Multi-task learning; Multi-objective trees;
   Ensemble learning; Semi-supervised learning; Multi-task learning;
   Multi-objective trees; Ensemble learning},
Keywords-Plus = {CLASSIFICATION},
Author-Email = {esra.adiyeke@eng.bau.edu.tr
   mustafa.baydogan@boun.edu.tr},
Number-of-Cited-References = {34},
Times-Cited = {6},
