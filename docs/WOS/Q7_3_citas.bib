}

@article{ WOS:001627875400034,
Author = {Metwalli, Ahmed and Fayed, Heba A. and Aly, Moustafa H.},
Title = {Intelligent 18-Tupling Optical Links: PSO-Tuned ML for Predicting and
   Minimizing Signal Penalties},
Journal = {JOURNAL OF LIGHTWAVE TECHNOLOGY},
Year = {2025},
Volume = {43},
Number = {23},
Pages = {10470-10477},
Month = {DEC 1},
Abstract = {A novel Machine Learning (ML) framework is proposed, in this paper to
   predict and optimize key performance indicators in an 18-tupling optical
   communication system. It starts with delivering and training on a public
   24,572-row OptiSystem dataset along with an open-source Python package,
   tupling\_ml, containing rigorous preprocessing that includes
   correlation-based feature selection and dimensionality reduction through
   Principal Components Analysis (PCA). This procedure reduces the feature
   space from 68 to 4 dimensions while preserving over 80\% of the
   variance. Several multi-output regression models are then evaluated,
   including multioutput Linear Regression (LR), Random Forest (RF),
   K-Nearest Neighbors (KNN), and a Regressor Chain of RF (RCRF).
   Validation is performed by means of 5-fold cross-validation (CV). The
   RCRF approach produces the best results, with a Mean Absolute Error
   (MAE) of 0.476, Mean Squared Error (MSE) of 0.963, and a coefficient of
   determination (R-2) of 0.893 on the test set. Finally, Particle Swarm
   Optimization (PSO) is employed to fine-tune two critical hyperparameters
   of the RF regressor: number of estimators and maximum depth, thereby
   further enhancing model performance by 3.3\% better than the untuned RF
   chain. By enabling proactive resource allocation and lowering signal
   penalties, the proposed framework expedites the deployment of
   next-generation (>100 Gb/s) optical fronthaul and fixed-wireless
   backhaul links.},
Type = {Article},
Affiliation = {Métwalli, A (Corresponding Author), Arab Acad Sci, Technol \& Maritime Transport, Alexandria 3650111, Egypt.
   Metwalli, Ahmed; Fayed, Heba A.; Aly, Moustafa H., Arab Acad Sci, Technol \& Maritime Transport, Alexandria 3650111, Egypt.},
DOI = {10.1109/JLT.2025.3604100},
Keywords = {Optical fiber communication; Optical receivers; Optical polarization;
   Radio frequency; Optical variables control; Optical modulation; Optical
   filters; Jitter; Optical coupling; Phase modulation; 18-tupling; machine
   learning; optical link; regressor chain random forest; particle swarm},
Author-Email = {ametwalli@aast.edu
   hebam@aast.edu
   mosaly@aast.edu},
Number-of-Cited-References = {27},
Times-Cited = {3},
Unique-ID = {WOS:001627875400034},
}

@article{ WOS:001600482700007,
Author = {Zubair, Muhammad and Din, Irfanud and Sarwar, Nadeem and Elov, Botir and
   Makhmudov, Samariddin and Trabelsi, Zouheir},
Title = {Revolutionizing sepsis diagnosis using machine learning and deep
   learning models: a systematic literature review},
Journal = {BMC INFECTIOUS DISEASES},
Year = {2025},
Volume = {25},
Number = {1},
Month = {OCT 23},
Abstract = {Sepsis is a life-threatening condition resulting from a dysregulated
   immune response to infection, often leading to organ failure and death.
   Early detection is vital, as delays significantly worsen outcomes. In
   recent years, the integration of artificial intelligence (AI),
   particularly Machine Learning (ML) and Deep Learning (DL), has shown
   great promise in enhancing early sepsis detection by identifying digital
   biomarkers from large-scale clinical datasets. This systematic review
   analyzes and synthesizes existing ML/DL approaches applied to sepsis
   prediction, with an emphasis on intensive care unit (ICU) settings. A
   total of 80 studies were included, covering diverse data sources (e.g.,
   MIMIC-III, eICU), feature selection methods, algorithm types,
   preprocessing techniques, and evaluation metrics. The models ranged from
   traditional techniques like logistic regression and decision trees to
   advanced architectures such as LSTM, transformers, and ensemble methods.
   A key contribution of this review is the inclusion of a forest plot
   summarizing reported AUC and sensitivity values from selected studies,
   offering a comparative visual of diagnostic performance. This helps
   highlight the relative effectiveness of different models and provides
   insights into their generalizability across clinical datasets. The
   review also discusses challenges related to model interpretability,
   ethical considerations, and the lack of external and temporal validation
   in many studies. It further identifies trends such as the use of
   real-time EHR data, patient-specific model development, and
   explainability tools like SHAP for clinician trust. By mapping out
   methodological strengths and limitations in current research, this work
   provides actionable recommendations for future studies and clinical
   deployment. The review contributes to the development of more robust,
   interpretable, and clinically relevant ML/DL models for early sepsis
   detection and improved patient care outcomes.},
Type = {Review},
Affiliation = {Din, I (Corresponding Author), New Uzbekistan Univ, Dept Comp Sci, Tashkent, Uzbekistan.
   Trabelsi, Z (Corresponding Author), United Arab Emirates Univ, Coll IT, Al Ain, U Arab Emirates.
   Zubair, Muhammad, Super Univ Lahore, Fac Comp Sci \& Informat Technol, Lahore, Pakistan.
   Din, Irfanud, New Uzbekistan Univ, Dept Comp Sci, Tashkent, Uzbekistan.
