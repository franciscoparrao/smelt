   Hosseinifard, Zahra, Univ Melbourne, Fac Business \& Econ, Parkville, Vic 3010, Australia.},
DOI = {10.1016/j.ijforecast.2023.05.004},
EarlyAccessDate = {NOV 2024},
Keywords = {Forecasting; Constraint optimization; Machine learning; Forecasting
   optimization solutions; Blood supply chain; Transshipment},
Keywords-Plus = {REGRESSION; OPTIMIZATION; PERFORMANCE; SELECTION; IMPACTS; CELLS; POWER},
