   Shashikumar, C. M., Manipal Acad Higher Educ, Manipal Inst Technol, Dept Mech \& Ind Engn, Manipal 576104, India.},
DOI = {10.1016/j.apples.2025.100257},
EarlyAccessDate = {AUG 2025},
Article-Number = {100257},
Keywords = {FRP composites; Delamination factor; CNT filler; Machine learning;
   Multi-output random forest regressor; Bayesian optimization},
Keywords-Plus = {TOOL WEAR; CARBON; SUPPRESSION},
Author-Email = {shashikumar.cm@manipal.edu},
Number-of-Cited-References = {27},
Times-Cited = {3},
