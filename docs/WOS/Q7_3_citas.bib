   Mohamed, Moamen Elsayed, Alexandria Univ, Alexandria, Egypt.
   Ramli, Ahmad Fakrul, Kawasan Inst Bangi, PETRONAS Res Sdn Bhd, Kajang 43000, Malaysia.
   Nasif, Mohammad Shakir, Univ Teknol PETRONAS, Dept Mech Engn, Seri Iskandar, Perak, Malaysia.
   Lim, Jeng Shiun, Univ Teknol Malaysia, Proc Syst Engn Ctr PROSPECT, Sch Chem \& Energy Engn, Res Inst Sustainable Environm RISE, Johor Baharu, Malaysia.},
DOI = {10.1002/cjce.25258},
EarlyAccessDate = {APR 2024},
Keywords = {Adam optimization; explosion durations predictions; explosion pressure
   predictions; neural network; volume blockage ratio},
Keywords-Plus = {BLOCKAGE; RATES},
Author-Email = {risza@utp.edu.my},
