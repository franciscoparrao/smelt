Unique-ID = {WOS:000650788900001},
}

@article{ WOS:000618009800007,
Author = {Santana, Everton Jose and dos Santos, Felipe Rodrigues and Mastelini,
   Saulo Martiello and Melquiades, Fabio Luiz and Barbon Jr, Sylvio},
Title = {Improved prediction of soil properties with multi-target stacked
   generalisation on EDXRF spectra},
Journal = {CHEMOMETRICS AND INTELLIGENT LABORATORY SYSTEMS},
Year = {2021},
Volume = {209},
Month = {FEB 15},
Abstract = {Energy dispersive X-ray fluorescence (EDXRF) is one of the most quick,
   environmentally friendly and least expensive spectroscopic analytical
   methodologies for assessing soil quality parameters. However, challenges
   in EDXRF spectral data analysis still demand more efficient methods. One
   possible solution is using Machine Learning (ML), particularly
   Multi-target Regression (MTR) methods, which predict multiple parameters
   taking advantage of inter-correlated parameters. In this study, we
   proposed the Multi-target Stacked Generalisation (MTSG), a novel MTR
   method relying on learning from different regressors in stacking
   structure for a boosted outcome. We compared MTSG and 5 MTR methods for
   predicting 10 parameters of soil fertility. Random Forest and Support
   Vector Regression (SVR) were used as learning algorithms embedded into
   each MTR method. Results showed the superiority of MTR methods over the
   Single-target Regression (the traditional ML method), reducing the
   predictive error for 5 parameters. Particularly, MTSG obtained the
   lowest error for phosphorus, total organic carbon and cation exchange
   capacity. When observing the relative performance of SVR with a radial
   kernel, the prediction of base saturation percentage was improved by
   19\%. Finally, the proposed method was able to reduce the average error
   from 0.67 (single-target) to 0.64 analysing all targets, representing a
   global improvement of 4.48\%.},
Type = {Article},
Affiliation = {Santana, EJ (Corresponding Author), State Univ Londrina UEL, Dept Comp Sci, Londrina, Parana, Brazil.
   Santana, Everton Jose; Barbon Jr, Sylvio, State Univ Londrina UEL, Dept Comp Sci, Londrina, Parana, Brazil.
   dos Santos, Felipe Rodrigues; Melquiades, Fabio Luiz, State Univ Londrina UEL, Dept Phys, Londrina, Parana, Brazil.
   Mastelini, Saulo Martiello, Univ Sao Paulo, Inst Math Sci \& Comp, Sao Carlos, Brazil.},
DOI = {10.1016/j.chemolab.2020.104231},
EarlyAccessDate = {JAN 2021},
Article-Number = {104231},
Keywords = {Machine learning; Multi-target regression; EDXRF Spectrometry; Soil
   quality},
Keywords-Plus = {X-RAY-FLUORESCENCE; ORGANIC-MATTER; SPECTROMETRY; MACRONUTRIENTS;
   CHEMOMETRICS; SPECTROSCOPY; QUALITY},
Author-Email = {evertonsantana@uel.br
