   Xiang, Yue, Sichuan Univ, Coll Elect Engn, Chengdu, Peoples R China.
   Zhou, Diehui, Zhuhai Powint Elect Co Ltd, Zhuhai, Peoples R China.},
DOI = {10.1109/ICPSAsia52756.2021.9621612},
