   Ziaei, Saber, Babol Noshirvani Univ Technol, Babol 4714871167, Iran.
   Gil, David, Univ Alicante, Dept Comp Technol \& Computat, Alicante 03690, Spain.},
DOI = {10.1109/ACCESS.2020.3012836},
Keywords = {Dimensionality reduction; Classification algorithms; Prediction
   algorithms; Principal component analysis; Logistics; Decision trees;
   Machine learning; data mining; large dataset; dimensionality reduction;
   ETL; PCA; cross-validation; dashboards},
Keywords-Plus = {PRINCIPAL COMPONENT ANALYSIS; MULTI-LABEL CLASSIFICATION; INTRUSION
   DETECTION; DYNAMIC SELECTION; ENSEMBLE; CLASSIFIERS; CURSE; SPECIFICITY;
