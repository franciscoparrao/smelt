   Riemenschneider, Mona; Neumann, Ursula; Heider, Dominik, Univ Appl Sci Weihenstephan Triesdorf, Hofgarten 4, D-85354 Freising Weihenstephan, Germany.},
DOI = {10.1186/s13040-016-0089-1},
Article-Number = {10},
Keywords = {Infectious diseases; Machine learning; Retrovirus; HIV therapy},
Keywords-Plus = {BEVIRIMAT RESISTANCE; DIVERSITY},
