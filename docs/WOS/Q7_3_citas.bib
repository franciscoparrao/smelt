   Wang, Xu, Shenzhen Univ, Coll Comp Sci \& Software Engn, Shenzhen 518060, Peoples R China.},
DOI = {10.1016/j.patcog.2020.107583},
Article-Number = {107583},
Keywords = {Multi-label learning; k-Labelsets Ensemble; Label powerset; Separability},
Keywords-Plus = {GUIDELINES; COMPLEXITY},
