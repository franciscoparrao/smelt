   Yang, Cuiwei, Key Lab Med Imaging Comp \& Comp Assisted Intervent, Shanghai 200093, Peoples R China.},
DOI = {10.1016/j.bspc.2023.104674},
EarlyAccessDate = {FEB 2023},
Article-Number = {104674},
Keywords = {Cascaded; Signal quality; Single -lead ECG; Long-term monitoring;
   Wearable devices},
Keywords-Plus = {QRS DETECTION; ATRIAL-FIBRILLATION; ALGORITHM; SELECTION},
Author-Email = {yangcw@fudan.edu.cn},
Number-of-Cited-References = {48},
