   Ghanim, Mohammad, Minist Transport, Doha, Qatar.
   Shaban, Khaled Bashir, Qatar Univ, Comp Sci \& Engn Dept, Doha, Qatar.},
DOI = {10.1016/j.ijtst.2022.02.003},
Keywords = {Traffic analysis; Traffic volume; Traffic count; Prediction; Artificial
