}

@article{ WOS:000672801900012,
Author = {Almagrabi, Alaa Omran and Khan, Yaser Daanial and Khan, Sher Afzal},
Title = {iPhosD-PseAAC: Identification of phosphoaspartate sites in proteins
   using statistical moments and PseAAC},
Journal = {BIOCELL},
Year = {2021},
Volume = {45},
Number = {5},
Pages = {1287-1298},
Abstract = {Phosphoaspartate is one of the major components of eukaryotes and
   prokaryotic two-component signaling pathways, and it communicates the
   signal from the sensor of histidine kinase, through the response
   regulator, to the DNA alongside transcription features and initiates the
   transcription of correct response genes. Thus, the prediction of
   phosphoaspartate sites is critical, and its experimental identification
   can be expensive, time-consuming, and tedious. For this purpose, we
   propose iPhosD-PseAAC, a new computational model for predicting
   phosphoaspartate sites in a particular protein sequence using Chou's
   5-steps rues: (1) Benchmark dataset. (2) The feature extraction
   techniques such as pseudo amino acid composition (PseAAC), statistical
   moments, and position relative features. (3) For the classification,
   artificial neural network AAN will be used. (4) In this step, 10-fold
   cross-validation and self-consistency testing will be used for
   validation. For self-consistency testing, 100\% Acc is achieved,
   whereas, for 10-fold crossvalidation 95.14\% Acc, 95.58\% Sn, 94.70\% Sp
   and 0.95 MCC are observed. (5). The final step is the development of a
   user-friendly web server for the ease of users. Thus, the iPhosD-PseAAC
   is the first and novel predictor for accurate and efficient
   identification of phosphoaspartate sites.},
Type = {Article},
Affiliation = {Khan, SA (Corresponding Author), Abdul Wali Khan Univ Mardan, Dept Comp Sci, Mardan 23200, Pakistan.
   Almagrabi, Alaa Omran, King Abdulaziz Univ, Fac Comp \& Informat Technol, Dept Informat Syst, Jeddah 80200, Saudi Arabia.
   Khan, Yaser Daanial, Univ Management \& Technol, Sch Syst \& Technol, Dept Comp Sci, Lahore 54770, Pakistan.
   Khan, Sher Afzal, Abdul Wali Khan Univ Mardan, Dept Comp Sci, Mardan 23200, Pakistan.},
DOI = {10.32604/biocell.2021.013770},
Keywords = {Phosphorylation; Phosphoaspartate; Prediction; 5-step rule; Statistical
   moments; PseAAC},
Keywords-Plus = {AMINO-ACID-COMPOSITION; PREDICTING SUBCELLULAR-LOCALIZATION; MULTI-LABEL
   CLASSIFIER; IDENTIFY RECOMBINATION SPOTS; PHOSPHORYLATION SITES;
   SIGNAL-TRANSDUCTION; ENSEMBLE CLASSIFIER; LEARNING CLASSIFIER; DIFFERENT
   MODES; VIRUS PROTEINS},
Author-Email = {sher.afzal@awkum.edu.pk},
Number-of-Cited-References = {115},
