   Fu, Yu; Tsuji, Junko; Weng, Zhiping, Univ Massachusetts, Program Bioinformat \& Integrat Biol, Sch Med, 368 Plantat St, Worcester, MA 01605 USA.},
DOI = {10.1186/s12859-017-1875-6},
Article-Number = {464},
Keywords = {Genetic algorithm; Multi-label learning; Human splicing branchpoint;
   Logistic regression},
Keywords-Plus = {CANONICAL CORRELATION-ANALYSIS; BINDING-AFFINITY; EUKARYOTES; DISCOVERY;
   DISEASE},
