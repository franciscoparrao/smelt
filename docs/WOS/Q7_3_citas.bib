   Yu, Wen, Natl Polytech Inst, Dept Control Automat, CINVESTAV IPN, Mexico City 07360, Mexico.},
DOI = {10.1016/j.engappai.2024.109157},
EarlyAccessDate = {AUG 2024},
Article-Number = {109157},
Keywords = {Municipal solid waste incineration (MSWI); Intelligent optimal control;
