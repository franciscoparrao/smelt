@incollection{ WOS:000358008500049,
Author = {Zdravevski, Eftim and Lameski, Petre and Kulakov, Andrea and
   Gjorgjevikj, Dejan},
Book-Group-Author = {IEEE},
Title = {Feature selection and allocation to diverse subsets for multi-label
   learning problems with large datasets},
Booktitle = {FEDERATED CONFERENCE ON COMPUTER SCIENCE AND INFORMATION SYSTEMS, 2014},
Series = {ACSIS-Annals of Computer Science and Information Systems},
Year = {2014},
Volume = {2},
Pages = {387-394},
Abstract = {Feature selection is important phase in machine learning and in the case
   of multi-label classification, it can be considerably challenging. In
   like manner, finding the best subset of good features is involved and
   difficult when the dataset has significantly large number of features
   (more than a thousand). In this paper we address the problem of feature
   selection for multi-label classification with large number of features.
   The proposed method is a hybrid of two phases - preliminary feature
   selection based on the information value and additional
   correlation-based selection. We show how with the first phase we can do
   preliminary selection of features from tens of thousands to couple of
   hundred, and then with the second phase we can make fine-grained feature
   selection with more sophisticated but computationally intensive methods.
   Finally, we analyze the ways of allocating the selected features to
   diverse subsets, which are suitable for training of ensembles of
   classifiers.},
Type = {Proceedings Paper},
Affiliation = {Zdravevski, E (Corresponding Author), Ss Cyril \& Methodius Univ, Fac Comp Sci \& Engn, Skopje, Macedonia.
   Zdravevski, Eftim; Lameski, Petre; Kulakov, Andrea; Gjorgjevikj, Dejan, Ss Cyril \& Methodius Univ, Fac Comp Sci \& Engn, Skopje, Macedonia.},
Author-Email = {eftim.zdravevski@finki.ukim.mk
   petre.lameski@finki.ukim.mk
   andrea.kulakov@finki.ukim.mk
   dejan.gjorgjevikj@finki.ukim.mk},
