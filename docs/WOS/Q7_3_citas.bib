DOI = {10.1007/s11227-021-04087-7},
EarlyAccessDate = {SEP 2021},
Keywords = {Ensemble model; Multi-label classification; Sentiment analysis; Consumer
   recommendations prediction; Natural language processing},
Keywords-Plus = {ONLINE RATINGS; REVIEWS; SATISFACTION; HELPFULNESS},
Author-Email = {praphulajn1@gmail.com},
Number-of-Cited-References = {44},
