   Yu, Han; Hu, Xiaofei, Wuhan Fiberhome Tech Serv Co Ltd, Wuhan, Peoples R China.},
DOI = {10.1016/j.is.2021.101772},
EarlyAccessDate = {SEP 2021},
Article-Number = {101772},
Keywords = {Rumor tracking; Natural language processing; Deep learning;
