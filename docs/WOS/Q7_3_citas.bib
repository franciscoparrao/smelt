   Jin, Zhe, Anhui Univ, Sch Artificial Intelligence, Hefei 230039, Peoples R China.},
DOI = {10.1007/s11063-022-10822-9},
EarlyAccessDate = {APR 2022},
Keywords = {Palmprint recognition; Soft biometrics; Transfer learning; Multi-task
   pre-training; Shared-weight convolutional neural network},
Keywords-Plus = {FACE; IDENTIFICATION; REPRESENTATION; ENSEMBLE; DEVICES; TRAIT},
