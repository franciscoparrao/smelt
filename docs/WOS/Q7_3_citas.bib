   Ayari, Mohamed Arselene, Qatar Univ, Technol Innovat \& Engn Educ Unit, Doha 2713, Qatar.
   Tounsi, Abdelouahed, Yonsei Univ, YFL Yonsei Frontier Lab, Seoul, South Korea.
   Tounsi, Abdelouahed, Univ Djillali Liabes Sidi Bel Abbes, Fac Technol, Dept Civil Engn, Mat \& Hydrol Lab, Sidi Bel Abbes, Algeria.
   Khandakar, Amith, Qatar Univ, Dept Elect Engn, Doha 2713, Qatar.
   Vaferi, Behzad, Islamic Azad Univ, Shiraz Branch, Dept Chem Engn, Shiraz, Iran.},
DOI = {10.12989/anr.2022.12.5.489},
Keywords = {alumina-water nanofluids; artificial intelligent classifiers;
   classification accuracy; multilayer perceptron; stability regime},
Keywords-Plus = {ARTIFICIAL NEURAL-NETWORK; THERMAL-CONDUCTIVITY; THERMOPHYSICAL
