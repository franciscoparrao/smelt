DOI = {10.1007/978-3-030-33676-9\_40},
Keywords = {Multi-label; Classifier chains; Naive Bayes; Dynamic chains; Nearest
   neighbour},
Author-Email = {pawel.trajdos@pwr.wroc.pl},
Number-of-Cited-References = {30},
Times-Cited = {10},
Unique-ID = {WOS:000582491200040},
