DOI = {10.1016/j.neucom.2018.08.053},
Keywords = {Sentiment analysis; Back propagation multi-label learning; Multi-label
   k-Nearest Neighbor; Hierarchy of multi-label classifier; Algorithm
   adaptation; Problem transformation},
