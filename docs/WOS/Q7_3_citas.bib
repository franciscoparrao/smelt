   Levatic, Jurica; Kocev, Dragi; Dzeroski, Sago, Jozef Stefan Int Postgrad Sch, Ljubljana, Slovenia.
   Ceci, Michelangelo; Kocev, Dragi, Univ Bari Aldo Moro, Dept Comp Sci, Bari, Italy.},
DOI = {10.1016/j.knosys.2017.02.014},
Keywords = {Semi-supervised learning; Self-training; Multi-target regression; Random
   forests; Reliability of predictions; Predictive clustering trees},
Keywords-Plus = {MODEL; INDUCTION; SINGLE},
