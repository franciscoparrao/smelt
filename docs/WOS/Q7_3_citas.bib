   time-series data; time generative adversarial network (TimeGAN)},
Keywords-Plus = {RECOGNITION; CLASSIFICATION; TEMPERATURE; HUMIDITY},
Author-Email = {vinay\_shrinivas@daiict.ac.in},
Number-of-Cited-References = {41},
Times-Cited = {10},
