DOI = {10.1002/widm.1240},
Article-Number = {e1240},
Keywords = {feature selection; multi-label data; classification; data mining},
Keywords-Plus = {LABEL FEATURE-SELECTION; SUPERVISED FEATURE-SELECTION; FEATURE
