   Elvati, Paolo; Saldinger, Jacob; Violi, Angela, Univ Michigan, Dept Mech Engn, Ann Arbor, MI USA.
   Violi, Angela, Univ Michigan, Dept Chem Engn \& Biophys, Ann Arbor, MI 48109 USA.},
DOI = {10.1093/bioinformatics/btae359},
Article-Number = {btae359},
Keywords-Plus = {PROTEIN-PROTEIN INTERACTIONS; DRUG DISCOVERY; KNOWLEDGE; DESIGN; TOOLS},
