   Song, Xiaoya, Harbin Inst Technol, Sch Architecture, Minist Ind \& Informat Technol, Key Lab Cold Reg Urban \& Rural Human Settlement E, Harbin 150001, Heilongjiang, Peoples R China.},
DOI = {10.3390/rs11091051},
