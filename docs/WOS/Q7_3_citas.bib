   Li, Yuefeng, Queensland Univ Technol, Sch Comp Sci, Brisbane, Qld, Australia.
   Xie, Haoran, Lingnan Univ, Dept Comp \& Decis Sci, Hong Kong, Peoples R China.},
DOI = {10.1016/j.knosys.2021.107662},
EarlyAccessDate = {NOV 2021},
Article-Number = {107662},
Keywords = {Multi-label classification; Knowledge graph; Medicine domain knowledge;
