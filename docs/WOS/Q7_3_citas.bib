   mine@main.ist.hokudai.ac.jp
   sunlu@main.ist.hokudai.ac.jp
   sadamori.koujaku@bristol.ac.uk},
Number-of-Cited-References = {21},
Times-Cited = {11},
Unique-ID = {WOS:000406771300076},
}

@incollection{ WOS:000366183700020,
Author = {Faerber, Michael and Kaliszyk, Cezary},
Editor = {Lutz, C and Ranise, S},
Title = {Random Forests for Premise Selection},
Booktitle = {FRONTIERS OF COMBINING SYSTEMS, FROCOS 2015},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2015},
Volume = {9322},
Pages = {325-340},
Abstract = {The success rates of automated theorem provers in large theories highly
   depend on the choice of given facts. Premise selection is the task of
   choosing a subset of given facts, which is most likely to lead to a
   successful automated deduction proof of a given conjecture. Premise
   selection can be viewed as a multi-label classification problem, where
   machine learning from related proofs turns out to currently be the most
   successful method. Random forests are a machine learning technique known
   to perform especially well on large datasets. In this paper, we evaluate
   random forest algorithms for premise selection. To deal with the
   specifics of automated reasoning, we propose a number of extensions to
   random forests, such as incremental learning, multi-path querying, depth
   weighting, feature IDF (inverse document frequency), and integration of
   secondary classifiers in the tree leaves. With these extensions, we
   improve on the k-nearest neighbour algorithm both in terms of prediction
   quality and ATP performance.},
Type = {Proceedings Paper},
Affiliation = {Färber, M (Corresponding Author), Univ Innsbruck, A-6020 Innsbruck, Austria.
   Faerber, Michael; Kaliszyk, Cezary, Univ Innsbruck, A-6020 Innsbruck, Austria.},
DOI = {10.1007/978-3-319-24246-0\_20},
Author-Email = {michael.faerber@uibk.ac.at
   cezary.kaliszyk@uibk.ac.at},
Number-of-Cited-References = {29},
Times-Cited = {11},
Unique-ID = {WOS:000366183700020},
}

@incollection{ WOS:000364539000002,
Author = {Robinson, Peter N. and Frasca, Marco and Koehler, Sebastian and Notaro,
   Marco and Re, Matteo and Valentini, Giorgio},
Editor = {Schwenker, F and Roli, F and Kittler, J},
Title = {A Hierarchical Ensemble Method for DAG-Structured Taxonomies},
Booktitle = {MULTIPLE CLASSIFIER SYSTEMS (MCS 2015)},
Series = {Lecture Notes in Computer Science},
Year = {2015},
Volume = {9132},
Pages = {15-26},
Abstract = {Structured taxonomies characterize several real world problems, ranging
   from text categorization, to video annotation and protein function
   prediction. In this context ``flat{''} learning methods may introduce
   inconsistent predictions, while structured output-aware learning methods
   can improve the accuracy of the predictions by exploiting the
   hierarchical relationships between classes. We propose a novel
   hierarchical ensemble method able to provide theoretically guaranteed
   consistent predictions for any Directed Acyclic Graph (DAG)-structured
   taxonomy, and consequently also for any taxonomy structured according to
   a tree. Results with a complex real-world DAG-structured taxonomy
   involving about one thousand classes and twenty thousand of examples
   show that the proposed hierarchical ensemble approach significantly
   improves flat methods, especially in terms of precision/recall curves.},
Type = {Proceedings Paper},
Affiliation = {Valentini, G (Corresponding Author), Univ Milan, Dipartimento Informat, AnacletoLab DI, Milan, Italy.
   Robinson, Peter N.; Koehler, Sebastian, Charite, Inst Med Genet \& Humangenet, D-13353 Berlin, Germany.
