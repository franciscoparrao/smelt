   Notaro, Marco, Univ Milan, Dipartimento Biosci, Milan, Italy.
   Robinson, Peter N., Free Univ Berlin, Inst Bioinformat, Dept Math \& Comp Sci, Berlin, Germany.},
DOI = {10.1007/978-3-319-20248-8\_2},
Keywords = {Hierarchical ensemble classification methods; DAG-structured prediction;
