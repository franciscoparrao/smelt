   Kocev, Dragi; Dzeroski, Saso, Jozef Stefan Int Postgrad Sch, Ljubljana, Slovenia.},
DOI = {10.2298/CSIS170115043S},
Keywords = {feature selection; feature ranking; structured data; hierarchical
   multi-label classification; ReliefF},
Keywords-Plus = {FEATURE-SELECTION; ENSEMBLES},
