   Pawlicka, Aleksandra, Univ Warsaw, Fac Appl Linguist, Warsaw, Poland.},
DOI = {10.3390/s23249666},
Article-Number = {9666},
Keywords = {deep learning; fake news; ensemble of classifiers; text classification;
   misinformation},
Author-Email = {rafal.kozik@pbs.edu.pl},
Number-of-Cited-References = {44},
Times-Cited = {5},
Unique-ID = {WOS:001131069200001},
}

@article{ WOS:001160804800001,
Author = {Zhang, Shuying and Luo, Xiaojun and Mai, Bixian},
Title = {Multi-task machine learning models for simultaneous prediction of
   tissue-to-blood partition coefficients of chemicals in mammals},
Journal = {ENVIRONMENTAL RESEARCH},
Year = {2024},
Volume = {241},
Month = {JAN 15},
Abstract = {Tissue-to-blood partition coefficients (P-tb) are crucial for assessing
   the distribution of chemicals in organisms. Given the lack of
   experimental data and laborious nature of experimental methods, there is
   an urgent need to develop efficient predictive models. With the help of
   machine learning algorithms, i,e., random forest (RF), and artificial
   neural network (ANN), this study developed multi-task (MT) models that
   can simultaneously predict P-tb values for various mammalian tissues,
   including liver, muscle, brain, lung, and adipose. Single-task (ST)
   models using partial least squares regression, RF, and ANN algorithms
   for each endpoint were established for comparison. Overall, the
   performances of MT models were superior to those of ST models. The MT
   model using ANN algorithms showed the highest prediction accuracy with
   determination coefficients ranging from 0.704 to 0.886, root mean square
   errors between 0.223 and 0.410, and mean absolute errors ranging from
   0.178 to 0.285 log units. Results showed that lipophilicity and
   polarizability of molecules significantly influence their partition
   behavior in organisms. Applicability domains (ADs) of the models were
   characterized by weighted molecular similarity density, and weighted
   inconsistency in molecular activities of structure-activity landscapes.
   When constrained by ADs, the models displayed enhanced predictive
   accuracy, making them valuable tools for the risk assessment and
   management of chemicals.},
