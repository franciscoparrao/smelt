Keywords = {Aircraft representation; Feature selection; Unsupervised filtering;
   Supervised learning; Aircraft grouping; Environmental impact of aviation},
Keywords-Plus = {VARIABLE SELECTION; REGRESSION; FOREST; PREDICTION; ENSEMBLES;
   RELEVANCE; NOISE; TREES; STATE},
