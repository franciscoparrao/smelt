EarlyAccessDate = {APR 2024},
Keywords = {Three-dimensional displays; Surface cracks; Volume measurement; Surface
   morphology; Predictive models; Optical variables measurement;
   Maintenance; Flexible pavement; pavement cracks; severity assessment;
