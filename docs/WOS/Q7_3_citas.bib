   Yang, Hong, Shanghai Univ Tradit Chinese Med, Shanghai Municipal Hosp Tradit Chinese Med, Shanghai, Peoples R China.
   Xu, Zhaoxia, Shanghai Key Lab Hlth Identificat \& Assessment, Shanghai, Peoples R China.},
DOI = {10.1016/j.heliyon.2024.e35283},
EarlyAccessDate = {JUL 2024},
Article-Number = {e35283},
Keywords = {Diagnosis; Feature selection; Machine learning; Pattern differentiation;
   Polycystic ovary syndrome; Prediction model; Traditional Chinese
   medicine},
Keywords-Plus = {CHINESE MEDICINE; DIFFERENTIATION; REGRESSION},
Author-Email = {jiekeelim@outlook.com
   zhaoxia7001@shutcm.edu.cn},
