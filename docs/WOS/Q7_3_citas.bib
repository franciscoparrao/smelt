@incollection{ WOS:000374793000009,
Author = {Trajdos, Pawel and Kurzynski, Marek},
Editor = {Jackowski, K and Burduk, R and Walkowiak, K and Wozniak, M and Yin, H},
Title = {An Extension of Multi-label Binary Relevance Models Based on Randomized
   Reference Classifier and Local Fuzzy Confusion Matrix},
Booktitle = {INTELLIGENT DATA ENGINEERING AND AUTOMATED LEARNING - IDEAL 2015},
Series = {Lecture Notes in Computer Science},
Year = {2015},
Volume = {9375},
Pages = {69-76},
Abstract = {In this paper we addressed the issue of applying a stochastic classifier
   and a local, fuzzy confusion matrix under the framework of multi-label
   classification. We proposed a novel solution to the problem of
   correcting Binary Relevance ensembles. The main step of the correction
   procedure is to compute label-wise competence and cross-competence
   measures, which model error pattern of the underlying classifier. The
   method was evaluated using 20 benchmark datasets. In order to assess the
   efficiency of the introduced model, it was compared against 3
   state-of-the-art approaches. The comparison was performed using 4
   different evaluation measures. Although the introduced algorithm, as its
   base algorithm-Binary Relevance, is insensitive to dependencies between
   labels, the conducted experimental study reveals that the proposed
   algorithm outperform other methods in terms of Hamming-loss and False
   Discovery Rate.},
Type = {Proceedings Paper},
Affiliation = {Trajdos, P (Corresponding Author), Wroclaw Univ Technol, Dept Syst \& Comp Networks, Wybrzeze Wyspianskiego 27, PL-50370 Wroclaw, Poland.
   Trajdos, Pawel; Kurzynski, Marek, Wroclaw Univ Technol, Dept Syst \& Comp Networks, Wybrzeze Wyspianskiego 27, PL-50370 Wroclaw, Poland.},
DOI = {10.1007/978-3-319-24834-9\_9},
Keywords = {Multi-label classification; Binary relevance; Confusion matrix},
Author-Email = {pawel.trajdos@pwr.wroc.pl},
Number-of-Cited-References = {16},
