   Dokeroglu, Tansel, TED Univ, Dept Comp Engn, TR-06420 Ankara, Turkey.
   Cosar, Ahmet, Ankara Sci Univ, Dept Comp Engn, TR-06200 Ankara, Turkey.},
DOI = {10.1109/ACCESS.2020.3022317},
Keywords = {Feature extraction; Prediction algorithms; Optimization; Dimensionality
   reduction; Machine learning algorithms; Genetic algorithms; Support
   vector machines; Feature selection; multi-label; multi-objective
   optimization; autoencoder; ensemble; classification},
Keywords-Plus = {FEATURE-SELECTION},
Author-Email = {gizem.karagoz@metu.edu.tr},
Number-of-Cited-References = {60},
