@incollection{ WOS:000380541000140,
Author = {Zhang, Qian and Zhang, Lefei and Du, Bo and Zheng, Wei and Bian, Wei and
   Tao, Dacheng},
Editor = {Aggarwal, C and Zhou, ZH and Tuzhilin, A and Xiong, H and Wu, X},
Title = {MMFE: Multitask Multiview Feature Embedding},
Booktitle = {2015 IEEE INTERNATIONAL CONFERENCE ON DATA MINING (ICDM)},
Series = {IEEE International Conference on Data Mining},
Year = {2015},
Pages = {1105-1110},
Abstract = {In data mining and pattern recognition area, the learned objects are
   often represented by the multiple features from various of views. How to
   learn an efficient and effective feature embedding for the subsequent
   learning tasks? In this paper, we address this issue by providing a
   novel multi-task multiview feature embedding (MMFE) framework. The MMFE
   algorithm is based on the idea of low-rank approximation, which suggests
   that the observed multiview feature matrix is approximately represented
   by the low-dimensional feature embedding multiplied by a projection
   matrix. In order to fully consider the particular role of each view to
   the multiview feature embedding, we simultaneously suggest the multitask
   learning scheme and ensemble manifold regularization into the MMFE
   algorithm to seek the optimal projection. Since the objection function
   of MMFE is multi-variable and non-convex, we further provide an
   iterative optimization procedure to find the available solution. Two
   real world experiments show that the proposed method outperforms
   single-task-based as well as state-of-the-art multiview feature
   embedding methods for the classification problem.},
Type = {Proceedings Paper},
Affiliation = {Zhang, Q (Corresponding Author), Beijing Samsung Telecom R\&D Ctr, Beijing 100028, Peoples R China.
   Zhang, Qian; Zheng, Wei, Beijing Samsung Telecom R\&D Ctr, Beijing 100028, Peoples R China.
   Zhang, Lefei; Du, Bo, Wuhan Univ, Sch Comp, Wuhan 430079, Peoples R China.
   Bian, Wei; Tao, Dacheng, Univ Technol, QCIS, Sydney, NSW 2007, Australia.
   Bian, Wei; Tao, Dacheng, Univ Technol, FEIT, Sydney, NSW 2007, Australia.},
