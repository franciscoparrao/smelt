@article{ WOS:001119605800001,
Author = {Ho, Minh Hung and Durupt, Amelie Ponchet and Vu, Hai Canh and Boudaoud,
   Nassim and Caracciolo, Arnaud and Sieg-Zieba, Sophie and Xu, Yun and
   Leduc, Patrick},
Title = {Ensemble Learning for Multi-Label Classification with Unbalanced
   Classes: A Case Study of a Curing Oven in Glass Wool Production},
Journal = {MATHEMATICS},
Year = {2023},
Volume = {11},
Number = {22},
Month = {NOV},
Abstract = {The Industrial Internet of Things (IIoT), which integrates sensors into
   the manufacturing system, provides new paradigms and technologies to
   industry. The massive acquisition of data, in an industrial context,
   brings with it a number of challenges to guarantee its quality and
   reliability, and to ensure that the results of data analysis and
   modelling are accurate, reliable, and reflect the real phenomena being
   studied. Common problems encountered with real industrial databases are
   missing data, outliers, anomalies, unbalanced classes, and
   non-exhaustive historical data. Unlike papers present in the literature
   that respond to those problems in a dissociated way, the work performed
   in this article aims to address all these problems at once. A
   comprehensive framework for data flow encompassing data acquisition,
   preprocessing, and machine class classification is proposed. The
   challenges of missing data, outliers, and anomalies are addressed with
   critical and novel class outliers distinguished. The study also tackles
   unbalanced class classification and evaluates the impact of missing data
   on classification accuracy. Several machine learning models for the
   operating state classification are implemented. The study also compares
   the performance of the proposed framework with two existing methods: the
   Histogram Gradient Boosting Classifier and the Extreme Gradient Boosting
   classifier. It is shown that using ``hard voting{''} ensemble learning
   methods to combine several classifiers makes the final classifier more
   robust to missing data. An application is carried out on data from a
   real industrial dataset. This research contributes to narrowing the
   theory-practice gap in leveraging IIoT technologies, offering practical
   insights into data analytics implementation in real industrial
   scenarios.},
Type = {Article},
Affiliation = {Durupt, AP (Corresponding Author), Univ Technol Compiegne UTC, CS 60319, F-60203 Compiegne, France.
   Ho, Minh Hung; Durupt, Amelie Ponchet; Vu, Hai Canh; Boudaoud, Nassim, Univ Technol Compiegne UTC, CS 60319, F-60203 Compiegne, France.
   Caracciolo, Arnaud; Sieg-Zieba, Sophie, Ctr Tech Ind Mecan CETIM, 52 Ave Felix Louat, F-60304 Senlis, France.
   Xu, Yun; Leduc, Patrick, ALFI ADLER, 6 Route Borde, F-60360 Crevecoeur Le Grand, France.},
DOI = {10.3390/math11224602},
Article-Number = {4602},
Keywords = {Industrial Internet of Things; missing data; imputation methods;
   imbalanced class; classification performance},
Keywords-Plus = {OUTLIER DETECTION; IMBALANCED DATA; MISSING VALUES; IMPUTATION;
   ALGORITHM; DENSITY; SMOTE; COMBINATION; DISTANCE; DESIGNS},
Author-Email = {minh-hung.ho@utc.fr
   amelie.durupt@utc.fr
   hai-canh.vu@utc.fr
