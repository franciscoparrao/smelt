   Elov, Botir, Alisher Navoi Tashkent State Univ Uzbek Language \&, Dept Comp Linguist \& Digital Technol, Tashkent, Uzbekistan.
   Makhmudov, Samariddin, Mamun Univ, Dept Econ, Khiva, Uzbekistan.
   Makhmudov, Samariddin, Termez Univ Econ \& Serv, Termez, Uzbekistan.
   Trabelsi, Zouheir, United Arab Emirates Univ, Coll IT, Al Ain, U Arab Emirates.},
DOI = {10.1186/s12879-025-11423-2},
