   transformers; Support vector regression; Random forest regression},
Keywords-Plus = {GLOBAL SOLAR-RADIATION; MASS-TRANSFER; ABSORPTION; PERFORMANCE;
   PREDICTION; DESIGN; OPTIMIZATION; PUMP; FILM},
Author-Email = {mbahrami@sfu.ca},
