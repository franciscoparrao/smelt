@article{ WOS:001218548000001,
Author = {Xu, Rongjing and Yang, Xianjun},
Title = {Machine learning optimization for catalytic desulfurization of
   petroleum: Multi-layered perceptron, Multi Task Lasso, and Gaussian
   process regression models},
Journal = {JOURNAL OF MOLECULAR LIQUIDS},
Year = {2024},
Volume = {400},
Month = {APR 15},
Abstract = {Machine learning models were developed and optimized in this study to
   optimize the process of hydrodesulfurization (HDS) for fuel production.
   A number of input parameters were considered and optimized to find the
   best response parameters. The input parameters of process/model
   included: pressure, catalyst dosage, temperature, and feed ` s sulfur
   content. This paper focuses on optimizing and evaluating AdaBoost
   ensemble models for predicting sulfur concentration, emission
   percentage, and HDS cost in industrial processes for fuel treatment.
   Employing Multilayer Perceptron (MLP), Gaussian Process Regression
   (GPR), and Multi-Task Lasso (MTL) as base models, and utilizing Tabu
   Search for tuning of hyper-parameter, we report the performance of the
   best models. The Bagged GPR stands out with a significant R 2 of 0.967
   for sulfur concentration and 0.959 for HDS cost, accompanied by RMSE
   values of 1.7691E +02 and 1.4191, respectively. For emission prediction,
   Bagged MTL demonstrates notable performance with an R 2 of 0.877 and
   RMSE of 8.4235. These outcomes highlight the efficacy of ensemble models
   in enhancing predictive accuracy and underscore the potential for
   informed decision-making in industrial settings for the area of
   petroleum industry.},
Type = {Article},
Affiliation = {Yang, XJ (Corresponding Author), Chinese Acad Sci, Hefei Inst Phys Sci, Hefei 230031, Peoples R China.
   Xu, Rongjing, Univ Sci \& Technol China, Hefei 230026, Peoples R China.
