   Kusi, Goodlet Akwasi; Mawuli, Bernard Cobbinah; Agbley, Bless Lord Y., Univ Elect Sci \& Technol China, Sch Comp Sci, Chengdu 610054, Peoples R China.},
DOI = {10.1016/j.autcon.2022.104396},
EarlyAccessDate = {JUN 2022},
Article-Number = {104396},
Keywords = {Deep learning; Structural health monitoring; Detection; Autonomous;
   Ensemble learning; Unmanned aerial vehicles; Drones},
