Keywords = {rotating machinery; fault detection; machine learning; multi-label
   classification; predictive maintenance; multi-sensor data integration},
Keywords-Plus = {DIAGNOSIS; OPTIMIZATION; ALGORITHMS; MACHINERY; CNN},
