Keywords-Plus = {PROSTATIC ACID-PHOSPHATASE; UNKNOWN PRIMARY; MOLECULAR CLASSIFICATION;
   COLON-CANCER; PRIMARY SITE; CARCINOMA; TUMOR; IMMUNOHISTOCHEMISTRY;
   ADENOCARCINOMA; IDENTIFICATION},
Author-Email = {hbscsmu@163.com
   bpping@163.com
   tiang@geneis.cn
   yangjl@geneis.cn},
Number-of-Cited-References = {55},
Times-Cited = {88},
Unique-ID = {WOS:000538880900001},
}

@article{ WOS:000513850100008,
Author = {Pereira, Rodolfo M. and Costa, Yandre M. G. and Silla Jr, Carlos N.},
Title = {MLTL: A multi-label approach for the Tomek Link undersampling algorithm},
Journal = {NEUROCOMPUTING},
Year = {2020},
Volume = {383},
Pages = {95-105},
Month = {MAR 28},
Abstract = {A large variety of problems are multi-labeled, which made the
   Multi-Label Classification field become an active topic in the machine
   learning community. However, real world problems tend to be imbalanced,
   meaning that some classes may have more samples than others. Learning
   from imbalanced datasets is a challenging task and for that has
   attracted the attention of researchers that have proposed some
   resampling algorithms to address this problem. This work presents two
   main contributions: A new resampling algorithm for multi-label
   classification problems named MLTL - Multi-Label Tomek Link, which is
   based on the standard Tomek Link resampling algorithm; A multi-label
   imbalanceness API for the Mulan framework. Results in seven well-known
   datasets showed that MLTL is a competitive technique when compared to
   other multi-label resampling methods from the literature. (C) 2019
   Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Pereira, RM (Corresponding Author), Pontificia Univ Catolica Parana PUCPR, Curitiba, Parana, Brazil.
   Pereira, Rodolfo M.; Silla Jr, Carlos N., Pontificia Univ Catolica Parana PUCPR, Curitiba, Parana, Brazil.
   Pereira, Rodolfo M., Inst Fed Educ Ciencia \& Tecnol Parana IFPR, Pinhais, PR, Brazil.
   Costa, Yandre M. G., Univ Estadual Maringa, Maringa, Parana, Brazil.},
DOI = {10.1016/j.neucom.2019.11.076},
Keywords = {Multi-label learning; Resampling techniques; Dataset imbalanceness},
Keywords-Plus = {CLASSIFICATION; ENSEMBLE},
Author-Email = {rodolfomp123@gmail.com},
Number-of-Cited-References = {35},
