@incollection{ WOS:000264173600120,
Author = {Read, Jesse and Pfahringer, Bernhard and Holmes, Geoff},
Editor = {Gunopulos, D and Turini, F and Zaniolo, C and Ramakrishnan, N and Wu, XD},
Book-Author = {Giannotti, F},
Title = {Multi-label Classification using Ensembles of Pruned Sets},
Booktitle = {ICDM 2008: EIGHTH IEEE INTERNATIONAL CONFERENCE ON DATA MINING,
   PROCEEDINGS},
Series = {IEEE International Conference on Data Mining},
Year = {2008},
Pages = {995-1000},
Abstract = {This paper presents a Pruned Sets method (PS)for multi-label
   classification. It is centred on the concept of treating sets of labels
   as single labels. This allows the classification process to inherently
   take into account correlations between labels. BY pruning these sets, PS
   focuses only on the most important correlations, which reduces
   complexity and improves accuracy. BY combining pruned sets in an
   ensemble scheme (EPS), new label sets can be formed to adapt to
   irregular or complex data. The results from experimental evaluation on a
   variety of multi-label datasets show that {[}E]PS can achieve better
   performance and train much faster than other multi-label methods.},
Type = {Proceedings Paper},
Affiliation = {Read, J (Corresponding Author), Univ Waikato, Dept Comp Sci, Hamilton, New Zealand.
   Read, Jesse; Pfahringer, Bernhard; Holmes, Geoff, Univ Waikato, Dept Comp Sci, Hamilton, New Zealand.},
