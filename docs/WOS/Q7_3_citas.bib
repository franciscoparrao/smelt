@article{ WOS:001057839800001,
Author = {Zhang, Qingshuo and Tsang, Eric C. C. and He, Qiang and Guo, Yanting},
Title = {Ensemble of kernel extreme learning machine based elimination
   optimization for multi-label classification},
Journal = {KNOWLEDGE-BASED SYSTEMS},
Year = {2023},
Volume = {278},
Month = {OCT 25},
Abstract = {Multi-label learning is a class of machine learning algorithms that
   study the classification problem of data associated with multiple labels
   simultaneously. Ensemble-based method is one of the representa-tive
   methods in multi-label learning. In the existing ensemble-based
   multi-label classification methods, the essence of its base learner is
   still a binary or multi-class classifier. At present, there is no
   ensemble-based multi-label method that uses a multi-label classifier
   based on algorithm adaptation as a base learner. Multi-label algorithms
   suffer from expensive time costs, and ensemble-based methods further
   exacerbate the time cost. To address these issues, we propose an
   efficient multi-label classification method based on kernel extreme
   learning machine and ensemble learning. Firstly, to solve the problem of
   high time complexity of multi-label classifiers, we use a Gaussian
   kernel function to generate a kernel extreme learning machine based
   multi-label classifier (KELM\_ML). Then, based on random sampling, we
   construct the base classifier, i.e., KELM\_ML, in ensemble learning.
   Finally, to build an ensemble model of multi-label classifiers, an
   elimination optimization ensemble strategy is proposed by defining an
   encoding vector of the base classifiers and updating it. Although our
   method is an ensemble model, it inherits the advantages of good time
   complexity of ELM, i.e., fast learning time. The experimental and
   statistical results show that compared with baseline methods and other
   ensemble-based multi-label methods, our proposed method has better
   classification performance and stable results.\& COPY; 2023 Elsevier
   B.V. All rights reserved.},
Type = {Article},
Affiliation = {Tsang, ECC (Corresponding Author), Macau Univ Sci \& Technol, Sch Comp Sci \& Engn, Taipa, Macau, Peoples R China.
   Zhang, Qingshuo; Tsang, Eric C. C., Macau Univ Sci \& Technol, Sch Comp Sci \& Engn, Taipa, Macau, Peoples R China.
   He, Qiang, Beijing Univ Civil Engn \& Architecture, Sch Sci, Beijing 102616, Peoples R China.
   Guo, Yanting, Shenzhen Univ, Coll Comp Sci \& Software Engn, Shenzhen 518060, Peoples R China.},
DOI = {10.1016/j.knosys.2023.110817},
EarlyAccessDate = {AUG 2023},
Article-Number = {110817},
Keywords = {Multi-label learning; Extreme learning machine; Ensemble learning;
   Encoding vector},
Keywords-Plus = {FEATURE-SELECTION},
Author-Email = {cctsang@must.edu.mo},
Number-of-Cited-References = {50},
Times-Cited = {24},
Unique-ID = {WOS:001057839800001},
}

@article{ WOS:001029327200001,
Author = {Yang, Qianqian and Kim, Jhoon and Cho, Yeseul and Lee, Won-Jin and Lee,
   Dong-Won and Yuan, Qiangqiang and Wang, Fan and Zhou, Chenhong and
   Zhang, Xiaorui and Xiao, Xiang and Guo, Meiyu and Guo, Yike and
   Carmichael, Gregory R. R. and Gao, Meng},
Title = {A synchronized estimation of hourly surface concentrations of six
   criteria air pollutants with GEMS data},
Journal = {NPJ CLIMATE AND ATMOSPHERIC SCIENCE},
Year = {2023},
Volume = {6},
Number = {1},
Month = {JUL 18},
Abstract = {Machine learning is widely used to infer ground-level concentrations of
   air pollutants from satellite observations. However, a single pollutant
   is commonly targeted in previous explorations, which would lead to
   duplication of efforts and ignoration of interactions considering the
   interactive nature of air pollutants and their common influencing
   factors. We aim to build a unified model to offer a synchronized
   estimation of ground-level air pollution levels. We constructed a
   multi-output random forest (MORF) model and achieved simultaneous
   estimation of hourly concentrations of PM2.5, PM10, O-3, NO2, CO, and
   SO2 in China, benefiting from the world's first geostationary
   air-quality monitoring instrument Geostationary Environment Monitoring
   Spectrometer. MORF yielded a high accuracy with cross-validated R-2
   reaching 0.94. Meanwhile, model efficiency was significantly improved
   compared to single-output models. Based on retrieved results, the
   spatial distributions, seasonality, and diurnal variations of six air
   pollutants were analyzed and two typical pollution events were tracked.},
