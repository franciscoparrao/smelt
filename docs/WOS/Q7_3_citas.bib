DOI = {10.1007/s11276-020-02379-z},
EarlyAccessDate = {JUL 2020},
Keywords = {Smart contract; Slice matrix; Vulnerability; Multi-label classification;
   Ethereum},
Author-Email = {lijin@gzhu.edu.cn},
Number-of-Cited-References = {30},
