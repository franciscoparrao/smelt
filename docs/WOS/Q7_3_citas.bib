@incollection{ WOS:000713413200028,
Author = {Rapp, Michael and Mencia, Eneldo Loza and Furnkranz, Johannes and
   Hullermeier, Eyke},
Editor = {Oliver, N and PerezCruz, F and Kramer, S and Read, J and Lozano, JA},
Title = {Gradient-Based Label Binning in Multi-label Classification},
Booktitle = {MACHINE LEARNING AND KNOWLEDGE DISCOVERY IN DATABASES, ECML PKDD 2021:
   RESEARCH TRACK, PT III},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2021},
Volume = {12977},
Pages = {462-477},
Abstract = {In multi-label classification, where a single example may be associated
   with several class labels at the same time, the ability to model
   dependencies between labels is considered crucial to effectively
   optimize non-decomposable evaluation measures, such as the Subset 0/1
   loss. The gradient boosting framework provides a well-studied foundation
   for learning models that are specifically tailored to such a loss
   function and recent research attests the ability to achieve high
   predictive accuracy in the multi-label setting. The utilization of
   second-order derivatives, as used by many recent boosting approaches,
   helps to guide the minimization of non-decomposable losses, due to the
   information about pairs of labels it incorporates into the optimization
   process. On the downside, this comes with high computational costs, even
   if the number of labels is small. In this work, we address the
   computational bottleneck of such approach-the need to solve a system of
   linear equations-by integrating a novel approximation technique into the
   boosting procedure. Based on the derivatives computed during training,
   we dynamically group the labels into a predefined number of bins to
   impose an upper bound on the dimensionality of the linear system. Our
   experiments, using an existing rule-based algorithm, suggest that this
   may boost the speed of training, without any significant loss in
   predictive performance.},
Type = {Proceedings Paper},
Affiliation = {Rapp, M (Corresponding Author), Tech Univ Darmstadt, Knowledge Engn Grp, Darmstadt, Germany.
   Rapp, Michael; Mencia, Eneldo Loza, Tech Univ Darmstadt, Knowledge Engn Grp, Darmstadt, Germany.
   Furnkranz, Johannes, JKU Linz, Computat Data Anal Grp, Linz, Austria.
   Hullermeier, Eyke, Paderborn Univ, Heinz Nixdorf Inst, Paderborn, Germany.},
DOI = {10.1007/978-3-030-86523-8\_28},
Keywords = {Multi-label classification; Gradient boosting; Rule learning},
Author-Email = {mrapp@ke.tu-darmstadt.de
   research@eneldo.net
   juffi@faw.jku.at
   eyke@upb.de},
Number-of-Cited-References = {26},
Times-Cited = {7},
Unique-ID = {WOS:000713413200028},
}

@article{ WOS:000645564400012,
Author = {Yekun, Ephrem Admasu and Haile, Abrahaley Teklay},
Title = {Student Performance Prediction with Optimum Multilabel Ensemble Model},
Journal = {JOURNAL OF INTELLIGENT SYSTEMS},
Year = {2021},
Volume = {30},
Number = {1},
Pages = {511-523},
Month = {JAN},
Abstract = {One of the important measures of quality of education is the performance
   of students in academic settings. Nowadays, abundant data is stored in
   educational institutions about students which can help to discover
   insight on how students are learning and to improve their performance
   ahead of time using data mining techniques. In this paper, we developed
   a student performance prediction model that predicts the performance of
   high school students for the next semester for five courses. We modeled
   our prediction system as a multi-label classification task and used
   support vector machine (SVM), Random Forest (RF), K-nearest Neighbors
   (KNN), and Multi-layer perceptron (MLP) as base-classifiers to train our
   model. We further improved the performance of the prediction model using
   a state-of-the-art partitioning scheme to divide the label space into
   smaller spaces and used Label Powerset (LP) transformation method to
   transform each labelset into a multi-class classification task. The
   proposed model achieved better performance in terms of different
   evaluation metrics when compared to other multi-label learning tasks
   such as binary relevance and classifier chains.},
Type = {Article},
Affiliation = {Yekun, EA (Corresponding Author), Ethiopian Inst Technol Mekelle, Sch Elect \& Comp Engn, Mekelle, Ethiopia.
   Yekun, Ephrem Admasu, Ethiopian Inst Technol Mekelle, Sch Elect \& Comp Engn, Mekelle, Ethiopia.
   Haile, Abrahaley Teklay, Ethiopian Inst Technol Mekelle, Sch Comp, Mekelle, Ethiopia.},
DOI = {10.1515/jisys-2021-0016},
Keywords = {EDM; Student performance prediction; Ensemble model; Multi-label
   classification},
Author-Email = {ephrem.admasu@mu.edu.et},
Number-of-Cited-References = {8},
Times-Cited = {7},
Unique-ID = {WOS:000645564400012},
