Times-Cited = {2},
Unique-ID = {WOS:001513415700001},
}

@article{ WOS:001512629600001,
Author = {Lei, Langhuan and Li, Wei},
Title = {Transformer-based multi-task model for lung tumor segmentation and
   classification in CT images},
Journal = {JOURNAL OF RADIATION RESEARCH AND APPLIED SCIENCES},
Year = {2025},
Volume = {18},
Number = {3},
Month = {SEP},
Abstract = {Objective: This study proposes a Transformer-based multi-task model for
   lung tumor segmentation and classification in CT images, enhancing
   accuracy and efficiency through advanced segmentation and optimized
   machine learning classifiers. Materials and methods: This study utilized
   a dataset of 678 CT images of lung tumors, including both benign and
   malignant cases. Tumor segmentation was performed using three deep
   learning models: UNETR (Transformer-based), nnU-Net, and U-Net. The
   segmented tumor regions were used for radiomic feature extraction,
   generating 215 quantitative features, including first-order statistics,
   co-occurrence matrix features, and run-length matrix features. To
   enhance classification performance, dimensionality reduction and feature
   selection were applied using Principal Component Analysis (PCA),
   Analysis of Variance (ANOVA), and Mutual Information (MI). For
   classification, three machine learning models were evaluated: XGBoost,
   Support Vector Machine (SVM), and Stacking Ensemble. The models were
   trained using a five-fold cross-validation strategy to ensure
   robustness. Performance was assessed based on Accuracy, Sensitivity, and
   AUC-ROC. The proposed multi-task framework integrates segmentation and
   classification to enhance early detection and diagnosis of lung cancer
   in CT imaging. Results: The UNETR-based segmentation model outperformed
   both UNet and nnU-Net, achieving higher values in key performance
   metrics. For example, the Dice Similarity Coefficient (DSC) was 0.96 for
   the UNETR, compared to 0.92 for UNet and 0.85 for nnU-Net. The
   Intersection over Union (IoU) was 0.95 for the UNETR, while it was 0.90
   for UNet and 0.82 for nnU-Net. Additionally, the UNETR showed better
   results in capturing tumor boundaries, with a lower HD95 value of 2.2 mm
   compared to 3.2 mm for UNet and 4.3 mm for nnU-Net. In terms of
   classification, the Stacking Ensemble combined with PCA delivered the
   highest accuracy, achieving 95 \% on training data and 92 \% on testing
   data, outperforming both XGBoost and SVM. Conclusion: The UNETR proposed
   in this study outperformed traditional methods in both segmentation
   accuracy and classification performance.},
Type = {Article},
Affiliation = {Li, W (Corresponding Author), 6 Taoyuan Rd, Nanning 530016, Guangxi, Peoples R China.
   Lei, Langhuan, Guangxi Zhuang Autonomous Reg Peoples Hosp, Res Ctr Hlth Management, Nanning 530016, Peoples R China.
   Lei, Langhuan; Li, Wei, Guangxi Acad Med Sci, Nanning 530016, Peoples R China.
   Li, Wei, Guangxi Zhuang Autonomous Reg Peoples Hosp, Dept Hlth Management, Nanning 530016, Peoples R China.},
DOI = {10.1016/j.jrras.2025.101657},
EarlyAccessDate = {JUN 2025},
Article-Number = {101657},
Keywords = {Lung cancer; CT images; UNETR; Tumor segmentation; Radiomic features;
   Machine learning},
Keywords-Plus = {NEURAL-NETWORKS; RADIOMICS; PREDICTION; FEATURES; DEEP},
Author-Email = {liwei2186gxqyy@163.com},
Number-of-Cited-References = {45},
Times-Cited = {2},
Unique-ID = {WOS:001512629600001},
}

@article{ WOS:001506164800007,
Author = {Ozaki, Hiroyuki and Ishida, Naoya and Kiyobayashi, Tetsu},
Title = {Prediction of the space group and cell volume by training a
   convolutional neural network with primitive `ideal' diffraction profiles
   and its application to `real' experimental data},
Journal = {JOURNAL OF APPLIED CRYSTALLOGRAPHY},
Year = {2025},
Volume = {58},
Number = {3},
Pages = {718-730},
Month = {JUN},
Abstract = {This study describes a deep learning approach to predict the space group
   and unit-cell volume of inorganic crystals from their powder X-ray
   diffraction profiles. Using an inorganic crystallographic database,
   convolutional neural network (CNN) models were successfully constructed
   with the.-function-like `ideal' X-ray diffraction profiles derived
   solely from the intrinsic properties of the crystal structure, which are
   dependent on neither the incident X-ray wavelength nor the line shape of
   the profiles. We examined how the statistical metrics (e.g. the
   prediction accuracy, precision and recall) are influenced by the
   ensemble averaging technique and the multi-task learning approach; six
   CNN models were created from an identical data set for the former, and
   the space group classification was coupled with the unit-cell volume
   prediction in a CNN architecture for the latter. The CNN models trained
   in the `ideal' world were tested with `real' X-ray profiles for eleven
   materials such as TiO2, LiNiO2 and LiMnO2. While the models mostly fared
   well in the `real' world, the cases at odds were scrutinized to
   elucidate the causes of the mismatch. Specifically for Li2MnO3, detailed
   crystallographic considerations revealed that the mismatch can stem from
   the state of the specific material and/or from the quality of the
   experimental data, and not from the CNN models. The present study
   demonstrates that we can obviate the need for emulating experimental
   diffraction profiles in training CNN models to elicit structural
   information, thereby focusing efforts on further improvements.},
Type = {Article},
Affiliation = {Kiyobayashi, T (Corresponding Author), Natl Inst Adv Ind Sci \& Technol, Res Inst Electrochem Energy, Environm \& Energy Dept, I-8-31 Midorigaoka, Ikeda, Osaka 5638577, Japan.
   Ozaki, Hiroyuki; Ishida, Naoya; Kiyobayashi, Tetsu, Natl Inst Adv Ind Sci \& Technol, Res Inst Electrochem Energy, Environm \& Energy Dept, I-8-31 Midorigaoka, Ikeda, Osaka 5638577, Japan.},
DOI = {10.1107/S1600576725002419},
Keywords = {space group classification; deep learning; powder X-ray diffraction;
   ensemble averaging; multi-task learning},
Keywords-Plus = {CRYSTAL-STRUCTURE; CLASSIFICATION},
Author-Email = {kiyobayashi-t@aist.go.jp},
Number-of-Cited-References = {35},
Times-Cited = {2},
Unique-ID = {WOS:001506164800007},
}

@article{ WOS:001494951100001,
Author = {Torabi, Mohammadreza and Sardari, Soroush and Rodriguez-Martinez,
   Alejandro and Arabi, Nooshin and Perez-Sanchez, Horacio and Ghasemi,
   Fahimeh},
Title = {Drug repurposing to identify potential FDA-approved drugs targeting
   three main angiogenesis receptors through a deep learning framework},
Journal = {MOLECULAR DIVERSITY},
Year = {2025},
Volume = {29},
Number = {4, SI},
Pages = {3637-3659},
Month = {AUG},
Abstract = {Tumor cell survival depends on the presence of oxygen and nutrients
   provided by existing blood vessels, particularly when cancer is in its
   early stage. Along with tumor growth in the vicinity of blood vessels,
   malignant cells require more nutrients; hence, capillary sprouting
   occurs from parental vessels, a process known as angiogenesis. Although
   multiple cellular pathways have been identified, controlling them with
   one single biomolecule as a multi-target inhibitor could be an
   attractive strategy for reducing medication side effects. Three critical
   pathways in angiogenesis have been identified, which are activated by
   the vascular endothelial growth factor receptor (VEGFR), fibroblast
   growth factor receptor (FGFR), and epidermal growth factor receptor
   (EGFR). This study aimed to develop a methodology to discover
   multi-target inhibitors among over 2000 FDA-approved drugs. Hence, a
   novel ensemble approach was employed, comprising classification and
   regression models. First, three different deep autoencoder
   classifications were generated for each target individually. The top 100
   trained models were selected for the high-throughput virtual screening
   step. After that, all identified molecules with a probability of more
   than 0.9 in more than 70\% of the models were removed to ensure accurate
   consideration in the regression step. Since the ultimate aim of virtual
   screening is to discover molecules with the highest success rate in the
   pharmaceutical industry, various aspects of the molecules in different
   assays were considered by integrating ten different regression models.
   In conclusion, this paper contributes to pharmaceutical sciences by
   introducing eleven diverse scaffolds and eight approved drugs that can
   potentially be used as inhibitors of angiogenesis receptors, including
   VEGFR, FGFR, and EGFR. Considering three target receptors simultaneously
   is another central concept and contribution used. This concept could
   increase the chance of success, while reducing the possibility of
   resistance to these agents.},
