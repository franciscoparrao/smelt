   Shen, Dinggang, Univ N Carolina, Dept Radiol, Chapel Hill, NC 27599 USA.
   Shen, Dinggang, Korea Univ, Dept Brain \& Cognit Engn, Seoul 02841, South Korea.},
DOI = {10.1109/TMI.2016.2519264},
