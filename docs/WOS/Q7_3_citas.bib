DOI = {10.1016/j.jnoncrysol.2025.123613},
EarlyAccessDate = {MAY 2025},
Article-Number = {123613},
Keywords = {Machine learning; Glass composition; Refractive index; Softening
   temperature; Thermal expansion},
Keywords-Plus = {REFRACTIVE-INDEX; ADVANTAGES; DYNAMICS; DENSITY; ZINC},
Author-Email = {qiaoang@whut.edu.cn
   thz@whut.edu.cn},
Number-of-Cited-References = {58},
