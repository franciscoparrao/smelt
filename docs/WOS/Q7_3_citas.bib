@incollection{ WOS:000693921300071,
Author = {Sanden, Chris and Zhang, John Z.},
Book-Group-Author = {ACM},
Title = {Enhancing Multi-Label Music Genre Classification Through Ensemble
   Techniques},
Booktitle = {PROCEEDINGS OF THE 34TH INTERNATIONAL ACM SIGIR CONFERENCE ON RESEARCH
   AND DEVELOPMENT IN INFORMATION RETRIEVAL (SIGIR'11)},
Year = {2011},
Pages = {705-714},
Abstract = {In the field of Music Information Retrieval (MIR), multi-label genre
   classification is the problem of assigning one or more genre labels to a
   music piece. In this work, we propose a set of ensemble techniques,
   which are specific to the task of multi-label genre classification. Our
   goal is to enhance classification performance by combining multiple
   classifiers. In addition, we also investigate some existing ensemble
   techniques from machine learning. The effectiveness of these techniques
   is demonstrated through a set of empirical experiments and various
   related issues are discussed. To the best of our knowledge, there has
   been limited work on applying ensemble techniques to multi-label genre
   classification in the literature and we consider the results in this
   work as our initial efforts toward this end. The significance of our
   work has two folds: (1) proposing a set of ensemble techniques specific
   to music genre classification and (2) shedding light on further research
   along this direction.},
Type = {Proceedings Paper},
Affiliation = {Sanden, C (Corresponding Author), Univ Lethbridge, Math \& Comp Sci, Lethbridge, AB T1K 3M4, Canada.
   Sanden, Chris; Zhang, John Z., Univ Lethbridge, Math \& Comp Sci, Lethbridge, AB T1K 3M4, Canada.},
Keywords = {Music Information Retrieval (MIR); genre classification; multi-label
   classification; ensemble techniques},
Keywords-Plus = {PERFORMANCE},
Author-Email = {sanden@cs.uleth.ca
   zhang@cs.uleth.ca},
Number-of-Cited-References = {26},
Times-Cited = {35},
