   Room, Shah, Ghalib Univ, Kabul, Afghanistan.},
DOI = {10.1007/s11869-022-01255-3},
EarlyAccessDate = {OCT 2022},
Keywords = {Air quality prediction; Environmental sustainability; Air pollution;
   Machine learning techniques; Environmental impacts},
Author-Email = {shah.fahad@mail.xjtu.edu.cn
