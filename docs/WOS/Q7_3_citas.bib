   Alginahi, Yasser, Adrian Coll, Dept Comp Sci, Michigan, ND USA.
   Said, Wael, Zagazig Univ, Fac Comp \& Informat, Comp Sci Dept, Zagazig 44511, Egypt.},
DOI = {10.1016/j.compeleceng.2025.110543},
EarlyAccessDate = {JUN 2025},
