   Cerri, Ricardo, Univ Fed Sao Carlos, Dept Comp Sci, Rodovia Washington Luis,Km 235, BR-13565905 Sao Carlos, SP, Brazil.},
DOI = {10.1007/s10618-020-00704-w},
EarlyAccessDate = {JUL 2020},
Keywords = {Active learning; Hierarchical multi-label classification; Predictive
