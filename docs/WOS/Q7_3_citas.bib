DOI = {10.1007/s11548-016-1493-1},
Keywords = {Liver tumor segmentation; Random forest; Supervoxels; Dynamic features;
   Hierarchical multi-scale tree; Spatial adaptivity},
Keywords-Plus = {DECISION FORESTS; AUTOMATIC SEGMENTATION; CRITERIA; CLASSIFICATION;
   VALIDATION; CONTEXT},
