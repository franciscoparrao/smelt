}

@incollection{ WOS:000463034400133,
Author = {Ibrahim, Mai and Torki, Marwan and El-Makky, Nagwa},
Editor = {Wani, MA and Kantardzic, M and Sayedmouchaweh, M and Gama, J and Lughofer, E},
Title = {Imbalanced Toxic Comments Classification using Data Augmentation and
   Deep Learning},
Booktitle = {2018 17TH IEEE INTERNATIONAL CONFERENCE ON MACHINE LEARNING AND
   APPLICATIONS (ICMLA)},
Year = {2018},
Pages = {875-878},
Abstract = {Recently cyber-bullying and online harassment have become two of the
   most serious issues in many public online communities. In this paper, we
   use data from Wikipedia talk page edits to train multi-label classifier
   that detects different types of toxicity in online user-generated
   content. We present different data augmentation techniques to overcome
   the data imbalance problem in the Wikipedia dataset. The proposed
   solution is an ensemble of three models: convolutional neural network
   (CNN), bidirectional long short-term memory (LSTM) and bidirectional
   gated recurrent units (GRU). We divide the classification problem into
   two steps, first we determine whether or not the input is toxic then we
   find the types of toxicity present in the toxic content. The evaluation
   results show that the proposed ensemble approach provides the highest
   accuracy among all considered algorithms. It achieves 0.828 F-1-score
   for toxic/non-toxic classification and 0.872 for toxicity types
   prediction.},
Type = {Proceedings Paper},
Affiliation = {Ibrahim, M (Corresponding Author), Alexandria Univ, Comp \& Syst Engn Dept, Alexandria, Egypt.
   Ibrahim, Mai; Torki, Marwan; El-Makky, Nagwa, Alexandria Univ, Comp \& Syst Engn Dept, Alexandria, Egypt.},
