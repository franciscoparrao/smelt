   Memeo, R.; Pessaux, P., Inst Hosp Univ Strasbourg, Strasbourg, France.},
DOI = {10.1109/ISBI.2016.7493296},
Keywords = {liver tumor segmentation; random forest; supervoxels; hierarchical
   multi-scale tree; spatial adaptivity},
Keywords-Plus = {DECISION FORESTS},
Number-of-Cited-References = {11},
