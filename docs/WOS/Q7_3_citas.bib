   structure; forest classification; high resolution imagery; NAIP;
   multi-task learning},
Keywords-Plus = {NEAREST-NEIGHBOR IMPUTATION; ABOVEGROUND BIOMASS; UNITED-STATES;
   LAND-COVER; TEXTURE; MANAGEMENT; LANDSCAPE; IMAGERY; LIDAR; SCALE},
Author-Email = {tony@csp-inc.org
   brandon@csp-inc.org
   brett@csp-inc.org
   luke@csp-inc.org},
Number-of-Cited-References = {91},
