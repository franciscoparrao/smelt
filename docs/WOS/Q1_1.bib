   Noto, Naoki; Saito, Susumu, Nagoya Univ, Integrated Res Consortium Chem Sci IRCCS, Nagoya 4648602, Japan.},
DOI = {10.1021/acs.joc.4c02347},
EarlyAccessDate = {JAN 2025},
Keywords-Plus = {ASYMMETRIC HYDROGENATION; HOMOGENEOUS CATALYSIS; AMINO-ACIDS; LIGANDS;
