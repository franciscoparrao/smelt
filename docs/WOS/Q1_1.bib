DOI = {10.1016/j.apsusc.2023.156675},
EarlyAccessDate = {FEB 2023},
Article-Number = {156675},
Keywords = {MD; DFT; Phenylenediamines; X-ray absorption spectroscopy; Gas-liquid
   interface},
Keywords-Plus = {GAUSSIAN-BASIS SETS; MOLECULAR CALCULATIONS; CARBON DOTS; ATOMS; RED},
Author-Email = {xushaofeng@dhu.edu.cn},
Number-of-Cited-References = {35},
Times-Cited = {5},
Unique-ID = {WOS:000942467400001},
}

@article{ WOS:001675406700002,
Author = {Garcia, Ignacio and Giovanini, Leonardo and Lopez, Leonardo},
Title = {Predictive modeling and spatiotemporal analysis of TB in Argentina:
   Advancing control efforts through machine learning},
Journal = {PUBLIC HEALTH},
Year = {2026},
Volume = {252},
Month = {MAR},
Abstract = {Objectives: To improve prediction and understanding of TB dynamics in
   Argentina, identifying key risk factors and high-incidence areas to
   inform surveillance and public health control strategies. Study design:
   Retrospective observational study. Methods: We applied (i) machine
   learning models (Histogram-Based Gradient Boosting, XGBoost, Random
   Forest, and Logistic Regression) to predict treatment outcomes, (ii)
   time series models (ARIMA, SARIMAX, and LSTM) to forecast weekly TB case
   counts, and (iii) spatial analysis tools (LISA, Moran's I) to identify
   high-incidence clusters. Results: Weekly TB notifications increased
   after the onset of the COVID-19 pandemic (t = 4.75, p = 2.10 x 10(-6)),
   with LISA revealing two significant clusters (p < 0.05). HGB predicted
   treatment outcomes (ROC-AUC = 0.86; top predictors: HIV, treatment
   duration, age). LSTM outperformed SARIMAX (RMSE 3.50 -> 2.88 in
   Salta-Jujuy; 3.82 -> 0.89 in Autonomous City of Buenos Aires
   (CABA)-Buenos Aires; -18 \%/-77 \%). A sex-difference test indicated
   higher infection among men (p < 0.05). Conclusions: Combining ML and
   spatial tools enhances TB monitoring by supporting early identification
   of high-risk areas, improving epidemiological surveillance, and enabling
   targeted, data-driven public health interventions in Argentina.},
Type = {Article},
Affiliation = {Lopez, L (Corresponding Author), Barcelona Inst Global Hlth, Dr Aiguader 88, Barcelona 08003, Spain.
   Garcia, Ignacio, Univ Barcelona, Fac Matemat Informat, Barcelona 08007, Spain.
   Garcia, Ignacio; Lopez, Leonardo, Barcelona Inst Global Hlth, Dr Aiguader 88, Barcelona 08003, Spain.
   Giovanini, Leonardo, Litoral Natl Univ, Res Inst Signals Syst \& Computat Intelligence, RA-3000 Santa Fe, Argentina.},
DOI = {10.1016/j.puhe.2026.106151},
EarlyAccessDate = {JAN 2026},
Article-Number = {106151},
Keywords = {Tuberculosis (TB); Machine learning (ML); Epidemiology; Public health;
   Predictive modeling; Argentina},
Author-Email = {leonardorafael.lopez@isglobal.org},
Number-of-Cited-References = {21},
Times-Cited = {0},
