}

@article{ WOS:001695415900001,
Author = {Zhang, Peng and Wang, Shaopeng and Zhang, Shuna},
Title = {Optimized prediction of peak floor acceleration, peak inter-story drift
   ratio, and residual inter-story drift ratio in steel moment-resisting
   frames using innovative techniques},
Journal = {SOIL DYNAMICS AND EARTHQUAKE ENGINEERING},
Year = {2026},
Volume = {204},
Month = {MAY},
Abstract = {Construction industry needs a precise prediction for seismic response
   for buildings. Key indicators assessed in seismic analysis include the
   Peak Inter-story Drift Ratio (PIDR), Peak Floor Acceleration (PFA), and
   Residual Inter-story Drift Ratio (RIDR). Target of this study is to make
   machine-learning-based predictions for the mentioned parameters, so
   several machine-learning algorithms along with optimization algorithms
   have been utilized. Decision Tree Regression (DTR), Elastic Net
   Regression (ENR), Histogram Gradient Boosting (HGBR), and Random Forest
   Regression (RFR) are models, and Moth Flame Optimization (MFO), Parrot
   Optimizer (PO), and Bayesian Optimizer (BO) are optimizers used to make
   several hybrid models, improving the performance of single models. For
   optimizing calculation process and reducing runtime, feature selection
   and outlier detection by Recursive Feature Elimination (RFE) and Zscore
   techniques have been implemented. The results of predictions have been
   evaluated through five statistical metrics, including Coefficient f
   Determination (R2), Root Mean Squared Error (RMSE), Relative Absolute
   Error (RAE), 95\% Uncertainty Interval (U95), Mean Normalized Bias
   (MNB), and Mean Absolute Percentage Error (MAPE). Furthermore, the
   runtime for all the models, along with analysis of sensitivity by the
   FAST and SHAP methods have been presented to measure the impact of
   inputs on the target values. According to the results of test phase for
   target PFA, RFPO (RFR + PO) with values of 0.9921 and 1.036,
   respectively for R2 and RMSE, is the best hybrid model amongst all
   models. For PIDR, HGPO (HGBR + PO) indicates better performance R2 and
   RMSE being 0.9652 and 0.0007. On the other hand, for RIDR, the
   best-performed model is RFMO as it has R2 value of 0.9956 and RMSE value
   of 0.00001.},
Type = {Article},
Affiliation = {Zhang, P (Corresponding Author), Hebei Vocat Univ Technol \& Engn, Dept Architectural Engn, Xingtai 054000, Hebei, Peoples R China.
   Zhang, Peng; Wang, Shaopeng; Zhang, Shuna, Hebei Vocat Univ Technol \& Engn, Dept Architectural Engn, Xingtai 054000, Hebei, Peoples R China.},
DOI = {10.1016/j.soildyn.2026.110189},
EarlyAccessDate = {FEB 2026},
Article-Number = {110189},
Keywords = {Seismic analysis; Machine-learning; Peak inter-story drift; Residual
   inter-story drift; Peak floor accelerations; Sensitivity analysis},
Keywords-Plus = {DEMANDS; REGULARIZATION; DEFORMATIONS},
Author-Email = {zhangpeng8246@126.com
   whylove1@163.com
