@article{ WOS:001551559700001,
Author = {Duran, Cristhian and Carrillo, Jeniffer and Perez, Omar and Quintero,
   Marcel and Bautista, Gustavo},
Title = {Electronic Nose Based on MEMS Sensors for Noninvasive Detection of
   Colorectal Cancer via Breath Profiling},
Journal = {IEEE SENSORS LETTERS},
Year = {2025},
Volume = {9},
Number = {9},
Month = {SEP},
Abstract = {This letter presents a micro-electro-mechanical systems (MEMSs)
   sensor-based electronic nose (eNose) designed for noninvasive and rapid
   colorectal cancer (CRC) detection through exhaled breath analysis. A
   total of 125 breath samples were collected from 62 patients (27 CRC and
   35 controls) under controlled clinical conditions. The eNose system
   comprises a 14-sensor array of MEMS metal-oxide gas sensors, capable of
   capturing distinct patterns of volatile organic compounds associated
   with CRC. Data preprocessing involved logarithmic difference
   transformation, MinMaxScaler normalization, and orthogonal signal
   correction. Dimensionality reduction via principal component analysis
   (PCA) and data classification were applied through supervised learning
   algorithms, including Support Vector Machine, Logistic Regression (LR),
   Histogram-based Gradient Boosting, Na \& iuml;ve Bayes, k-Nearest
   Neighbors, and Random Forest. The best performance was achieved using
   PCA+LR, with an accuracy of 91.9\%, precision of 92.3\%, and specificity
   of 94.3\%, respectively. These results validate the feasibility of the
   MEMS-eNose system as a portable, cost-effective, and noninvasive
   diagnostic tool for CRC detection.},
Type = {Article},
Affiliation = {Durán, C (Corresponding Author), Univ Pamplona, Dept EEST, GISM Grp, Pamplona 543050, Colombia.
   Duran, Cristhian; Carrillo, Jeniffer; Bautista, Gustavo, Univ Pamplona, Dept EEST, GISM Grp, Pamplona 543050, Colombia.
