Keywords = {Inverse structural design; Explainable artificial intelligence;
   Surrogate modelling; Structural design automation; Perforated steel
   beams},
Keywords-Plus = {STEEL BEAMS; STRENGTH; OPTIMIZATION},
Author-Email = {sina.sarfarazi@unina.it},
