   Evrendilek, Fatih, Ardahan Univ, Dept Environm Engn, TR-75002 Ardahan, Turkey.},
DOI = {10.1016/j.renene.2019.11.038},
Keywords = {Thermochemical conversions; Box-Behnken design; Machine learning;
