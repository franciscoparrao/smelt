   Alashi, Alaa; Murugiah, Karthik, Yale Sch Med, Dept Internal Med, Sect Cardiovasc Med, New Haven, CT 06510 USA.
   Murugiah, Karthik, Yale New Haven Hosp, Ctr Outcomes Res \& Evaluat, New Haven, CT 06510 USA.},
DOI = {10.1371/journal.pone.0336809},
