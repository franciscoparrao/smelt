@article{ WOS:000971222500016,
Author = {Patro, Sibo Prasad and Padhy, Neelamadhab and Sah, Rahul Deo},
Title = {An Ensemble Approach for Prediction of Cardiovascular Disease Using Meta
   Classifier Boosting Algorithms},
Journal = {INTERNATIONAL JOURNAL OF DATA WAREHOUSING AND MINING},
Year = {2022},
Volume = {18},
Number = {1},
Abstract = {There are very few studies are carried for investigating the potential
   of hybrid ensemble machine learning techniques for building a model for
   the detection and prediction of heart disease in the human body. In this
   research, the authors deal with a classification problem that is a
   hybridization of fusion-based ensemble model with machine learning
   approaches, which produces a more trustworthy ensemble than the original
   ensemble model and outperforms previous heart disease prediction models.
   The proposed model is evaluated on the Cleveland heart disease dataset
   using six boosting techniques named XGBoost, AdaBoost, Gradient
   Boosting, LightGBM, CatBoost, and Histogram-Based Gradient Boosting.
   Hybridization produces superior results under consideration of
   classification algorithms. The remarkable accuracies of 96.51\% for
   training and 93.37\% for testing have been achieved by the Meta-XGBoost
   classifier.},
Type = {Article},
Affiliation = {Patro, SP (Corresponding Author), GIET Univ, Gunupur, India.
   Patro, Sibo Prasad; Padhy, Neelamadhab, GIET Univ, Gunupur, India.
   Sah, Rahul Deo, Dr Shyama Prasad Mukherjee Univ, Ranchi, India.},
DOI = {10.4018/IJDWM.316145},
Keywords = {AdaBoost; CatBoost; Classification Algorithms; Fusion-Based Ensemble
   Model; Gradient Boosting; Histogram-Based Gradient Boosting;
   Hybridization; LightGBM; XGBoost},
Keywords-Plus = {HEART-DISEASE; NEURAL-NETWORKS; SYSTEM; ASSOCIATION; DIAGNOSIS; FAILURE;
   TREE},
Number-of-Cited-References = {47},
Times-Cited = {2},
Unique-ID = {WOS:000971222500016},
