   Desalination; Economic assessment; Multi-criteria optimization},
Keywords-Plus = {MULTIOBJECTIVE OPTIMIZATION; ENERGY; FUTURE},
Author-Email = {601023@zjsru.edu.cn},
Number-of-Cited-References = {51},
