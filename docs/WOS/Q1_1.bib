DOI = {10.1109/JBHI.2024.3363765},
Keywords = {Artificial intelligence; cost-sensitive classification; ordinal
   classification; SARS-CoV-2 pneumonia; severity prediction; COVID-19},
Keywords-Plus = {ARTIFICIAL-INTELLIGENCE; RISK; SELECTION},
