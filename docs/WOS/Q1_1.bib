}

@article{ WOS:001713059000001,
Author = {Rajput, Gayatri and Gosu, Vijayalakshmi and Nemiwal, Meena and
   Subbaramaiah, Verraboina},
Title = {Machine learning approach for predicting fluoroquinolone adsorption on
   metal-organic frameworks},
Journal = {CHEMICAL ENGINEERING RESEARCH \& DESIGN},
Year = {2026},
Volume = {228},
Pages = {247-264},
Month = {APR},
Abstract = {This study explores the adsorption behavior of fluoroquinolone
   antibiotics (ciprofloxacin (CPX) and levofloxacin (LVX)) onto
   metal-organic frameworks (MOFs) through the integration of advanced
   machine learning (ML) techniques. The influence of important
   physicochemical properties of adsorbent such specific surface area, and
   average pore width, along with critical operational parameters including
   pH, initial antibiotic concentration, adsorbent dose, contact time, and
   temperatures, were systematically evaluated in relation to adsorption
   capacity and removal efficiency. Pearson correlation analysis
   highlighted the amphoteric behavior of CPX and LVX, revealed that pH and
   contact time are the dominant factors governing adsorption efficiency. A
   suite of ML regression algorithms including Random Forest (RF), Gradient
   boosting regressor (GBR), XGBoost (XG-B), Histogram-based gradient
   boosting (HGBR), AdaBoost (Ada-B), and CatBoost (Cat-B) were employed to
   predict the adsorption performance. Among these, the GBR model achieved
   the highest predictive accuracy (R2 = 1.0) and lowest root mean square
   error (RMSE), indicated superior predictive accuracy. Nevertheless,
   residual error and stability assessments demonstrated that the XG-B
   provided superior generalization capability when applied to unseen
   datasets, demonstrating its reliability for practical applications.
   Furthermore, SHAP analysis identified pH and initial antibiotic
   concentration as the most influential variable, followed by temperature
   and adsorbent dose. The integration of ML model with adsorption data
   provides a powerful predictive framework for understanding and
   optimizing the removal of antibiotics using MOFs, thereby enhancing the
   design of efficient and sustainable wastewater treatment plants.},
Type = {Article},
