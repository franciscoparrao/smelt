Keywords = {Micropollutants; XGBoost; Machine learning; Photoreactivity; center dot
   OH and SO4 center dot-},
Keywords-Plus = {WASTE-WATER EFFLUENT; DRINKING-WATER; DEGRADATION; PHARMACEUTICALS;
