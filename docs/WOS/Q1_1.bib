   Zhang, Zeyu, Australian Natl Univ, Canberra, ACT 2601, Australia.
   Wu, Biao, Australian Artificial Intelligence Inst, Sydney, NSW, Australia.},
DOI = {10.1109/EMBC58623.2025.11251774},
Keywords = {Lung cancer; Radiation therapy; Radiation pneumonitis; CT; Dose; Machine
