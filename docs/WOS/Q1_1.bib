DOI = {10.32604/cmc.2024.055106},
Keywords = {Diabetic retinopathy; transfer learning; machine learning; fundus
   images; binary classification; APTOS},
Author-Email = {aaurrahman@iau.edu.sa},
Number-of-Cited-References = {27},
