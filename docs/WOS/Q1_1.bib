   Seo, Yongwon, Ulsan Natl Inst Sci \& Technol, Grad Sch Carbon Neutral, Ulsan 44919, South Korea.},
DOI = {10.1021/acs.energyfuels.3c04930},
EarlyAccessDate = {MAR 2024},
