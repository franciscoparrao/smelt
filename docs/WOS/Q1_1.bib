Keywords = {lung cancer; machine learning; radiation pneumonitis; prediction;
   radiotherapy},
Keywords-Plus = {3-DIMENSIONAL CONFORMAL RADIOTHERAPY; VOLUME HISTOGRAM ANALYSIS;
