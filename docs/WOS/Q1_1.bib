Affiliation = {Alzubi, Y (Corresponding Author), Al Balqa Appl Univ, Fac Engn Technol, Civil Engn Dept, Amman, Jordan.
   Al Adwan, J.; Alzubi, Y.; Alkhdour, A.; Alqawasmeh, H., Al Balqa Appl Univ, Fac Engn Technol, Civil Engn Dept, Amman, Jordan.},
