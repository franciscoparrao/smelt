}

@article{ WOS:001647004400001,
Author = {Yang, Yongjian and Liu, Yanhui and He, Yuqian and Pan, Zengren and Li,
   Zhiwei},
Title = {A Hybrid Estimation Model for Graphite Nodularity of Ductile Cast Iron
