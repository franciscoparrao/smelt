   Mwakipunda, Grant Charles, China Univ Geosci, Key Lab Theory \& Technol Petr Explorat \& Dev Hubei, Wuhan 430074, Peoples R China.},
DOI = {10.1007/s10668-024-05566-6},
EarlyAccessDate = {OCT 2024},
Keywords = {Environmental sustainability; Emissions; Machine learning algorithms;
   Energy consumption; Variance decomposition},
