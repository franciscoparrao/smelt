Article-Number = {114329},
Keywords = {Haloacetic acids; Secondary water supply systems; UV-Vis; EEM; RF},
Keywords-Plus = {DISSOLVED ORGANIC-MATTER; DRINKING-WATER; QUALITY; PARAFAC; COD},
Author-Email = {liji99@hit.edu.cn
   whj1533qihan@163.com},
