@article{ WOS:001621786600001,
Author = {Mounika, Kandi and Goel, Akash and Bhattacharjee, Ankur},
Title = {An accurate prediction of power sharing in a fuel-cell-based
   grid-interactive local energy system using machine learning techniques},
Journal = {INTERNATIONAL JOURNAL OF HYDROGEN ENERGY},
Year = {2025},
Volume = {196},
Month = {DEC 8},
Abstract = {This paper presents a novel approach for the accurate prediction of
   shared power between the fuel cell and the AC distribution grid using
   machine learning (ML) algorithms for local load demand management. The
   proposed approach is framed in a three-stage structure. In phase 1,
   several ML algorithms such as AdaBoost, extra trees, gradient boosting,
   histogram gradient boosting, k-nearest neighbours (KNN), light GBM,
   linear regression (LR), random forest (RF), stacking regressor, support
   vector machines (SVM), voting regressor (VR), and XGBoost are evaluated
   for PEMFC-grid shared power prediction to manage dynamic load demand.
   Phase 2 focuses on training and validating these ML models using
   pre-processed experimental data for a kW-scale PEMFC-grid connected
   system. The ML model performance is assessed using error metrics such as
   correlation coefficient (R-2), mean absolute error (MAE), root mean
   square error (RMSE) and computational time. In phase 3, after evaluating
   all ML models, AdaBoost shows the highest prediction accuracy (R-2
   similar to 90 \%) with moderate computational time, and is thus
   considered to be the most suitable ML model for this work. The
   accurately predicted day-ahead dynamic power profile supports further
   estimation of optimized load power sharing between the PEMFC and grid.
   Such a generalised solution is also applicable to scalable
   PEMFC-grid-interactive local energy systems.},
Type = {Article},
Affiliation = {Bhattacharjee, A (Corresponding Author), Birla Inst Technol \& Sci, Dept Elect \& Elect Engn, Hyderabad Campus, Hyderabad, India.
   Mounika, Kandi; Goel, Akash; Bhattacharjee, Ankur, Birla Inst Technol \& Sci, Dept Elect \& Elect Engn, Hyderabad Campus, Hyderabad, India.},
DOI = {10.1016/j.ijhydene.2025.152536},
EarlyAccessDate = {NOV 2025},
Article-Number = {152536},
Keywords = {Proton exchange membrane fuel cell (PEMFC); Machine learning (ML);
   Energy management; Power-sharing; AC distribution grid},
Author-Email = {a.bhattacharjee@hyderabad.bits-pilani.ac.in},
Number-of-Cited-References = {40},
Times-Cited = {1},
Unique-ID = {WOS:001621786600001},
}

@article{ WOS:001248187100006,
Author = {Karakus, Yasin and Altuntas, Volkan},
Title = {Protein complex detection from protein-protein interaction networks with
   machine learning methods},
Journal = {PAMUKKALE UNIVERSITY JOURNAL OF ENGINEERING SCIENCES-PAMUKKALE
   UNIVERSITESI MUHENDISLIK BILIMLERI DERGISI},
Year = {2024},
Volume = {30},
Number = {3},
Pages = {333-342},
Abstract = {Understanding Protein - Protein interaction networks, which show the
   interactions between proteins involved in tasks that are very important
   for our organisms such as structural support, storage, signal
   transduction and defence, provides a better understanding of cellular
   processes. One of the important studies carried out for this purpose is
   to try to detect protein complexes from protein - protein interaction
   networks. Supervised and unsupervised machine learning methods were used
   to detect protein complexes. It is known that the machine learning
   methods used produce better performance when more than one method is
   used together. Based on this knowledge, a method that detects protein
   complexes from protein-protein interaction networks is proposed in this
   study. The method first weights protein-protein interaction networks
   using biological and topological properties of proteins. Then it
   estimates local and global protein complex core. Then it builds a
   protein complex detection model using the structural modularity of
   proteins and the voting regression model. We predict that XGB
   regression, gaussian process regression, catboost regression and
   histogram -based gradient boosting regression supervised learning
   methods can achieve more successful results when used together in the
   voting regression model. When we compare the success of the model with
   other models, it has shown the best performance many times among the
   compared models.},
Type = {Article},
Affiliation = {Karakus, Y (Corresponding Author), Bursa Tech Univ, Grad Sch, Dept Comp Engn, Bursa, Turkiye.
   Karakus, Yasin, Bursa Tech Univ, Grad Sch, Dept Comp Engn, Bursa, Turkiye.
   Altuntas, Volkan, Bursa Tech Univ, Fac Engn \& Nat Sci, Dept Comp Engn, Bursa, Turkiye.},
DOI = {10.5505/pajes.2023.56887},
Keywords = {Protein-Protein interaction networks; Protein complex detection; Machine
   learning; Voting regression; Bioinformatics; Network embedding},
Keywords-Plus = {IDENTIFICATION; ALGORITHM},
Author-Email = {22435004005@ogrenci.btu.edu.tr
   volkan.altuntas@btu.edu.tr},
Number-of-Cited-References = {36},
Times-Cited = {1},
Unique-ID = {WOS:001248187100006},
}

@article{ WOS:001629277000003,
Author = {Sarfarazi, Sina and Shamass, Rabee and Rabi, Musab and Abarkan, Ikram
   and Ferreira, Felipe Piana Vendramell and Tsavdaridis, Konstantinos
   Daniel},
Title = {Inverse machine learning for the design of perforated beams: Parent
   section and material prediction},
Journal = {ENGINEERING APPLICATIONS OF ARTIFICIAL INTELLIGENCE},
Year = {2026},
Volume = {164},
Number = {A},
Month = {JAN 15},
Abstract = {This study introduces a novel machine learning-based inverse design
   methodology for predicting the parent cross-sectional and material
   properties of perforated steel beams with elliptically-based openings.
   Unlike conventional forward design or optimisation-based methods, the
   proposed approach frames structural design as an inverse problem. It
   enables the direct mapping of opening geometry and resistance parameters
   to essential properties such as section depth, flange width, web
   thickness, flange thickness, and yield strength. Five advanced
   supervised machine learning models including Histogram-Based Gradient
   Boosting, Random Forest, Extreme Gradient Boosting, k-Nearest Neighbors,
   and Support Vector Regression were trained on a dataset generated
   through forward structural analysis. This methodology develops
   non-iterative surrogate models that enhance the generalizability and
   accessibility of the structural design process. The models demonstrated
   excellent predictive performance, with coefficient of determination (R2)
   values exceeding 0.99 for most outputs. Shapley Additive Explanations
   (SHAP) analysis identified web-post buckling resistance and section
   height as the most influential input features, with other variables
   contributing depending on the output. The proposed inverse learning
   framework was also benchmarked against an analytical design model to
   assess accuracy and consistency. To support practical implementation, a
   user-friendly web tool was developed, allowing engineers and researchers
   to access instant predictions. Overall, this research offers an
   efficient and explainable data-driven solution for structural design,
   demonstrating the practical value of artificial intelligence in
   engineering applications.},
Type = {Article},
Affiliation = {Sarfarazi, S (Corresponding Author), Univ Naples Federico II, Dept Struct Engn \& Architecture, I-80125 Naples, Italy.
   Sarfarazi, Sina, Univ Naples Federico II, Dept Struct Engn \& Architecture, I-80125 Naples, Italy.
