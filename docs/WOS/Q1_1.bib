}

@article{ WOS:001478942000001,
Author = {Kapustynska, Viroslava and Abromavicius, Vytautas and Serackis, Arturas
   and Andruskevicius, Saulius and Ryliskiene, Kristina and Paulikas,
   Sarunas},
Title = {Advancing a generalizable model for migraine prediction: Analysis of
   filtering techniques on physiological signals},
Journal = {TECHNOLOGY AND HEALTH CARE},
Year = {2025},
Volume = {33},
Number = {5},
Pages = {2184-2193},
Month = {SEP},
Abstract = {Background Despite wearable sensors' ability to provide continuous
   physiologic monitoring, migraine remains challenging to predict due to
   unpredictability of onset and a variety of triggers. Developing an
   accurate prediction model requires reducing signal variability by using
   effective filtering techniques.Objective The main objective of this
   study is to evaluate machine learning models for predicting migraines
   and analyze the effect of different filtering techniques and classifiers
   on prediction performance.Methods A feature set based on ANOVA analysis
   of four key physiological signals was used. After the pre-processing,
   filtering methods, including median, Butterworth, and Savitzky-Golay
   filter, were applied. Five classification models, Extreme Gradient
   Boosting, Histogram-Based Gradient Boosting, Random Forest, Support
   Vector Machine, and K-Nearest Neighbors, were evaluated.Results The
   highest predictive performance was achieved using the Savitzky-Golay
   filter. The Random Forest model demonstrated the best accuracy (0.858)
   and precision (0.815), and an F1-score of 0.677, indicating the
   potential of investigated signals for migraine prediction. Furthermore,
   the Histogram-Based Gradient Boosting model achieved the highest recall
   using the Savitzky-Golay filter (0.719), demonstrating its effectiveness
   in identifying true positive cases of migraines.Conclusion The results
   indicate significant potential for healthcare applications for early
   migraine prediction and treatment using wearable technology. The study
   highlights the importance of selecting appropriate features and
   filtering methods to improve the accuracy and reliability of the
   predictions.},
Type = {Article},
Affiliation = {Kapustynska, V (Corresponding Author), Vilnius Gediminas Tech Univ, Fac Elect, Plytines St 25, LT-10105 Vilnius, Lithuania.
   Kapustynska, Viroslava; Abromavicius, Vytautas; Serackis, Arturas; Paulikas, Sarunas, Vilnius Gediminas Tech Univ, Fac Elect, Plytines St 25, LT-10105 Vilnius, Lithuania.
   Andruskevicius, Saulius; Ryliskiene, Kristina, Vilnius Univ, Ctr Neurol, LT-08406 Vilnius, Lithuania.},
DOI = {10.1177/09287329251332415},
EarlyAccessDate = {APR 2025},
Keywords = {digital signal processing; migraine disorders; machine learning;
   wearable devices; wearable device data},
Author-Email = {viroslava.kapustynska@vilniustech.lt},
Number-of-Cited-References = {39},
Times-Cited = {1},
Unique-ID = {WOS:001478942000001},
}

@article{ WOS:001655676800011,
Author = {Sasi, Deepika and Joseph, Thomas},
Title = {PWaveSense: DAS-Based Knowledge-Driven Seismic Signal Processing and
   Ensemble Learning Framework for REST API-Enabled Real-Time Earthquake
   Early Warning System},
Journal = {IEEE GEOSCIENCE AND REMOTE SENSING LETTERS},
Year = {2026},
Volume = {23},
Abstract = {Effective earthquake early warning (EEW) relies on accurate and rapid
   signal detection. This letter presents PWaveSense-a real-time earthquake
   detection framework using distributed acoustic sensing (DAS) data. The
   pipeline combines advanced signal processing, probabilistic feature
   relevance, and a stacked ensemble classifier. Using extreme gradient
   boosting (XGBoost)-based feature selection, synthetic minority
   oversampling technique (SMOTE), and second-order polynomial feature
   expansion, the model generalizes well across domains. PWaveSense
   achieved 100\% accuracy after a post hoc threshold-sweep calibration
   that optimized performance. However, the results are limited to binary
   classification on two real-world DAS datasets. An ablation study
   highlights each pipeline component's contribution. Real-time deployment
   via a Flask-based REST API yields sub-150-ms inference latency, making
   PWaveSense a scalable and robust solution for real-time EEW in diverse
   seismic environments.},
Type = {Article},
Affiliation = {Sasi, D (Corresponding Author), Natl Inst Technol Puducherry, Dept Elect \& Commun Engn, Karaikal 609609, India.
   Sasi, Deepika; Joseph, Thomas, Natl Inst Technol Puducherry, Dept Elect \& Commun Engn, Karaikal 609609, India.},
DOI = {10.1109/LGRS.2025.3648645},
Article-Number = {6002705},
Keywords = {Feature extraction; Earthquakes; Real-time systems; Optical fiber
   cables; Trees (botanical); Redundancy; Pipelines; Accuracy; Training;
   Polynomials; Distributed acoustic sensing (DAS); earthquake early
   warning (EEW); p-wave detection; REST API},
Author-Email = {deepikajoy2013@gmail.com
   thomas.joseph@nitpy.ac.in},
Number-of-Cited-References = {17},
