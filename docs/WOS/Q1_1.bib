   Sagasti, Guillermina, Pluspetrol, Lima 339, RA-1073 Caba, Argentina.},
DOI = {10.1016/j.uncres.2025.100293},
Article-Number = {100293},
Keywords = {Vaca Muerta Formation; Multiple Imputation; Miceforest; Random Forest;
