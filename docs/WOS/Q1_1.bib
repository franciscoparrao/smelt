   Azodinia, Mohamadreza, Obuda Univ, John Von Neumann Fac Informat, Budapest, Hungary.
   Mudabbir, Mohamed, Obuda Univ, Doctoral Sch Appl Informat \& Appl Math, Budapest, Hungary.},
DOI = {10.1109/SACI60582.2024.10619733},
Keywords = {Gas hydrate reservoirs; Thermodynamic aspects; Artificial intelligence
