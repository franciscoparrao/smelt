Unique-ID = {WOS:001533895000001},
}

@article{ WOS:001717781100001,
Author = {Hussain, Rehaan and Yaqoob, Mohammed and Ishaq, Mohammed and Saleh,
   Mohammad Alshaikh and Refaat, Shady S.},
Title = {Quantifying stator winding fault severity in induction motors: A machine
   learning approach with spectral feature extraction},
Journal = {INTERNATIONAL JOURNAL OF ELECTRICAL POWER \& ENERGY SYSTEMS},
Year = {2026},
Volume = {176},
Month = {MAR},
Abstract = {Induction motors (IMs) constitute a fundamental component of industrial
   infrastructure, accounting for approximately 60\%-70\% of global
   industrial energy consumption and driving critical manufacturing
   processes. The proliferation of electrical faults in electric motors,
   particularly in their incipient stages, presents significant challenges
   to operational reliability and energy efficiency, necessitating advanced
   fault diagnostic methodologies. The challenge lies in detecting the
   incipient fault in its early stages, as there is minimal damage and it
   may not be easily detectable. This paper introduces a novel machine
   learning-based framework for quantifying stator winding fault (SWF)
   severity in IMs through multi-domain signal analysis. The proposed
   methodology implements a hybrid feature extraction approach, integrating
   Fourier and wavelet transform coefficients derived from three-phase
   current signals to capture both frequency-domain characteristics and
   localized time-frequency patterns indicative of electrical degradation,
   along with statistical features. The experimental validation
   incorporates a diverse range of machine learning architectures, spanning
   traditional algorithmic approaches such as Support Vector Machines
   (SVMs) and advanced ensemble methodologies including Histogram Gradient
   Boosting (HGBM) and XGBoost (XGB). The proposed framework demonstrates
   superior fault detection capabilities, achieving classification accuracy
   exceeding 95\% across multiple evaluation metrics including precision
   (0.9952), recall (0.9949), and F1-score (0.9952), which is an extremely
   high score for a multiclassification model of four classes in signals.
   Furthermore, SHapley Additive exPlanation (SHAP) is used to recognize
   the important features that led to the success of the models. The
   obtained results establish the efficacy of machine learning techniques
   in facilitating early fault detection and enabling condition-based
   maintenance strategies, thereby enhancing operational reliability in
   industrial applications. To promote reproducibility and facilitate
   further research in this domain, the complete implementation framework,
   including source code, is made publicly available in
   https://github.com/rehaan-hussain/Quantifying-Electrical-Severity-in-Ind
   uction-Motors-A-Machine-Learning-Approach.},
Type = {Article},
Affiliation = {Hussain, R (Corresponding Author), Texas A\&M Univ Qatar, Elect \& Comp Engn, Doha, Qatar.
   Hussain, Rehaan; Yaqoob, Mohammed; Ishaq, Mohammed, Texas A\&M Univ Qatar, Elect \& Comp Engn, Doha, Qatar.
   Saleh, Mohammad Alshaikh, Texas A\&M Univ, Elect \& Comp Engn, College Stn, TX 77843 USA.
   Refaat, Shady S., Univ Hertfordshire, Sch Phys Engn \& Comp Sci, Hatfield, England.},
DOI = {10.1016/j.ijepes.2026.111705},
EarlyAccessDate = {MAR 2026},
Article-Number = {111705},
Keywords = {Fault detection; Predictive maintenance; Wavelet transform; Feature
   extraction; Electrical fault diagnosis},
Author-Email = {rehaan.hussain@qatar.tamu.edu},
Number-of-Cited-References = {43},
Times-Cited = {0},
Unique-ID = {WOS:001717781100001},
}

@article{ WOS:001138907800001,
Author = {Boncan, Delbert Almerick T. and Yu, Yan and Zhang, Miaoru and Lian, Jie
   and Vardhanabhuti, Varut},
Title = {Machine learning prediction of hepatic steatosis using body composition
   parameters: A UK Biobank Study},
Journal = {NPJ AGING},
Year = {2024},
Volume = {10},
Number = {1},
Month = {JAN 9},
Abstract = {Non-alcoholic fatty liver disease (NAFLD) has emerged as the most
   prevalent chronic liver disease worldwide, yet detection has remained
   largely based on surrogate serum biomarkers, elastography or biopsy. In
   this study, we used a total of 2959 participants from the UK biobank
   cohort and established the association of dual-energy X-ray
   absorptiometry (DXA)-derived body composition parameters and leveraged
   machine learning models to predict NAFLD. Hepatic steatosis reference
   was based on MRI-PDFF which has been extensively validated previously.
   We found several significant associations with traditional measurements
   such as abdominal obesity, as defined by waist-to-hip ratio (OR = 2.50
   (male), 3.35 (female)), android-gynoid ratio (OR = 3.35 (male), 6.39
   (female)) and waist circumference (OR = 1.79 (male), 3.80 (female)) with
   hepatic steatosis. Similarly, A Body Shape Index (Quantile 4 OR = 1.89
   (male), 5.81 (female)), and for fat mass index, both overweight (OR =
   6.93 (male), 2.83 (female)) and obese (OR = 14.12 (male), 5.32 (female))
   categories were likewise significantly associated with hepatic
   steatosis. DXA parameters were shown to be highly associated such as
   visceral adipose tissue mass (OR = 8.37 (male), 19.03 (female)), trunk
   fat mass (OR = 8.64 (male), 25.69 (female)) and android fat mass (OR =
   7.93 (male), 21.77 (female)) with NAFLD. We trained machine learning
   classifiers with logistic regression and two histogram-based gradient
   boosting ensembles for the prediction of hepatic steatosis using
   traditional body composition indices and DXA parameters which achieved
   reasonable performance (AUC = 0.83-0.87). Based on SHapley Additive
   exPlanations (SHAP) analysis, DXA parameters that had the largest
   contribution to the classifiers were the features predicted with
   significant association with NAFLD. Overall, this study underscores the
   potential utility of DXA as a practical and potentially opportunistic
   method for the screening of hepatic steatosis.},
Type = {Article},
Affiliation = {Vardhanabhuti, V (Corresponding Author), Snowhill Sci Ltd, Units 801-803,Level 8,Core C, Hong Kong, Peoples R China.
   Vardhanabhuti, V (Corresponding Author), Univ Hong Kong, Li Ka Shing Fac Med, Dept Diagnost Radiol, Hong Kong, Peoples R China.
   Boncan, Delbert Almerick T.; Yu, Yan; Vardhanabhuti, Varut, Snowhill Sci Ltd, Units 801-803,Level 8,Core C, Hong Kong, Peoples R China.
   Boncan, Delbert Almerick T., Chinese Univ Hong Kong, Sch Life Sci, Shatin, Hong Kong, Peoples R China.
   Zhang, Miaoru; Lian, Jie; Vardhanabhuti, Varut, Univ Hong Kong, Li Ka Shing Fac Med, Dept Diagnost Radiol, Hong Kong, Peoples R China.},
DOI = {10.1038/s41514-023-00127-z},
Article-Number = {4},
Keywords-Plus = {NONALCOHOLIC FATTY LIVER; X-RAY ABSORPTIOMETRY; CARDIOVASCULAR-DISEASE;
   SURFACE AREA; INCREASED PREVALENCE; KIDNEY-FUNCTION; ASSOCIATION;
   MANAGEMENT; NAFLD; RISK},
Author-Email = {varv@hku.hk},
Number-of-Cited-References = {72},
Times-Cited = {8},
Unique-ID = {WOS:001138907800001},
}

@article{ WOS:000849454800001,
Author = {Suyama, Shun and Kato, Shingo and Nakaura, Takeshi and Azuma, Mai and
   Kodama, Sho and Nakayama, Naoki and Fukui, Kazuki and Utsunomiya,
   Daisuke},
Title = {Machine learning to predict left ventricular reverse remodeling by
   guideline-directed medical therapy by utilizing texture feature of
   extracellular volume fraction in patients with non-ischemic dilated
   cardiomyopathy},
Journal = {HEART AND VESSELS},
Year = {2023},
Volume = {38},
Number = {3},
Pages = {361-370},
Month = {MAR},
Abstract = {Extracellular volume fraction (ECV) by cardiac magnetic resonance (CMR)
   allows for the non-invasive quantification of diffuse myocardial
   fibrosis. Texture analysis and machine learning are now gathering
   attention in the medical field to exploit the ability of diagnostic
   imaging for various diseases. This study aimed to investigate the
   predictive value of texture analysis of ECV and machine learning for
   predicting response to guideline-directed medical therapy (GDMT) for
   patients with non-ischemic dilated cardiomyopathy (NIDCM). A total of
   one-hundred and fourteen NIDCM patients {[}age: 63 +/- 12 years, 91
   (81\%) males] were retrospectively analyzed. We performed texture
   analysis of ECV mapping of LV myocardium using dedicated software. We
   calculated nine histogram-based features (mean, standard deviation,
   maximum, minimum, etc.) and five gray-level co-occurrence matrices. Five
   machine learning techniques and the fivefold cross-validation method
   were used to develop prediction models for LVRR by GDMT based on 14
   texture parameters on ECV mapping. We defined the LVRR as follows: LVEF
   increased >= 10\% points and decreased LVEDV >= 10\% on echocardiography
   after GDMT > 12 months. Fifty (44\%) patients were classified as
   non-responders. The area under the receiver operating characteristics
   curve for predicting non-responder was 0.82 for eXtreme Gradient
   Boosting, 0.85 for support vector machine, 0.76 for multi-layer
   perception, 0.81 for Naive Bayes, 0.77 for logistic regression,
   respectively. Mean ECV value was the most critical factor among texture
   features for differentiating NIDCM patients with LVRR and those without
   (0.28 +/- 0.03 vs. 0.36 +/- 0.06, p < 0.001). Machine learning analysis
   using the support vector machine may be helpful in detecting high-risk
   NIDCM patients resistant to GDMT. Mean ECV is the most crucial feature
   among texture features.},
Type = {Article},
Affiliation = {Kato, S (Corresponding Author), Yokohama City Univ, Dept Diagnost Radiol, Grad Sch Med, Yokohama, Kanagawa, Japan.
   Kato, S (Corresponding Author), Kanagawa Cardiovasc \& Resp Ctr, Dept Cardiol, Yokohama, Kanagawa, Japan.
   Suyama, Shun; Kato, Shingo; Utsunomiya, Daisuke, Yokohama City Univ, Dept Diagnost Radiol, Grad Sch Med, Yokohama, Kanagawa, Japan.
   Kato, Shingo; Azuma, Mai; Kodama, Sho; Nakayama, Naoki; Fukui, Kazuki, Kanagawa Cardiovasc \& Resp Ctr, Dept Cardiol, Yokohama, Kanagawa, Japan.
   Nakaura, Takeshi, Kumamoto Univ, Grad Sch Med, Dept Diagnost Radiol, Kumamoto, Japan.},
DOI = {10.1007/s00380-022-02167-z},
EarlyAccessDate = {SEP 2022},
Keywords = {Magnetic resonance; Histogram analysis; Extracellular volume fraction;
   Heterogeneity; Non-ischemic dilated cardiomyopathy},
Keywords-Plus = {DIFFUSE MYOCARDIAL FIBROSIS; MAGNETIC-RESONANCE; QUANTIFICATION;
   ASSOCIATION},
Author-Email = {sk513@yokohama-cu.ac.jp},
Number-of-Cited-References = {24},
Times-Cited = {3},
Unique-ID = {WOS:000849454800001},
}

@article{ WOS:001613760100001,
Author = {Ying, Zhao and Xia, Wang},
Title = {Dynamic Infrared Feature Enhancement Simulation Method for
   Multi-Temporal Landsat 8 Data},
Journal = {ACTA OPTICA SINICA},
Year = {2025},
Volume = {45},
Number = {19},
Month = {OCT},
Abstract = {Objective Land surface temperature (LST) is a key geophysical variable
   that reflects the thermal state of the Earth's surface and plays an
   essential role in characterizing the surface energy balance. Accurate
   LST retrieval is crucial for a variety of environmental and urban
   studies, including urban heat island monitoring, hydrological modeling,
   agricultural drought detection, and climate change assessment. Thermal
   infrared remote sensing is the primary technique for obtaining LST
   information at regional to global scales. However, conventional LST
   retrieval models-particularly those based on single-date, single-channel
   thermal imagery-are limited in their capacity to characterize the
   spatio-temporal variability and complex nonlinear influences of terrain,
   land cover, and atmospheric conditions. The need for enhanced methods
   that integrate multi-temporal information and address these limitations
   is becoming increasingly critical, especially for applications in
   heterogeneous urban landscapes. In response, we propose a novel
   correction framework that combines physical modeling with data-driven
   learning, using a multi-temporal dynamic feature fusion strategy to
   significantly improve LST retrieval accuracy. This hybrid approach not
   only enhances retrieval performance but also provides interpretability
   by quantifying the contributions of individual spatio-temporal features.
   Methods The proposed framework consists of a three-step workflow that
   leverages both physical models and machine learning for LST correction.
   First, an initial LST field is generated using a single-channel
   algorithm, which incorporates MODTRAN-simulated atmospheric parameters
   to correct for atmospheric effects. The surface emissivity is estimated
   using a vegetation cover-based model, and radiative transfer equations
   are applied to compute baseline surface temperature maps. Second, we
   construct a four-dimensional feature space to represent the
   spatio-temporal variability of land surface thermal behavior. The
   temporal features include the inter-monthly temperature differential
   matrix, which captures abrupt thermal changes between consecutive
   months, and seasonal standard deviation, which quantifies temperature
   variability within each season. Spatial features include terrain slope
   extracted from a 30 m resolution digital elevation model (DEM), and a
   binary urban land classification mask derived from 10 m European Space
   Agency (ESA) land cover data. These features are spatially aligned and
   fused using a Gaussian-weighted kernel to generate the final feature
   dataset. Third, the extreme gradient boosting (XGBoost) algorithm is
   employed to learn a nonlinear residual correction model. XGBoost is a
   scalable implementation of gradient boosting that incorporates
   second-order optimization, tree regularization, and parallel
   computation. It is well-suited for high-dimensional data and provides a
   mechanism to quantify feature importance, offering insights into which
   features most influence the temperature correction process. The model is
   trained on over 1.2 million valid pixels using Landsat 8 Collection 2
   Level-2 LST products as ground truth. Root mean square error (RMSE) and
   mean absolute error (MAE) are used as performance metrics, which are
   calculated for both the entire region and for urban/non-urban subsets.
   Results and Discussions The proposed framework shows substantial
   improvements in LST retrieval accuracy across different seasons and land
   types. Compared to the original single-channel method, the annual RMSE
   is reduced from 5.93 degrees C to 3.90 degrees C (a 34.
   2 degrees o improvement), and the MAE is reduced from 5.71 degrees C to
   3.43 degrees C (a 39.9 degrees o improvement). In urban built-up areas,
   where the thermal environment is more complex, the correction achieves a
   36.4 degrees o reduction in RMSE, demonstrating the framework's ability
   to handle heterogeneous surface conditions effectively (Fig. 4).
   Seasonal breakdown shows that the most significant improvement occurs in
   winter, where RMSE drops from 3.69 degrees C to 1.94 degrees C (a 47.4
   degrees o improvement). Feature importance analysis reveals that the
   winter seasonal standard deviation contributes 84.9 degrees o to the
   correction (Fig. 5 and Table 2), suggesting that temperature fluctuation
   during cold months is a strong predictor of residual error and thermal
   behavior. This reflects the influence of materials with high thermal
   inertia, such as concrete, which stores heat during the day and releases
   it at night, thereby amplifying seasonal dynamics in urban areas. To
   further evaluate model robustness, we performed an ablation experiment
   by removing the dynamic temporal features and retaining only static
   features (slope and urban land classification). The absence of temporal
   dynamics led to a deterioration in performance, with annual RMSE
   increasing by 11.3 degrees o and winter RMSE rising by 20.1 degrees o
   (Fig. 6). This confirms the indispensable role of temporal features in
   modeling the dynamic nature of LST. In addition, we conducted a
   comparative evaluation using two other machine learning methods:
   gradient boosted regression trees (GBRT) and random forest (RF). While
   GBRT achieved similar accuracy to XGBoost (RMSE of 3.896 degrees C ),
   its training time was significantly longer (1066.8 min vs. 7.5 min for
   XGBoost). RF performed worse in both accuracy and speed (Table 3). These
   results validate XGBoost as a highly efficient and effective solution
   for large-scale, multi-temporal LST retrieval tasks. Conclusions This
   study presents a novel hybrid framework that integrates multi-temporal
   thermal features with physical modeling and machine learning to enhance
   LST retrieval accuracy. By constructing a comprehensive spatio-temporal
   feature space and applying XGBoost-based residual correction, the
   proposed approach significantly improves retrieval performance and
   reduces seasonal biases. Importantly, the use of feature importance
   analysis offers new interpretability to the thermal infrared inversion
   process, allowing for better understanding and trust in the model's
   predictions. The framework represents a step forward in transitioning
   remote sensing from empirical ``black-box{''} models to explainable,
   data-informed physical modeling. It is especially well-suited for
   complex urban environments and offers a scalable, transferable method
   for dynamic thermal environment monitoring. These findings highlight the
   essential role of temporal dynamics in surface temperature estimation
   and pave the way for future applications in climate modeling, urban
   planning, and environmental monitoring.},
