   Piazza, Ornella; Cascella, Marco, Univ Salerno, Scuola Med Salernitana, Dept Med Surg \& Dent, Anesthesia \& Pain Med, I-84081 Baronissi, Italy.},
DOI = {10.62713/aic.3485},
