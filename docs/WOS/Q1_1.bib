   Rabi, Musab, Jerash Univ, Dept Civil Engn, Jerash 26150, Jordan.
   Abarkan, Ikram, Abdelmalek Essaadi Univ, Fac Sci, Dept Phys, Tetouan 93002, Morocco.
   Ferreira, Felipe Piana Vendramell, Univ Estadual Maringa, Dept Civil Engn, Maringa, Parana, Brazil.
   Tsavdaridis, Konstantinos Daniel, City St Georges Univ London, Sch Sci \& Technol, Dept Engn, Northampton Sq, London EC1V 0HB, England.},
DOI = {10.1016/j.engappai.2025.113275},
EarlyAccessDate = {NOV 2025},
