}

@article{ WOS:001382998300001,
Author = {Zubair, Muhammad and Chen, Shuyan and Ma, Yongfeng and Ong, Ghim Ping
   and Pang, Qianqian},
Title = {Explore driving factors to energy consumption of electric vehicles based
   on structural equation modeling},
Journal = {INTERNATIONAL JOURNAL OF GREEN ENERGY},
Year = {2025},
Volume = {22},
Number = {9, SI},
Pages = {1755-1765},
Month = {JUL 4},
Abstract = {This study addresses the imperative of thoroughly exploring electric
   vehicles (EVs) energy consumption patterns and their underlying
   determinants. Existing models within the EVs domain often lack
   transparency and interpretability, necessitating a rigorous analytical
   approach to enhance their efficacy. For this purpose, a real-time
   driving data of EVs collected in Nanjing, China, has been analyzed.
   Initially, energy consumption was estimated using power and speed data
   of EVs. The method involves two steps: firstly, a structural equation
   modeling (SEM) framework was developed to explore the driving factors
   influencing energy consumption of EVs. The analysis revealed that energy
   consumption has a negative relationship with distance (latitude and
   longitude), inside temperature, power, odometer and estimated battery
   range. Conversely, a positive relationship was observed with speed,
   battery level, outside temperature, driver area temperature, passenger
   area temperature and ideal battery range. Secondly, an ensemble model of
   histogram-based gradient boosting regression tree (HistGBRT) was applied
   using factors selected by SEM to predict energy consumption. The
   determination coefficient (R-2) and root mean square error (RMSE)
   achieved values of 0.99 and 0.01, respectively, indicating predictive
   ability of HistGBRT model for energy consumption modeling. The findings
   provide meaningful insights into energy consumption patterns and enhance
   predictive accuracy in sustainable transportation research.},
Type = {Article},
Affiliation = {Chen, SY (Corresponding Author), Southeast Univ, Sch Transportat, Jiangsu Key Lab Urban ITS, Nanjing 211189, Peoples R China.
   Zubair, Muhammad; Chen, Shuyan; Ma, Yongfeng; Pang, Qianqian, Southeast Univ, Sch Transportat, Jiangsu Key Lab Urban ITS, Nanjing 211189, Peoples R China.
