   Hu, Zhengyi, Changchun Tech Univ Automobile, Sci Res Dept, Changchun 130013, Jilin, Peoples R China.},
DOI = {10.1177/18724981251394128},
EarlyAccessDate = {NOV 2025},
Keywords = {Car evaluation classification; machine learning models; optimization
   frameworks; histogram-based gradient boosting; evolutionary strategies},
Author-Email = {20190035@huat.edu.cn},
Number-of-Cited-References = {37},
Times-Cited = {0},
