   Kenny, Rose Anne; Romero-Ortuno, Roman, St James Hosp, Mercers Inst Successful Ageing, Dublin, Ireland.},
DOI = {10.3389/fnetp.2021.754477},
Article-Number = {754477},
Keywords = {gait; speed; maximum; reserve; explainable; gradient; walking;
   physiological},
Keywords-Plus = {WALKING SPEED; OLDER-ADULTS; MULTISENSORY INTEGRATION; SUSTAINED
   ATTENTION; TIME; VARIABILITY; ASSESSMENTS; ILLUSION; FITNESS; VERTIGO},
Author-Email = {davisj5@tcd.ie},
