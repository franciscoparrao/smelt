@article{ WOS:000647509400007,
Author = {Lin, Pengfei and Hu, Gang and Li, Chao and Li, Lixiao and Xiao, Yiqing
   and Tse, K. T. and Kwok, K. C. S.},
Title = {Machine learning-based prediction of crosswind vibrations of rectangular
   cylinders},
Journal = {JOURNAL OF WIND ENGINEERING AND INDUSTRIAL AERODYNAMICS},
Year = {2021},
Volume = {211},
Month = {APR},
Abstract = {Due to the complexity of crosswind vibrations of rectangular cylinders,
   current research on crosswind vibrations of rectangular cylinders mainly
   relies on expensive wind tunnel tests and time-consuming numerical
   simulation techniques. In this study, in order to evaluate crosswind
   vibrations of rectangular cylinders, machine learning method was used to
   build an efficient and effective prediction model for supplementing the
   above two research tools. 5 machine learning models based on decision
   tree regression, k-nearest neighbor regression, random forest, gradient
   boosting regression tree (GBRT) and histogram gradient boosting
   regression tree algorithms were trained based on the existing
   high-quality and reliable wind tunnel test datasets of crosswind
   responses of rectangular cylinders. The hyper-parameters were optimized
   by using particle swarm optimization method. 4 types of crosswind
   vibration phenomena, including over-coupled, coupled, semi-coupled and
   decoupled, were predicted. It was found that the GBRT model is capable
   of predicting crosswind responses of rectangular cylinders at side
   ratios from 0.75 to 3 and Scruton numbers from 0 to 150 under wind flow
   with turbulence intensities from 0 to 16\%. Evidently, GBRT model can be
   an effective and economical method to study crosswind vibrations of
   rectangular cylinders and hence supplement traditional wind tunnel tests
   and numerical simulation techniques.},
Type = {Article},
Affiliation = {Hu, G; Li, C (Corresponding Author), Harbin Inst Technol, Sch Civil \& Environm Engn, Shenzhen 518055, Peoples R China.
   Lin, Pengfei; Hu, Gang; Li, Chao; Xiao, Yiqing, Harbin Inst Technol, Sch Civil \& Environm Engn, Shenzhen 518055, Peoples R China.
