EarlyAccessDate = {NOV 2023},
Keywords = {Energy-efficient allocation; Multi-objective optimization; Energy
   efficiency; Energy consumption; Machine learning},
Keywords-Plus = {PRODUCTION LINES; THROUGHPUT ANALYSIS; OPTIMIZATION; SERVER},
Author-Email = {csuliuhui@csu.edu.cn},
Number-of-Cited-References = {56},
