   Huete, Alfredo, Univ Technol Sydney, POB 123, Broadway, NSW, Australia.},
DOI = {10.1016/j.isprsjprs.2018.07.017},
Keywords = {Cropland mapping; Landsat; Machine learning algorithm; Random forest;
