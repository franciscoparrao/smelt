   Homayouni, Saeid, Inst Natl Rech Sci, Ctr Eau Terre Environm, Quebec City, PQ G1K 9A9, Canada.
   DeLancey, Evan R., Univ Alberta, Alberta Biodivers Monitoring Inst, Edmonton, AB T6G 2E9, Canada.
   Bourgeau-Chavez, Laura, Michigan Technol Univ, Michigan Tech Res Inst, Ann Arbor, MI USA.},
DOI = {10.1080/07038992.2019.1711366},
EarlyAccessDate = {MAR 2020},
Keywords-Plus = {RANDOM FOREST; CLASSIFICATION; ALGORITHM},
Author-Email = {masoud.mahdianpari@c-core.ca},
