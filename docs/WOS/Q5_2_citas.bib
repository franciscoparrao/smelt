@article{ WOS:000418873000017,
Author = {Xia, Junshi and Ghamisi, Pedram and Yokoya, Naoto and Iwasaki, Akira},
Title = {Random Forest Ensembles and Extended Multiextinction Profiles for
   Hyperspectral Image Classification},
Journal = {IEEE TRANSACTIONS ON GEOSCIENCE AND REMOTE SENSING},
Year = {2018},
Volume = {56},
Number = {1},
Pages = {202-216},
Month = {JAN},
Abstract = {Classification techniques for hyperspectral images based on random
   forest (RF) ensembles and extended multiextinction profiles (EMEPs) are
   proposed as a means of improving performance. To this end, five
   strategies-bagging, boosting, random subspace, rotation-based, and
   boosted rotation-based-are used to construct the RF ensembles. EPs,
   which are based on an extrema-oriented connected filtering technique,
   are applied to the images associated with the first informative
   components extracted by independent component analysis, leading to a set
   of EMEPs. The effectiveness of the proposed method is investigated on
   two benchmark hyperspectral images: the University of Pavia and Indian
   Pines. Comparative experimental evaluations reveal the superior
   performance of the proposed methods, especially those employing
   rotation-based and boosted rotation-based approaches. An additional
   advantage is that the CPU processing time is acceptable.},
Type = {Article},
Affiliation = {Xia, J (Corresponding Author), Univ Tokyo, Res Ctr Adv Sci \& Technol, Tokyo 1538904, Japan.
   Xia, Junshi; Yokoya, Naoto; Iwasaki, Akira, Univ Tokyo, Res Ctr Adv Sci \& Technol, Tokyo 1538904, Japan.
   Ghamisi, Pedram, German Aerosp Ctr DLR, Remote Sensing Technol Inst IMF, D-82234 Wessling, Germany.
   Ghamisi, Pedram, Tech Univ Munich, Signal Proc Earth Observat, D-80333 Munich, Germany.},
DOI = {10.1109/TGRS.2017.2744662},
Keywords = {Ensemble learning; extended multiextinction profiles (EMEPs);
   hyperspectral image classification; random forest (RF)},
Keywords-Plus = {SPECTRAL-SPATIAL CLASSIFICATION; REMOTE-SENSING IMAGES;
