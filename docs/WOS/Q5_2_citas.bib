Article-Number = {368},
Keywords = {training sample size; supervised machine learning; high-resolution
   imagery; large area; GEOBIA},
Keywords-Plus = {TREE SPECIES CLASSIFICATION; RANDOM FOREST; IMAGE CLASSIFICATION; VECTOR
   QUANTIZATION; SAMPLE-SIZE; SEGMENTATION; CLASSIFIERS; ALGORITHMS;
   PREDICTION; SELECTION},
Author-Email = {Christopher.Ramezan@mail.wvu.edu
   Tim.Warner@mail.wvu.edu
