@article{ WOS:000473794600062,
Author = {Tsai, Ya-Lun S. and Dietz, Andreas and Oppelt, Natascha and Kuenzer,
   Claudia},
Title = {Remote Sensing of Snow Cover Using Spaceborne SAR: A Review},
Journal = {REMOTE SENSING},
Year = {2019},
Volume = {11},
Number = {12},
Month = {JUN 2},
Abstract = {The importance of snow cover extent (SCE) has been proven to strongly
   link with various natural phenomenon and human activities; consequently,
   monitoring snow cover is one the most critical topics in studying and
   understanding the cryosphere. As snow cover can vary significantly
   within short time spans and often extends over vast areas, spaceborne
   remote sensing constitutes an efficient observation technique to track
   it continuously. However, as optical imagery is limited by cloud cover
   and polar darkness, synthetic aperture radar (SAR) attracted more
   attention for its ability to sense day-and-night under any cloud and
   weather condition. In addition to widely applied backscattering-based
   method, thanks to the advancements of spaceborne SAR sensors and image
   processing techniques, many new approaches based on interferometric SAR
   (InSAR) and polarimetric SAR (PolSAR) have been developed since the
   launch of ERS-1 in 1991 to monitor snow cover under both dry and wet
   snow conditions. Critical auxiliary data including DEM, land cover
   information, and local meteorological data have also been explored to
   aid the snow cover analysis. This review presents an overview of
   existing studies and discusses the advantages, constraints, and
   trajectories of the current developments.},
Type = {Review},
Affiliation = {Tsai, YLS (Corresponding Author), German Aerosp Ctr DLR, German Remote Sensing Data Ctr DFD, Muenchener Str 20, D-82234 Wessling, Germany.
   Tsai, Ya-Lun S.; Dietz, Andreas; Kuenzer, Claudia, German Aerosp Ctr DLR, German Remote Sensing Data Ctr DFD, Muenchener Str 20, D-82234 Wessling, Germany.
   Oppelt, Natascha, Univ Kiel, Dept Geog Earth Observat \& Modelling, Ludewig Meyn Str 14, D-24118 Kiel, Germany.},
DOI = {10.3390/rs11121456},
Article-Number = {1456},
Keywords = {synthetic aperture radar; backscattering; InSAR; PolSAR; snow
   classification; wet snow; cryosphere; data fusion; machine learning},
Keywords-Plus = {SYNTHETIC-APERTURE RADAR; TARGET DECOMPOSITION-THEOREMS; SEA-ICE MODEL;
