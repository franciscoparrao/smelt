DOI = {10.1155/2015/538063},
Article-Number = {538063},
Keywords-Plus = {IMAGES; SEGMENTATION; AREAS; MODEL; ALGORITHM; MACHINES; TEXTURE; FUSION},
Author-Email = {lvqi@nudt.edu.cn},
Number-of-Cited-References = {37},
