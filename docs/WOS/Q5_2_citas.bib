   Homayouni, Saeid, Inst Natl Rech Sci INRS, Ctr Eau Terre Environm, Quebec City, PQ G1K 9A9, Canada.},
DOI = {10.3390/rs13214405},
Article-Number = {4405},
Keywords = {classification; ensemble classifier; bagging; boosting; multispectral;
   hyperspectral; PolSAR},
Keywords-Plus = {LAND-COVER CLASSIFICATION; DECISION TREES; RANDOM FOREST; PERFORMANCE;
   ALGORITHMS; SELECTION},
