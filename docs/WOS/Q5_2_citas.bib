   Shi, Chunxiang, China Meteorol Adm, Natl Meteorol Informat Ctr, Beijing 100081, Peoples R China.},
DOI = {10.1016/j.rse.2019.111364},
Article-Number = {111364},
Keywords = {Microwave soil moisture; Land surface temperature; Downscaling; Random
