   Cao, Shubo, Sichuan Inst Nucl Geol, 35 Huaguan Rd, Chengdu 610052, Sichuan, Peoples R China.},
DOI = {10.1016/j.geomorph.2017.09.007},
Keywords = {Landslide spatial modeling; ANFIS-FR; GAM; SVM; China},
Keywords-Plus = {2008 WENCHUAN EARTHQUAKE; DATA-MINING TECHNIQUES; REMOTE-SENSING DATA;
