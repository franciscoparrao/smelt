   van der Linden, Sebastian, Ernst Moritz Arndt Univ Greifswald, Inst Geog \& Geol, Friedrich Ludwig Jahn Str 16, D-17489 Greifswald, Germany.},
DOI = {10.1016/j.rse.2020.112128},
Article-Number = {112128},
Keywords = {Germany; Machine learning; Copernicus; SAR; Optical; Multi-sensor; Data
   synergy; Urbanization; Quantitative remote sensing},
Author-Email = {david.frantz@geo.hu-berlin.de},
