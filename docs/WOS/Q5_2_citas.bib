   Jeganathan, C., Birla Inst Technol, Dept Remote Sensing, Mesra Ranchi 835215, Jharkhand, India.},
DOI = {10.1016/j.rse.2011.12.003},
Keywords = {Texture; Geostatistic; Variogram; Spatial autocorrelation; Random Forest},
Keywords-Plus = {REMOTELY-SENSED DATA; FUYO-1 SAR DATA; NEURAL-NETWORKS; VEGETATION
   DISCRIMINATION; TM IMAGERY; SELECTION; FEATURES; BAND; MAP; TREES},
