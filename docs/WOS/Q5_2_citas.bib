DOI = {10.3390/plants8110468},
Article-Number = {468},
Keywords = {plant disease; deep learning; convolutional neural networks (CNN)},
Keywords-Plus = {MAIZE LEAF DISEASES; NEURAL-NETWORKS; LAND-COVER; IDENTIFICATION;
