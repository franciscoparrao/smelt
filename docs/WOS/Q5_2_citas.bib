   Finke, Peter, Univ Ghent, Dept Soil Management, Coupure Links 653, B-9000 Ghent, Belgium.},
DOI = {10.1016/j.geoderma.2018.09.006},
Keywords = {Environmental covariates; Soil characteristics; Spatial prediction;
   Modeling accuracy},
