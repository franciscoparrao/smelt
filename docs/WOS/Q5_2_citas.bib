   Cotton; Corn},
Keywords-Plus = {TIME-SERIES DATA; RANDOM FOREST; FEATURE-SELECTION; FOOD-DEMAND; NDVI
   DATA; LANDSAT; AREA; PERFORMANCE; ACCURACY; UNCERTAINTY},
