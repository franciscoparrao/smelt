   Lin, Shangrong, Sun Yat sen Univ, Sch Atmospher Sci, Southern Marine Sci \& Engn Guangdong Lab Zhuhai, Zhuhai 519082, Guangdong, Peoples R China.},
DOI = {10.5194/essd-15-265-2023},
Keywords-Plus = {LAND-COVER CHANGE; SURFACE-WATER; CLOUD SHADOW; FOREST COVER; LONG-TERM;
   AREA; MULTISOURCE; VALIDATION; ALGORITHM; ACCURACY},
