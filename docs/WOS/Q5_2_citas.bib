   Inglada, Jordi; Derksen, Dawa, Univ Toulouse, Ctr Etud Spatiales BIOsphere CESBIO, CNES, CNRS,IRD,UPS,INRA, F-31555 Toulouse, France.
   Inglada, Jordi; Poughon, Victor, CNES, F-31555 Toulouse, France.},
DOI = {10.3390/rs11171986},
Article-Number = {1986},
Keywords = {land cover mapping; convolutional neural networks; UNET; Sentinel-2},
Keywords-Plus = {CLASSIFICATION},
