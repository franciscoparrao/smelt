   dirk.pflugmacher@geo.hu-berlin.de
   sebastian.linden@geo.hu-berlin.de
   patrick.hostert@geo.hu-berlin.de},
Number-of-Cited-References = {50},
Times-Cited = {98},
Unique-ID = {WOS:000320771100011},
}

