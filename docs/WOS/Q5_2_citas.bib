   Lung, Shih-Chun Candice, Natl Taiwan Univ, Dept Atmospher Sci, Taipei, Taiwan.
   Lung, Shih-Chun Candice, Natl Taiwan Univ, Inst Environm Hlth, Taipei, Taiwan.},
DOI = {10.1016/j.envpol.2021.116846},
