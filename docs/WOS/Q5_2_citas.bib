@article{ WOS:000255370700028,
Author = {Rogan, John and Franklin, Janet and Stow, Doug and Miller, Jennifer and
   Woodcock, Curtis and Roberts, Dar},
Title = {Mapping land-cover modifications over large areas: A comparison of
   machine learning algorithms},
Journal = {REMOTE SENSING OF ENVIRONMENT},
Year = {2008},
Volume = {112},
Number = {5},
Pages = {2272-2283},
Month = {MAY 15},
Abstract = {Large area land-cover monitoring scenarios, involving large volumes of
   data, are becoming more prevalent in remote sensing applications. Thus,
   there is a pressing need for increased automation in the change mapping
   process. The objective of this research is to compare the performance of
   three machine learning algorithms (MLAs); two classification tree
   software routines (S-plus and C4.5) and an artificial neural network
   (ARTMAP), in the context of mapping land-cover modifications in northern
   and southern California study sites between 1990/91 and 1996.
   Comparisons were based on several criteria: overall accuracy,
   sensitivity to data set size and variation, and noise. ARTMAP produced
   the most accurate maps overall (similar to 84\%), for two study areas -
   in southern and northern California, and was most resistant to training
   data deficiencies. The change map generated using ARTMAP has similar
   accuracies to a human-interpreted map produced by the U.S. Forest
   Service in the southern study area. ARTMAP appears to be robust and
   accurate for automated, large area change monitoring as it performed
   equally well across the diverse study areas with minimal human
   intervention in the classification process. (C) 2007 Elsevier Inc. All
   rights reserved.},
Type = {Article},
Affiliation = {Rogan, J (Corresponding Author), Clark Univ, Dept Geog, 950 Main St, Worcester, MA 01610 USA.
   Franklin, Janet, San Diego State Univ, Dept Biol, San Diego, CA 92182 USA.
   Rogan, John; Stow, Doug, San Diego State Univ, Dept Geog, San Diego, CA 92182 USA.
   Miller, Jennifer, W Virginia Univ, Dept Geol \& Geog \& Geol, Morgantown, WV 26506 USA.
   Woodcock, Curtis, Boston Univ, Dept Geog, Boston, MA 02215 USA.
   Roberts, Dar, Univ Calif Santa Barbara, Dept Geog, Santa Barbara, CA 93106 USA.},
DOI = {10.1016/j.rse.2007.10.004},
Keywords = {land-cover change; machine learning; large area monitoring},
Keywords-Plus = {NEURAL-NETWORK CLASSIFICATION; DECISION-TREE; FUZZY ARTMAP; VEGETATION;
   TEXTURE; TM; FORESTS},
Author-Email = {jrogan@clarku.edu},
