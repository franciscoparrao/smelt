   fusion},
Keywords-Plus = {LAND-COVER CLASSIFICATION; TIME-SERIES; URBANIZATION DYNAMICS;
   RESOLUTION; IMAGERY; METRICS; REFLECTANCE; PHENOLOGY; EXPANSION; CLIMATE},
Author-Email = {cmertes@wisc.edu},
Number-of-Cited-References = {101},
