   Prager, Case M.; Griffin, Kevin L., Columbia Univ, Dept Ecol Evolut \& Environm Biol, 1200 Amsterdam Ave, New York, NY 10027 USA.},
DOI = {10.1016/j.rse.2016.07.026},
