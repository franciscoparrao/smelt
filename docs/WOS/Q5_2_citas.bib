   Plaza, Javier; Plaza, Antonio, Univ Extremadura, Escuela Politecn Caceres, Hyperspectral Comp Lab, E-06071 Badajoz, Spain.},
DOI = {10.1109/TGRS.2017.2726901},
Keywords = {Extinction profiles (EPs); feature fusion; hyperspectral; light
   detection and ranging (LiDAR); sparse and low-rank component analysis
   (SLRCA)},
Keywords-Plus = {TREE SPECIES CLASSIFICATION; LAND-COVER CLASSIFICATION; REMOTE-SENSING
