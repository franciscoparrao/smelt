Unique-ID = {WOS:000498268600052},
}

@article{ WOS:000424826300016,
Author = {Leuenberger, Michael and Parente, Joana and Tonini, Marj and Pereira,
   Mario Gonzalez and Kanevski, Mikhail},
Title = {Wildfire susceptibility mapping: Deterministic vs. stochastic approaches},
Journal = {ENVIRONMENTAL MODELLING \& SOFTWARE},
Year = {2018},
Volume = {101},
Pages = {194-203},
Month = {MAR},
Abstract = {Wildfire susceptibility is a measure of land propensity for the
   occurrence of wildfires based on terrain's intrinsic characteristics. In
   the present study, two stochastic approaches (i.e., extreme learning
   machine and random forest) for wildfire susceptibility mapping are
   compared versus a well established deterministic method. The same
   predisposing variables were combined and used as predictors in all
   models. The Portuguese region of Dao-Lafoes was selected as a pilot site
   since it presents national average values of fire incidence and a high
   heterogeneity in land cover and slope. Maps representing the
   susceptibility of the study area to wildfires were finally elaborated.
   Two measures were used to compare the different methods, namely the
   location of the pixels with similar standardized susceptibility and
   total validation burnt area. Results obtained with the stochastic
   methods are very alike with the deterministic ones, with the advantage
   of not depending on a priori knowledge of the phenomenon. (C) 2017
   Elsevier Ltd. All rights reserved.},
Type = {Article},
Affiliation = {Leuenberger, M (Corresponding Author), Univ Neuchatel, Fac Sci, Inst Stat, CH-2000 Neuchatel, Switzerland.
   Leuenberger, Michael, Univ Neuchatel, Fac Sci, Inst Stat, CH-2000 Neuchatel, Switzerland.
   Tonini, Marj; Kanevski, Mikhail, Univ Lausanne, Fac Geosci \& Environm, Inst Earth Surface Dynam IDYST, CH-1000 Lausanne, Switzerland.
   Parente, Joana; Pereira, Mario Gonzalez, Univ Tras Os Montes \& Alto Douro, Ctr Invest \& Tecnol Agroambientais \& Biol CITAB, P-5000801 Vila Real, Portugal.
