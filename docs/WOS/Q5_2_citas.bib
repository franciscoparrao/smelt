@article{ WOS:000403031400008,
Author = {Pham, Lien T. H. and Brabyn, Lars},
Title = {Monitoring mangrove biomass change in Vietnam using SPOT images and an
   object-based approach combined with machine learning algorithms},
Journal = {ISPRS JOURNAL OF PHOTOGRAMMETRY AND REMOTE SENSING},
Year = {2017},
Volume = {128},
Pages = {86-97},
Month = {JUN},
Abstract = {Mangrove forests are well-known for their provision of ecosystem
   services and capacity to reduce carbon dioxide concentrations in the
   atmosphere. Mapping and quantifying mangrove biomass is useful for the
   effective management of these forests and maximizing their ecosystem
   service performance. The objectives of this research were to model, map,
   and analyse the biomass change between 2000 and 2011 of mangrove forests
   in the Cangio region in Vietnam. SPOT 4 and 5 images were used in
   conjunction with object-based image analysis and machine learning
   algorithms. The study area included natural and planted mangroves of
   diverse species. After image preparation, three different mangrove
   associations were identified using two levels of image segmentation
   followed by a Support Vector Machine classifier and a range of spectral,
   texture and GIS information for classification. The overall
   classification accuracy for the 2000 and 2011 images were 77.1\% and
   82.9\%, respectively. Random Forest regression algorithms were then used
   for modelling and mapping biomass. The model that integrated spectral,
   vegetation association type, texture, and vegetation indices obtained
   the highest accuracy (R-adj(2) = 0.73). Among the different variables,
   vegetation association type was the most important variable identified
   by the Random Forest model. Based on the biomass maps generated from the
   Random Forest, total biomass in the Cangio mangrove forest increased by
   820,136 tons over this period, although this change varied between the
   three different mangrove associations. (C) 2017 International Society
   for Photogrammetry and Remote Sensing, Inc. (ISPRS). Published by
   Elsevier B.V. All rights reserved.},
Type = {Article},
Affiliation = {Pham, LTH (Corresponding Author), Univ Waikato, Dept Geog \& Environm Planning, Private Bag 3105, Hamilton 3240, New Zealand.
   Pham, Lien T. H.; Brabyn, Lars, Univ Waikato, Dept Geog \& Environm Planning, Private Bag 3105, Hamilton 3240, New Zealand.
   Pham, Lien T. H., Vietnam Natl Univ Ho Chi Minh City, Univ Sci, Fac Environm Sci, 227 Nguyen Van Cu Str,Dist 5, Hcmc, Vietnam.},
DOI = {10.1016/j.isprsjprs.2017.03.013},
Keywords = {Mangrove; Biomass change; Object-based; Random forest; Support vector
   machine},
Keywords-Plus = {FOREST ABOVEGROUND BIOMASS; VEGETATION INDEX; AIRBORNE LIDAR;
   CLASSIFICATION; INTEGRATION; QUICKBIRD; IKONOS; PARAMETERS; SUPPORT;
   METRICS},
