   Gomez, C.; Lagacherie, P., Univ Montpellier, INRA, UMR LISAH, IRD,SupAgro, F-34000 Montpellier, France.},
DOI = {10.1016/j.jag.2019.101905},
Article-Number = {101905},
Keywords = {Remote sensing; Digital soil mapping; Sentinel-2; National scale;
