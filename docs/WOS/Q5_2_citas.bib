@article{ WOS:000379718600027,
Author = {Verrelst, Jochem and Dethier, Sara and Rivera, Juan Pablo and
   Munoz-Mari, Jordi and Camps-Valls, Gustau and Moreno, Jose},
Title = {Active Learning Methods for Efficient Hybrid Biophysical Variable
   Retrieval},
Journal = {IEEE GEOSCIENCE AND REMOTE SENSING LETTERS},
Year = {2016},
Volume = {13},
Number = {7},
Pages = {1012-1016},
Month = {JUL},
Abstract = {Kernel-based machine learning regression algorithms (MLRAs) are
   potentially powerful methods for being implemented into operational
   biophysical variable retrieval schemes. However, they face difficulties
   in coping with large training data sets. With the increasing amount of
   optical remote sensing data made available for analysis and the
   possibility of using a large amount of simulated data from radiative
   transfer models (RTMs) to train kernel MLRAs, efficient data reduction
   techniques will need to be implemented. Active learning (AL) methods
   enable to select the most informative samples in a data set. This letter
   introduces six AL methods for achieving optimized biophysical variable
   estimation with a manageable training data set, and their implementation
   into a Matlab-based MLRA toolbox for semiautomatic use. The AL methods
   were analyzed on their efficiency of improving the estimation accuracy
   of the leaf area index and chlorophyll content based on PROSAIL
   simulations. Each of the implemented methods outperformed random
   sampling, improving retrieval accuracy with lower sampling rates.
   Practically, AL methods open opportunities to feed advanced MLRAs with
   RTM-generated training data for the development of operational retrieval
   models.},
Type = {Article},
Affiliation = {Verrelst, J (Corresponding Author), Univ Valencia, Image Proc Lab, Valencia 46010, Spain.
   Verrelst, Jochem; Rivera, Juan Pablo; Munoz-Mari, Jordi; Camps-Valls, Gustau; Moreno, Jose, Univ Valencia, Image Proc Lab, Valencia 46010, Spain.
   Dethier, Sara, Imperial Coll London, Dept Phys, London SW7 2BB, England.},
DOI = {10.1109/LGRS.2016.2560799},
Keywords = {Active learning (AL); hybrid retrieval methods; kernel methods; machine
   learning regression algorithms (MLRAs); PROSAIL; Sentinel-3},
Keywords-Plus = {VEGETATION; REGRESSION; LAI; CLASSIFICATION; PRINCIPLES; ALGORITHMS;
   FAPAR},
Author-Email = {jochem.verrelst@uv.es
