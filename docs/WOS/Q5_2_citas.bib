   Rezaie, Fatemeh; Lee, Saro, Korea Univ Sci \& Technol, Dept Geophys Explorat, 217 Gajeong Ro, Daejeon 34113, South Korea.},
DOI = {10.1016/j.scitotenv.2020.139937},
Article-Number = {139937},
Keywords = {Landslide susceptibility; Support vector regression (SVR); Adaptive
   neuro-fuzzy inference system (ANFIS); Metaheuristic algorithms},
Keywords-Plus = {REMOTE-SENSING DATA; LOGISTIC-REGRESSION; DECISION TREE; FREQUENCY
