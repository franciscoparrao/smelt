   Abbasi-Moghadam, Dariush; Nejad, Seyed Mahdi Mirhoseini, Shahid Bahonar Univ Kerman, Dept Elect Engn, Kerman 7616914111, Iran.},
DOI = {10.1109/JSTARS.2023.3239756},
