   Attribution analysis},
Keywords-Plus = {CARBON-DIOXIDE; LOESS PLATEAU; IMPACTS; PROGRAM; TRENDS; REGION;
   RESTORATION; VARIABILITY; GREENNESS; DYNAMICS},
