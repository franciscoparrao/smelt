   Ma, Lei; Cheng, Liang; Li, Manchun; Liu, Yongxue; Ma, Xiaoxue, Nanjing Univ, Sch Geog \& Oceanog Sci, Nanjing 210023, Jiangsu, Peoples R China.
   Li, Manchun; Liu, Yongxue, Jiangsu Ctr Collaborat Innovat Geog Informat Reso, Nanjing, Jiangsu, Peoples R China.},
DOI = {10.1016/j.isprsjprs.2014.12.026},
