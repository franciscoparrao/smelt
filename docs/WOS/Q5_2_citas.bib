   Ndehedehe, Christopher E., Griffith Univ, Australian Rivers Inst, Nathan, Qld 4111, Australia.
   Ndehedehe, Christopher E., Griffith Univ, Griffith Sch Environm \& Sci, Nathan, Qld 4111, Australia.},
DOI = {10.1016/j.patcog.2020.107298},
Article-Number = {107298},
Keywords = {Remote sensing; Hyperspectral image; Deep support vector machine; Image
   classification},
Keywords-Plus = {SVM; MULTICLASS; MODEL},
Author-Email = {c.ndehedehe@griffith.edu.au},
Number-of-Cited-References = {36},
Times-Cited = {193},
Unique-ID = {WOS:000530845000031},
}

@article{ WOS:000515569800006,
Author = {Wang, Sherrie and Chen, William and Xie, Sang Michael and Azzari, George
   and Lobell, David B.},
Title = {Weakly Supervised Deep Learning for Segmentation of Remote Sensing
   Imagery},
Journal = {REMOTE SENSING},
Year = {2020},
Volume = {12},
Number = {2},
Month = {JAN},
Abstract = {Accurate automated segmentation of remote sensing data could benefit
   applications from land cover mapping and agricultural monitoring to
   urban development surveyal and disaster damage assessment. While
   convolutional neural networks (CNNs) achieve state-of-the-art accuracy
   when segmenting natural images with huge labeled datasets, their
   successful translation to remote sensing tasks has been limited by low
   quantities of ground truth labels, especially fully segmented ones, in
   the remote sensing domain. In this work, we perform cropland
   segmentation using two types of labels commonly found in remote sensing
   datasets that can be considered sources of ``weak supervision{''}: (1)
   labels comprised of single geotagged points and (2) image-level labels.
   We demonstrate that (1) a U-Net trained on a single labeled pixel per
   image and (2) a U-Net image classifier transferred to segmentation can
   outperform pixel-level algorithms such as logistic regression, support
   vector machine, and random forest. While the high performance of neural
   networks is well-established for large datasets, our experiments
   indicate that U-Nets trained on weak labels outperform baseline methods
   with as few as 100 labels. Neural networks, therefore, can combine
   superior classification performance with efficient label usage, and
   allow pixel-level labels to be obtained from image labels.},
Type = {Article},
Affiliation = {Wang, S (Corresponding Author), Stanford Univ, Inst Computat \& Math Engn, Stanford, CA 94305 USA.
   Wang, S (Corresponding Author), Stanford Univ, Dept Earth Syst Sci, Stanford, CA 94305 USA.
   Wang, Sherrie, Stanford Univ, Inst Computat \& Math Engn, Stanford, CA 94305 USA.
   Wang, Sherrie; Azzari, George; Lobell, David B., Stanford Univ, Dept Earth Syst Sci, Stanford, CA 94305 USA.
   Chen, William; Xie, Sang Michael, Stanford Univ, Dept Comp Sci, Stanford, CA 94305 USA.},
DOI = {10.3390/rs12020207},
Article-Number = {207},
Keywords = {deep learning; image segmentation; weak supervision; agriculture;
   Landsat; land cover classification},
Keywords-Plus = {SATELLITE IMAGERY; COVER; ALGORITHM; PRODUCT},
Author-Email = {sherwang@stanford.edu
   wic006@stanford.edu
   xie@cs.stanford.edu
