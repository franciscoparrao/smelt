   Barreto Luiz, Alfredo Jose, Embrapa Meio Ambiente, BR-13820000 Jaguariuna, SP, Brazil.},
DOI = {10.3390/rs71114482},
Keywords = {OBIA; crop mapping; Brazil; multi-resolution segmentation; OLI; random
   forest},
Keywords-Plus = {OBJECT-BASED CLASSIFICATION; NDVI TIME-SERIES; SAO-PAULO STATE;
