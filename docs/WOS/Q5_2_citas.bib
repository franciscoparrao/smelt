   Singh, Mewa, Univ Mysore, Biopsychol Lab, Mysore 570006, Karnataka, India.
   Singh, Mewa, Univ Mysore, Inst Excellence, Mysore 570006, Karnataka, India.
   Singh, Mewa, Jawaharlal Nehru Ctr Adv Sci Res, Evolutionary \& Organismal Biol Unit, Bangalore 560064, Karnataka, India.
   Erinjery, Joseph J., Tel Aviv Univ, George S Wise Fac Life Sci, Dept Zool, IL-6997801 Tel Aviv, Israel.},
DOI = {10.1016/j.rse.2018.07.006},
Keywords = {Habitat fragmentation; Tropical rainforest; Sentinel-1; Sentinel-2;
   Vegetation type; Western Ghats},
