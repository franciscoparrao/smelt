   Zheng, Zheng, South China Agr Univ, Coll Agr, Guangzhou 510642, Peoples R China.},
DOI = {10.1016/j.compag.2020.105234},
Article-Number = {105234},
Keywords = {Citrus HLB detection; UAV; Multispectral images; Machine learning},
Keywords-Plus = {LEAF-AREA INDEX; VEGETATION INDEX; SPECTROSCOPY; YIELD; NDVI; CORN; LAI},
