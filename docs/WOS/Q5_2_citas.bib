   Chen, Zhenjie; Li, Manchun, Nanjing Univ, Jiangsu Prov Key Lab Geog Informat Sci \& Technol, Nanjing 210023, Peoples R China.},
DOI = {10.3390/rs13030453},
Article-Number = {453},
Keywords = {land use; land cover; auxiliary datasets; random forest; Google Earth
   Engine; Yangtze river delta},
Keywords-Plus = {LAND-COVER CLASSIFICATION; YANGTZE-RIVER DELTA; TIME-SERIES; RANDOM
   FOREST; IMAGE-ANALYSIS; ANCILLARY DATA; PER-PIXEL; AREA; DYNAMICS},
