   Uhe, Peter; Paulo, Luntadila; Sosa, Jeison; Savage, James; Sampson, Christopher; Neal, Jeffrey, Sq Works, Fathom, 17-18 Berkeley Sq, Bristol, Avon, England.},
DOI = {10.1088/1748-9326/ac4d4f},
Article-Number = {024016},
Keywords = {digital elevation model; bare-earth; terrain; remote sensing; machine
