   winter wheat; detection},
Keywords-Plus = {REFLECTANCE MEASUREMENTS; OPTICAL-PROPERTIES; DISEASE DETECTION;
   VEGETATION; INFECTION; NITROGEN; DAMAGE; SELECTION; FOREST; STRESS},
