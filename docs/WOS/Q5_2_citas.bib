   Ngoc Bich Hoang; Huu Hao Ngo, Nguyen Tat Thanh Univ, Inst Environm Sci, Ho Chi Minh City, Vietnam.},
DOI = {10.1016/j.scitotenv.2021.150187},
EarlyAccessDate = {SEP 2021},
Article-Number = {150187},
Keywords = {SOC; Machine learning; Multi-sensor data fusion; Sentinel 1; Sentinel 2},
Keywords-Plus = {SENTINEL-2; VEGETATION; INDEXES; AIRBORNE; TEXTURE; BANDS; RED},
Author-Email = {tiendat.pham@mq.edu.au
   ngohuuhao121@gmail.com},
Number-of-Cited-References = {58},
