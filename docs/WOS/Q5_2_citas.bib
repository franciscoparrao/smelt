   Lampinen, Jouko, Aalto Univ, Sch Sci, Dept Comp Sci, Aalto 00076, Finland.
   Kukko, Antero; Hyyppa, Hannu, Aalto Univ, Sch Engn, Dept Real Estate Planning \& Geoinformat, Aalto 00076, Finland.},
DOI = {10.1109/TGRS.2015.2476502},
Keywords = {Laser radar; machine vision; remote sensing},
