   Wang, Lin, Chinese Acad Fishery Sci, Beijing 100141, Peoples R China.
   Qi, Shuhua; Liu, Ying, Jiangxi Normal Univ, Sch Geog \& Environm, Nanchang 330027, Peoples R China.},
DOI = {10.1016/j.rse.2012.09.018},
Keywords = {Remote sensing; Vegetation; Wetland; Plant functional types; Landsat;
