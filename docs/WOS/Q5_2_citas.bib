   Avtar, Ram, Hokkaido Univ, Fac Environm Earth Sci, Sapporo, Hokkaido 0600810, Japan.},
DOI = {10.3390/s19122788},
Article-Number = {2788},
Keywords = {aquatic environment; remote sensing; topographic mapping; spectral
   reflectance; random forest},
Keywords-Plus = {SHALLOW-WATER BATHYMETRY; SATELLITE IMAGERY; LANDSLIDE SUSCEPTIBILITY;
