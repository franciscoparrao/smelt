   Hamza, Salma, Bahria Univ, Dept Earth \& Environm Sci, Karachi Campus, Karachi 75300, Pakistan.
   Li, Qingting, Chinese Acad Sci, Airborne Remote Sensing Ctr, Aerosp Informat Res Inst, Beijing 100094, Peoples R China.},
DOI = {10.3390/land10070700},
