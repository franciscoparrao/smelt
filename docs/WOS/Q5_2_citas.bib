}

@article{ WOS:000480527800044,
Author = {Pu, Fangling and Ding, Chujiang and Chao, Zeyi and Yu, Yue and Xu, Xin},
Title = {Water-Quality Classification of Inland Lakes Using Landsat8 Images by
   Convolutional Neural Networks},
Journal = {REMOTE SENSING},
Year = {2019},
Volume = {11},
Number = {14},
Month = {JUL 2},
Abstract = {Water-quality monitoring of inland lakes is essential for
   freshwater-resource protection. In situ water-quality measurements and
   ratings are accurate but high costs limit their usage. Water-quality
   monitoring using remote sensing has shown to be cost-effective. However,
   the nonoptically active parameters that mainly determine water-quality
   levels in China are difficult to estimate because of their weak optical
   characteristics and lack of explicit correlation between remote-sensing
   images and parameters. To address the problems, a convolutional neural
   network (CNN) with hierarchical structure was designed to represent the
   relationship between Landsat8 images and in situ water-quality levels. A
   transfer-learning strategy in the CNN model was introduced to deal with
   the lack of in situ measurement data. After the CNN model was trained by
   spatially and temporally matched Landsat8 images and in situ
   water-quality data that were collected from official websites, the
   surface quality of the whole water body could be classified. We tested
   the CNN model at the Erhai and Chaohu lakes in China, respectively. The
   experiment results demonstrate that the CNN model outperformed widely
   used machine-learning methods. The trained model at Erhai Lake can be
   used for the water-quality classification of Chaohu Lake. The introduced
   CNN model and the water-quality classification method could cover the
   whole lake with low costs. The proposed method has potential in
   inland-lake monitoring.},
Type = {Article},
Affiliation = {Pu, FL (Corresponding Author), Wuhan Univ, Sch Elect Informat, Wuhan 430072, Peoples R China.
   Pu, Fangling; Ding, Chujiang; Chao, Zeyi; Yu, Yue; Xu, Xin, Wuhan Univ, Sch Elect Informat, Wuhan 430072, Peoples R China.},
DOI = {10.3390/rs11141674},
Article-Number = {1674},
Keywords = {water-quality classification; convolutional neural network; transfer
   learning},
Keywords-Plus = {TOTAL PHOSPHORUS CONCENTRATION; ATMOSPHERIC CORRECTION; TOTAL NITROGEN;
   REMOTE},
Author-Email = {flpu@whu.edu.cn},
Number-of-Cited-References = {40},
Times-Cited = {98},
Unique-ID = {WOS:000480527800044},
}

@article{ WOS:000475307000006,
Author = {Bachri, Imane and Hakdaoui, Mustapha and Raji, Mohammed and Teodoro, Ana
   Claudia and Benbouziane, Abdelmajid},
Title = {Machine Learning Algorithms for Automatic Lithological Mapping Using
   Remote Sensing Data: A Case Study from Souk Arbaa Sahel, Sidi Ifni
   Inlier, Western Anti-Atlas, Morocco},
Journal = {ISPRS INTERNATIONAL JOURNAL OF GEO-INFORMATION},
Year = {2019},
Volume = {8},
Number = {6},
Month = {JUN},
Abstract = {Remote sensing data proved to be a valuable resource in a variety of
   earth science applications. Using high-dimensional data with advanced
   methods such as machine learning algorithms (MLAs), a sub-domain of
   artificial intelligence, enhances lithological mapping by spectral
   classification. Support vector machines (SVM) are one of the most
   popular MLAs with the ability to define non-linear decision boundaries
   in high-dimensional feature space by solving a quadratic optimization
   problem. This paper describes a supervised classification method
   considering SVM for lithological mapping in the region of Souk Arbaa
   Sahel belonging to the Sidi Ifni inlier, located in southern Morocco
   (Western Anti-Atlas). The aims of this study were (1) to refine the
   existing lithological map of this region, and (2) to evaluate and study
   the performance of the SVM approach by using combined spectral features
   of Landsat 8 OLI with digital elevation model (DEM) geomorphometric
   attributes of ALOS/PALSAR data. We performed an SVM classification
   method to allow the joint use of geomorphometric features and
   multispectral data of Landsat 8 OLI. The results indicated an overall
   classification accuracy of 85\%. From the results obtained, we can
   conclude that the classification approach produced an image containing
   lithological units which easily identified formations such as silt,
   alluvium, limestone, dolomite, conglomerate, sandstone, rhyolite,
   andesite, granodiorite, quartzite, lutite, and ignimbrite, coinciding
   with those already existing on the published geological map. This result
   confirms the ability of SVM as a supervised learning algorithm for
   lithological mapping purposes.},
Type = {Article},
Affiliation = {Teodoro, AC (Corresponding Author), Univ Porto, Fac Sci, Earth Sci Inst ICT, P-4169007 Porto, Portugal.
   Bachri, Imane; Hakdaoui, Mustapha, Hassan II Univ Casablanca, Fac Sci Ben Msik Driss El Harti, Lab Appl Geol Geomat \& Environm, BP 7955, Casablanca, Morocco.
   Raji, Mohammed, Hassan II Univ Casablanca, Fac Sci Ben Msik Driss El Harti, Lab Geodynam Older Belts, BP 7955, Casablanca, Morocco.
   Teodoro, Ana Claudia, Univ Porto, Fac Sci, Earth Sci Inst ICT, P-4169007 Porto, Portugal.
   Teodoro, Ana Claudia, Univ Porto, Fac Sci, Dept Geosci Environm \& Land Planning, P-4169007 Porto, Portugal.
   Benbouziane, Abdelmajid, Hassan II Univ Casablanca, Fac Sci Ben Msik Driss El Harti, Lab Dynam Sedimentary Basins \& Geol Correlat, BP 7955, Casablanca, Morocco.},
DOI = {10.3390/ijgi8060248},
Keywords = {machine learning algorithms; Landsat 8 OLI; Sidi Ifni inlier; ALOS;
   PALSAR; supervised classification},
Keywords-Plus = {SUPPORT VECTOR MACHINES; SPACEBORNE THERMAL EMISSION; TRAINING DATA;
   CLASSIFICATION; COMPLEX; EXPLORATION; COVER; IDENTIFICATION;
