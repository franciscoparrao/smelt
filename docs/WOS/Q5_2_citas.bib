   Gong, Peng; Wang, Lin, Poyang Lake Ecol Res Stn Environm \& Hlth, Duchang 332600, Peoples R China.
   Gong, Peng, Joint Ctr Global Change Studies, Beijing 100875, Peoples R China.
   Wang, Lin, Chinese Acad Fishery Sci, Beijing 100141, Peoples R China.},
DOI = {10.1016/j.rse.2014.10.027},
Keywords = {Dynamic cover types; Wetland remote sensing; Object-based image
   analysis; PR China; Extended PCA; Phenology; Change trajectory analysis},
Keywords-Plus = {LAND-USE CHANGE; POYANG LAKE; TIME-SERIES; CHANGE TRAJECTORIES;
   SPATIAL-RESOLUTION; FUNCTIONAL TYPES; WATER INDEX; TM DATA; IMAGERY;
   INUNDATION},
