   Wagner, Paul D.; Narasimhan, Balaji, Indian Inst Technol Madras, Indogerman Ctr Sustainabil, Madras 600036, Tamil Nadu, India.},
DOI = {10.1016/j.jag.2018.08.011},
Keywords = {Sentinel-1; Sentinel-2; Random forest; Multi-sensory; SAR; Land use and
