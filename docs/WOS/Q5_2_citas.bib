DOI = {10.1016/j.rse.2020.112223},
Article-Number = {112223},
Keywords = {Airborne data; Drone; Unmanned aerial system (UAS); Unmanned aerial
   vehicle (UAV); Terrestrial laser scanning; Photogrammetry; Structure
   from motion (SFM); Lidar; Hyperspectral; Machine learning; Digital
