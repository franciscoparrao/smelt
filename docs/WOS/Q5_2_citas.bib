DOI = {10.1016/j.geoderma.2018.05.027},
Keywords = {Gully erosion; Machine learning model; Remote sensing data; Robustness;
   Topographic attribute},
Keywords-Plus = {CATCHMENT NORTHERN CALABRIA; ARTIFICIAL NEURAL-NETWORKS; MACHINE
