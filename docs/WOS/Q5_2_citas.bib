DOI = {10.3390/rs11091123},
Article-Number = {1123},
Keywords = {change detection; deep learning; Tsunami; damage mapping; remote sensing},
Keywords-Plus = {NETWORK},
Author-Email = {jeremie.sublime@isep.fr
   ekaterina.kalinicheva@isep.fr},
Number-of-Cited-References = {33},
Times-Cited = {107},
