   Li, Congcong, Beijing Normal Univ, Coll Global Change \& Earth Syst Sci, Beijing 100875, Peoples R China.
   Liu, Desheng, Ohio State Univ, Dept Geog, Columbus, OH 43210 USA.
   Gong, Peng, Univ Calif Berkeley, Dept Environm Sci Policy \& Management, Berkeley, CA 94720 USA.
   Gong, Peng, Joint Ctr Global Change Studies, Beijing 100875, Peoples R China.},
DOI = {10.1016/j.isprsjprs.2014.03.007},
Keywords = {MODIS time series data; Land cover; Change; Random forest; Markov random
   field; Label adjustment},
Keywords-Plus = {CLASSIFICATION; MODIS; DATABASE},
Author-Email = {penggong@tsinghua.edu.cn},
