   Johnson, Timothy L.; Newell, Richard G., Duke Univ, Nicholas Sch Environm, Durham, NC 27708 USA.
   Malof, Jordan M.; Collins, Leslie M., Duke Univ, Dept Elect \& Comp Engn, Durham, NC 27708 USA.
   Devarajan, Arjun; Zhang, Wuming, Duke Univ, Dept Comp Sci, Durham, NC 27708 USA.},
DOI = {10.1038/sdata.2016.106},
