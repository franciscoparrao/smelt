   Peng, Jiangtao, Hubei Univ, Fac Math \& Stat, Wuhan 430062, Peoples R China.},
DOI = {10.1016/j.jag.2021.102572},
Article-Number = {102572},
Keywords = {Coastal wetlands; Mapping; Hyperspectral remote sensing; Simple and
   effective spatial-spectral method},
Keywords-Plus = {NONLINEAR DIMENSIONALITY REDUCTION; YELLOW-RIVER DELTA; CLASSIFICATION},
