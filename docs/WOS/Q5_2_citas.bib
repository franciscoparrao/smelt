Keywords = {Remote sensing; UAV; Unmanned aerial vehicle; Precision agriculture;
   Smart farming; Visual imagery; Deep learning; Systematic literature
   review},
Keywords-Plus = {RESOLUTION MULTISPECTRAL IMAGERY; HIGH-SPATIAL-RESOLUTION; LEARNING
