   Skakun, Sergii, Univ Maryland, Dept Geog Sci, College Pk, MD 20742 USA.
   Skakun, Sergii, NASA, Goddard Space Flight Ctr, Greenbelt, MD USA.},
DOI = {10.3389/feart.2017.00017},
Article-Number = {17},
Keywords = {Google Earth Engine; big data; classification; optical satellite
   imagery; land cover; land use; image processing},
Keywords-Plus = {EFFICIENCY ASSESSMENT; LANDSAT DATA; REFLECTANCE; FUSION},
