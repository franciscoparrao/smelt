   Romero-Alvarez, Daniel, Univ Kansas, Dept Ecol \& Evolutionary Biol, Lawrence, KS 66045 USA.
   Romero-Alvarez, Daniel, Univ las Amer, Fac Med, OneHlth Res Grp, Quito, Ecuador.},
DOI = {10.1186/s13071-021-05051-3},
