DOI = {10.1016/j.catena.2021.105222},
EarlyAccessDate = {FEB 2021},
Article-Number = {105222},
Keywords = {Soil heavy metal; Hyperspectral; Random forest model (RF); Support
   vector machine (SVM); Three-River Source Region},
Keywords-Plus = {REFLECTANCE SPECTROSCOPY; CLASSIFICATION; CONTAMINATION},
