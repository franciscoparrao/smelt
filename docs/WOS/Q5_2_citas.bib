   Han, Jiwan, Aberystwyth Univ, IBERS, Aberystwyth SY23 3FL, Ceredigion, Wales.},
DOI = {10.1186/s13007-019-0399-7},
Article-Number = {15},
Keywords = {Unmanned aerial vehicle (UAV); Potato; Image analysis; Remote sensing;
   Crop emergence; Random Forest},
Keywords-Plus = {VEGETATION INDEXES; RANDOM FOREST; PLANT-DENSITY; GROWTH-STAGES;
   WATER-STRESS; LOW-ALTITUDE; WEED; SOIL; CLASSIFICATION; TEMPERATURE},
Author-Email = {jinliping@caas.cn
   liujiangang@caas.cn},
Number-of-Cited-References = {42},
