   Dieu Tien Bui, Univ Coll Southeast Norway, Dept Business \& IT, Geog Informat Syst Grp, Gulbringvegen 36, N-3800 Bo I Telemark, Norway.},
DOI = {10.1016/j.scitotenv.2018.01.266},
Keywords = {Flood susceptibility assessment; Machine learning; Alternating Decision
