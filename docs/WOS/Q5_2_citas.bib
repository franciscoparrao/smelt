   Atkinson, Peter M., Queens Univ Belfast, Sch Nat \& Built Environm, Belfast BT7 1NN, Antrim, North Ireland.
   Atkinson, Peter M., Univ Southampton, Geog \& Environm Sci, Southampton SO17 1BJ, Hants, England.
   Atkinson, Peter M., Chinese Acad Sci, Inst Geog Sci \& Nat Resources Res, 11A Datun Rd, Beijing 100101, Peoples R China.},
DOI = {10.1016/j.rse.2019.111593},
Article-Number = {111593},
Keywords = {Multi-scale deep learning; Optimal scale selection; Convolutional neural
   network; Joint classification; Hierarchical representations},
Keywords-Plus = {NEURAL-NETWORKS; SCENE CLASSIFICATION; TEXTURE; GEOBIA; CNN},
Author-Email = {c.zhang9@lancaster.ac.uk
   pma@lancaster.ac.uk},
