}

@article{ WOS:000519656700014,
Author = {Boroughani, Mahdi and Pourhashemi, Sima and Hashemi, Hossein and Salehi,
   Mahdi and Amirahmadi, Abolghasem and Asadi, Mohammad Ali Zangane and
   Berndtsson, Ronny},
Title = {Application of remote sensing techniques and machine learning algorithms
   in dust source detection and dust source susceptibility mapping},
Journal = {ECOLOGICAL INFORMATICS},
Year = {2020},
Volume = {56},
Month = {MAR},
Abstract = {The aim of this research was to develop a method to produce a Dust
   Source Susceptibility Map (DSSM). For this purpose, we applied remote
   sensing and statistical-based machine learning algorithms for
   experimental dust storm studies in the Khorasan Razavi Province, in
   north-eastern Iran. We identified dust sources in the study area using
   MODIS satellite images during the 2005-2016 period. For dust source
   identification, four indices encompassing BTD3132, BTD2931, NDDI, and D
   variable for 23 MODIS satellite images were calculated. As a result, 65
   dust source points were identified, which were categorized into dust
   source data points for training and validation of the machine learning
   algorithms. Three statistical-based machine learning algorithms were
   used including Weights of Evidence (WOE), Frequency Ratio (FR), and
   Random Forest (RF) to produce DSSM for the study region. We used land
   use, lithology, slope, soil, geomorphology, NDVI (Normalized Difference
   Vegetation Index), and distance from river as conditioning variables in
   the modelling. To check the performance of the models, we applied the
   Area Under the Curve (AUC) of the Receiver Operating Characteristic
   (ROC). As for the AUC success rate (training), the FR and WOE algorithms
   resulted in 82 and 83\% accuracy, respectively, while the RF algorithm
   resulted in 91\% accuracy. As for the AUC predictive rate (validation),
   the accuracy of all three models, FR, WOE, and RF, were 80, 81, and
   88\%, respectively. Although all three algorithms produced acceptable
   susceptibility maps of dust sources, the results indicated better
   performance of the RF algorithm.},
Type = {Article},
Affiliation = {Boroughani, M (Corresponding Author), Hak Sabzevari Univ, Res Ctr Geosci \& Social Studies, Sabzevar, Iran.
   Boroughani, Mahdi, Hak Sabzevari Univ, Res Ctr Geosci \& Social Studies, Sabzevar, Iran.
   Pourhashemi, Sima; Amirahmadi, Abolghasem; Asadi, Mohammad Ali Zangane, Hakim Sabzevari Univ, Dept Geog, Sabzevar, Iran.
   Hashemi, Hossein; Berndtsson, Ronny, Lund Univ, Dept Water Resources Engn, Lund, Sweden.
   Boroughani, Mahdi; Pourhashemi, Sima; Hashemi, Hossein; Berndtsson, Ronny, Lund Univ, Ctr Middle Eastern Studies, Lund, Sweden.
   Salehi, Mahdi, Univ Neyshabur, Dept Math \& Stat, Neyshabur, Iran.},
DOI = {10.1016/j.ecoinf.2020.101059},
Article-Number = {101059},
Keywords = {Dust source; Frequency ratio (FR); Weights of evidence (WOE); Random
   Forest (RF); Remote sensing; Iran},
Keywords-Plus = {LOGISTIC-REGRESSION; RANDOM FOREST; OF-EVIDENCE; FREQUENCY RATIO; DESERT
   DUST; 3 GORGES; STORM; WEIGHT; GIS; IDENTIFICATION},
