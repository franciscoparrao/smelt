@article{ WOS:000334661600004,
Author = {Rodriguez-Galiano, Victor F. and Chica-Rivas, Mario},
Title = {Evaluation of different machine learning methods for land cover mapping
   of a Mediterranean area using multi-seasonal Landsat images and Digital
   Terrain Models},
Journal = {INTERNATIONAL JOURNAL OF DIGITAL EARTH},
Year = {2014},
