   Ma, Xiaoxue, Nanjing Second Normal Univ, Urban \& Resources Environm Coll, Nanjing 210013, Jiangsu, Peoples R China.},
DOI = {10.1016/j.isprsjprs.2017.06.001},
Keywords = {OBIA; GEOBIA; Meta-analysis; Supervised object-based classification;
   Land-cover mapping; Review},
Keywords-Plus = {HIGH-SPATIAL-RESOLUTION; MACHINE-LEARNING ALGORITHMS; REMOTE-SENSING
