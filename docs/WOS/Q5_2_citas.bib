   Burke, Marshall, Natl Bur Econ Res, Cambridge, MA 02138 USA.
   Ermon, Stefano, Stanford Univ, Dept Comp Sci, Stanford, CA 94305 USA.},
DOI = {10.1126/science.abe8628},
