@article{ WOS:001230135700002,
Author = {Foumani, Navid Mohammadi and Miller, Lynn and Tan, Chang Wei and Webb,
   Geoffrey I. and Forestier, Germain and Salehi, Mahsa},
Title = {Deep Learning for Time Series Classification and Extrinsic Regression: A
   Current Survey},
Journal = {ACM COMPUTING SURVEYS},
Year = {2024},
Volume = {56},
Number = {9},
Month = {SEP},
Abstract = {Time Series Classification and Extrinsic Regression are important and
   challenging machine learning tasks. Deep learning has revolutionized
   natural language processing and computer vision and holds great promise
   in other fields such as time series analysis where the relevant features
   must often be abstracted from the raw data but are not known a priori.
   This article surveys the current state of the art in the fast-moving
   field of deep learning for time series classification and extrinsic
   regression. We review different network architectures and training
   methods used for these tasks and discuss the challenges and
   opportunities when applying deep learning to time series data. We also
   summarize two critical applications of time series classification and
   extrinsic regression, human activity recognition and satellite earth
   observation.},
