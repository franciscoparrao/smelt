DOI = {10.1109/TGRS.2015.2409195},
Keywords = {Classification; extended multiattribute profiles (EMAPs); hyperspectral
   data; random subspace (RS)},
Keywords-Plus = {SPECTRAL-SPATIAL CLASSIFICATION; EXTREME LEARNING-MACHINE;
