   Ostapowicz, Katarzyna, Univ Calif Berkeley, Dept Environm Sci Policy \& Management, 326 Mulford Hall, Berkeley, CA 94720 USA.},
DOI = {10.1016/j.rse.2020.112103},
Article-Number = {112103},
Keywords = {Classification; Ensemble; Random forest; Support vector machines;
   Extreme gradient boosting; Mountains; Vegetation},
Keywords-Plus = {TIME-SERIES; PIXEL CLASSIFICATION; COVER CLASSIFICATION; VEGETATION;
   PHENOLOGY; ACCURACY; SELECTION; AREA; INFORMATION; PERFORMANCE},
Author-Email = {ewa2.grabska@doctoral.uj.edu.pl},
Number-of-Cited-References = {100},
