   Li, Yuechen; Ma, Mingguo, Southwest Univ, Sch Geog Sci, Chongqing Engn Res Ctr Remote Sensing Big Data Ap, Chongqing 400715, Peoples R China.},
DOI = {10.3390/su13020503},
Article-Number = {503},
