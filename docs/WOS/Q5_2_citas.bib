   Chen, Shuangling, Minist Nat Resources, Inst Oceanog 2, State Key Lab Satellite Ocean Environm Dynam, Hangzhou 310012, Zhejiang, Peoples R China.},
DOI = {10.1016/j.rse.2019.04.019},
Keywords = {Surface pCO(2); SST; SSS; Chlorophyll; Kd; Satellite remote sensing;
   Gulf of Mexico},
Keywords-Plus = {GULF-OF-MEXICO; SEA CO2 FLUXES; MISSISSIPPI RIVER PLUME; SELF-ORGANIZING
   MAP; CARBON-DIOXIDE; NORTH PACIFIC; IN-SITU; INTERANNUAL VARIABILITY;
   TEMPORAL VARIABILITY; PARTIAL-PRESSURE},
