   Zeng, Wei, Shenzhen Inst Adv Technol, Shenzhen VisuCA Key Lab, Shenzhen, Peoples R China.
   Zhong, Teng, Univ Hong Kong, Dept Urban Planning \& Design, Hong Kong, Peoples R China.},
DOI = {10.1016/j.landurbplan.2018.08.028},
Article-Number = {103434},
Keywords = {Visible greenery; Google Street View; Space syntax; Human-scale;
   Accessible greenery; Machine learning},
Keywords-Plus = {TREE COVER; NEIGHBORHOOD; VIEW; ACCESSIBILITY; PERCEPTION; NETWORK;
   IMAGERY; SYNTAX},
Author-Email = {yye@tongji.edu.cn
