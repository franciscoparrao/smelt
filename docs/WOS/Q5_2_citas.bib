DOI = {10.3390/rs11010043},
Article-Number = {43},
Keywords = {wetland; Google Earth Engine; Sentinel-1; Sentinel-2; random forest;
   cloud computing; geo-big data},
Keywords-Plus = {RANDOM FOREST CLASSIFIER; REMOTE-SENSING DATA; WATER INDEX NDWI; SAR
